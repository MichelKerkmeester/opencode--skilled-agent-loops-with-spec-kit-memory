iority'],\n32:   priority: ['tier', 'importance'],\n33:   memory: ['context', 'knowledge'],\n34:   memories: ['memory', 'context', 'knowledge'],\n35:   retrieval: ['search', 'query'],\n36:   search: ['retrieval', 'query'],\n37:   query: ['search', 'retrieval'],\n38: };\n39: \n40: function simpleStem(word: string): string {\n41:   let stem = word.toLowerCase();\n42:   let suffixRemoved = false;\n43: \n44:   if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n45:   else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n46:   else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n47:   else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n48:   else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n49:   else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n50: \n51:   if (suffixRemoved && stem.length >= 3) {\n52:     const last = stem[stem.length - 1];\n53:     if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n54:       stem = stem.slice(0, -1);\n55:     }\n56:   }\n57: \n58:   return stem;\n59: }\n60: \n61: function splitLexicalFragments(text: string): string[] {\n62:   if (!text || typeof text !== 'string') return [];\n63: \n64:   return text\n65:     .toLowerCase()\n66:     .replace(/[^a-z0-9\\s-_]/g, ' ')\n67:     .split(/\\s+/)\n68:     .map(t => t.trim())\n69:     .filter(Boolean);\n70: }\n71: \n72: function tokenize(text: string): string[] {\n73:   return splitLexicalFragments(text)\n74:     .filter(t => t.length >= 2 && !STOP_WORDS.has(t))\n75:     .map(simpleStem);\n76: }\n77: \n78: function sanitizeQueryTokens(query: string): string[] {\n79:   if (query.length > 2000) {\n80:     query = query.substring(0, 2000);\n81:   }\n82: \n83:   let sanitized = query\n84:     .replace(/\\bNEAR\\b/gi, '')\n85:     .replace(/\\bNOT\\b/gi, '')\n86:     .replace(/\\bAND\\b/gi, '')\n87:     .replace(/\\bOR\\b/gi, '');\n88: \n89:   sanitized = sanitized.replace(/\\/\\d+/g, ' ');\n90:   sanitized = sanitized\n\n(Showing lines 1-90 of 147. Use offset=91 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Lexical Normalizer\n// ───────────────────────────────────────────────────────────────\n\ninterface NormalizedLexicalQueryTokens {\n  fts: string;\n  bm25: string[];\n  synonyms: string[];\n}\n\nconst STOP_WORDS = new Set([\n  'the', 'a', 'an', 'and', 'or', 'but', 'in', 'on', 'at', 'to', 'for',\n  'of', 'with', 'by', 'from', 'is', 'it', 'as', 'was', 'are', 'be',\n  'has', 'had', 'have', 'been', 'were', 'will', 'would', 'could', 'should',\n  'may', 'might', 'can', 'this', 'that', 'these', 'those', 'not', 'no',\n  'do', 'does', 'did', 'so', 'if', 'then', 'than', 'too', 'very',\n]);\n\nconst LEXICAL_QUERY_SYNONYMS: Record<string, string[]> = {\n  ephemeral: ['temporary', 'short-term', 'transient'],","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/lexical-normalizer.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Lexical Normalizer\n// ───────────────────────────────────────────────────────────────\n\ninterface NormalizedLexicalQueryTokens {\n  fts: string;\n  bm25: string[];\n  synonyms: string[];\n}\n\nconst STOP_WORDS = new Set([\n  'the', 'a', 'an', 'and', 'or', 'but', 'in', 'on', 'at', 'to', 'for',\n  'of', 'with', 'by', 'from', 'is', 'it', 'as', 'was', 'are', 'be',\n  'has', 'had', 'have', 'been', 'were', 'will', 'would', 'could', 'should',\n  'may', 'might', 'can', 'this', 'that', 'these', 'those', 'not', 'no',\n  'do', 'does', 'did', 'so', 'if', 'then', 'than', 'too', 'very',\n]);\n\nconst LEXICAL_QUERY_SYNONYMS: Record<string, string[]> = {\n  ephemeral: ['temporary', 'short-term', 'transient'],\n  temporary: ['ephemeral', 'short-term', 'transient'],\n  transient: ['ephemeral', 'temporary', 'short-term'],\n  short: ['ephemeral', 'temporary'],\n  term: ['ephemeral', 'temporary'],\n  constitutional: ['always-surface', 'pinned', 'critical'],\n  always: ['constitutional', 'pinned', 'critical'],\n  surface: ['constitutional', 'pinned', 'critical'],\n  pinned: ['constitutional', 'always-surface'],\n  critical: ['constitutional', 'always-surface'],\n  tier: ['importance', 'priority'],\n  importance: ['tier', 'priority'],\n  priority: ['tier', 'importance'],\n  memory: ['context', 'knowledge'],\n  memories: ['memory', 'context', 'knowledge'],\n  retrieval: ['search', 'query'],\n  search: ['retrieval', 'query'],\n  query: ['search', 'retrieval'],\n};\n\nfunction simpleStem(word: string): string {\n  let stem = word.toLowerCase();\n  let suffixRemoved = false;\n\n  if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n  else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n  else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n\n  if (suffixRemoved && stem.length >= 3) {\n    const last = stem[stem.length - 1];\n    if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n      stem = stem.slice(0, -1);\n    }\n  }\n\n  return stem;\n}\n\nfunction splitLexicalFragments(text: string): string[] {\n  if (!text || typeof text !== 'string') return [];\n\n  return text\n    .toLowerCase()\n    .replace(/[^a-z0-9\\s-_]/g, ' ')\n    .split(/\\s+/)\n    .map(t => t.trim())\n    .filter(Boolean);\n}\n\nfunction tokenize(text: string): string[] {\n  return splitLexicalFragments(text)\n    .filter(t => t.length >= 2 && !STOP_WORDS.has(t))\n    .map(simpleStem);\n}\n\nfunction sanitizeQueryTokens(query: string): string[] {\n  if (query.length > 2000) {\n    query = query.substring(0, 2000);\n  }\n\n  let sanitized = query\n    .replace(/\\bNEAR\\b/gi, '')\n    .replace(/\\bNOT\\b/gi, '')\n    .replace(/\\bAND\\b/gi, '')\n    .replace(/\\bOR\\b/gi, '');\n\n  sanitized = sanitized.replace(/\\/\\d+/g, ' ');\n  sanitized = sanitized","lineStart":1,"lineEnd":90,"totalLines":147,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/lexical-normalizer.ts","time":{"start":1781151935404,"end":1781151935407}},"metadata":{"openai":{"itemId":"fc_08399fe21eca3e1a016a2a38be4ebc81918fd61ad87f60c5de"}},"id":"prt_eb4eda75e001Xm2aeyC2UGHB9C","sessionID":"ses_14b140814ffe4N8PH7Vn6Su76Z","messageID":"msg_eb4eda0c3001sfFTONm8HA1W4b"}}
