fast_write_pipeline,\n        build_stm_write_pipeline,\n        build_strong_write_pipeline,\n    )\n    from core_api.pipeline.context import PipelineContext\n    from core_api.services.organization_settings import resolve_config\n\n    # STM branch: bypass tenant config resolution and LTM pipelines entirely\n    if data.write_mode == \"stm\":","lineStart":180,"lineEnd":249,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728550642,"end":1780728550680}},"metadata":{"openai":{"itemId":"fc_007b3c3b301f65ca016a23c2e682c08191803d9678a7722545"}},"id":"prt_e9bb154c9001fFrY4BjKZ6Nu4l","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9bb1346d0010C9B4KzJm424xV"}}
