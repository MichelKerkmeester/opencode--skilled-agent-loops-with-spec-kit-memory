0\":0,\"P1\":2,\"P2\":0},\"findingsNew\":[\"SOL-A-I002-P1-001\",\"SOL-A-I002-P1-002\"],\"findingDetails\":[{\"id\":\"SOL-A-I002-P1-001\",\"severity\":\"P1\",\"category\":\"security\",\"title\":\"Hydration has no contracted filesystem-containment boundary\",\"file\":\".opencode/specs/sk-design/011-sk-design-styles-utilization/004-retrieval-substrate/spec.md:103-112\",\"evidence\":\"The planned manifest and hydration CLI has generation guards but no canonical-root, traversal, or symlink acceptance criterion, so a conforming implementation may read outside styles/.\",\"findingClass\":\"class-of-bug\",\"scopeProof\":\"Scoped exact search across phase 004/006/007/010 planning artifacts found no filesystem-containment control; phase 004 is the shared filesystem producer.\",\"affectedSurfaceHints\":[\"manifest generator\",\"hydrate CLI\",\"source-scan fallback\",\"STUDY hydration\"],\"content_hash\":\"0ceb90d3104e2eaa2a0bd5f53ba022816036432ea983b4853e65e39ca85095b5\",\"claimAdjudication\":{\"type\":\"claim-adjudication\",\"findingId\":\"SOL-A-I002-P1-001\",\"claim\":\"The phase-004 contract permits hydration outside the styles root because no containment or symlink invariant is specified.\",\"evidenceRefs\":[\".opencode/specs/sk-design/011-sk-design-styles-utilization/004-retrieval-substrate/spec.md:103-112\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/004-retrieval-substrate/spec.md:124-136\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/004-retrieval-substrate/spec.md:188-200\"],\"counterevidenceSought\":\"Searched all four assigned phase planning trees for realpath, canonicalization, traversal, escape, confinement, and symlink controls; reviewed generation and permitted-artifact language.\",\"alternativeExplanation\":\"Manifest-derived fixed child paths or independent implementation containment may mitigate the risk, but neither is required or tested.\",\"finalSeverity\":\"P1\",\"confidence\":0.9,\"downgradeTrigger\":\"Downgrade to P2 after canonical root containment, explicit symlink policy, and negative traversal fixtures become binding acceptance criteria.\"}},{\"id\":\"SOL-A-I002-P1-002\",\"severity\":\"P1\",\"category\":\"security\",\"title\":\"The STUDY injection envelope records a boundary but does not neutralize untrusted instructions\",\"file\":\".opencode/specs/sk-design/011-sk-design-styles-utilization/006-md-generator-study-exemplars/spec.md:104-117\",\"evidence\":\"The planned transformer injects corpus-derived observations but specifies only an auditable envelope and literal/span leak gates, not instruction rejection or a data-only prompt boundary.\",\"findingClass\":\"cross-consumer\",\"scopeProof\":\"Scoped search found envelope references across phase-006 artifacts but no behavioral prompt-injection criterion; phase-007 authority ordering does not sanitize prompt content.\",\"affectedSurfaceHints\":[\"study transformer\",\"STUDY prompt block\",\"adversarial fixtures\",\"runGuided retry\"],\"content_hash\":\"5d2be1beddf22032bde4e59d4bb0d4b73c7f3a54d1718ede78e6988f0c7918aa\",\"claimAdjudication\":{\"type\":\"claim-adjudication\",\"findingId\":\"SOL-A-I002-P1-002\",\"claim\":\"Corpus-borne instructions can influence generated prose while all planned phase-006 controls pass because the leak gate only tests copied values and spans.\",\"evidenceRefs\":[\".opencode/specs/sk-design/011-sk-design-styles-utilization/006-md-generator-study-exemplars/spec.md:73-79\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/006-md-generator-study-exemplars/spec.md:104-117\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/006-md-generator-study-exemplars/spec.md:165-187\"],\"counterevidenceSought\":\"Searched assigned phase trees for prompt injection, untrusted content, instruction rejection, sanitization, and boundary controls; reviewed de-literalization, locked FACTS, authority order, leak gates, and retry.\",\"alternativeExplanation\":\"A strict transformer could incidentally remove imperative text, but that behavior is neither specified nor tested.\",\"finalSeverity\":\"P1\",\"confidence\":0.88,\"downgradeTrigger\":\"Downgrade to P2 after a closed data-only observation schema, instruction rejection, and behavioral injection fixtures become binding.\"}}],\"findingsRefined\":[\"SOL-A-I001-P1-001\"],\"findingRefinements\":[{\"findingId\":\"SOL-A-I001-P1-001\",\"type\":\"claim-adjudication\",\"claim\":\"Canonical packet surfaces give obsolete next actions and completion percentages for already-completed research phases.\",\"evidenceRefs\":[\".opencode/specs/sk-design/011-sk-design-styles-utilization/spec.md:13-25\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/spec.md:46\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/002-md-generator-upgrade/spec.md:13-30\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/002-md-generator-upgrade/implementation-summary.md:10-30\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/003-global-modes-utilization/spec.md:13-30\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/003-global-modes-utilization/implementation-summary.md:10-31\"],\"counterevidenceSought\":\"Iteration 001 checked status tables, implementation summaries, parent phase map, planned child lifecycle fields, and graph metadata.\",\"alternativeExplanation\":\"Resume precedence contains some runtime impact but does not remove contradictory canonical metadata.\",\"finalSeverity\":\"P1\",\"confidence\":0.92,\"downgradeTrigger\":\"Downgrade only if all validators and resume consumers exclude these spec continuity fields.\"}],\"traceabilityChecks\":[{\"protocol\":\"security_contract_phase_004\",\"status\":\"partial\",\"notes\":\"Generation and rights controls exist; filesystem containment is absent.\"},{\"protocol\":\"security_contract_phase_006\",\"status\":\"partial\",\"notes\":\"Anti-copy controls exist; behavioral prompt-injection resistance is absent.\"},{\"protocol\":\"authority_