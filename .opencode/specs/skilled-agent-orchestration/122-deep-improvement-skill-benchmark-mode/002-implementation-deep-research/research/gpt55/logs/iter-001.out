   206	function hasExplicitWorkflowSignal(contributions: readonly LaneContribution[], skillId: string): boolean {
   207	  const explicit = contributions.find((contribution) => contribution.lane === 'explicit_author');
   208	  if (!explicit || explicit.rawScore < 0.55) return false;
