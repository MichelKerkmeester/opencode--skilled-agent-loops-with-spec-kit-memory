{"type":"tool_use","timestamp":1781764124942,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_IT6TibXsEsnrzWjmzvEwFw97","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1140,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1140: // 11. HYBRID SEARCH\n1141: \n1142: /**\n1143:  * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n1144:  * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n1145:  * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n1146:  * Retained as internal fallback only.\n1147:  */\n1148: async function hybridSearch(\n1149:   query: string,\n1150:   embedding: Float32Array | number[] | null,\n1151:   options: HybridSearchOptions = {}\n1152: ): Promise<HybridSearchResult[]> {\n1153:   const {\n1154:     limit = DEFAULT_LIMIT,\n1155:     specFolder,\n1156:     minSimilarity = 0,\n1157:     useBm25 = isBm25Enabled(),\n1158:     useFts = true,\n1159:     useVector = true,\n1160:     useGraph = true,\n1161:     includeArchived = false,\n1162:   } = options;\n1163: \n1164:   const results: HybridSearchResult[] = [];\n1165: \n1166:   // Vector search\n1167:   if (useVector && embedding && vectorSearchFn) {\n1168:     try {\n1169:       const vectorResults = vectorSearchFn(embedding, {\n1170:         limit,\n1171:         specFolder,\n1172:         minSimilarity,\n1173:         includeConstitutional: false, // Handler manages constitutional separately\n1174:         includeArchived,\n1175:       });\n1176:       for (const r of vectorResults) {\n1177:         results.push({\n1178:           ...r,\n1179:           id: r.id as number,\n1180:           score: (r.similarity as number) || 0,\n1181:           source: 'vector',\n1182:         });\n1183:       }\n1184:     } catch (error: unknown) {\n1185:       const msg = error instanceof Error ? error.message : String(error);\n1186:       console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n1187:     }\n1188:   }\n1189: \n1190:   // FTS search\n1191:   if (useFts) {\n1192:     const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n1193:     results.push(...ftsResults);\n1194:   }\n1195: \n1196:   // BM25 search\n1197:   if (useBm25) {\n1198:     const bm25Results = bm25Search(query, { limit, specFolder });\n1199:     results.push(...bm25Results);\n1200:   }\n1201: \n1202:   // Graph search\n1203:   if (useGraph && graphSearchFn) {\n1204:     try {\n1205:       graphMetrics.totalQueries++;\n1206:       const graphResults = graphSearchFn(query, { limit, specFolder });\n1207:       for (const r of graphResults) {\n1208:         results.push({\n1209:           ...r,\n1210:           id: r.id as number | string,\n1211:           score: (r.score as number) || 0,\n1212:           source: 'graph',\n1213:         });\n1214:       }\n1215:       if (graphResults.length > 0) {\n1216:         graphMetrics.graphHits++;\n1217:         graphMetrics.graphResultCount += graphResults.length;\n1218:       }\n1219:     } catch (error: unknown) {\n1220:       const msg = error instanceof Error ? error.message : String(error);\n1221:       console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n1222:     }\n1223:   }\n1224: \n1225:   // Normalize scores per source before merging so one method's raw scale\n1226:   // Does not dominate others during final ranking.\n1227:   const bySource = new Map<string, HybridSearchResult[]>();\n1228:   for (const r of results) {\n1229:     const src = r.source || 'unknown';\n1230:     if (!bySource.has(src)) bySource.set(src, []);\n1231:     bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n1232:   }\n1233: \n1234:   const normalized: HybridSearchResult[] = [];\n1235:   for (const [, group] of bySource) {\n1236:     if (group.length === 0) continue;\n1237:     const scores = group.map(r => r.score);\n1238:     let min = Infinity;\n1239:     let max = -Infinity;\n1240:     for (const s of scores) {\n1241:       if (s < min) min = s;\n1242:       if (s > max) max = s;\n1243:     }\n1244:     const range = max - min;\n1245:     for (const r of group) {\n1246:       normalized.push({\n1247:         ...r,\n1248:         score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n1249:       });\n1250:     }\n1251:   }\n1252: \n1253:   // Deduplicate by ID (keep highest normalized score)\n1254:   // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n1255:   // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n1256:   // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n1257:   // Field and downstream consumers would need to be updated accordingly.\n1258:   const deduped = new Map<string, HybridSearchResult>();\n1259:   for (const r of normalized) {\n1260:     const canonicalId = canonicalResultId(r.id);\n1261:     const existing = deduped.get(canonicalId);\n1262:     if (!existing || r.score > existing.score) {\n1263:       deduped.set(canonicalId, r);\n1264:     }\n1265:   }\n1266: \n1267:   return Array.from(deduped.values())\n1268:     .sort((a, b) => b.score - a.score)\n1269:     .slice(0, limit);\n1270: }\n1271: \n1272: /**\n1273:  * Enhanced hybrid search with RRF fusion.\n1274:  * All search channels use synchronous better-sqlite3; sequential execution\n1275:  * is correct — Promise.all would add overhead without achieving parallelism.\n1276:  */\n1277: async function hybridSearchEnhanced(\n1278:   query: string,\n1279:   embedding: Float32Array | number[] | null,\n1280:   options: HybridSearchOptions = {}\n1281: ): Promise<HybridSearchResult[]> {\n1282:   const execution = await collectAndFuseHybridResults(query, embedding, options);\n1283:   if (execution) {\n1284:     if (options.stopAfterFusion) {\n1285:       return applyResultLimit(execution.fusedResults, options.limit);\n1286:     }\n1287: \n1288:     return enrichFusedResults(query, execution, options);\n1289:   }\n1290: \n1291:   return hybridSearch(query, embedding, options);\n1292: }\n1293: \n1294: async function collectAndFuseHybridResults(\n1295:   query: string,\n1296:   embedding: Float32Array | number[] | null,\n1297:   options: HybridSearchOptions = {}\n1298: ): Promise<HybridFusionExecution | null> {\n1299:   try {\n1300:     const evaluationMode = options.evaluationMode === true;\n1301:     const lists: HybridFusionExecution['lists'] = [];\n1302: \n1303:     // Pipeline metadata collector (populated by flag-gated stages)\n1304:     const s3meta: Sprint3PipelineMeta = {};\n1305: \n1306:     // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n1307:     // When enabled, classifies query complexity and restricts channels to a\n1308:     // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n1309:     const routeResult = routeQuery(query, options.triggerPhrases);\n1310:     const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n1311:     const activeChannels = options.forceAllChannels\n1312:       ? new Set<ChannelName>(allPossibleChannels)\n1313:       : new Set<ChannelName>(routeResult.channels);\n1314: \n1315:     // Respect explicit caller channel disables across both the primary route and\n1316:     // every fallback tier. useGraph=false also disables the dependent degree lane.\n1317:     const allowedChannels = getAllowedChannels(options);\n1318:     for (const channel of allPossibleChannels) {\n1319:       if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n\n(Showing lines 1140-1319 of 2972. Use offset=1320 to continue.)\n</content>","metadata":{"preview":"// 11. HYBRID SEARCH\n\n/**\n * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n * Retained as internal fallback only.\n */\nasync function hybridSearch(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"// 11. HYBRID SEARCH\n\n/**\n * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n * Retained as internal fallback only.\n */\nasync function hybridSearch(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,\n    useGraph = true,\n    includeArchived = false,\n  } = options;\n\n  const results: HybridSearchResult[] = [];\n\n  // Vector search\n  if (useVector && embedding && vectorSearchFn) {\n    try {\n      const vectorResults = vectorSearchFn(embedding, {\n        limit,\n        specFolder,\n        minSimilarity,\n        includeConstitutional: false, // Handler manages constitutional separately\n        includeArchived,\n      });\n      for (const r of vectorResults) {\n        results.push({\n          ...r,\n          id: r.id as number,\n          score: (r.similarity as number) || 0,\n          source: 'vector',\n        });\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n    }\n  }\n\n  // FTS search\n  if (useFts) {\n    const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n    results.push(...ftsResults);\n  }\n\n  // BM25 search\n  if (useBm25) {\n    const bm25Results = bm25Search(query, { limit, specFolder });\n    results.push(...bm25Results);\n  }\n\n  // Graph search\n  if (useGraph && graphSearchFn) {\n    try {\n      graphMetrics.totalQueries++;\n      const graphResults = graphSearchFn(query, { limit, specFolder });\n      for (const r of graphResults) {\n        results.push({\n          ...r,\n          id: r.id as number | string,\n          score: (r.score as number) || 0,\n          source: 'graph',\n        });\n      }\n      if (graphResults.length > 0) {\n        graphMetrics.graphHits++;\n        graphMetrics.graphResultCount += graphResults.length;\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n    }\n  }\n\n  // Normalize scores per source before merging so one method's raw scale\n  // Does not dominate others during final ranking.\n  const bySource = new Map<string, HybridSearchResult[]>();\n  for (const r of results) {\n    const src = r.source || 'unknown';\n    if (!bySource.has(src)) bySource.set(src, []);\n    bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n  }\n\n  const normalized: HybridSearchResult[] = [];\n  for (const [, group] of bySource) {\n    if (group.length === 0) continue;\n    const scores = group.map(r => r.score);\n    let min = Infinity;\n    let max = -Infinity;\n    for (const s of scores) {\n      if (s < min) min = s;\n      if (s > max) max = s;\n    }\n    const range = max - min;\n    for (const r of group) {\n      normalized.push({\n        ...r,\n        score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n      });\n    }\n  }\n\n  // Deduplicate by ID (keep highest normalized score)\n  // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n  // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n  // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n  // Field and downstream consumers would need to be updated accordingly.\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const r of normalized) {\n    const canonicalId = canonicalResultId(r.id);\n    const existing = deduped.get(canonicalId);\n    if (!existing || r.score > existing.score) {\n      deduped.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(deduped.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, limit);\n}\n\n/**\n * Enhanced hybrid search with RRF fusion.\n * All search channels use synchronous better-sqlite3; sequential execution\n * is correct — Promise.all would add overhead without achieving parallelism.\n */\nasync function hybridSearchEnhanced(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const execution = await collectAndFuseHybridResults(query, embedding, options);\n  if (execution) {\n    if (options.stopAfterFusion) {\n      return applyResultLimit(execution.fusedResults, options.limit);\n    }\n\n    return enrichFusedResults(query, execution, options);\n  }\n\n  return hybridSearch(query, embedding, options);\n}\n\nasync function collectAndFuseHybridResults(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridFusionExecution | null> {\n  try {\n    const evaluationMode = options.evaluationMode === true;\n    const lists: HybridFusionExecution['lists'] = [];\n\n    // Pipeline metadata collector (populated by flag-gated stages)\n    const s3meta: Sprint3PipelineMeta = {};\n\n    // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n    // When enabled, classifies query complexity and restricts channels to a\n    // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n    const routeResult = routeQuery(query, options.triggerPhrases);\n    const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n    const activeChannels = options.forceAllChannels\n      ? new Set<ChannelName>(allPossibleChannels)\n      : new Set<ChannelName>(routeResult.channels);\n\n    // Respect explicit caller channel disables across both the primary route and\n    // every fallback tier. useGraph=false also disables the dependent degree lane.\n    const allowedChannels = getAllowedChannels(options);\n    for (const channel of allPossibleChannels) {\n      if (!allowedChannels.has(channel)) activeChannels.delete(channel);","lineStart":1140,"lineEnd":1319,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781764124932,"end":1781764124941}},"metadata":{"openai":{"itemId":"fc_09ce19760b694a7c016a33901cba208191a828d5feb3bdcb91"}},"id":"prt_ed96af0a6001gP34tZeBiisZaN","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ab68d001yXE4gNbuKK33KX"}}
{"type":"tool_use","timestamp":1781764125028,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_DoQxWMJYn4rzCVvmtz9s2RzX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage1 Candidate Gen\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-stage retrieval pipeline architecture\n5: //\n6: // Responsibility: Execute search channels and collect raw candidate results.\n7: // This stage avoids downstream fusion/reranking, but may apply temporal\n8: // Contiguity to raw vector-channel hits before later pipeline stages.\n9: // Results are collected from the appropriate search channel based on search type.\n10: //\n11: // Search channels handled:\n12: //   - multi-concept: Generate per-concept embeddings, run multiConceptSearch\n13: //   - hybrid (deep mode): Query expansion + multi-variant hybrid search + dedup\n14: // hybrid: Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n15: // Suppressed when classifies query as \"simple\" (mutual exclusion)\n16: //   - hybrid: collectRawCandidates → falls back to vector on failure\n17: //   - vector: Direct vectorSearch\n18: //\n19: // Post-channel operations:\n20: //   - Constitutional memory injection (if not already present)\n21: //   - Quality score filtering\n22: //   - Tier and contextType filtering\n23: //\n24: // I/O CONTRACT:\n25: // Input:  Stage1Input { config: PipelineConfig }\n26: // Output: Stage1Output { candidates: PipelineRow[], metadata }\n27: // Key invariants:\n28: //     - candidates contains raw channel scores; vector hits may include an\n29: //       optional temporal-contiguity boost applied before downstream fusion\n30: //     - Constitutional rows are always present when includeConstitutional=true and no tier filter\n31: //     - All rows pass qualityThreshold (if set) and tier/contextType filters\n32: // Side effects:\n33: //     - Generates query embeddings via the embeddings provider (external call)\n34: //     - Reads from the vector index and FTS5 / BM25 index (DB reads only)\n35: //\n36: import type { Stage1Input, Stage1Output, PipelineRow } from './types.js';\n37: import { resolveEffectiveScore } from './types.js';\n38: import * as vectorIndex from '../vector-index.js';\n39: import * as hybridSearch from '../hybrid-search.js';\n40: import { vectorSearchWithContiguity } from '../../cognitive/temporal-contiguity.js';\n41: import { isMultiQueryEnabled, isEmbeddingExpansionEnabled, isMemorySummariesEnabled, isQueryDecompositionEnabled, isGraphConceptRoutingEnabled, isLlmReformulationEnabled, isHyDEEnabled, isQuerySurrogatesEnabled, isTemporalContiguityEnabled, isQueryConceptExpansionEnabled } from '../search-flags.js';\n42: import { expandQuery } from '../query-expander.js';\n43: import { expandQueryWithEmbeddings, isExpansionActive } from '../embedding-expansion.js';\n44: import { querySummaryEmbeddings, checkScaleGate } from '../memory-summaries.js';\n45: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n46: import { requireDb } from '../../../utils/db-helpers.js';\n47: import { filterRowsByScope } from '../../governance/scope-governance.js';\n48: import { withTimeout } from '../../errors/core.js';\n49: import { GRAPH_METADATA_MIGRATED_QUALITY_FLAG } from '../../graph/graph-metadata-schema.js';\n50: import { computeBackfillQualityScore } from '../../validation/save-quality-gate.js';\n51: import {\n52:   isMultiFacet,\n53:   decompose,\n54:   mergeByFacetCoverage as mergeFacetCoveragePools,\n55:   MAX_FACETS,\n56: } from '../query-decomposer.js';\n57: import { routeQueryConcepts, nounPhrases, getConceptExpansionTerms } from '../entity-linker.js';\n58: import { cheapSeedRetrieve, llm, fanout } from '../llm-reformulation.js';\n59: import { runHyDE } from '../hyde.js';\n60: import { matchSurrogates } from '../query-surrogates.js';\n61: import { loadSurrogatesBatch } from '../surrogate-storage.js';\n62: \n63: // Feature catalog: 4-stage pipeline architecture\n64: // Feature catalog: Hybrid search pipeline\n65: \n66: \n67: // -- Constants --\n68: \n69: /** Maximum number of deep-mode query variants to generate (original + expanded). */\n70: const MAX_DEEP_QUERY_VARIANTS = 3;\n71: \n72: /** F1: Deep-mode expansion timeout — fall back to base query if variants take too long. */\n73: const DEEP_EXPANSION_TIMEOUT_MS = 5000;\n74: \n75: /** Minimum cosine similarity for multi-concept search. */\n76: const MULTI_CONCEPT_MIN_SIMILARITY = 0.5;\n77: \n78: /** Number of constitutional results to fetch when none appear in hybrid/vector results. */\n79: const CONSTITUTIONAL_INJECT_LIMIT = 5;\n80: \n81: /** Number of similar memories to mine for embedding-based query expansion terms. */\n82: const DEFAULT_EXPANSION_CANDIDATE_LIMIT = 5;\n83: \n84: /** D2: Timeout for facet decomposition parallel searches (ms). */\n85: const DECOMPOSITION_TIMEOUT_MS = 5000;\n86: const MAX_QUERY_DECOMPOSITION_FACETS = MAX_FACETS;\n87: \n88: // -- Helper Functions --\n89: \n90: /**\n91:  * Filter results by a minimum quality score threshold.\n92:  *\n93:  * - If no threshold is provided or it is not a finite number, all results pass.\n94:  * - Threshold is clamped to [0, 1].\n95:  * - Rows with a missing or non-finite `quality_score` are treated as 0.\n96:  *\n97:  * @param results - Candidate rows to filter.\n98:  * @param threshold - Minimum quality score in [0, 1] (inclusive).\n99:  * @returns Filtered array; original array returned unchanged when no threshold applies.\n100:  */\n101: function filterByMinQualityScore(\n102:   results: PipelineRow[],\n103:   threshold?: number\n104: ): PipelineRow[] {\n105:   if (typeof threshold !== 'number' || !Number.isFinite(threshold)) {\n106:     return results;\n107:   }\n108: \n109:   const clampedThreshold = Math.max(0, Math.min(1, threshold));\n110: \n111:   return results.filter((row) => {\n112:     const rawScore = row.quality_score as number | undefined;\n113:     const score =\n114:       typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n115:     return score >= clampedThreshold;\n116:   });\n117: }\n118: \n119: function backfillMissingQualityScores(results: PipelineRow[]): PipelineRow[] {\n120:   return results.map((row) => {\n121:     if (row.quality_score !== 0 && row.quality_score != null) {\n122:       return row;\n123:     }\n124: \n125:     return {\n126:       ...row,\n127:       quality_score: computeBackfillQualityScore(row),\n128:     };\n129:   });\n130: }\n131: \n132: function applyArchiveFilter(\n133:   results: PipelineRow[],\n134:   _includeArchived: boolean\n135: ): PipelineRow[] {\n136:   return results;\n137: }\n138: \n139: function applyFolderFilter(\n140:   results: PipelineRow[],\n141:   specFolder?: string\n142: ): PipelineRow[] {\n143:   if (!specFolder) return results;\n144:   return results.filter((row) => {\n145:     const rowSpecFolder = row.spec_folder ?? row.specFolder;\n146:     return rowSpecFolder === specFolder;\n147:   });\n148: }\n149: \n150: function applyTierFilter(\n151:   results: PipelineRow[],\n152:   tier?: string\n153: ): PipelineRow[] {\n154:   if (!tier) return results;\n155:   return results.filter((row) => row.importance_tier === tier);\n156: }\n157: \n158: /**\n159:  * Resolve the effective context type from a pipeline row.\n160:  *\n161:  * Rows may carry context type under either `contextType` (camelCase) or\n162:  * `context_type` (snake_case). This function normalises the lookup.\n163:  *\n164:  * @param row - The pipeline row to inspect.\n165:  * @returns The context type string, or `undefined` if absent.\n166:  */\n167: function resolveRowContextType(row: PipelineRow): string | undefined {\n168:   if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n169:     return row.contextType;\n170:   }\n171:   if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n172:     return row.context_type;\n173:   }\n174:   return undefined;\n175: }\n176: \n177: function mergeStringLists(...values: unknown[]): string[] {\n178:   const merged = new Set<string>();\n179:   for (const value of values) {\n180:     if (!Array.isArray(value)) {\n181:       continue;\n182:     }\n183:     for (const entry of value) {\n184:       if (typeof entry === 'string' && entry.length > 0) {\n185:         merged.add(entry);\n186:       }\n187:     }\n188:   }\n189:   return Array.from(merged);\n190: }\n191: \n192: function readFiniteScoreMap(value: unknown): Record<string, number> {\n193:   if (!value || typeof value !== 'object' || Array.isArray(value)) {\n194:     return {};\n195:   }\n196: \n197:   const normalized: Record<string, number> = {};\n198:   for (const [key, score] of Object.entries(value as Record<string, unknown>)) {\n199:     if (typeof score === 'number' && Number.isFinite(score)) {\n200:       normalized[key] = score;\n201:     }\n202:   }\n203:   return normalized;\n204: }\n205: \n206: function readQualityFlags(value: unknown): string[] {\n207:   if (Array.isArray(value)) {\n208:     return value.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n209:   }\n210:   if (typeof value !== 'string' || value.trim().length === 0) {\n211:     return [];\n212:   }\n213:   try {\n214:     const parsed = JSON.parse(value) as unknown;\n215:     if (Array.isArray(parsed)) {\n216:       return parsed.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n217:     }\n218:   } catch {\n219:     // Fall back to comma-delimited parsing for legacy callers/tests.\n220:   }\n221:   return value\n222:     .split(',')\n223:     .map((entry) => entry.trim())\n224:     .filter((entry) => entry.length > 0);\n225: }\n226: \n227: function isMigratedGraphMetadataCandidate(row: PipelineRow): boolean {\n228:   const migratedValue = row.migrated ?? row.is_migrated ?? row.metadata_migrated;\n229:   if (migratedValue === true || migratedValue === 1 || migratedValue === '1' || migratedValue === 'true') {\n230:     return true;\n231:   }\n232:   const qualityFlags = readQualityFlags(row.quality_flags ?? row.qualityFlags);\n233:   return qualityFlags.includes(GRAPH_METADATA_MIGRATED_QUALITY_FLAG);\n234: }\n235: \n236: function mergeScoreMaps(...maps: Array<Record<string, number>>): Record<string, number> {\n237:   const merged: Record<string, number> = {};\n238:   for (const map of maps) {\n239:     for (const [key, score] of Object.entries(map)) {\n240:       if (!(key in merged) || score > merged[key]!) {\n241:         merged[key] = score;\n242:       }\n243:     }\n244:   }\n245:   return merged;\n246: }\n247: \n248: function getCandidateSources(row: PipelineRow): string[] {\n249:   const explicitSources = mergeStringLists(row.sources);\n250:   if (explicitSources.length > 0) {\n251:     return explicitSources;\n252:   }\n253:   return typeof row.source === 'string' && row.source.length > 0 ? [row.source] : [];\n254: }\n255: \n256: function getCandidateSourceScores(row: PipelineRow): Record<string, number> {\n257:   const sourceScores = readFiniteScoreMap(row.sourceScores);\n258:   if (Object.keys(sourceScores).length > 0) {\n259:     return sourceScores;\n260:   }\n\n(Showing lines 1-260 of 1510. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage1 Candidate Gen\n// ───────────────────────────────────────────────────────────────\n// 4-stage retrieval pipeline architecture\n//\n// Responsibility: Execute search channels and collect raw candidate results.\n// This stage avoids downstream fusion/reranking, but may apply temporal\n// Contiguity to raw vector-channel hits before later pipeline stages.\n// Results are collected from the appropriate search channel based on search type.\n//\n// Search channels handled:\n//   - multi-concept: Generate per-concept embeddings, run multiConceptSearch\n//   - hybrid (deep mode): Query expansion + multi-variant hybrid search + dedup\n// hybrid: Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n// Suppressed when classifies query as \"simple\" (mutual exclusion)\n//   - hybrid: collectRawCandidates → falls back to vector on failure\n//   - vector: Direct vectorSearch\n//\n// Post-channel operations:\n//   - Constitutional memory injection (if not already present)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage1 Candidate Gen\n// ───────────────────────────────────────────────────────────────\n// 4-stage retrieval pipeline architecture\n//\n// Responsibility: Execute search channels and collect raw candidate results.\n// This stage avoids downstream fusion/reranking, but may apply temporal\n// Contiguity to raw vector-channel hits before later pipeline stages.\n// Results are collected from the appropriate search channel based on search type.\n//\n// Search channels handled:\n//   - multi-concept: Generate per-concept embeddings, run multiConceptSearch\n//   - hybrid (deep mode): Query expansion + multi-variant hybrid search + dedup\n// hybrid: Embedding-based query expansion (SPECKIT_EMBEDDING_EXPANSION)\n// Suppressed when classifies query as \"simple\" (mutual exclusion)\n//   - hybrid: collectRawCandidates → falls back to vector on failure\n//   - vector: Direct vectorSearch\n//\n// Post-channel operations:\n//   - Constitutional memory injection (if not already present)\n//   - Quality score filtering\n//   - Tier and contextType filtering\n//\n// I/O CONTRACT:\n// Input:  Stage1Input { config: PipelineConfig }\n// Output: Stage1Output { candidates: PipelineRow[], metadata }\n// Key invariants:\n//     - candidates contains raw channel scores; vector hits may include an\n//       optional temporal-contiguity boost applied before downstream fusion\n//     - Constitutional rows are always present when includeConstitutional=true and no tier filter\n//     - All rows pass qualityThreshold (if set) and tier/contextType filters\n// Side effects:\n//     - Generates query embeddings via the embeddings provider (external call)\n//     - Reads from the vector index and FTS5 / BM25 index (DB reads only)\n//\nimport type { Stage1Input, Stage1Output, PipelineRow } from './types.js';\nimport { resolveEffectiveScore } from './types.js';\nimport * as vectorIndex from '../vector-index.js';\nimport * as hybridSearch from '../hybrid-search.js';\nimport { vectorSearchWithContiguity } from '../../cognitive/temporal-contiguity.js';\nimport { isMultiQueryEnabled, isEmbeddingExpansionEnabled, isMemorySummariesEnabled, isQueryDecompositionEnabled, isGraphConceptRoutingEnabled, isLlmReformulationEnabled, isHyDEEnabled, isQuerySurrogatesEnabled, isTemporalContiguityEnabled, isQueryConceptExpansionEnabled } from '../search-flags.js';\nimport { expandQuery } from '../query-expander.js';\nimport { expandQueryWithEmbeddings, isExpansionActive } from '../embedding-expansion.js';\nimport { querySummaryEmbeddings, checkScaleGate } from '../memory-summaries.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/db-helpers.js';\nimport { filterRowsByScope } from '../../governance/scope-governance.js';\nimport { withTimeout } from '../../errors/core.js';\nimport { GRAPH_METADATA_MIGRATED_QUALITY_FLAG } from '../../graph/graph-metadata-schema.js';\nimport { computeBackfillQualityScore } from '../../validation/save-quality-gate.js';\nimport {\n  isMultiFacet,\n  decompose,\n  mergeByFacetCoverage as mergeFacetCoveragePools,\n  MAX_FACETS,\n} from '../query-decomposer.js';\nimport { routeQueryConcepts, nounPhrases, getConceptExpansionTerms } from '../entity-linker.js';\nimport { cheapSeedRetrieve, llm, fanout } from '../llm-reformulation.js';\nimport { runHyDE } from '../hyde.js';\nimport { matchSurrogates } from '../query-surrogates.js';\nimport { loadSurrogatesBatch } from '../surrogate-storage.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Hybrid search pipeline\n\n\n// -- Constants --\n\n/** Maximum number of deep-mode query variants to generate (original + expanded). */\nconst MAX_DEEP_QUERY_VARIANTS = 3;\n\n/** F1: Deep-mode expansion timeout — fall back to base query if variants take too long. */\nconst DEEP_EXPANSION_TIMEOUT_MS = 5000;\n\n/** Minimum cosine similarity for multi-concept search. */\nconst MULTI_CONCEPT_MIN_SIMILARITY = 0.5;\n\n/** Number of constitutional results to fetch when none appear in hybrid/vector results. */\nconst CONSTITUTIONAL_INJECT_LIMIT = 5;\n\n/** Number of similar memories to mine for embedding-based query expansion terms. */\nconst DEFAULT_EXPANSION_CANDIDATE_LIMIT = 5;\n\n/** D2: Timeout for facet decomposition parallel searches (ms). */\nconst DECOMPOSITION_TIMEOUT_MS = 5000;\nconst MAX_QUERY_DECOMPOSITION_FACETS = MAX_FACETS;\n\n// -- Helper Functions --\n\n/**\n * Filter results by a minimum quality score threshold.\n *\n * - If no threshold is provided or it is not a finite number, all results pass.\n * - Threshold is clamped to [0, 1].\n * - Rows with a missing or non-finite `quality_score` are treated as 0.\n *\n * @param results - Candidate rows to filter.\n * @param threshold - Minimum quality score in [0, 1] (inclusive).\n * @returns Filtered array; original array returned unchanged when no threshold applies.\n */\nfunction filterByMinQualityScore(\n  results: PipelineRow[],\n  threshold?: number\n): PipelineRow[] {\n  if (typeof threshold !== 'number' || !Number.isFinite(threshold)) {\n    return results;\n  }\n\n  const clampedThreshold = Math.max(0, Math.min(1, threshold));\n\n  return results.filter((row) => {\n    const rawScore = row.quality_score as number | undefined;\n    const score =\n      typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n    return score >= clampedThreshold;\n  });\n}\n\nfunction backfillMissingQualityScores(results: PipelineRow[]): PipelineRow[] {\n  return results.map((row) => {\n    if (row.quality_score !== 0 && row.quality_score != null) {\n      return row;\n    }\n\n    return {\n      ...row,\n      quality_score: computeBackfillQualityScore(row),\n    };\n  });\n}\n\nfunction applyArchiveFilter(\n  results: PipelineRow[],\n  _includeArchived: boolean\n): PipelineRow[] {\n  return results;\n}\n\nfunction applyFolderFilter(\n  results: PipelineRow[],\n  specFolder?: string\n): PipelineRow[] {\n  if (!specFolder) return results;\n  return results.filter((row) => {\n    const rowSpecFolder = row.spec_folder ?? row.specFolder;\n    return rowSpecFolder === specFolder;\n  });\n}\n\nfunction applyTierFilter(\n  results: PipelineRow[],\n  tier?: string\n): PipelineRow[] {\n  if (!tier) return results;\n  return results.filter((row) => row.importance_tier === tier);\n}\n\n/**\n * Resolve the effective context type from a pipeline row.\n *\n * Rows may carry context type under either `contextType` (camelCase) or\n * `context_type` (snake_case). This function normalises the lookup.\n *\n * @param row - The pipeline row to inspect.\n * @returns The context type string, or `undefined` if absent.\n */\nfunction resolveRowContextType(row: PipelineRow): string | undefined {\n  if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n    return row.contextType;\n  }\n  if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n    return row.context_type;\n  }\n  return undefined;\n}\n\nfunction mergeStringLists(...values: unknown[]): string[] {\n  const merged = new Set<string>();\n  for (const value of values) {\n    if (!Array.isArray(value)) {\n      continue;\n    }\n    for (const entry of value) {\n      if (typeof entry === 'string' && entry.length > 0) {\n        merged.add(entry);\n      }\n    }\n  }\n  return Array.from(merged);\n}\n\nfunction readFiniteScoreMap(value: unknown): Record<string, number> {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) {\n    return {};\n  }\n\n  const normalized: Record<string, number> = {};\n  for (const [key, score] of Object.entries(value as Record<string, unknown>)) {\n    if (typeof score === 'number' && Number.isFinite(score)) {\n      normalized[key] = score;\n    }\n  }\n  return normalized;\n}\n\nfunction readQualityFlags(value: unknown): string[] {\n  if (Array.isArray(value)) {\n    return value.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n  }\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    return [];\n  }\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (Array.isArray(parsed)) {\n      return parsed.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);\n    }\n  } catch {\n    // Fall back to comma-delimited parsing for legacy callers/tests.\n  }\n  return value\n    .split(',')\n    .map((entry) => entry.trim())\n    .filter((entry) => entry.length > 0);\n}\n\nfunction isMigratedGraphMetadataCandidate(row: PipelineRow): boolean {\n  const migratedValue = row.migrated ?? row.is_migrated ?? row.metadata_migrated;\n  if (migratedValue === true || migratedValue === 1 || migratedValue === '1' || migratedValue === 'true') {\n    return true;\n  }\n  const qualityFlags = readQualityFlags(row.quality_flags ?? row.qualityFlags);\n  return qualityFlags.includes(GRAPH_METADATA_MIGRATED_QUALITY_FLAG);\n}\n\nfunction mergeScoreMaps(...maps: Array<Record<string, number>>): Record<string, number> {\n  const merged: Record<string, number> = {};\n  for (const map of maps) {\n    for (const [key, score] of Object.entries(map)) {\n      if (!(key in merged) || score > merged[key]!) {\n        merged[key] = score;\n      }\n    }\n  }\n  return merged;\n}\n\nfunction getCandidateSources(row: PipelineRow): string[] {\n  const explicitSources = mergeStringLists(row.sources);\n  if (explicitSources.length > 0) {\n    return explicitSources;\n  }\n  return typeof row.source === 'string' && row.source.length > 0 ? [row.source] : [];\n}\n\nfunction getCandidateSourceScores(row: PipelineRow): Record<string, number> {\n  const sourceScores = readFiniteScoreMap(row.sourceScores);\n  if (Object.keys(sourceScores).length > 0) {\n    return sourceScores;\n  }","lineStart":1,"lineEnd":260,"totalLines":1510,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781764125016,"end":1781764125020}},"metadata":{"openai":{"itemId":"fc_09ce19760b694a7c016a33901cba388191904781100b6ae69b"}},"id":"prt_ed96af112001xpsYs5NGp3sjCS","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ab68d001yXE4gNbuKK33KX"}}
{"type":"tool_use","timestamp":1781764125077,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_MJkKiSFUVMOwhmuP71oKJoJk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage2 Fusion\n3: // ───────────────────────────────────────────────────────────────\n4: // the rollout: 4-Stage Retrieval Pipeline\n5: //\n6: // I/O CONTRACT:\n7: // Input:  Stage2Input { candidates: PipelineRow[], config, stage1Metadata }\n8: // Output: Stage2Output { scored: PipelineRow[], metadata }\n9: // Key invariants:\n10: //     - Every score modification in the pipeline happens exactly once here\n11: //     - Intent weights are NEVER applied to hybrid results (G2 double-weighting guard)\n12: //     - scored is sorted descending by effective composite score on exit\n13: // Side effects:\n14: //     - FSRS write-back to memory_index (when trackAccess=true) — DB write\n15: //     - Learned trigger and negative-feedback reads from DB\n16: //\n17: // PURPOSE: Single point for ALL scoring signals. Intent weights are\n18: // Applied ONCE here only — this is the architectural guard against\n19: // The G2 double-weighting recurrence bug.\n20: //\n21: // SIGNAL APPLICATION ORDER (must not be reordered — 13 steps):\n22: // 1.  Session boost           — working-memory attention amplification\n23: // 1a. Recency fusion          — time-decay bonus for recent memories\n24: // 2.  Causal boost            — graph-traversal neighbor amplification\n25: // 2a. Co-activation spreading — spreading activation from top-N seeds\n26: // 2b. Community co-retrieval  — N2c inject community co-members\n27: // 2c. Graph signals           — N2a momentum + N2b causal depth\n28: // 3.  Testing effect          — FSRS strengthening write-back (trackAccess)\n29: // 4.  Intent weights          — non-hybrid search post-scoring adjustment\n30: // 5.  Artifact routing        — class-based weight boosts\n31: // 6.  Feedback signals        — learned trigger boosts + negative demotions\n32: // 6a. Retrieval rescue        — default-on trigger/sibling/backfill rescue layer\n33: // 7.  Artifact limiting       — result count cap from routing strategy\n34: // 8.  Anchor metadata         — extract named ANCHOR sections (annotation)\n35: // 9.  Validation metadata     — spec quality signals enrichment + quality scoring\n36: //\n37: // Hybrid search already applies intent-aware scoring\n38: // Internally (RRF / RSF fusion). Post-search intent weighting is\n39: // Therefore ONLY applied for non-hybrid search types (vector,\n40: // Multi-concept). Applying it to hybrid results would double-count.\n41: //\n42: // SCORE AUDIT CONTRACT: Stage 2 writes the fused `score` field (steps 1-7).\n43: // Stage 3 (rerank) MAY overwrite `score` with the reranked value and MUST\n44: // preserve the original in `stage2Score` for auditability (see F2.02 fix).\n45: // Stage 4 (filter) MUST NOT mutate any score fields — it is read-only.\n46: \n47: import type Database from 'better-sqlite3';\n48: import path from 'path';\n49: import { readFile } from 'fs/promises';\n50: \n51: import { resolveEffectiveScore } from './types.js';\n52: import type { Stage2Input, Stage2Output, PipelineRow, IntentWeightsConfig, ArtifactRoutingConfig } from './types.js';\n53: \n54: import * as sessionBoost from '../session-boost.js';\n55: import * as causalBoost from '../causal-boost.js';\n56: import {\n57:   isEnabled as isCoActivationEnabled,\n58:   spreadActivation,\n59:   getRelatedMemoryCounts,\n60:   resolveCoActivationBoostFactor,\n61: } from '../../cognitive/co-activation.js';\n62: import type { SpreadResult } from '../../cognitive/co-activation.js';\n63: import { ensureAdaptiveTables, getAdaptiveMode } from '../../cognitive/adaptive-ranking.js';\n64: import * as fsrsScheduler from '../../cognitive/fsrs-scheduler.js';\n65: import { queryLearnedTriggers } from '../learned-feedback.js';\n66: import { applyNegativeFeedback, getNegativeFeedbackStats } from '../../scoring/negative-feedback.js';\n67: import {\n68:   isNegativeFeedbackEnabled,\n69:   isCommunityDetectionEnabled,\n70:   isGraphCalibrationProfileEnabled,\n71:   isGraphSignalsEnabled,\n72:   isUsageRankingEnabled,\n73:   resolveGraphWalkRolloutState,\n74:   isLearnedStage2CombinerEnabled,\n75:   isResultProvenanceEnabled,\n76: } from '../search-flags.js';\n77: import { applyGraphContributionCalibration } from '../graph-calibration.js';\n78: import { shadowScore, extractFeatureVector, loadModel } from '@spec-kit/shared/ranking/learned-combiner';\n79: import type { LearnedModel } from '@spec-kit/shared/ranking/learned-combiner';\n80: import { getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\n81: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n82: import { requireDb } from '../../../utils/db-helpers.js';\n83: import { computeRecencyScore } from '../../scoring/folder-scoring.js';\n84: import { enrichResultsWithAnchorMetadata } from '../anchor-metadata.js';\n85: import { enrichResultsWithValidationMetadata } from '../validation-metadata.js';\n86: // Stage 2b enrichment extracted for decomposition clarity\n87: import { executeStage2bEnrichment } from './stage2b-enrichment.js';\n88: import { applyCommunityBoost } from '../../graph/community-detection.js';\n89: import { applyGraphSignals } from '../../graph/graph-signals.js';\n90: import { computeUsageBoost } from '../../graph/usage-ranking-signal.js';\n91: import { ensureUsageColumn } from '../../graph/usage-tracking.js';\n92: import { isGraphUnifiedEnabled } from '../graph-flags.js';\n93: import { resolveFusionIntentContract } from '../search-utils.js';\n94: import { sortDeterministicRows } from './ranking-contract.js';\n95: import { applyRetrievalRescueLayer, isRetrievalRescueEnabled } from '../rerank/retrieval-rescue.js';\n96: import { createLogger } from '../../utils/logger.js';\n97: \n98: // Feature catalog: 4-stage pipeline architecture\n99: // Feature catalog: MPAB chunk-to-memory aggregation\n100: \n101: \n102: // -- Internal type aliases --\n103: \n104: /** A row with a resolved numeric base score for internal use. */\n105: interface ScoredRow extends PipelineRow {\n106:   intentAdjustedScore?: number;\n107: }\n108: \n109: /** Result of the strengthenOnAccess FSRS write-back. */\n110: interface StrengthenResult {\n111:   stability: number;\n112:   difficulty: number;\n113: }\n114: \n115: interface ValidationMetadataLike {\n116:   qualityScore?: number;\n117:   specLevel?: number;\n118:   completionStatus?: 'complete' | 'partial' | 'unknown';\n119:   hasChecklist?: boolean;\n120: }\n121: \n122: // -- Constants --\n123: \n124: /** Number of top results used as seeds for co-activation spreading. */\n125: const SPREAD_ACTIVATION_TOP_N = 5;\n126: const DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH = path.join('models', 'learned-stage2-combiner.json');\n127: const logger = createLogger('stage2-fusion');\n128: \n129: /** Recency fusion weight — controls how much recency score contributes to the fused score.\n130:  *  Env-tunable via SPECKIT_RECENCY_FUSION_WEIGHT (default 0.07). */\n131: const RECENCY_FUSION_WEIGHT = parseFloat(process.env.SPECKIT_RECENCY_FUSION_WEIGHT || '') || 0.07;\n132: \n133: /** Recency fusion cap — maximum bonus a candidate can receive from recency fusion.\n134:  *  Env-tunable via SPECKIT_RECENCY_FUSION_CAP (default 0.10). */\n135: const RECENCY_FUSION_CAP = parseFloat(process.env.SPECKIT_RECENCY_FUSION_CAP || '') || 0.10;\n136: \n137: const MIN_VALIDATION_MULTIPLIER = 0.8;\n138: const MAX_VALIDATION_MULTIPLIER = 1.2;\n139: \n140: type LearnedStage2ModelCacheEntry = {\n141:   path: string;\n142:   model: LearnedModel | null;\n143: };\n144: \n145: let cachedLearnedStage2Model: LearnedStage2ModelCacheEntry | null = null;\n146: let learnedStage2ModelLoadPromise: Promise<LearnedStage2ModelCacheEntry> | null = null;\n147: let learnedStage2ModelLoadPromisePath: string | null = null;\n148: \n149: function clampMultiplier(value: number): number {\n150:   if (!Number.isFinite(value)) return 1;\n151:   if (value < MIN_VALIDATION_MULTIPLIER) return MIN_VALIDATION_MULTIPLIER;\n152:   if (value > MAX_VALIDATION_MULTIPLIER) return MAX_VALIDATION_MULTIPLIER;\n153:   return value;\n154: }\n155: \n156: function isShadowLearningModelLoadEnabled(): boolean {\n157:   return process.env.SPECKIT_SHADOW_LEARNING?.toLowerCase().trim() === 'true';\n158: }\n159: \n160: // Learned blend weight. Reads SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT\n161: // (default 0.0 → identical to today's shadow-only behavior). Clamped to\n162: // [0, 0.05] so promotion stays a small guarded blend, never a flip. The\n163: // bound is intentional: even when opted in, the manual combiner remains the\n164: // dominant signal (>=95%) and the learned model acts as a tiebreaker, not a\n165: // steering wheel. NaN, negative, and out-of-range values clamp to the bound.\n166: const MAX_LEARNED_BLEND_WEIGHT = 0.05;\n167: let warnedLearnedBlendClamp = false;\n168: \n169: function resolveLearnedBlendWeight(env: NodeJS.ProcessEnv = process.env): number {\n170:   const raw = env.SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT;\n171:   if (raw === undefined || raw === '') return 0;\n172:   const parsed = Number.parseFloat(raw);\n173:   if (!Number.isFinite(parsed)) return 0;\n174:   if (parsed <= 0) return 0;\n175:   if (parsed > MAX_LEARNED_BLEND_WEIGHT) {\n176:     if (!warnedLearnedBlendClamp) {\n177:       warnedLearnedBlendClamp = true;\n178:       console.warn(\n179:         `[stage2-fusion] SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT=${raw} exceeds the ${MAX_LEARNED_BLEND_WEIGHT} guard; clamping. Promotion is a small guarded blend, not a flip.`\n180:       );\n181:     }\n182:     return MAX_LEARNED_BLEND_WEIGHT;\n183:   }\n184:   return parsed;\n185: }\n186: \n187: function resolveLearnedStage2ModelPath(): string {\n188:   const configured = process.env.SPECKIT_LEARNED_STAGE2_MODEL?.trim();\n189:   if (!configured) {\n190:     return path.resolve(process.cwd(), DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH);\n191:   }\n192:   if (path.isAbsolute(configured)) {\n193:     return configured;\n194:   }\n195:   return path.resolve(process.cwd(), configured);\n196: }\n197: \n198: async function loadPersistedLearnedStage2Model(): Promise<LearnedModel | null> {\n199:   if (!isShadowLearningModelLoadEnabled()) {\n200:     return null;\n201:   }\n202: \n203:   const modelPath = resolveLearnedStage2ModelPath();\n204:   if (cachedLearnedStage2Model?.path === modelPath) {\n205:     return cachedLearnedStage2Model.model;\n206:   }\n207: \n208:   if (learnedStage2ModelLoadPromise && learnedStage2ModelLoadPromisePath === modelPath) {\n209:     return (await learnedStage2ModelLoadPromise).model;\n210:   }\n211: \n212:   if (learnedStage2ModelLoadPromisePath !== modelPath) {\n213:     learnedStage2ModelLoadPromise = null;\n214:     learnedStage2ModelLoadPromisePath = null;\n215:   }\n216: \n217:   learnedStage2ModelLoadPromisePath = modelPath;\n218:   learnedStage2ModelLoadPromise = (async (): Promise<LearnedStage2ModelCacheEntry> => {\n219:     try {\n220:       const json = await readFile(modelPath, 'utf8');\n221:       const model = loadModel(json);\n222:       if (!model) {\n223:         console.warn(`[stage2-fusion] learned stage2 model at ${modelPath} is invalid; shadow scoring will use manual-only fallback`);\n224:       }\n225:       const entry = { path: modelPath, model };\n226:       cachedLearnedStage2Model = entry;\n227:       return entry;\n228:     } catch (err: unknown) {\n229:       const entry = { path: modelPath, model: null };\n230:       cachedLearnedStage2Model = entry;\n231: \n232:       const code = typeof err === 'object' && err !== null && 'code' in err\n233:         ? String((err as { code?: unknown }).code)\n234:         : '';\n235:       if (code !== 'ENOENT') {\n236:         const message = err instanceof Error ? err.message : String(err);\n237:         console.warn(`[stage2-fusion] learned stage2 model load failed: ${message}`);\n238:       }\n239:       return entry;\n240:     } finally {\n241:       learnedStage2ModelLoadPromise = null;\n242:       learnedStage2ModelLoadPromisePath = null;\n243:     }\n244:   })();\n245: \n246:   return (await learnedStage2ModelLoadPromise).model;\n247: }\n248: \n249: /**\n250:  * Apply validation-signal scoring at the Stage 2 single scoring point.\n251:  *\n252:  * Uses quality metadata extracted from spec artifacts to apply a bounded\n253:  * multiplier over the current composite score. This keeps integrated\n254:  * in ranking while preserving score stability.\n255:  */\n256: function applyValidationSignalScoring(results: PipelineRow[]): PipelineRow[] {\n257:   if (!Array.isArray(results) || results.length === 0) return results;\n258: \n259:   const adjusted = results.map((row) => {\n260:     const metadata = row.validationMetadata as ValidationMetadataLike | undefined;\n261:     if (!metadata || typeof metadata !== 'object') return row;\n262: \n263:     const baseScore = resolveBaseScore(row);\n264:     const quality = typeof metadata.qualityScore === 'number' && Number.isFinite(metadata.qualityScore)\n265:       ? Math.max(0, Math.min(1, metadata.qualityScore))\n266:       : 0.5;\n267: \n268:     const qualityFactor = 0.9 + (quality * 0.2); // [0.9, 1.1]\n269:     const specLevelBonus = typeof metadata.specLevel === 'number' && Number.isFinite(metadata.specLevel)\n270:       ? Math.max(0, Math.min(0.06, (metadata.specLevel - 1) * 0.02))\n271:       : 0;\n272: \n273:     const completionBonus = metadata.completionStatus === 'complete'\n274:       ? 0.04\n275:       : metadata.completionStatus === 'partial'\n276:         ? 0.015\n277:         : 0;\n278: \n279:     const checklistBonus = metadata.hasChecklist ? 0.01 : 0;\n280:     const multiplier = clampMultiplier(qualityFactor + specLevelBonus + completionBonus + checklistBonus);\n281:     const scored = Math.min(1, Math.max(0, baseScore * multiplier));\n282: \n283:     if (scored === baseScore) return row;\n284:     return withSyncedScoreAliases(row, scored);\n285:   });\n286: \n287:   return sortDeterministicRows(adjusted as Array<PipelineRow & { id: number }>);\n288: }\n289: \n290: // -- Internal helpers --\n291: \n292: /**\n293:  * Replaced with shared resolveEffectiveScore()\n294:  * from types.ts. The shared function uses the correct fallback chain:\n295:  * intentAdjustedScore → rrfScore → score → similarity/100, all clamped to [0,1].\n296:  * This alias ensures all call sites use the shared implementation.\n297:  */\n298: const resolveBaseScore = resolveEffectiveScore;\n299: \n300: function withSyncedScoreAliases(row: PipelineRow, score: number): PipelineRow {\n\n(Showing lines 1-300 of 1486. Use offset=301 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage2 Fusion\n// ───────────────────────────────────────────────────────────────\n// the rollout: 4-Stage Retrieval Pipeline\n//\n// I/O CONTRACT:\n// Input:  Stage2Input { candidates: PipelineRow[], config, stage1Metadata }\n// Output: Stage2Output { scored: PipelineRow[], metadata }\n// Key invariants:\n//     - Every score modification in the pipeline happens exactly once here\n//     - Intent weights are NEVER applied to hybrid results (G2 double-weighting guard)\n//     - scored is sorted descending by effective composite score on exit\n// Side effects:\n//     - FSRS write-back to memory_index (when trackAccess=true) — DB write\n//     - Learned trigger and negative-feedback reads from DB\n//\n// PURPOSE: Single point for ALL scoring signals. Intent weights are\n// Applied ONCE here only — this is the architectural guard against\n// The G2 double-weighting recurrence bug.\n//","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage2 Fusion\n// ───────────────────────────────────────────────────────────────\n// the rollout: 4-Stage Retrieval Pipeline\n//\n// I/O CONTRACT:\n// Input:  Stage2Input { candidates: PipelineRow[], config, stage1Metadata }\n// Output: Stage2Output { scored: PipelineRow[], metadata }\n// Key invariants:\n//     - Every score modification in the pipeline happens exactly once here\n//     - Intent weights are NEVER applied to hybrid results (G2 double-weighting guard)\n//     - scored is sorted descending by effective composite score on exit\n// Side effects:\n//     - FSRS write-back to memory_index (when trackAccess=true) — DB write\n//     - Learned trigger and negative-feedback reads from DB\n//\n// PURPOSE: Single point for ALL scoring signals. Intent weights are\n// Applied ONCE here only — this is the architectural guard against\n// The G2 double-weighting recurrence bug.\n//\n// SIGNAL APPLICATION ORDER (must not be reordered — 13 steps):\n// 1.  Session boost           — working-memory attention amplification\n// 1a. Recency fusion          — time-decay bonus for recent memories\n// 2.  Causal boost            — graph-traversal neighbor amplification\n// 2a. Co-activation spreading — spreading activation from top-N seeds\n// 2b. Community co-retrieval  — N2c inject community co-members\n// 2c. Graph signals           — N2a momentum + N2b causal depth\n// 3.  Testing effect          — FSRS strengthening write-back (trackAccess)\n// 4.  Intent weights          — non-hybrid search post-scoring adjustment\n// 5.  Artifact routing        — class-based weight boosts\n// 6.  Feedback signals        — learned trigger boosts + negative demotions\n// 6a. Retrieval rescue        — default-on trigger/sibling/backfill rescue layer\n// 7.  Artifact limiting       — result count cap from routing strategy\n// 8.  Anchor metadata         — extract named ANCHOR sections (annotation)\n// 9.  Validation metadata     — spec quality signals enrichment + quality scoring\n//\n// Hybrid search already applies intent-aware scoring\n// Internally (RRF / RSF fusion). Post-search intent weighting is\n// Therefore ONLY applied for non-hybrid search types (vector,\n// Multi-concept). Applying it to hybrid results would double-count.\n//\n// SCORE AUDIT CONTRACT: Stage 2 writes the fused `score` field (steps 1-7).\n// Stage 3 (rerank) MAY overwrite `score` with the reranked value and MUST\n// preserve the original in `stage2Score` for auditability (see F2.02 fix).\n// Stage 4 (filter) MUST NOT mutate any score fields — it is read-only.\n\nimport type Database from 'better-sqlite3';\nimport path from 'path';\nimport { readFile } from 'fs/promises';\n\nimport { resolveEffectiveScore } from './types.js';\nimport type { Stage2Input, Stage2Output, PipelineRow, IntentWeightsConfig, ArtifactRoutingConfig } from './types.js';\n\nimport * as sessionBoost from '../session-boost.js';\nimport * as causalBoost from '../causal-boost.js';\nimport {\n  isEnabled as isCoActivationEnabled,\n  spreadActivation,\n  getRelatedMemoryCounts,\n  resolveCoActivationBoostFactor,\n} from '../../cognitive/co-activation.js';\nimport type { SpreadResult } from '../../cognitive/co-activation.js';\nimport { ensureAdaptiveTables, getAdaptiveMode } from '../../cognitive/adaptive-ranking.js';\nimport * as fsrsScheduler from '../../cognitive/fsrs-scheduler.js';\nimport { queryLearnedTriggers } from '../learned-feedback.js';\nimport { applyNegativeFeedback, getNegativeFeedbackStats } from '../../scoring/negative-feedback.js';\nimport {\n  isNegativeFeedbackEnabled,\n  isCommunityDetectionEnabled,\n  isGraphCalibrationProfileEnabled,\n  isGraphSignalsEnabled,\n  isUsageRankingEnabled,\n  resolveGraphWalkRolloutState,\n  isLearnedStage2CombinerEnabled,\n  isResultProvenanceEnabled,\n} from '../search-flags.js';\nimport { applyGraphContributionCalibration } from '../graph-calibration.js';\nimport { shadowScore, extractFeatureVector, loadModel } from '@spec-kit/shared/ranking/learned-combiner';\nimport type { LearnedModel } from '@spec-kit/shared/ranking/learned-combiner';\nimport { getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/db-helpers.js';\nimport { computeRecencyScore } from '../../scoring/folder-scoring.js';\nimport { enrichResultsWithAnchorMetadata } from '../anchor-metadata.js';\nimport { enrichResultsWithValidationMetadata } from '../validation-metadata.js';\n// Stage 2b enrichment extracted for decomposition clarity\nimport { executeStage2bEnrichment } from './stage2b-enrichment.js';\nimport { applyCommunityBoost } from '../../graph/community-detection.js';\nimport { applyGraphSignals } from '../../graph/graph-signals.js';\nimport { computeUsageBoost } from '../../graph/usage-ranking-signal.js';\nimport { ensureUsageColumn } from '../../graph/usage-tracking.js';\nimport { isGraphUnifiedEnabled } from '../graph-flags.js';\nimport { resolveFusionIntentContract } from '../search-utils.js';\nimport { sortDeterministicRows } from './ranking-contract.js';\nimport { applyRetrievalRescueLayer, isRetrievalRescueEnabled } from '../rerank/retrieval-rescue.js';\nimport { createLogger } from '../../utils/logger.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: MPAB chunk-to-memory aggregation\n\n\n// -- Internal type aliases --\n\n/** A row with a resolved numeric base score for internal use. */\ninterface ScoredRow extends PipelineRow {\n  intentAdjustedScore?: number;\n}\n\n/** Result of the strengthenOnAccess FSRS write-back. */\ninterface StrengthenResult {\n  stability: number;\n  difficulty: number;\n}\n\ninterface ValidationMetadataLike {\n  qualityScore?: number;\n  specLevel?: number;\n  completionStatus?: 'complete' | 'partial' | 'unknown';\n  hasChecklist?: boolean;\n}\n\n// -- Constants --\n\n/** Number of top results used as seeds for co-activation spreading. */\nconst SPREAD_ACTIVATION_TOP_N = 5;\nconst DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH = path.join('models', 'learned-stage2-combiner.json');\nconst logger = createLogger('stage2-fusion');\n\n/** Recency fusion weight — controls how much recency score contributes to the fused score.\n *  Env-tunable via SPECKIT_RECENCY_FUSION_WEIGHT (default 0.07). */\nconst RECENCY_FUSION_WEIGHT = parseFloat(process.env.SPECKIT_RECENCY_FUSION_WEIGHT || '') || 0.07;\n\n/** Recency fusion cap — maximum bonus a candidate can receive from recency fusion.\n *  Env-tunable via SPECKIT_RECENCY_FUSION_CAP (default 0.10). */\nconst RECENCY_FUSION_CAP = parseFloat(process.env.SPECKIT_RECENCY_FUSION_CAP || '') || 0.10;\n\nconst MIN_VALIDATION_MULTIPLIER = 0.8;\nconst MAX_VALIDATION_MULTIPLIER = 1.2;\n\ntype LearnedStage2ModelCacheEntry = {\n  path: string;\n  model: LearnedModel | null;\n};\n\nlet cachedLearnedStage2Model: LearnedStage2ModelCacheEntry | null = null;\nlet learnedStage2ModelLoadPromise: Promise<LearnedStage2ModelCacheEntry> | null = null;\nlet learnedStage2ModelLoadPromisePath: string | null = null;\n\nfunction clampMultiplier(value: number): number {\n  if (!Number.isFinite(value)) return 1;\n  if (value < MIN_VALIDATION_MULTIPLIER) return MIN_VALIDATION_MULTIPLIER;\n  if (value > MAX_VALIDATION_MULTIPLIER) return MAX_VALIDATION_MULTIPLIER;\n  return value;\n}\n\nfunction isShadowLearningModelLoadEnabled(): boolean {\n  return process.env.SPECKIT_SHADOW_LEARNING?.toLowerCase().trim() === 'true';\n}\n\n// Learned blend weight. Reads SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT\n// (default 0.0 → identical to today's shadow-only behavior). Clamped to\n// [0, 0.05] so promotion stays a small guarded blend, never a flip. The\n// bound is intentional: even when opted in, the manual combiner remains the\n// dominant signal (>=95%) and the learned model acts as a tiebreaker, not a\n// steering wheel. NaN, negative, and out-of-range values clamp to the bound.\nconst MAX_LEARNED_BLEND_WEIGHT = 0.05;\nlet warnedLearnedBlendClamp = false;\n\nfunction resolveLearnedBlendWeight(env: NodeJS.ProcessEnv = process.env): number {\n  const raw = env.SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT;\n  if (raw === undefined || raw === '') return 0;\n  const parsed = Number.parseFloat(raw);\n  if (!Number.isFinite(parsed)) return 0;\n  if (parsed <= 0) return 0;\n  if (parsed > MAX_LEARNED_BLEND_WEIGHT) {\n    if (!warnedLearnedBlendClamp) {\n      warnedLearnedBlendClamp = true;\n      console.warn(\n        `[stage2-fusion] SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT=${raw} exceeds the ${MAX_LEARNED_BLEND_WEIGHT} guard; clamping. Promotion is a small guarded blend, not a flip.`\n      );\n    }\n    return MAX_LEARNED_BLEND_WEIGHT;\n  }\n  return parsed;\n}\n\nfunction resolveLearnedStage2ModelPath(): string {\n  const configured = process.env.SPECKIT_LEARNED_STAGE2_MODEL?.trim();\n  if (!configured) {\n    return path.resolve(process.cwd(), DEFAULT_LEARNED_STAGE2_MODEL_RELATIVE_PATH);\n  }\n  if (path.isAbsolute(configured)) {\n    return configured;\n  }\n  return path.resolve(process.cwd(), configured);\n}\n\nasync function loadPersistedLearnedStage2Model(): Promise<LearnedModel | null> {\n  if (!isShadowLearningModelLoadEnabled()) {\n    return null;\n  }\n\n  const modelPath = resolveLearnedStage2ModelPath();\n  if (cachedLearnedStage2Model?.path === modelPath) {\n    return cachedLearnedStage2Model.model;\n  }\n\n  if (learnedStage2ModelLoadPromise && learnedStage2ModelLoadPromisePath === modelPath) {\n    return (await learnedStage2ModelLoadPromise).model;\n  }\n\n  if (learnedStage2ModelLoadPromisePath !== modelPath) {\n    learnedStage2ModelLoadPromise = null;\n    learnedStage2ModelLoadPromisePath = null;\n  }\n\n  learnedStage2ModelLoadPromisePath = modelPath;\n  learnedStage2ModelLoadPromise = (async (): Promise<LearnedStage2ModelCacheEntry> => {\n    try {\n      const json = await readFile(modelPath, 'utf8');\n      const model = loadModel(json);\n      if (!model) {\n        console.warn(`[stage2-fusion] learned stage2 model at ${modelPath} is invalid; shadow scoring will use manual-only fallback`);\n      }\n      const entry = { path: modelPath, model };\n      cachedLearnedStage2Model = entry;\n      return entry;\n    } catch (err: unknown) {\n      const entry = { path: modelPath, model: null };\n      cachedLearnedStage2Model = entry;\n\n      const code = typeof err === 'object' && err !== null && 'code' in err\n        ? String((err as { code?: unknown }).code)\n        : '';\n      if (code !== 'ENOENT') {\n        const message = err instanceof Error ? err.message : String(err);\n        console.warn(`[stage2-fusion] learned stage2 model load failed: ${message}`);\n      }\n      return entry;\n    } finally {\n      learnedStage2ModelLoadPromise = null;\n      learnedStage2ModelLoadPromisePath = null;\n    }\n  })();\n\n  return (await learnedStage2ModelLoadPromise).model;\n}\n\n/**\n * Apply validation-signal scoring at the Stage 2 single scoring point.\n *\n * Uses quality metadata extracted from spec artifacts to apply a bounded\n * multiplier over the current composite score. This keeps integrated\n * in ranking while preserving score stability.\n */\nfunction applyValidationSignalScoring(results: PipelineRow[]): PipelineRow[] {\n  if (!Array.isArray(results) || results.length === 0) return results;\n\n  const adjusted = results.map((row) => {\n    const metadata = row.validationMetadata as ValidationMetadataLike | undefined;\n    if (!metadata || typeof metadata !== 'object') return row;\n\n    const baseScore = resolveBaseScore(row);\n    const quality = typeof metadata.qualityScore === 'number' && Number.isFinite(metadata.qualityScore)\n      ? Math.max(0, Math.min(1, metadata.qualityScore))\n      : 0.5;\n\n    const qualityFactor = 0.9 + (quality * 0.2); // [0.9, 1.1]\n    const specLevelBonus = typeof metadata.specLevel === 'number' && Number.isFinite(metadata.specLevel)\n      ? Math.max(0, Math.min(0.06, (metadata.specLevel - 1) * 0.02))\n      : 0;\n\n    const completionBonus = metadata.completionStatus === 'complete'\n      ? 0.04\n      : metadata.completionStatus === 'partial'\n        ? 0.015\n        : 0;\n\n    const checklistBonus = metadata.hasChecklist ? 0.01 : 0;\n    const multiplier = clampMultiplier(qualityFactor + specLevelBonus + completionBonus + checklistBonus);\n    const scored = Math.min(1, Math.max(0, baseScore * multiplier));\n\n    if (scored === baseScore) return row;\n    return withSyncedScoreAliases(row, scored);\n  });\n\n  return sortDeterministicRows(adjusted as Array<PipelineRow & { id: number }>);\n}\n\n// -- Internal helpers --\n\n/**\n * Replaced with shared resolveEffectiveScore()\n * from types.ts. The shared function uses the correct fallback chain:\n * intentAdjustedScore → rrfScore → score → similarity/100, all clamped to [0,1].\n * This alias ensures all call sites use the shared implementation.\n */\nconst resolveBaseScore = resolveEffectiveScore;\n\nfunction withSyncedScoreAliases(row: PipelineRow, score: number): PipelineRow {","lineStart":1,"lineEnd":300,"totalLines":1486,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","time":{"start":1781764125070,"end":1781764125075}},"metadata":{"openai":{"itemId":"fc_09ce19760b694a7c016a33901cba448191ba61fca631bd08c9"}},"id":"prt_ed96af1690013ChDi3YCoz1SRa","sessionID":"ses_12697437