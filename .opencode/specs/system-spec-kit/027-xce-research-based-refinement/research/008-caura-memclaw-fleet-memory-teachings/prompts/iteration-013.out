c.now(),\n\n  Line 4607:                 .returning(IdempotencyResponse)\n\n  Line 4622:         request_hash: str,\n\n  Line 4626:     ) -> IdempotencyResponse:\n\n  Line 4627:         \"\"\"Persist the handler's response and clear ``is_pending``.\n\n  Line 4629:         Optimistic about the prior :meth:`idempotency_claim` having\n\n  Line 4631:         scoped to the still-pending claim. If no row exists (claim was\n\n  Line 4634:         wins. The ``request_hash`` filter ensures a late-arriving record\n\n  Line 4636:         reclaimed the slot — its UPDATE will match no rows and the\n\n  Line 4642:                 sql_update(IdempotencyResponse)\n\n  Line 4644:                     IdempotencyResponse.tenant_id == tenant_id,\n\n  Line 4645:                     IdempotencyResponse.idempotency_key == idempotency_key,\n\n  Line 4646:                     IdempotencyResponse.request_hash == request_hash,\n\n  Line 4647:                     IdempotencyResponse.is_pending.is_(True),\n\n  Line 4653:                     is_pending=False,\n\n  Line 4655:                 .returning(IdempotencyResponse)\n\n  Line 4663:                 pg_insert(IdempotencyResponse)\n\n  Line 4667:                     request_hash=request_hash,\n\n  Line 4671:                     is_pending=False,\n\n  Line 4674:                 .returning(IdempotencyResponse)\n\n  Line 4682:                 select(IdempotencyResponse).where(\n\n  Line 4683:                     IdempotencyResponse.tenant_id == tenant_id,\n\n  Line 4684:                     IdempotencyResponse.idempotency_key == idempotency_key,\n\n  Line 4699:             if row.is_pending:\n\n  Line 4700:                 # Expiry-reclaim race: our (slow) handler's pending row\n\n  Line 4701:                 # expired, a fresh request reclaimed the slot with a\n\n  Line 4706:                 # pending row (status_code=0, is_pending=True). Returning\n\n  Line 4712:                     \"is still pending under a different claim — the original \"\n\n  Line 4713:                     \"pending TTL likely elapsed and the slot was reclaimed\"\n\n  Line 4715:             if row.request_hash != request_hash:\n\n  Line 4717:                 # already finished. The SELECT has no ``request_hash``\n\n  Line 4725:                     \"holds a different request hash — slot reclaimed by a \"\n\n  Line 4726:                     \"fresh request that completed before our record() arrived\"\n\n  Line 4735:         request_hash: str,\n\n  Line 4739:     ) -> IdempotencyResponse:\n\n  Line 4750:             request_hash=request_hash,\n","metadata":{"matches":79,"truncated":false},"title":"idempotency_claim|idempotency_complete|idempotency_get|Idempotency|request_hash|pending|claimed|complete","time":{"start":1780728859607,"end":1780728859625}},"metadata":{"openai":{"itemId":"fc_04e51764e092a4a7016a23c41a3b84819195f1ccd261cf90a7"}},"id":"prt_e9bb60bd5001AUsynMbgLrDoNA","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb5e0c40015pyQypwsTnfEFA"}}
{"type":"tool_use","timestamp":1780728859630,"sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","part":{"type":"tool","tool":"grep","callID":"call_uO6RQI2cgJnFvJEdjVF5KzHW","state":{"status":"completed","input":{"pattern":"idempotency|Idempotency|request_hash|claim|complete","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers","include":"*.py"},"output":"Found 38 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/memories.py:\n  Line 71:     \"\"\"Insert a batch with per-attempt idempotency (CAURA-602).\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/reports.py:\n  Line 44:     report = await _svc.report_get_latest_completed(tenant_id)\n\n  Line 46:         raise HTTPException(status_code=404, detail=\"No completed report found\")\n\n  Line 69:     await _svc.report_update_completed(\n\n  Line 72:         completed_at=datetime.fromisoformat(body[\"completed_at\"])\n\n  Line 73:         if isinstance(body.get(\"completed_at\"), str)\n\n  Line 74:         else body[\"completed_at\"],\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/__init__.py:\n  Line 8: from core_storage_api.routers.idempotency import router as idempotency_router\n\n  Line 26:     \"idempotency_router\",\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/idempotency.py:\n  Line 1: \"\"\"Idempotency inbox — CRUD for the (tenant_id, key) → response cache.\"\"\"\n\n  Line 13: router = APIRouter(prefix=\"/idempotency\", tags=[\"Idempotency\"])\n\n  Line 17: class IdempotencyClaimRequest(BaseModel):\n\n  Line 19:     idempotency_key: str\n\n  Line 20:     request_hash: str\n\n  Line 24: class IdempotencyUpsertRequest(BaseModel):\n\n  Line 26:     idempotency_key: str\n\n  Line 27:     request_hash: str\n\n  Line 34: async def get_idempotency(tenant_id: str, idempotency_key: str) -> dict:\n\n  Line 35:     row = await _svc.idempotency_get(\n\n  Line 37:         idempotency_key=idempotency_key,\n\n  Line 40:         raise HTTPException(status_code=404, detail=\"idempotency record not found or expired\")\n\n  Line 44: @router.post(\"/claim\", status_code=201, responses={409: {\"description\": \"Already claimed\"}})\n\n  Line 45: async def claim_idempotency(body: IdempotencyClaimRequest, response: Response) -> dict:\n\n  Line 46:     \"\"\"Insert a pending claim for ``(tenant_id, idempotency_key)``.\n\n  Line 48:     Returns 201 with the claim row when the caller wins the race;\n\n  Line 52:     holder completes the response (``is_pending`` flips to False) or\n\n  Line 55:     row = await _svc.idempotency_claim(\n\n  Line 57:         idempotency_key=body.idempotency_key,\n\n  Line 58:         request_hash=body.request_hash,\n\n  Line 62:         existing = await _svc.idempotency_get(\n\n  Line 64:             idempotency_key=body.idempotency_key,\n\n  Line 74:         return {\"found\": False, \"detail\": \"idempotency record not found or expired\"}\n\n  Line 79: async def upsert_idempotency(body: IdempotencyUpsertRequest) -> dict:\n\n  Line 80:     # If a prior ``claim`` inserted a pending row, this UPDATEs it in\n\n  Line 82:     # legacy callers that skipped the claim step.\n\n  Line 83:     row = await _svc.idempotency_upsert(\n\n  Line 85:         idempotency_key=body.idempotency_key,\n\n  Line 86:         request_hash=body.request_hash,\n","metadata":{"matches":38,"truncated":false},"title":"idempotency|Idempotency|request_hash|claim|complete","time":{"start":1780728859610,"end":1780728859628}},"metadata":{"openai":{"itemId":"fc_04e51764e092a4a7016a23c41a3b8c8191834997bec1cf3685"}},"id":"prt_e9bb60bd8001GHiyG3RSzcd0fy","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb5e0c40015pyQypwsTnfEFA"}}
{"type":"tool_use","timestamp":1780728859630,"sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","part":{"type":"tool","tool":"read","callID":"call_A6UnWoe71ozE6A8GJxDiDeIk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/idempotency.py","offset":1,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/idempotency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Idempotency inbox for Idempotency-Key replay (CAURA-601).\n2: \n3: A row per (tenant_id, idempotency_key) stores the request body hash\n4: and the response to replay. The hash guards against the same key\n5: being reused with a different body (which the client treats as a\n6: conflict) — that's the contract every idempotency-key standard\n7: (IETF draft, Stripe) agrees on.\n8: \n9: A short TTL keeps the table bounded; opportunistic cleanup or a\n10: periodic job (tracked separately) prunes expired rows.\n11: \"\"\"\n12: \n13: from datetime import datetime\n14: \n15: from sqlalchemy import (\n16:     Boolean,\n17:     DateTime,\n18:     Index,\n19:     Integer,\n20:     PrimaryKeyConstraint,\n21:     Text,\n22:     text,\n23: )\n24: from sqlalchemy.dialects.postgresql import JSONB\n25: from sqlalchemy.orm import Mapped, mapped_column\n26: \n27: from common.models.base import Base\n28: \n29: \n30: class IdempotencyResponse(Base):\n31:     __tablename__ = \"idempotency_responses\"\n32:     __table_args__ = (\n33:         PrimaryKeyConstraint(\n34:             \"tenant_id\", \"idempotency_key\", name=\"pk_idempotency_responses\"\n35:         ),\n36:         # TTL cleanup job scans by expires_at.\n37:         Index(\"ix_idempotency_responses_expires_at\", \"expires_at\"),\n38:     )\n39: \n40:     tenant_id: Mapped[str] = mapped_column(Text, nullable=False)\n41:     idempotency_key: Mapped[str] = mapped_column(Text, nullable=False)\n42:     request_hash: Mapped[str] = mapped_column(Text, nullable=False)\n43:     response_body: Mapped[dict] = mapped_column(\n44:         JSONB, nullable=False, server_default=text(\"'{}'::jsonb\")\n45:     )\n46:     status_code: Mapped[int] = mapped_column(Integer, nullable=False)\n47:     created_at: Mapped[datetime] = mapped_column(\n48:         DateTime(timezone=True), nullable=False, server_default=text(\"now()\")\n49:     )\n50:     expires_at: Mapped[datetime] = mapped_column(\n51:         DateTime(timezone=True), nullable=False\n52:     )\n53:     # ``true`` while the handler is still running, flipped to ``false``\n54:     # by ``idempotency_record`` once the response body is durable.\n55:     # Closes the race where two concurrent requests with the same key\n56:     # both miss the cache and both execute the handler.\n57:     is_pending: Mapped[bool] = mapped_column(\n58:         Boolean, nullable=False, server_default=text(\"false\")\n59:     )\n\n(End of file - total 59 lines)\n</content>","metadata":{"preview":"\"\"\"Idempotency inbox for Idempotency-Key replay (CAURA-601).\n\nA row per (tenant_id, idempotency_key) stores the request body hash\nand the response to replay. The hash guards against the same key\nbeing reused with a different body (which the client treats as a\nconflict) — that's the contract every idempotency-key standard\n(IETF draft, Stripe) agrees on.\n\nA short TTL keeps the table bounded; opportunistic cleanup or a\nperiodic job (tracked separately) prunes expired rows.\n\"\"\"\n\nfrom datetime import datetime\n\nfrom sqlalchemy import (\n    Boolean,\n    DateTime,\n    Index,\n    Integer,\n    PrimaryKeyConstraint,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/idempotency.py","text":"\"\"\"Idempotency inbox for Idempotency-Key replay (CAURA-601).\n\nA row per (tenant_id, idempotency_key) stores the request body hash\nand the response to replay. The hash guards against the same key\nbeing reused with a different body (which the client treats as a\nconflict) — that's the contract every idempotency-key standard\n(IETF draft, Stripe) agrees on.\n\nA short TTL keeps the table bounded; opportunistic cleanup or a\nperiodic job (tracked separately) prunes expired rows.\n\"\"\"\n\nfrom datetime import datetime\n\nfrom sqlalchemy import (\n    Boolean,\n    DateTime,\n    Index,\n    Integer,\n    PrimaryKeyConstraint,\n    Text,\n    text,\n)\nfrom sqlalchemy.dialects.postgresql import JSONB\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom common.models.base import Base\n\n\nclass IdempotencyResponse(Base):\n    __tablename__ = \"idempotency_responses\"\n    __table_args__ = (\n        PrimaryKeyConstraint(\n            \"tenant_id\", \"idempotency_key\", name=\"pk_idempotency_responses\"\n        ),\n        # TTL cleanup job scans by expires_at.\n        Index(\"ix_idempotency_responses_expires_at\", \"expires_at\"),\n    )\n\n    tenant_id: Mapped[str] = mapped_column(Text, nullable=False)\n    idempotency_key: Mapped[str] = mapped_column(Text, nullable=False)\n    request_hash: Mapped[str] = mapped_column(Text, nullable=False)\n    response_body: Mapped[dict] = mapped_column(\n        JSONB, nullable=False, server_default=text(\"'{}'::jsonb\")\n    )\n    status_code: Mapped[int] = mapped_column(Integer, nullable=False)\n    created_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), nullable=False, server_default=text(\"now()\")\n    )\n    expires_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), nullable=False\n    )\n    # ``true`` while the handler is still running, flipped to ``false``\n    # by ``idempotency_record`` once the response body is durable.\n    # Closes the race where two concurrent requests with the same key\n    # both miss the cache and both execute the handler.\n    is_pending: Mapped[bool] = mapped_column(\n        Boolean, nullable=False, server_default=text(\"false\")\n    )","lineStart":1,"lineEnd":59,"totalLines":59,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/models/idempotency.py","time":{"start":1780728859604,"end":1780728859629}},"metadata":{"openai":{"itemId":"fc_04e51764e092a4a7016a23c41a3b8081919f96ab87d5652d22"}},"id":"prt_e9bb60bd2001XIKWBhZh7jrCXX","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb5e0c40015pyQypwsTnfEFA"}}
{"type":"tool_use","timestamp":1780728859632,"sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","part":{"type":"tool","tool":"read","callID":"call_e5qtymhaIQ3PQGsnY7YAE6xQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Idempotency-Key helper (CAURA-601).\n2: \n3: Per-route opt-in: handlers call :func:`idempotency_for` after auth\n4: has enforced the tenant, get back a :class:`IdempotencyGuard`, check\n5: ``guard.cached_replay`` for a cached response, and call\n6: ``guard.record(...)`` after running the work.\n7: \n8: Not a middleware — slowapi + FastAPI already handle the request/response\n9: pipeline, and per-handler wiring keeps the replay contract explicit at\n10: the route level. The boilerplate is five lines per decorated handler.\n11: \"\"\"\n12: \n13: from __future__ import annotations\n14: \n15: import asyncio\n16: import hashlib\n17: import logging\n18: from datetime import UTC, datetime, timedelta\n19: from typing import Any, Literal\n20: \n21: from fastapi import HTTPException, Request\n22: \n23: from core_api.clients.storage_client import get_storage_client\n24: from core_api.config import settings\n25: \n26: logger = logging.getLogger(__name__)\n27: \n28: IDEMPOTENCY_HEADER = \"Idempotency-Key\"\n29: # Matches Stripe's limit. Guards the `Text` column against oversized\n30: # values from buggy or adversarial clients before it reaches storage.\n31: MAX_IDEMPOTENCY_KEY_LEN = 255\n32: \n33: # Poll cadence + budget while waiting for a concurrent holder of the\n34: # same key to finish. Total wait =\n35: # ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n36: # enough to absorb a typical write pipeline (~2-5s end-to-end) without\n37: # holding the second request indefinitely; on timeout the caller gets\n38: # 409 and can retry.\n39: _CLAIM_POLL_INTERVAL_SECONDS = 0.5\n40: _CLAIM_POLL_MAX_ATTEMPTS = 20\n41: \n42: # Sentinels ``_poll_until_complete`` may return alongside the\n43: # completed row dict and ``None`` (budget exhausted):\n44: #\n45: # - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n46: #   or pending TTL elapsed). Caller can tell the client to retry as\n47: #   a fresh request.\n48: # - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n49: #   timeout, network). Caller should respond 503 — retrying into a\n50: #   downed cluster wastes the client's retry budget.\n51: _POLL_VANISHED = \"vanished\"\n52: _POLL_STORAGE_ERROR = \"storage_error\"\n53: \n54: # Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n55: # header is absent. ``Idempotency-Key`` (header) remains the\n56: # canonical form per the IETF draft; the body fallback exists for\n57: # SDK / load-test clients that can't easily set headers per request.\n58: # ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n59: # alias the loadtest harness uses.\n60: _IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n61: \n62: \n63: def idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n64:     \"\"\"Extract the idempotency key from a request body's ``metadata``\n65:     dict, if present. Returns ``None`` if metadata is missing/empty\n66:     or no recognised key field is set.\n67: \n68:     The header takes precedence — call this only as a fallback when\n69:     the header is absent. Routes that wire idempotency wire it once\n70:     via:\n71: \n72:         key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n73:     \"\"\"\n74:     if not metadata:\n75:         return None\n76:     for field in _IDEMPOTENCY_BODY_FIELDS:\n77:         value = metadata.get(field)\n78:         # Return the un-stripped value: ``idempotency_for`` hashes the\n79:         # RAW request bytes for replay-conflict detection, so any\n80:         # normalisation here would let two byte-identical retries —\n81:         # one with surrounding whitespace, one without — hit the same\n82:         # cache bucket but mismatch on body hash, triggering a false\n83:         # 422. The blank guard still rejects pure-whitespace values.\n84:         if isinstance(value, str) and value.strip():\n85:             return value\n86:     return None\n87: \n88: \n89: class IdempotencyGuard:\n90:     \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n91: \n92:     def __init__(\n93:         self,\n94:         tenant_id: str,\n95:         key: str,\n96:         request_hash: str,\n97:         cached: dict | None,\n98:     ) -> None:\n99:         self.tenant_id = tenant_id\n100:         self.key = key\n101:         self.request_hash = request_hash\n102:         self._cached = cached\n103: \n104:     @property\n105:     def cached_replay(self) -> tuple[Any, int] | None:\n106:         \"\"\"``(response_body, status_code)`` if the same key + body was\n107:         served before and is still within TTL; else ``None``.\"\"\"\n108:         if self._cached is None:\n109:             return None\n110:         return self._cached[\"response_body\"], self._cached[\"status_code\"]\n111: \n112:     async def record(self, response_body: Any, status_code: int = 200) -> None:\n113:         \"\"\"Cache the response body under this key. Failures are logged,\n114:         not raised — the client already has the live response; losing the\n115:         cache only costs a chance at future dedup.\"\"\"\n116:         expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n117:         try:\n118:             await get_storage_client().upsert_idempotency(\n119:                 tenant_id=self.tenant_id,\n120:                 idempotency_key=self.key,\n121:                 request_hash=self.request_hash,\n122:                 response_body=response_body,\n123:                 status_code=status_code,\n124:                 expires_at=expires_at.isoformat(),\n125:             )\n126:         except Exception:\n127:             logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n128: \n129: \n130: async def idempotency_for(\n131:     request: Request,\n132:     tenant_id: str,\n133:     idempotency_key: str | None,\n134:     *,\n135:     source: Literal[\"header\", \"body\"] = \"header\",\n136: ) -> IdempotencyGuard | None:\n137:     \"\"\"Look up — and atomically claim — the inbox for (tenant, key).\n138: \n139:     Returns None if the key was absent. On a cache hit with a\n140:     *different* body hash, raises 422 — reusing the same key with\n141:     different content is explicitly a client error per the IETF\n142:     idempotency-key draft.\n143: \n144:     Call this inside a route handler *after* auth enforcement, so the\n145:     tenant_id passed here is already vetted.\n146: \n147:     ``source`` selects a transport-specific prefix (``\"header\"`` →\n148:     ``header:``, ``\"body\"`` → ``body:``) prepended before the lookup\n149:     so the same string value sent via different transports never\n150:     shares a cache bucket. Validation runs against the RAW key the\n151:     caller supplied; the prefix is added only for storage.\n152: \n153:     Body hashing note: uses raw request bytes. Clients retrying a write\n154:     MUST send byte-identical bodies (same JSON serializer, same key\n155:     ordering). Non-deterministic serialization will falsely flag a\n156:     retry as a conflict. Matches Stripe and the IETF draft.\n157: \n158:     Concurrency: closes the race where two requests with the same key\n159:     arrive within milliseconds. The flow is lookup → claim → poll:\n160: \n161:     1. ``get_idempotency`` reads any existing row.\n162:     2. If a completed row matches the request hash, replay it.\n163:     3. If no row, ``claim_idempotency`` atomically inserts a pending\n164:        sentinel via INSERT ... ON CONFLICT DO NOTHING. The winning\n165:        caller proceeds with the handler; ``record()`` flips\n166:        ``is_pending`` to False.\n167:     4. If the claim collided (a concurrent caller raced ahead between\n168:        step 1 and step 3, or the row was pending in step 1), poll the\n169:        existing row until ``is_pending`` is False, then replay.\n170: \n171:     Storage outages degrade to \"no cache\" — a lost dedup opportunity\n172:     beats a blocked write.\n173:     \"\"\"\n174:     if not idempotency_key:\n175:         return None\n176:     if not idempotency_key.strip():\n177:         raise HTTPException(status_code=400, detail=\"Idempotency-Key must not be blank\")\n178:     if len(idempotency_key) > MAX_IDEMPOTENCY_KEY_LEN:\n179:         raise HTTPException(\n180:             status_code=400,\n181:             detail=f\"Idempotency-Key must be at most {MAX_IDEMPOTENCY_KEY_LEN} characters\",\n182:         )\n183: \n184:     namespaced_key = f\"{source}:{idempotency_key}\"\n185: \n186:     body_bytes = await request.body()\n187:     request_hash = hashlib.sha256(body_bytes).hexdigest()\n188: \n189:     sc = get_storage_client()\n190: \n191:     cached: dict | None\n192:     try:\n193:         cached = await sc.get_idempotency(tenant_id, namespaced_key)\n194:     except Exception:\n195:         logger.warning(\"Idempotency lookup failed (degrading to no-cache)\", exc_info=True)\n196:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n197: \n198:     if cached and not cached.get(\"is_pending\", False):\n199:         if cached[\"request_hash\"] != request_hash:\n200:             raise HTTPException(\n201:                 status_code=422,\n202:                 detail=\"Idempotency-Key reused with a different request body\",\n203:             )\n204:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=cached)\n205: \n206:     if cached and cached.get(\"is_pending\", False):\n207:         # Hash-check before polling: a different body for the same key is\n208:         # always a 422 regardless of the in-flight handler's outcome,\n209:         # and the pending row already carries the original hash. Without\n210:         # this short-circuit the loser burns the full poll budget before\n211:         # getting the same 422.\n212:         if cached[\"request_hash\"] != request_hash:\n213:             raise HTTPException(\n214:                 status_code=422,\n215:                 detail=\"Idempotency-Key reused with a different request body\",\n216:             )\n217:         completed = await _poll_until_complete(sc, tenant_id, namespaced_key)\n218:         if completed is None:\n219:             raise HTTPException(\n220:                 status_code=409,\n221:                 detail=\"Idempotency-Key still in progress; retry shortly\",\n222:             )\n223:         if completed == _POLL_STORAGE_ERROR:\n224:             raise HTTPException(\n225:                 status_code=503,\n226:                 detail=\"Upstream storage unavailable; retry later\",\n227:             )\n228:         if completed == _POLL_VANISHED:\n229:             raise HTTPException(\n230:                 status_code=409,\n231:                 detail=\"Previous request did not complete; safe to retry\",\n232:             )\n233:         assert isinstance(completed, dict)  # narrow for mypy after sentinel checks\n234:         if completed[\"request_hash\"] != request_hash:\n235:             raise HTTPException(\n236:                 status_code=422,\n237:                 detail=\"Idempotency-Key reused with a different request body\",\n238:             )\n239:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=completed)\n240: \n241:     # Claim with a short pending-TTL. ``record()`` later extends to the\n242:     # full TTL on success. A crashed handler leaves the row pending only\n243:     # until ``idempotency_pending_ttl_seconds`` elapses; after that the\n244:     # expired-row reclaim path in ``idempotency_claim`` lets a fresh\n245:     # request take over the key automatically.\n246:     pending_expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_pending_ttl_seconds)\n247:     try:\n248:         claimed, existing = await sc.claim_idempotency(\n249:             tenant_id=tenant_id,\n250:             idempotency_key=namespaced_key,\n251:             request_hash=request_hash,\n252:             expires_at=pending_expires_at.isoformat(),\n253:         )\n254:     except Exception:\n255:         logger.warning(\"Idempotency claim failed (degrading to no-cache)\", exc_info=True)\n256:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n257: \n258:     if claimed:\n259:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n260: \n\n(Showing lines 1-260 of 333. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","text":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n\nfrom fastapi import HTTPException, Request\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\nIDEMPOTENCY_HEADER = \"Idempotency-Key\"\n# Matches Stripe's limit. Guards the `Text` column against oversized\n# values from buggy or adversarial clients before it reaches storage.\nMAX_IDEMPOTENCY_KEY_LEN = 255\n\n# Poll cadence + budget while waiting for a concurrent holder of the\n# same key to finish. Total wait =\n# ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n# enough to absorb a typical write pipeline (~2-5s end-to-end) without\n# holding the second request indefinitely; on timeout the caller gets\n# 409 and can retry.\n_CLAIM_POLL_INTERVAL_SECONDS = 0.5\n_CLAIM_POLL_MAX_ATTEMPTS = 20\n\n# Sentinels ``_poll_until_complete`` may return alongside the\n# completed row dict and ``None`` (budget exhausted):\n#\n# - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n#   or pending TTL elapsed). Caller can tell the client to retry as\n#   a fresh request.\n# - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n#   timeout, network). Caller should respond 503 — retrying into a\n#   downed cluster wastes the client's retry budget.\n_POLL_VANISHED = \"vanished\"\n_POLL_STORAGE_ERROR = \"storage_error\"\n\n# Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n# header is absent. ``Idempotency-Key`` (header) remains the\n# canonical form per the IETF draft; the body fallback exists for\n# SDK / load-test clients that can't easily set headers per request.\n# ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n# alias the loadtest harness uses.\n_IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n\n\ndef idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n    \"\"\"Extract the idempotency key from a request body's ``metadata``\n    dict, if present. Returns ``None`` if metadata is missing/empty\n    or no recognised key field is set.\n\n    The header takes precedence — call this only as a fallback when\n    the header is absent. Routes that wire idempotency wire it once\n    via:\n\n        key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n    \"\"\"\n    if not metadata:\n        return None\n    for field in _IDEMPOTENCY_BODY_FIELDS:\n        value = metadata.get(field)\n        # Return the un-stripped value: ``idempotency_for`` hashes the\n        # RAW request bytes for replay-conflict detection, so any\n        # normalisation here would let two byte-identical retries —\n        # one with surrounding whitespace, one without — hit the same\n        # cache bucket but mismatch on body hash, triggering a false\n        # 422. The blank guard still rejects pure-whitespace values.\n        if isinstance(value, str) and value.strip():\n            return value\n    return None\n\n\nclass IdempotencyGuard:\n    \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n\n    def __init__(\n        self,\n        tenant_id: str,\n        key: str,\n        request_hash: str,\n        cached: dict | None,\n    ) -> None:\n        self.tenant_id = tenant_id\n        self.key = key\n        self.request_hash = request_hash\n        self._cached = cached\n\n    @property\n    def cached_replay(self) -> tuple[Any, int] | None:\n        \"\"\"``(response_body, status_code)`` if the same key + body was\n        served before and is still within TTL; else ``None``.\"\"\"\n        if self._cached is None:\n            return None\n        return self._cached[\"response_body\"], self._cached[\"status_code\"]\n\n    async def record(self, response_body: Any, status_code: int = 200) -> None:\n        \"\"\"Cache the response body under this key. Failures are logged,\n        not raised — the client already has the live response; losing the\n        cache only costs a chance at future dedup.\"\"\"\n        expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n        try:\n            await get_storage_client().upsert_idempotency(\n                tenant_id=self.tenant_id,\n                idempotency_key=self.key,\n                request_hash=self.request_hash,\n                response_body=response_body,\n                status_code=status_code,\n                expires_at=expires_at.isoformat(),\n            )\n        except Exception:\n            logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n\n\nasync def idempotency_for(\n    request: Request,\n    tenant_id: str,\n    idempotency_key: str | None,\n    *,\n    source: Literal[\"header\", \"body\"] = \"header\",\n) -> IdempotencyGuard | None:\n    \"\"\"Look up — and atomically claim — the inbox for (tenant, key).\n\n    Returns None if the key was absent. On a cache hit with a\n    *different* body hash, raises 422 — reusing the same key with\n    different content is explicitly a client error per the IETF\n    idempotency-key draft.\n\n    Call this inside a route handler *after* auth enforcement, so the\n    tenant_id passed here is already vetted.\n\n    ``source`` selects a transport-specific prefix (``\"header\"`` →\n    ``header:``, ``\"body\"`` → ``body:``) prepended before the lookup\n    so the same string value sent via different transports never\n    shares a cache bucket. Validation runs against the RAW key the\n    caller supplied; the prefix is added only for storage.\n\n    Body hashing note: uses raw request bytes. Clients retrying a write\n    MUST send byte-identical bodies (same JSON serializer, same key\n    ordering). Non-deterministic serialization will falsely flag a\n    retry as a conflict. Matches Stripe and the IETF draft.\n\n    Concurrency: closes the race where two requests with the same key\n    arrive within milliseconds. The flow is lookup → claim → poll:\n\n    1. ``get_idempotency`` reads any existing row.\n    2. If a completed row matches the request hash, replay it.\n    3. If no row, ``claim_idempotency`` atomically inserts a pending\n       sentinel via INSERT ... ON CONFLICT DO NOTHING. The winning\n       caller proceeds with the handler; ``record()`` flips\n       ``is_pending`` to False.\n    4. If the claim collided (a concurrent caller raced ahead between\n       step 1 and step 3, or the row was pending in step 1), poll the\n       existing row until ``is_pending`` is False, then replay.\n\n    Storage outages degrade to \"no cache\" — a lost dedup opportunity\n    beats a blocked write.\n    \"\"\"\n    if not idempotency_key:\n        return None\n    if not idempotency_key.strip():\n        raise HTTPException(status_code=400, detail=\"Idempotency-Key must not be blank\")\n    if len(idempotency_key) > MAX_IDEMPOTENCY_KEY_LEN:\n        raise HTTPException(\n            status_code=400,\n            detail=f\"Idempotency-Key must be at most {MAX_IDEMPOTENCY_KEY_LEN} characters\",\n        )\n\n    namespaced_key = f\"{source}:{idempotency_key}\"\n\n    body_bytes = await request.body()\n    request_hash = hashlib.sha256(body_bytes).hexdigest()\n\n    sc = get_storage_client()\n\n    cached: dict | None\n    try:\n        cached = await sc.get_idempotency(tenant_id, namespaced_key)\n    except Exception:\n        logger.warning(\"Idempotency lookup failed (degrading to no-cache)\", exc_info=True)\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n\n    if cached and not cached.get(\"is_pending\", False):\n        if cached[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=cached)\n\n    if cached and cached.get(\"is_pending\", False):\n        # Hash-check before polling: a different body for the same key is\n        # always a 422 regardless of the in-flight handler's outcome,\n        # and the pending row already carries the original hash. Without\n        # this short-circuit the loser burns the full poll budget before\n        # getting the same 422.\n        if cached[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        completed = await _poll_until_complete(sc, tenant_id, namespaced_key)\n        if completed is None:\n            raise HTTPException(\n                status_code=409,\n                detail=\"Idempotency-Key still in progress; retry shortly\",\n            )\n        if completed == _POLL_STORAGE_ERROR:\n            raise HTTPException(\n                status_code=503,\n                detail=\"Upstream storage unavailable; retry later\",\n            )\n        if completed == _POLL_VANISHED:\n            raise HTTPException(\n                status_code=409,\n                detail=\"Previous request did not complete; safe to retry\",\n            )\n        assert isinstance(completed, dict)  # narrow for mypy after sentinel checks\n        if completed[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=completed)\n\n    # Claim with a short pending-TTL. ``record()`` later extends to the\n    # full TTL on success. A crashed handler leaves the row pending only\n    # until ``idempotency_pending_ttl_seconds`` elapses; after that the\n    # expired-row reclaim path in ``idempotency_claim`` lets a fresh\n    # request take over the key automatically.\n    pending_expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_pending_ttl_seconds)\n    try:\n        claimed, existing = await sc.claim_idempotency(\n            tenant_id=tenant_id,\n            idempotency_key=namespaced_key,\n            request_hash=request_hash,\n            expires_at=pending_expires_at.isoformat(),\n        )\n    except Exception:\n        logger.warning(\"Idempotency claim failed (degrading to no-cache)\", exc_info=True)\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n\n    if claimed:\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n","lineStart":1,"lineEnd":260,"totalLines":333,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","time":{"start":1780728859600,"end":1780728859631}},"metadata":{"openai":{"itemId":"fc_04e51764e092a4a7016a23c41a3b708191a235ee6868e84fe1"}},"id":"prt_e9bb60bbd001PZPHUkRhVzRgxA","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb5e0c40015pyQypwsTnfEFA"}}
