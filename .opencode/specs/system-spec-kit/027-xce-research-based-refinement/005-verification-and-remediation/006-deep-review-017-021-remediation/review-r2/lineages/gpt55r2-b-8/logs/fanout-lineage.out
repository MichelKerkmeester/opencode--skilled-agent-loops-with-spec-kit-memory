medPath);\n\n    const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n    if (hasTraversalAfterResolve) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    // Resolve symlinks so traversal checks apply to canonical targets.\n    let realPath: string;\n    try {\n      realPath = fs.realpathSync(resolvedPath);\n    } catch {\n      // Fall back to resolvedPath during pre-validation when target does not yet exist.\n      realPath = resolvedPath;\n    }\n\n    const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n      realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n    ));\n    if (!isWithinAllowedBase) {\n      invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n      continue;\n    }\n\n    normalizedPaths.push(realPath);\n  }\n\n  if (invalidPaths.length > 0) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_start',\n      error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n      code: 'E_VALIDATION',\n      details: {\n        allowedBasePathCount: allowedBasePaths.length,\n        allowedPathPolicy: 'configured-memory-roots',\n        rejectedCount: invalidPaths.length,\n      },\n      recovery: {\n        hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n        actions: ['Use absolute paths rooted in the configured memory base path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const deduplicatedPaths: string[] = [];\n  const seenPaths = new Set<string>();\n  let duplicatePathCount = 0;\n\n  for (const normalizedPath of normalizedPaths) {\n    if (seenPaths.has(normalizedPath)) {\n      duplicatePathCount++;\n      continue;\n    }\n\n    seenPaths.add(normalizedPath);\n    deduplicatedPaths.push(normalizedPath);\n  }\n\n  paths = deduplicatedPaths;\n\n  const jobId = createJobId();\n  const job = await createIngestJob({\n    id: jobId,\n    paths,\n    specFolder: args.specFolder,\n    governance: governedIngest ? governanceDecision : null,\n  });\n\n  enqueueIngestJob(job.id);\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_start',\n    summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n    data: {\n      jobId: job.id,\n      state: job.state,\n      filesTotal: job.filesTotal,\n      acceptedPathCount: paths.length,\n      rejectedPathCount: overlengthPaths.length,\n      ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n      ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n    },\n    hints: [\n      'Use memory_ingest_status with jobId to poll progress',\n      'Use memory_ingest_cancel with jobId to stop processing',\n      ...(duplicatePathCount > 0\n        ? ['Duplicate input paths were deduplicated before queueing']\n        : []),\n      ...(overlengthPaths.length > 0\n        ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n        : []),\n    ],\n  });\n}\n\nasync function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n  await checkDatabaseUpdated();","lineStart":160,"lineEnd":289,"totalLines":375,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","time":{"start":1781763764687,"end":1781763764700}},"metadata":{"openai":{"itemId":"fc_0b38cb568e535529016a338eb494608191ba8a5aa30727fa88"}},"id":"prt_ed96571cc001LZiYzqknGRlqMK","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed96528950012cNmNhaKI9QDaG"}}
{"type":"tool_use","timestamp":1781763764709,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_TsRZn8qPskuzA1pZhNgnDHqD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n\n(Showing lines 1-240 of 650. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n","lineStart":1,"lineEnd":240,"totalLines":650,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781763764689,"end":1781763764701}},"metadata":{"openai":{"itemId":"fc_0b38cb568e535529016a338eb4946481919eb6dbc29f2140ce"}},"id":"prt_ed96571cf0014T8KK6V6mFIRRJ","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed96528950012cNmNhaKI9QDaG"}}
{"type":"tool_use","timestamp":1781763764722,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_14Ac4mvHJGgIbtORlr6bRisc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":3160,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n3160:     provenanceActor,\n3161:     governedAt,\n3162:     retentionPolicy,\n3163:     deleteAfter,\n3164:   } = args;\n3165:   const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n3166:   const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n3167: \n3168:   // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n3169:   // Return a classified validation error instead of a bare throw, which the dispatcher would\n3170:   // otherwise flatten into the generic \"unexpected error\" (E081).\n3171:   if (!file_path || typeof file_path !== 'string') {\n3172:     return createMCPErrorResponse({\n3173:       tool: 'memory_save',\n3174:       error: 'filePath is required and must be a string',\n3175:       code: 'E089',\n3176:       details: { requestId },\n3177:       recovery: {\n3178:         hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n3179:         actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n3180:         severity: 'warning',\n3181:       },\n3182:     });\n3183:   }\n3184: \n3185:   await checkDatabaseUpdated();\n3186: \n3187:   const validatedPath: string = validateFilePathLocal(file_path);\n3188:   const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n3189:   const database = requireDb();\n3190: \n3191:   if (!shouldIndexForMemory(canonicalValidatedPath)) {\n3192:     return createIndexScopeExcludedResponse(requestId, canonicalValidatedPath, validatedPath);\n3193:   }\n3194: \n3195:   // A non-canonical target (e.g. a scratch file outside specs/**) returns a clear\n3196:   // validation error rather than a bare throw the dispatcher would surface as E081.\n3197:   if (!memoryParser.isMemoryFile(validatedPath)) {\n3198:     return createMCPErrorResponse({\n3199:       tool: 'memory_save',\n3200:       error: 'File must be a canonical spec document under specs/**/ (spec.md, plan.md, tasks.md, checklist.md, decision-record.md, implementation-summary.md, handover.md, research.md, resource-map.md, review-report.md, description.json, graph-metadata.json) or a constitutional memory under .opencode/skills/*/constitutional/',\n3201:       code: 'E089',\n3202:       details: { requestId, filePath: validatedPath },\n3203:       recovery: {\n3204:         hint: 'Save a canonical spec document or constitutional memory; scratch files outside specs/** are not indexable.',\n3205:         actions: ['Move the content into a spec folder under specs/** or .opencode/specs/**', 'Retry memory_save with the canonical path'],\n3206:         severity: 'warning',\n3207:       },\n3208:     });\n3209:   }\n3210: \n3211:   // Fail fast with a clear message when a spec doc's folder lacks both structural\n3212:   // metadata files, instead of the generic save \"unexpected error\" (E081).\n3213:   if (path.basename(canonicalValidatedPath) !== 'description.json'\n3214:     && path.basename(canonicalValidatedPath) !== 'graph-metadata.json'\n3215:     && !canonicalValidatedPath.includes('/constitutional/')) {\n3216:     const specFolderDir = path.dirname(canonicalValidatedPath);\n3217:     const missingMetadata = ['description.json', 'graph-metadata.json']\n3218:       .filter((name) => !fs.existsSync(path.join(specFolderDir, name)));\n3219:     if (missingMetadata.length === 2) {\n3220:       return createMCPErrorResponse({\n3221:         tool: 'memory_save',\n3222:         error: `Spec folder is missing required metadata (${missingMetadata.join(', ')}): ${specFolderDir}`,\n3223:         code: 'E089',\n3224:         details: { requestId, filePath: canonicalValidatedPath, missingMetadata },\n3225:         recovery: {\n3226:           hint: 'Generate the spec-folder metadata before indexing its other documents.',\n3227:           actions: ['Run generate-context.js / generate-description.js for this spec folder', 'Then retry memory_save'],\n3228:           severity: 'warning',\n3229:         },\n3230:       });\n3231:     }\n3232:   }\n3233: \n3234:   if (typeof database.exec === 'function') {\n3235:     ensureGovernanceRuntime(database);\n3236:   }\n3237: \n3238:   const governanceDecision = validateGovernedIngest({\n3239:     tenantId,\n3240:     userId,\n3241:     agentId,\n3242:     sessionId,\n3243:     provenanceSource,\n3244:     provenanceActor,\n3245:     governedAt,\n3246:     retentionPolicy,\n3247:     deleteAfter,\n3248:   });\n3249: \n3250:   if (!governanceDecision.allowed) {\n3251:     recordGovernanceAudit(database, {\n3252:       action: 'memory_save',\n3253:       decision: 'deny',\n3254:       tenantId,\n3255:       userId,\n3256:       agentId,\n3257:       sessionId,\n3258:       reason: governanceDecision.reason ?? 'governance_rejected',\n3259:       metadata: { issues: governanceDecision.issues },\n3260:     });\n3261:     // Surface the governance rejection with its own code + issue list instead of a bare\n3262:     // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n3263:     return createMCPErrorResponse({\n3264:       tool: 'memory_save',\n3265:       error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n3266:       code: 'E085',\n3267:       details: { requestId, issues: governanceDecision.issues },\n3268:       recovery: {\n3269:         hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n3270:         actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n3271:         severity: 'warning',\n3272:       },\n3273:     });\n3274:   }\n3275: \n3276:   // Shared dry-run response builder — both the skipPreflight and post-preflight\n3277:   // dry-run branches delegate here to prevent near-duplicate envelope drift.\n3278:   async function buildDryRunResponse(\n3279:     preparedDryRun: PreparedParsedMemory,\n3280:     parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n3281:     preflightValidation: {\n3282:       skipped: boolean;\n3283:       errors: preflight.PreflightIssue[];\n3284:       warnings: preflight.PreflightResult['warnings'];\n3285:       details: Record<string, unknown>;\n3286:       wouldPass: boolean;\n3287:     },\n3288:   ) {\n3289:     const templateContractPass = preparedDryRun.templateContract.valid\n3290:       || shouldBypassTemplateContract(\n3291:         preparedDryRun.sourceClassification,\n3292:         preparedDryRun.sufficiencyResult,\n3293:         preparedDryRun.templateContract,\n3294:         preparedDryRun.specDocHealth,\n3295:         preparedDryRun.parsed.documentType,\n3296:       );\n3297:     const bypassMode = shouldBypassTemplateContract(\n3298:       preparedDryRun.sourceClassification,\n3299:       preparedDryRun.sufficiencyResult,\n\n(Showing lines 3160-3299 of 4082. Use offset=3300 to continue.)\n</content>","metadata":{"preview":"    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  } = args;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n  // Return a classified validation error instead of a bare throw, which the dispatcher would\n  // otherwise flatten into the generic \"unexpected error\" (E081).\n  if (!file_path || typeof file_path !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'filePath is required and must be a string',\n      code: 'E089',\n      details: { requestId },\n      recovery: {\n        hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n        actions: ['Provide a non-empty filePath string', 'Retry memory_save'],","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  } = args;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n  // Return a classified validation error instead of a bare throw, which the dispatcher would\n  // otherwise flatten into the generic \"unexpected error\" (E081).\n  if (!file_path || typeof file_path !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'filePath is required and must be a string',\n      code: 'E089',\n      details: { requestId },\n      recovery: {\n        hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n        actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const validatedPath: string = validateFilePathLocal(file_path);\n  const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n  const database = requireDb();\n\n  if (!shouldIndexForMemory(canonicalValidatedPath)) {\n    return createIndexScopeExcludedResponse(requestId, canonicalValidatedPath, validatedPath);\n  }\n\n  // A non-canonical target (e.g. a scratch file outside specs/**) returns a clear\n  // validation error rather than a bare throw the dispatcher would surface as E081.\n  if (!memoryParser.isMemoryFile(validatedPath)) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'File must be a canonical spec document under specs/**/ (spec.md, plan.md, tasks.md, checklist.md, decision-record.md, implementation-summary.md, handover.md, research.md, resource-map.md, review-report.md, description.json, graph-metadata.json) or a constitutional memory under .opencode/skills/*/constitutional/',\n      code: 'E089',\n      details: { requestId, filePath: validatedPath },\n      recovery: {\n        hint: 'Save a canonical spec document or constitutional memory; scratch files outside specs/** are not indexable.',\n        actions: ['Move the content into a spec folder under specs/** or .opencode/specs/**', 'Retry memory_save with the canonical path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Fail fast with a clear message when a spec doc's folder lacks both structural\n  // metadata files, instead of the generic save \"unexpected error\" (E081).\n  if (path.basename(canonicalValidatedPath) !== 'description.json'\n    && path.basename(canonicalValidatedPath) !== 'graph-metadata.json'\n    && !canonicalValidatedPath.includes('/constitutional/')) {\n    const specFolderDir = path.dirname(canonicalValidatedPath);\n    const missingMetadata = ['description.json', 'graph-metadata.json']\n      .filter((name) => !fs.existsSync(path.join(specFolderDir, name)));\n    if (missingMetadata.length === 2) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `Spec folder is missing required metadata (${missingMetadata.join(', ')}): ${specFolderDir}`,\n        code: 'E089',\n        details: { requestId, filePath: canonicalValidatedPath, missingMetadata },\n        recovery: {\n          hint: 'Generate the spec-folder metadata before indexing its other documents.',\n          actions: ['Run generate-context.js / generate-description.js for this spec folder', 'Then retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  if (typeof database.exec === 'function') {\n    ensureGovernanceRuntime(database);\n  }\n\n  const governanceDecision = validateGovernedIngest({\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  });\n\n  if (!governanceDecision.allowed) {\n    recordGovernanceAudit(database, {\n      action: 'memory_save',\n      decision: 'deny',\n      tenantId,\n      userId,\n      agentId,\n      sessionId,\n      reason: governanceDecision.reason ?? 'governance_rejected',\n      metadata: { issues: governanceDecision.issues },\n    });\n    // Surface the governance rejection with its own code + issue list instead of a bare\n    // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n      code: 'E085',\n      details: { requestId, issues: governanceDecision.issues },\n      recovery: {\n        hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n        actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Shared dry-run response builder — both the skipPreflight and post-preflight\n  // dry-run branches delegate here to prevent near-duplicate envelope drift.\n  async function buildDryRunResponse(\n    preparedDryRun: PreparedParsedMemory,\n    parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n    preflightValidation: {\n      skipped: boolean;\n      errors: preflight.PreflightIssue[];\n      warnings: preflight.PreflightResult['warnings'];\n      details: Record<string, unknown>;\n      wouldPass: boolean;\n    },\n  ) {\n    const templateContractPass = preparedDryRun.templateContract.valid\n      || shouldBypassTemplateContract(\n        preparedDryRun.sourceClassification,\n        preparedDryRun.sufficiencyResult,\n        preparedDryRun.templateContract,\n        preparedDryRun.specDocHealth,\n        preparedDryRun.parsed.documentType,\n      );\n    const bypassMode = shouldBypassTemplateContract(\n      preparedDryRun.sourceClassification,\n      preparedDryRun.sufficiencyResult,","lineStart":3160,"lineEnd":3299,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781763764683,"end":1781763764719}},"metadata":{"openai":{"itemId":"fc_0b38cb568e535529016a338eb494588191b31da3139f6f16b6"}},"id":"prt_ed96571c9001uKkHZKqCHjU22i","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed96528950012cNmNhaKI9QDaG"}}
{"type":"tool_use","timestamp":1781763764722,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_P0hVaU8Eb5zhqk9W8BWFZnQB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2800,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2800:   }\n2801: \n2802:   return withSpecFolderLock(prepared.parsed.specFolder, runWithinSpecFolderLock);\n2803: }\n2804: \n2805: /* --- 8. INDEX MEMORY FILE --- */\n2806: \n2807: type BaseIndexMemoryFileOptions = {\n2808:   force?: boolean;\n2809:   parsedOverride?: ReturnType<typeof memoryParser.parseMemoryFile> | null;\n2810:   asyncEmbedding?: boolean;\n2811:   plannerMode?: AtomicSaveParams['plannerMode'];\n2812:   scope?: MemoryScopeMatch;\n2813:   qualityGateMode?: 'enforce' | 'warn-only';\n2814:   routing?: RoutedSaveOptions;\n2815:   provenance?: WriteProvenanceContext;\n2816:   // Validated governance decision threaded from the bulk scan/ingest paths so\n2817:   // their indexed rows carry the same provenance/retention/scope metadata the\n2818:   // direct memory_save path applies post-insert. Omitted for ungoverned saves.\n2819:   governance?: GovernanceDecision;\n2820: };\n2821: \n2822: type IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n2823:   origin?: IndexingOrigin;\n2824:   fromScan?: never;\n2825: };\n2826: \n2827: type LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n2828:   fromScan?: boolean;\n2829:   origin?: never;\n2830: };\n2831: \n2832: /** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\n2833: async function indexMemoryFile(\n2834:   filePath: string,\n2835:   {\n2836:     force = false,\n2837:     parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n2838:     asyncEmbedding = false,\n2839:     plannerMode,\n2840:     scope = {} as MemoryScopeMatch,\n2841:     qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n2842:     routing,\n2843:     provenance,\n2844:     governance,\n2845:     ...originOptions\n2846:   }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n2847: ): Promise<IndexResult> {\n2848:   // Reuse parsed content when provided by caller to avoid a second parse.\n2849:   const indexingOrigin = resolveIndexingOrigin(originOptions);\n2850:   const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n2851:   const database = requireDb();\n2852:   const prepared = prepareParsedMemoryForIndexing(parsed, database);\n2853:   const validation = prepared.validation;\n2854:   if (!validation.valid) {\n2855:     throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n2856:   }\n2857:   if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n2858:     console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n2859:   }\n2860: \n2861:   // When a governance decision is threaded in (bulk scan/ingest), derive the\n2862:   // scope tuple from it so the row is created under the governed scope, matching\n2863:   // how the direct save path seeds saveScope from governanceDecision.normalized.\n2864:   const effectiveScope: MemoryScopeMatch = governance\n2865:     ? {\n2866:         tenantId: governance.normalized.tenantId ?? null,\n2867:         userId: governance.normalized.userId ?? null,\n2868:         agentId: governance.normalized.agentId ?? null,\n2869:         sessionId: governance.normalized.sessionId ?? null,\n2870:       }\n2871:     : scope;\n2872:   const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n2873:     ? {\n2874:         provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n2875:         provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n2876:         tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n2877:       }\n2878:     : undefined);\n2879: \n2880:   const result = await processPreparedMemory(prepared, filePath, {\n2881:     force,\n2882:     asyncEmbedding,\n2883:     plannerMode,\n2884:     origin: indexingOrigin,\n2885:     persistQualityLoopContent: true,\n2886:     refreshFromDiskAfterLock: parsedOverride !== null,\n2887:     scope: effectiveScope,\n2888:     qualityGateMode,\n2889:     routing,\n2890:     provenance: effectiveProvenance,\n2891:   });\n2892: \n2893:   // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n2894:   // direct memory_save path so governed bulk/scan/async ingests are not silently\n2895:   // downgraded to ungoverned rows. Only for freshly written rows.\n2896:   if (governance && typeof result.id === 'number' && result.id > 0\n2897:     && result.status !== 'unchanged' && result.status !== 'duplicate') {\n2898:     applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n2899:   }\n2900: \n2901:   return result;\n2902: }\n2903: \n2904: async function indexMemoryFileFromScan(\n2905:   filePath: string,\n2906:   options: BaseIndexMemoryFileOptions = {},\n2907: ): Promise<IndexResult> {\n2908:   return indexMemoryFile(filePath, {\n2909:     ...options,\n2910:     origin: 'scan',\n2911:   });\n2912: }\n2913: \n2914: /* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n2915: \n2916: // Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n2917: // entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n2918: // slots free.\n2919: const MAX_BACKGROUND_ENRICHMENTS = 4;\n2920: let activeBackgroundEnrichments = 0;\n2921: const backgroundEnrichmentQueue: Array<() => void> = [];\n2922: \n2923: // Set during shutdown BEFORE closeDb. A deferred/queued enrichment run re-resolves the DB handle via\n2924: // requireDb(), which REOPENS a closed connection — so without this fence a run firing during the\n2925: // shutdown drain would reopen the DB and write fresh WAL frames after the TRUNCATE checkpoint, leaving\n2926: // a non-empty WAL at rest and defeating the close durability guarantee. Same hazard the fileWatcher\n2927: // and ingestWorker fences guard against.\n2928: let enrichmentShuttingDown = false;\n2929: \n2930: /**\n2931:  * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n2932:  * in-flight run bail before it touches the DB. Synchronous so fatalShutdown can call it in its\n2933:  * pre-close fence block, before any await lets a queued setImmediate run fire. Dropped rows remain\n2934:  * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n2935:  */\n2936: export function shutdownBackgroundEnrichment(): void {\n2937:   enrichmentShuttingDown = true;\n2938:   backgroundEnrichmentQueue.length = 0;\n2939: }\n2940: \n2941: // Bound the OVERFLOW queue, not just concurrency. A sustained live-save flood (saves arriving faster\n2942: // than the 4-wide drain) would otherwise grow the queue — and the parsed payload each entry retains —\n2943: // without bound. On overflow we DROP rather than push: the row is enrichment-pending in the commit\n2944: // transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n2945: // scheduler visible through memory_health (otherwise a stuck scheduler is a silent enrichment outage).\n2946: const MAX_QUEUED_ENRICHMENTS = 2000;\n2947: let enrichmentDroppedTotal = 0;\n2948: let enrichmentFailureTotal = 0;\n2949: let enrichmentLastError: string | null = null;\n2950: let enrichmentLastErrorAt: string | null = null;\n2951: let enrichmentSuppressedWarnings = 0;\n2952: \n2953: /** Scheduler observability snapshot for memory_health — module-local counters only, no DB access. */\n2954: export function getBackgroundEnrichmentStats(): {\n2955:   active: number;\n2956:   queued: number;\n2957:   max: number;\n2958:   maxQueued: number;\n2959:   droppedTotal: number;\n\n(Showing lines 2800-2959 of 4082. Use offset=2960 to continue.)\n</content>","metadata":{"preview":"  }\n\n  return withSpecFolderLock(prepared.parsed.specFolder, runWithinSpecFolderLock);\n}\n\n/* --- 8. INDEX MEMORY FILE --- */\n\ntype BaseIndexMemoryFileOptions = {\n  force?: boolean;\n  parsedOverride?: ReturnType<typeof memoryParser.parseMemoryFile> | null;\n  asyncEmbedding?: boolean;\n  plannerMode?: AtomicSaveParams['plannerMode'];\n  scope?: MemoryScopeMatch;\n  qualityGateMode?: 'enforce' | 'warn-only';\n  routing?: RoutedSaveOptions;\n  provenance?: WriteProvenanceContext;\n  // Validated governance decision threaded from the bulk scan/ingest paths so\n  // their indexed rows carry the same provenance/retention/scope metadata the\n  // direct memory_save path applies post-insert. Omitted for ungoverned saves.\n  governance?: GovernanceDecision;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"  }\n\n  return withSpecFolderLock(prepared.parsed.specFolder, runWithinSpecFolderLock);\n}\n\n/* --- 8. INDEX MEMORY FILE --- */\n\ntype BaseIndexMemoryFileOptions = {\n  force?: boolean;\n  parsedOverride?: ReturnType<typeof memoryParser.parseMemoryFile> | null;\n  asyncEmbedding?: boolean;\n  plannerMode?: AtomicSaveParams['plannerMode'];\n  scope?: MemoryScopeMatch;\n  qualityGateMode?: 'enforce' | 'warn-only';\n  routing?: RoutedSaveOptions;\n  provenance?: WriteProvenanceContext;\n  // Validated governance decision threaded from the bulk scan/ingest paths so\n  // their indexed rows carry the same provenance/retention/scope metadata the\n  // direct memory_save path applies post-insert. Omitted for ungoverned saves.\n  governance?: GovernanceDecision;\n};\n\ntype IndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  origin?: IndexingOrigin;\n  fromScan?: never;\n};\n\ntype LegacyIndexMemoryFileOptions = BaseIndexMemoryFileOptions & {\n  fromScan?: boolean;\n  origin?: never;\n};\n\n/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    provenance,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);\n  const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n  const database = requireDb();\n  const prepared = prepareParsedMemoryForIndexing(parsed, database);\n  const validation = prepared.validation;\n  if (!validation.valid) {\n    throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n  }\n  if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n    console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n  }\n\n  // When a governance decision is threaded in (bulk scan/ingest), derive the\n  // scope tuple from it so the row is created under the governed scope, matching\n  // how the direct save path seeds saveScope from governanceDecision.normalized.\n  const effectiveScope: MemoryScopeMatch = governance\n    ? {\n        tenantId: governance.normalized.tenantId ?? null,\n        userId: governance.normalized.userId ?? null,\n        agentId: governance.normalized.agentId ?? null,\n        sessionId: governance.normalized.sessionId ?? null,\n      }\n    : scope;\n  const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n    ? {\n        provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n        provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n        tool: indexingOrigin === 'scan' ? 'memory_index_scan' : 'memory_save',\n      }\n    : undefined);\n\n  const result = await processPreparedMemory(prepared, filePath, {\n    force,\n    asyncEmbedding,\n    plannerMode,\n    origin: indexingOrigin,\n    persistQualityLoopContent: true,\n    refreshFromDiskAfterLock: parsedOverride !== null,\n    scope: effectiveScope,\n    qualityGateMode,\n    routing,\n    provenance: effectiveProvenance,\n  });\n\n  // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n  // direct memory_save path so governed bulk/scan/async ingests are not silently\n  // downgraded to ungoverned rows. Only for freshly written rows.\n  if (governance && typeof result.id === 'number' && result.id > 0\n    && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n  }\n\n  return result;\n}\n\nasync function indexMemoryFileFromScan(\n  filePath: string,\n  options: BaseIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    ...options,\n    origin: 'scan',\n  });\n}\n\n/* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n\n// Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n// entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n// slots free.\nconst MAX_BACKGROUND_ENRICHMENTS = 4;\nlet activeBackgroundEnrichments = 0;\nconst backgroundEnrichmentQueue: Array<() => void> = [];\n\n// Set during shutdown BEFORE closeDb. A deferred/queued enrichment run re-resolves the DB handle via\n// requireDb(), which REOPENS a closed connection — so without this fence a run firing during the\n// shutdown drain would reopen the DB and write fresh WAL frames after the TRUNCATE checkpoint, leaving\n// a non-empty WAL at rest and defeating the close durability guarantee. Same hazard the fileWatcher\n// and ingestWorker fences guard against.\nlet enrichmentShuttingDown = false;\n\n/**\n * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n * in-flight run bail before it touches the DB. Synchronous so fatalShutdown can call it in its\n * pre-close fence block, before any await lets a queued setImmediate run fire. Dropped rows remain\n * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n */\nexport function shutdownBackgroundEnrichment(): void {\n  enrichmentShuttingDown = true;\n  backgroundEnrichmentQueue.length = 0;\n}\n\n// Bound the OVERFLOW queue, not just concurrency. A sustained live-save flood (saves arriving faster\n// than the 4-wide drain) would otherwise grow the queue — and the parsed payload each entry retains —\n// without bound. On overflow we DROP rather than push: the row is enrichment-pending in the commit\n// transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n// scheduler visible through memory_health (otherwise a stuck scheduler is a silent enrichment outage).\nconst MAX_QUEUED_ENRICHMENTS = 2000;\nlet enrichmentDroppedTotal = 0;\nlet enrichmentFailureTotal = 0;\nlet enrichmentLastError: string | null = null;\nlet enrichmentLastErrorAt: string | null = null;\nlet enrichmentSuppressedWarnings = 0;\n\n/** Scheduler observability snapshot for memory_health — module-local counters only, no DB access. */\nexport function getBackgroundEnrichmentStats(): {\n  active: number;\n  queued: number;\n  max: number;\n  maxQueued: number;\n  droppedTotal: number;","lineStart":2800,"lineEnd":2959,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781763764676,"end":1781763764721}},"metadata":{"openai":{"itemId":"fc_0b38cb568e535529016a338eb49444819198aadd2ca4802a83"}},"id":"prt_ed965718e001vLZxYWvxodBtBJ","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed96528950012cNmNhaKI9QDaG"}}
