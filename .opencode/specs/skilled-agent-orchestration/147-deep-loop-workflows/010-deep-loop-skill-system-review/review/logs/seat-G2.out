ver\"\n78: \n79: # Token presence only\n80: log \"-- ClickUp auth --\"\n81: if [ -n \"${CLICKUP_API_KEY:-}\" ]; then\n82:   ok \"CLICKUP_API_KEY env var present (value not shown)\"\n83: else\n84:   info \"CLICKUP_API_KEY env var not set\"\n85: fi\n86: \n87: log \"\"\n88: log \"Doctor is read-only. For setup and authentication, run install.sh or read INSTALL_GUIDE.md.\"\n89: exit 0\n\n(End of file - total 89 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# WHY: Read-only diagnostics for the ClickUp skill. It changes nothing and\n# installs nothing, and it never prints secrets.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n\n_c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\nlog()  { printf '%s\\n' \"$*\"; }\ninfo() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\nok()   { printf '%sâś“ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\nwarn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\nerr()  { printf '%sâś— %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n\nnode_major() {\n  command -v node >/dev/null 2>&1 || { printf ''; return 0; }\n  node -p 'process.versions.node.split(\".\")[0]' 2>/dev/null || printf ''\n}\n\nfirst_line_or_unknown() {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-click-up/scripts/doctor.sh","text":"#!/usr/bin/env bash\n# WHY: Read-only diagnostics for the ClickUp skill. It changes nothing and\n# installs nothing, and it never prints secrets.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n\n_c_red=$'\\033[31m'; _c_grn=$'\\033[32m'; _c_ylw=$'\\033[33m'; _c_dim=$'\\033[2m'; _c_rst=$'\\033[0m'\nlog()  { printf '%s\\n' \"$*\"; }\ninfo() { printf '%s%s%s\\n' \"$_c_dim\" \"$*\" \"$_c_rst\"; }\nok()   { printf '%sâś“ %s%s\\n' \"$_c_grn\" \"$*\" \"$_c_rst\"; }\nwarn() { printf '%s! %s%s\\n' \"$_c_ylw\" \"$*\" \"$_c_rst\" >&2; }\nerr()  { printf '%sâś— %s%s\\n' \"$_c_red\" \"$*\" \"$_c_rst\" >&2; }\n\nnode_major() {\n  command -v node >/dev/null 2>&1 || { printf ''; return 0; }\n  node -p 'process.versions.node.split(\".\")[0]' 2>/dev/null || printf ''\n}\n\nfirst_line_or_unknown() {\n  local value=\"$1\"\n  value=\"${value%%$'\\n'*}\"\n  [ -n \"$value\" ] && printf '%s' \"$value\" || printf 'version unknown'\n}\n\nlog \"== mcp-click-up doctor (read-only) ==\"\n\n# Platform and runtime\ncase \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\nif command -v node >/dev/null 2>&1; then\n  nm=\"$(node_major)\"\n  nv=\"$(node -v 2>/dev/null || printf 'unknown')\"\n  if [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null; then ok \"Node $nv\"; else warn \"Node $nv (<18)\"; fi\nelse warn \"Node not found\"; fi\ncommand -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n\n# Embedded CLI\nlog \"-- cupt CLI --\"\ninfo \"CLI package: cupt\"\nif command -v cupt >/dev/null 2>&1; then\n  cupt_version=\"$(cupt --version 2>/dev/null || true)\"\n  ok \"cupt: $(command -v cupt) ($(first_line_or_unknown \"$cupt_version\"))\"\nelse\n  warn \"cupt: not on PATH\"\nfi\n\n# Python package installer path\nlog \"-- Python package installer --\"\nif command -v pipx >/dev/null 2>&1; then\n  pipx_version=\"$(pipx --version 2>/dev/null || true)\"\n  ok \"pipx $(first_line_or_unknown \"$pipx_version\")\"\nelse\n  info \"pipx not found (recommended install path)\"\nfi\n\nif command -v python3 >/dev/null 2>&1; then\n  pip_version=\"$(python3 -m pip --version 2>/dev/null || true)\"\n  if [ -n \"$pip_version\" ]; then ok \"pip via python3: $(first_line_or_unknown \"$pip_version\")\"; else info \"pip via python3: not available\"; fi\nelif command -v pip3 >/dev/null 2>&1; then\n  pip_version=\"$(pip3 --version 2>/dev/null || true)\"\n  ok \"pip3 $(first_line_or_unknown \"$pip_version\")\"\nelif command -v pip >/dev/null 2>&1; then\n  pip_version=\"$(pip --version 2>/dev/null || true)\"\n  ok \"pip $(first_line_or_unknown \"$pip_version\")\"\nelse\n  warn \"pip not found\"\nfi\n\n# Optional MCP via Code Mode\nlog \"-- Optional ClickUp MCP via Code Mode --\"\nUTCP=\"$HERE/../../../../.utcp_config.json\"\nif [ -f \"$UTCP\" ]; then\n  if grep -qi '\"clickup' \"$UTCP\" 2>/dev/null; then ok \"Code Mode ClickUp manual registered in .utcp_config.json (for example clickup_official)\"; else info \"No ClickUp manual in .utcp_config.json\"; fi\nelse\n  info \".utcp_config.json not found at expected repo root\"\nfi\ninfo \"MCP package: @clickup/mcp-server\"\n\n# Token presence only\nlog \"-- ClickUp auth --\"\nif [ -n \"${CLICKUP_API_KEY:-}\" ]; then\n  ok \"CLICKUP_API_KEY env var present (value not shown)\"\nelse\n  info \"CLICKUP_API_KEY env var not set\"\nfi\n\nlog \"\"\nlog \"Doctor is read-only. For setup and authentication, run install.sh or read INSTALL_GUIDE.md.\"\nexit 0","lineStart":1,"lineEnd":89,"totalLines":89,"truncated":false}},"title":".opencode/skills/mcp-click-up/scripts/doctor.sh","time":{"start":1781544815527,"end":1781544815549}},"metadata":{"openai":{"itemId":"fc_0293ae9edfd8a8df016a30376d73b08191a847866d6e4e8dbd"}},"id":"prt_ecc588b91001zmLntmDWExe844","sessionID":"ses_133a82fbbffevAjtqNLJ4lglcd","messageID":"msg_ecc5844da001LfvSst96dr5Uq0"}}
{"type":"tool_use","timestamp":1781544815581,"sessionID":"ses_133a82fbbffevAjtqNLJ4lglcd","part":{"type":"tool","tool":"read","callID":"call_BaDCx74mJ1F6Z5Q8I2HjaZhO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # mcp-figma doctor: REPORT-ONLY diagnostics. Changes nothing, installs nothing,\n3: # never exposes the daemon token, never connects or patches.\n4: \n5: set -euo pipefail\n6: HERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7: # shellcheck source=_common.sh\n8: . \"$HERE/_common.sh\"\n9: \n10: log \"== mcp-figma doctor (read-only) ==\"\n11: \n12: # Platform / runtime\n13: case \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\n14: if command -v node >/dev/null 2>&1; then\n15:   nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null||echo none) (<18)\"\n16: else warn \"Node not found\"; fi\n17: command -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n18: \n19: # Binary identity (the collision check)\n20: log \"-- figma binary --\"\n21: if command -v figma-ds-cli >/dev/null 2>&1; then ok \"figma-ds-cli: $(command -v figma-ds-cli) ($(figma-ds-cli --version 2>/dev/null|head -1||echo '?'))\"; else info \"figma-ds-cli: not on PATH\"; fi\n22: if command -v figma-cli >/dev/null 2>&1; then ok \"figma-cli: $(command -v figma-cli) (silships repo build, if from upstream)\"; else info \"figma-cli: not on PATH (expected unless installed from the silships repo)\"; fi\n23: if command -v figma >/dev/null 2>&1; then warn \"a 'figma' command is on PATH, likely the UNRELATED unic/figma-cli, NOT the silships tool\"; fi\n24: if b=\"$(figma_bin)\"; then ok \"Resolved skill binary: $b\"; else err \"No silships figma binary resolved, run install.sh (do NOT 'npm i -g figma-cli')\"; fi\n25: \n26: # Figma Desktop\n27: log \"-- Figma Desktop --\"\n28: if p=\"$(figma_desktop_path)\"; then ok \"Found: $p\"; else warn \"Not found in /Applications or ~/Applications\"; fi\n29: if pgrep -x Figma >/dev/null 2>&1; then ok \"Figma Desktop: running\"; else info \"Figma Desktop: not running (CLI ops need it open with a file)\"; fi\n30: \n31: # Daemon\n32: log \"-- Daemon --\"\n33: if [ -f \"$DAEMON_TOKEN_FILE\" ]; then ok \"Token file present: $DAEMON_TOKEN_FILE (contents NOT shown)\"; else info \"No token file ($DAEMON_TOKEN_FILE), daemon not initialized yet\"; fi\n34: if [ -f \"$DAEMON_PID_FILE\" ]; then info \"PID file: $DAEMON_PID_FILE ($(cat \"$DAEMON_PID_FILE\" 2>/dev/null||echo '?'))\"; else info \"No PID file ($DAEMON_PID_FILE)\"; fi\n35: case \"$(port_listening \"$DAEMON_PORT\"; echo $?)\" in\n36:   0) ok \"Daemon port $DAEMON_PORT: LISTENING\";;\n37:   1) info \"Daemon port $DAEMON_PORT: not listening\";;\n38:   *) info \"Daemon port $DAEMON_PORT: unknown (lsof unavailable)\";;\n39: esac\n40: case \"$(port_listening \"$CDP_PORT\"; echo $?)\" in\n41:   0) info \"CDP port $CDP_PORT: LISTENING (yolo/remote-debugging active or another CDP client)\";;\n42:   1) info \"CDP port $CDP_PORT: not listening\";;\n43:   *) info \"CDP port $CDP_PORT: unknown\";;\n44: esac\n45: \n46: # Optional MCP (Code Mode, Framelink figma manual)\n47: log \"-- Optional Figma MCP via Code Mode (Framelink) --\"\n48: UTCP=\"$HERE/../../../../.utcp_config.json\"\n49: if [ -f \"$UTCP\" ]; then\n50:   if grep -q '\"figma\"' \"$UTCP\" 2>/dev/null; then ok \"Code Mode 'figma' manual registered in .utcp_config.json\"; else info \"No 'figma' manual in .utcp_config.json\"; fi\n51: else info \".utcp_config.json not found at expected repo root (optional MCP is opt-in)\"; fi\n52: info \"Token must be in .env as: figma_FIGMA_API_KEY=figd_... (Code Mode prefixes the manual name)\"\n53: \n54: log \"\"\n55: log \"Doctor is read-only. To connect: connect-safe.sh (safe) or connect-yolo.sh (gated patch).\"\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# mcp-figma doctor: REPORT-ONLY diagnostics. Changes nothing, installs nothing,\n# never exposes the daemon token, never connects or patches.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nlog \"== mcp-figma doctor (read-only) ==\"\n\n# Platform / runtime\ncase \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\nif command -v node >/dev/null 2>&1; then\n  nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null||echo none) (<18)\"\nelse warn \"Node not found\"; fi\ncommand -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n\n# Binary identity (the collision check)\nlog \"-- figma binary --\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/scripts/doctor.sh","text":"#!/usr/bin/env bash\n# mcp-figma doctor: REPORT-ONLY diagnostics. Changes nothing, installs nothing,\n# never exposes the daemon token, never connects or patches.\n\nset -euo pipefail\nHERE=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=_common.sh\n. \"$HERE/_common.sh\"\n\nlog \"== mcp-figma doctor (read-only) ==\"\n\n# Platform / runtime\ncase \"$(uname -s)\" in Darwin) ok \"Platform: macOS\";; *) warn \"Platform: $(uname -s) (unsupported/unverified)\";; esac\nif command -v node >/dev/null 2>&1; then\n  nm=\"$(node_major)\"; { [ -n \"$nm\" ] && [ \"$nm\" -ge 18 ] 2>/dev/null && ok \"Node $(node -v)\"; } || warn \"Node $(node -v 2>/dev/null||echo none) (<18)\"\nelse warn \"Node not found\"; fi\ncommand -v npm >/dev/null 2>&1 && ok \"npm $(npm -v)\" || warn \"npm not found\"\n\n# Binary identity (the collision check)\nlog \"-- figma binary --\"\nif command -v figma-ds-cli >/dev/null 2>&1; then ok \"figma-ds-cli: $(command -v figma-ds-cli) ($(figma-ds-cli --version 2>/dev/null|head -1||echo '?'))\"; else info \"figma-ds-cli: not on PATH\"; fi\nif command -v figma-cli >/dev/null 2>&1; then ok \"figma-cli: $(command -v figma-cli) (silships repo build, if from upstream)\"; else info \"figma-cli: not on PATH (expected unless installed from the silships repo)\"; fi\nif command -v figma >/dev/null 2>&1; then warn \"a 'figma' command is on PATH, likely the UNRELATED unic/figma-cli, NOT the silships tool\"; fi\nif b=\"$(figma_bin)\"; then ok \"Resolved skill binary: $b\"; else err \"No silships figma binary resolved, run install.sh (do NOT 'npm i -g figma-cli')\"; fi\n\n# Figma Desktop\nlog \"-- Figma Desktop --\"\nif p=\"$(figma_desktop_path)\"; then ok \"Found: $p\"; else warn \"Not found in /Applications or ~/Applications\"; fi\nif pgrep -x Figma >/dev/null 2>&1; then ok \"Figma Desktop: running\"; else info \"Figma Desktop: not running (CLI ops need it open with a file)\"; fi\n\n# Daemon\nlog \"-- Daemon --\"\nif [ -f \"$DAEMON_TOKEN_FILE\" ]; then ok \"Token file present: $DAEMON_TOKEN_FILE (contents NOT shown)\"; else info \"No token file ($DAEMON_TOKEN_FILE), daemon not initialized yet\"; fi\nif [ -f \"$DAEMON_PID_FILE\" ]; then info \"PID file: $DAEMON_PID_FILE ($(cat \"$DAEMON_PID_FILE\" 2>/dev/null||echo '?'))\"; else info \"No PID file ($DAEMON_PID_FILE)\"; fi\ncase \"$(port_listening \"$DAEMON_PORT\"; echo $?)\" in\n  0) ok \"Daemon port $DAEMON_PORT: LISTENING\";;\n  1) info \"Daemon port $DAEMON_PORT: not listening\";;\n  *) info \"Daemon port $DAEMON_PORT: unknown (lsof unavailable)\";;\nesac\ncase \"$(port_listening \"$CDP_PORT\"; echo $?)\" in\n  0) info \"CDP port $CDP_PORT: LISTENING (yolo/remote-debugging active or another CDP client)\";;\n  1) info \"CDP port $CDP_PORT: not listening\";;\n  *) info \"CDP port $CDP_PORT: unknown\";;\nesac\n\n# Optional MCP (Code Mode, Framelink figma manual)\nlog \"-- Optional Figma MCP via Code Mode (Framelink) --\"\nUTCP=\"$HERE/../../../../.utcp_config.json\"\nif [ -f \"$UTCP\" ]; then\n  if grep -q '\"figma\"' \"$UTCP\" 2>/dev/null; then ok \"Code Mode 'figma' manual registered in .utcp_config.json\"; else info \"No 'figma' manual in .utcp_config.json\"; fi\nelse info \".utcp_config.json not found at expected repo root (optional MCP is opt-in)\"; fi\ninfo \"Token must be in .env as: figma_FIGMA_API_KEY=figd_... (Code Mode prefixes the manual name)\"\n\nlog \"\"\nlog \"Doctor is read-only. To connect: connect-safe.sh (safe) or connect-yolo.sh (gated patch).\"","lineStart":1,"lineEnd":55,"totalLines":55,"truncated":false}},"title":".opencode/skills/mcp-figma/scripts/doctor.sh","time":{"start":1781544815539,"end":1781544815576}},"metadata":{"openai":{"itemId":"fc_0293ae9edfd8a8df016a30376d73c08191832e8d9c68b32bad"}},"id":"prt_ecc588baf001ggimUU0UG6c833","sessionID":"ses_133a82fbbffevAjtqNLJ4lglcd","messageID":"msg_ecc5844da001LfvSst96dr5Uq0"}}
