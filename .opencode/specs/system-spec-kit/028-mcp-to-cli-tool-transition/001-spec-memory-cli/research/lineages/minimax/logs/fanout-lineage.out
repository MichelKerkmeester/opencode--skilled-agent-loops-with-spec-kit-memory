{"type":"tool_use","timestamp":1780736179193,"sessionID":"ses_163de1863ffeLd3K58IkmWaFwL","part":{"type":"tool","tool":"read","callID":"call_function_gwk9f2hx7rqr_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/cli.ts","offset":100,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/cli.ts</path>\n<type>file</type>\n<content>\n100: }\n101: \n102: function printUsage(): void {\n103:   console.log(`\n104: spec-kit-cli — Bulk database operations for Spec Kit Memory\n105: \n106: Usage:\n107:   spec-kit-cli <command> [options]\n108: \n109: Commands:\n110:   stats                          Show memory database statistics\n111:   bulk-delete --tier <tier>      Delete memories by importance tier\n112:     [--folder <spec-folder>]       Optional: scope to a spec folder\n113:     [--older-than <days>]          Optional: only delete older than N days\n114:     [--dry-run]                    Preview without deleting\n115:     [--skip-checkpoint]            Optional: skip pre-delete checkpoint (blocked for constitutional/critical)\n116:   reindex [--force] [--eager-warmup]\n117:                                  Re-index memory files (lazy model load by default)\n118:   schema-downgrade --to 15 --confirm\n119:                                  Downgrade schema from v16 to v15 (targeted, destructive)\n120: \n121: Options:\n122:   --help                         Show this help message\n123:   --version                      Show CLI version\n124: \n125: Examples:\n126:   spec-kit-cli stats\n127:   spec-kit-cli bulk-delete --tier deprecated\n128:   spec-kit-cli bulk-delete --tier temporary --older-than 30\n129:   spec-kit-cli bulk-delete --tier deprecated --folder system-spec-kit --dry-run\n130:   spec-kit-cli reindex\n131:   spec-kit-cli reindex --force\n132:   spec-kit-cli reindex --eager-warmup\n133:   spec-kit-cli schema-downgrade --to 15 --confirm\n134: `);\n135: }\n136: \n137: /* ───────────────────────────────────────────────────────────────\n138:    2. DATABASE INITIALIZATION (minimal — no MCP, no embeddings)\n139: ──────────────────────────────────────────────────────────────── */\n140: \n141: async function initDatabase(): Promise<void> {\n142:   const [vectorIndex, checkpointsLib, accessTracker, coreIndex] = await Promise.all([\n143:     getVectorIndex(),\n144:     getCheckpointsLib(),\n145:     getAccessTracker(),\n146:     getCoreIndex(),\n147:   ]);\n148: \n149:   vectorIndex.initializeDb();\n150:   const db = vectorIndex.getDb();\n151:   const databasePath = await getDatabasePath();\n152:   if (!db) {\n153:     console.error(`ERROR: Failed to open database at ${databasePath}`);\n154:     process.exit(1);\n155:   }\n156:   // Keep CLI and MCP handlers aligned: handlers invoked from CLI rely on db-state wiring.\n157:   coreIndex.init({ vectorIndex, checkpoints: checkpointsLib, accessTracker });\n158:   checkpointsLib.init(db);\n159:   accessTracker.init(db);\n160: }\n161: \n162: /* ───────────────────────────────────────────────────────────────\n163:    3. STATS COMMAND\n164: ──────────────────────────────────────────────────────────────── */\n165: \n166: async function runStats(): Promise<void> {\n167:   await initDatabase();\n168:   const vectorIndex = await getVectorIndex();\n169:   const databasePath = await getDatabasePath();\n170:   const db = vectorIndex.getDb()!;\n171: \n172:   // Total count\n173:   const totalRow = db.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number };\n174:   console.log(`\\nMemory Database Statistics`);\n175:   console.log(`${'-'.repeat(50)}`);\n176:   console.log(`  Database:  ${databasePath}`);\n177:   console.log(`  Total:     ${totalRow.count} memories`);\n178: \n179:   // Tier distribution\n180:   const tiers = db.prepare(\n181:     'SELECT importance_tier, COUNT(*) as count FROM memory_index GROUP BY importance_tier ORDER BY count DESC'\n182:   ).all() as Array<{ importance_tier: string; count: number }>;\n183: \n184:   console.log(`\\n  Tier Distribution:`);\n185:   for (const tier of tiers) {\n186:     const bar = '█'.repeat(Math.min(Math.ceil(tier.count / Math.max(1, totalRow.count) * 30), 30));\n187:     console.log(`    ${(tier.importance_tier || 'null').padEnd(16)} ${bar} ${tier.count}`);\n188:   }\n189: \n190:   // Top folders\n191:   const folders = db.prepare(\n192:     'SELECT spec_folder, COUNT(*) as count FROM memory_index WHERE spec_folder IS NOT NULL GROUP BY spec_folder ORDER BY count DESC LIMIT 10'\n193:   ).all() as Array<{ spec_folder: string; count: number }>;\n194: \n195:   if (folders.length > 0) {\n196:     console.log(`\\n  Top Folders:`);\n197:     for (const folder of folders) {\n198:       const bar = '█'.repeat(Math.min(Math.ceil(folder.count / Math.max(1, folders[0].count) * 20), 20));\n199:       console.log(`    ${folder.spec_folder.padEnd(40)} ${bar} ${folder.count}`);\n200:     }\n201:   }\n202: \n203:   // Schema version\n204:   try {\n205:     const versionRow = db.prepare('SELECT version FROM schema_version WHERE id = 1').get() as { version: number } | undefined;\n206:     if (versionRow) {\n207:       console.log(`\\n  Schema:    v${versionRow.version}`);\n208:     }\n209:   } catch {\n210:     // Schema_version table may not exist\n211:     try {\n212:       const legacyVersion = db.prepare(\"SELECT value FROM config WHERE key = 'schema_version'\").get() as { value: string } | undefined;\n213:       if (legacyVersion) {\n214:         console.log(`\\n  Schema:    v${legacyVersion.value}`);\n215:       }\n216:     } catch {\n217:       // No schema version metadata available\n218:     }\n219:   }\n220: \n221:   // Chunked memories (parent/child)\n222:   try {\n223:     const chunkedParents = db.prepare(\n224:       \"SELECT COUNT(*) as count FROM memory_index WHERE embedding_status = 'partial'\"\n225:     ).get() as { count: number };\n226:     const childChunks = db.prepare(\n227:       'SELECT COUNT(*) as count FROM memory_index WHERE parent_id IS NOT NULL'\n228:     ).get() as { count: number };\n229:     if (chunkedParents.count > 0 || childChunks.count > 0) {\n230:       console.log(`\\n  Chunked:   ${chunkedParents.count} parent(s), ${childChunks.count} chunk(s)`);\n231:     }\n232:   } catch {\n233:     // Parent_id column may not exist yet\n234:   }\n235: \n236:   console.log('');\n237: }\n238: \n239: /* ───────────────────────────────────────────────────────────────\n240:    4. BULK DELETE COMMAND\n241: ──────────────────────────────────────────────────────────────── */\n242: \n243: async function runBulkDelete(): Promise<void> {\n244:   const tier = getOption('tier');\n245:   if (!tier) {\n246:     console.error('ERROR: --tier is required. Example: spec-kit-cli bulk-delete --tier deprecated');\n247:     process.exit(1);\n248:   }\n249: \n250:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n251:   if (!validTiers.includes(tier)) {\n252:     console.error(`ERROR: Invalid tier \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n253:     process.exit(1);\n254:   }\n255: \n256:   const specFolder = getOption('folder');\n257:   const olderThanDays = getOption('older-than');\n258:   const dryRun = getFlag('dry-run');\n259:   const skipCheckpoint = getFlag('skip-checkpoint');\n260: \n261:   // Validate --older-than is a positive integer.\n262:   // Use strict check: entire string must be digits only (parseInt accepts \"10abc\" as 10).\n263:   if (olderThanDays) {\n264:     if (!/^\\d+$/.test(olderThanDays) || parseInt(olderThanDays, 10) <= 0) {\n265:       console.error(`ERROR: --older-than must be a positive integer (got \"${olderThanDays}\")`);\n266:       process.exit(1);\n267:     }\n268:   }\n269: \n270:   // Safety: refuse constitutional/critical without folder scope\n271:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n272:     console.error(`ERROR: Bulk delete of \"${tier}\" tier requires --folder scope for safety.`);\n273:     process.exit(1);\n274:   }\n275:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n276:     console.error(`ERROR: --skip-checkpoint is not allowed for \"${tier}\" tier.`);\n277:     process.exit(1);\n278:   }\n279: \n280:   await initDatabase();\n281:   const [vectorIndex, checkpointsLib, mutationLedger, triggerMatcher, causalEdges, history] = await Promise.all([\n282:     getVectorIndex(),\n283:     getCheckpointsLib(),\n284:     getMutationLedger(),\n285:     getTriggerMatcher(),\n286:     getCausalEdges(),\n287:     getHistory(),\n288:   ]);\n289:   const db = vectorIndex.getDb()!;\n290: \n291:   // Count affected\n292:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n293:   const countParams: unknown[] = [tier];\n294: \n295:   if (specFolder) {\n296:     countSql += ' AND spec_folder = ?';\n297:     countParams.push(specFolder);\n298:   }\n299:   if (olderThanDays) {\n300:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n301:     countParams.push(parseInt(olderThanDays, 10));\n302:   }\n303: \n304:   const countResult = db.prepare(countSql).get(...countParams) as { count: number };\n305:   const affectedCount = countResult.count;\n306: \n307:   console.log(`\\nBulk Delete Preview`);\n308:   console.log(`${'-'.repeat(50)}`);\n309:   console.log(`  Tier:        ${tier}`);\n310:   if (specFolder) console.log(`  Folder:      ${specFolder}`);\n311:   if (olderThanDays) console.log(`  Older than:  ${olderThanDays} days`);\n312:   if (skipCheckpoint) console.log(`  Checkpoint:  skipped (--skip-checkpoint)`);\n313:   console.log(`  Affected:    ${affectedCount} memories`);\n314: \n315:   if (affectedCount === 0) {\n316:     console.log(`\\n  No memories match the criteria.`);\n317:     return;\n318:   }\n319: \n320:   if (dryRun) {\n321:     console.log(`\\n  [DRY RUN] Would delete ${affectedCount} memories. No changes made.`);\n322: \n323:     // Show sample of affected memories\n324:     let sampleSql = 'SELECT id, title, created_at FROM memory_index WHERE importance_tier = ?';\n325:     const sampleParams: unknown[] = [tier];\n326:     if (specFolder) { sampleSql += ' AND spec_folder = ?'; sampleParams.push(specFolder); }\n327:     if (olderThanDays) { sampleSql += ` AND created_at < datetime('now', '-' || ? || ' days')`; sampleParams.push(parseInt(olderThanDays, 10)); }\n328:     sampleSql += ' ORDER BY created_at ASC LIMIT 10';\n329: \n330:     const samples = db.prepare(sampleSql).all(...sampleParams) as Array<{ id: number; title: string; created_at: string }>;\n331:     if (samples.length > 0) {\n332:       console.log(`\\n  Sample (first ${samples.length}):`);\n333:       for (const s of samples) {\n334:         console.log(`    #${s.id}  ${(s.title || '(no title)').slice(0, 50).padEnd(50)}  ${s.created_at}`);\n335:       }\n336:       if (affectedCount > 10) {\n337:         console.log(`    ... and ${affectedCount - 10} more`);\n338:       }\n339:     }\n340:     return;\n341:   }\n342: \n343:   let checkpointName: string | null = null;\n344:   if (!skipCheckpoint) {\n345:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n346:     checkpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n347: \n348:     try {\n349:       checkpointsLib.createCheckpoint({\n350:         name: checkpointName,\n351:         specFolder,\n352:         metadata: {\n353:           reason: `CLI bulk delete of ${affectedCount} \"${tier}\" memories`,\n354:           tier,\n355:           affectedCount,\n356:           olderThanDays: olderThanDays ? parseInt(olderThanDays, 10) : null,\n357:         },\n358:       });\n359:       console.log(`\\n  Checkpoint:  ${checkpointName}`);\n360:     } catch (err: unknown) {\n361:       const message = err instanceof Error ? err.message : String(err);\n362:       console.error(`  WARNING: Failed to create checkpoint: ${message}`);\n363:       console.error(`  Proceeding with deletion...`);\n364:       checkpointName = null;\n365:     }\n366:   } else {\n367:     console.log(`\\n  Checkpoint:  skipped`);\n368:   }\n369: \n370:   // Fetch IDs for deletion\n371:   let selectSql = 'SELECT id, spec_folder FROM memory_index WHERE importance_tier = ?';\n372:   const selectParams: unknown[] = [tier];\n373:   if (specFolder) { selectSql += ' AND spec_folder = ?'; selectParams.push(specFolder); }\n374:   if (olderThanDays) { selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`; selectParams.push(parseInt(olderThanDays, 10)); }\n375: \n376:   const toDelete = db.prepare(selectSql).all(...selectParams) as Array<{ id: number; spec_folder: string | null }>;\n377: \n378:   // Initialize causal edges for cleanup\n379:   causalEdges.init(db);\n380: \n381:   // Delete in transaction\n382:   let deletedCount = 0;\n383:   const deletedIds: number[] = [];\n384: \n385:   const bulkDeleteTx = db.transaction(() => {\n386:     for (const memory of toDelete) {\n387:       if (vectorIndex.deleteMemory(memory.id)) {\n388:         deletedCount++;\n389:         deletedIds.push(memory.id);\n390:         // Record DELETE history only after confirmed deletion.\n391:         try {\n392:           history.recordHistory(memory.id, 'DELETE', null, null, 'mcp:cli_bulk_delete', memory.spec_folder ?? null);\n393:         } catch (_histErr: unknown) {\n394:           // History recording is best-effort\n395:         }\n396:         try { causalEdges.deleteEdgesForMemory(String(memory.id)); } catch { /* ignore */ }\n397:       }\n398:     }\n399:   });\n\n(Showing lines 100-399 of 597. Use offset=400 to continue.)\n</content>","metadata":{"preview":"}\n\nfunction printUsage(): void {\n  console.log(`\nspec-kit-cli — Bulk database operations for Spec Kit Memory\n\nUsage:\n  spec-kit-cli <command> [options]\n\nCommands:\n  stats                          Show memory database statistics\n  bulk-delete --tier <tier>      Delete memories by importance tier\n    [--folder <spec-folder>]       Optional: scope to a spec folder\n    [--older-than <days>]          Optional: only delete older than N days\n    [--dry-run]                    Preview without deleting\n    [--skip-checkpoint]            Optional: skip pre-delete checkpoint (blocked for constitutional/critical)\n  reindex [--force] [--eager-warmup]\n                                 Re-index memory files (lazy model load by default)\n  schema-downgrade --to 15 --confirm\n                                 Downgrade schema from v16 to v15 (targeted, destructive)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/cli.ts","text":"}\n\nfunction printUsage(): void {\n  console.log(`\nspec-kit-cli — Bulk database operations for Spec Kit Memory\n\nUsage:\n  spec-kit-cli <command> [options]\n\nCommands:\n  stats                          Show memory database statistics\n  bulk-delete --tier <tier>      Delete memories by importance tier\n    [--folder <spec-folder>]       Optional: scope to a spec folder\n    [--older-than <days>]          Optional: only delete older than N days\n    [--dry-run]                    Preview without deleting\n    [--skip-checkpoint]            Optional: skip pre-delete checkpoint (blocked for constitutional/critical)\n  reindex [--force] [--eager-warmup]\n                                 Re-index memory files (lazy model load by default)\n  schema-downgrade --to 15 --confirm\n                                 Downgrade schema from v16 to v15 (targeted, destructive)\n\nOptions:\n  --help                         Show this help message\n  --version                      Show CLI version\n\nExamples:\n  spec-kit-cli stats\n  spec-kit-cli bulk-delete --tier deprecated\n  spec-kit-cli bulk-delete --tier temporary --older-than 30\n  spec-kit-cli bulk-delete --tier deprecated --folder system-spec-kit --dry-run\n  spec-kit-cli reindex\n  spec-kit-cli reindex --force\n  spec-kit-cli reindex --eager-warmup\n  spec-kit-cli schema-downgrade --to 15 --confirm\n`);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. DATABASE INITIALIZATION (minimal — no MCP, no embeddings)\n──────────────────────────────────────────────────────────────── */\n\nasync function initDatabase(): Promise<void> {\n  const [vectorIndex, checkpointsLib, accessTracker, coreIndex] = await Promise.all([\n    getVectorIndex(),\n    getCheckpointsLib(),\n    getAccessTracker(),\n    getCoreIndex(),\n  ]);\n\n  vectorIndex.initializeDb();\n  const db = vectorIndex.getDb();\n  const databasePath = await getDatabasePath();\n  if (!db) {\n    console.error(`ERROR: Failed to open database at ${databasePath}`);\n    process.exit(1);\n  }\n  // Keep CLI and MCP handlers aligned: handlers invoked from CLI rely on db-state wiring.\n  coreIndex.init({ vectorIndex, checkpoints: checkpointsLib, accessTracker });\n  checkpointsLib.init(db);\n  accessTracker.init(db);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. STATS COMMAND\n──────────────────────────────────────────────────────────────── */\n\nasync function runStats(): Promise<void> {\n  await initDatabase();\n  const vectorIndex = await getVectorIndex();\n  const databasePath = await getDatabasePath();\n  const db = vectorIndex.getDb()!;\n\n  // Total count\n  const totalRow = db.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number };\n  console.log(`\\nMemory Database Statistics`);\n  console.log(`${'-'.repeat(50)}`);\n  console.log(`  Database:  ${databasePath}`);\n  console.log(`  Total:     ${totalRow.count} memories`);\n\n  // Tier distribution\n  const tiers = db.prepare(\n    'SELECT importance_tier, COUNT(*) as count FROM memory_index GROUP BY importance_tier ORDER BY count DESC'\n  ).all() as Array<{ importance_tier: string; count: number }>;\n\n  console.log(`\\n  Tier Distribution:`);\n  for (const tier of tiers) {\n    const bar = '█'.repeat(Math.min(Math.ceil(tier.count / Math.max(1, totalRow.count) * 30), 30));\n    console.log(`    ${(tier.importance_tier || 'null').padEnd(16)} ${bar} ${tier.count}`);\n  }\n\n  // Top folders\n  const folders = db.prepare(\n    'SELECT spec_folder, COUNT(*) as count FROM memory_index WHERE spec_folder IS NOT NULL GROUP BY spec_folder ORDER BY count DESC LIMIT 10'\n  ).all() as Array<{ spec_folder: string; count: number }>;\n\n  if (folders.length > 0) {\n    console.log(`\\n  Top Folders:`);\n    for (const folder of folders) {\n      const bar = '█'.repeat(Math.min(Math.ceil(folder.count / Math.max(1, folders[0].count) * 20), 20));\n      console.log(`    ${folder.spec_folder.padEnd(40)} ${bar} ${folder.count}`);\n    }\n  }\n\n  // Schema version\n  try {\n    const versionRow = db.prepare('SELECT version FROM schema_version WHERE id = 1').get() as { version: number } | undefined;\n    if (versionRow) {\n      console.log(`\\n  Schema:    v${versionRow.version}`);\n    }\n  } catch {\n    // Schema_version table may not exist\n    try {\n      const legacyVersion = db.prepare(\"SELECT value FROM config WHERE key = 'schema_version'\").get() as { value: string } | undefined;\n      if (legacyVersion) {\n        console.log(`\\n  Schema:    v${legacyVersion.value}`);\n      }\n    } catch {\n      // No schema version metadata available\n    }\n  }\n\n  // Chunked memories (parent/child)\n  try {\n    const chunkedParents = db.prepare(\n      \"SELECT COUNT(*) as count FROM memory_index WHERE embedding_status = 'partial'\"\n    ).get() as { count: number };\n    const childChunks = db.prepare(\n      'SELECT COUNT(*) as count FROM memory_index WHERE parent_id IS NOT NULL'\n    ).get() as { count: number };\n    if (chunkedParents.count > 0 || childChunks.count > 0) {\n      console.log(`\\n  Chunked:   ${chunkedParents.count} parent(s), ${childChunks.count} chunk(s)`);\n    }\n  } catch {\n    // Parent_id column may not exist yet\n  }\n\n  console.log('');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. BULK DELETE COMMAND\n──────────────────────────────────────────────────────────────── */\n\nasync function runBulkDelete(): Promise<void> {\n  const tier = getOption('tier');\n  if (!tier) {\n    console.error('ERROR: --tier is required. Example: spec-kit-cli bulk-delete --tier deprecated');\n    process.exit(1);\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    console.error(`ERROR: Invalid tier \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n    process.exit(1);\n  }\n\n  const specFolder = getOption('folder');\n  const olderThanDays = getOption('older-than');\n  const dryRun = getFlag('dry-run');\n  const skipCheckpoint = getFlag('skip-checkpoint');\n\n  // Validate --older-than is a positive integer.\n  // Use strict check: entire string must be digits only (parseInt accepts \"10abc\" as 10).\n  if (olderThanDays) {\n    if (!/^\\d+$/.test(olderThanDays) || parseInt(olderThanDays, 10) <= 0) {\n      console.error(`ERROR: --older-than must be a positive integer (got \"${olderThanDays}\")`);\n      process.exit(1);\n    }\n  }\n\n  // Safety: refuse constitutional/critical without folder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    console.error(`ERROR: Bulk delete of \"${tier}\" tier requires --folder scope for safety.`);\n    process.exit(1);\n  }\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    console.error(`ERROR: --skip-checkpoint is not allowed for \"${tier}\" tier.`);\n    process.exit(1);\n  }\n\n  await initDatabase();\n  const [vectorIndex, checkpointsLib, mutationLedger, triggerMatcher, causalEdges, history] = await Promise.all([\n    getVectorIndex(),\n    getCheckpointsLib(),\n    getMutationLedger(),\n    getTriggerMatcher(),\n    getCausalEdges(),\n    getHistory(),\n  ]);\n  const db = vectorIndex.getDb()!;\n\n  // Count affected\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n  if (olderThanDays) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(parseInt(olderThanDays, 10));\n  }\n\n  const countResult = db.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  console.log(`\\nBulk Delete Preview`);\n  console.log(`${'-'.repeat(50)}`);\n  console.log(`  Tier:        ${tier}`);\n  if (specFolder) console.log(`  Folder:      ${specFolder}`);\n  if (olderThanDays) console.log(`  Older than:  ${olderThanDays} days`);\n  if (skipCheckpoint) console.log(`  Checkpoint:  skipped (--skip-checkpoint)`);\n  console.log(`  Affected:    ${affectedCount} memories`);\n\n  if (affectedCount === 0) {\n    console.log(`\\n  No memories match the criteria.`);\n    return;\n  }\n\n  if (dryRun) {\n    console.log(`\\n  [DRY RUN] Would delete ${affectedCount} memories. No changes made.`);\n\n    // Show sample of affected memories\n    let sampleSql = 'SELECT id, title, created_at FROM memory_index WHERE importance_tier = ?';\n    const sampleParams: unknown[] = [tier];\n    if (specFolder) { sampleSql += ' AND spec_folder = ?'; sampleParams.push(specFolder); }\n    if (olderThanDays) { sampleSql += ` AND created_at < datetime('now', '-' || ? || ' days')`; sampleParams.push(parseInt(olderThanDays, 10)); }\n    sampleSql += ' ORDER BY created_at ASC LIMIT 10';\n\n    const samples = db.prepare(sampleSql).all(...sampleParams) as Array<{ id: number; title: string; created_at: string }>;\n    if (samples.length > 0) {\n      console.log(`\\n  Sample (first ${samples.length}):`);\n      for (const s of samples) {\n        console.log(`    #${s.id}  ${(s.title || '(no title)').slice(0, 50).padEnd(50)}  ${s.created_at}`);\n      }\n      if (affectedCount > 10) {\n        console.log(`    ... and ${affectedCount - 10} more`);\n      }\n    }\n    return;\n  }\n\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    checkpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      checkpointsLib.createCheckpoint({\n        name: checkpointName,\n        specFolder,\n        metadata: {\n          reason: `CLI bulk delete of ${affectedCount} \"${tier}\" memories`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays ? parseInt(olderThanDays, 10) : null,\n        },\n      });\n      console.log(`\\n  Checkpoint:  ${checkpointName}`);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.error(`  WARNING: Failed to create checkpoint: ${message}`);\n      console.error(`  Proceeding with deletion...`);\n      checkpointName = null;\n    }\n  } else {\n    console.log(`\\n  Checkpoint:  skipped`);\n  }\n\n  // Fetch IDs for deletion\n  let selectSql = 'SELECT id, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n  if (specFolder) { selectSql += ' AND spec_folder = ?'; selectParams.push(specFolder); }\n  if (olderThanDays) { selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`; selectParams.push(parseInt(olderThanDays, 10)); }\n\n  const toDelete = db.prepare(selectSql).all(...selectParams) as Array<{ id: number; spec_folder: string | null }>;\n\n  // Initialize causal edges for cleanup\n  causalEdges.init(db);\n\n  // Delete in transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  const bulkDeleteTx = db.transaction(() => {\n    for (const memory of toDelete) {\n      if (vectorIndex.deleteMemory(memory.id)) {\n        deletedCount++;\n        deletedIds.push(memory.id);\n        // Record DELETE history only after confirmed deletion.\n        try {\n          history.recordHistory(memory.id, 'DELETE', null, null, 'mcp:cli_bulk_delete', memory.spec_folder ?? null);\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n        try { causalEdges.deleteEdgesForMemory(String(memory.id)); } catch { /* ignore */ }\n      }\n    }\n  });","lineStart":100,"lineEnd":399,"totalLines":597,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/cli.ts","time":{"start":1780736179188,"end":1780736179192}},"id":"prt_e9c25b93f001FRiH0SzABBe761","sessionID":"ses_163de1863ffeLd3K58IkmWaFwL","messageID":"msg_e9c25ac200012uCO9U7p8TkjY1"}}
