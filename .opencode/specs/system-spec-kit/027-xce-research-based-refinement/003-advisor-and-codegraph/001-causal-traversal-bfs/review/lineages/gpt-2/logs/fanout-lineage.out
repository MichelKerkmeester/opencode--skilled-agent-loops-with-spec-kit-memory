oper_noun\",\n162:         \"path\": \"plan.md\",\n163:         \"source\": \"derived\"\n164:       },\n165:       {\n166:         \"name\": \"Task Format\",\n167:         \"kind\": \"proper_noun\",\n168:         \"path\": \"tasks.md\",\n169:         \"source\": \"derived\"\n170:       },\n171:       {\n172:         \"name\": \"Task Notation\",\n173:         \"kind\": \"proper_noun\",\n174:         \"path\": \"tasks.md\",\n175:         \"source\": \"derived\"\n176:       },\n177:       {\n178:         \"name\": \"Completion Criteria\",\n179:         \"kind\": \"proper_noun\",\n180:         \"path\": \"tasks.md\",\n181:         \"source\": \"derived\"\n182:       },\n183:       {\n184:         \"name\": \"CTE\",\n185:         \"kind\": \"key_phrase\",\n186:         \"path\": \"tasks.md\",\n187:         \"source\": \"derived\"\n188:       },\n189:       {\n190:         \"name\": \"Implementation Summary\",\n191:         \"kind\": \"proper_noun\",\n192:         \"path\": \"implementation-summary.md\",\n193:         \"source\": \"derived\"\n194:       }\n195:     ],\n196:     \"causal_summary\": \"The only two WITH RECURSIVE consumers in the memory backend are read paths with measurable inefficiencies. getNeighborBoosts (lib/search/causal-boost.ts:431) recurses with ON ce.source_id = cw.node_id OR ce.target_id = cw.node_id, which prevents single-index use on every hop; the live graph measured 10,240 causal edges with max degree 22, so an indexed two-query-per-hop BFS is estimated at 0.5-2ms - at or below the CTE. collectDependents (lib/storage/memo.ts:192) runs an unbounded recursive CTE and wouldCreateCycle fires per insert, yet dependency_edges and memoization_records both held zero rows when measured (2026-06-10). Source evidence: z_future/sqlite-to-turso research.md gap 6 and 004 - gap-alternatives.md section 4.\",\n197:     \"created_at\": \"2026-06-10T17:48:32Z\",\n198:     \"last_save_at\": \"2026-06-10T19:22:14.994Z\",\n199:     \"save_lineage\": \"graph_only\",\n200:     \"last_accessed_at\": null,\n201:     \"source_docs\": [\n202:       \"spec.md\",\n203:       \"plan.md\",\n204:       \"tasks.md\",\n205:       \"implementation-summary.md\"\n206:     ],\n207:     \"last_active_child_id\": null,\n208:     \"last_active_at\": null\n209:   }\n210: }\n\n(End of file - total 210 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/012-causal-traversal-bfs\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/012-causal-traversal-bfs\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"causal traversal bfs\",\n      \"recursive cte replacement\",\n      \"neighbor boost traversal\",\n      \"memo cycle check\",\n      \"012-causal-traversal-bfs plan\",\n      \"012-causal-traversal-bfs tasks\",\n      \"012-causal-traversal-bfs summary\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/012-causal-traversal-bfs/graph-metadata.json","text":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/012-causal-traversal-bfs\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/012-causal-traversal-bfs\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"causal traversal bfs\",\n      \"recursive cte replacement\",\n      \"neighbor boost traversal\",\n      \"memo cycle check\",\n      \"012-causal-traversal-bfs plan\",\n     