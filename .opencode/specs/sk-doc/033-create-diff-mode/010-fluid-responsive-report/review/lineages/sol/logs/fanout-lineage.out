\":1,\"skipped\":0},\"evidence\":[\".opencode/specs/sk-doc/033-create-diff-mode/010-fluid-responsive-report/spec.md:137\",\".opencode/specs/sk-doc/033-create-diff-mode/010-fluid-responsive-report/spec.md:153\",\".opencode/skills/sk-doc/create-diff/scripts/create_diff.py:720-727\"],\"findingRefs\":[\"P1-001\"],\"summary\":\"Unsupported-engine fallback claim conflicts with the variable-backed cqi implementation.\"},{\"protocolId\":\"checklist_evidence\",\"status\":\"partial\",\"gateClass\":\"hard\",\"applicable\":true,\"counts\":{\"pass\":1,\"partial\":1,\"fail\":0,\"skipped\":0},\"evidence\":[\".opencode/specs/sk-doc/033-create-diff-mode/010-fluid-responsive-report/checklist.md:75-79\",\".opencode/skills/sk-doc/create-diff/scripts/test_create_diff.py:325-332\"],\"findingRefs\":[\"P1-001\",\"P2-001\"],\"summary\":\"Current-path literals are tested; unsupported-engine fallback and full named-container wiring are not.\"},{\"protocolId\":\"feature_catalog_code\",\"status\":\"fail\",\"gateClass\":\"advisory\",\"applicable\":true,\"counts\":{\"pass\":0,\"partial\":0,\"fail\":1,\"skipped\":0},\"evidence\":[\".opencode/skills/sk-doc/create-diff/feature-catalog/snapshot-lifecycle/snapshot-state-management.md:20-28\",\".opencode/skills/sk-doc/create-diff/scripts/create_diff.py:1431-1448\"],\"findingRefs\":[\"P0-001\"],\"summary\":\"Cleanup safety narrative omits manifest path containment.\"},{\"protocolId\":\"playbook_capability\",\"status\":\"partial\",\"gateClass\":\"advisory\",\"applicable\":true,\"counts\":{\"pass\":1,\"partial\":1,\"fail\":0,\"skipped\":0},\"evidence\":[\".opencode/skills/sk-doc/create-diff/manual-testing-playbook/snapshot/snapshot-status-and-cleanup.md:24-68\",\".opencode/skills/sk-doc/create-diff/manual-testing-playbook/safety/hostile-content-escaped.md:24-66\"],\"findingRefs\":[\"P0-001\"],\"summary\":\"Ordinary lifecycle and hostile-content cases are executable; corrupt-manifest cleanup is uncovered.\"}]},\"searchCoverage\":{\"requiredBugClasses\":[\"