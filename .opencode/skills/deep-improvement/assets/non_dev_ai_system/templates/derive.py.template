#!/usr/bin/env python3
"""Executable derivation of the {{SYSTEM_NAME}} copies (Prereq B).

  derive.py derive   -> regenerate the verbatim-copy surfaces from the CLI knowledge base
  derive.py check    -> verify every derived copy matches its CLI source-of-truth; exit 1 on drift

The council's reuse-blocker: the copies are hand-maintained, not derived.
This makes the MECHANICAL half real: every shared knowledge doc is a verbatim copy of the CLI
source, so it can be regenerated and sha-verified. Promotion regenerates these, never hand-edits
them.

The SYNTHESIZED surfaces are NOT mechanical copies, so they cannot be regenerated by code.
They are flagged here as synthesis-required: when their CLI source sections change, they need
an LLM/human re-derivation step (the loop must escalate, not auto-promote them).
"""
import sys, os, shutil, hashlib

CW = os.environ.get("{{PACKAGING_ROOT_ENV}}", "{{PACKAGING_ROOT}}")
KB = os.path.join(CW, "knowledge base")

DERIVED = {{DERIVED_COPIES}}
SYNTHESIZED = {{SYNTHESIZED_SURFACES}}
SKILL_FRONTMATTER = {{SKILL_FRONTMATTER}}


def sha(p):
    return hashlib.sha256(open(p, "rb").read()).hexdigest() if os.path.exists(p) else None


def _skill_doc_bytes(src, skill_name):
    """Deterministic skill-reference content: template frontmatter + the verbatim CLI source."""
    fm_entry = SKILL_FRONTMATTER.get(skill_name, {})
    title = fm_entry.get("title", skill_name.replace("_", " ").replace(".md", "").title())
    desc = fm_entry.get("description", "")
    fm = f"---\ntitle: {title}\ndescription: {desc}\n---\n\n"
    return fm.encode("utf-8") + open(src, "rb").read()


def derive():
    n = 0
    for entry in DERIVED:
        src = os.path.join(KB, entry["src_relpath"])
        for target in entry["targets"]:
            dst = os.path.join(CW, target["relpath"])
            os.makedirs(os.path.dirname(dst), exist_ok=True)
            if target.get("is_skill_ref"):
                skill_name = target.get("skill_ref_basename", os.path.basename(target["relpath"]))
                open(dst, "wb").write(_skill_doc_bytes(src, skill_name))
            else:
                shutil.copyfile(src, dst)
            n += 1
    print(f"Derived {n} copies from the CLI knowledge base.")
    if SYNTHESIZED:
        print("Synthesized surfaces NOT regenerated (need LLM/human re-derivation on source change):")
        for s in SYNTHESIZED:
            print("  - " + s)


def check():
    drift = []
    for entry in DERIVED:
        src = os.path.join(KB, entry["src_relpath"])
        ref = sha(src)
        if ref is None:
            drift.append(f"MISSING CLI source: knowledge base/{entry['src_relpath']}")
            continue
        for target in entry["targets"]:
            dst = os.path.join(CW, target["relpath"])
            if target.get("is_skill_ref"):
                skill_name = target.get("skill_ref_basename", os.path.basename(target["relpath"]))
                expected = hashlib.sha256(_skill_doc_bytes(src, skill_name)).hexdigest()
            else:
                expected = ref
            h = sha(dst)
            label = "skill" if target.get("is_skill_ref") else "copy"
            if h is None:
                drift.append(f"MISSING {label}: {target['relpath']}")
            elif h != expected:
                drift.append(f"DRIFT  {label} differs from CLI source: {target['relpath']}")
    if drift:
        print("COPY DERIVATION DRIFT (loop must re-derive before promoting):")
        for d in drift:
            print("  - " + d)
        sys.exit(1)
    print(f"All {sum(len(e['targets']) for e in DERIVED)} derived copies match the CLI source. OK")
    if SYNTHESIZED:
        print("Note: synthesized surfaces are NOT checked here; they need synthesis re-derivation.")


if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "check"
    {"derive": derive, "check": check}.get(cmd, lambda: (_ for _ in ()).throw(SystemExit(f"unknown cmd: {cmd}")))()
