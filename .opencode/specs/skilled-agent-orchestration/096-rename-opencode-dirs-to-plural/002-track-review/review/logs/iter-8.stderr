    79	def parse_yaml_frontmatter_description(text: str) -> Optional[str]:
    80	    """Extract the `description:` field from a YAML frontmatter block.
    81	
    82	    Returns the unwrapped (post-quote-strip) string, or None if missing/multiline.
    83	    Mirrors quick_validate.py logic for consistency.
    84	    """
    85	    if not text.startswith("---"):
    86	        return None
    87	    match = re.match(r"^---\n(.*?)\n---", text, re.DOTALL)
    88	    if not match:
    89	        return None
    90	    fm = match.group(1)
    91	    if re.search(r"description:\s*\n\s+", fm) or re.search(r"^description:\s*[|>]\s*$", fm, flags=re.MULTILINE):
    92	        return None
    93	    desc_match = re.search(r"description:\s*(.+)", fm)
    94	    if not desc_match:
    95	        return None
    96	    return strip_matching_quotes(desc_match.group(1))
    97	
    98	
    99	def parse_toml_description(text: str) -> Optional[str]:
   100	    """Extract `description = "..."` from a top-level TOML file (Codex agents).
   101	
   102	    Uses tomllib when available (Python 3.11+); falls back to a regex match
   103	    for older Pythons. The regex is deliberately conservative: top-level only,
   104	    string literal only.
   105	    """
   106	    try:
   107	        import tomllib  # type: ignore
   108	        try:
   109	            data = tomllib.loads(text)
   110	            value = data.get("description")
   111	            if isinstance(value, str):
   112	                return value
   113	        except tomllib.TOMLDecodeError:
   114	            pass
   115	    except ImportError:
   116	        pass
   117	    # Regex fallback. Anchors to a top-level (non-indented) `description = "..."`.
   118	    match = re.search(r'^description\s*=\s*"([^"\n]*)"', text, flags=re.MULTILINE)
   119	    if match:
   120	        return match.group(1)
   121	    return None
