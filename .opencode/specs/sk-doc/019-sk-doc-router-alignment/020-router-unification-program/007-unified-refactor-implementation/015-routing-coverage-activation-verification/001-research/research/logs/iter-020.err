  1077	// ─────────────────────────────────────────────────────────────────────────────
  1078	// 12. BUILD HELPERS
  1079	// ─────────────────────────────────────────────────────────────────────────────
  1080	
  1080	
  1081	function run(command, args, options = {}) {
  1082	  const result = spawnSync(command, args, {
  1083	    cwd: options.cwd || root,
  1084	    env: createChildEnv(),
  1085	    encoding: 'utf8',
  1086	    stdio: ['ignore', 'pipe', 'pipe'],
  1087	  });
  1088	
  1089	  if (result.stdout) {
  1090	    process.stderr.write(result.stdout);
  1091	  }
  1092	  if (result.stderr) {
  1093	    process.stderr.write(result.stderr);
  1094	  }
  1095	  if (result.error) {
  1096	    throw result.error;
  1097	  }
  1098	  if (result.status !== 0) {
  1099	    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);
  1100	  }
  1101	}
  1102	
  1103	function serverEntrypoint() {
  1104	  return path.join(mcpDir, 'dist', 'mcp-server', 'advisor-server.js');
  1105	}
  1106	
  1107	function requiredArtifacts() {
  1108	  return [
  1109	    serverEntrypoint(),
  1110	  ];
  1111	}
  1112	
  1113	function latestSourceMtimeMs() {
  1114	  let latest = 0;
  1115	  const candidates = [
  1116	    path.join(mcpDir, 'advisor-server.ts'),
  1117	    path.join(mcpDir, 'package.json'),
  1118	    path.join(mcpDir, 'tsconfig.json'),
  1119	    path.join(mcpDir, 'tsconfig.build.json'),
  1120	    ...SOURCE_DIRS.map((dir) => path.join(mcpDir, dir)),
  1121	  ];
  1122	
  1123	  const visit = (candidate) => {
  1124	    if (!exists(candidate)) return;
  1125	    const stat = fs.statSync(candidate);
  1126	    if (stat.isDirectory()) {
  1127	      for (const entry of fs.readdirSync(candidate)) {
  1128	        visit(path.join(candidate, entry));
  1129	      }
  1130	      return;
  1131	    }
  1132	    if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {
  1133	      latest = Math.max(latest, stat.mtimeMs);
  1134	    }
  1135	  };
  1136	
  1137	  for (const candidate of candidates) {
  1138	    visit(candidate);
  1139	  }
  1140	  return latest;
  1141	}
  1142	
  1143	function artifactsReady() {
  1144	  const artifacts = requiredArtifacts();
  1145	  if (!artifacts.every(exists)) {
  1146	    return false;
  1147	  }
  1148	
  1149	  const sourceMtime = latestSourceMtimeMs();
  1150	  if (sourceMtime === 0) {
  1151	    return true;
  1152	  }
  1153	  return artifacts.every((artifact) => fs.statSync(artifact).mtimeMs >= sourceMtime);
  1154	}
  1155	
  1156	function buildIfNeeded(actions) {
  1157	  if (artifactsReady()) {
  1158	    return;
  1159	  }
  1160	
  1161	  if (!exists(kitDir)) {
  1162	    throw new Error(`system-skill-advisor not found at ${rel(kitDir)}`);
  1163	  }
  1164	
  1165	  actions.push('installed dependencies and built @spec-kit/system-skill-advisor MCP server');
  1166	  const installCommand = exists(path.join(mcpDir, 'package-lock.json')) ? 'ci' : 'install';
  1167	  run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: mcpDir });
  1168	  run('npm', ['run', 'build'], { cwd: mcpDir });
  1169	
  1170	  const missing = requiredArtifacts().filter((artifact) => !exists(artifact));
  1171	  if (missing.length > 0) {
  1172	    throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);
  1173	  }
  1174	}
