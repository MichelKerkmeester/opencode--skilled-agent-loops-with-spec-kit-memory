  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "UI body — used for all body text, buttons, nav, links, card content, footers, icons. Weight 500 is the default for nearly all UI text (buttons, nav, body), giving Attio a slightly heavier, more confident UI voice than typical 400-only systems. Activated 'ss03' alternates give the text a distinctive geometric character."
    },
    "interdisplay": {
      "$value": "InterDisplay",
      "$type": "fontFamily",
      "$description": "Marketing headlines and display copy — weight 600 exclusively for large hero and section headings, with tight tracking (-0.015em to -0.02em) and near-1.0 line-heights creating dramatic, compact display blocks. The 56px size with -0.015em tracking is the signature hero voice. Activates 'ss03' and 'calt' for the same alternate character as Inter body."
    },
    "tiempostext": {
      "$value": "TiemposText",
      "$type": "fontFamily",
      "$description": "Editorial pull-quote and testimonial headings — a humanist serif that breaks the sans-serif system to create warmth and editorial weight. Used sparingly for quoted customer voices. This serif/sans contrast is the single most distinctive typographic choice in the system."
    }
  },
