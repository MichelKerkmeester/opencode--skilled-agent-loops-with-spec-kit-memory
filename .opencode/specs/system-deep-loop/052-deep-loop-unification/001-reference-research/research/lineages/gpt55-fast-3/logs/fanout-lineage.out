{"type":"tool_use","timestamp":1783486572779,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_GelDrwmTAPtzMiBb1NlXpMTU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DEEP RESEARCH: AUTONOMOUS DEEP RESEARCH LOOP (AUTO MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: # YAML PREDICATE GRAMMAR CONTRACT (S7 / M11):\n5: # - This asset does not currently use typed BooleanExpr predicates under\n6: #   `when:`; flow control is branch-label-driven (`on_resume`, `on_fresh`,\n7: #   `on_restart`, etc.). Retain the existing shape.\n8: # - `after:` carries prose timing / narrative notes if needed; `when:` in\n9: #   this file is reserved for future typed predicates and must NOT carry\n10: #   free-form narrative prose.\n11: # - See `.opencode/skills/system-spec-kit/shared/predicates/boolean-expr.ts`\n12: #   for the canonical BooleanExpr grammar.\n13: #\n14: # GATE 3 CLASSIFICATION (T-YML-DPR-01 / paired with T-DOC-03 R50-001):\n15: # - `resume` is a tested WRITE-PATH that produces `iteration-NNN.md` files\n16: #   and JSONL state-log appends. The workflow classifies resume as\n17: #   write-path below (see `gate3_classification` fields) so Gate 3 trigger\n18: #   extraction can surface resume correctly rather than false-negative.\n19: # ─────────────────────────────────────────────────────────────────\n20: role: Deep Research Loop Manager\n21: purpose: Iterative deep research with convergence detection\n22: action: Run deep-research loop from initialization through synthesis\n23: operating_mode:\n24:   workflow: iterative_loop\n25:   workflow_compliance: MANDATORY\n26:   workflow_execution: autonomous\n27:   approvals: none\n28:   tracking: progressive_research_state\n29:   validation: convergence_detection\n30: \n31: # ─────────────────────────────────────────────────────────────────\n32: # OPERATING PRINCIPLES\n33: # ─────────────────────────────────────────────────────────────────\n34: operating_principles:\n35:   core: \"Fresh context per iteration + externalized state = no context degradation\"\n36:   approach: \"Dispatch focused agent, evaluate convergence, repeat or stop\"\n37:   mandate: \"Never hold findings in memory; write everything to files\"\n38: \n39: # ─────────────────────────────────────────────────────────────────\n40: # USER INPUTS (from setup phase)\n41: # ─────────────────────────────────────────────────────────────────\n42: user_inputs:\n43:   research_topic: \"[RESEARCH_TOPIC] - Topic to investigate deeply. REQUIRED.\"\n44:   spec_folder: \"[SPEC_FOLDER] - Spec folder path. REQUIRED.\"\n45:   max_iterations: \"[MAX_ITERATIONS] - Maximum loop iterations. Default: 10.\"\n46:   convergence_threshold: \"[CONVERGENCE_THRESHOLD] - Stop threshold. Default: 0.05.\"\n47: \n48: # ─────────────────────────────────────────────────────────────────\n49: # CONTEXT LOADING\n50: # ─────────────────────────────────────────────────────────────────\n51: context_loading:\n52:   trigger: \"At workflow START, before phase_init\"\n53:   purpose: \"Load prior research context for the topic and buffer it until strategy.md exists\"\n54:   mcp_integration:\n55:     tool: memory_context\n56:     note: \"Call MCP tools directly - NEVER through Code Mode\"\n57:     parameters: { input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n58:   when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n59:   behavior:\n60:     if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n61:     if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n62: \n63: # ─────────────────────────────────────────────────────────────────\n64: # SKILL REFERENCE\n65: # ─────────────────────────────────────────────────────────────────\n66: skill_reference:\n67:   skill: deep-loop-workflows\n68:   skill_md: .opencode/skills/deep-loop-workflows/deep-research/SKILL.md\n69:   references:\n70:     loop_protocol: .opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md\n71:     spec_check_protocol: .opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md\n72:     state_format: .opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md\n73:     convergence: .opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md\n74:   templates:\n75:     config: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json\n76:     strategy: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md\n77: \n78: # ─────────────────────────────────────────────────────────────────\n79: # AGENT CONFIGURATION\n80: # ─────────────────────────────────────────────────────────────────\n81: agent_config:\n82:   agent: deep-research\n83:   agent_file: \".opencode/agents/deep-research.md\"\n84:   # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n85:   model: opus\n86:   leaf_only: true\n87:   tools: [Read, Write, Edit, Bash, Grep, Glob, WebFetch]\n88:   mcp_servers: [mk-spec-memory]\n89:   tool_call_budget: { target: 8, max: 12 }\n90: \n91: # ─────────────────────────────────────────────────────────────────\n92: # STATE FILE PATHS\n93: # ─────────────────────────────────────────────────────────────────\n94: state_paths:\n95:   # Template paths document the canonical packet layout. Runtime resolution happens via\n96:   # step_resolve_artifact_root plus the shared resolver, so root specs keep root-local\n97:   # research/ and child phases keep local research/ packet directories.\n98:   packet_dir: \"{artifact_dir}\"\n99:   config: \"{artifact_dir}/deep-research-config.json\"\n100:   state_log: \"{artifact_dir}/deep-research-state.jsonl\"\n101:   status_ledger: \"{artifact_dir}/orchestration-status.log\"\n102:   strategy: \"{artifact_dir}/deep-research-strategy.md\"\n103:   registry: \"{artifact_dir}/deep-research-findings-registry.json\"\n104:   dashboard: \"{artifact_dir}/deep-research-dashboard.md\"\n105:   pause_sentinel: \"{artifact_dir}/.deep-research-pause\"\n106:   run_now_sentinel: \"{artifact_dir}/.deep-research-run-now\"\n107:   lock_file: \"{artifact_dir}/.deep-research.lock\"\n108:   prompt_dir: \"{artifact_dir}/prompts\"\n109:   iteration_dir: \"{artifact_dir}/iterations\"\n110:   iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n111:   # Per-iteration structured delta stream (one file per iteration) — complement to the\n112:   # canonical state_log append. The delta file MUST contain at least one record whose\n113:   # `type === \"iteration\"` so the reducer can rehydrate iteration state after a partial\n114:   # run. Variants like `\"iteration_delta\"` are silently dropped by the reducer; the\n115:   # post_dispatch_validate step enforces the canonical type below.\n116:   delta_dir: \"{artifact_dir}/deltas\"\n117:   delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n118:   research_output: \"{artifact_dir}/research.md\"\n119:   resource_map_output: \"{artifact_dir}/resource-map.md\"\n120:   archive_root: \"{artifact_archive_root}\"\n121:   synthesis_snapshot_pattern: \"{artifact_dir}/synthesis-v{generation}.md\"\n122: \n123: # ─────────────────────────────────────────────────────────────────\n124: # WORKFLOW\n125: # ─────────────────────────────────────────────────────────────────\n126: workflow:\n127: \n128:   step_resolve_artifact_root:\n129:     description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n130:     note: \"Root specs keep research artifacts directly in {spec_folder}/research/. Child phases and sub-phases keep local packet directories in {spec_folder}/research/{packet}/, and archives stay local at {spec_folder}/research_archive/{packet}/.\"\n131:     branch_on: \"config.fanout_lineage_artifact_dir\"\n132:     if_present:\n133:       bind:\n134:         artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n135:         artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n136:         artifact_subfolder: null\n137:         artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n138:     if_absent:\n139:       command: \"node -e \\\"const { resolveArtifactRoot } = require('.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'research')));\\\"\"\n140:       outputs:\n141:         - artifact_root_dir: \"Resolved local research owner directory\"\n142:         - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n143:         - artifact_dir: \"Resolved research packet directory for this target\"\n144:         - artifact_archive_root: \"Resolved local research archive directory for this target\"\n145: \n146:   step_fanout_spawn:\n147:     description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n148:     skip_when: \"config.fanout is absent\"\n149:     instructions: |\n150:       Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n151:       isolated sub-packet under {artifact_dir}/lineages/{label}/.\n152:       After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n153:       phase_main_loop entirely (those are the single-executor path). The merge step in\n154:       phase_synthesis will consolidate results across all lineages.\n155:     sub_steps:\n156:       step_fanout_spawn_cli:\n157:         description: \"Spawn all CLI lineages in capped worker pool\"\n158:         skip_when: \"no entries in config.fanout.executors with kind != 'native'\"\n159:         command: |\n160:           node .opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs \\\n161:             --spec-folder {spec_folder} \\\n162:             --loop-type research \\\n163:             --research-topic \"{research_topic}\" \\\n164:             --fanout-config-json '{config.fanout_json}' \\\n165:             --base-artifact-dir {artifact_dir}\n166:         working_directory: \"{repo_root}\"\n167:         wait_for_completion: true\n168:       step_fanout_spawn_native:\n169:         description: \"Dispatch each native lineage as a sequential deep-research sub-agent\"\n170:         skip_when: \"no entries in config.fanout.executors with kind == 'native'\"\n171:         for_each: \"lineage in expanded native entries of config.fanout\"\n172:         dispatch:\n173:           agent: deep-research\n174:           model: opus\n175:           context: |\n176:             Execute the deep-research loop with these parameters:\n177:               spec_folder: {spec_folder}\n178:               config.fanout_lineage_artifact_dir: {artifact_dir}/lineages/{lineage.label}\n179:               session_id: fanout-{lineage.label}-{fanout_run_id}\n180:               executor: native\n181:             Run to convergence. Write all outputs to the override directory.\n182:         wait_for_completion: true\n183: \n184:   # ═══════════════════════════════════════════════════════════════\n185:   # PHASE 1: INITIALIZATION\n186:   # ═══════════════════════════════════════════════════════════════\n187:   phase_init:\n188:     purpose: Create all state files for the research session\n189:     steps:\n190: \n191:       step_preflight_contract:\n192:         action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n193:         verify:\n194:           - required_values_present: [research_topic, spec_folder, max_iterations, convergence_threshold]\n195:           - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n196:           - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n197:           - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n198:         on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n199: \n200:       step_create_directories:\n201:         action: \"Create spec folder and research packet directories if they don't exist\"\n202:         command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n203: \n204:       step_detect_resource_map:\n205:         action: \"Detect resource-map.md before config creation so init can persist the flag and seed Known Context\"\n206:         inspect:\n207:           - \"{spec_folder}/resource-map.md\"\n208:         classify:\n209:           present: \"resource-map.md exists at init\"\n210:           absent: \"resource-map.md does not exist at init\"\n211:         outputs:\n212:           - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n213:           - resource_map_known_context: \"When present: summarize the map by section with entry counts across READMEs, Documents, Commands, Agents, Skills, Specs, Scripts, Tests, Config, and Meta, plus a one-line theme summary for each section. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n214: \n215:       step_resolve_canonical_names:\n216:         action: \"Resolve canonical research packet artifact names before classification\"\n217:         inspect_legacy:\n218:           - \"{state_paths.packet_dir}/config.json\"\n219:           - \"{state_paths.packet_dir}/state.jsonl\"\n220:           - \"{state_paths.packet_dir}/strategy.md\"\n221:           - \"{state_paths.packet_dir}/dashboard.md\"\n222:           - \"{state_paths.packet_dir}/.pause\"\n223:         migration_policy: \"dual-read / single-write for 4 weeks\"\n224:         on_legacy_read:\n225:           append_jsonl: '{\"type\":\"event\",\"event\":\"migration\",\"legacyPath\":\"{legacy_path}\",\"canonicalPath\":\"{canonical_path}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n226: \n227:       step_acquire_lock:\n228:         action: \"Acquire the single-writer advisory lock before session classification\"\n229:         command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n230:         on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-research run already holds this packet.\"\n231:         note: \"Uses the promoted deep-loop-runtime loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n232:         # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n233:         # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n234:         on_halt:\n235:           action: \"Release the lock before any terminal halt branch returns control\"\n236:           applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\", \"step_preinit_spec_branch.conflict-detected\"]\n237:           command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n238:         on_cancel:\n239:           action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n240:           command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n241:         on_workflow_exit:\n242:           action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n243:           command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n244: \n245:       step_classify_session:\n246:         action: \"Classify the session before writing files\"\n247:         inspect:\n248:           - \"{state_paths.config}\"\n249:           - \"{state_paths.state_log}\"\n250:           - \"{state_paths.strategy}\"\n251:         classify:\n252:           fresh: \"None of the three state artifacts exist\"\n253:           resume: \"Config, JSONL, and strategy all exist and agree on topic/spec folder; missing wait-checkpoint fields are read as nextRunAt:null and remainingDelayMs:null\"\n254:           completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n255:           invalid-state: \"Any partial, missing, or contradictory combination\"\n256:         outputs:\n257:           - session_state: \"fresh | resume | completed-session | invalid-state\"\n258:         on_resume:\n259:           # T-YML-DPR-01 / R50-001: Resume is a WRITE-PATH. Produces `iteration-NNN.md` + JSONL appends.\n260:           # Paired with T-DOC-03 Gate 3 trigger addition (resume, save context, save memory, /memory:save).\n261:           gate3_classification: write-path\n262:           gate3_rationale: \"resume produces iteration-NNN.md writes and JSONL state-log appends\"\n263:           log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n264:           append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n265:           skip_to: phase_loop\n266:         on_restart:\n267:           action: \"Archive the current research packet under the root-level research_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n268:           command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n269:           set:\n270:             lineage_mode: \"restart\"\n271:             parent_session_id: \"{prior_session_id}\"\n272:             generation: \"{prior_generation + 1}\"\n273:           append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n274:           skip_to: step_create_config\n275:         note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract for the one-session contract.\"\n276:         on_completed_session:\n277:           log: \"Prior session already completed. Do not route directly to synthesis; archive the completed research/ tree or start a fresh packet instead.\"\n278:           halt: true\n279:           message: \"Completed deep-research packet detected. Archive or replace the existing research/ tree before starting a new session.\"\n280:         on_invalid_state:\n281:           halt: true\n282:           message: \"Existing deep-research state is incomplete or contradictory. Repair or archive the invalid research packet before continuing.\"\n283:         on_fresh:\n284:           action: \"Proceed with a new session\"\n285: \n286:       step_resolve_session_id:\n287:         action: \"Resolve init session id from caller when supplied, else preserve the auto-generated fallback\"\n288:         branch_on: \"session_id\"\n289:         if_present:\n290:           bind:\n291:             session_id_init: \"{session_id}\"\n292:         if_absent:\n293:           bind:\n294:             session_id_init: \"{AUTO_SESSION_ID}\"\n295: \n296:       step_create_config:\n297:         action: \"Create deep-research-config.json from template\"\n298:         template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json\n299:         populate:\n300:           topic: \"{research_topic}\"\n301:           maxIterations: \"{max_iterations}\"\n302:           minIterations: 3\n303:           # Semantic: newInfoRatio with negative-knowledge emphasis. See SKILL.md §\"Convergence Threshold Semantics\".\n304:           convergenceThreshold: \"{convergence_threshold}\"\n305:           convergenceMode: \"default\"\n306:           stuckThreshold: 3\n307:           minIdeaObservations: 2\n308:           maxDurationMinutes: 120\n309:           specFolder: \"{spec_folder}\"\n310:           resource_map_present: \"{resource_map_present}\"\n311:           # Honor the parsed --no-resource-map flag from deep-research.md:73 (default true; false when flag is set).\n312:           # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n313:           resource_map.emit: \"{resource_map_emit}\"\n314:           createdAt: \"{ISO_8601_NOW}\"\n315:           status: \"initialized\"\n316:           executionMode: \"auto\"\n317:           lineage.sessionId: \"{session_id_init}\"\n318:           lineage.parentSessionId: null\n319:           lineage.lineageMode: \"new\"\n320:           lineage.generation: 1\n321:           lineage.continuedFromRun: null\n322:           nextRunAt: null\n323:           remainingDelayMs: null\n324:         output: \"{state_paths.config}\"\n325: \n326:       step_create_state_log:\n327:         action: \"Initialize JSONL state log with config record\"\n328:         # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n329:         content: '{\"type\":\"config\",\"topic\":\"{research_topic}\",\"maxIterations\":{max_iterations},\"minIterations\":3,\"convergenceThreshold\":{convergence_threshold},\"convergenceMode\":\"default\",\"minIdeaObservations\":2,\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\",\"nextRunAt\":null,\"remainingDelayMs\":null}'\n330:         output: \"{state_paths.state_log}\"\n331: \n332:       step_create_strategy:\n333:         action: \"Create strategy file from template with initial questions\"\n334:         template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md\n335:         populate:\n336:           topic: \"{research_topic}\"\n337:           key_questions: \"Derive 3-5 key questions from the research topic\"\n338:           known_context: \"None\"\n339:           known_context_summary: \"None\"\n340:           max_iterations: \"{max_iterations}\"\n341:           convergence_threshold: \"{convergence_threshold}\"\n342:         output: \"{state_paths.strategy}\"\n343: \n344:       step_create_registry:\n345:         action: \"Initialize reducer-owned findings registry\"\n346:         content: '{\"openQuestions\":[],\"resolvedQuestions\":[],\"keyFindings\":[],\"ruledOutDirections\":[],\"metrics\":{\"iterationsCompleted\":0,\"openQuestions\":0,\"resolvedQuestions\":0,\"keyFindings\":0,\"convergenceScore\":0,\"coverageBySources\":{}}}'\n347:         output: \"{state_paths.registry}\"\n348: \n349:       step_enrich_strategy_context:\n350:         action: \"Ensure Known Context is written only after strategy.md exists\"\n351:         condition: \"prior_context_found\"\n352:         edit: \"{state_paths.strategy}\"\n353:         note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n354: \n355:       step_enrich_strategy_resource_map:\n356:         action: \"Inject resource-map status into Known Context after strategy.md exists\"\n357:         edit: \"{state_paths.strategy}\"\n358:         note: \"When resource_map_present is true, append the resource_map_known_context snapshot. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n359: \n360:       step_detect_spec_present:\n361:         action: \"Classify late-INIT spec.md state after the durable research packet exists\"\n362:         inspect:\n363:           - \"{spec_folder}/spec.md\"\n364:           - \"{state_paths.lock_file}\"\n365:         classify:\n366:           no-spec: \"spec.md is absent before any pre-init mutation\"\n367:           spec-present: \"spec.md exists and approved host anchors are available for bounded mutation\"\n368:           spec-just-created-by-this-run: \"spec.md already carries this run's DR seed markers and should not be reseeded\"\n369:           conflict-detected: \"missing host anchor, duplicate markers, or generated-block ambiguity makes mutation unsafe\"\n370:         outputs:\n371:           - folder_state: \"no-spec | spec-present | spec-just-created-by-this-run | conflict-detected\"\n372:           - normalized_topic: \"Trim, lowercase, and collapse whitespace in research_topic before dedupe checks\"\n373:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"spec_check_result\",\"folder_state\":\"{folder_state}\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"lockPath\":\"{state_paths.lock_file}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n374: \n375:       step_preinit_spec_branch:\n376:         action: \"Run the bounded pre-init spec branch required by spec_check_protocol\"\n377:         protocol_reference: \".opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md\"\n378:         branches:\n379:           no-spec:\n380:             create: \"{spec_folder}/spec.md\"\n381:             seed_markers:\n382:               - \"<!-- DR-SEED:REQUIREMENTS -->\"\n383:               - \"<!-- DR-SEED:SCOPE -->\"\n384:             requirements_host: \"Seed Requirements from the research ask without broadening scope\"\n385:             scope_host: \"Seed Scope from the research ask without inventing implementation details\"\n386:             set:\n387:               folder_state: \"spec-just-created-by-this-run\"\n388:               validate_spec_doc: true\n389:             append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_seed_created\",\"folder_state\":\"spec-just-created-by-this-run\",\"anchors_touched\":[\"Requirements\",\"Scope\"],\"diff_summary\":\"Seeded Level 1 spec.md from research topic with DR seed markers.\",\"seed_markers\":[\"DR-SEED:REQUIREMENTS\",\"DR-SEED:SCOPE\"],\"timestamp\":\"{ISO_8601_NOW}\"}'\n390:           spec-present:\n391:             edit: \"{spec_folder}/spec.md\"\n392:             set:\n393:               validate_spec_doc: true\n394:             idempotency_check:\n395:               host_anchor: \"Open Questions\"\n396:               normalized_match: \"Normalize the existing anchor text by lowercasing, stripping punctuation, collapsing whitespace, and trimming before comparing with {normalized_topic}.\"\n397:               if_match:\n398:                 skip_append: true\n399:                 append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_deduped\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\"],\"diff_summary\":\"Skipped duplicate pre-init topic append because normalized topic already exists in Open Questions.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n400:               if_no_match:\n401:                 append_only:\n402:                   - host_anchor: \"Open Questions\"\n403:                     content: \"Add the normalized research topic only if it is not already present.\"\n404:                   - host_anchor: \"Research Context\"\n405:                     content: \"Add a bounded note that deep-research is active for this topic and that research/research.md remains canonical.\"\n406:                 append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_added\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\",\"Research Context\"],\"diff_summary\":\"Appended bounded pre-init research context for the normalized topic.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n407:           spec-just-created-by-this-run:\n408:             verify_markers:\n409:               - \"<!-- DR-SEED:REQUIREMENTS -->\"\n410:               - \"<!-- DR-SEED:SCOPE -->\"\n411:             set:\n412:               validate_spec_doc: false\n413:             note: \"Treat already-seeded spec.md as a no-op guard and continue.\"\n414:           conflict-detected:\n415:             append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Pre-init spec.md mutation is ambiguous or unsafe.\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n416:             halt: true\n417: \n418:       step_validate_preinit_spec_doc:\n419:         action: \"Run targeted strict validation after any deep-research pre-init spec.md mutation\"\n420:         condition: \"validate_spec_doc\"\n421:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n422:         note: \"This enforces the authored-spec markdown structural contract without applying full-packet required-file or completeness checks to workflow-owned research artifacts. It uses the Node validation orchestrator, whose strict path was measured at about 108ms for a fresh Level 3 packet on the local harness.\"\n423: \n424:       step_telemetry_heartbeat_started:\n425:         action: \"Emit a single-loop started row in the orchestration status ledger\"\n426:         skip_when: \"config.fanout is present\"\n427:         canonical_lifecycle_event: \"iteration_start\"\n428:         command: |\n429:           node --experimental-strip-types --input-type=module <<'EOF'\n430:           import { readFileSync } from 'node:fs';\n431: \n432:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n433:           import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n434: \n435:           const { appendObservabilityEvent } = observabilityEvents;\n436:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n437:           const timestamp = '{ISO_8601_NOW}';\n438:           const sessionId = String(config.lineage?.sessionId ?? '{AUTO_SESSION_ID}');\n439:           const generation = Number(config.lineage?.generation ?? 1);\n440:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n441:           const row = {\n442:             event: 'started',\n443:             label: 'single',\n444:             at: timestamp,\n445:             duration_ms: 0,\n446:             loop_type: 'research',\n447:             sessionId,\n448:             generation,\n449:             gauges: { iterations: 0, elapsed_ms: 0, score: 0 },\n450:           };\n451: \n452:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n453:             diffData: { event: row.event, label: row.label, sessionId, generation, gauges: { iterations: 0, score: 0 } },\n454:             diffField: 'state_hash',\n455:           });\n456:           if (appended) {\n457:             try {\n458:               appendObservabilityEvent(observabilityPath, row, {\n459:                 producer: 'deep-research-auto',\n460:                 stream: 'single-loop-telemetry',\n461:                 subject: { label: row.label, sessionId, generation },\n462:                 event: row.event,\n463:                 status: 'running',\n464:               });\n465:             } catch {}\n466:           }\n467:           EOF\n468:         working_directory: \"{repo_root}\"\n469:         outputs:\n470:           - status_ledger_started: \"A fan-out-shaped status row with label single and event started\"\n471: \n472:       step_init_complete:\n473:         log: \"Initialization complete. Config, state, and strategy files created.\"\n474:         set: { current_iteration: 1, current_segment: 1, stuck_count: 0 }\n475: \n476:   # ═══════════════════════════════════════════════════════════════\n477:   # PHASE 2: ITERATION LOOP\n478:   # ═══════════════════════════════════════════════════════════════\n479:   phase_loop:\n480:     purpose: Dispatch agent iterations until convergence\n481:     repeat: true\n482:     max_repeats: \"{max_iterations}\"\n483:     steps:\n484: \n485:       step_read_state:\n486:         action: \"Read current state from JSONL and strategy\"\n487:         read:\n488:           - \"{state_paths.state_log}\"\n489:           - \"{state_paths.strategy}\"\n490:           - \"{state_paths.config}\"\n491:         extract:\n492:           - iteration_count: \"Count lines where type === 'iteration'\"\n493:           - current_iteration: \"iteration_count + 1\"\n494:           - current_segment: \"Latest segment_start event segment, else 1\"\n495:           - last_newInfoRatio: \"Extract newInfoRatio from last iteration record\"\n496:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n497:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n498:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n499:           - next_focus: \"Extract 'Next Focus' section from strategy.md\"\n500:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n501:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n502:           - carried_forward_open_questions: \"Extract 'Carried-Forward Open Questions' section from strategy.md, else '[None yet]'\"\n503:           - answered_count: \"Count answered questions from strategy.md\"\n504:           - total_questions: \"Count total questions tracked in strategy.md\"\n505:           - resource_map_present: \"Extract boolean from deep-research-config.json, default false\"\n506:           - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource map: prior-inventoried files are listed in {spec_folder}/resource-map.md; treat them as the exclusion set when hunting for net-new files; flag only missed-from-map candidates as gaps.' Else return 'Resource map: resource-map.md not present; skipping coverage gate.'\"\n507:           - memory_context_prompt_line: \"If a refreshed memory context summary exists from the previous iteration, return 'Memory context refresh: {summary}'. Else use prior_context_summary from startup when available; otherwise return 'Memory context refresh: none loaded yet.'\"\n508:           - least_explored: \"First unanswered question not covered by the most recent iteration focus, else first unanswered question\"\n509:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n510:           - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n511:           - nextRunAt: \"Extract nullable nextRunAt from deep-research-config.json, default null\"\n512:           - remainingDelayMs: \"Extract nullable remainingDelayMs from deep-research-config.json, default null\"\n513:           - min_iterations_present: \"Boolean true when deep-research-config.json has a numeric minIterations field\"\n514:           - min_iterations_missing_warning: \"Boolean true when minIterations is missing; use no floor and log a warning so older configs keep prior stop behavior\"\n515:           - min_iterations_raw: \"Extract numeric minIterations from deep-research-config.json when present, default 0\"\n516:           - effective_min_iterations: \"Clamp min_iterations_raw to the inclusive range 0..max_iterations; if min_iterations_raw exceeds max_iterations, use max_iterations\"\n517:           - min_iterations_clamped: \"Boolean true when min_iterations_raw > max_iterations\"\n518:           - min_iterations_guard_already_passed: \"Boolean true when state_log already contains event == 'min_iterations_guard_pass'\"\n519:           - convergence_mode: \"Extract convergenceMode when it is 'default' or 'off'; default to 'default'\"\n520:           - convergence_mode_warning: \"Boolean true when convergenceMode is present with an unsupported value; use 'default'\"\n521:           - rejected_patterns_count: \"Read registry.rejectedPatterns length when registry exists, else 0\"\n522:           - rejected_candidate_matches: \"Read registry.suppressedCandidates when registry exists, else []\"\n523:           - rejected_pattern_fuzzy_threshold: \"Read config.rejectedPatternFuzzyThreshold when present, else 0.85\"\n524:           - min_idea_observations: \"Read config.minIdeaObservations when present, default 2; clamp to 1..10\"\n525:           - observed_ideas_count: \"Read registry.observedIdeas length when registry exists, else 0\"\n526:           - promoted_ideas_count: \"Read registry.promotedIdeas length when registry exists, else 0\"\n527:           - promoted_ideas_list: \"Read registry.promotedIdeas idea text in rank order when registry exists, else []\"\n528:           - suppressed_ideas_count: \"Read registry.suppressedIdeas length when registry exists, else 0\"\n529: \n530:       step_run_now_check:\n531:         action: \"Detect and consume a one-shot run-now sentinel before pause/convergence/dispatch\"\n532:         command: |\n533:           node <<'EOF'\n534:           const { appendFileSync, existsSync, renameSync, unlinkSync } = require('node:fs');\n535: \n536:           const stateLogPath = \"{state_paths.state_log}\";\n537:           const sentinelPath = \"{state_paths.run_now_sentinel}\";\n538:           const pausePath = \"{state_paths.pause_sentinel}\";\n539:           const timestamp = \"{ISO_8601_NOW}\";\n540:           const sessionId = \"{config.lineage.sessionId}\";\n541:           const generation = Number(\"{config.lineage.generation}\");\n542:           const run = Number(\"{current_iteration}\");\n543: \n544:           function append(event) {\n545:             appendFileSync(\n546:               stateLogPath,\n547:               `${JSON.stringify({\n548:                 type: \"event\",\n549:                 mode: \"research\",\n550:                 run,\n551:                 timestamp,\n552:                 sessionId,\n553:                 generation,\n554:                 ...event,\n555:               })}\\n`,\n556:               \"utf8\",\n557:             );\n558:           }\n559: \n560:           if (existsSync(sentinelPath)) {\n561:             append({ event: \"run_now_requested\", sentinelPath });\n562:             if (existsSync(pausePath)) {\n563:               append({\n564:                 event: \"run_now_rejected\",\n565:                 reason: \"loop_paused\",\n566:                 sentinelPath,\n567:                 pauseSentinelPath: pausePath,\n568:               });\n569:             } else {\n570:               const claimPath = `${sentinelPath}.consuming.${process.pid}.${Date.now()}`;\n571:               try {\n572:                 renameSync(sentinelPath, claimPath);\n573:                 unlinkSync(claimPath);\n574:                 append({\n575:                   event: \"run_now_accepted\",\n576:                   sentinelPath,\n577:                   dispatchEvent: \"iteration_start\",\n578:                 });\n579:               } catch (error) {\n580:                 if (!error || error.code !== \"ENOENT\") {\n581:                   throw error;\n582:                 }\n583:               }\n584:             }\n585:           }\n586:           EOF\n587:         outputs:\n588:           - run_now_requested: \"Emitted when {state_paths.run_now_sentinel} exists at the loop boundary\"\n589:           - run_now_accepted: \"Emitted after the sentinel is atomically renamed and deleted before dispatch\"\n590:           - run_now_rejected: \"Emitted with reason loop_paused when pause takes precedence; sentinel remains present\"\n591: \n592:       step_check_pause_sentinel:\n593:         action: \"Check for pause sentinel file\"\n594:         check: \"Does {state_paths.pause_sentinel} exist?\"\n595:         if_exists:\n596:           log_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n597:           message: \"Research paused. Delete research/.deep-research-pause to resume.\"\n598:           halt: true\n599:         if_not_exists:\n600:           proceed: true\n601: \n602:       step_validate_convergence_config:\n603:         action: \"Validate convergence floor settings when loading config\"\n604:         if_min_iterations_missing:\n605:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"fallback\":0,\"message\":\"minIterations missing; using no convergence floor for backward compatibility.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n606:           log: \"minIterations missing; using no convergence floor for backward compatibility.\"\n607:         if_min_iterations_clamped:\n608:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"configured\":{min_iterations_raw},\"effective\":{effective_min_iterations},\"maxIterations\":{max_iterations},\"message\":\"minIterations exceeds maxIterations; clamping to the hard cap.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n609:           log: \"minIterations exceeds maxIterations; clamping to the hard cap.\"\n610:         if_convergence_mode_invalid:\n611:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"convergenceMode\",\"fallback\":\"default\",\"message\":\"Unsupported convergenceMode; using default convergence behavior.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n612:           log: \"Unsupported convergenceMode; using default convergence behavior.\"\n613: \n614:       step_graph_convergence:\n615:         action: \"Evaluate coverage-graph convergence before the inline 3-signal vote and persist the graph decision snapshot\"\n616:         bash: 'node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"research\" --session-id \"{config.lineage.sessionId}\"'\n617:         note: \"Run before the inline vote. STOP from the inline 3-signal vote is allowed only when the graph decision is STOP_ALLOWED or absent.\"\n618:         outputs:\n619:           - graph_decision: \"Tool decision value (CONTINUE | STOP_ALLOWED | STOP_BLOCKED), else null when unavailable\"\n620:           - graph_decision_json: \"JSON-encoded graph decision string, else null\"\n621:           - graph_signals_json: \"Tool signals object, else {}\"\n622:           - graph_blockers_json: \"Tool blockers array, else []\"\n623:           - graph_trace_json: \"Tool trace payload, else []\"\n624:           - graph_convergence_score: \"signals.blendedScore when present, else the best available graph score, else 0\"\n625:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"research\",\"run\":{current_iteration},\"decision\":{graph_decision_json},\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n626: \n627:       step_check_convergence:\n628:         action: \"Evaluate stop conditions and combine the inline 3-signal vote with graph convergence\"\n629:         algorithm: |\n630:           1. if iteration_count >= max_iterations: STOP (maxIterationsReached). This terminal cap bypasses quality-guard overrides; record failed guards/blockers as synthesis evidence instead of continuing.\n631:           2. if stuck_count >= config.stuckThreshold: STUCK_RECOVERY\n632:           3. if convergence_mode == \"off\": skip convergence stop candidates and continue unless a terminal cap, pause sentinel, or recovery halt has already fired.\n633:           4. if remaining_questions == 0: STOP (all_questions_answered)\n634:           5. GRAPH-ASSISTED COMPOSITE CONVERGENCE:\n635:                step_graph_convergence already recorded graph_decision, graph_signals_json, graph_blockers_json, and graph_convergence_score for this run.\n636:                The existing inline 3-signal vote still computes the inline STOP candidate and is not replaced.\n637:                signals = []\n638:                Filter: exclude iterations where status == thought from signal inputs (use only evidence iterations)\n639:                a) Rolling average (w=0.30, needs 3+ iterations):\n640:                   avg = mean(last 3 newInfoRatios)\n641:                   stop if avg < convergence_threshold\n642:                b) MAD noise floor (w=0.35, needs 4+ iterations):\n643:                   noiseFloor = MAD(all ratios) * 1.4826\n644:                   stop if latest ratio <= noiseFloor\n645:                c) Question entropy (w=0.35):\n646:                   coverage = answered / total questions\n647:                   stop if coverage >= 0.85\n648:                Redistribute weights for unavailable signals.\n649:                if weighted_stop_score > 0.60: inline_stop_candidate = true\n650:                Combined stop rule: STOP only if the inline 3-signal vote says STOP AND graph_decision is STOP_ALLOWED or absent.\n651:                if inline_stop_candidate and graph_decision == \"STOP_BLOCKED\":\n652:                  decision = \"BLOCKED\"\n653:                  reason = \"blockedStop\"\n654:                  stop_blocked = true\n655:                  blocked_by_json = JSON array derived from graph_blockers_json\n656:                  blocked_by_csv = comma-separated blocker names derived from graph_blockers_json\n657:                  gate_convergence_pass = false\n658:                  gate_convergence_score = graph_convergence_score\n659:                  gate_key_question_coverage_pass = no blocker named questionCoverage\n660:                  gate_evidence_density_pass = no blocker named sourceDiversity or evidenceDepth\n661:                  gate_evidence_density_sources = graph_signals_json.sourceDiversity or 0\n662:                  gate_hotspot_saturation_pass = true\n663:                  recovery_strategy = first blocker reason/message, else \"Collect deeper graph evidence before stopping.\"\n664:                else if inline_stop_candidate and (graph_decision == \"STOP_ALLOWED\" or graph_decision is absent):\n665:                  decision = \"STOP\"\n666:                  reason = \"composite_converged\"\n667:                  stop_blocked = false\n668:           6. else: CONTINUE\n669:           7. if decision == \"STOP\" and reason != \"maxIterationsReached\" and effective_min_iterations > 1 and iteration_count < effective_min_iterations:\n670:                decision = \"CONTINUE\"\n671:                reason = \"minIterationsNotReached\"\n672:                min_iterations_guard_blocked = true\n673:                min_iterations_guard_pass = false\n674:           8. if effective_min_iterations > 1 and iteration_count >= effective_min_iterations and min_iterations_guard_already_passed == false:\n675:                min_iterations_guard_pass = true\n676:           9. if decision == \"STOP\" and reason != \"maxIterationsReached\":\n677:                guardResult = checkQualityGuards(state, strategy)\n678:                if not guardResult.passed:\n679:                  log: \"Quality guard failed: {guardResult.violations}. Overriding STOP to CONTINUE.\"\n680:                  decision = \"CONTINUE\"\n681:           See convergence.md for full pseudocode and signal definitions.\n682:           Segment-aware convergence is experimental/reference-only; live workflow uses the current session as a single segment.\n683:         outputs:\n684:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n685:           - reason: \"Human-readable stop reason\"\n686:           - stop_blocked: \"Boolean marker set when graph convergence vetoes an inline STOP candidate\"\n687:           - blocked_by_json: \"JSON array of graph blocker names when decision == BLOCKED\"\n688:           - blocked_by_csv: \"Comma-separated graph blocker names when decision == BLOCKED\"\n689:           - gate_convergence_pass: \"Boolean pass/fail for the graph-assisted convergence gate\"\n690:           - gate_convergence_score: \"Numeric score recorded from graph convergence\"\n691:           - gate_key_question_coverage_pass: \"Boolean pass/fail derived from graph blocker coverage signals\"\n692:           - gate_evidence_density_pass: \"Boolean pass/fail derived from graph blocker evidence-depth signals\"\n693:           - gate_evidence_density_sources: \"Source-diversity count or equivalent evidence-depth proxy\"\n694:           - gate_hotspot_saturation_pass: \"Research placeholder gate; true unless an explicit blocker sets otherwise\"\n695:           - recovery_strategy: \"One-line hint describing the next research action when decision == BLOCKED or STUCK_RECOVERY\"\n696:           - min_iterations_guard_pass: \"Boolean true when the configured convergence floor has cleared for the first time\"\n697:           - min_iterations_guard_blocked: \"Boolean true when the configured convergence floor overrides a STOP candidate to CONTINUE\"\n698: \n699:       step_emit_min_iterations_guard_pass:\n700:         action: \"Persist a first-class event when the convergence floor clears\"\n701:         if_pass:\n702:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"min_iterations_guard_pass\",\"mode\":\"research\",\"run\":{current_iteration},\"iterationCount\":{iteration_count},\"minIterations\":{effective_min_iterations},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n703:           log: \"Minimum iteration floor cleared for convergence stopping.\"\n704: \n705:       step_emit_blocked_stop:\n706:         action: \"Persist a first-class blocked_stop event when the legal-stop decision tree returns blocked\"\n707:         if_blocked:\n708:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"research\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergence\":{\"pass\":{gate_convergence_pass},\"score\":{gate_convergence_score}},\"keyQuestionCoverage\":{\"pass\":{gate_key_question_coverage_pass},\"answered\":{answered_count},\"total\":{total_questions}},\"evidenceDensity\":{\"pass\":{gate_evidence_density_pass},\"sources\":{gate_evidence_density_sources}},\"hotspotSaturation\":{\"pass\":{gate_hotspot_saturation_pass}}},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n709:           log: \"Graph convergence blocked STOP. Failed blockers: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n710:           set:\n711:             decision: \"CONTINUE\"\n712:             reason: \"blockedStop\"\n713:             stop_blocked: false\n714: \n715:       step_handle_convergence:\n716:         action: \"Act on convergence decision\"\n717:         if_stop:\n718:           log: \"Loop stopping. Reason: {reason}\"\n719:           skip_to: phase_synthesis\n720:         if_stuck_recovery:\n721:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n722:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n723:           set: { next_focus: \"RECOVERY: Widen scope. Try fundamentally different approach. Least-explored question: {least_explored}\" }\n724:           reset: { stuck_count: 0 }\n725:         if_continue:\n726:           log: \"Iteration {current_iteration}: Continuing. Focus: {next_focus}\"\n727: \n728:       step_rejected_pattern_cache:\n729:         action: \"Apply reducer-derived rejected-pattern suppression before dispatch candidate selection\"\n730:         read:\n731:           - \"{state_paths.state_log}\"\n732:           - \"{state_paths.registry}\"\n733:           - \"{state_paths.strategy}\"\n734:         candidate_sources:\n735:           next_focus:\n736:             category: \"next-focus\"\n\n(Output capped at 50 KB. Showing lines 1-736. Use offset=737 to continue.)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DEEP RESEARCH: AUTONOMOUS DEEP RESEARCH LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# YAML PREDICATE GRAMMAR CONTRACT (S7 / M11):\n# - This asset does not currently use typed BooleanExpr predicates under\n#   `when:`; flow control is branch-label-driven (`on_resume`, `on_fresh`,\n#   `on_restart`, etc.). Retain the existing shape.\n# - `after:` carries prose timing / narrative notes if needed; `when:` in\n#   this file is reserved for future typed predicates and must NOT carry\n#   free-form narrative prose.\n# - See `.opencode/skills/system-spec-kit/shared/predicates/boolean-expr.ts`\n#   for the canonical BooleanExpr grammar.\n#\n# GATE 3 CLASSIFICATION (T-YML-DPR-01 / paired with T-DOC-03 R50-001):\n# - `resume` is a tested WRITE-PATH that produces `iteration-NNN.md` files\n#   and JSONL state-log appends. The workflow classifies resume as\n#   write-path below (see `gate3_classification` fields) so Gate 3 trigger\n#   extraction can surface resume correctly rather than false-negative.\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Research Loop Manager","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DEEP RESEARCH: AUTONOMOUS DEEP RESEARCH LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# YAML PREDICATE GRAMMAR CONTRACT (S7 / M11):\n# - This asset does not currently use typed BooleanExpr predicates under\n#   `when:`; flow control is branch-label-driven (`on_resume`, `on_fresh`,\n#   `on_restart`, etc.). Retain the existing shape.\n# - `after:` carries prose timing / narrative notes if needed; `when:` in\n#   this file is reserved for future typed predicates and must NOT carry\n#   free-form narrative prose.\n# - See `.opencode/skills/system-spec-kit/shared/predicates/boolean-expr.ts`\n#   for the canonical BooleanExpr grammar.\n#\n# GATE 3 CLASSIFICATION (T-YML-DPR-01 / paired with T-DOC-03 R50-001):\n# - `resume` is a tested WRITE-PATH that produces `iteration-NNN.md` files\n#   and JSONL state-log appends. The workflow classifies resume as\n#   write-path below (see `gate3_classification` fields) so Gate 3 trigger\n#   extraction can surface resume correctly rather than false-negative.\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Research Loop Manager\npurpose: Iterative deep research with convergence detection\naction: Run deep-research loop from initialization through synthesis\noperating_mode:\n  workflow: iterative_loop\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_research_state\n  validation: convergence_detection\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING PRINCIPLES\n# ─────────────────────────────────────────────────────────────────\noperating_principles:\n  core: \"Fresh context per iteration + externalized state = no context degradation\"\n  approach: \"Dispatch focused agent, evaluate convergence, repeat or stop\"\n  mandate: \"Never hold findings in memory; write everything to files\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (from setup phase)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  research_topic: \"[RESEARCH_TOPIC] - Topic to investigate deeply. REQUIRED.\"\n  spec_folder: \"[SPEC_FOLDER] - Spec folder path. REQUIRED.\"\n  max_iterations: \"[MAX_ITERATIONS] - Maximum loop iterations. Default: 10.\"\n  convergence_threshold: \"[CONVERGENCE_THRESHOLD] - Stop threshold. Default: 0.05.\"\n\n# ─────────────────────────────────────────────────────────────────\n# CONTEXT LOADING\n# ─────────────────────────────────────────────────────────────────\ncontext_loading:\n  trigger: \"At workflow START, before phase_init\"\n  purpose: \"Load prior research context for the topic and buffer it until strategy.md exists\"\n  mcp_integration:\n    tool: memory_context\n    note: \"Call MCP tools directly - NEVER through Code Mode\"\n    parameters: { input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n  when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n  behavior:\n    if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n    if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n\n# ─────────────────────────────────────────────────────────────────\n# SKILL REFERENCE\n# ─────────────────────────────────────────────────────────────────\nskill_reference:\n  skill: deep-loop-workflows\n  skill_md: .opencode/skills/deep-loop-workflows/deep-research/SKILL.md\n  references:\n    loop_protocol: .opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md\n    spec_check_protocol: .opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md\n    state_format: .opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md\n    convergence: .opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md\n  templates:\n    config: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json\n    strategy: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md\n\n# ─────────────────────────────────────────────────────────────────\n# AGENT CONFIGURATION\n# ─────────────────────────────────────────────────────────────────\nagent_config:\n  agent: deep-research\n  agent_file: \".opencode/agents/deep-research.md\"\n  # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n  model: opus\n  leaf_only: true\n  tools: [Read, Write, Edit, Bash, Grep, Glob, WebFetch]\n  mcp_servers: [mk-spec-memory]\n  tool_call_budget: { target: 8, max: 12 }\n\n# ─────────────────────────────────────────────────────────────────\n# STATE FILE PATHS\n# ─────────────────────────────────────────────────────────────────\nstate_paths:\n  # Template paths document the canonical packet layout. Runtime resolution happens via\n  # step_resolve_artifact_root plus the shared resolver, so root specs keep root-local\n  # research/ and child phases keep local research/ packet directories.\n  packet_dir: \"{artifact_dir}\"\n  config: \"{artifact_dir}/deep-research-config.json\"\n  state_log: \"{artifact_dir}/deep-research-state.jsonl\"\n  status_ledger: \"{artifact_dir}/orchestration-status.log\"\n  strategy: \"{artifact_dir}/deep-research-strategy.md\"\n  registry: \"{artifact_dir}/deep-research-findings-registry.json\"\n  dashboard: \"{artifact_dir}/deep-research-dashboard.md\"\n  pause_sentinel: \"{artifact_dir}/.deep-research-pause\"\n  run_now_sentinel: \"{artifact_dir}/.deep-research-run-now\"\n  lock_file: \"{artifact_dir}/.deep-research.lock\"\n  prompt_dir: \"{artifact_dir}/prompts\"\n  iteration_dir: \"{artifact_dir}/iterations\"\n  iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n  # Per-iteration structured delta stream (one file per iteration) — complement to the\n  # canonical state_log append. The delta file MUST contain at least one record whose\n  # `type === \"iteration\"` so the reducer can rehydrate iteration state after a partial\n  # run. Variants like `\"iteration_delta\"` are silently dropped by the reducer; the\n  # post_dispatch_validate step enforces the canonical type below.\n  delta_dir: \"{artifact_dir}/deltas\"\n  delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n  research_output: \"{artifact_dir}/research.md\"\n  resource_map_output: \"{artifact_dir}/resource-map.md\"\n  archive_root: \"{artifact_archive_root}\"\n  synthesis_snapshot_pattern: \"{artifact_dir}/synthesis-v{generation}.md\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW\n# ─────────────────────────────────────────────────────────────────\nworkflow:\n\n  step_resolve_artifact_root:\n    description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n    note: \"Root specs keep research artifacts directly in {spec_folder}/research/. Child phases and sub-phases keep local packet directories in {spec_folder}/research/{packet}/, and archives stay local at {spec_folder}/research_archive/{packet}/.\"\n    branch_on: \"config.fanout_lineage_artifact_dir\"\n    if_present:\n      bind:\n        artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_subfolder: null\n        artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n    if_absent:\n      command: \"node -e \\\"const { resolveArtifactRoot } = require('.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'research')));\\\"\"\n      outputs:\n        - artifact_root_dir: \"Resolved local research owner directory\"\n        - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n        - artifact_dir: \"Resolved research packet directory for this target\"\n        - artifact_archive_root: \"Resolved local research archive directory for this target\"\n\n  step_fanout_spawn:\n    description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n    skip_when: \"config.fanout is absent\"\n    instructions: |\n      Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n      isolated sub-packet under {artifact_dir}/lineages/{label}/.\n      After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n      phase_main_loop entirely (those are the single-executor path). The merge step in\n      phase_synthesis will consolidate results across all lineages.\n    sub_steps:\n      step_fanout_spawn_cli:\n        description: \"Spawn all CLI lineages in capped worker pool\"\n        skip_when: \"no entries in config.fanout.executors with kind != 'native'\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs \\\n            --spec-folder {spec_folder} \\\n            --loop-type research \\\n            --research-topic \"{research_topic}\" \\\n            --fanout-config-json '{config.fanout_json}' \\\n            --base-artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n      step_fanout_spawn_native:\n        description: \"Dispatch each native lineage as a sequential deep-research sub-agent\"\n        skip_when: \"no entries in config.fanout.executors with kind == 'native'\"\n        for_each: \"lineage in expanded native entries of config.fanout\"\n        dispatch:\n          agent: deep-research\n          model: opus\n          context: |\n            Execute the deep-research loop with these parameters:\n              spec_folder: {spec_folder}\n              config.fanout_lineage_artifact_dir: {artifact_dir}/lineages/{lineage.label}\n              session_id: fanout-{lineage.label}-{fanout_run_id}\n              executor: native\n            Run to convergence. Write all outputs to the override directory.\n        wait_for_completion: true\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 1: INITIALIZATION\n  # ═══════════════════════════════════════════════════════════════\n  phase_init:\n    purpose: Create all state files for the research session\n    steps:\n\n      step_preflight_contract:\n        action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n        verify:\n          - required_values_present: [research_topic, spec_folder, max_iterations, convergence_threshold]\n          - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n          - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n          - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n        on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n\n      step_create_directories:\n        action: \"Create spec folder and research packet directories if they don't exist\"\n        command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n\n      step_detect_resource_map:\n        action: \"Detect resource-map.md before config creation so init can persist the flag and seed Known Context\"\n        inspect:\n          - \"{spec_folder}/resource-map.md\"\n        classify:\n          present: \"resource-map.md exists at init\"\n          absent: \"resource-map.md does not exist at init\"\n        outputs:\n          - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n          - resource_map_known_context: \"When present: summarize the map by section with entry counts across READMEs, Documents, Commands, Agents, Skills, Specs, Scripts, Tests, Config, and Meta, plus a one-line theme summary for each section. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_resolve_canonical_names:\n        action: \"Resolve canonical research packet artifact names before classification\"\n        inspect_legacy:\n          - \"{state_paths.packet_dir}/config.json\"\n          - \"{state_paths.packet_dir}/state.jsonl\"\n          - \"{state_paths.packet_dir}/strategy.md\"\n          - \"{state_paths.packet_dir}/dashboard.md\"\n          - \"{state_paths.packet_dir}/.pause\"\n        migration_policy: \"dual-read / single-write for 4 weeks\"\n        on_legacy_read:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"migration\",\"legacyPath\":\"{legacy_path}\",\"canonicalPath\":\"{canonical_path}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_acquire_lock:\n        action: \"Acquire the single-writer advisory lock before session classification\"\n        command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n        on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-research run already holds this packet.\"\n        note: \"Uses the promoted deep-loop-runtime loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n        # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n        # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n        on_halt:\n          action: \"Release the lock before any terminal halt branch returns control\"\n          applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\", \"step_preinit_spec_branch.conflict-detected\"]\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n        on_cancel:\n          action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n        on_workflow_exit:\n          action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n\n      step_classify_session:\n        action: \"Classify the session before writing files\"\n        inspect:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.strategy}\"\n        classify:\n          fresh: \"None of the three state artifacts exist\"\n          resume: \"Config, JSONL, and strategy all exist and agree on topic/spec folder; missing wait-checkpoint fields are read as nextRunAt:null and remainingDelayMs:null\"\n          completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n          invalid-state: \"Any partial, missing, or contradictory combination\"\n        outputs:\n          - session_state: \"fresh | resume | completed-session | invalid-state\"\n        on_resume:\n          # T-YML-DPR-01 / R50-001: Resume is a WRITE-PATH. Produces `iteration-NNN.md` + JSONL appends.\n          # Paired with T-DOC-03 Gate 3 trigger addition (resume, save context, save memory, /memory:save).\n          gate3_classification: write-path\n          gate3_rationale: \"resume produces iteration-NNN.md writes and JSONL state-log appends\"\n          log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: phase_loop\n        on_restart:\n          action: \"Archive the current research packet under the root-level research_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n          command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n          set:\n            lineage_mode: \"restart\"\n            parent_session_id: \"{prior_session_id}\"\n            generation: \"{prior_generation + 1}\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"research\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: step_create_config\n        note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract for the one-session contract.\"\n        on_completed_session:\n          log: \"Prior session already completed. Do not route directly to synthesis; archive the completed research/ tree or start a fresh packet instead.\"\n          halt: true\n          message: \"Completed deep-research packet detected. Archive or replace the existing research/ tree before starting a new session.\"\n        on_invalid_state:\n          halt: true\n          message: \"Existing deep-research state is incomplete or contradictory. Repair or archive the invalid research packet before continuing.\"\n        on_fresh:\n          action: \"Proceed with a new session\"\n\n      step_resolve_session_id:\n        action: \"Resolve init session id from caller when supplied, else preserve the auto-generated fallback\"\n        branch_on: \"session_id\"\n        if_present:\n          bind:\n            session_id_init: \"{session_id}\"\n        if_absent:\n          bind:\n            session_id_init: \"{AUTO_SESSION_ID}\"\n\n      step_create_config:\n        action: \"Create deep-research-config.json from template\"\n        template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json\n        populate:\n          topic: \"{research_topic}\"\n          maxIterations: \"{max_iterations}\"\n          minIterations: 3\n          # Semantic: newInfoRatio with negative-knowledge emphasis. See SKILL.md §\"Convergence Threshold Semantics\".\n          convergenceThreshold: \"{convergence_threshold}\"\n          convergenceMode: \"default\"\n          stuckThreshold: 3\n          minIdeaObservations: 2\n          maxDurationMinutes: 120\n          specFolder: \"{spec_folder}\"\n          resource_map_present: \"{resource_map_present}\"\n          # Honor the parsed --no-resource-map flag from deep-research.md:73 (default true; false when flag is set).\n          # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n          resource_map.emit: \"{resource_map_emit}\"\n          createdAt: \"{ISO_8601_NOW}\"\n          status: \"initialized\"\n          executionMode: \"auto\"\n          lineage.sessionId: \"{session_id_init}\"\n          lineage.parentSessionId: null\n          lineage.lineageMode: \"new\"\n          lineage.generation: 1\n          lineage.continuedFromRun: null\n          nextRunAt: null\n          remainingDelayMs: null\n        output: \"{state_paths.config}\"\n\n      step_create_state_log:\n        action: \"Initialize JSONL state log with config record\"\n        # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n        content: '{\"type\":\"config\",\"topic\":\"{research_topic}\",\"maxIterations\":{max_iterations},\"minIterations\":3,\"convergenceThreshold\":{convergence_threshold},\"convergenceMode\":\"default\",\"minIdeaObservations\":2,\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\",\"nextRunAt\":null,\"remainingDelayMs\":null}'\n        output: \"{state_paths.state_log}\"\n\n      step_create_strategy:\n        action: \"Create strategy file from template with initial questions\"\n        template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md\n        populate:\n          topic: \"{research_topic}\"\n          key_questions: \"Derive 3-5 key questions from the research topic\"\n          known_context: \"None\"\n          known_context_summary: \"None\"\n          max_iterations: \"{max_iterations}\"\n          convergence_threshold: \"{convergence_threshold}\"\n        output: \"{state_paths.strategy}\"\n\n      step_create_registry:\n        action: \"Initialize reducer-owned findings registry\"\n        content: '{\"openQuestions\":[],\"resolvedQuestions\":[],\"keyFindings\":[],\"ruledOutDirections\":[],\"metrics\":{\"iterationsCompleted\":0,\"openQuestions\":0,\"resolvedQuestions\":0,\"keyFindings\":0,\"convergenceScore\":0,\"coverageBySources\":{}}}'\n        output: \"{state_paths.registry}\"\n\n      step_enrich_strategy_context:\n        action: \"Ensure Known Context is written only after strategy.md exists\"\n        condition: \"prior_context_found\"\n        edit: \"{state_paths.strategy}\"\n        note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n\n      step_enrich_strategy_resource_map:\n        action: \"Inject resource-map status into Known Context after strategy.md exists\"\n        edit: \"{state_paths.strategy}\"\n        note: \"When resource_map_present is true, append the resource_map_known_context snapshot. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_detect_spec_present:\n        action: \"Classify late-INIT spec.md state after the durable research packet exists\"\n        inspect:\n          - \"{spec_folder}/spec.md\"\n          - \"{state_paths.lock_file}\"\n        classify:\n          no-spec: \"spec.md is absent before any pre-init mutation\"\n          spec-present: \"spec.md exists and approved host anchors are available for bounded mutation\"\n          spec-just-created-by-this-run: \"spec.md already carries this run's DR seed markers and should not be reseeded\"\n          conflict-detected: \"missing host anchor, duplicate markers, or generated-block ambiguity makes mutation unsafe\"\n        outputs:\n          - folder_state: \"no-spec | spec-present | spec-just-created-by-this-run | conflict-detected\"\n          - normalized_topic: \"Trim, lowercase, and collapse whitespace in research_topic before dedupe checks\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"spec_check_result\",\"folder_state\":\"{folder_state}\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"lockPath\":\"{state_paths.lock_file}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_preinit_spec_branch:\n        action: \"Run the bounded pre-init spec branch required by spec_check_protocol\"\n        protocol_reference: \".opencode/skills/deep-loop-workflows/deep-research/references/protocol/spec_check_protocol.md\"\n        branches:\n          no-spec:\n            create: \"{spec_folder}/spec.md\"\n            seed_markers:\n              - \"<!-- DR-SEED:REQUIREMENTS -->\"\n              - \"<!-- DR-SEED:SCOPE -->\"\n            requirements_host: \"Seed Requirements from the research ask without broadening scope\"\n            scope_host: \"Seed Scope from the research ask without inventing implementation details\"\n            set:\n              folder_state: \"spec-just-created-by-this-run\"\n              validate_spec_doc: true\n            append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_seed_created\",\"folder_state\":\"spec-just-created-by-this-run\",\"anchors_touched\":[\"Requirements\",\"Scope\"],\"diff_summary\":\"Seeded Level 1 spec.md from research topic with DR seed markers.\",\"seed_markers\":[\"DR-SEED:REQUIREMENTS\",\"DR-SEED:SCOPE\"],\"timestamp\":\"{ISO_8601_NOW}\"}'\n          spec-present:\n            edit: \"{spec_folder}/spec.md\"\n            set:\n              validate_spec_doc: true\n            idempotency_check:\n              host_anchor: \"Open Questions\"\n              normalized_match: \"Normalize the existing anchor text by lowercasing, stripping punctuation, collapsing whitespace, and trimming before comparing with {normalized_topic}.\"\n              if_match:\n                skip_append: true\n                append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_deduped\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\"],\"diff_summary\":\"Skipped duplicate pre-init topic append because normalized topic already exists in Open Questions.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              if_no_match:\n                append_only:\n                  - host_anchor: \"Open Questions\"\n                    content: \"Add the normalized research topic only if it is not already present.\"\n                  - host_anchor: \"Research Context\"\n                    content: \"Add a bounded note that deep-research is active for this topic and that research/research.md remains canonical.\"\n                append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_preinit_context_added\",\"folder_state\":\"spec-present\",\"anchors_touched\":[\"Open Questions\",\"Research Context\"],\"diff_summary\":\"Appended bounded pre-init research context for the normalized topic.\",\"normalized_topic\":\"{normalized_topic}\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n          spec-just-created-by-this-run:\n            verify_markers:\n              - \"<!-- DR-SEED:REQUIREMENTS -->\"\n              - \"<!-- DR-SEED:SCOPE -->\"\n            set:\n              validate_spec_doc: false\n            note: \"Treat already-seeded spec.md as a no-op guard and continue.\"\n          conflict-detected:\n            append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Pre-init spec.md mutation is ambiguous or unsafe.\",\"specPath\":\"{spec_folder}/spec.md\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            halt: true\n\n      step_validate_preinit_spec_doc:\n        action: \"Run targeted strict validation after any deep-research pre-init spec.md mutation\"\n        condition: \"validate_spec_doc\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"This enforces the authored-spec markdown structural contract without applying full-packet required-file or completeness checks to workflow-owned research artifacts. It uses the Node validation orchestrator, whose strict path was measured at about 108ms for a fresh Level 3 packet on the local harness.\"\n\n      step_telemetry_heartbeat_started:\n        action: \"Emit a single-loop started row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        canonical_lifecycle_event: \"iteration_start\"\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{AUTO_SESSION_ID}');\n          const generation = Number(config.lineage?.generation ?? 1);\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n          const row = {\n            event: 'started',\n            label: 'single',\n            at: timestamp,\n            duration_ms: 0,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: 0, elapsed_ms: 0, score: 0 },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event: row.event, label: row.label, sessionId, generation, gauges: { iterations: 0, score: 0 } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation },\n                event: row.event,\n                status: 'running',\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_started: \"A fan-out-shaped status row with label single and event started\"\n\n      step_init_complete:\n        log: \"Initialization complete. Config, state, and strategy files created.\"\n        set: { current_iteration: 1, current_segment: 1, stuck_count: 0 }\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 2: ITERATION LOOP\n  # ═══════════════════════════════════════════════════════════════\n  phase_loop:\n    purpose: Dispatch agent iterations until convergence\n    repeat: true\n    max_repeats: \"{max_iterations}\"\n    steps:\n\n      step_read_state:\n        action: \"Read current state from JSONL and strategy\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.config}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_newInfoRatio: \"Extract newInfoRatio from last iteration record\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - next_focus: \"Extract 'Next Focus' section from strategy.md\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - carried_forward_open_questions: \"Extract 'Carried-Forward Open Questions' section from strategy.md, else '[None yet]'\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - resource_map_present: \"Extract boolean from deep-research-config.json, default false\"\n          - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource map: prior-inventoried files are listed in {spec_folder}/resource-map.md; treat them as the exclusion set when hunting for net-new files; flag only missed-from-map candidates as gaps.' Else return 'Resource map: resource-map.md not present; skipping coverage gate.'\"\n          - memory_context_prompt_line: \"If a refreshed memory context summary exists from the previous iteration, return 'Memory context refresh: {summary}'. Else use prior_context_summary from startup when available; otherwise return 'Memory context refresh: none loaded yet.'\"\n          - least_explored: \"First unanswered question not covered by the most recent iteration focus, else first unanswered question\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n          - nextRunAt: \"Extract nullable nextRunAt from deep-research-config.json, default null\"\n          - remainingDelayMs: \"Extract nullable remainingDelayMs from deep-research-config.json, default null\"\n          - min_iterations_present: \"Boolean true when deep-research-config.json has a numeric minIterations field\"\n          - min_iterations_missing_warning: \"Boolean true when minIterations is missing; use no floor and log a warning so older configs keep prior stop behavior\"\n          - min_iterations_raw: \"Extract numeric minIterations from deep-research-config.json when present, default 0\"\n          - effective_min_iterations: \"Clamp min_iterations_raw to the inclusive range 0..max_iterations; if min_iterations_raw exceeds max_iterations, use max_iterations\"\n          - min_iterations_clamped: \"Boolean true when min_iterations_raw > max_iterations\"\n          - min_iterations_guard_already_passed: \"Boolean true when state_log already contains event == 'min_iterations_guard_pass'\"\n          - convergence_mode: \"Extract convergenceMode when it is 'default' or 'off'; default to 'default'\"\n          - convergence_mode_warning: \"Boolean true when convergenceMode is present with an unsupported value; use 'default'\"\n          - rejected_patterns_count: \"Read registry.rejectedPatterns length when registry exists, else 0\"\n          - rejected_candidate_matches: \"Read registry.suppressedCandidates when registry exists, else []\"\n          - rejected_pattern_fuzzy_threshold: \"Read config.rejectedPatternFuzzyThreshold when present, else 0.85\"\n          - min_idea_observations: \"Read config.minIdeaObservations when present, default 2; clamp to 1..10\"\n          - observed_ideas_count: \"Read registry.observedIdeas length when registry exists, else 0\"\n          - promoted_ideas_count: \"Read registry.promotedIdeas length when registry exists, else 0\"\n          - promoted_ideas_list: \"Read registry.promotedIdeas idea text in rank order when registry exists, else []\"\n          - suppressed_ideas_count: \"Read registry.suppressedIdeas length when registry exists, else 0\"\n\n      step_run_now_check:\n        action: \"Detect and consume a one-shot run-now sentinel before pause/convergence/dispatch\"\n        command: |\n          node <<'EOF'\n          const { appendFileSync, existsSync, renameSync, unlinkSync } = require('node:fs');\n\n          const stateLogPath = \"{state_paths.state_log}\";\n          const sentinelPath = \"{state_paths.run_now_sentinel}\";\n          const pausePath = \"{state_paths.pause_sentinel}\";\n          const timestamp = \"{ISO_8601_NOW}\";\n          const sessionId = \"{config.lineage.sessionId}\";\n          const generation = Number(\"{config.lineage.generation}\");\n          const run = Number(\"{current_iteration}\");\n\n          function append(event) {\n            appendFileSync(\n              stateLogPath,\n              `${JSON.stringify({\n                type: \"event\",\n                mode: \"research\",\n                run,\n                timestamp,\n                sessionId,\n                generation,\n                ...event,\n              })}\\n`,\n              \"utf8\",\n            );\n          }\n\n          if (existsSync(sentinelPath)) {\n            append({ event: \"run_now_requested\", sentinelPath });\n            if (existsSync(pausePath)) {\n              append({\n                event: \"run_now_rejected\",\n                reason: \"loop_paused\",\n                sentinelPath,\n                pauseSentinelPath: pausePath,\n              });\n            } else {\n              const claimPath = `${sentinelPath}.consuming.${process.pid}.${Date.now()}`;\n              try {\n                renameSync(sentinelPath, claimPath);\n                unlinkSync(claimPath);\n                append({\n                  event: \"run_now_accepted\",\n                  sentinelPath,\n                  dispatchEvent: \"iteration_start\",\n                });\n              } catch (error) {\n                if (!error || error.code !== \"ENOENT\") {\n                  throw error;\n                }\n              }\n            }\n          }\n          EOF\n        outputs:\n          - run_now_requested: \"Emitted when {state_paths.run_now_sentinel} exists at the loop boundary\"\n          - run_now_accepted: \"Emitted after the sentinel is atomically renamed and deleted before dispatch\"\n          - run_now_rejected: \"Emitted with reason loop_paused when pause takes precedence; sentinel remains present\"\n\n      step_check_pause_sentinel:\n        action: \"Check for pause sentinel file\"\n        check: \"Does {state_paths.pause_sentinel} exist?\"\n        if_exists:\n          log_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          message: \"Research paused. Delete research/.deep-research-pause to resume.\"\n          halt: true\n        if_not_exists:\n          proceed: true\n\n      step_validate_convergence_config:\n        action: \"Validate convergence floor settings when loading config\"\n        if_min_iterations_missing:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"fallback\":0,\"message\":\"minIterations missing; using no convergence floor for backward compatibility.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"minIterations missing; using no convergence floor for backward compatibility.\"\n        if_min_iterations_clamped:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"minIterations\",\"configured\":{min_iterations_raw},\"effective\":{effective_min_iterations},\"maxIterations\":{max_iterations},\"message\":\"minIterations exceeds maxIterations; clamping to the hard cap.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"minIterations exceeds maxIterations; clamping to the hard cap.\"\n        if_convergence_mode_invalid:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"research\",\"field\":\"convergenceMode\",\"fallback\":\"default\",\"message\":\"Unsupported convergenceMode; using default convergence behavior.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Unsupported convergenceMode; using default convergence behavior.\"\n\n      step_graph_convergence:\n        action: \"Evaluate coverage-graph convergence before the inline 3-signal vote and persist the graph decision snapshot\"\n        bash: 'node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"research\" --session-id \"{config.lineage.sessionId}\"'\n        note: \"Run before the inline vote. STOP from the inline 3-signal vote is allowed only when the graph decision is STOP_ALLOWED or absent.\"\n        outputs:\n          - graph_decision: \"Tool decision value (CONTINUE | STOP_ALLOWED | STOP_BLOCKED), else null when unavailable\"\n          - graph_decision_json: \"JSON-encoded graph decision string, else null\"\n          - graph_signals_json: \"Tool signals object, else {}\"\n          - graph_blockers_json: \"Tool blockers array, else []\"\n          - graph_trace_json: \"Tool trace payload, else []\"\n          - graph_convergence_score: \"signals.blendedScore when present, else the best available graph score, else 0\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"research\",\"run\":{current_iteration},\"decision\":{graph_decision_json},\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_check_convergence:\n        action: \"Evaluate stop conditions and combine the inline 3-signal vote with graph convergence\"\n        algorithm: |\n          1. if iteration_count >= max_iterations: STOP (maxIterationsReached). This terminal cap bypasses quality-guard overrides; record failed guards/blockers as synthesis evidence instead of continuing.\n          2. if stuck_count >= config.stuckThreshold: STUCK_RECOVERY\n          3. if convergence_mode == \"off\": skip convergence stop candidates and continue unless a terminal cap, pause sentinel, or recovery halt has already fired.\n          4. if remaining_questions == 0: STOP (all_questions_answered)\n          5. GRAPH-ASSISTED COMPOSITE CONVERGENCE:\n               step_graph_convergence already recorded graph_decision, graph_signals_json, graph_blockers_json, and graph_convergence_score for this run.\n               The existing inline 3-signal vote still computes the inline STOP candidate and is not replaced.\n               signals = []\n               Filter: exclude iterations where status == thought from signal inputs (use only evidence iterations)\n               a) Rolling average (w=0.30, needs 3+ iterations):\n                  avg = mean(last 3 newInfoRatios)\n                  stop if avg < convergence_threshold\n               b) MAD noise floor (w=0.35, needs 4+ iterations):\n                  noiseFloor = MAD(all ratios) * 1.4826\n                  stop if latest ratio <= noiseFloor\n               c) Question entropy (w=0.35):\n                  coverage = answered / total questions\n                  stop if coverage >= 0.85\n               Redistribute weights for unavailable signals.\n               if weighted_stop_score > 0.60: inline_stop_candidate = true\n               Combined stop rule: STOP only if the inline 3-signal vote says STOP AND graph_decision is STOP_ALLOWED or absent.\n               if inline_stop_candidate and graph_decision == \"STOP_BLOCKED\":\n                 decision = \"BLOCKED\"\n                 reason = \"blockedStop\"\n                 stop_blocked = true\n                 blocked_by_json = JSON array derived from graph_blockers_json\n                 blocked_by_csv = comma-separated blocker names derived from graph_blockers_json\n                 gate_convergence_pass = false\n                 gate_convergence_score = graph_convergence_score\n                 gate_key_question_coverage_pass = no blocker named questionCoverage\n                 gate_evidence_density_pass = no blocker named sourceDiversity or evidenceDepth\n                 gate_evidence_density_sources = graph_signals_json.sourceDiversity or 0\n                 gate_hotspot_saturation_pass = true\n                 recovery_strategy = first blocker reason/message, else \"Collect deeper graph evidence before stopping.\"\n               else if inline_stop_candidate and (graph_decision == \"STOP_ALLOWED\" or graph_decision is absent):\n                 decision = \"STOP\"\n                 reason = \"composite_converged\"\n                 stop_blocked = false\n          6. else: CONTINUE\n          7. if decision == \"STOP\" and reason != \"maxIterationsReached\" and effective_min_iterations > 1 and iteration_count < effective_min_iterations:\n               decision = \"CONTINUE\"\n               reason = \"minIterationsNotReached\"\n               min_iterations_guard_blocked = true\n               min_iterations_guard_pass = false\n          8. if effective_min_iterations > 1 and iteration_count >= effective_min_iterations and min_iterations_guard_already_passed == false:\n               min_iterations_guard_pass = true\n          9. if decision == \"STOP\" and reason != \"maxIterationsReached\":\n               guardResult = checkQualityGuards(state, strategy)\n               if not guardResult.passed:\n                 log: \"Quality guard failed: {guardResult.violations}. Overriding STOP to CONTINUE.\"\n                 decision = \"CONTINUE\"\n          See convergence.md for full pseudocode and signal definitions.\n          Segment-aware convergence is experimental/reference-only; live workflow uses the current session as a single segment.\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean marker set when graph convergence vetoes an inline STOP candidate\"\n          - blocked_by_json: \"JSON array of graph blocker names when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated graph blocker names when decision == BLOCKED\"\n          - gate_convergence_pass: \"Boolean pass/fail for the graph-assisted convergence gate\"\n          - gate_convergence_score: \"Numeric score recorded from graph convergence\"\n          - gate_key_question_coverage_pass: \"Boolean pass/fail derived from graph blocker coverage signals\"\n          - gate_evidence_density_pass: \"Boolean pass/fail derived from graph blocker evidence-depth signals\"\n          - gate_evidence_density_sources: \"Source-diversity count or equivalent evidence-depth proxy\"\n          - gate_hotspot_saturation_pass: \"Research placeholder gate; true unless an explicit blocker sets otherwise\"\n          - recovery_strategy: \"One-line hint describing the next research action when decision == BLOCKED or STUCK_RECOVERY\"\n          - min_iterations_guard_pass: \"Boolean true when the configured convergence floor has cleared for the first time\"\n          - min_iterations_guard_blocked: \"Boolean true when the configured convergence floor overrides a STOP candidate to CONTINUE\"\n\n      step_emit_min_iterations_guard_pass:\n        action: \"Persist a first-class event when the convergence floor clears\"\n        if_pass:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"min_iterations_guard_pass\",\"mode\":\"research\",\"run\":{current_iteration},\"iterationCount\":{iteration_count},\"minIterations\":{effective_min_iterations},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Minimum iteration floor cleared for convergence stopping.\"\n\n      step_emit_blocked_stop:\n        action: \"Persist a first-class blocked_stop event when the legal-stop decision tree returns blocked\"\n        if_blocked:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"research\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergence\":{\"pass\":{gate_convergence_pass},\"score\":{gate_convergence_score}},\"keyQuestionCoverage\":{\"pass\":{gate_key_question_coverage_pass},\"answered\":{answered_count},\"total\":{total_questions}},\"evidenceDensity\":{\"pass\":{gate_evidence_density_pass},\"sources\":{gate_evidence_density_sources}},\"hotspotSaturation\":{\"pass\":{gate_hotspot_saturation_pass}}},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Graph convergence blocked STOP. Failed blockers: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n          set:\n            decision: \"CONTINUE\"\n            reason: \"blockedStop\"\n            stop_blocked: false\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          log: \"Loop stopping. Reason: {reason}\"\n          skip_to: phase_synthesis\n        if_stuck_recovery:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          set: { next_focus: \"RECOVERY: Widen scope. Try fundamentally different approach. Least-explored question: {least_explored}\" }\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Focus: {next_focus}\"\n\n      step_rejected_pattern_cache:\n        action: \"Apply reducer-derived rejected-pattern suppression before dispatch candidate selection\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        candidate_sources:\n          next_focus:\n            category: \"next-focus\"","lineStart":1,"lineEnd":736,"totalLines":737,"truncated":true}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1783486572758,"end":1783486572765}},"metadata":{"openai":{"itemId":"fc_004a99ebed27f485016a4dd86cb6f88191aed11d4fc02acc68"}},"id":"prt_f401568d3001S9Uw7BHXFOrRPI","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40153b91001UQnxJNHI78P6Ce"}}
{"type":"tool_use","timestamp":1783486572811,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_XVNqxMFmTB9szdiQjqzfuqnq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Research Quick Reference\n3: description: One-page cheat sheet for the autonomous deep research loop.\n4: trigger_phrases:\n5:   - \"deep research quick reference\"\n6:   - \"research loop cheat sheet\"\n7:   - \"research iteration checklist\"\n8:   - \"research loop troubleshooting\"\n9:   - \"research tuning guide\"\n10:   - \"research progress visualization\"\n11: importance_tier: normal\n12: contextType: general\n13: version: 1.14.0.26\n14: ---\n15: \n16: # Deep Research Quick Reference\n17: \n18: One-page operator cheat sheet for the autonomous deep research loop.\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: Lookup surface during runs covering when to invoke the loop, what each phase produces, how convergence is computed, and where live state lives on disk. Defer to the full protocol and convergence references for deep reasoning.\n25: \n26: Operator contract source of truth for this page:\n27: - command syntax: `.opencode/commands/deep/research.md`\n28: - convergence stop contract: `references/convergence/convergence.md`, `references/convergence/convergence_signals.md`, and the deep-research YAML workflow\n29: - state packet contract: `references/state/state_format.md`, `references/state/state_jsonl.md`, `references/state/state_outputs.md`, and `references/state/state_reducer_registry.md`\n30: \n31: ---\n32: \n33: ## 2. COMMANDS\n34: \n35: | Command | Description |\n36: |---------|-------------|\n37: | `/deep:research:auto \"topic\"` | Run autonomous deep research (no approval gates) |\n38: | `/deep:research:confirm \"topic\"` | Run with approval gates at each iteration |\n39: | `/deep:research \"topic\"` | Ask which mode to use |\n40: \n41: ### Parameters\n42: \n43: | Parameter | Default | Description |\n44: |-----------|---------|-------------|\n45: | `--max-iterations` | 10 | Maximum loop iterations |\n46: | `--convergence` | 0.05 | Stop when avg newInfoRatio below this |\n47: | `--spec-folder` | auto | Target spec folder path |\n48: | `progressiveSynthesis` | true | Allow incremental `research/research.md` updates before final synthesis |\n49: \n50: ---\n51: \n52: ## 3. WHEN TO USE\n53: \n54: | Scenario | Use |\n55: |----------|-----|\n56: | Deep unknown topic, multi-round needed | `/deep:research` |\n57: | Simple question, 1-2 sources | Direct search with `@context` |\n58: | Check prior work only | `memory_context()` |\n59: | Exhaustive critical research | `/deep:research --max-iterations 15 --convergence 0.02` |\n60: \n61: ---\n62: \n63: ## 4. ARCHITECTURE\n64: \n65: ```text\n66: /deep:research  -->  YAML workflow  -->  @deep-research agent (LEAF)\n67:     |                    |                      |\n68:     |                    |                      +-- Read state\n69:     |                    |                      +-- Research (3-5 actions)\n70:     |                    |                      +-- Write findings\n71:     |                    |                      +-- Update state\n72:     |                    |\n73:     |                    +-- Init (config, strategy, state)\n74:     |                    +-- Loop (dispatch, evaluate, decide)\n75:     |                    +-- Synthesize (final research/research.md)\n76:     |                    +-- Save (memory context)\n77: ```\n78: \n79: ---\n80: \n81: ## 5. STATE FILES\n82: \n83: | File | Location | Format | Purpose |\n84: |------|----------|--------|---------|\n85: | Config | `research/deep-research-config.json` | JSON | Loop parameters |\n86: | State | `research/deep-research-state.jsonl` | JSONL | Iteration log (append-only) |\n87: | Strategy | `research/deep-research-strategy.md` | Markdown | What worked/failed, next focus |\n88: | Registry | `research/findings-registry.json` | JSON | Reducer-owned open/resolved questions and key findings |\n89: | Dashboard | `research/deep-research-dashboard.md` | Markdown | Reducer-owned lifecycle and convergence summary |\n90: | Iterations | `research/iterations/iteration-NNN.md` | Markdown | Per-iteration findings |\n91: | Output | `research/research.md` | Markdown | Workflow-owned progressive synthesis output |\n92: \n93: > **Live lifecycle branches:** `resume`, `restart`. (`fork` and `completed-continue` are deferred and not runtime-wired.) `progressiveSynthesis` defaults to `true`, so `research/research.md` is updated during the loop and finalized at synthesis.\n94: \n95: > **Path contract:** root-spec runs write directly to `{spec_folder}/research/`; child-phase and sub-phase first runs use the local `{spec_folder}/research/` directory directly, with `{ownerSlug}-pt-NN` allocated only when prior non-matching content already exists.\n96: \n97: > **Canonical pause sentinel:** `research/.deep-research-pause`\n98: \n99: > **Runtime capability matrix:** `.opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md` and `.opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json`\n100: \n101: ---\n102: \n103: ## 6. ITERATION STATUS LEGEND\n104: \n105: | Status | Meaning |\n106: |--------|---------|\n107: | `complete` | Normal iteration with findings |\n108: | `timeout` | Exceeded time/tool budget |\n109: | `error` | Failed to produce outputs |\n110: | `stuck` | No new information found |\n111: | `insight` | Low ratio but conceptual breakthrough |\n112: | `thought` | Analytical-only, no evidence |\n113: \n114: ---\n115: \n116: ## 7. CONVERGENCE DECISION TREE\n117: \n118: ```text\n119: Max iterations reached?\n120:   Yes --> STOP\n121: \n122: All questions answered?\n123:   Yes --> STOP\n124: \n125: stuckThreshold consecutive no-progress?\n126:   Yes --> STUCK_RECOVERY\n127:     Recovery works? --> CONTINUE\n128:     Recovery fails? --> STOP (with gaps)\n129: \n130: Composite convergence (3-signal weighted > 0.60)?\n131:   Yes --> STOP (converged)\n132: \n133: Otherwise --> CONTINUE\n134: ```\n135: \n136: ### 3-Signal Convergence Model\n137: \n138: | Signal | Weight | Min Iterations | Votes STOP When |\n139: |--------|--------|---------------|-----------------|\n140: | Rolling Average | 0.30 | 3 | avg(last 3 newInfoRatios) < convergenceThreshold |\n141: | MAD Noise Floor | 0.35 | 4 | latest ratio <= MAD * 1.4826 |\n142: | Question Entropy | 0.35 | 1 | answered / total questions >= 0.85 |\n143: \n144: **Composite stop threshold:** 0.60 -- weighted stop score must exceed this before quality guards are evaluated.\n145: \n146: Quality guards (source diversity, focus alignment, no single-weak-source) must pass before STOP.\n147: \n148: ---\n149: \n150: ## 8. AGENT ITERATION CHECKLIST\n151: \n152: Each @deep-research iteration:\n153: 1. Read `deep-research-state.jsonl` and `deep-research-strategy.md`\n154: 2. Determine focus from reducer-owned strategy \"Next Focus\"\n155: 3. Execute 3-5 research actions (WebFetch, Grep, Read, memory_search)\n156: 4. Write `research/iterations/iteration-NNN.md` with findings\n157: 5. Append iteration record to `deep-research-state.jsonl`\n158: 6. Let the workflow reducer update `deep-research-strategy.md`, `findings-registry.json`, and `deep-research-dashboard.md`\n159: 7. Optionally update machine-owned sections in `research/research.md` when progressive synthesis is enabled\n160: \n161: ---\n162: \n163: ## 9. TUNING GUIDE\n164: \n165: | Goal | Adjustment |\n166: |------|------------|\n167: | Deeper research | Lower convergence (0.02), raise max iterations (15) |\n168: | Faster completion | Raise convergence (0.10), lower max iterations (5) |\n169: | Broader coverage | Start with broad topic, let iterations narrow |\n170: | Specific answer | Start with specific question, lower max iterations (5) |\n171: \n172: ---\n173: \n174: ## 10. TROUBLESHOOTING\n175: \n176: | Problem | Fix |\n177: |---------|-----|\n178: | Stops too early | Lower `--convergence` from 0.05 to 0.02 |\n179: | Repeats same research | Check strategy.md \"Exhausted Approaches\" is being read |\n180: | Agent ignores state | Verify file paths in dispatch prompt |\n181: | State file corrupt | Validate JSONL: `cat research/deep-research-state.jsonl \\| jq .` |\n182: | Loop runs too long | Set lower `--max-iterations` or higher `--convergence` |\n183: \n184: ---\n185: \n186: ## 11. PROGRESS VISUALIZATION\n187: \n188: After each iteration, the orchestrator can display a text-based convergence summary:\n189: \n190: ### Format\n191: \n192: | Element | Format | Example |\n193: |---------|--------|---------|\n194: | newInfoRatio trend | ASCII sparkline | `[0.9 0.7 0.5 0.3 0.1]` |\n195: | Question coverage | Progress bar | `[=======>...] 7/10 (70%)` |\n196: | Composite score | Threshold bar | `[####----] 0.42 / 0.60` |\n197: | Noise floor | Comparison | `ratio: 0.12 > floor: 0.08` |\n198: \n199: ### Example Output\n200: \n201: ```text\n202: ITERATION 5 PROGRESS\n203: ─────────────────────\n204: newInfoRatio: 0.9 -> 0.7 -> 0.5 -> 0.3 -> 0.1  trending down\n205: Questions:   [========>..] 8/10 answered (80%)\n206: Composite:   [######--] 0.48 / 0.60 threshold\n207: Noise floor: 0.08 (ratio 0.10 ABOVE floor)\n208: Stuck count: 0 | Segment: 1 | Recovery: none\n209: Signals: RollingAvg=STOP MAD=CONTINUE Entropy=CONTINUE\n210: ```\n211: \n212: ### When to Display\n213: \n214: - After each iteration evaluation (Step 4)\n215: - In the convergence report (synthesis phase)\n216: - In confirm mode approval gates\n217: \n218: ---\n219: \n220: ## 12. RELATED\n221: \n222: | Resource | Purpose |\n223: |----------|---------|\n224: | `@context` | Single-pass codebase search (not iterative) |\n225: | `@orchestrate` | Multi-agent coordination |\n226: | `memory_context()` | Prior work retrieval |\n227: | `generate-context.js` | Supported memory save script |\n228: | `references/convergence/convergence_signals.md` | Convergence signal details |\n229: | `references/state/state_jsonl.md` | JSONL state record details |\n230: \n231: ---\n232: \n233: ## 13. REVIEW MODE\n234: \n235: Review mode has been split into a separate skill. See `deep-review/references/protocol/quick_reference.md`.\n\n(End of file - total 235 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Research Quick Reference\ndescription: One-page cheat sheet for the autonomous deep research loop.\ntrigger_phrases:\n  - \"deep research quick reference\"\n  - \"research loop cheat sheet\"\n  - \"research iteration checklist\"\n  - \"research loop troubleshooting\"\n  - \"research tuning guide\"\n  - \"research progress visualization\"\nimportance_tier: normal\ncontextType: general\nversion: 1.14.0.26\n---\n\n# Deep Research Quick Reference\n\nOne-page operator cheat sheet for the autonomous deep research loop.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md","text":"---\ntitle: Deep Research Quick Reference\ndescription: One-page cheat sheet for the autonomous deep research loop.\ntrigger_phrases:\n  - \"deep research quick reference\"\n  - \"research loop cheat sheet\"\n  - \"research iteration checklist\"\n  - \"research loop troubleshooting\"\n  - \"research tuning guide\"\n  - \"research progress visualization\"\nimportance_tier: normal\ncontextType: general\nversion: 1.14.0.26\n---\n\n# Deep Research Quick Reference\n\nOne-page operator cheat sheet for the autonomous deep research loop.\n\n---\n\n## 1. OVERVIEW\n\nLookup surface during runs covering when to invoke the loop, what each phase produces, how convergence is computed, and where live state lives on disk. Defer to the full protocol and convergence references for deep reasoning.\n\nOperator contract source of truth for this page:\n- command syntax: `.opencode/commands/deep/research.md`\n- convergence stop contract: `references/convergence/convergence.md`, `references/convergence/convergence_signals.md`, and the deep-research YAML workflow\n- state packet contract: `references/state/state_format.md`, `references/state/state_jsonl.md`, `references/state/state_outputs.md`, and `references/state/state_reducer_registry.md`\n\n---\n\n## 2. COMMANDS\n\n| Command | Description |\n|---------|-------------|\n| `/deep:research:auto \"topic\"` | Run autonomous deep research (no approval gates) |\n| `/deep:research:confirm \"topic\"` | Run with approval gates at each iteration |\n| `/deep:research \"topic\"` | Ask which mode to use |\n\n### Parameters\n\n| Parameter | Default | Description |\n|-----------|---------|-------------|\n| `--max-iterations` | 10 | Maximum loop iterations |\n| `--convergence` | 0.05 | Stop when avg newInfoRatio below this |\n| `--spec-folder` | auto | Target spec folder path |\n| `progressiveSynthesis` | true | Allow incremental `research/research.md` updates before final synthesis |\n\n---\n\n## 3. WHEN TO USE\n\n| Scenario | Use |\n|----------|-----|\n| Deep unknown topic, multi-round needed | `/deep:research` |\n| Simple question, 1-2 sources | Direct search with `@context` |\n| Check prior work only | `memory_context()` |\n| Exhaustive critical research | `/deep:research --max-iterations 15 --convergence 0.02` |\n\n---\n\n## 4. ARCHITECTURE\n\n```text\n/deep:research  -->  YAML workflow  -->  @deep-research agent (LEAF)\n    |                    |                      |\n    |                    |                      +-- Read state\n    |                    |                      +-- Research (3-5 actions)\n    |                    |                      +-- Write findings\n    |                    |                      +-- Update state\n    |                    |\n    |                    +-- Init (config, strategy, state)\n    |                    +-- Loop (dispatch, evaluate, decide)\n    |                    +-- Synthesize (final research/research.md)\n    |                    +-- Save (memory context)\n```\n\n---\n\n## 5. STATE FILES\n\n| File | Location | Format | Purpose |\n|------|----------|--------|---------|\n| Config | `research/deep-research-config.json` | JSON | Loop parameters |\n| State | `research/deep-research-state.jsonl` | JSONL | Iteration log (append-only) |\n| Strategy | `research/deep-research-strategy.md` | Markdown | What worked/failed, next focus |\n| Registry | `research/findings-registry.json` | JSON | Reducer-owned open/resolved questions and key findings |\n| Dashboard | `research/deep-research-dashboard.md` | Markdown | Reducer-owned lifecycle and convergence summary |\n| Iterations | `research/iterations/iteration-NNN.md` | Markdown | Per-iteration findings |\n| Output | `research/research.md` | Markdown | Workflow-owned progressive synthesis output |\n\n> **Live lifecycle branches:** `resume`, `restart`. (`fork` and `completed-continue` are deferred and not runtime-wired.) `progressiveSynthesis` defaults to `true`, so `research/research.md` is updated during the loop and finalized at synthesis.\n\n> **Path contract:** root-spec runs write directly to `{spec_folder}/research/`; child-phase and sub-phase first runs use the local `{spec_folder}/research/` directory directly, with `{ownerSlug}-pt-NN` allocated only when prior non-matching content already exists.\n\n> **Canonical pause sentinel:** `research/.deep-research-pause`\n\n> **Runtime capability matrix:** `.opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md` and `.opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json`\n\n---\n\n## 6. ITERATION STATUS LEGEND\n\n| Status | Meaning |\n|--------|---------|\n| `complete` | Normal iteration with findings |\n| `timeout` | Exceeded time/tool budget |\n| `error` | Failed to produce outputs |\n| `stuck` | No new information found |\n| `insight` | Low ratio but conceptual breakthrough |\n| `thought` | Analytical-only, no evidence |\n\n---\n\n## 7. CONVERGENCE DECISION TREE\n\n```text\nMax iterations reached?\n  Yes --> STOP\n\nAll questions answered?\n  Yes --> STOP\n\nstuckThreshold consecutive no-progress?\n  Yes --> STUCK_RECOVERY\n    Recovery works? --> CONTINUE\n    Recovery fails? --> STOP (with gaps)\n\nComposite convergence (3-signal weighted > 0.60)?\n  Yes --> STOP (converged)\n\nOtherwise --> CONTINUE\n```\n\n### 3-Signal Convergence Model\n\n| Signal | Weight | Min Iterations | Votes STOP When |\n|--------|--------|---------------|-----------------|\n| Rolling Average | 0.30 | 3 | avg(last 3 newInfoRatios) < convergenceThreshold |\n| MAD Noise Floor | 0.35 | 4 | latest ratio <= MAD * 1.4826 |\n| Question Entropy | 0.35 | 1 | answered / total questions >= 0.85 |\n\n**Composite stop threshold:** 0.60 -- weighted stop score must exceed this before quality guards are evaluated.\n\nQuality guards (source diversity, focus alignment, no single-weak-source) must pass before STOP.\n\n---\n\n## 8. AGENT ITERATION CHECKLIST\n\nEach @deep-research iteration:\n1. Read `deep-research-state.jsonl` and `deep-research-strategy.md`\n2. Determine focus from reducer-owned strategy \"Next Focus\"\n3. Execute 3-5 research actions (WebFetch, Grep, Read, memory_search)\n4. Write `research/iterations/iteration-NNN.md` with findings\n5. Append iteration record to `deep-research-state.jsonl`\n6. Let the workflow reducer update `deep-research-strategy.md`, `findings-registry.json`, and `deep-research-dashboard.md`\n7. Optionally update machine-owned sections in `research/research.md` when progressive synthesis is enabled\n\n---\n\n## 9. TUNING GUIDE\n\n| Goal | Adjustment |\n|------|------------|\n| Deeper research | Lower convergence (0.02), raise max iterations (15) |\n| Faster completion | Raise convergence (0.10), lower max iterations (5) |\n| Broader coverage | Start with broad topic, let iterations narrow |\n| Specific answer | Start with specific question, lower max iterations (5) |\n\n---\n\n## 10. TROUBLESHOOTING\n\n| Problem | Fix |\n|---------|-----|\n| Stops too early | Lower `--convergence` from 0.05 to 0.02 |\n| Repeats same research | Check strategy.md \"Exhausted Approaches\" is being read |\n| Agent ignores state | Verify file paths in dispatch prompt |\n| State file corrupt | Validate JSONL: `cat research/deep-research-state.jsonl \\| jq .` |\n| Loop runs too long | Set lower `--max-iterations` or higher `--convergence` |\n\n---\n\n## 11. PROGRESS VISUALIZATION\n\nAfter each iteration, the orchestrator can display a text-based convergence summary:\n\n### Format\n\n| Element | Format | Example |\n|---------|--------|---------|\n| newInfoRatio trend | ASCII sparkline | `[0.9 0.7 0.5 0.3 0.1]` |\n| Question coverage | Progress bar | `[=======>...] 7/10 (70%)` |\n| Composite score | Threshold bar | `[####----] 0.42 / 0.60` |\n| Noise floor | Comparison | `ratio: 0.12 > floor: 0.08` |\n\n### Example Output\n\n```text\nITERATION 5 PROGRESS\n─────────────────────\nnewInfoRatio: 0.9 -> 0.7 -> 0.5 -> 0.3 -> 0.1  trending down\nQuestions:   [========>..] 8/10 answered (80%)\nComposite:   [######--] 0.48 / 0.60 threshold\nNoise floor: 0.08 (ratio 0.10 ABOVE floor)\nStuck count: 0 | Segment: 1 | Recovery: none\nSignals: RollingAvg=STOP MAD=CONTINUE Entropy=CONTINUE\n```\n\n### When to Display\n\n- After each iteration evaluation (Step 4)\n- In the convergence report (synthesis phase)\n- In confirm mode approval gates\n\n---\n\n## 12. RELATED\n\n| Resource | Purpose |\n|----------|---------|\n| `@context` | Single-pass codebase search (not iterative) |\n| `@orchestrate` | Multi-agent coordination |\n| `memory_context()` | Prior work retrieval |\n| `generate-context.js` | Supported memory save script |\n| `references/convergence/convergence_signals.md` | Convergence signal details |\n| `references/state/state_jsonl.md` | JSONL state record details |\n\n---\n\n## 13. REVIEW MODE\n\nReview mode has been split into a separate skill. See `deep-review/references/protocol/quick_reference.md`.","lineStart":1,"lineEnd":235,"totalLines":235,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/references/guides/quick_reference.md","time":{"start":1783486572787,"end":1783486572806}},"metadata":{"openai":{"itemId":"fc_004a99ebed27f485016a4dd86cb7088191a938869516aac68d"}},"id":"prt_f401568d8001DYVk6Fx2dUL1cb","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40153b91001UQnxJNHI78P6Ce"}}
{"type":"tool_use","timestamp":1783486572811,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_xM4trcx3tU0K4ATDrUASyz64","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Loop Protocol Reference\n3: description: Canonical specification for the deep research loop lifecycle with 4 phases, reference-only wave orchestration, and error handling.\n4: trigger_phrases:\n5:   - \"research loop protocol\"\n6:   - \"research loop lifecycle\"\n7:   - \"research loop initialization\"\n8:   - \"research auto resume protocol\"\n9:   - \"research pause sentinel\"\n10:   - \"research synthesis phase\"\n11: importance_tier: important\n12: contextType: implementation\n13: version: 1.14.0.29\n14: ---\n15: \n16: # Loop Protocol Reference\n17: \n18: Canonical specification for the deep research loop lifecycle. Use it as the lifecycle map for initialization, iteration, synthesis, save, and recovery.\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: ### Purpose\n25: \n26: Define the lifecycle contract for deep-research initialization, iteration, synthesis, save, reference-only dispatch concepts, and error handling.\n27: \n28: ### When to Use\n29: \n30: Load this reference when running or validating the research loop lifecycle. Use `../convergence/convergence.md` for STOP decisions and `../state/state_format.md` for packet file schemas.\n31: \n32: ### Core Principle\n33: \n34: The YAML workflow owns lifecycle orchestration, `@deep-research` executes LEAF iterations, and the reducer synchronizes packet state after each iteration and lifecycle transition.\n35: \n36: ### Phase Model\n37: \n38: The deep research loop has 4 phases: initialization, iteration (repeated), synthesis, and save.\n39: \n40: Runtime capability matrix references for parity-sensitive loop behavior:\n41: - Human-readable matrix: `.opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md`\n42: - Machine-readable matrix: `.opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json`\n43: \n44: ```text\n45: ┌──────────┐     ┌──────────────────────────┐     ┌───────────────────────┐     ┌──────────┐\n46: │  INIT    │────>│  LOOP                    │────>│  SYNTHESIS            │────>│  SAVE    │\n47: │          │     │  ┌────────────────────┐  │     │                       │     │          │\n48: │ Config    │     │  │ Read State         │  │     │ Final                 │     │ Memory   │\n49: │ Strategy │     │  │ Check Convergence  │  │     │ research/research.md  │     │ Context  │\n50: │ State    │     │  │ Dispatch Agent     │  │     │ compilation           │     │ Save     │\n51: │          │     │  │ Evaluate Results   │  │     │                       │     │          │\n52: │          │     │  │ Loop Decision      │  │     │                       │     │          │\n53: │          │     │  └────────┬───────────┘  │     │                       │     │          │\n54: │          │     │           │ repeat       │     │                       │     │          │\n55: └──────────┘     └──────────────────────────┘     └───────────────────────┘     └──────────┘\n56: ```\n57: \n58: ---\n59: \n60: ## 2. PHASE: INITIALIZATION\n61: \n62: ### Purpose\n63: Set up all state files for a new research session.\n64: \n65: ### Steps\n66: \n67: 1. **Classify session state before writing**:\n68:    - `fresh`: no config/state/strategy files exist\n69:    - `resume`: config + state + strategy all exist and agree\n70:    - `completed-session`: consistent prior state with `config.status == \"complete\"`\n71:    - `invalid-state`: partial or contradictory artifacts\n72: 2. **Resolve canonical artifact names**:\n73:    - Read legacy aliases during the migration window if needed\n74:    - Write only canonical `deep-research-*` names\n75:    - Emit a `migration` event for every legacy alias consumed\n76: 3. **Resolve local artifact owner**: `artifact_dir = resolveArtifactRoot(specFolder, 'research').artifactDir`, then `mkdir -p {artifact_dir}/iterations`\n77: 4. **Write config**: `research/deep-research-config.json` from template + user parameters\n78: 5. **Initialize state log**: First line of `research/deep-research-state.jsonl` with config record\n79: 6. **Initialize strategy**: `research/deep-research-strategy.md` from template with:\n80:    - Topic from user input\n81:    - Initial key questions (3-5, from topic analysis)\n82:    - Known context from `memory_context()` results (if any), injected only after the strategy file exists\n83:    - Research boundaries from config\n84: 6a. **Detect resource-map integration state**:\n85:    - Check `{spec_folder}/resource-map.md` once during init\n86:    - If present: set `resource_map_present = true` in `deep-research-config.json`\n87:    - Summarize the map into `deep-research-strategy.md` `Known Context`\n88:    - The summary MUST include per-section entry counts for `READMEs`, `Documents`, `Commands`, `Agents`, `Skills`, `Specs`, `Scripts`, `Tests`, `Config`, and `Meta`\n89:    - The summary MUST also include a one-line theme summary for each resource-map section\n90:    - If absent: set `resource_map_present = false` and append `resource-map.md not present; skipping coverage gate` to `Known Context`\n91: 7. **Initialize findings registry**: `research/findings-registry.json` with empty `openQuestions`, `resolvedQuestions`, `keyFindings`, and `ruledOutDirections`\n92: 7a. **Validate Research Charter**:\n93:    - Verify strategy.md contains a \"Non-Goals\" section (may be empty but must exist)\n94:    - Verify strategy.md contains a \"Stop Conditions\" section (may be empty but must exist)\n95:    - If either section is missing, append it as an empty placeholder before proceeding\n96:    - In **confirm mode**: present the charter (topic, key questions, non-goals, stop conditions) for user review before proceeding\n97:    - In **auto mode**: accept the charter automatically and continue\n98: 8. **Resume only if config, JSONL, and strategy agree**; otherwise halt for repair instead of guessing\n99: \n100: ### Outputs\n101: - `research/deep-research-config.json`\n102: - `research/deep-research-state.jsonl` (1 line)\n103: - `research/deep-research-strategy.md`\n104: \n105: ### Auto-Resume Protocol\n106: If state files already exist from a prior session:\n107: 1. Verify config, JSONL, and strategy all exist and agree on topic/spec folder\n108: 2. Read JSONL, count iteration records\n109: 3. Read strategy.md for current state\n110: 4. Set iteration counter to last completed + 1\n111: 5. Append the canonical resume event to `deep-research-state.jsonl` (all fields below are required by the reducer):\n112: \n113: ```json\n114: {\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"research\",\"sessionId\":\"rsr-2026-03-18T10-00-00Z\",\"parentSessionId\":\"rsr-2026-03-18T10-00-00Z\",\"lineageMode\":\"resume\",\"continuedFromRun\":4,\"generation\":1,\"timestamp\":\"2026-03-18T14:05:00Z\"}\n115: ```\n116: \n117: 6. Continue loop from `step_read_state`.\n118: \n119: ### Lifecycle Branch Contract (current release)\n120: \n121: The runtime supports three lineage modes today. `fork` and `completed-continue` were described in earlier drafts but have no workflow wiring in this release, so they MUST NOT be exposed to operators. If the long-form lineage feature is picked up later it will arrive with first-class event emission, reducer ancestry handling, and replay fixtures; until then treat the contract below as canonical.\n122: \n123: | Mode | Session id | Generation | Archive | JSONL event | When to pick |\n124: |------|-----------|-----------|---------|-------------|--------------|\n125: | `new` | fresh | 1 | n/a | implicit (config record) | no existing state |\n126: | `resume` | same | same | none | `resumed` (see example above) | operator wants to continue the current lineage boundary |\n127: | `restart` | fresh | `prior + 1` | prior `research/` tree moved under `research_archive/{timestamp}/` | `restarted` (same field set plus `archivedPath`) | operator wants to clear the workspace and replay with a new angle |\n128: \n129: **Contract for every persisted lifecycle event**:\n130: \n131: ```json\n132: {\n133:   \"type\": \"event\",\n134:   \"event\": \"resumed | restarted\",\n135:   \"mode\": \"research\",\n136:   \"sessionId\": \"<session id of the new or continuing lineage>\",\n137:   \"parentSessionId\": \"<session id of the prior lineage (equals sessionId on resume)>\",\n138:   \"lineageMode\": \"resume | restart\",\n139:   \"generation\": <number>,\n140:   \"continuedFromRun\": <number or null>,\n141:   \"archivedPath\": \"<path or null>\",\n142:   \"timestamp\": \"<ISO 8601>\"\n143: }\n144: ```\n145: \n146: Every field in the contract MUST be present on every persisted lifecycle event. `archivedPath` is null for `resumed` and set to the archive destination for `restarted`. `continuedFromRun` is the number of completed iteration records before the lifecycle boundary. Reducer parity tests ensure the dashboard `Lifecycle` section reads exactly those fields.\n147: \n148: ---\n149: \n150: ## 3. PHASE: ITERATION LOOP\n151: \n152: ### Loop Steps (repeated until convergence)\n153: \n154: #### Step 1: Read State\n155: - Read `deep-research-state.jsonl` -- count iterations, get last newInfoRatio\n156: - Read `deep-research-strategy.md` -- get next focus, remaining questions\n157: \n158: #### Step 2: Check Convergence\n159: Run the convergence algorithm (see convergence.md):\n160: - Max iterations reached? STOP\n161: - Stuck count >= threshold? STUCK_RECOVERY\n162: - Average newInfoRatio < threshold? STOP\n163: - All questions answered? STOP\n164: - Otherwise: CONTINUE\n165: \n166: #### Step 2c: Quality Guard Check\n167: \n168: When the convergence algorithm returns STOP:\n169: 1. Run quality guard checks (see convergence.md §2.4)\n170: 2. Verify minimum coverage, source diversity, and question resolution thresholds\n171: 3. If **all guards pass**: proceed with STOP, exit to synthesis\n172: 4. If **any guard fails**: override decision to CONTINUE\n173:    - Log each violation: `{\"type\":\"event\",\"event\":\"guard_violation\",\"guard\":\"<name>\",\"iteration\":N,\"detail\":\"<reason>\"}`\n174:    - Persist the blocked legal-stop outcome: `{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"research\",\"run\":N,\"blockedBy\":[\"<gate>\"],\"gateResults\":{\"convergence\":{\"pass\":true,\"score\":0.0},\"keyQuestionCoverage\":{\"pass\":false,\"answered\":X,\"total\":Y},\"evidenceDensity\":{\"pass\":false,\"sources\":N},\"hotspotSaturation\":{\"pass\":true}},\"recoveryStrategy\":\"<one-line hint>\",\"timestamp\":\"<ISO8601>\",\"sessionId\":\"<sid>\",\"generation\":G}`\n175:    - Append failed guard details to strategy.md \"Active Risks\" section\n176: 5. The loop continues until BOTH convergence AND quality guards pass simultaneously\n177: 6. Guard checks apply only to STOP decisions - CONTINUE and STUCK_RECOVERY bypass this step\n178: \n179: If the legal-stop decision tree returns `blocked`, the workflow MUST append the `blocked_stop` JSONL event before continuing. Reducers and dashboards consume the persisted event; they must not infer blocked-stop state solely from prose logs.\n180: \n181: #### Step 2a: Check Pause Sentinel\n182: \n183: Before dispatching, check for a pause sentinel file:\n184: \n185: 1. Check if `research/.deep-research-pause` exists\n186: 2. If present:\n187:    - Log event to JSONL: `{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":N,\"stopReason\":\"userPaused\",\"sentinelPath\":\"{artifact_dir}/.deep-research-pause\",\"timestamp\":\"<ISO8601>\",\"sessionId\":\"<sid>\",\"generation\":G}`\n188:    - Halt the loop with message:\n189:      ```text\n190:      Research paused. Delete research/.deep-research-pause to resume.\n191:      Current state: Iteration {N}, {remaining} questions remaining.\n192:      ```\n193:    - Do NOT exit to synthesis -- the loop is suspended, not stopped\n194: 3. On resume (file deleted and loop restarted):\n195:    - Log event: `{\"type\":\"event\",\"event\":\"resumed\",\"fromIteration\":N}`\n196:    - Continue from step_read_state\n197: \n198: Pause and recovery events use the frozen stop-reason enum on the live path. Raw `paused` and `stuck_recovery` labels are legacy aliases and MUST be normalized to `userPaused` and `stuckRecovery` at emission time.\n199: \n200: **Use case**: In autonomous mode, this provides the only graceful intervention mechanism short of killing the process. Users can create the sentinel file at any time to pause research between iterations.\n201: \n202: #### Step 2b: Generate State Summary\n203: \n204: Generate a compact state summary (~200 tokens) for injection into the dispatch prompt:\n205: \n206: ```text\n207: STATE SUMMARY (auto-generated):\n208: Segment: {current_segment} | Iteration: {N} of {max}\n209: Questions: {answered}/{total} answered | Last focus: {last_focus}\n210: Last 2 ratios: {ratio_N-1} -> {ratio_N} | Stuck count: {stuck_count}\n211: Recovery: {active_recovery_strategy or \"none\"}\n212: Next focus: {strategy.nextFocus}\n213: ```\n214: \n215: This summary is prepended to the dispatch context (Step 3) to ensure the agent has baseline context even if detailed strategy.md reading fails or is incomplete. It serves as a redundant context channel.\n216: \n217: #### Step 2d: Rejected Pattern Cache Check\n218: \n219: Before selecting the next-focus, recovery, or ideas-backed candidate for dispatch, read the reducer-owned rejected-pattern cache and promoted ideas backlog from the findings registry.\n220: \n221: Rejected-cache lifecycle:\n222: \n223: 1. `idea_rejected` appends one rejected pattern to JSONL with `ideaId`, `idea` or `pattern`, optional `category`, optional `reason`, and normal lifecycle fields.\n224: 2. The reducer derives the active cache from JSONL events; generated registry and dashboard files expose `rejectedPatterns`, `rejectedPatternIndex`, and `suppressedCandidates`.\n225: 3. Exact suppression compares normalized candidate text against normalized rejected text.\n226: 4. Fuzzy suppression uses `rejectedPatternFuzzyThreshold` from config when present, otherwise `0.85`, and only applies when the rejected category is compatible with the candidate category.\n227: 5. `ideaRejectedRemoved` removes a single active pattern by id or by pattern/category.\n228: 6. `ideaRejectedReset` clears all active rejected patterns for the current replay.\n229: \n230: The active cache is capped at 100 entries. When the replay would exceed that cap, the oldest active entry is evicted and the reducer emits a warning. Operators can re-add an evicted pattern with another `idea_rejected` event if it remains relevant. Existing `ideaRejected` replay rows are legacy aliases and remain accepted for backward compatibility.\n231: \n232: Ideas lifecycle:\n233: \n234: 1. Leaf agents may append `idea_observed` events only. They must not append `idea_promoted`.\n235: 2. The reducer accumulates observations by `ideaId` or a normalized text-derived id.\n236: 3. `minIdeaObservations` defaults to `2` and is clamped to `1..10`.\n237: 4. When an idea reaches `observationCount >= minIdeaObservations`, the reducer appends one idempotent `idea_promoted` event and ranks promoted ideas by observation count, latest observation, then first observation.\n238: 5. `idea_rejected` removes the matching idea from `promotedIdeas` and from ideas-backed next-focus candidates until a reset/removal event clears the active rejected pattern.\n239: \n240: Candidate categories:\n241: \n242: | Category | Candidate source |\n243: |----------|------------------|\n244: | `next-focus` | Strategy next-focus, carried-forward open questions, open questions, and follow-up findings |\n245: | `recovery` | Stuck and blocked-stop recovery strategies |\n246: | `ideas` | Reducer-promoted ideas backlog entries |\n247: | `general` | Cross-category fallback when a narrower category is not known |\n248: \n249: When all candidates in a category are suppressed, continue with the next eligible category or halt for operator input rather than reusing the rejected idea.\n250: \n251: #### Step 3: Dispatch Agent\n252: Dispatch `@deep-research` with explicit context:\n253: ```text\n254: {state_summary}  // Auto-generated (Step 2b)\n255: \n256: Research Topic: {config.topic}\n257: Iteration: {N} of {maxIterations}\n258: Focus Area: {strategy.nextFocus}\n259: Remaining Questions: {strategy.remainingQuestions}\n260: Last 3 Iterations Summary: {brief summaries}\n261: Resource Map: if `config.resource_map_present == true`, prior-inventoried files are listed in `{spec_folder}/resource-map.md`; treat them as the exclusion set when hunting for net-new files; flag only missed-from-map candidates as gaps.\n262: State Files:\n263:   - Config: {artifact_dir}/deep-research-config.json\n264:   - State: {artifact_dir}/deep-research-state.jsonl\n265:   - Strategy: {artifact_dir}/deep-research-strategy.md\n266: Output: Write findings to {artifact_dir}/iterations/iteration-{NNN}.md\n267: CONSTRAINT: LEAF agent -- do NOT dispatch sub-agents\n268: ```\n269: \n270: #### Executor Resolution (spec 018 + 019)\n271: \n272: Before dispatching, the YAML resolves the executor via `parseExecutorConfig` from `.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts`. The resolved `config.executor.kind` selects the dispatch branch:\n273: \n274: - `native` (spec 018): dispatch `@deep-research` agent with model Opus.\n275: - `cli-opencode` (spec 018): pipe rendered prompt via stdin to `opencode run --model X -c model_reasoning_effort=Y -c service_tier=Z -c approval_policy=never --sandbox workspace-write`.\n276: - `cli-claude-code` (spec 019): `claude -p \"$(cat prompt)\" --model X --permission-mode acceptEdits --output-format text` with optional `--effort Y`. Default permission-mode is `plan` (read-only); we override to `acceptEdits` so iteration writes succeed.\n277: \n278: All branches share:\n279: 1. Pre-dispatch prompt rendering via `renderPromptPack` (writes to `{artifact_dir}/prompts/iteration-{n}.md`).\n280: 2. Post-dispatch validation via `validateIterationOutputs` (asserts iteration file + JSONL delta + required fields).\n281: 3. Executor audit append via `appendExecutorAuditToLastRecord` (skipped when kind=='native').\n282: \n283: Per-kind flag-compatibility is enforced at config parse time by `EXECUTOR_KIND_FLAG_SUPPORT` in `executor-config.ts`. Setting a flag that the chosen kind does not support throws `ExecutorConfigError` before dispatch.\n284: \n285: Cross-CLI delegation (a running executor invoking other CLIs via its shell) is documented design intent. Runtime recursion detection is out of scope; see the SKILL.md Cross-CLI Delegation subsection.\n286: \n287: Failure handling remains unchanged from spec 018: `schema_mismatch` → conflict event → 3 consecutive failures → `stuck_recovery`.\n288: \n289: The dispatch context may include a suggested `focusTrack` label (e.g., `\"focusTrack\": \"performance\"`, `\"focusTrack\": \"security\"`). Agents may tag their iteration with this track label for post-hoc grouping and analysis. Track labels are metadata only - the orchestrator does not use them for loop decisions.\n290: \n291: #### Step 3a: Per-Iteration Budget\n292: \n293: After dispatch, the orchestrator monitors the running iteration against budget limits:\n294: - **Tool call count**: tracked against `config.maxToolCallsPerIteration` (default: 12)\n295: - **Elapsed time**: tracked against `config.maxMinutesPerIteration` (default: 10)\n296: - If either limit is exceeded and no iteration file has been written yet:\n297:   1. Mark the iteration as `\"status\": \"timeout\"` in the JSONL record\n298:   2. Log event: `{\"type\":\"event\",\"event\":\"iteration_timeout\",\"iteration\":N,\"reason\":\"tool_calls|elapsed_time\"}`\n299:   3. Continue to the next iteration (do not retry the timed-out iteration)\n300: - Budget limits are soft caps - if the agent is actively writing its iteration file when the limit is reached, allow completion\n301: \n302: #### Step 4: Evaluate Results\n303: After agent completes:\n304: 1. Verify `{artifact_dir}/iterations/iteration-{NNN}.md` was created\n305: 2. Verify JSONL was appended with iteration record\n306: 3. Run reducer with `{ latestJSONLDelta, newIterationFile, priorReducedState }`\n307:    - This is a **delta refresh**, not a full replay of every historical JSONL row on each iteration.\n308:    - The reducer consumes only the newest JSONL slice plus the latest iteration artifact against the previously reduced packet state.\n309: 4. Verify reducer refreshed `deep-research-strategy.md`, `findings-registry.json`, and `deep-research-dashboard.md`\n310: 5. Verify the refreshed packet surfaces reflect the new iteration evidence\n311: 6. Extract `newInfoRatio` from JSONL record\n312: 7. Track stuck count: skip if `status == \"thought\"` (no change), reset to 0 if `status == \"insight\"` (breakthrough counts as progress), increment if `newInfoRatio < config.convergenceThreshold`, reset otherwise\n313: \n314: #### Step 4a: Generate Dashboard\n315: \n316: After evaluating iteration results, generate a human-readable dashboard:\n317: \n318: 1. Read JSONL state log, findings registry, and strategy.md\n319: 2. Generate or regenerate `research/deep-research-dashboard.md` with the following sections:\n320:    - **Iteration table**: `| run | focus | newInfoRatio | findings count | status |`\n321:    - **Question status**: `X/Y answered` with itemized list (answered vs remaining)\n322:    - **Trend**: Last 3 newInfoRatio values with direction indicator (ascending, descending, flat)\n323:    - **Dead ends**: Consolidated from all iteration `ruledOut` data\n324:    - **Next focus**: Current value from strategy.md\n325:    - **Active risks**: Guard violations, stuck count, budget warnings\n326: 3. Log event: `{\"type\":\"event\",\"event\":\"dashboard_generated\",\"iteration\":N}`\n327: 4. The dashboard is **auto-generated only** - never manually edited\n328: 5. The dashboard file is overwritten each iteration (not appended)\n329: 6. Dashboard generation is non-blocking: if it fails, log a warning and continue the loop\n330: \n331: In **confirm mode**, the dashboard is displayed to the user at each iteration approval gate. In **auto mode**, it is written silently for post-hoc review.\n332: \n333: #### Step 4b: Checkpoint Commit (REFERENCE-ONLY)\n334: \n335: This checkpointing pattern is documented for reference, but current runtimes should not assume it is available.\n336: \n337: After each iteration is verified (JSONL appended, iteration file written, reducer outputs refreshed):\n338: \n339: 1. **Stage targeted files only** (never `git add -A`):\n340:    ```bash\n341:    git add research/iterations/iteration-{NNN}.md\n342:    git add research/deep-research-state.jsonl\n343:    git add research/deep-research-strategy.md\n344:    git add research/findings-registry.json\n345:    git add research/deep-research-dashboard.md\n346:    git add research/research.md  # if it exists\n347:    ```\n348: 2. **Sanitize**: Exclude `.env`, credentials, large binaries from staging\n349: 3. **Commit**: `git commit -m \"chore(deep-research): iteration {NNN} complete\"`\n350: 4. **On commit failure**: Log warning and continue (checkpoint is non-blocking)\n351: \n352: Checkpoint commits provide rollback points: `git log -- research/` shows the last good state for the research packet. If state corruption occurs, `git checkout HEAD~1 -- research/deep-research-state.jsonl` restores the previous version.\n353: \n354: #### Step 5: Loop Decision\n355: - If convergence check returns STOP: exit to synthesis\n356: - If STUCK_RECOVERY: modify focus directive, reset stuck count, continue\n357: - Otherwise: increment iteration counter, go to Step 1\n358: \n359: ### Ideas Backlog Convention\n360: \n361: The canonical ideas backlog is reducer-owned and derived from JSONL lifecycle events. A persistent ideas file at `research/research-ideas.md` may still exist as operator-authored context, but leaf agents record new machine-discovered tangents with `idea_observed` events.\n362: \n363: #### Check Points\n364: \n365: The orchestrator checks the ideas backlog at three points:\n366: \n367: 1. **Init**: During strategy initialization, if `research/research-ideas.md` exists from a prior session, read it as operator-authored context and incorporate relevant ideas into the initial key questions or \"Next Focus\"\n368: 2. **Stuck**: During stuck recovery (Step 2a of the recovery protocol in convergence.md), check reducer-promoted ideas before defaulting to generic recovery strategies. Promoted ideas often provide the best escape from stuck states\n369: 3. **Resume**: On auto-resume, read JSONL, registry, strategy.md, and any operator-authored ideas file to restore full context\n370: \n371: #### Event Format\n372: \n373: ```json\n374: {\"type\":\"event\",\"event\":\"idea_observed\",\"mode\":\"research\",\"run\":4,\"ideaId\":\"idea-cache-stampede\",\"idea\":\"Investigate cache stampede mitigation\",\"category\":\"ideas\",\"source\":\"iteration-004.md\",\"timestamp\":\"2026-05-24T00:00:00Z\"}\n375: {\"type\":\"event\",\"event\":\"idea_promoted\",\"mode\":\"research\",\"run\":5,\"ideaId\":\"idea-cache-stampede\",\"idea\":\"Investigate cache stampede mitigation\",\"category\":\"ideas\",\"observationCount\":2,\"minIdeaObservations\":2,\"firstObservedRun\":4,\"lastObservedRun\":5,\"timestamp\":\"2026-05-24T00:01:00Z\"}\n376: {\"type\":\"event\",\"event\":\"idea_rejected\",\"mode\":\"research\",\"run\":6,\"ideaId\":\"idea-cache-stampede\",\"idea\":\"Investigate cache stampede mitigation\",\"category\":\"ideas\",\"reason\":\"Operator rejected this direction\",\"timestamp\":\"2026-05-24T00:02:00Z\"}\n377: ```\n378: \n379: Users can edit `research-ideas.md` between sessions to steer future iterations. Agents do not promote ideas directly; they emit observations, and the reducer owns promotion, ranking, rejection filtering, and dashboard projection.\n380: \n381: ### Stuck Recovery Protocol\n382: When stuckThreshold consecutive iterations show no progress (default: 3, configurable via config.json):\n383: \n384: **Step 0: Classify Failure Mode**\n385: Before selecting a recovery strategy, classify why progress stalled:\n386: 1. Read the last N iteration files (where N = stuckThreshold) to determine the failure pattern\n387: 2. Classify into one of the following modes:\n388:    - `shallow_sources` - iterations find content but lack depth or authoritative sources\n389:    - `contradictory` - iterations return conflicting information without resolution\n390:    - `too_broad` - focus area is too wide, producing scattered low-value findings\n391:    - `repetitive` - iterations keep rediscovering the same information\n392:    - `exhausted` - the topic area has been thoroughly explored with diminishing returns\n393: 3. Select a targeted recovery prompt based on the classification (see convergence.md §4 for category-specific strategies)\n394: 4. Log classification: `{\"type\":\"event\",\"event\":\"stuck_classified\",\"mode\":\"<classification>\",\"iteration\":N}`\n395: \n396: **Steps 1-5: Execute Recovery**\n397: 1. Read strategy.md \"What Worked\" section\n398: 2. Identify least-explored question from \"Key Questions\"\n399: 3. Set next focus to: \"RECOVERY: Widen scope to {least-explored-area}. Try a fundamentally different approach.\" (refined by classification)\n400: 4. Reset stuck counter\n401: 5. If recovery iteration also shows no progress: exit to synthesis with gaps documented\n402: \n403: ### Step 3b: Direct Mode Fallback (REFERENCE-ONLY)\n404: \n405: When agent dispatch fails after the earlier recovery tiers are exhausted:\n406: \n407: 1. Detect dispatch failure: Task tool timeout, API overload (529), or agent crash\n408: 2. Log event: `{\"type\":\"event\",\"event\":\"direct_mode\",\"iteration\":N,\"reason\":\"dispatch_failure\"}`\n409: 3. Orchestrator absorbs the iteration work:\n410:    - Read state files (JSONL + strategy.md)\n411:    - Determine focus from strategy \"Next Focus\"\n412:    - Execute 3-5 research actions directly\n413:    - Write `research/iterations/iteration-NNN.md`\n414:    - Update strategy.md\n415:    - Append iteration record to JSONL\n416: 4. Continue loop normally after direct-mode iteration completes\n417: 5. If direct mode also fails, escalate to the final user-escalation tier\n418: \n419: **Note**: Direct mode iterations are logged with `\"directMode\": true` in their JSONL record for diagnostic tracking.\n420: \n421: ---\n422: \n423: ## 4. WAVE ORCHESTRATION PROTOCOL (REFERENCE-ONLY)\n424: \n425: An optional parallel execution concept for research topics with multiple independent questions. Treat this as reference guidance only; the live workflow remains sequential and does **not** emit wave-specific JSONL events or routing today.\n426: \n427: ### When to Use Waves\n428: \n429: - 3+ independent key questions identified during initialization\n430: - Questions do not depend on each other's answers\n431: - Parallelism is beneficial (time-constrained research, broad survey)\n432: \n433: ### Wave Execution Model (conceptual only)\n434: \n435: ```text\n436: Wave 1: Dispatch N agents on independent questions\n437:   |\n438:   +-- Agent A: Question 1 --> iteration-001.md (newInfoRatio: 0.8)\n439:   +-- Agent B: Question 2 --> iteration-002.md (newInfoRatio: 0.3)\n440:   +-- Agent C: Question 3 --> iteration-003.md (newInfoRatio: 0.7)\n441:   |\n442: Scoring: Rank by newInfoRatio, prune below median only in a future runtime that explicitly adds wave support\n443:   |\n444: Wave 2: Follow-up on top-K questions (K = ceil(N/2))\n445:   +-- Agent A: Question 1 follow-up --> iteration-004.md\n446:   +-- Agent C: Question 3 follow-up --> iteration-005.md\n447:   |\n448: Repeat until convergence\n449: ```\n450: \n451: ### Scoring and Pruning\n452: \n453: In a future wave-enabled runtime:\n454: 1. Rank all wave iterations by `newInfoRatio`\n455: 2. Compute wave median: `median([i.newInfoRatio for i in wave_iterations])`\n456: 3. **Prune**: Questions with newInfoRatio below median would be deprioritized\n457: 4. **Promote**: Top-K questions (K = ceil(N/2)) would get follow-up iterations\n458: 5. Pruned questions would move to the ideas backlog, not be discarded\n459: \n460: ### Breakthrough Detection\n461: \n462: When any single iteration in a wave achieves `newInfoRatio > 2x wave_average`:\n463: \n464: 1. Flag as **breakthrough**: `{\"type\":\"event\",\"event\":\"breakthrough\",\"iteration\":N,\"ratio\":X.XX}`\n465: 2. Generate 2-3 adjacent questions from the breakthrough findings\n466: 3. Prioritize these adjacent questions in the next wave\n467: 4. Breakthrough iterations are NEVER pruned\n468: \n469: ### Wave JSONL Records\n470: \n471: Wave-specific fields and events are **not part of the current persisted contract**. Until a runtime explicitly ships wave support, keep iteration records and events on the standard sequential schema only.\n472: \n473: ### Integration with Sequential Loop\n474: \n475: - Waves are an ALTERNATIVE to sequential iteration, not a replacement\n476: - The convergence algorithm applies identically (uses all iteration records)\n477: - A future wave-capable runtime could transition back to sequential mode when questions narrow to 1-2\n478: - The current runtime never spawns a wave automatically\n479: \n480: ---\n481: \n482: ## 5. CONTEXT ISOLATION DISPATCH (EXPERIMENTAL, REFERENCE-ONLY)\n483: \n484: An alternative dispatch mechanism that guarantees fresh context per iteration by launching a new OS process. Treat this as reference-only unless the runtime explicitly implements alternate CLI dispatch.\n485: \n486: ### Motivation\n487: \n488: The standard dispatch (Task tool) shares the parent session's token budget. In long research sessions (10+ iterations), this may cause context compression that degrades reasoning quality. Process-level isolation eliminates this risk.\n489: \n490: ### Dispatch Mechanism\n491: \n492: Replace Task tool dispatch with shell-level `claude -p` invocation:\n493: \n494: 1. **Generate prompt**: Orchestrator builds a self-contained prompt from:\n495:    - Strategy.md (current state)\n496:    - Config.json (parameters)\n497:    - Last N iteration summaries (from JSONL)\n498:    - Compact state summary (Step 2b)\n499:    - Full agent protocol instructions\n500: 2. **Write to temp file**: `scratch/.dispatch-prompt-{NNN}.md`\n501: 3. **Execute**: `claude -p \"$(cat scratch/.dispatch-prompt-{NNN}.md)\" --max-turns 50 --output-format json`\n502: 4. **Collect output**: Agent writes iteration file directly to disk\n503: 5. **Verify**: Orchestrator checks iteration file and JSONL were created\n504: 6. **Cleanup**: Remove temp prompt file\n505: \n506: ### Trade-offs\n507: \n508: | Aspect | Task Tool Dispatch | `claude -p` Dispatch |\n509: |--------|-------------------|---------------------|\n510: | Context freshness | Shared budget, may degrade | Guaranteed fresh |\n511: | Token cost | Lower (cached context) | Higher (full context per call) |\n512: | Latency | Lower (in-process) | Higher (new process startup) |\n513: | Context size | Limited by parent budget | Full model context available |\n514: | Error handling | In-process exceptions | Process exit codes |\n515: \n516: ### When to Use\n517: \n518: - Autonomous/unattended research sessions (overnight runs)\n519: - Research past iteration 8+ where context degradation is measurable\n520: - Critical research where reasoning quality must not degrade\n521: \n522: **Status**: Reference-only. Track adoption based on need for fully autonomous overnight research sessions.\n523: \n524: ---\n525: \n526: ## 6. PHASE: SYNTHESIS\n527: \n528: ### Purpose\n529: Compile all iteration findings into final research/research.md. The synthesis workflow owns the canonical `research/research.md` output.\n530: \n531: ### Steps\n532: \n533: 1. **Read all iteration files**: `research/iterations/iteration-*.md`\n534: 2. **Read strategy.md**: Final state of questions, approaches\n535: 3. **Compile research/research.md**: Merge findings into 17-section format\n536:    - Deduplicate overlapping findings\n537:    - Organize by section topic\n538:    - Add citations from iteration files\n539:    - Cite `{spec_folder}/resource-map.md` in the References section when `config.resource_map_present == true`\n540:    - Do not synthesize a placeholder reference when `resource-map.md` was absent at init\n541:    - Note unanswered questions in Section 12 (Open Questions)\n542:    - **Include a mandatory \"## Eliminated Alternatives\" section** as primary research output:\n543:      - Consolidate all `ruledOut` entries from iteration JSONL records\n544:      - Consolidate all `## Dead Ends` sections from iteration files\n545:      - Format as a table: `| Approach | Reason Eliminated | Evidence | Iteration(s) |`\n546:      - This section documents negative knowledge (what was tried and why it failed)\n547:      - Treat as primary research output - not an appendix or afterthought\n548:      - Place after Section 11 (Recommendations) and before Section 12 (Open Questions)\n549: 4. **If reopening a completed packet later**: snapshot this file as `research/synthesis-v{generation}.md` before any `completed-continue` flow\n550: 5. **Update config status**: Set `status: \"complete\"` in config.json\n551: 6. **Final JSONL entry**: `{\"type\":\"event\",\"event\":\"synthesis_complete\",\"totalIterations\":N,\"answeredCount\":A,\"totalQuestions\":Q,\"stopReason\":\"converged\"}`\n552: \n553: ### Progressive vs Final Synthesis\n554: - If `progressiveSynthesis: true` (default): research/research.md was updated each iteration. Final synthesis is a cleanup pass.\n555: - If `progressiveSynthesis: false`: research/research.md is created from scratch during synthesis.\n556: \n557: ---\n558: \n559: ## 7. PHASE: SAVE\n560: \n561: ### Purpose\n562: Preserve research context to memory system.\n563: \n564: ### Steps\n565: \n566: 1. **Generate context**: `node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js {spec_folder}`\n567: 2. **No extra indexing step in the live contract**: `generate-context.js` is the supported save boundary for this workflow\n568: 3. **Verify**: Confirm memory/*.md file created with proper anchors\n569: \n570: ---\n571: \n572: ## 8. STATE TRANSITIONS\n573: \n574: ```text\n575: [INITIALIZED] --> config + strategy + state created\n576:     |\n577: [ITERATING] --> agent dispatched, executing research\n578:     |\n579: [EVALUATING] --> iteration complete, checking convergence\n580:     |\n581:     |-- newInfoRatio >= threshold --> [ITERATING]\n582:     |-- stuck_count >= stuckThreshold --> [STUCK_RECOVERY]\n583:     |-- converged or max_iterations --> [SYNTHESIZING]\n584: \n585: [STUCK_RECOVERY] --> widen focus, try different approach\n586:     |\n587:     |-- recovered (newInfoRatio > 0) --> [ITERATING]\n588:     |-- still stuck --> [SYNTHESIZING] (gaps documented)\n589: \n590: [SYNTHESIZING] --> final research/research.md compilation\n591:     |\n592: [SAVING] --> memory context preservation\n593:     |\n594: [COMPLETE] --> all artifacts created, loop finished\n595: ```\n596: \n597: Hook-capable and non-hook runtimes must follow the same state machine. Hooks may pre-prime context, but they must not change which lifecycle branch the packet selects.\n598: \n599: ---\n600: \n601: ## 9. ERROR HANDLING\n602: \n603: | Error | Phase | Action |\n604: |-------|-------|--------|\n605: | Agent dispatch timeout | Loop | Retry once with reduced scope. If second timeout, mark iteration as \"timeout\" and continue |\n606: | WebFetch fails | Loop | Log URL in iteration file, try alternative source, continue with available data |\n607: | State file missing | Init/Loop | If JSONL missing: re-initialize. If strategy missing: reconstruct from JSONL |\n608: | JSONL malformed | Loop | Skip malformed lines, reconstruct from valid entries |\n609: | 3+ consecutive failures | Loop | Halt loop, enter synthesis with partial findings |\n610: | Agent dispatch failure (API overload, timeout) | Loop | Escalate through the documented recovery ladder in order. Direct mode fallback is reference-only unless the runtime explicitly supports it. |\n611: | Memory save fails | Save | Preserve the current `{artifact_dir}` packet as backup, then log the error |\n612: \n613: ### State Recovery Protocol\n614: \n615: When state files are missing or corrupted, apply this 5-priority cascade:\n616: \n617: | Priority | Condition | Recovery Action |\n618: |----------|-----------|----------------|\n619: | 1 (Primary) | JSONL exists and parseable | Normal operation (with fault-tolerant parsing) |\n620: | 2 (Strategy rebuild) | JSONL exists, strategy.md missing | Reconstruct strategy from JSONL: extract questions, focus areas, newInfoRatio trend. Create minimal strategy.md |\n621: | 3 (JSONL reconstruction) | JSONL missing/corrupt, iteration files exist | Scan `research/iterations/iteration-*.md`, parse Assessment sections, reconstruct JSONL with `status: \"reconstructed\"` |\n622: | 4 (Config-only restart) | Only config.json remains | Restart from initialization phase using config parameters. Log: `{\"type\":\"event\",\"event\":\"fresh_restart\",\"reason\":\"state_files_missing\"}` |\n623: | 5 (Abort) | Config.json also missing | Cannot recover. Report error and halt. |\n624: \n625: Each priority level is attempted in order. If a level fails, fall through to the next. See state_format.md for JSONL reconstruction details.\n626: \n627: ---\n628: \n629: ## 10. CONFIRM MODE ADDITIONS\n630: \n631: In confirm mode, the YAML workflow adds approval gates:\n632: \n633: | Gate Location | Behavior |\n634: |---------------|----------|\n635: | After initialization | Show config and initial strategy. Wait for approval |\n636: | After each iteration | Show iteration findings and convergence status. Options: Continue, Adjust Focus, Stop |\n637: | Before synthesis | Show summary of all iterations. Wait for approval to synthesize |\n638: | After synthesis | Show final research/research.md summary. Approve or request revisions |\n639: \n640: ---\n641: \n642: ## 11. REVIEW MODE ROUTING\n643: \n644: Deep-review lifecycle, convergence, state schemas, traceability protocols, and report contracts live in the sibling `deep-review` skill.\n645: \n646: This reference keeps only the routing rule: do not document or execute review-mode loop behavior from `deep-research`. Route review requests to `deep-review/SKILL.md` and its references.\n\n(End of file - total 646 lines)\n</content>","metadata":{"preview":"---\ntitle: Loop Protocol Reference\ndescription: Canonical specification for the deep research loop lifecycle with 4 phases, reference-only wave orchestration, and error handling.\ntrigger_phrases:\n  - \"research loop protocol\"\n  - \"research loop lifecycle\"\n  - \"research loop initialization\"\n  - \"research auto resume protocol\"\n  - \"research pause sentinel\"\n  - \"research synthesis phase\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.14.0.29\n---\n\n# Loop Protocol Reference\n\nCanonical specification for the deep research loop lifecycle. Use it as the lifecycle map for initialization, iteration, synthesis, save, and recovery.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md","text":"---\ntitle: Loop Protocol Reference\ndescription: Canonical specification for the deep research loop lifecycle with 4 phases, reference-only wave orchestration, and error handling.\ntrigger_phrases:\n  - \"research loop protocol\"\n  - \"research loop lifecycle\"\n  - \"research loop initialization\"\n  - \"research auto resume protocol\"\n  - \"research pause sentinel\"\n  - \"research synthesis phase\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.14.0.29\n---\n\n# Loop Protocol Reference\n\nCanonical specification for the deep research loop lifecycle. Use it as the lifecycle map for initialization, iteration, synthesis, save, and recovery.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nDefine the lifecycle contract for deep-research initialization, iteration, synthesis, save, reference-only dispatch concepts, and error handling.\n\n### When to Use\n\nLoad this reference when running or validating the research loop lifecycle. Use `../convergence/convergence.md` for STOP decisions and `../state/state_format.md` for packet file schemas.\n\n### Core Principle\n\nThe YAML workflow owns lifecycle orchestration, `@deep-research` executes LEAF iterations, and the reducer synchronizes packet state after each iteration and lifecycle transition.\n\n### Phase Model\n\nThe deep research loop has 4 phases: initialization, iteration (repeated), synthesis, and save.\n\nRuntime capability matrix references for parity-sensitive loop behavior:\n- Human-readable matrix: `.opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md`\n- Machine-readable matrix: `.opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json`\n\n```text\n┌──────────┐     ┌──────────────────────────┐     ┌───────────────────────┐     ┌──────────┐\n│  INIT    │────>│  LOOP                    │────>│  SYNTHESIS            │────>│  SAVE    │\n│          │     │  ┌────────────────────┐  │     │                       │     │          │\n│ Config    │     │  │ Read State         │  │     │ Final                 │     │ Memory   │\n│ Strategy │     │  │ Check Convergence  │  │     │ research/research.md  │     │ Context  │\n│ State    │     │  │ Dispatch Agent     │  │     │ compilation           │     │ Save     │\n│          │     │  │ Evaluate Results   │  │     │                       │     │          │\n│          │     │  │ Loop Decision      │  │     │                       │     │          │\n│          │     │  └────────┬───────────┘  │     │                       │     │          │\n│          │     │           │ repeat       │     │                       │     │          │\n└──────────┘     └──────────────────────────┘     └───────────────────────┘     └──────────┘\n```\n\n---\n\n## 2. PHASE: INITIALIZATION\n\n### Purpose\nSet up all state files for a new research session.\n\n### Steps\n\n1. **Classify session state before writing**:\n   - `fresh`: no config/state/strategy files exist\n   - `resume`: config + state + strategy all exist and agree\n   - `completed-session`: consistent prior state with `config.status == \"complete\"`\n   - `invalid-state`: partial or contradictory artifacts\n2. **Resolve canonical artifact names**:\n   - Read legacy aliases during the migration window if needed\n   - Write only canonical `deep-research-*` names\n   - Emit a `migration` event for every legacy alias consumed\n3. **Resolve local artifact owner**: `artifact_dir = resolveArtifactRoot(specFolder, 'research').artifactDir`, then `mkdir -p {artifact_dir}/iterations`\n4. **Write config**: `research/deep-research-config.json` from template + user parameters\n5. **Initialize state log**: First line of `research/deep-research-state.jsonl` with config record\n6. **Initialize strategy**: `research/deep-research-strategy.md` from template with:\n   - Topic from user input\n   - Initial key questions (3-5, from topic analysis)\n   - Known context from `memory_context()` results (if any), injected only after the strategy file exists\n   - Research boundaries from config\n6a. **Detect resource-map integration state**:\n   - Check `{spec_folder}/resource-map.md` once during init\n   - If present: set `resource_map_present = true` in `deep-research-config.json`\n   - Summarize the map into `deep-research-strategy.md` `Known Context`\n   - The summary MUST include per-section entry counts for `READMEs`, `Documents`, `Commands`, `Agents`, `Skills`, `Specs`, `Scripts`, `Tests`, `Config`, and `Meta`\n   - The summary MUST also include a one-line theme summary for each resource-map section\n   - If absent: set `resource_map_present = false` and append `resource-map.md not present; skipping coverage gate` to `Known Context`\n7. **Initialize findings registry**: `research/findings-registry.json` with empty `openQuestions`, `resolvedQuestions`, `keyFindings`, and `ruledOutDirections`\n7a. **Validate Research Charter**:\n   - Verify strategy.md contains a \"Non-Goals\" section (may be empty but must exist)\n   - Verify strategy.md contains a \"Stop Conditions\" section (may be empty but must exist)\n   - If either section is missing, append it as an empty placeholder before proceeding\n   - In **confirm mode**: present the charter (topic, key questions, non-goals, stop conditions) for user review before proceeding\n   - In **auto mode**: accept the charter automatically and continue\n8. **Resume only if config, JSONL, and strategy agree**; otherwise halt for repair instead of guessing\n\n### Outputs\n- `research/deep-research-config.json`\n- `research/deep-research-state.jsonl` (1 line)\n- `research/deep-research-strategy.md`\n\n### Auto-Resume Protocol\nIf state files already exist from a prior session:\n1. Verify config, JSONL, and strategy all exist and agree on topic/spec folder\n2. Read JSONL, count iteration records\n3. Read strategy.md for current state\n4. Set iteration counter to last completed + 1\n5. Append the canonical resume event to `deep-research-state.jsonl` (all fields below are required by the reducer):\n\n```json\n{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"research\",\"sessionId\":\"rsr-2026-03-18T10-00-00Z\",\"parentSessionId\":\"rsr-2026-03-18T10-00-00Z\",\"lineageMode\":\"resume\",\"continuedFromRun\":4,\"generation\":1,\"timestamp\":\"2026-03-18T14:05:00Z\"}\n```\n\n6. Continue loop from `step_read_state`.\n\n### Lifecycle Branch Contract (current release)\n\nThe runtime supports three lineage modes today. `fork` and `completed-continue` were described in earlier drafts but have no workflow wiring in this release, so they MUST NOT be exposed to operators. If the long-form lineage feature is picked up later it will arrive with first-class event emission, reducer ancestry handling, and replay fixtures; until then treat the contract below as canonical.\n\n| Mode | Session id | Generation | Archive | JSONL event | When to pick |\n|------|-----------|-----------|---------|-------------|--------------|\n| `new` | fresh | 1 | n/a | implicit (config record) | no existing state |\n| `resume` | same | same | none | `resumed` (see example above) | operator wants to continue the current lineage boundary |\n| `restart` | fresh | `prior + 1` | prior `research/` tree moved under `research_archive/{timestamp}/` | `restarted` (same field set plus `archivedPath`) | operator wants to clear the workspace and replay with a new angle |\n\n**Contract for every persisted lifecycle event**:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"resumed | restarted\",\n  \"mode\": \"research\",\n  \"sessionId\": \"<session id of the new or continuing lineage>\",\n  \"parentSessionId\": \"<session id of the prior lineage (equals sessionId on resume)>\",\n  \"lineageMode\": \"resume | restart\",\n  \"generation\": <number>,\n  \"continuedFromRun\": <number or null>,\n  \"archivedPath\": \"<path or null>\",\n  \"timestamp\": \"<ISO 8601>\"\n}\n```\n\nEvery field in the contract MUST be present on every persisted lifecycle event. `archivedPath` is null for `resumed` and set to the archive destination for `restarted`. `continuedFromRun` is the number of completed iteration records before the lifecycle boundary. Reducer parity tests ensure the dashboard `Lifecycle` section reads exactly those fields.\n\n---\n\n## 3. PHASE: ITERATION LOOP\n\n### Loop Steps (repeated until convergence)\n\n#### Step 1: Read State\n- Read `deep-research-state.jsonl` -- count iterations, get last newInfoRatio\n- Read `deep-research-strategy.md` -- get next focus, remaining questions\n\n#### Step 2: Check Convergence\nRun the convergence algorithm (see convergence.md):\n- Max iterations reached? STOP\n- Stuck count >= threshold? STUCK_RECOVERY\n- Average newInfoRatio < threshold? STOP\n- All questions answered? STOP\n- Otherwise: CONTINUE\n\n#### Step 2c: Quality Guard Check\n\nWhen the convergence algorithm returns STOP:\n1. Run quality guard checks (see convergence.md §2.4)\n2. Verify minimum coverage, source diversity, and question resolution thresholds\n3. If **all guards pass**: proceed with STOP, exit to synthesis\n4. If **any guard fails**: override decision to CONTINUE\n   - Log each violation: `{\"type\":\"event\",\"event\":\"guard_violation\",\"guard\":\"<name>\",\"iteration\":N,\"detail\":\"<reason>\"}`\n   - Persist the blocked legal-stop outcome: `{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"research\",\"run\":N,\"blockedBy\":[\"<gate>\"],\"gateResults\":{\"convergence\":{\"pass\":true,\"score\":0.0},\"keyQuestionCoverage\":{\"pass\":false,\"answered\":X,\"total\":Y},\"evidenceDensity\":{\"pass\":false,\"sources\":N},\"hotspotSaturation\":{\"pass\":true}},\"recoveryStrategy\":\"<one-line hint>\",\"timestamp\":\"<ISO8601>\",\"sessionId\":\"<sid>\",\"generation\":G}`\n   - Append failed guard details to strategy.md \"Active Risks\" section\n5. The loop continues until BOTH convergence AND quality guards pass simultaneously\n6. Guard checks apply only to STOP decisions - CONTINUE and STUCK_RECOVERY bypass this step\n\nIf the legal-stop decision tree returns `blocked`, the workflow MUST append the `blocked_stop` JSONL event before continuing. Reducers and dashboards consume the persisted event; they must not infer blocked-stop state solely from prose logs.\n\n#### Step 2a: Check Pause Sentinel\n\nBefore dispatching, check for a pause sentinel file:\n\n1. Check if `research/.deep-research-pause` exists\n2. If present:\n   - Log event to JSONL: `{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":N,\"stopReason\":\"userPaused\",\"sentinelPath\":\"{artifact_dir}/.deep-research-pause\",\"timestamp\":\"<ISO8601>\",\"sessionId\":\"<sid>\",\"generation\":G}`\n   - Halt the loop with message:\n     ```text\n     Research paused. Delete research/.deep-research-pause to resume.\n     Current state: Iteration {N}, {remaining} questions remaining.\n     ```\n   - Do NOT exit to synthesis -- the loop is suspended, not stopped\n3. On resume (file deleted and loop restarted):\n   - Log event: `{\"type\":\"event\",\"event\":\"resumed\",\"fromIteration\":N}`\n   - Continue from step_read_state\n\nPause and recovery events use the frozen stop-reason enum on the live path. Raw `paused` and `stuck_recovery` labels are legacy aliases and MUST be normalized to `userPaused` and `stuckRecovery` at emission time.\n\n**Use case**: In autonomous mode, this provides the only graceful intervention mechanism short of killing the process. Users can create the sentinel file at any time to pause research between iterations.\n\n#### Step 2b: Generate State Summary\n\nGenerate a compact state summary (~200 tokens) for injection into the dispatch prompt:\n\n```text\nSTATE SUMMARY (auto-generated):\nSegment: {current_segment} | Iteration: {N} of {max}\nQuestions: {answered}/{total} answered | Last focus: {last_focus}\nLast 2 ratios: {ratio_N-1} -> {ratio_N} | Stuck count: {stuck_count}\nRecovery: {active_recovery_strategy or \"none\"}\nNext focus: {strategy.nextFocus}\n```\n\nThis summary is prepended to the dispatch context (Step 3) to ensure the agent has baseline context even if detailed strategy.md reading fails or is incomplete. It serves as a redundant context channel.\n\n#### Step 2d: Rejected Pattern Cache Check\n\nBefore selecting the next-focus, recovery, or ideas-backed candidate for dispatch, read the reducer-owned rejected-pattern cache and promoted ideas backlog from the findings registry.\n\nRejected-cache lifecycle:\n\n1. `idea_rejected` appends one rejected pattern to JSONL with `ideaId`, `idea` or `pattern`, optional `category`, optional `reason`, and normal lifecycle fields.\n2. The reducer derives the active cache from JSONL events; generated registry and dashboard files expose `rejectedPatterns`, `rejectedPatternIndex`, and `suppressedCandidates`.\n3. Exact suppression compares normalized candidate text against normalized rejected text.\n4. Fuzzy suppression uses `rejectedPatternFuzzyThreshold` from config when present, otherwise `0.85`, and only applies when the rejected category is compatible with the candidate category.\n5. `ideaRejectedRemoved` removes a single active pattern by id or by pattern/category.\n6. `ideaRejectedReset` clears all active rejected patterns for the current replay.\n\nThe active cache is capped at 100 entries. When the replay would exceed that cap, the oldest active entry is evicted and the reducer emits a warning. Operators can re-add an evicted pattern with another `idea_rejected` event if it remains relevant. Existing `ideaRejected` replay rows are legacy aliases and remain accepted for backward compatibility.\n\nIdeas lifecycle:\n\n1. Leaf agents may append `idea_observed` events only. They must not append `idea_promoted`.\n2. The reducer accumulates observations by `ideaId` or a normalized text-derived id.\n3. `minIdeaObservations` defaults to `2` and is clamped to `1..10`.\n4. When an idea reaches `observationCount >= minIdeaObservations`, the reducer appends one idempotent `idea_promoted` event and ranks promoted ideas by observation count, latest observation, then first observation.\n5. `idea_rejected` removes the matching idea from `promotedIdeas` and from ideas-backed next-focus candidates until a reset/removal event clears the active rejected pattern.\n\nCandidate categories:\n\n| Category | Candidate source |\n|----------|------------------|\n| `next-focus` | Strategy next-focus, carried-forward open questions, open questions, and follow-up findings |\n| `recovery` | Stuck and blocked-stop recovery strategies |\n| `ideas` | Reducer-promoted ideas backlog entries |\n| `general` | Cross-category fallback when a narrower category is not known |\n\nWhen all candidates in a category are suppressed, continue with the next eligible category or halt for operator input rather than reusing the rejected idea.\n\n#### Step 3: Dispatch Agent\nDispatch `@deep-research` with explicit context:\n```text\n{state_summary}  // Auto-generated (Step 2b)\n\nResearch Topic: {config.topic}\nIteration: {N} of {maxIterations}\nFocus Area: {strategy.nextFocus}\nRemaining Questions: {strategy.remainingQuestions}\nLast 3 Iterations Summary: {brief summaries}\nResource Map: if `config.resource_map_present == true`, prior-inventoried files are listed in `{spec_folder}/resource-map.md`; treat them as the exclusion set when hunting for net-new files; flag only missed-from-map candidates as gaps.\nState Files:\n  - Config: {artifact_dir}/deep-research-config.json\n  - State: {artifact_dir}/deep-research-state.jsonl\n  - Strategy: {artifact_dir}/deep-research-strategy.md\nOutput: Write findings to {artifact_dir}/iterations/iteration-{NNN}.md\nCONSTRAINT: LEAF agent -- do NOT dispatch sub-agents\n```\n\n#### Executor Resolution (spec 018 + 019)\n\nBefore dispatching, the YAML resolves the executor via `parseExecutorConfig` from `.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts`. The resolved `config.executor.kind` selects the dispatch branch:\n\n- `native` (spec 018): dispatch `@deep-research` agent with model Opus.\n- `cli-opencode` (spec 018): pipe rendered prompt via stdin to `opencode run --model X -c model_reasoning_effort=Y -c service_tier=Z -c approval_policy=never --sandbox workspace-write`.\n- `cli-claude-code` (spec 019): `claude -p \"$(cat prompt)\" --model X --permission-mode acceptEdits --output-format text` with optional `--effort Y`. Default permission-mode is `plan` (read-only); we override to `acceptEdits` so iteration writes succeed.\n\nAll branches share:\n1. Pre-dispatch prompt rendering via `renderPromptPack` (writes to `{artifact_dir}/prompts/iteration-{n}.md`).\n2. Post-dispatch validation via `validateIterationOutputs` (asserts iteration file + JSONL delta + required fields).\n3. Executor audit append via `appendExecutorAuditToLastRecord` (skipped when kind=='native').\n\nPer-kind flag-compatibility is enforced at config parse time by `EXECUTOR_KIND_FLAG_SUPPORT` in `executor-config.ts`. Setting a flag that the chosen kind does not support throws `ExecutorConfigError` before dispatch.\n\nCross-CLI delegation (a running executor invoking other CLIs via its shell) is documented design intent. Runtime recursion detection is out of scope; see the SKILL.md Cross-CLI Delegation subsection.\n\nFailure handling remains unchanged from spec 018: `schema_mismatch` → conflict event → 3 consecutive failures → `stuck_recovery`.\n\nThe dispatch context may include a suggested `focusTrack` label (e.g., `\"focusTrack\": \"performance\"`, `\"focusTrack\": \"security\"`). Agents may tag their iteration with this track label for post-hoc grouping and analysis. Track labels are metadata only - the orchestrator does not use them for loop decisions.\n\n#### Step 3a: Per-Iteration Budget\n\nAfter dispatch, the orchestrator monitors the running iteration against budget limits:\n- **Tool call count**: tracked against `config.maxToolCallsPerIteration` (default: 12)\n- **Elapsed time**: tracked against `config.maxMinutesPerIteration` (default: 10)\n- If either limit is exceeded and no iteration file has been written yet:\n  1. Mark the iteration as `\"status\": \"timeout\"` in the JSONL record\n  2. Log event: `{\"type\":\"event\",\"event\":\"iteration_timeout\",\"iteration\":N,\"reason\":\"tool_calls|elapsed_time\"}`\n  3. Continue to the next iteration (do not retry the timed-out iteration)\n- Budget limits are soft caps - if the agent is actively writing its iteration file when the limit is reached, allow completion\n\n#### Step 4: Evaluate Results\nAfter agent completes:\n1. Verify `{artifact_dir}/iterations/iteration-{NNN}.md` was created\n2. Verify JSONL was appended with iteration record\n3. Run reducer with `{ latestJSONLDelta, newIterationFile, priorReducedState }`\n   - This is a **delta refresh**, not a full replay of every historical JSONL row on each iteration.\n   - The reducer consumes only the newest JSONL slice plus the latest iteration artifact against the previously reduced packet state.\n4. Verify reducer refreshed `deep-research-strategy.md`, `findings-registry.json`, and `deep-research-dashboard.md`\n5. Verify the refreshed packet surfaces reflect the new iteration evidence\n6. Extract `newInfoRatio` from JSONL record\n7. Track stuck count: skip if `status == \"thought\"` (no change), reset to 0 if `status == \"insight\"` (breakthrough counts as progress), increment if `newInfoRatio < config.convergenceThreshold`, reset otherwise\n\n#### Step 4a: Generate Dashboard\n\nAfter evaluating iteration results, generate a human-readable dashboard:\n\n1. Read JSONL state log, findings registry, and strategy.md\n2. Generate or regenerate `research/deep-research-dashboard.md` with the following sections:\n   - **Iteration table**: `| run | focus | newInfoRatio | findings count | status |`\n   - **Question status**: `X/Y answered` with itemized list (answered vs remaining)\n   - **Trend**: Last 3 newInfoRatio values with direction indicator (ascending, descending, flat)\n   - **Dead ends**: Consolidated from all iteration `ruledOut` data\n   - **Next focus**: Current value from strategy.md\n   - **Active risks**: Guard violations, stuck count, budget warnings\n3. Log event: `{\"type\":\"event\",\"event\":\"dashboard_generated\",\"iteration\":N}`\n4. The dashboard is **auto-generated only** - never manually edited\n5. The dashboard file is overwritten each iteration (not appended)\n6. Dashboard generation is non-blocking: if it fails, log a warning and continue the loop\n\nIn **confirm mode**, the dashboard is displayed to the user at each iteration approval gate. In **auto mode**, it is written silently for post-hoc review.\n\n#### Step 4b: Checkpoint Commit (REFERENCE-ONLY)\n\nThis checkpointing pattern is documented for reference, but current runtimes should not assume it is available.\n\nAfter each iteration is verified (JSONL appended, iteration file written, reducer outputs refreshed):\n\n1. **Stage targeted files only** (never `git add -A`):\n   ```bash\n   git add research/iterations/iteration-{NNN}.md\n   git add research/deep-research-state.jsonl\n   git add research/deep-research-strategy.md\n   git add research/findings-registry.json\n   git add research/deep-research-dashboard.md\n   git add research/research.md  # if it exists\n   ```\n2. **Sanitize**: Exclude `.env`, credentials, large binaries from staging\n3. **Commit**: `git commit -m \"chore(deep-research): iteration {NNN} complete\"`\n4. **On commit failure**: Log warning and continue (checkpoint is non-blocking)\n\nCheckpoint commits provide rollback points: `git log -- research/` shows the last good state for the research packet. If state corruption occurs, `git checkout HEAD~1 -- research/deep-research-state.jsonl` restores the previous version.\n\n#### Step 5: Loop Decision\n- If convergence check returns STOP: exit to synthesis\n- If STUCK_RECOVERY: modify focus directive, reset stuck count, continue\n- Otherwise: increment iteration counter, go to Step 1\n\n### Ideas Backlog Convention\n\nThe canonical ideas backlog is reducer-owned and derived from JSONL lifecycle events. A persistent ideas file at `research/research-ideas.md` may still exist as operator-authored context, but leaf agents record new machine-discovered tangents with `idea_observed` events.\n\n#### Check Points\n\nThe orchestrator checks the ideas backlog at three points:\n\n1. **Init**: During strategy initialization, if `research/research-ideas.md` exists from a prior session, read it as operator-authored context and incorporate relevant ideas into the initial key questions or \"Next Focus\"\n2. **Stuck**: During stuck recovery (Step 2a of the recovery protocol in convergence.md), check reducer-promoted ideas before defaulting to generic recovery strategies. Promoted ideas often provide the best escape from stuck states\n3. **Resume**: On auto-resume, read JSONL, registry, strategy.md, and any operator-authored ideas file to restore full context\n\n#### Event Format\n\n```json\n{\"type\":\"event\",\"event\":\"idea_observed\",\"mode\":\"research\",\"run\":4,\"ideaId\":\"idea-cache-stampede\",\"idea\":\"Investigate cache stampede mitigation\",\"category\":\"ideas\",\"source\":\"iteration-004.md\",\"timestamp\":\"2026-05-24T00:00:00Z\"}\n{\"type\":\"event\",\"event\":\"idea_promoted\",\"mode\":\"research\",\"run\":5,\"ideaId\":\"idea-cache-stampede\",\"idea\":\"Investigate cache stampede mitigation\",\"category\":\"ideas\",\"observationCount\":2,\"minIdeaObservations\":2,\"firstObservedRun\":4,\"lastObservedRun\":5,\"timestamp\":\"2026-05-24T00:01:00Z\"}\n{\"type\":\"event\",\"event\":\"idea_rejected\",\"mode\":\"research\",\"run\":6,\"ideaId\":\"idea-cache-stampede\",\"idea\":\"Investigate cache stampede mitigation\",\"category\":\"ideas\",\"reason\":\"Operator rejected this direction\",\"timestamp\":\"2026-05-24T00:02:00Z\"}\n```\n\nUsers can edit `research-ideas.md` between sessions to steer future iterations. Agents do not promote ideas directly; they emit observations, and the reducer owns promotion, ranking, rejection filtering, and dashboard projection.\n\n### Stuck Recovery Protocol\nWhen stuckThreshold consecutive iterations show no progress (default: 3, configurable via config.json):\n\n**Step 0: Classify Failure Mode**\nBefore selecting a recovery strategy, classify why progress stalled:\n1. Read the last N iteration files (where N = stuckThreshold) to determine the failure pattern\n2. Classify into one of the following modes:\n   - `shallow_sources` - iterations find content but lack depth or authoritative sources\n   - `contradictory` - iterations return conflicting information without resolution\n   - `too_broad` - focus area is too wide, producing scattered low-value findings\n   - `repetitive` - iterations keep rediscovering the same information\n   - `exhausted` - the topic area has been thoroughly explored with diminishing returns\n3. Select a targeted recovery prompt based on the classification (see convergence.md §4 for category-specific strategies)\n4. Log classification: `{\"type\":\"event\",\"event\":\"stuck_classified\",\"mode\":\"<classification>\",\"iteration\":N}`\n\n**Steps 1-5: Execute Recovery**\n1. Read strategy.md \"What Worked\" section\n2. Identify least-explored question from \"Key Questions\"\n3. Set next focus to: \"RECOVERY: Widen scope to {least-explored-area}. Try a fundamentally different approach.\" (refined by classification)\n4. Reset stuck counter\n5. If recovery iteration also shows no progress: exit to synthesis with gaps documented\n\n### Step 3b: Direct Mode Fallback (REFERENCE-ONLY)\n\nWhen agent dispatch fails after the earlier recovery tiers are exhausted:\n\n1. Detect dispatch failure: Task tool timeout, API overload (529), or agent crash\n2. Log event: `{\"type\":\"event\",\"event\":\"direct_mode\",\"iteration\":N,\"reason\":\"dispatch_failure\"}`\n3. Orchestrator absorbs the iteration work:\n   - Read state files (JSONL + strategy.md)\n   - Determine focus from strategy \"Next Focus\"\n   - Execute 3-5 research actions directly\n   - Write `research/iterations/iteration-NNN.md`\n   - Update strategy.md\n   - Append iteration record to JSONL\n4. Continue loop normally after direct-mode iteration completes\n5. If direct mode also fails, escalate to the final user-escalation tier\n\n**Note**: Direct mode iterations are logged with `\"directMode\": true` in their JSONL record for diagnostic tracking.\n\n---\n\n## 4. WAVE ORCHESTRATION PROTOCOL (REFERENCE-ONLY)\n\nAn optional parallel execution concept for research topics with multiple independent questions. Treat this as reference guidance only; the live workflow remains sequential and does **not** emit wave-specific JSONL events or routing today.\n\n### When to Use Waves\n\n- 3+ independent key questions identified during initialization\n- Questions do not depend on each other's answers\n- Parallelism is beneficial (time-constrained research, broad survey)\n\n### Wave Execution Model (conceptual only)\n\n```text\nWave 1: Dispatch N agents on independent questions\n  |\n  +-- Agent A: Question 1 --> iteration-001.md (newInfoRatio: 0.8)\n  +-- Agent B: Question 2 --> iteration-002.md (newInfoRatio: 0.3)\n  +-- Agent C: Question 3 --> iteration-003.md (newInfoRatio: 0.7)\n  |\nScoring: Rank by newInfoRatio, prune below median only in a future runtime that explicitly adds wave support\n  |\nWave 2: Follow-up on top-K questions (K = ceil(N/2))\n  +-- Agent A: Question 1 follow-up --> iteration-004.md\n  +-- Agent C: Question 3 follow-up --> iteration-005.md\n  |\nRepeat until convergence\n```\n\n### Scoring and Pruning\n\nIn a future wave-enabled runtime:\n1. Rank all wave iterations by `newInfoRatio`\n2. Compute wave median: `median([i.newInfoRatio for i in wave_iterations])`\n3. **Prune**: Questions with newInfoRatio below median would be deprioritized\n4. **Promote**: Top-K questions (K = ceil(N/2)) would get follow-up iterations\n5. Pruned questions would move to the ideas backlog, not be discarded\n\n### Breakthrough Detection\n\nWhen any single iteration in a wave achieves `newInfoRatio > 2x wave_average`:\n\n1. Flag as **breakthrough**: `{\"type\":\"event\",\"event\":\"breakthrough\",\"iteration\":N,\"ratio\":X.XX}`\n2. Generate 2-3 adjacent questions from the breakthrough findings\n3. Prioritize these adjacent questions in the next wave\n4. Breakthrough iterations are NEVER pruned\n\n### Wave JSONL Records\n\nWave-specific fields and events are **not part of the current persisted contract**. Until a runtime explicitly ships wave support, keep iteration records and events on the standard sequential schema only.\n\n### Integration with Sequential Loop\n\n- Waves are an ALTERNATIVE to sequential iteration, not a replacement\n- The convergence algorithm applies identically (uses all iteration records)\n- A future wave-capable runtime could transition back to sequential mode when questions narrow to 1-2\n- The current runtime never spawns a wave automatically\n\n---\n\n## 5. CONTEXT ISOLATION DISPATCH (EXPERIMENTAL, REFERENCE-ONLY)\n\nAn alternative dispatch mechanism that guarantees fresh context per iteration by launching a new OS process. Treat this as reference-only unless the runtime explicitly implements alternate CLI dispatch.\n\n### Motivation\n\nThe standard dispatch (Task tool) shares the parent session's token budget. In long research sessions (10+ iterations), this may cause context compression that degrades reasoning quality. Process-level isolation eliminates this risk.\n\n### Dispatch Mechanism\n\nReplace Task tool dispatch with shell-level `claude -p` invocation:\n\n1. **Generate prompt**: Orchestrator builds a self-contained prompt from:\n   - Strategy.md (current state)\n   - Config.json (parameters)\n   - Last N iteration summaries (from JSONL)\n   - Compact state summary (Step 2b)\n   - Full agent protocol instructions\n2. **Write to temp file**: `scratch/.dispatch-prompt-{NNN}.md`\n3. **Execute**: `claude -p \"$(cat scratch/.dispatch-prompt-{NNN}.md)\" --max-turns 50 --output-format json`\n4. **Collect output**: Agent writes iteration file directly to disk\n5. **Verify**: Orchestrator checks iteration file and JSONL were created\n6. **Cleanup**: Remove temp prompt file\n\n### Trade-offs\n\n| Aspect | Task Tool Dispatch | `claude -p` Dispatch |\n|--------|-------------------|---------------------|\n| Context freshness | Shared budget, may degrade | Guaranteed fresh |\n| Token cost | Lower (cached context) | Higher (full context per call) |\n| Latency | Lower (in-process) | Higher (new process startup) |\n| Context size | Limited by parent budget | Full model context available |\n| Error handling | In-process exceptions | Process exit codes |\n\n### When to Use\n\n- Autonomous/unattended research sessions (overnight runs)\n- Research past iteration 8+ where context degradation is measurable\n- Critical research where reasoning quality must not degrade\n\n**Status**: Reference-only. Track adoption based on need for fully autonomous overnight research sessions.\n\n---\n\n## 6. PHASE: SYNTHESIS\n\n### Purpose\nCompile all iteration findings into final research/research.md. The synthesis workflow owns the canonical `research/research.md` output.\n\n### Steps\n\n1. **Read all iteration files**: `research/iterations/iteration-*.md`\n2. **Read strategy.md**: Final state of questions, approaches\n3. **Compile research/research.md**: Merge findings into 17-section format\n   - Deduplicate overlapping findings\n   - Organize by section topic\n   - Add citations from iteration files\n   - Cite `{spec_folder}/resource-map.md` in the References section when `config.resource_map_present == true`\n   - Do not synthesize a placeholder reference when `resource-map.md` was absent at init\n   - Note unanswered questions in Section 12 (Open Questions)\n   - **Include a mandatory \"## Eliminated Alternatives\" section** as primary research output:\n     - Consolidate all `ruledOut` entries from iteration JSONL records\n     - Consolidate all `## Dead Ends` sections from iteration files\n     - Format as a table: `| Approach | Reason Eliminated | Evidence | Iteration(s) |`\n     - This section documents negative knowledge (what was tried and why it failed)\n     - Treat as primary research output - not an appendix or afterthought\n     - Place after Section 11 (Recommendations) and before Section 12 (Open Questions)\n4. **If reopening a completed packet later**: snapshot this file as `research/synthesis-v{generation}.md` before any `completed-continue` flow\n5. **Update config status**: Set `status: \"complete\"` in config.json\n6. **Final JSONL entry**: `{\"type\":\"event\",\"event\":\"synthesis_complete\",\"totalIterations\":N,\"answeredCount\":A,\"totalQuestions\":Q,\"stopReason\":\"converged\"}`\n\n### Progressive vs Final Synthesis\n- If `progressiveSynthesis: true` (default): research/research.md was updated each iteration. Final synthesis is a cleanup pass.\n- If `progressiveSynthesis: false`: research/research.md is created from scratch during synthesis.\n\n---\n\n## 7. PHASE: SAVE\n\n### Purpose\nPreserve research context to memory system.\n\n### Steps\n\n1. **Generate context**: `node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js {spec_folder}`\n2. **No extra indexing step in the live contract**: `generate-context.js` is the supported save boundary for this workflow\n3. **Verify**: Confirm memory/*.md file created with proper anchors\n\n---\n\n## 8. STATE TRANSITIONS\n\n```text\n[INITIALIZED] --> config + strategy + state created\n    |\n[ITERATING] --> agent dispatched, executing research\n    |\n[EVALUATING] --> iteration complete, checking convergence\n    |\n    |-- newInfoRatio >= threshold --> [ITERATING]\n    |-- stuck_count >= stuckThreshold --> [STUCK_RECOVERY]\n    |-- converged or max_iterations --> [SYNTHESIZING]\n\n[STUCK_RECOVERY] --> widen focus, try different approach\n    |\n    |-- recovered (newInfoRatio > 0) --> [ITERATING]\n    |-- still stuck --> [SYNTHESIZING] (gaps documented)\n\n[SYNTHESIZING] --> final research/research.md compilation\n    |\n[SAVING] --> memory context preservation\n    |\n[COMPLETE] --> all artifacts created, loop finished\n```\n\nHook-capable and non-hook runtimes must follow the same state machine. Hooks may pre-prime context, but they must not change which lifecycle branch the packet selects.\n\n---\n\n## 9. ERROR HANDLING\n\n| Error | Phase | Action |\n|-------|-------|--------|\n| Agent dispatch timeout | Loop | Retry once with reduced scope. If second timeout, mark iteration as \"timeout\" and continue |\n| WebFetch fails | Loop | Log URL in iteration file, try alternative source, continue with available data |\n| State file missing | Init/Loop | If JSONL missing: re-initialize. If strategy missing: reconstruct from JSONL |\n| JSONL malformed | Loop | Skip malformed lines, reconstruct from valid entries |\n| 3+ consecutive failures | Loop | Halt loop, enter synthesis with partial findings |\n| Agent dispatch failure (API overload, timeout) | Loop | Escalate through the documented recovery ladder in order. Direct mode fallback is reference-only unless the runtime explicitly supports it. |\n| Memory save fails | Save | Preserve the current `{artifact_dir}` packet as backup, then log the error |\n\n### State Recovery Protocol\n\nWhen state files are missing or corrupted, apply this 5-priority cascade:\n\n| Priority | Condition | Recovery Action |\n|----------|-----------|----------------|\n| 1 (Primary) | JSONL exists and parseable | Normal operation (with fault-tolerant parsing) |\n| 2 (Strategy rebuild) | JSONL exists, strategy.md missing | Reconstruct strategy from JSONL: extract questions, focus areas, newInfoRatio trend. Create minimal strategy.md |\n| 3 (JSONL reconstruction) | JSONL missing/corrupt, iteration files exist | Scan `research/iterations/iteration-*.md`, parse Assessment sections, reconstruct JSONL with `status: \"reconstructed\"` |\n| 4 (Config-only restart) | Only config.json remains | Restart from initialization phase using config parameters. Log: `{\"type\":\"event\",\"event\":\"fresh_restart\",\"reason\":\"state_files_missing\"}` |\n| 5 (Abort) | Config.json also missing | Cannot recover. Report error and halt. |\n\nEach priority level is attempted in order. If a level fails, fall through to the next. See state_format.md for JSONL reconstruction details.\n\n---\n\n## 10. CONFIRM MODE ADDITIONS\n\nIn confirm mode, the YAML workflow adds approval gates:\n\n| Gate Location | Behavior |\n|---------------|----------|\n| After initialization | Show config and initial strategy. Wait for approval |\n| After each iteration | Show iteration findings and convergence status. Options: Continue, Adjust Focus, Stop |\n| Before synthesis | Show summary of all iterations. Wait for approval to synthesize |\n| After synthesis | Show final research/research.md summary. Approve or request revisions |\n\n---\n\n## 11. REVIEW MODE ROUTING\n\nDeep-review lifecycle, convergence, state schemas, traceability protocols, and report contracts live in the sibling `deep-review` skill.\n\nThis reference keeps only the routing rule: do not document or execute review-mode loop behavior from `deep-research`. Route review requests to `deep-review/SKILL.md` and its references.","lineStart":1,"lineEnd":646,"totalLines":646,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/references/protocol/loop_protocol.md","time":{"start":1783486572795,"end":1783486572808}},"metadata":{"openai":{"itemId":"fc_004a99ebed27f485016a4dd86cb71081919b0b9259d1182cb3"}},"id":"prt_f401568f8001iJHUkDFUX1oDKR","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40153b91001UQnxJNHI78P6Ce"}}
{"type":"tool_use","timestamp":1783486572865,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_ZKUkf1sQoLUzLGyc2513s3OZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Convergence Detection Reference\n3: description: Live stop contract and navigation hub for deep-research convergence.\n4: trigger_phrases:\n5:   - \"research convergence detection\"\n6:   - \"research stop contract\"\n7:   - \"research stopreason values\"\n8:   - \"research legal stop gates\"\n9:   - \"research convergence decision order\"\n10: importance_tier: important\n11: contextType: implementation\n12: version: 1.14.0.20\n13: ---\n14: \n15: # Convergence Detection Reference\n16: \n17: Live stop-contract hub for deep-research convergence and routed convergence references.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: ### Purpose\n24: \n25: Keep the executable deep-research stop contract short enough to load during routing while pointing detailed signal, recovery, and graph behavior to focused references.\n26: \n27: ### When to Use\n28: \n29: Load this hub when deciding whether a deep-research loop should continue, recover, or stop.\n30: \n31: ### Key Sources\n32: \n33: - Command syntax: `.opencode/commands/deep/research.md`\n34: - Workflow algorithm: `.opencode/commands/deep/assets/deep_research_auto.yaml` and `_confirm.yaml`\n35: - Signal details: `references/convergence/convergence_signals.md`\n36: - Recovery details: `references/convergence/convergence_recovery.md`\n37: - Graph stop gates: `references/convergence/convergence_graph.md`\n38: \n39: For iterative code review convergence, use `deep-review`. Review-mode algorithms and state are not part of the deep-research live contract.\n40: \n41: ### Live Decision Model\n42: \n43: Convergence decides whether the loop should continue, recover from a stuck state, or stop. A STOP candidate is not legal until the legal-stop gate bundle passes. Novelty math can nominate STOP; gates authorize it.\n44: \n45: The live deep-research algorithm evaluates:\n46: \n47: | Stage | Outcome |\n48: |-------|---------|\n49: | Hard stops | Stop on max iterations or all key questions answered |\n50: | Stuck detection | Enter recovery after configured consecutive no-progress iterations |\n51: | Composite convergence | Nominate STOP when weighted signal score is above `0.60` |\n52: | Legal-stop gates | Allow or block the STOP candidate |\n53: | Graph gates | Add STOP-blocking graph checks when `graphEvents` exist |\n54: \n55: ---\n56: \n57: ## 2. STOP CONTRACT\n58: \n59: ### stopReason Values\n60: \n61: | Value | When It Is Used |\n62: |-------|-----------------|\n63: | `converged` | Legal-stop gates passed and the loop may exit normally |\n64: | `maxIterationsReached` | The loop hit the configured iteration cap |\n65: | `userPaused` | A pause sentinel or equivalent user pause request halted execution |\n66: | `blockedStop` | A STOP candidate was blocked by legal-stop or graph gates |\n67: | `stuckRecovery` | Stuck detection triggered or failed recovery |\n68: | `error` | The loop hit an unrecoverable workflow or state error |\n69: \n70: ### Legacy Stop Labels\n71: \n72: Legacy labels are normalized before persistence:\n73: \n74: | Legacy label or phrase | New `stopReason` |\n75: |------------------------|------------------|\n76: | `composite_converged` | `converged` |\n77: | `novelty below threshold` | `converged` |\n78: | `all_questions_answered` | `converged` |\n79: | `max_iterations_reached` | `maxIterationsReached` |\n80: | `paused` | `userPaused` |\n81: | `stuck_detected` | `stuckRecovery` |\n82: | `stuck_unrecoverable` | `stuckRecovery` |\n83: \n84: ---\n85: \n86: ## 3. LIVE ALGORITHM\n87: \n88: ### Decision Order\n89: \n90: ```text\n91: 1. If iteration count >= maxIterations, STOP with maxIterationsReached.\n92: 2. If all key questions have evidence-backed answers, nominate STOP.\n93: 3. If stuckCount >= stuckThreshold, enter stuck recovery.\n94: 4. Compute composite convergence signals.\n95: 5. If weighted stop score > 0.60, nominate STOP.\n96: 6. Evaluate legal-stop gates for every STOP candidate except hard max-iteration stop.\n97: 7. If graphEvents exist, evaluate graph-aware STOP blockers.\n98: 8. If gates pass, STOP; otherwise emit blockedStop and CONTINUE with recovery focus.\n99: ```\n100: \n101: ### Composite Signal Weights\n102: \n103: | Signal | Weight | Min Iterations | Measures |\n104: |--------|--------|----------------|----------|\n105: | Rolling Average | `0.30` | 3 evidence iterations | Recent information yield |\n106: | MAD Noise Floor | `0.35` | 4 evidence iterations | Signal vs noise in `newInfoRatio` |\n107: | Question Entropy | `0.35` | 1 key question | Evidence-backed question coverage |\n108: \n109: The weighted stop score is normalized over active signals. STOP is nominated only when the normalized score is greater than `0.60`. See `convergence_signals.md` for exact signal rules and reporting.\n110: \n111: ---\n112: \n113: ## 4. LEGAL STOP GATES\n114: \n115: Every non-terminal STOP candidate must pass the gate bundle before the workflow exits.\n116: \n117: | Gate | Rule | Failure |\n118: |------|------|---------|\n119: | Convergence Gate | Low novelty holds for the required consecutive evidence iterations | Emit `blocked_stop`, continue |\n120: | Coverage Gate | Every key question has an evidence-backed answer | Emit `blocked_stop`, continue |\n121: | Quality Gate | Source diversity, focus alignment, and no single weak-source dominance pass | Emit `blocked_stop`, continue |\n122: | Graph Gate | When graph data exists, graph coverage has no STOP blockers | Emit `graph_convergence`/`blocked_stop`, continue |\n123: \n124: The reducer surfaces legal-stop evidence through the findings registry and dashboard. The JSONL event shapes live in `../state/state_jsonl.md`.\n125: \n126: ---\n127: \n128: ## 5. ROUTED REFERENCES\n129: \n130: | Resource | Use When |\n131: |----------|----------|\n132: | `convergence_signals.md` | Need scoring, `newInfoRatio`, `stuckCount`, MAD, entropy, report fields, or threshold tuning |\n133: | `convergence_recovery.md` | Need stuck recovery, recovery strategy selection, tiered errors, or escalation behavior |\n134: | `convergence_graph.md` | Need graph-aware STOP gates, graph convergence events, or coverage graph fallback behavior |\n135: | `convergence_reference_only.md` | Need future/reference-only models such as segment filtering, semantic convergence, or optimizer metadata |\n136: | `../state/state_jsonl.md` | Need JSONL event shapes persisted by the convergence workflow |\n137: | `../state/state_reducer_registry.md` | Need reducer-owned registry/dashboard fields derived from convergence |\n138: \n139: ---\n140: \n141: ## 6. NON-GOALS\n142: \n143: - Do not copy `deep-review` convergence into this skill. Use the `deep-review` references for severity-weighted review convergence.\n144: - Do not treat reference-only semantic or segment models as executable contracts.\n145: - Do not change the YAML workflow by editing this document. This document describes and routes the live contract; workflow changes require command/YAML work.\n\n(End of file - total 145 lines)\n</content>","metadata":{"preview":"---\ntitle: Convergence Detection Reference\ndescription: Live stop contract and navigation hub for deep-research convergence.\ntrigger_phrases:\n  - \"research convergence detection\"\n  - \"research stop contract\"\n  - \"research stopreason values\"\n  - \"research legal stop gates\"\n  - \"research convergence decision order\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.14.0.20\n---\n\n# Convergence Detection Reference\n\nLive stop-contract hub for deep-research convergence and routed convergence references.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md","text":"---\ntitle: Convergence Detection Reference\ndescription: Live stop contract and navigation hub for deep-research convergence.\ntrigger_phrases:\n  - \"research convergence detection\"\n  - \"research stop contract\"\n  - \"research stopreason values\"\n  - \"research legal stop gates\"\n  - \"research convergence decision order\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.14.0.20\n---\n\n# Convergence Detection Reference\n\nLive stop-contract hub for deep-research convergence and routed convergence references.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nKeep the executable deep-research stop contract short enough to load during routing while pointing detailed signal, recovery, and graph behavior to focused references.\n\n### When to Use\n\nLoad this hub when deciding whether a deep-research loop should continue, recover, or stop.\n\n### Key Sources\n\n- Command syntax: `.opencode/commands/deep/research.md`\n- Workflow algorithm: `.opencode/commands/deep/assets/deep_research_auto.yaml` and `_confirm.yaml`\n- Signal details: `references/convergence/convergence_signals.md`\n- Recovery details: `references/convergence/convergence_recovery.md`\n- Graph stop gates: `references/convergence/convergence_graph.md`\n\nFor iterative code review convergence, use `deep-review`. Review-mode algorithms and state are not part of the deep-research live contract.\n\n### Live Decision Model\n\nConvergence decides whether the loop should continue, recover from a stuck state, or stop. A STOP candidate is not legal until the legal-stop gate bundle passes. Novelty math can nominate STOP; gates authorize it.\n\nThe live deep-research algorithm evaluates:\n\n| Stage | Outcome |\n|-------|---------|\n| Hard stops | Stop on max iterations or all key questions answered |\n| Stuck detection | Enter recovery after configured consecutive no-progress iterations |\n| Composite convergence | Nominate STOP when weighted signal score is above `0.60` |\n| Legal-stop gates | Allow or block the STOP candidate |\n| Graph gates | Add STOP-blocking graph checks when `graphEvents` exist |\n\n---\n\n## 2. STOP CONTRACT\n\n### stopReason Values\n\n| Value | When It Is Used |\n|-------|-----------------|\n| `converged` | Legal-stop gates passed and the loop may exit normally |\n| `maxIterationsReached` | The loop hit the configured iteration cap |\n| `userPaused` | A pause sentinel or equivalent user pause request halted execution |\n| `blockedStop` | A STOP candidate was blocked by legal-stop or graph gates |\n| `stuckRecovery` | Stuck detection triggered or failed recovery |\n| `error` | The loop hit an unrecoverable workflow or state error |\n\n### Legacy Stop Labels\n\nLegacy labels are normalized before persistence:\n\n| Legacy label or phrase | New `stopReason` |\n|------------------------|------------------|\n| `composite_converged` | `converged` |\n| `novelty below threshold` | `converged` |\n| `all_questions_answered` | `converged` |\n| `max_iterations_reached` | `maxIterationsReached` |\n| `paused` | `userPaused` |\n| `stuck_detected` | `stuckRecovery` |\n| `stuck_unrecoverable` | `stuckRecovery` |\n\n---\n\n## 3. LIVE ALGORITHM\n\n### Decision Order\n\n```text\n1. If iteration count >= maxIterations, STOP with maxIterationsReached.\n2. If all key questions have evidence-backed answers, nominate STOP.\n3. If stuckCount >= stuckThreshold, enter stuck recovery.\n4. Compute composite convergence signals.\n5. If weighted stop score > 0.60, nominate STOP.\n6. Evaluate legal-stop gates for every STOP candidate except hard max-iteration stop.\n7. If graphEvents exist, evaluate graph-aware STOP blockers.\n8. If gates pass, STOP; otherwise emit blockedStop and CONTINUE with recovery focus.\n```\n\n### Composite Signal Weights\n\n| Signal | Weight | Min Iterations | Measures |\n|--------|--------|----------------|----------|\n| Rolling Average | `0.30` | 3 evidence iterations | Recent information yield |\n| MAD Noise Floor | `0.35` | 4 evidence iterations | Signal vs noise in `newInfoRatio` |\n| Question Entropy | `0.35` | 1 key question | Evidence-backed question coverage |\n\nThe weighted stop score is normalized over active signals. STOP is nominated only when the normalized score is greater than `0.60`. See `convergence_signals.md` for exact signal rules and reporting.\n\n---\n\n## 4. LEGAL STOP GATES\n\nEvery non-terminal STOP candidate must pass the gate bundle before the workflow exits.\n\n| Gate | Rule | Failure |\n|------|------|---------|\n| Convergence Gate | Low novelty holds for the required consecutive evidence iterations | Emit `blocked_stop`, continue |\n| Coverage Gate | Every key question has an evidence-backed answer | Emit `blocked_stop`, continue |\n| Quality Gate | Source diversity, focus alignment, and no single weak-source dominance pass | Emit `blocked_stop`, continue |\n| Graph Gate | When graph data exists, graph coverage has no STOP blockers | Emit `graph_convergence`/`blocked_stop`, continue |\n\nThe reducer surfaces legal-stop evidence through the findings registry and dashboard. The JSONL event shapes live in `../state/state_jsonl.md`.\n\n---\n\n## 5. ROUTED REFERENCES\n\n| Resource | Use When |\n|----------|----------|\n| `convergence_signals.md` | Need scoring, `newInfoRatio`, `stuckCount`, MAD, entropy, report fields, or threshold tuning |\n| `convergence_recovery.md` | Need stuck recovery, recovery strategy selection, tiered errors, or escalation behavior |\n| `convergence_graph.md` | Need graph-aware STOP gates, graph convergence events, or coverage graph fallback behavior |\n| `convergence_reference_only.md` | Need future/reference-only models such as segment filtering, semantic convergence, or optimizer metadata |\n| `../state/state_jsonl.md` | Need JSONL event shapes persisted by the convergence workflow |\n| `../state/state_reducer_registry.md` | Need reducer-owned registry/dashboard fields derived from convergence |\n\n---\n\n## 6. NON-GOALS\n\n- Do not copy `deep-review` convergence into this skill. Use the `deep-review` references for severity-weighted review convergence.\n- Do not treat reference-only semantic or segment models as executable contracts.\n- Do not change the YAML workflow by editing this document. This document describes and routes the live contract; workflow changes require command/YAML work.","lineStart":1,"lineEnd":145,"totalLines":145,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/references/convergence/convergence.md","time":{"start":1783486572848,"end":1783486572860}},"metadata":{"openai":{"itemId":"fc_004a99ebed27f485016a4dd86cb720819186674cd75e611e3a"}},"id":"prt_f4015692e001sx29ZlFYHYG4wi","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40153b91001UQnxJNHI78P6Ce"}}
{"type":"tool_use","timestamp":1783486572865,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_fIDvyEG2ycRtJVl0sranMJ8s","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Research Output Files Reference\n3: description: Markdown output structures for strategy, iterations, dashboard, synthesis, and resource-map artifacts.\n4: trigger_phrases:\n5:   - \"research output files\"\n6:   - \"research iteration files\"\n7:   - \"research synthesis document\"\n8:   - \"research resource map\"\n9:   - \"research strategy file\"\n10:   - \"spec anchoring output\"\n11: importance_tier: normal\n12: contextType: implementation\n13: version: 1.14.0.3\n14: ---\n15: \n16: # Deep Research Output Files Reference\n17: \n18: This reference covers human-readable packet outputs. JSONL records live in `state_jsonl.md`; reducer ownership lives in `state_reducer_registry.md`.\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: ### Purpose\n25: \n26: Define the human-readable deep-research packet outputs: strategy, iteration markdown, synthesis, dashboard, resource map, and bounded spec anchoring.\n27: \n28: ### When to Use\n29: \n30: Load this reference when writing or validating markdown outputs rather than JSONL records.\n31: \n32: ### Core Principle\n33: \n34: Human-readable outputs must stay synchronized with raw state and respect reducer ownership.\n35: \n36: ---\n37: \n38: ## 2. STRATEGY FILE\n39: \n40: `deep-research-strategy.md` is the persistent research plan. The reducer owns machine-managed sections.\n41: \n42: Required sections:\n43: \n44: - Research Topic\n45: - Known Context\n46: - Key Questions\n47: - Answered Questions\n48: - What Worked\n49: - What Failed\n50: - Exhausted Approaches\n51: - Ruled-Out Directions\n52: - Next Focus\n53: \n54: Update protocol:\n55: \n56: - read strategy before each iteration;\n57: - choose one focus from `Next Focus`;\n58: - append what worked, failed, and was ruled out;\n59: - update answered/open questions through reducer-owned sections;\n60: - when a STOP candidate is blocked, override `Next Focus` with the blocker recovery focus.\n61: \n62: ---\n63: \n64: ## 3. ITERATION FILES\n65: \n66: Iteration files are write-once markdown narratives.\n67: \n68: ```text\n69: research/iterations/iteration-001.md\n70: research/iterations/iteration-002.md\n71: research/iterations/iteration-003.md\n72: ```\n73: \n74: Required shape:\n75: \n76: | Markdown Element | Required Content |\n77: |------------------|------------------|\n78: | H1 title | `Iteration N: Focus Area` |\n79: | `Focus` section | What this iteration investigated |\n80: | `Findings` section | Evidence-backed findings with source citations |\n81: | `Sources Consulted` section | Files, URLs, memory hits, or commands used |\n82: | `Assessment` section | `newInfoRatio`, novelty justification, and confidence notes |\n83: | `Reflection` section | What worked, failed, or was ruled out |\n84: | `Recommended Next Focus` section | One concrete next focus |\n85: \n86: Every finding must cite a source such as `[SOURCE: file:path:line]` or `[SOURCE: https://example.test]`.\n87: \n88: ---\n89: \n90: ## 4. RESEARCH SYNTHESIS\n91: \n92: `research.md` is the workflow-owned synthesis output at `{artifact_dir}/research.md`.\n93: \n94: Rules:\n95: \n96: - progressive synthesis may update the file during the loop;\n97: - final synthesis consolidates duplicate findings and unresolved gaps;\n98: - prior findings are not silently overwritten;\n99: - generated or machine-owned sections must be marked explicitly when the workflow uses them;\n100: - when `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References.\n101: \n102: ---\n103: \n104: ## 5. DASHBOARD\n105: \n106: `deep-research-dashboard.md` is auto-generated from JSONL, strategy, and registry state.\n107: \n108: Expected sections:\n109: \n110: | Section | Source |\n111: |---------|--------|\n112: | Iteration Table | JSONL iteration records |\n113: | Question Status | Strategy + registry |\n114: | Convergence Trend | `convergenceSignals` + reducer |\n115: | Dead Ends | JSONL `ruledOut` + strategy |\n116: | Blocked Stops | Registry blocked-stop history |\n117: | Graph Convergence | Graph convergence registry fields |\n118: | Next Focus | Strategy |\n119: \n120: Generation rules:\n121: \n122: - regenerate after each iteration evaluation;\n123: - compute derived values from raw state;\n124: - overwrite the full dashboard rather than appending;\n125: - if state is missing, write a minimal \"No iteration data available\" dashboard;\n126: - agent writes are discarded on next refresh.\n127: \n128: ---\n129: \n130: ## 6. RESOURCE MAP\n131: \n132: When `{spec_folder}/resource-map.md` exists at init:\n133: \n134: - persist `resource_map_present: true` in config;\n135: - summarize section counts and themes into strategy `Known Context`;\n136: - treat listed files as known inventory, not net-new discoveries;\n137: - cite the map in final synthesis references;\n138: - emit `{artifact_dir}/resource-map.md` from converged deltas unless disabled.\n139: \n140: When absent:\n141: \n142: - persist `resource_map_present: false`;\n143: - write `resource-map.md not present; skipping coverage gate` into `Known Context`;\n144: - continue normally.\n145: \n146: ---\n147: \n148: ## 7. SPEC ANCHORING OUTPUT\n149: \n150: `references/protocol/spec_check_protocol.md` defines bounded `spec.md` writes:\n151: \n152: - acquire `research/.deep-research.lock`;\n153: - classify `folder_state`;\n154: - seed or append bounded context during init when allowed;\n155: - replace exactly one generated findings fence during synthesis.\n156: \n157: This output path is protocol-owned, not iteration-agent owned.\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Research Output Files Reference\ndescription: Markdown output structures for strategy, iterations, dashboard, synthesis, and resource-map artifacts.\ntrigger_phrases:\n  - \"research output files\"\n  - \"research iteration files\"\n  - \"research synthesis document\"\n  - \"research resource map\"\n  - \"research strategy file\"\n  - \"spec anchoring output\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.14.0.3\n---\n\n# Deep Research Output Files Reference\n\nThis reference covers human-readable packet outputs. JSONL records live in `state_jsonl.md`; reducer ownership lives in `state_reducer_registry.md`.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md","text":"---\ntitle: Deep Research Output Files Reference\ndescription: Markdown output structures for strategy, iterations, dashboard, synthesis, and resource-map artifacts.\ntrigger_phrases:\n  - \"research output files\"\n  - \"research iteration files\"\n  - \"research synthesis document\"\n  - \"research resource map\"\n  - \"research strategy file\"\n  - \"spec anchoring output\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.14.0.3\n---\n\n# Deep Research Output Files Reference\n\nThis reference covers human-readable packet outputs. JSONL records live in `state_jsonl.md`; reducer ownership lives in `state_reducer_registry.md`.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nDefine the human-readable deep-research packet outputs: strategy, iteration markdown, synthesis, dashboard, resource map, and bounded spec anchoring.\n\n### When to Use\n\nLoad this reference when writing or validating markdown outputs rather than JSONL records.\n\n### Core Principle\n\nHuman-readable outputs must stay synchronized with raw state and respect reducer ownership.\n\n---\n\n## 2. STRATEGY FILE\n\n`deep-research-strategy.md` is the persistent research plan. The reducer owns machine-managed sections.\n\nRequired sections:\n\n- Research Topic\n- Known Context\n- Key Questions\n- Answered Questions\n- What Worked\n- What Failed\n- Exhausted Approaches\n- Ruled-Out Directions\n- Next Focus\n\nUpdate protocol:\n\n- read strategy before each iteration;\n- choose one focus from `Next Focus`;\n- append what worked, failed, and was ruled out;\n- update answered/open questions through reducer-owned sections;\n- when a STOP candidate is blocked, override `Next Focus` with the blocker recovery focus.\n\n---\n\n## 3. ITERATION FILES\n\nIteration files are write-once markdown narratives.\n\n```text\nresearch/iterations/iteration-001.md\nresearch/iterations/iteration-002.md\nresearch/iterations/iteration-003.md\n```\n\nRequired shape:\n\n| Markdown Element | Required Content |\n|------------------|------------------|\n| H1 title | `Iteration N: Focus Area` |\n| `Focus` section | What this iteration investigated |\n| `Findings` section | Evidence-backed findings with source citations |\n| `Sources Consulted` section | Files, URLs, memory hits, or commands used |\n| `Assessment` section | `newInfoRatio`, novelty justification, and confidence notes |\n| `Reflection` section | What worked, failed, or was ruled out |\n| `Recommended Next Focus` section | One concrete next focus |\n\nEvery finding must cite a source such as `[SOURCE: file:path:line]` or `[SOURCE: https://example.test]`.\n\n---\n\n## 4. RESEARCH SYNTHESIS\n\n`research.md` is the workflow-owned synthesis output at `{artifact_dir}/research.md`.\n\nRules:\n\n- progressive synthesis may update the file during the loop;\n- final synthesis consolidates duplicate findings and unresolved gaps;\n- prior findings are not silently overwritten;\n- generated or machine-owned sections must be marked explicitly when the workflow uses them;\n- when `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References.\n\n---\n\n## 5. DASHBOARD\n\n`deep-research-dashboard.md` is auto-generated from JSONL, strategy, and registry state.\n\nExpected sections:\n\n| Section | Source |\n|---------|--------|\n| Iteration Table | JSONL iteration records |\n| Question Status | Strategy + registry |\n| Convergence Trend | `convergenceSignals` + reducer |\n| Dead Ends | JSONL `ruledOut` + strategy |\n| Blocked Stops | Registry blocked-stop history |\n| Graph Convergence | Graph convergence registry fields |\n| Next Focus | Strategy |\n\nGeneration rules:\n\n- regenerate after each iteration evaluation;\n- compute derived values from raw state;\n- overwrite the full dashboard rather than appending;\n- if state is missing, write a minimal \"No iteration data available\" dashboard;\n- agent writes are discarded on next refresh.\n\n---\n\n## 6. RESOURCE MAP\n\nWhen `{spec_folder}/resource-map.md` exists at init:\n\n- persist `resource_map_present: true` in config;\n- summarize section counts and themes into strategy `Known Context`;\n- treat listed files as known inventory, not net-new discoveries;\n- cite the map in final synthesis references;\n- emit `{artifact_dir}/resource-map.md` from converged deltas unless disabled.\n\nWhen absent:\n\n- persist `resource_map_present: false`;\n- write `resource-map.md not present; skipping coverage gate` into `Known Context`;\n- continue normally.\n\n---\n\n## 7. SPEC ANCHORING OUTPUT\n\n`references/protocol/spec_check_protocol.md` defines bounded `spec.md` writes:\n\n- acquire `research/.deep-research.lock`;\n- classify `folder_state`;\n- seed or append bounded context during init when allowed;\n- replace exactly one generated findings fence during synthesis.\n\nThis output path is protocol-owned, not iteration-agent owned.","lineStart":1,"lineEnd":157,"totalLines":157,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/references/state/state_outputs.md","time":{"start":1783486572843,"end":1783486572862}},"metadata":{"openai":{"itemId":"fc_004a99ebed27f485016a4dd86cb71c8191aeacb8fbe8277a13"}},"id":"prt_f4015691b0015K3rGRoFjuYwaP","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40153b91001UQnxJNHI78P6Ce"}}
{"type":"tool_use","timestamp":1783486572865,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_GaGzJ1fLbhRMrD6jwwd1plBe","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: State Format Reference\n3: description: Live state packet hub for the deep-research loop.\n4: trigger_phrases:\n5:   - \"research state format\"\n6:   - \"research state packet hub\"\n7:   - \"research file ownership model\"\n8:   - \"research file protection rules\"\n9:   - \"research packet location\"\n10: importance_tier: important\n11: contextType: implementation\n12: version: 1.14.0.29\n13: ---\n14: \n15: # State Format Reference\n16: \n17: Live state packet hub for deep-research files, mutability, and routed state references.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: ### Purpose\n24: \n25: Summarize the live deep-research packet files, mutability rules, and focused state references without carrying every JSON shape inline.\n26: \n27: ### When to Use\n28: \n29: Load this hub when navigating packet files, deciding file ownership, or choosing which detailed state reference to load next.\n30: \n31: ### Routed Details\n32: \n33: - `state_jsonl.md` for config, iteration, event, lifecycle, graph, and blocked-stop records.\n34: - `state_outputs.md` for strategy, iteration markdown, `research.md`, dashboard, and resource-map output.\n35: - `state_reducer_registry.md` for reducer ownership, findings registry, validation, reconstruction, and file protection.\n36: \n37: For iterative code review state, use `deep-review`. Review-mode state is not part of this skill's live state contract.\n38: \n39: ### Packet Summary\n40: \n41: The deep-research loop persists continuity in packet files so each iteration can run with fresh context.\n42: \n43: | File | Format | Purpose | Mutability |\n44: |------|--------|---------|------------|\n45: | `deep-research-config.json` | JSON | Loop parameters and lineage | Created at init; read-only after |\n46: | `deep-research-state.jsonl` | JSONL | Append-only structured log | Append-only |\n47: | `deep-research-strategy.md` | Markdown | Current research plan and next focus | Reducer-managed sections |\n48: | `deep-research-findings-registry.json` / `findings-registry.json` | JSON | Reducer-owned findings and question state | Auto-generated |\n49: | `deep-research-dashboard.md` | Markdown | Operator summary | Auto-generated |\n50: | `iterations/iteration-NNN.md` | Markdown | Per-iteration narrative | Write-once |\n51: | `deltas/iter-NNN.jsonl` | JSONL | Per-iteration structured delta | Write-once |\n52: | `research.md` | Markdown | Final/progressive synthesis | Workflow-owned |\n53: | `resource-map.md` | Markdown | Optional evidence-derived resource map | Workflow-owned |\n54: \n55: The artifact directory is resolved by `resolveArtifactRoot(specFolder, 'research')` from `.opencode/skills/system-spec-kit/shared/review-research-paths.cjs`.\n56: \n57: ---\n58: \n59: ## 2. PACKET LOCATION\n60: \n61: Root specs use:\n62: \n63: ```text\n64: {spec_folder}/research/\n65: ```\n66: \n67: Child-phase and sub-phase targets use flat-first behavior:\n68: \n69: - first run with an empty local `research/` directory writes flat at `{spec_folder}/research/`;\n70: - a `{basename(spec_folder)}-pt-NN` subfolder is allocated only when prior content already exists for a non-matching target;\n71: - continuation runs reuse the existing matching packet.\n72: \n73: This avoids an unnecessary `pt-01` wrapper on first runs.\n74: \n75: ---\n76: \n77: ## 3. OWNERSHIP MODEL\n78: \n79: | Owner | Writes |\n80: |-------|--------|\n81: | Agent iteration | `iterations/iteration-NNN.md`, JSONL iteration/event append, optional progressive synthesis contribution |\n82: | Workflow reducer | strategy machine-owned sections, findings registry, dashboard |\n83: | Workflow synthesis | `research.md`, lifecycle snapshots |\n84: | Spec anchoring protocol | bounded `spec.md` seed/context/fenced findings block |\n85: \n86: The reducer is the source of truth for derived state. Manual edits to reducer-owned outputs are overwritten on the next refresh.\n87: \n88: ---\n89: \n90: ## 4. FILE PROTECTION\n91: \n92: | Protection | Meaning |\n93: |------------|---------|\n94: | `immutable` | Created once and not modified after init |\n95: | `append-only` | New JSONL records may be appended; existing records are not rewritten |\n96: | `write-once` | Each iteration artifact is created once |\n97: | `mutable` | Workflow may update the file under defined ownership rules |\n98: | `auto-generated` | Reducer/workflow regenerates the full file |\n99: \n100: The config file carries the protection map; details live in `state_reducer_registry.md`.\n101: \n102: ---\n103: \n104: ## 5. ROUTED REFERENCES\n105: \n106: | Resource | Use When |\n107: |----------|----------|\n108: | `state_jsonl.md` | Need the JSONL config, iteration, event, lineage, graph, or blocked-stop schemas |\n109: | `state_outputs.md` | Need markdown output structure for strategy, iterations, dashboard, research synthesis, or resource map |\n110: | `state_reducer_registry.md` | Need reducer ownership, registry schema, validation, fault tolerance, or reconstruction |\n111: | `../convergence/convergence.md` | Need STOP contract and legal-stop semantics |\n112: | `../protocol/spec_check_protocol.md` | Need bounded `spec.md` anchoring and generated-fence write-back |\n113: \n114: ---\n115: \n116: ## 6. NON-GOALS\n117: \n118: - Do not document `deep-review` state here; route to the sibling skill.\n119: - Do not treat legacy aliases as write targets. The workflow reads legacy aliases only for migration windows and writes canonical `deep-research-*` names.\n120: - Do not manually edit reducer-owned dashboard or registry files.\n\n(End of file - total 120 lines)\n</content>","metadata":{"preview":"---\ntitle: State Format Reference\ndescription: Live state packet hub for the deep-research loop.\ntrigger_phrases:\n  - \"research state format\"\n  - \"research state packet hub\"\n  - \"research file ownership model\"\n  - \"research file protection rules\"\n  - \"research packet location\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.14.0.29\n---\n\n# State Format Reference\n\nLive state packet hub for deep-research files, mutability, and routed state references.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md","text":"---\ntitle: State Format Reference\ndescription: Live state packet hub for the deep-research loop.\ntrigger_phrases:\n  - \"research state format\"\n  - \"research state packet hub\"\n  - \"research file ownership model\"\n  - \"research file protection rules\"\n  - \"research packet location\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.14.0.29\n---\n\n# State Format Reference\n\nLive state packet hub for deep-research files, mutability, and routed state references.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nSummarize the live deep-research packet files, mutability rules, and focused state references without carrying every JSON shape inline.\n\n### When to Use\n\nLoad this hub when navigating packet files, deciding file ownership, or choosing which detailed state reference to load next.\n\n### Routed Details\n\n- `state_jsonl.md` for config, iteration, event, lifecycle, graph, and blocked-stop records.\n- `state_outputs.md` for strategy, iteration markdown, `research.md`, dashboard, and resource-map output.\n- `state_reducer_registry.md` for reducer ownership, findings registry, validation, reconstruction, and file protection.\n\nFor iterative code review state, use `deep-review`. Review-mode state is not part of this skill's live state contract.\n\n### Packet Summary\n\nThe deep-research loop persists continuity in packet files so each iteration can run with fresh context.\n\n| File | Format | Purpose | Mutability |\n|------|--------|---------|------------|\n| `deep-research-config.json` | JSON | Loop parameters and lineage | Created at init; read-only after |\n| `deep-research-state.jsonl` | JSONL | Append-only structured log | Append-only |\n| `deep-research-strategy.md` | Markdown | Current research plan and next focus | Reducer-managed sections |\n| `deep-research-findings-registry.json` / `findings-registry.json` | JSON | Reducer-owned findings and question state | Auto-generated |\n| `deep-research-dashboard.md` | Markdown | Operator summary | Auto-generated |\n| `iterations/iteration-NNN.md` | Markdown | Per-iteration narrative | Write-once |\n| `deltas/iter-NNN.jsonl` | JSONL | Per-iteration structured delta | Write-once |\n| `research.md` | Markdown | Final/progressive synthesis | Workflow-owned |\n| `resource-map.md` | Markdown | Optional evidence-derived resource map | Workflow-owned |\n\nThe artifact directory is resolved by `resolveArtifactRoot(specFolder, 'research')` from `.opencode/skills/system-spec-kit/shared/review-research-paths.cjs`.\n\n---\n\n## 2. PACKET LOCATION\n\nRoot specs use:\n\n```text\n{spec_folder}/research/\n```\n\nChild-phase and sub-phase targets use flat-first behavior:\n\n- first run with an empty local `research/` directory writes flat at `{spec_folder}/research/`;\n- a `{basename(spec_folder)}-pt-NN` subfolder is allocated only when prior content already exists for a non-matching target;\n- continuation runs reuse the existing matching packet.\n\nThis avoids an unnecessary `pt-01` wrapper on first runs.\n\n---\n\n## 3. OWNERSHIP MODEL\n\n| Owner | Writes |\n|-------|--------|\n| Agent iteration | `iterations/iteration-NNN.md`, JSONL iteration/event append, optional progressive synthesis contribution |\n| Workflow reducer | strategy machine-owned sections, findings registry, dashboard |\n| Workflow synthesis | `research.md`, lifecycle snapshots |\n| Spec anchoring protocol | bounded `spec.md` seed/context/fenced findings block |\n\nThe reducer is the source of truth for derived state. Manual edits to reducer-owned outputs are overwritten on the next refresh.\n\n---\n\n## 4. FILE PROTECTION\n\n| Protection | Meaning |\n|------------|---------|\n| `immutable` | Created once and not modified after init |\n| `append-only` | New JSONL records may be appended; existing records are not rewritten |\n| `write-once` | Each iteration artifact is created once |\n| `mutable` | Workflow may update the file under defined ownership rules |\n| `auto-generated` | Reducer/workflow regenerates the full file |\n\nThe config file carries the protection map; details live in `state_reducer_registry.md`.\n\n---\n\n## 5. ROUTED REFERENCES\n\n| Resource | Use When |\n|----------|----------|\n| `state_jsonl.md` | Need the JSONL config, iteration, event, lineage, graph, or blocked-stop schemas |\n| `state_outputs.md` | Need markdown output structure for strategy, iterations, dashboard, research synthesis, or resource map |\n| `state_reducer_registry.md` | Need reducer ownership, registry schema, validation, fault tolerance, or reconstruction |\n| `../convergence/convergence.md` | Need STOP contract and legal-stop semantics |\n| `../protocol/spec_check_protocol.md` | Need bounded `spec.md` anchoring and generated-fence write-back |\n\n---\n\n## 6. NON-GOALS\n\n- Do not document `deep-review` state here; route to the sibling skill.\n- Do not treat legacy aliases as write targets. The workflow reads legacy aliases only for migration windows and writes canonical `deep-research-*` names.\n- Do not manually edit reducer-owned dashboard or registry files.","lineStart":1,"lineEnd":120,"totalLines":120,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/references/state/state_format.md","time":{"start":1783486572825,"end":1783486572863}},"metadata":{"openai":{"itemId":"fc_004a99ebed27f485016a4dd86cb71481919c036625ba8cfa97"}},"id":"prt_f4015690d001uofuiM4pGXkUJ4","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40153b91001UQnxJNHI78P6Ce"}}
{"type":"step_finish","timestamp":1783486573211,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"id":"prt_f40156a99001KeMxAny7PFo79d","reason":"tool-calls","snapshot":"ca3af0d0e38d0513011331c6581b57000b4b4d2c","messageID":"msg_f40153b91001UQnxJNHI78P6Ce","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","type":"step-finish","tokens":{"total":39943,"input":10773,"output":423,"reasoning":75,"cache":{"write":0,"read":28672}},"cost":0}}
{"type":"step_start","timestamp":1783486574465,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"id":"prt_f40156f80001Vlghjft2Vu7IhF","messageID":"msg_f40156be30015xKmGAeLFLa3KG","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","snapshot":"ca3af0d0e38d0513011331c6581b57000b4b4d2c","type":"step-start"}}
{"type":"tool_use","timestamp":1783486581275,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_vUxz9m64uwltlnqdJy7X1iSK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":737,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n737:             values:\n738:               - \"{next_focus}\"\n739:               - \"{remaining_questions_list}\"\n740:               - \"{carried_forward_open_questions}\"\n741:           recovery:\n742:             category: \"recovery\"\n743:             values:\n744:               - \"{recovery_strategy}\"\n745:               - \"{least_explored}\"\n746:           ideas:\n747:             category: \"ideas\"\n748:             values:\n749:               - \"{promoted_ideas_list}\"\n750:             optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n751:         algorithm: |\n752:           Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n753:           reducer pass as the source of truth.\n754:           Compare normalized exact text first. Then compare fuzzy similarity with\n755:           rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n756:           are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n757:           selection before rendering the dispatch prompt. If all candidates are suppressed,\n758:           halt for operator input instead of reusing a rejected idea.\n759:         outputs:\n760:           - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n761:           - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n762:           - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n763:           - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n764:         if_next_focus_suppressed:\n765:           set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n766:           log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n767:         if_all_candidates_suppressed:\n768:           halt: true\n769:           message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n770: \n771:       step_ideas_backlog_lifecycle:\n772:         action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n773:         read:\n774:           - \"{state_paths.state_log}\"\n775:           - \"{state_paths.registry}\"\n776:           - \"{state_paths.config}\"\n777:         lifecycle:\n778:           observed_event: \"idea_observed\"\n779:           promoted_event: \"idea_promoted\"\n780:           rejected_event: \"idea_rejected\"\n781:           min_observations: \"{min_idea_observations}\"\n782:           authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n783:         validate:\n784:           - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n785:           - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n786:           - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n787:         outputs:\n788:           - observed_ideas_count: \"Reducer-derived observed ideas count\"\n789:           - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n790:           - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n791:           - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n792: \n793:       step_normalize_pause_events:\n794:         action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n795:         stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n796:         rule_pause_sentinel:\n797:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n798:           canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n799:         rule_stuck_recovery:\n800:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n801:           canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n802: \n803:       step_marker_scan:\n804:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n805:         algorithm: |\n806:           if current_iteration > 1:\n807:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n808:             if file_exists(PREV_PROMPT_PATH):\n809:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n810:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n811:                 log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n812:                 halt with exit code 2\n813:         note: |\n814:           False-positive prevention: only matches when the first line is exactly one of the\n815:           three canonical markers. Markers appearing in comments or body text are ignored.\n816:           True-positive triggers only when a previous iteration's rendered prompt literally\n817:           starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n818: \n819:       step_dispatch_iteration:\n820:         action: \"Dispatch one iteration via the selected executor\"\n821:         resolve_executor:\n822:           source: \"config.executor\"\n823:           loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n824:         pre_dispatch:\n825:           generate_summary: |\n826:             STATE SUMMARY (auto-generated):\n827:             Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n828:             Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n829:             Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n830:             {resource_map_prompt_line}\n831:             {memory_context_prompt_line}\n832:             Next focus: {next_focus}\n833:           render_prompt_pack:\n834:             template_path: \".opencode/skills/deep-loop-workflows/deep-research/assets/prompt_pack_iteration.md.tmpl\"\n835:             renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n836:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n837:             variables:\n838:               state_summary: \"{state_summary}\"\n839:               research_topic: \"{research_topic}\"\n840:               current_iteration: \"{current_iteration}\"\n841:               max_iterations: \"{max_iterations}\"\n842:               next_focus: \"{next_focus}\"\n843:               remaining_questions_list: \"{remaining_questions_list}\"\n844:               carried_forward_open_questions: \"{carried_forward_open_questions}\"\n845:               last_3_summaries: \"{last_3_summaries}\"\n846:               state_paths_config: \"{state_paths.config}\"\n847:               state_paths_state_log: \"{state_paths.state_log}\"\n848:               state_paths_strategy: \"{state_paths.strategy}\"\n849:               state_paths_registry: \"{state_paths.registry}\"\n850:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n851:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n852:         pre_dispatch_audit:\n853:           skip_when: \"config.executor.type == 'native'\"\n854:           call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n855:           args:\n856:             stateLogPath: \"{state_paths.state_log}\"\n857:             executor: \"{config.executor}\"\n858:             iteration: \"{current_iteration}\"\n859:         branch_on: \"config.executor.type\"\n860:         if_native:\n861:           dispatch:\n862:             agent: deep-research\n863:             model: opus\n864:             context_source: \"rendered_prompt_pack\"\n865:           wait_for_completion: true\n866:         if_cli_claude_code:\n867:           command: |\n868:             node --experimental-strip-types --input-type=module <<'EOF'\n869:             import { readFileSync } from 'node:fs';\n870:             import { createHash } from 'node:crypto';\n871: \n872:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n873:             import { resolveClaudePermissionMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n874: \n875:             const executor = {\n876:               kind: 'cli-claude-code',\n877:               model: '{config.executor.model}',\n878:               reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n879:               serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n880:               sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n881:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n882:             };\n883:             const args = [\n884:               '-p',\n885:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n886:               '--model',\n887:               executor.model,\n888:               '--permission-mode',\n889:               resolveClaudePermissionMode(executor.sandboxMode),\n890:               '--output-format',\n891:               'text',\n892:             ];\n893:             if (executor.reasoningEffort) {\n894:               args.push('--effort', executor.reasoningEffort);\n895:             }\n896: \n897:             const dispatchFacts = {\n898:               command: 'deep/research',\n899:               mode: 'research',\n900:               specFolder: '{spec_folder}',\n901:               artifactDir: '{state_paths.packet_dir}',\n902:               iteration: Number('{current_iteration}'),\n903:               executorKind: '{config.executor.type}',\n904:               branchId: '{config.executor.type}',\n905:               sessionId: '{config.lineage.sessionId}',\n906:               generation: Number('{config.lineage.generation}'),\n907:             };\n908:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n909:             process.exit(\n910:               runAuditedExecutorCommand({\n911:                 command: 'claude',\n912:                 args,\n913:                 cwd: '{repo_root}',\n914:                 timeoutSeconds: executor.timeoutSeconds,\n915:                 stateLogPath: '{state_paths.state_log}',\n916:                 executor,\n917:                 iteration: Number('{current_iteration}'),\n918:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n919:                 dispatchId,\n920:               }),\n921:             );\n922:             EOF\n923:           working_directory: \"{repo_root}\"\n924:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n925:           wait_for_completion: true\n926:           notes:\n927:             - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n928:             - \"claude-code has no serviceTier flag\"\n929:             - \"claude-code supports --effort for reasoning depth\"\n930:         record_executor_audit:\n931:           skip_when: \"config.executor.type == 'native'\"\n932:           target: \"{state_paths.state_log}\"\n933:           field: \"executor\"\n934:           value:\n935:             kind: \"{config.executor.type}\"\n936:             model: \"{config.executor.model}\"\n937:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n938:             serviceTier: \"{config.executor.serviceTier}\"\n939:         if_cli_opencode:\n940:           command: |\n941:             node --experimental-strip-types --input-type=module <<'EOF'\n942:             import { readFileSync } from 'node:fs';\n943:             import { createHash } from 'node:crypto';\n944: \n945:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n946: \n947:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n948:             const executor = {\n949:               kind: 'cli-opencode',\n950:               model: '{config.executor.model}',\n951:               configDir: null,\n952:               reasoningEffort,\n953:               serviceTier: null,\n954:               sandboxMode: null,\n955:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n956:               governor: null,\n957:             };\n958:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n959:             const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n960:               + '\\n\\n'\n961:               + promptBody;\n962:             const args = [\n963:               'run',\n964:               '--model',\n965:               executor.model,\n966:               '--format',\n967:               'json',\n968:               '--dangerously-skip-permissions',\n969:               '--pure',\n970:               '--dir',\n971:               '{repo_root}',\n972:             ];\n973:             if (executor.reasoningEffort) {\n974:               args.push('--variant', executor.reasoningEffort);\n975:             }\n976:             args.push(message);\n977: \n978:             const dispatchFacts = {\n979:               command: 'deep/research',\n980:               mode: 'research',\n981:               specFolder: '{spec_folder}',\n982:               artifactDir: '{state_paths.packet_dir}',\n983:               iteration: Number('{current_iteration}'),\n984:               executorKind: '{config.executor.type}',\n985:               branchId: '{config.executor.type}',\n986:               sessionId: '{config.lineage.sessionId}',\n987:               generation: Number('{config.lineage.generation}'),\n988:             };\n989:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n990:             process.exit(\n991:               runAuditedExecutorCommand({\n992:                 command: 'opencode',\n993:                 args,\n994:                 cwd: '{repo_root}',\n995:                 timeoutSeconds: executor.timeoutSeconds,\n996:                 stateLogPath: '{state_paths.state_log}',\n997:                 executor,\n998:                 iteration: Number('{current_iteration}'),\n999:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1000:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1001:                 input: '',\n1002:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1003:                 dispatchId,\n1004:               }),\n1005:             );\n1006:             EOF\n1007:           working_directory: \"{repo_root}\"\n1008:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1009:           wait_for_completion: true\n1010:           notes:\n1011:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1012:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (cli-opencode SKILL.md §4 ALWAYS rule)\"\n1013:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1014:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1015:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1016:             - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1017:         post_dispatch_validate:\n1018:           validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1019:           command: \"node .opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1020:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1021:           assert_exists: \"{state_paths.iteration_pattern}\"\n1022:           assert_appended: \"{state_paths.state_log}\"\n1023:           assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n1024:           route_proof:\n1025:             mode: research\n1026:             target_agent: deep-research\n1027:             agent_definition_loaded: true\n1028:             resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n1029:           dispatchReceipt:\n1030:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1031:             dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n1032:           optional_jsonl_fields:\n1033:             logOffset: \"Byte offset where the seekable log region starts\"\n1034:             logSize: \"Byte length of the seekable log region\"\n1035:             logPath: \"Absolute path to the file containing the seekable log region\"\n1036:             skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n1037:             slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n1038:           assert_canonical_type: \"iteration\"\n1039:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1040:           assert_delta_file_has_iteration_record: true\n1041:           on_failure:\n1042:             action: \"emit schema_mismatch canonical conflict event\"\n1043:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n1044:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1045:           failure_reasons_reference:\n1046:             - \"iteration_file_missing — iteration narrative markdown not written\"\n1047:             - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n1048:             - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n1049:             - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n1050:             - \"jsonl_parse_error — last state-log line is not valid JSON\"\n1051:             - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n1052:             - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n1053:             - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n1054:             - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n1055:             - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n1056:             - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n1057:             - \"executor_missing — non-native executor did not record provenance\"\n1058:             - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n1059: \n1060:       step_run_now_restore_check:\n1061:         action: \"Record a run-now sentinel recreated during the completed dispatch\"\n1062:         command: |\n1063:           node <<'EOF'\n1064:           const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n1065: \n1066:           const stateLogPath = \"{state_paths.state_log}\";\n1067:           const sentinelPath = \"{state_paths.run_now_sentinel}\";\n1068:           const timestamp = \"{ISO_8601_NOW}\";\n1069:           const sessionId = \"{config.lineage.sessionId}\";\n1070:           const generation = Number(\"{config.lineage.generation}\");\n1071:           const run = Number(\"{current_iteration}\");\n1072: \n1073:           function hasAcceptedCurrentRun() {\n1074:             if (!existsSync(stateLogPath)) return false;\n1075:             const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n1076:             for (let index = lines.length - 1; index >= 0; index -= 1) {\n1077:               const record = JSON.parse(lines[index]);\n1078:               if (record.run !== run || record.sessionId !== sessionId) continue;\n1079:               if (record.event === \"run_now_accepted\") return true;\n1080:               if (record.event === \"run_now_rejected\") return false;\n1081:             }\n1082:             return false;\n1083:           }\n1084: \n1085:           if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n1086:             appendFileSync(\n1087:               stateLogPath,\n1088:               `${JSON.stringify({\n1089:                 type: \"event\",\n1090:                 event: \"run_now_restored\",\n1091:                 mode: \"research\",\n1092:                 run,\n1093:                 sentinelPath,\n1094:                 timestamp,\n1095:                 sessionId,\n1096:                 generation,\n1097:               })}\\n`,\n1098:               \"utf8\",\n1099:             );\n1100:           }\n1101:           EOF\n1102:         outputs:\n1103:           - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n1104: \n1105:       step_reduce_state:\n1106:         action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n1107:         command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n1108:         inputs:\n1109:           latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n1110:           newIterationFile: \"{state_paths.iteration_pattern}\"\n1111:           priorReducedState: \"{state_paths.registry}\"\n1112:         outputs:\n1113:           - \"{state_paths.registry}\"\n1114:           - \"{state_paths.dashboard}\"\n1115:           - \"{state_paths.strategy}\"\n1116:           - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n1117:           - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n1118:           - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n1119:         failure_modes:\n1120:           malformed_delta: \"skip + warn\"\n1121:           missing_iteration_file: \"no-op + error\"\n1122:           schema_mismatch: \"reject + conflict event\"\n1123:           question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n1124:         guarantee: \"Idempotent for identical inputs\"\n1125: \n1126:       step_graph_upsert:\n1127:         action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n1128:         read:\n1129:           - \"{state_paths.state_log}\"\n1130:         extract:\n1131:           - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n1132:           - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n1133:           - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n1134:           - graph_upsert_event_count: \"Count mapped node and edge events\"\n1135:         if_graph_events_present:\n1136:           bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n1137:           note: \"Skip silently when graphEvents is missing or empty.\"\n1138:         if_graph_events_missing:\n1139:           proceed: true\n1140: \n1141:       step_memory_upsert_iteration:\n1142:         action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n1143:         mcp_tool: memory_save\n1144:         invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n1145:         timeout_seconds: 5\n1146:         idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n1147:         failure_policy:\n1148:           mcp_error: \"non-fatal; log advisory warning and continue\"\n1149:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n1150:         outputs:\n1151:           - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n1152:           - memory_upsert_status: \"upserted | advisory_error\"\n1153: \n1154:       step_refresh_memory_context:\n1155:         action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n1156:         mcp_tool: memory_context\n1157:         invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n1158:         timeout_seconds: 5\n1159:         use_response:\n1160:           - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n1161:         failure_policy:\n1162:           mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n1163:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n1164:         outputs:\n1165:           - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n1166:           - memory_context_refresh_status: \"refreshed | advisory_error\"\n1167: \n1168:       step_evaluate_results:\n1169:         action: \"Verify iteration outputs and extract metrics\"\n1170:         verify:\n1171:           - file_exists: \"{state_paths.iteration_pattern}\"\n1172:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1173:           - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n1174:           - registry_updated: \"Reducer refreshed deep-research-findings-registry.json\"\n1175:         extract:\n1176:           - newInfoRatio: \"From latest JSONL iteration record\"\n1177:           - findings_count: \"From latest JSONL iteration record\"\n1178:           - status: \"From latest JSONL iteration record\"\n1179:           - latest_focus: \"From latest JSONL iteration record\"\n1180:         on_missing_outputs:\n1181:           action: \"Mark iteration as 'error', continue to next\"\n1182:           # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n1183:           # so the reducer can persist the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1184:           append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n1185: \n1186:       step_telemetry_heartbeat_progress:\n1187:         action: \"Emit a single-loop progress row when iteration state changes\"\n1188:         skip_when: \"config.fanout is present\"\n1189:         command: |\n1190:           node --experimental-strip-types --input-type=module <<'EOF'\n1191:           import { existsSync, readFileSync } from 'node:fs';\n1192: \n1193:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n1194:           import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n1195: \n1196:           const { appendObservabilityEvent } = observabilityEvents;\n1197:           const stateLogPath = '{state_paths.state_log}';\n1198:           const timestamp = '{ISO_8601_NOW}';\n1199:           const sessionId = '{config.lineage.sessionId}';\n1200:           const generation = Number('{config.lineage.generation}');\n1201:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1202: \n1203:           function readRecords(path) {\n1204:             if (!existsSync(path)) return [];\n1205:             return readFileSync(path, 'utf8')\n1206:               .split(/\\r?\\n/)\n1207:               .map((line) => line.trim())\n1208:               .filter(Boolean)\n1209:               .map((line) => JSON.parse(line));\n1210:           }\n1211: \n1212:           function elapsedSince(value) {\n1213:             const startedAtMs = Date.parse(String(value ?? ''));\n1214:             const nowMs = Date.parse(timestamp);\n1215:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1216:             return Math.max(0, nowMs - startedAtMs);\n1217:           }\n1218: \n1219:           const records = readRecords(stateLogPath);\n1220:           const iterations = records.filter((record) => record.type === 'iteration');\n1221:           const latest = iterations.at(-1) ?? {};\n1222:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1223:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1224:             ?? timestamp;\n1225:           const elapsedMs = elapsedSince(startedAt);\n1226:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1227:           const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n1228:           const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n1229:           const row = {\n1230:             event: 'progress',\n1231:             label: 'single',\n1232:             at: timestamp,\n1233:             duration_ms: elapsedMs,\n1234:             loop_type: 'research',\n1235:             sessionId,\n1236:             generation,\n1237:             run,\n1238:             status,\n1239:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1240:           };\n1241: \n1242:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1243:             diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n1244:             diffField: 'state_hash',\n1245:           });\n1246:           if (appended) {\n1247:             try {\n1248:               appendObservabilityEvent(observabilityPath, row, {\n1249:                 producer: 'deep-research-auto',\n1250:                 stream: 'single-loop-telemetry',\n1251:                 subject: { label: row.label, sessionId, generation, run },\n1252:                 event: row.event,\n1253:                 status,\n1254:               });\n1255:             } catch {}\n1256:           }\n1257:           EOF\n1258:         working_directory: \"{repo_root}\"\n1259:         outputs:\n1260:           - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n1261: \n1262:       step_generate_dashboard:\n1263:         action: \"Generate or refresh the human-readable dashboard\"\n1264:         read:\n1265:           - \"{state_paths.state_log}\"\n1266:           - \"{state_paths.registry}\"\n1267:           - \"{state_paths.strategy}\"\n1268:         template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_dashboard.md\n1269:         output: \"{state_paths.dashboard}\"\n1270:         note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n1271: \n1272:       step_update_tracking:\n1273:         action: \"Update loop tracking variables\"\n1274:         set:\n1275:           current_iteration: \"{current_iteration + 1}\"\n1276:           stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n1277:         log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n1278: \n1279:       step_loop_decision:\n1280:         action: \"Return to step_read_state for next iteration\"\n1281:         goto: step_read_state\n1282: \n1283:   # ═══════════════════════════════════════════════════════════════\n1284:   # PHASE 3: SYNTHESIS\n1285:   # ═══════════════════════════════════════════════════════════════\n1286:   phase_synthesis:\n1287:     purpose: Compile all iteration findings into final research/research.md\n1288:     steps:\n1289: \n1290:       step_fanout_merge:\n1291:         description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n1292:         skip_when: \"config.fanout is absent\"\n1293:         command: |\n1294:           node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n1295:             --loop-type research \\\n1296:             --artifact-dir {artifact_dir}\n1297:         working_directory: \"{repo_root}\"\n1298:         wait_for_completion: true\n1299: \n1300:       step_hydrate_summary_metrics:\n1301:         action: \"Hydrate summary metrics before synthesis\"\n1302:         read:\n1303:           - \"{state_paths.config}\"\n1304:           - \"{state_paths.state_log}\"\n1305:           - \"{state_paths.registry}\"\n1306:           - \"{state_paths.strategy}\"\n1307:         extract:\n1308:           - iteration_count: \"Count lines where type === 'iteration'\"\n1309:           - current_iteration: \"iteration_count + 1\"\n1310:           - current_segment: \"Latest segment_start event segment, else 1\"\n1311:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n1312:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n1313:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n1314:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n1315:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n1316:           - answered_count: \"Count answered questions from strategy.md\"\n1317:           - total_questions: \"Count total questions tracked in strategy.md\"\n1318:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n1319:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1320: \n1321:       step_read_all_iterations:\n1322:         action: \"Read all iteration files and strategy\"\n1323:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1324:         read_also: \"{state_paths.strategy}\"\n1325: \n1326:       step_emit_resource_map:\n1327:         action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n1328:         command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1329:         read:\n1330:           - \"{state_paths.config}\"\n1331:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1332:         write:\n1333:           - \"{state_paths.resource_map_output}\"\n1334:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1335: \n1336:       step_compile_research:\n1337:         action: \"Compile or finalize research/research.md\"\n1338:         instructions: |\n1339:           If research/research.md exists (progressive synthesis was active):\n1340:             1. Read current research/research.md\n1341:             2. Consolidate and deduplicate findings across all iterations\n1342:             3. Fill any empty sections with findings from iteration files\n1343:             4. Remove redundancy while preserving all unique findings\n1344:             5. Add convergence report as appendix\n1345:             6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1346: \n1347:           If research/research.md does not exist:\n1348:             1. Create research/research.md following 17-section template\n1349:             2. Populate sections from iteration files\n1350:             3. Add citations from original sources\n1351:             4. Note unanswered questions in Open Questions section\n1352:             5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1353:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n1354:         output: \"{state_paths.research_output}\"\n1355: \n1356:       step_convergence_report:\n1357:         action: \"Generate and append convergence report\"\n1358:         report: |\n1359:           ## Convergence Report\n1360:           - Stop reason: {reason}\n1361:           - Total iterations: {iteration_count}\n1362:           - Questions answered: {answered_count} / {total_questions}\n1363:           - Remaining questions: {remaining_questions}\n1364:           - Last 3 iteration summaries: {last_3_summaries}\n1365:           - Convergence threshold: {convergence_threshold}\n1366:           - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n1367:         command: |\n1368:           node --input-type=module <<'EOF'\n1369:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1370: \n1371:           const paths = {\n1372:             stateLog: String.raw`{state_paths.state_log}`,\n1373:             registry: String.raw`{state_paths.registry}`,\n1374:             research: String.raw`{state_paths.research_output}`,\n1375:             dashboard: String.raw`{state_paths.dashboard}`,\n1376:           };\n1377: \n1378:           function hasFile(filePath) {\n1379:             try {\n1380:               return existsSync(filePath) && statSync(filePath).isFile();\n1381:             } catch {\n1382:               return false;\n1383:             }\n1384:           }\n1385: \n1386:           function readJson(filePath) {\n1387:             try {\n1388:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1389:             } catch {\n1390:               return null;\n1391:             }\n1392:           }\n1393: \n1394:           function readJsonl(filePath) {\n1395:             if (!hasFile(filePath)) return [];\n1396:             return readFileSync(filePath, 'utf8')\n1397:               .split(/\\r?\\n/)\n1398:               .map((line) => line.trim())\n1399:               .filter(Boolean)\n1400:               .flatMap((line) => {\n1401:                 try {\n1402:                   return [JSON.parse(line)];\n1403:                 } catch {\n1404:                   return [];\n1405:                 }\n1406:               });\n1407:           }\n1408: \n1409:           function countIterationFindings(record) {\n1410:             if (!record || record.type !== 'iteration') return 0;\n1411:             const numeric = Number(record.findingsCount);\n1412:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1413:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1414:             if (Array.isArray(record.findings)) return record.findings.length;\n1415:             return 0;\n1416:           }\n1417: \n1418:           function normalizeFindingKey(value) {\n1419:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1420:           }\n1421: \n1422:           function findingKeys(candidate) {\n1423:             if (typeof candidate === 'string') {\n1424:               const key = normalizeFindingKey(candidate);\n1425:               return key ? [key] : [];\n1426:             }\n1427:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1428:             return [...new Set([\n1429:               candidate.id,\n1430:               candidate.title,\n1431:               candidate.summary,\n1432:               candidate.text,\n1433:               candidate.finding,\n1434:               candidate.description,\n1435:             ].map(normalizeFindingKey).filter(Boolean))];\n1436:           }\n\n(Showing lines 737-1436 of 1740. Use offset=1437 to continue.)\n</content>","metadata":{"preview":"            values:\n              - \"{next_focus}\"\n              - \"{remaining_questions_list}\"\n              - \"{carried_forward_open_questions}\"\n          recovery:\n            category: \"recovery\"\n            values:\n              - \"{recovery_strategy}\"\n              - \"{least_explored}\"\n          ideas:\n            category: \"ideas\"\n            values:\n              - \"{promoted_ideas_list}\"\n            optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n        algorithm: |\n          Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n          reducer pass as the source of truth.\n          Compare normalized exact text first. Then compare fuzzy similarity with\n          rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n          are compatible. Remove suppressed candidates from next_focus, recovery, and ideas","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"            values:\n              - \"{next_focus}\"\n              - \"{remaining_questions_list}\"\n              - \"{carried_forward_open_questions}\"\n          recovery:\n            category: \"recovery\"\n            values:\n              - \"{recovery_strategy}\"\n              - \"{least_explored}\"\n          ideas:\n            category: \"ideas\"\n            values:\n              - \"{promoted_ideas_list}\"\n            optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n        algorithm: |\n          Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n          reducer pass as the source of truth.\n          Compare normalized exact text first. Then compare fuzzy similarity with\n          rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n          are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n          selection before rendering the dispatch prompt. If all candidates are suppressed,\n          halt for operator input instead of reusing a rejected idea.\n        outputs:\n          - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n          - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n          - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n          - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n        if_next_focus_suppressed:\n          set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n          log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n        if_all_candidates_suppressed:\n          halt: true\n          message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n\n      step_ideas_backlog_lifecycle:\n        action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.config}\"\n        lifecycle:\n          observed_event: \"idea_observed\"\n          promoted_event: \"idea_promoted\"\n          rejected_event: \"idea_rejected\"\n          min_observations: \"{min_idea_observations}\"\n          authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n        validate:\n          - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n          - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n          - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n        outputs:\n          - observed_ideas_count: \"Reducer-derived observed ideas count\"\n          - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n          - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n          - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n\n      step_normalize_pause_events:\n        action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n        stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n        rule_pause_sentinel:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n        rule_stuck_recovery:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch one iteration via the selected executor\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n            Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n            {resource_map_prompt_line}\n            {memory_context_prompt_line}\n            Next focus: {next_focus}\n          render_prompt_pack:\n            template_path: \".opencode/skills/deep-loop-workflows/deep-research/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              research_topic: \"{research_topic}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_focus: \"{next_focus}\"\n              remaining_questions_list: \"{remaining_questions_list}\"\n              carried_forward_open_questions: \"{carried_forward_open_questions}\"\n              last_3_summaries: \"{last_3_summaries}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_registry: \"{state_paths.registry}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.type\"\n        if_native:\n          dispatch:\n            agent: deep-research\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n            import { resolveClaudePermissionMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n              serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n              sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              resolveClaudePermissionMode(executor.sandboxMode),\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n            - \"claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        record_executor_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.type}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (cli-opencode SKILL.md §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n          route_proof:\n            mode: research\n            target_agent: deep-research\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n          optional_jsonl_fields:\n            logOffset: \"Byte offset where the seekable log region starts\"\n            logSize: \"Byte length of the seekable log region\"\n            logPath: \"Absolute path to the file containing the seekable log region\"\n            skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n            slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n          failure_reasons_reference:\n            - \"iteration_file_missing — iteration narrative markdown not written\"\n            - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n            - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n            - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n            - \"jsonl_parse_error — last state-log line is not valid JSON\"\n            - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n            - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n            - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n            - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n            - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n            - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n            - \"executor_missing — non-native executor did not record provenance\"\n            - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n\n      step_run_now_restore_check:\n        action: \"Record a run-now sentinel recreated during the completed dispatch\"\n        command: |\n          node <<'EOF'\n          const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n\n          const stateLogPath = \"{state_paths.state_log}\";\n          const sentinelPath = \"{state_paths.run_now_sentinel}\";\n          const timestamp = \"{ISO_8601_NOW}\";\n          const sessionId = \"{config.lineage.sessionId}\";\n          const generation = Number(\"{config.lineage.generation}\");\n          const run = Number(\"{current_iteration}\");\n\n          function hasAcceptedCurrentRun() {\n            if (!existsSync(stateLogPath)) return false;\n            const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n            for (let index = lines.length - 1; index >= 0; index -= 1) {\n              const record = JSON.parse(lines[index]);\n              if (record.run !== run || record.sessionId !== sessionId) continue;\n              if (record.event === \"run_now_accepted\") return true;\n              if (record.event === \"run_now_rejected\") return false;\n            }\n            return false;\n          }\n\n          if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n            appendFileSync(\n              stateLogPath,\n              `${JSON.stringify({\n                type: \"event\",\n                event: \"run_now_restored\",\n                mode: \"research\",\n                run,\n                sentinelPath,\n                timestamp,\n                sessionId,\n                generation,\n              })}\\n`,\n              \"utf8\",\n            );\n          }\n          EOF\n        outputs:\n          - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n\n      step_reduce_state:\n        action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n        inputs:\n          latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n          newIterationFile: \"{state_paths.iteration_pattern}\"\n          priorReducedState: \"{state_paths.registry}\"\n        outputs:\n          - \"{state_paths.registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n          - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n          - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n          question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n        guarantee: \"Idempotent for identical inputs\"\n\n      step_graph_upsert:\n        action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n        read:\n          - \"{state_paths.state_log}\"\n        extract:\n          - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n          - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n          - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n          - graph_upsert_event_count: \"Count mapped node and edge events\"\n        if_graph_events_present:\n          bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n          note: \"Skip silently when graphEvents is missing or empty.\"\n        if_graph_events_missing:\n          proceed: true\n\n      step_memory_upsert_iteration:\n        action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n        timeout_seconds: 5\n        idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n        outputs:\n          - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n          - memory_upsert_status: \"upserted | advisory_error\"\n\n      step_refresh_memory_context:\n        action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n        mcp_tool: memory_context\n        invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n        timeout_seconds: 5\n        use_response:\n          - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n        outputs:\n          - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n          - memory_context_refresh_status: \"refreshed | advisory_error\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n          - registry_updated: \"Reducer refreshed deep-research-findings-registry.json\"\n        extract:\n          - newInfoRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - latest_focus: \"From latest JSONL iteration record\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n          # so the reducer can persist the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_telemetry_heartbeat_progress:\n        action: \"Emit a single-loop progress row when iteration state changes\"\n        skip_when: \"config.fanout is present\"\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = '{config.lineage.sessionId}';\n          const generation = Number('{config.lineage.generation}');\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n          const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n          const row = {\n            event: 'progress',\n            label: 'single',\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            run,\n            status,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, run },\n                event: row.event,\n                status,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the human-readable dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_dashboard.md\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n        log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into final research/research.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n            --loop-type research \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_compile_research:\n        action: \"Compile or finalize research/research.md\"\n        instructions: |\n          If research/research.md exists (progressive synthesis was active):\n            1. Read current research/research.md\n            2. Consolidate and deduplicate findings across all iterations\n            3. Fill any empty sections with findings from iteration files\n            4. Remove redundancy while preserving all unique findings\n            5. Add convergence report as appendix\n            6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n\n          If research/research.md does not exist:\n            1. Create research/research.md following 17-section template\n            2. Populate sections from iteration files\n            3. Add citations from original sources\n            4. Note unanswered questions in Open Questions section\n            5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n        output: \"{state_paths.research_output}\"\n\n      step_convergence_report:\n        action: \"Generate and append convergence report\"\n        report: |\n          ## Convergence Report\n          - Stop reason: {reason}\n          - Total iterations: {iteration_count}\n          - Questions answered: {answered_count} / {total_questions}\n          - Remaining questions: {remaining_questions}\n          - Last 3 iteration summaries: {last_3_summaries}\n          - Convergence threshold: {convergence_threshold}\n          - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.registry}`,\n            research: String.raw`{state_paths.research_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }","lineStart":737,"lineEnd":1436,"totalLines":1740,"truncated":true}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1783486581268,"end":1783486581273}},"metadata":{"openai":{"itemId":"fc_00b09cdc8d1ddb64016a4dd8753d608191bca638aedde140b0"}},"id":"prt_f40158a0c001Jwo0la1ksMICn5","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40156be30015xKmGAeLFLa3KG"}}
{"type":"tool_use","timestamp":1783486581310,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_WqYNPdFpdzXMoHzY6mYOWg4b","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Research JSONL State Reference\n3: description: Config, iteration, event, lineage, graph, and blocked-stop records for deep-research state logs.\n4: trigger_phrases:\n5:   - \"research state jsonl\"\n6:   - \"research config record\"\n7:   - \"research iteration records\"\n8:   - \"research negative knowledge\"\n9:   - \"research graph events\"\n10:   - \"research event records\"\n11: importance_tier: normal\n12: contextType: implementation\n13: version: 1.14.0.3\n14: ---\n15: \n16: # Deep Research JSONL State Reference\n17: \n18: `deep-research-state.jsonl` is append-only. Each line is one JSON object. The first line is normally the config record, followed by iteration and event records.\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: ### Purpose\n25: \n26: Define the append-only JSONL records used by deep-research config, iteration, lifecycle, graph, pause, stuck-recovery, and blocked-stop state.\n27: \n28: ### When to Use\n29: \n30: Load this reference when validating state logs, adding event records, reconstructing a packet, or mapping legacy stop labels to current values.\n31: \n32: ### Core Principle\n33: \n34: Raw JSONL is append-only evidence. Reducer-owned files derive from it, but they do not replace it.\n35: \n36: ---\n37: \n38: ## 2. CONFIG RECORD\n39: \n40: The config record captures the initialized loop contract.\n41: \n42: ```json\n43: {\n44:   \"type\": \"config\",\n45:   \"topic\": \"API response time optimization\",\n46:   \"maxIterations\": 10,\n47:   \"convergenceThreshold\": 0.05,\n48:   \"stuckThreshold\": 3,\n49:   \"specFolder\": \"028-auto-deep-research\",\n50:   \"createdAt\": \"2026-05-24T00:00:00Z\"\n51: }\n52: ```\n53: \n54: The full config file also stores executor, lineage, reducer, capability matrix, pause sentinel, archive, and file-protection settings.\n55: \n56: ---\n57: \n58: ## 3. ITERATION RECORDS\n59: \n60: ```json\n61: {\n62:   \"type\": \"iteration\",\n63:   \"run\": 1,\n64:   \"status\": \"complete\",\n65:   \"focus\": \"Initial broad survey\",\n66:   \"findingsCount\": 5,\n67:   \"newInfoRatio\": 1.0,\n68:   \"noveltyJustification\": \"First pass; all findings are new to this packet\",\n69:   \"keyQuestions\": [\"What causes latency?\"],\n70:   \"answeredQuestions\": [\"What causes latency?\"],\n71:   \"timestamp\": \"2026-05-24T00:05:00Z\",\n72:   \"durationMs\": 45000\n73: }\n74: ```\n75: \n76: | Field | Required | Notes |\n77: |-------|----------|-------|\n78: | `type` | Yes | `iteration` |\n79: | `run` | Yes | 1-indexed iteration number |\n80: | `status` | Yes | See status values below |\n81: | `focus` | Yes | Single focus investigated |\n82: | `findingsCount` | Yes | Number of findings reported |\n83: | `newInfoRatio` | Yes | Novelty score used by convergence |\n84: | `noveltyJustification` | Recommended | One-sentence explanation of the ratio |\n85: | `keyQuestions` | Recommended | Questions considered during this iteration |\n86: | `answeredQuestions` | Recommended | Questions answered by evidence |\n87: | `ruledOut` | Optional | Negative knowledge entries |\n88: | `graphEvents` | Optional | Coverage graph mutations |\n89: \n90: Status values:\n91: \n92: | Status | Meaning |\n93: |--------|---------|\n94: | `complete` | Normal evidence-gathering iteration |\n95: | `timeout` | Time/tool budget exceeded |\n96: | `error` | Tool, parse, or unexpected failure |\n97: | `stuck` | No new information and no clear next direction |\n98: | `insight` | Low ratio but important conceptual breakthrough |\n99: | `thought` | Analytical-only iteration; excluded from stuck and signal math |\n100: \n101: ---\n102: \n103: ## 4. CONVERGENCE SIGNAL FIELDS\n104: \n105: When the composite algorithm runs, the iteration may include signal values:\n106: \n107: ```json\n108: {\n109:   \"type\": \"iteration\",\n110:   \"run\": 5,\n111:   \"convergenceSignals\": {\n112:     \"rollingAvg\": 0.12,\n113:     \"madScore\": 0.08,\n114:     \"entropyCoverage\": 0.71,\n115:     \"compositeStop\": 0.42\n116:   }\n117: }\n118: ```\n119: \n120: Signal rules live in `../convergence/convergence_signals.md`.\n121: \n122: ---\n123: \n124: ## 5. NEGATIVE KNOWLEDGE\n125: \n126: Use `ruledOut` to preserve eliminated approaches.\n127: \n128: ```json\n129: {\n130:   \"type\": \"iteration\",\n131:   \"run\": 3,\n132:   \"status\": \"complete\",\n133:   \"ruledOut\": [\n134:     {\n135:       \"approach\": \"HTTP/3 multiplexing\",\n136:       \"reason\": \"No server-side support in target environment\",\n137:       \"evidence\": \"file:docs/protocols.md:42\"\n138:     }\n139:   ]\n140: }\n141: ```\n142: \n143: Ruled-out directions should also appear in strategy and synthesis outputs.\n144: \n145: ---\n146: \n147: ## 6. GRAPH EVENTS\n148: \n149: `graphEvents` records coverage graph mutations from an iteration.\n150: \n151: ```json\n152: {\n153:   \"type\": \"iteration\",\n154:   \"run\": 4,\n155:   \"graphEvents\": [\n156:     {\"type\": \"question\", \"id\": \"q-reconnect\", \"label\": \"How should reconnect work?\"},\n157:     {\"type\": \"finding\", \"id\": \"f-backoff\", \"label\": \"Exponential backoff is required\"},\n158:     {\"type\": \"edge\", \"from\": \"f-backoff\", \"to\": \"q-reconnect\", \"relation\": \"ANSWERS\"}\n159:   ]\n160: }\n161: ```\n162: \n163: Valid node types are `question`, `finding`, `claim`, and `source`; `edge` records connect nodes. IDs must be unique within a single `(specFolder, loopType, sessionId)` namespace. Reusing the same logical ID across independent sessions is allowed because the coverage graph uses a composite key.\n164: \n165: ---\n166: \n167: ## 7. EVENT RECORDS\n168: \n169: Lifecycle event:\n170: \n171: ```json\n172: {\n173:   \"type\": \"event\",\n174:   \"event\": \"resumed\",\n175:   \"mode\": \"research\",\n176:   \"sessionId\": \"dr-2026-05-24T00-00-00Z\",\n177:   \"parentSessionId\": \"dr-2026-05-24T00-00-00Z\",\n178:   \"lineageMode\": \"resume\",\n179:   \"continuedFromRun\": 4,\n180:   \"generation\": 1,\n181:   \"archivedPath\": null,\n182:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n183: }\n184: ```\n185: \n186: Blocked stop event:\n187: \n188: ```json\n189: {\n190:   \"type\": \"event\",\n191:   \"event\": \"blocked_stop\",\n192:   \"mode\": \"research\",\n193:   \"run\": 7,\n194:   \"stopReason\": \"blockedStop\",\n195:   \"blockedBy\": [\"keyQuestionCoverage\", \"sourceDiversity\"],\n196:   \"recoveryStrategy\": \"focus_pivot\",\n197:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n198: }\n199: ```\n200: \n201: Pause event:\n202: \n203: ```json\n204: {\n205:   \"type\": \"event\",\n206:   \"event\": \"userPaused\",\n207:   \"mode\": \"research\",\n208:   \"run\": 7,\n209:   \"stopReason\": \"userPaused\",\n210:   \"sentinelPath\": \"research/.deep-research-pause\",\n211:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n212: }\n213: ```\n214: \n215: Stuck recovery event:\n216: \n217: ```json\n218: {\n219:   \"type\": \"event\",\n220:   \"event\": \"stuckRecovery\",\n221:   \"mode\": \"research\",\n222:   \"run\": 7,\n223:   \"stopReason\": \"stuckRecovery\",\n224:   \"fromFocus\": \"Connection pooling\",\n225:   \"toFocus\": \"Transport alternatives\",\n226:   \"strategy\": \"try_opposites\",\n227:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n228: }\n229: ```\n230: \n231: Idea observation event:\n232: \n233: ```json\n234: {\n235:   \"type\": \"event\",\n236:   \"event\": \"idea_observed\",\n237:   \"mode\": \"research\",\n238:   \"run\": 7,\n239:   \"ideaId\": \"idea-cache-stampede\",\n240:   \"idea\": \"Investigate cache stampede mitigation as a follow-up focus\",\n241:   \"category\": \"ideas\",\n242:   \"source\": \"iteration-007.md\",\n243:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n244: }\n245: ```\n246: \n247: Leaf agents may append `idea_observed` for promising tangents. They must not append `idea_promoted`; promotion is reducer-owned.\n248: \n249: Idea promotion event:\n250: \n251: ```json\n252: {\n253:   \"type\": \"event\",\n254:   \"event\": \"idea_promoted\",\n255:   \"mode\": \"research\",\n256:   \"run\": 8,\n257:   \"ideaId\": \"idea-cache-stampede\",\n258:   \"idea\": \"Investigate cache stampede mitigation as a follow-up focus\",\n259:   \"category\": \"ideas\",\n260:   \"observationCount\": 2,\n261:   \"minIdeaObservations\": 2,\n262:   \"firstObservedRun\": 6,\n263:   \"lastObservedRun\": 7,\n264:   \"timestamp\": \"2026-05-24T00:02:00Z\"\n265: }\n266: ```\n267: \n268: The reducer emits `idea_promoted` once per idea after replay shows `observationCount >= minIdeaObservations`. `minIdeaObservations` defaults to `2` and is clamped to the inclusive range `1..10`.\n269: \n270: Rejected idea event:\n271: \n272: ```json\n273: {\n274:   \"type\": \"event\",\n275:   \"event\": \"idea_rejected\",\n276:   \"mode\": \"research\",\n277:   \"run\": 7,\n278:   \"ideaId\": \"idea-cache-stampede\",\n279:   \"idea\": \"Investigate cache stampede mitigation as a follow-up focus\",\n280:   \"category\": \"ideas\",\n281:   \"reason\": \"Already rejected by environment evidence\",\n282:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n283: }\n284: ```\n285: \n286: `idea_rejected` durably suppresses the matching promoted idea and also enters the reducer-owned rejected-pattern cache. Use `category: \"general\"` only when the rejection should suppress matching text across next-focus, recovery, and ideas candidates.\n287: \n288: Rejected idea removal event:\n289: \n290: ```json\n291: {\n292:   \"type\": \"event\",\n293:   \"event\": \"ideaRejectedRemoved\",\n294:   \"mode\": \"research\",\n295:   \"pattern\": \"Retry HTTP/3 as the primary latency fix\",\n296:   \"category\": \"next-focus\",\n297:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n298: }\n299: ```\n300: \n301: Rejected idea reset event:\n302: \n303: ```json\n304: {\n305:   \"type\": \"event\",\n306:   \"event\": \"ideaRejectedReset\",\n307:   \"mode\": \"research\",\n308:   \"reason\": \"Operator wants previously rejected ideas eligible again\",\n309:   \"timestamp\": \"2026-05-24T00:00:00Z\"\n310: }\n311: ```\n312: \n313: The reducer derives a bounded active rejected-pattern cache from these events. `idea_rejected` adds or refreshes one pattern, `ideaRejectedRemoved` removes a single matching pattern or id, and `ideaRejectedReset` clears the active cache. Legacy `ideaRejected`, `ideaRejectedRemoved`, and `ideaRejectedReset` rows remain replayable for existing state logs. The active cache is capped at 100 entries; when more are added, the oldest active entry is evicted and the reducer emits a warning.\n314: \n315: Candidate checks compare normalized exact text first, then apply fuzzy matching only when the candidate category is compatible with the rejected category. Omit `category` for a general rejection that can suppress candidates across next-focus, recovery, or ideas surfaces.\n316: \n317: Graph convergence event shape lives in `../convergence/convergence_graph.md`.\n318: \n319: ---\n320: \n321: ## 8. NORMALIZATION\n322: \n323: Emission-time normalization maps legacy labels into canonical `stopReason` values before persistence. The mapping lives in `../convergence/convergence.md`.\n324: \n325: Malformed lines are handled by the reducer according to its strict/lenient mode. Fault tolerance and reconstruction are documented in `state_reducer_registry.md`.\n\n(End of file - total 325 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Research JSONL State Reference\ndescription: Config, iteration, event, lineage, graph, and blocked-stop records for deep-research state logs.\ntrigger_phrases:\n  - \"research state jsonl\"\n  - \"research config record\"\n  - \"research iteration records\"\n  - \"research negative knowledge\"\n  - \"research graph events\"\n  - \"research event records\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.14.0.3\n---\n\n# Deep Research JSONL State Reference\n\n`deep-research-state.jsonl` is append-only. Each line is one JSON object. The first line is normally the config record, followed by iteration and event records.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md","text":"---\ntitle: Deep Research JSONL State Reference\ndescription: Config, iteration, event, lineage, graph, and blocked-stop records for deep-research state logs.\ntrigger_phrases:\n  - \"research state jsonl\"\n  - \"research config record\"\n  - \"research iteration records\"\n  - \"research negative knowledge\"\n  - \"research graph events\"\n  - \"research event records\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.14.0.3\n---\n\n# Deep Research JSONL State Reference\n\n`deep-research-state.jsonl` is append-only. Each line is one JSON object. The first line is normally the config record, followed by iteration and event records.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nDefine the append-only JSONL records used by deep-research config, iteration, lifecycle, graph, pause, stuck-recovery, and blocked-stop state.\n\n### When to Use\n\nLoad this reference when validating state logs, adding event records, reconstructing a packet, or mapping legacy stop labels to current values.\n\n### Core Principle\n\nRaw JSONL is append-only evidence. Reducer-owned files derive from it, but they do not replace it.\n\n---\n\n## 2. CONFIG RECORD\n\nThe config record captures the initialized loop contract.\n\n```json\n{\n  \"type\": \"config\",\n  \"topic\": \"API response time optimization\",\n  \"maxIterations\": 10,\n  \"convergenceThreshold\": 0.05,\n  \"stuckThreshold\": 3,\n  \"specFolder\": \"028-auto-deep-research\",\n  \"createdAt\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nThe full config file also stores executor, lineage, reducer, capability matrix, pause sentinel, archive, and file-protection settings.\n\n---\n\n## 3. ITERATION RECORDS\n\n```json\n{\n  \"type\": \"iteration\",\n  \"run\": 1,\n  \"status\": \"complete\",\n  \"focus\": \"Initial broad survey\",\n  \"findingsCount\": 5,\n  \"newInfoRatio\": 1.0,\n  \"noveltyJustification\": \"First pass; all findings are new to this packet\",\n  \"keyQuestions\": [\"What causes latency?\"],\n  \"answeredQuestions\": [\"What causes latency?\"],\n  \"timestamp\": \"2026-05-24T00:05:00Z\",\n  \"durationMs\": 45000\n}\n```\n\n| Field | Required | Notes |\n|-------|----------|-------|\n| `type` | Yes | `iteration` |\n| `run` | Yes | 1-indexed iteration number |\n| `status` | Yes | See status values below |\n| `focus` | Yes | Single focus investigated |\n| `findingsCount` | Yes | Number of findings reported |\n| `newInfoRatio` | Yes | Novelty score used by convergence |\n| `noveltyJustification` | Recommended | One-sentence explanation of the ratio |\n| `keyQuestions` | Recommended | Questions considered during this iteration |\n| `answeredQuestions` | Recommended | Questions answered by evidence |\n| `ruledOut` | Optional | Negative knowledge entries |\n| `graphEvents` | Optional | Coverage graph mutations |\n\nStatus values:\n\n| Status | Meaning |\n|--------|---------|\n| `complete` | Normal evidence-gathering iteration |\n| `timeout` | Time/tool budget exceeded |\n| `error` | Tool, parse, or unexpected failure |\n| `stuck` | No new information and no clear next direction |\n| `insight` | Low ratio but important conceptual breakthrough |\n| `thought` | Analytical-only iteration; excluded from stuck and signal math |\n\n---\n\n## 4. CONVERGENCE SIGNAL FIELDS\n\nWhen the composite algorithm runs, the iteration may include signal values:\n\n```json\n{\n  \"type\": \"iteration\",\n  \"run\": 5,\n  \"convergenceSignals\": {\n    \"rollingAvg\": 0.12,\n    \"madScore\": 0.08,\n    \"entropyCoverage\": 0.71,\n    \"compositeStop\": 0.42\n  }\n}\n```\n\nSignal rules live in `../convergence/convergence_signals.md`.\n\n---\n\n## 5. NEGATIVE KNOWLEDGE\n\nUse `ruledOut` to preserve eliminated approaches.\n\n```json\n{\n  \"type\": \"iteration\",\n  \"run\": 3,\n  \"status\": \"complete\",\n  \"ruledOut\": [\n    {\n      \"approach\": \"HTTP/3 multiplexing\",\n      \"reason\": \"No server-side support in target environment\",\n      \"evidence\": \"file:docs/protocols.md:42\"\n    }\n  ]\n}\n```\n\nRuled-out directions should also appear in strategy and synthesis outputs.\n\n---\n\n## 6. GRAPH EVENTS\n\n`graphEvents` records coverage graph mutations from an iteration.\n\n```json\n{\n  \"type\": \"iteration\",\n  \"run\": 4,\n  \"graphEvents\": [\n    {\"type\": \"question\", \"id\": \"q-reconnect\", \"label\": \"How should reconnect work?\"},\n    {\"type\": \"finding\", \"id\": \"f-backoff\", \"label\": \"Exponential backoff is required\"},\n    {\"type\": \"edge\", \"from\": \"f-backoff\", \"to\": \"q-reconnect\", \"relation\": \"ANSWERS\"}\n  ]\n}\n```\n\nValid node types are `question`, `finding`, `claim`, and `source`; `edge` records connect nodes. IDs must be unique within a single `(specFolder, loopType, sessionId)` namespace. Reusing the same logical ID across independent sessions is allowed because the coverage graph uses a composite key.\n\n---\n\n## 7. EVENT RECORDS\n\nLifecycle event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"resumed\",\n  \"mode\": \"research\",\n  \"sessionId\": \"dr-2026-05-24T00-00-00Z\",\n  \"parentSessionId\": \"dr-2026-05-24T00-00-00Z\",\n  \"lineageMode\": \"resume\",\n  \"continuedFromRun\": 4,\n  \"generation\": 1,\n  \"archivedPath\": null,\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nBlocked stop event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"blocked_stop\",\n  \"mode\": \"research\",\n  \"run\": 7,\n  \"stopReason\": \"blockedStop\",\n  \"blockedBy\": [\"keyQuestionCoverage\", \"sourceDiversity\"],\n  \"recoveryStrategy\": \"focus_pivot\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nPause event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"userPaused\",\n  \"mode\": \"research\",\n  \"run\": 7,\n  \"stopReason\": \"userPaused\",\n  \"sentinelPath\": \"research/.deep-research-pause\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nStuck recovery event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"stuckRecovery\",\n  \"mode\": \"research\",\n  \"run\": 7,\n  \"stopReason\": \"stuckRecovery\",\n  \"fromFocus\": \"Connection pooling\",\n  \"toFocus\": \"Transport alternatives\",\n  \"strategy\": \"try_opposites\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nIdea observation event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"idea_observed\",\n  \"mode\": \"research\",\n  \"run\": 7,\n  \"ideaId\": \"idea-cache-stampede\",\n  \"idea\": \"Investigate cache stampede mitigation as a follow-up focus\",\n  \"category\": \"ideas\",\n  \"source\": \"iteration-007.md\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nLeaf agents may append `idea_observed` for promising tangents. They must not append `idea_promoted`; promotion is reducer-owned.\n\nIdea promotion event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"idea_promoted\",\n  \"mode\": \"research\",\n  \"run\": 8,\n  \"ideaId\": \"idea-cache-stampede\",\n  \"idea\": \"Investigate cache stampede mitigation as a follow-up focus\",\n  \"category\": \"ideas\",\n  \"observationCount\": 2,\n  \"minIdeaObservations\": 2,\n  \"firstObservedRun\": 6,\n  \"lastObservedRun\": 7,\n  \"timestamp\": \"2026-05-24T00:02:00Z\"\n}\n```\n\nThe reducer emits `idea_promoted` once per idea after replay shows `observationCount >= minIdeaObservations`. `minIdeaObservations` defaults to `2` and is clamped to the inclusive range `1..10`.\n\nRejected idea event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"idea_rejected\",\n  \"mode\": \"research\",\n  \"run\": 7,\n  \"ideaId\": \"idea-cache-stampede\",\n  \"idea\": \"Investigate cache stampede mitigation as a follow-up focus\",\n  \"category\": \"ideas\",\n  \"reason\": \"Already rejected by environment evidence\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\n`idea_rejected` durably suppresses the matching promoted idea and also enters the reducer-owned rejected-pattern cache. Use `category: \"general\"` only when the rejection should suppress matching text across next-focus, recovery, and ideas candidates.\n\nRejected idea removal event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"ideaRejectedRemoved\",\n  \"mode\": \"research\",\n  \"pattern\": \"Retry HTTP/3 as the primary latency fix\",\n  \"category\": \"next-focus\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nRejected idea reset event:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"ideaRejectedReset\",\n  \"mode\": \"research\",\n  \"reason\": \"Operator wants previously rejected ideas eligible again\",\n  \"timestamp\": \"2026-05-24T00:00:00Z\"\n}\n```\n\nThe reducer derives a bounded active rejected-pattern cache from these events. `idea_rejected` adds or refreshes one pattern, `ideaRejectedRemoved` removes a single matching pattern or id, and `ideaRejectedReset` clears the active cache. Legacy `ideaRejected`, `ideaRejectedRemoved`, and `ideaRejectedReset` rows remain replayable for existing state logs. The active cache is capped at 100 entries; when more are added, the oldest active entry is evicted and the reducer emits a warning.\n\nCandidate checks compare normalized exact text first, then apply fuzzy matching only when the candidate category is compatible with the rejected category. Omit `category` for a general rejection that can suppress candidates across next-focus, recovery, or ideas surfaces.\n\nGraph convergence event shape lives in `../convergence/convergence_graph.md`.\n\n---\n\n## 8. NORMALIZATION\n\nEmission-time normalization maps legacy labels into canonical `stopReason` values before persistence. The mapping lives in `../convergence/convergence.md`.\n\nMalformed lines are handled by the reducer according to its strict/lenient mode. Fault tolerance and reconstruction are documented in `state_reducer_registry.md`.","lineStart":1,"lineEnd":325,"totalLines":325,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/references/state/state_jsonl.md","time":{"start":1783486581303,"end":1783486581309}},"metadata":{"openai":{"itemId":"fc_00b09cdc8d1ddb64016a4dd8753d708191ada63c46b0eaa36f"}},"id":"prt_f40158a22001h4aOcWDjVrxvv0","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40156be30015xKmGAeLFLa3KG"}}
{"type":"tool_use","timestamp":1783486581312,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_S2sI8XKB8j0CH10o6lE5WFTw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/README.md","offset":1,"limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/README.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"deep research scripts: Code README\"\n3: description: \"Code-facing README for .opencode/skills/deep-loop-workflows/deep-research/scripts.\"\n4: trigger_phrases:\n5:   - \"deep-research scripts\"\n6:   - \"code README\"\n7: ---\n8: \n9: # deep research scripts\n10: \n11: Operator and maintenance scripts for this skill.\n12: \n13: ---\n14: \n15: ## 1. OVERVIEW\n16: \n17: ### Purpose\n18: \n19: This README documents the code-bearing folder `.opencode/skills/deep-loop-workflows/deep-research/scripts` so operators can understand its role without opening every source file first. It follows the sk-doc skill README structure while staying focused on code navigation.\n20: \n21: ### Usage\n22: \n23: Use this file to identify the folder boundary, the likely verification path, and the local source files that need sk-code conventions. Keep behavior details in source comments and higher-level workflow details in the owning `SKILL.md`.\n24: \n25: ### Key Statistics\n26: \n27: | Metric | Value |\n28: |---|---:|\n29: | Code files | 2 |\n30: | README scope | Direct files in this folder |\n31: | Audit context | Internal validation notes |\n32: \n33: ---\n34: \n35: ## 2. QUICK START\n36: \n37: **Step 1: Confirm the owner.**\n38: \n39: Start with `.opencode/skills/deep-loop-workflows/deep-research/SKILL.md` for runtime routing and workflow boundaries.\n40: \n41: **Step 2: Inspect the local code.**\n42: \n43: ```bash\n44: rg --files .opencode/skills/deep-loop-workflows/deep-research/scripts\n45: ```\n46: \n47: Expected result: the command lists the source files summarized below.\n48: \n49: **Step 3: Verify changes.**\n50: \n51: Run individual scripts from the repository root with the documented arguments.\n52: \n53: ---\n54: \n55: ## 3. FEATURES\n56: \n57: | Feature | What It Does |\n58: |---|---|\n59: | Folder boundary | Documents direct code files under `scripts`. |\n60: | sk-code alignment | Points reviewers at OpenCode naming, header, error-handling, and type-discipline checks. |\n61: | Verification handoff | Records the expected owner and audit packet for follow-up work. |\n62: \n63: ---\n64: \n65: ## 4. STRUCTURE\n66: \n67: | Path | Purpose |\n68: |---|---|\n69: | `reduce-state.cjs` | CJS source file in this folder. |\n70: | `runtime-capabilities.cjs` | CJS source file in this folder. |\n71: \n72: ---\n73: \n74: ## 5. CONFIGURATION\n75: \n76: | Setting | Default | Purpose |\n77: |---|---|---|\n78: | sk-code surface | OPENCODE | Applies OpenCode TypeScript, JavaScript, Python, Shell, and config conventions. |\n79: | README scope | Direct folder | This file documents this folder, not sibling folders. |\n80: \n81: ---\n82: \n83: ## 6. USAGE EXAMPLES\n84: \n85: **Audit this folder**\n86: \n87: ```text\n88: User request: Check .opencode/skills/deep-loop-workflows/deep-research/scripts for sk-code and README coverage.\n89: Skill routing: sk-code plus sk-doc.\n90: Expected output: Findings recorded in the 026 audit report.\n91: ```\n92: \n93: ---\n94: \n95: ## 7. TROUBLESHOOTING\n96: \n97: | What You See | Cause | Fix |\n98: |---|---|---|\n99: | README appears stale | Source files changed after this audit | Refresh the structure table and rerun the 026 audit check. |\n100: | Verification command is unclear | Folder is a helper boundary | Use the nearest package or skill-level verification command. |\n101: \n102: ---\n103: \n104: ## 8. RELATED DOCUMENTS\n105: \n106: | Document | Purpose |\n107: |---|---|\n108: | [`deep-research/SKILL.md`](../SKILL.md) | Runtime instructions for the owning skill. |\n109: | [`sk-code/SKILL.md`](../../../sk-code/SKILL.md) | OpenCode coding standards and verification routing. |\n110: | [`sk-doc skill_readme_template.md`](../../../sk-doc/create-skill/assets/skill/skill_readme_template.md) | README structure used for this code README. |\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"---\ntitle: \"deep research scripts: Code README\"\ndescription: \"Code-facing README for .opencode/skills/deep-loop-workflows/deep-research/scripts.\"\ntrigger_phrases:\n  - \"deep-research scripts\"\n  - \"code README\"\n---\n\n# deep research scripts\n\nOperator and maintenance scripts for this skill.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis README documents the code-bearing folder `.opencode/skills/deep-loop-workflows/deep-research/scripts` so operators can understand its role without opening every source file first. It follows the sk-doc skill README structure while staying focused on code navigation.\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/README.md","text":"---\ntitle: \"deep research scripts: Code README\"\ndescription: \"Code-facing README for .opencode/skills/deep-loop-workflows/deep-research/scripts.\"\ntrigger_phrases:\n  - \"deep-research scripts\"\n  - \"code README\"\n---\n\n# deep research scripts\n\nOperator and maintenance scripts for this skill.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis README documents the code-bearing folder `.opencode/skills/deep-loop-workflows/deep-research/scripts` so operators can understand its role without opening every source file first. It follows the sk-doc skill README structure while staying focused on code navigation.\n\n### Usage\n\nUse this file to identify the folder boundary, the likely verification path, and the local source files that need sk-code conventions. Keep behavior details in source comments and higher-level workflow details in the owning `SKILL.md`.\n\n### Key Statistics\n\n| Metric | Value |\n|---|---:|\n| Code files | 2 |\n| README scope | Direct files in this folder |\n| Audit context | Internal validation notes |\n\n---\n\n## 2. QUICK START\n\n**Step 1: Confirm the owner.**\n\nStart with `.opencode/skills/deep-loop-workflows/deep-research/SKILL.md` for runtime routing and workflow boundaries.\n\n**Step 2: Inspect the local code.**\n\n```bash\nrg --files .opencode/skills/deep-loop-workflows/deep-research/scripts\n```\n\nExpected result: the command lists the source files summarized below.\n\n**Step 3: Verify changes.**\n\nRun individual scripts from the repository root with the documented arguments.\n\n---\n\n## 3. FEATURES\n\n| Feature | What It Does |\n|---|---|\n| Folder boundary | Documents direct code files under `scripts`. |\n| sk-code alignment | Points reviewers at OpenCode naming, header, error-handling, and type-discipline checks. |\n| Verification handoff | Records the expected owner and audit packet for follow-up work. |\n\n---\n\n## 4. STRUCTURE\n\n| Path | Purpose |\n|---|---|\n| `reduce-state.cjs` | CJS source file in this folder. |\n| `runtime-capabilities.cjs` | CJS source file in this folder. |\n\n---\n\n## 5. CONFIGURATION\n\n| Setting | Default | Purpose |\n|---|---|---|\n| sk-code surface | OPENCODE | Applies OpenCode TypeScript, JavaScript, Python, Shell, and config conventions. |\n| README scope | Direct folder | This file documents this folder, not sibling folders. |\n\n---\n\n## 6. USAGE EXAMPLES\n\n**Audit this folder**\n\n```text\nUser request: Check .opencode/skills/deep-loop-workflows/deep-research/scripts for sk-code and README coverage.\nSkill routing: sk-code plus sk-doc.\nExpected output: Findings recorded in the 026 audit report.\n```\n\n---\n\n## 7. TROUBLESHOOTING\n\n| What You See | Cause | Fix |\n|---|---|---|\n| README appears stale | Source files changed after this audit | Refresh the structure table and rerun the 026 audit check. |\n| Verification command is unclear | Folder is a helper boundary | Use the nearest package or skill-level verification command. |\n\n---\n\n## 8. RELATED DOCUMENTS\n\n| Document | Purpose |\n|---|---|\n| [`deep-research/SKILL.md`](../SKILL.md) | Runtime instructions for the owning skill. |\n| [`sk-code/SKILL.md`](../../../sk-code/SKILL.md) | OpenCode coding standards and verification routing. |\n| [`sk-doc skill_readme_template.md`](../../../sk-doc/create-skill/assets/skill/skill_readme_template.md) | README structure used for this code README. |","lineStart":1,"lineEnd":110,"totalLines":110,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/scripts/README.md","time":{"start":1783486581306,"end":1783486581311}},"metadata":{"openai":{"itemId":"fc_00b09cdc8d1ddb64016a4dd8753d788191902c3aea0df16847"}},"id":"prt_f40158a380011eSrVThfo4Cv6D","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40156be30015xKmGAeLFLa3KG"}}
{"type":"tool_use","timestamp":1783486581319,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_X8Cq8BuXQ224qaPd7IxhZhWs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json","offset":1,"limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"topic\": \"\",\n3:   \"maxIterations\": 10,\n4:   \"convergenceThreshold\": 0.05,\n5:   \"antiConvergence\": {\n6:     \"minIterations\": 3,\n7:     \"convergenceMode\": \"default\",\n8:     \"stopPolicy\": \"fail-closed\"\n9:   },\n10:   \"stuckThreshold\": 3,\n11:   \"maxDurationMinutes\": 120,\n12:   \"maxToolCallsPerIteration\": 12,\n13:   \"maxMinutesPerIteration\": 10,\n14:   \"progressiveSynthesis\": true,\n15:   \"specFolder\": \"\",\n16:   \"createdAt\": \"\",\n17:   \"status\": \"initialized\",\n18:   \"executionMode\": \"auto\",\n19:   \"executor\": {\n20:     \"kind\": \"native\",\n21:     \"model\": null,\n22:     \"reasoningEffort\": null,\n23:     \"serviceTier\": null,\n24:     \"sandboxMode\": null,\n25:     \"timeoutSeconds\": 900\n26:   },\n27:   \"lineage\": {\n28:     \"sessionId\": \"\",\n29:     \"parentSessionId\": null,\n30:     \"lineageMode\": \"new\",\n31:     \"allowedModes\": [\n32:       \"new\",\n33:       \"resume\",\n34:       \"restart\"\n35:     ],\n36:     \"deferredModes\": [\n37:       \"fork\",\n38:       \"completed-continue\"\n39:     ],\n40:     \"generation\": 1,\n41:     \"continuedFromRun\": null\n42:   },\n43:   \"reducer\": {\n44:     \"enabled\": true,\n45:     \"version\": \"1.0\",\n46:     \"registryFile\": \"research/findings-registry.json\",\n47:     \"dashboardFile\": \"research/deep-research-dashboard.md\",\n48:     \"strategyFile\": \"research/deep-research-strategy.md\",\n49:     \"machineOwnedSections\": [\n50:       \"key-questions\",\n51:       \"answered-questions\",\n52:       \"what-worked\",\n53:       \"what-failed\",\n54:       \"exhausted-approaches\",\n55:       \"ruled-out-directions\",\n56:       \"next-focus\"\n57:     ]\n58:   },\n59:   \"capabilityMatrixPath\": \".opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json\",\n60:   \"capabilityMatrixDocPath\": \".opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md\",\n61:   \"runtimeCapabilityResolver\": \".opencode/skills/deep-loop-workflows/deep-research/scripts/runtime-capabilities.cjs\",\n62:   \"reducerScriptPath\": \".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs\",\n63:   \"pauseSentinelPath\": \"research/.deep-research-pause\",\n64:   \"archiveRoot\": \"research_archive\",\n65:   \"migrationWindowDays\": 28,\n66:   \"fileProtection\": {\n67:     \"deep-research-config.json\": \"immutable\",\n68:     \"deep-research-state.jsonl\": \"append-only\",\n69:     \"deep-research-strategy.md\": \"mutable\",\n70:     \"deep-research-dashboard.md\": \"auto-generated\",\n71:     \"findings-registry.json\": \"auto-generated\",\n72:     \"iteration-*.md\": \"write-once\",\n73:     \"research/research.md\": \"mutable\"\n74:   },\n75:   \"_optimizerManaged\": {\n76:     \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n77:     \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n78:     \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n79:     \"lockedFields\": [\"lineage\", \"reducer\", \"fileProtection\", \"sessionId\", \"status\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n80:     \"promotionMode\": \"advisory-only\"\n81:   }\n82: }\n\n(End of file - total 82 lines)\n</content>","metadata":{"preview":"{\n  \"topic\": \"\",\n  \"maxIterations\": 10,\n  \"convergenceThreshold\": 0.05,\n  \"antiConvergence\": {\n    \"minIterations\": 3,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 3,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": true,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json","text":"{\n  \"topic\": \"\",\n  \"maxIterations\": 10,\n  \"convergenceThreshold\": 0.05,\n  \"antiConvergence\": {\n    \"minIterations\": 3,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 3,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": true,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",\n    \"model\": null,\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900\n  },\n  \"lineage\": {\n    \"sessionId\": \"\",\n    \"parentSessionId\": null,\n    \"lineageMode\": \"new\",\n    \"allowedModes\": [\n      \"new\",\n      \"resume\",\n      \"restart\"\n    ],\n    \"deferredModes\": [\n      \"fork\",\n      \"completed-continue\"\n    ],\n    \"generation\": 1,\n    \"continuedFromRun\": null\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"version\": \"1.0\",\n    \"registryFile\": \"research/findings-registry.json\",\n    \"dashboardFile\": \"research/deep-research-dashboard.md\",\n    \"strategyFile\": \"research/deep-research-strategy.md\",\n    \"machineOwnedSections\": [\n      \"key-questions\",\n      \"answered-questions\",\n      \"what-worked\",\n      \"what-failed\",\n      \"exhausted-approaches\",\n      \"ruled-out-directions\",\n      \"next-focus\"\n    ]\n  },\n  \"capabilityMatrixPath\": \".opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json\",\n  \"capabilityMatrixDocPath\": \".opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md\",\n  \"runtimeCapabilityResolver\": \".opencode/skills/deep-loop-workflows/deep-research/scripts/runtime-capabilities.cjs\",\n  \"reducerScriptPath\": \".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs\",\n  \"pauseSentinelPath\": \"research/.deep-research-pause\",\n  \"archiveRoot\": \"research_archive\",\n  \"migrationWindowDays\": 28,\n  \"fileProtection\": {\n    \"deep-research-config.json\": \"immutable\",\n    \"deep-research-state.jsonl\": \"append-only\",\n    \"deep-research-strategy.md\": \"mutable\",\n    \"deep-research-dashboard.md\": \"auto-generated\",\n    \"findings-registry.json\": \"auto-generated\",\n    \"iteration-*.md\": \"write-once\",\n    \"research/research.md\": \"mutable\"\n  },\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n    \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n    \"lockedFields\": [\"lineage\", \"reducer\", \"fileProtection\", \"sessionId\", \"status\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n    \"promotionMode\": \"advisory-only\"\n  }\n}","lineStart":1,"lineEnd":82,"totalLines":82,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_config.json","time":{"start":1783486581313,"end":1783486581318}},"metadata":{"openai":{"itemId":"fc_00b09cdc8d1ddb64016a4dd8753d7c81919ab2abf83109d64a"}},"id":"prt_f40158a3a001pNmjC46bOg5Z1d","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40156be30015xKmGAeLFLa3KG"}}
{"type":"tool_use","timestamp":1783486581319,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_4DWeVA5JaZCfmOhSrFaprGlF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Research Strategy Template\n3: description: Runtime template copied to research/ during initialization to track research progress, focus decisions, and outcomes across iterations.\n4: trigger_phrases:\n5:   - \"deep research strategy\"\n6:   - \"research strategy template\"\n7:   - \"research session tracking\"\n8:   - \"exhausted research approaches\"\n9:   - \"research stop conditions\"\n10:   - \"ruled out research directions\"\n11: importance_tier: normal\n12: contextType: planning\n13: version: 1.14.0.19\n14: ---\n15: \n16: # Deep Research Strategy - Session Tracking Template\n17: \n18: Runtime template copied to `{spec_folder}/research/` during initialization. Tracks research progress across iterations.\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: Serves as the \"persistent brain\" for a deep research session. Records what to investigate, what worked, what failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n25: \n26: ### Usage\n27: \n28: - **Init:** Orchestrator copies this template to `{spec_folder}/research/deep-research-strategy.md` and populates Topic, Key Questions, Known Context, and Research Boundaries from config and memory context.\n29: - **Per iteration:** Agent reads Next Focus, writes iteration evidence, and the reducer refreshes What Worked/Failed, answered questions, carried-forward questions, ruled-out directions, and Next Focus.\n30: - **Mutability:** Mutable — analyst-owned sections remain stable, while machine-owned sections are rewritten by the reducer after each iteration. Section 3 is a generated projection from the reducer registry.\n31: - **Protection:** Shared state with explicit ownership boundaries. Orchestrator validates consistency on resume.\n32: \n33: ### Question Injection Surface\n34: \n35: Use `{spec_folder}/research/inbox.jsonl` to append external questions during an active run. Each line is one JSON object with:\n36: \n37: - `id`: stable inbox record identifier\n38: - `text`: question text to promote\n39: - `source`: concrete source label, such as an angle bank entry, analyst strategy, or operator note\n40: - `origin`: one of `angle-bank`, `analyst-strategy`, `operator`, or `legacy-import`\n41: - `injectedAtIteration`: iteration number when the question was introduced\n42: - `promotedQuestionId`: promoted registry question id, or `null` until promotion\n43: \n44: The reducer reads the inbox on every reduce step and carries `origin` into the question registry and dashboard badges. Direct edits to Section 3 still work as a compatibility path, but they are attributed as `legacy-import`.\n45: \n46: Question ownership is explicit:\n47: \n48: - Inbox rows are immutable input.\n49: - The reducer registry is canonical question state.\n50: - Section 3 is rendered only from the registry view.\n51: \n52: When an inbox row targets an existing registry question but carries different text, the reducer keeps the registry value, records `operatorDecision: needs_decision`, and appends a `question_conflict` event with both `inboxValue` and `registryValue`.\n53: \n54: ---\n55: \n56: ## 2. TOPIC\n57: [Research topic from config -- set during initialization]\n58: \n59: ---\n60: \n61: <!-- ANCHOR:key-questions -->\n62: ## 3. KEY QUESTIONS (remaining)\n63: Generated from the reducer registry. Add external or late questions through `{spec_folder}/research/inbox.jsonl`; direct edits are imported as compatibility input and may be replaced on the next reduce step.\n64: \n65: - [ ] [Question 1 -- identified during initialization or iteration 1]\n66: - [ ] [Question 2]\n67: - [ ] [Question 3]\n68: <!-- /ANCHOR:key-questions -->\n69: \n70: ---\n71: \n72: ## 4. NON-GOALS\n73: [What this research session is NOT trying to answer -- populated during initialization]\n74: \n75: ---\n76: \n77: ## 5. STOP CONDITIONS\n78: [Explicit conditions beyond convergence that should end the session -- populated during initialization]\n79: \n80: ---\n81: \n82: <!-- ANCHOR:answered-questions -->\n83: ## 6. ANSWERED QUESTIONS\n84: [None yet -- populated as iterations answer questions]\n85: <!-- /ANCHOR:answered-questions -->\n86: \n87: ---\n88: \n89: <!-- MACHINE-OWNED: START -->\n90: <!-- ANCHOR:what-worked -->\n91: ## 7. WHAT WORKED\n92: [First iteration -- populated after iteration 1 completes]\n93: - [Approach]: [Why it worked] (iteration N)\n94: <!-- /ANCHOR:what-worked -->\n95: \n96: ---\n97: \n98: <!-- ANCHOR:what-failed -->\n99: ## 8. WHAT FAILED\n100: [First iteration -- populated after iteration 1 completes]\n101: - [Approach]: [Why it failed] (iteration N)\n102: <!-- /ANCHOR:what-failed -->\n103: \n104: ---\n105: \n106: <!-- ANCHOR:exhausted-approaches -->\n107: ## 9. EXHAUSTED APPROACHES (do not retry)\n108: [Populated when an approach has been tried from multiple angles without success]\n109: \n110: ### [Category Name] -- BLOCKED (iteration N, N attempts)\n111: - What was tried: [specific approaches attempted]\n112: - Why blocked: [root cause of exhaustion]\n113: - Do NOT retry: [explicit prohibition]\n114: \n115: ### [Category Name] -- PRODUCTIVE (iteration N)\n116: - What worked: [successful approaches in this category]\n117: - Prefer for: [related questions where this category may help]\n118: <!-- /ANCHOR:exhausted-approaches -->\n119: \n120: ---\n121: \n122: <!-- ANCHOR:ruled-out-directions -->\n123: ## 10. RULED OUT DIRECTIONS\n124: [Approaches that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n125: - [Approach]: [Why ruled out] (iteration N, evidence: [source])\n126: <!-- /ANCHOR:ruled-out-directions -->\n127: \n128: ---\n129: \n130: <!-- ANCHOR:carried-forward-open-questions -->\n131: ## 11A. CARRIED-FORWARD OPEN QUESTIONS\n132: [Self-owned open questions from iteration write-back -- populated after iteration 1 completes]\n133: <!-- /ANCHOR:carried-forward-open-questions -->\n134: \n135: ---\n136: \n137: <!-- ANCHOR:next-focus -->\n138: ## 11. NEXT FOCUS\n139: [Recommended focus area for the next iteration -- updated at end of each iteration]\n140: <!-- /ANCHOR:next-focus -->\n141: \n142: ---\n143: \n144: <!-- MACHINE-OWNED: END -->\n145: ## 12. KNOWN CONTEXT\n146: [Populated during initialization from memory_context() results, if any prior work exists]\n147: \n148: ### Bounded Context Snapshot\n149: \n150: Populate during initialization when the target is codebase-scoped. Keep this pointer-based and small:\n151: \n152: - Source pointers: paths, symbols, or resource-map entries relevant to the topic.\n153: - Reuse candidates: existing utilities, patterns, docs, or agents worth extending.\n154: - Integration points: files or contracts the research is likely to touch.\n155: - Constraints and risks: scope limits, stale graph or memory gaps, and known non-goals.\n156: \n157: Do not inline full source bodies. Do not dispatch the retired standalone context loop. Use `@context` for one-shot retrieval, and use this snapshot only to seed the research loop.\n158: \n159: ---\n160: \n161: ## 13. RESEARCH BOUNDARIES\n162: - Max iterations: [from config]\n163: - Convergence threshold: [from config]\n164: - Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n165: - Progressive synthesis: true (default)\n166: - research/research.md ownership: workflow-owned canonical synthesis output\n167: - Lifecycle branches: `resume`, `restart` (live); `fork`, `completed-continue` (deferred, not runtime-wired)\n168: - Machine-owned sections: reducer controls Sections 3, 6, 7-11A\n169: - Question injection surface: `{spec_folder}/research/inbox.jsonl`\n170: - Question conflict owner: reducer registry; `question_conflict` events surface inbox/registry disagreements for operator decision\n171: - Canonical pause sentinel: `research/.deep-research-pause`\n172: - Capability matrix: `.opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json`\n173: - Capability matrix doc: `.opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md`\n174: - Capability resolver: `.opencode/skills/deep-loop-workflows/deep-research/scripts/runtime-capabilities.cjs`\n175: - Current generation: [from config.lineage.generation]\n176: - Started: [timestamp]\n\n(End of file - total 176 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Research Strategy Template\ndescription: Runtime template copied to research/ during initialization to track research progress, focus decisions, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep research strategy\"\n  - \"research strategy template\"\n  - \"research session tracking\"\n  - \"exhausted research approaches\"\n  - \"research stop conditions\"\n  - \"ruled out research directions\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.14.0.19\n---\n\n# Deep Research Strategy - Session Tracking Template\n\nRuntime template copied to `{spec_folder}/research/` during initialization. Tracks research progress across iterations.\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md","text":"---\ntitle: Deep Research Strategy Template\ndescription: Runtime template copied to research/ during initialization to track research progress, focus decisions, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep research strategy\"\n  - \"research strategy template\"\n  - \"research session tracking\"\n  - \"exhausted research approaches\"\n  - \"research stop conditions\"\n  - \"ruled out research directions\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.14.0.19\n---\n\n# Deep Research Strategy - Session Tracking Template\n\nRuntime template copied to `{spec_folder}/research/` during initialization. Tracks research progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose\n\nServes as the \"persistent brain\" for a deep research session. Records what to investigate, what worked, what failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n\n### Usage\n\n- **Init:** Orchestrator copies this template to `{spec_folder}/research/deep-research-strategy.md` and populates Topic, Key Questions, Known Context, and Research Boundaries from config and memory context.\n- **Per iteration:** Agent reads Next Focus, writes iteration evidence, and the reducer refreshes What Worked/Failed, answered questions, carried-forward questions, ruled-out directions, and Next Focus.\n- **Mutability:** Mutable — analyst-owned sections remain stable, while machine-owned sections are rewritten by the reducer after each iteration. Section 3 is a generated projection from the reducer registry.\n- **Protection:** Shared state with explicit ownership boundaries. Orchestrator validates consistency on resume.\n\n### Question Injection Surface\n\nUse `{spec_folder}/research/inbox.jsonl` to append external questions during an active run. Each line is one JSON object with:\n\n- `id`: stable inbox record identifier\n- `text`: question text to promote\n- `source`: concrete source label, such as an angle bank entry, analyst strategy, or operator note\n- `origin`: one of `angle-bank`, `analyst-strategy`, `operator`, or `legacy-import`\n- `injectedAtIteration`: iteration number when the question was introduced\n- `promotedQuestionId`: promoted registry question id, or `null` until promotion\n\nThe reducer reads the inbox on every reduce step and carries `origin` into the question registry and dashboard badges. Direct edits to Section 3 still work as a compatibility path, but they are attributed as `legacy-import`.\n\nQuestion ownership is explicit:\n\n- Inbox rows are immutable input.\n- The reducer registry is canonical question state.\n- Section 3 is rendered only from the registry view.\n\nWhen an inbox row targets an existing registry question but carries different text, the reducer keeps the registry value, records `operatorDecision: needs_decision`, and appends a `question_conflict` event with both `inboxValue` and `registryValue`.\n\n---\n\n## 2. TOPIC\n[Research topic from config -- set during initialization]\n\n---\n\n<!-- ANCHOR:key-questions -->\n## 3. KEY QUESTIONS (remaining)\nGenerated from the reducer registry. Add external or late questions through `{spec_folder}/research/inbox.jsonl`; direct edits are imported as compatibility input and may be replaced on the next reduce step.\n\n- [ ] [Question 1 -- identified during initialization or iteration 1]\n- [ ] [Question 2]\n- [ ] [Question 3]\n<!-- /ANCHOR:key-questions -->\n\n---\n\n## 4. NON-GOALS\n[What this research session is NOT trying to answer -- populated during initialization]\n\n---\n\n## 5. STOP CONDITIONS\n[Explicit conditions beyond convergence that should end the session -- populated during initialization]\n\n---\n\n<!-- ANCHOR:answered-questions -->\n## 6. ANSWERED QUESTIONS\n[None yet -- populated as iterations answer questions]\n<!-- /ANCHOR:answered-questions -->\n\n---\n\n<!-- MACHINE-OWNED: START -->\n<!-- ANCHOR:what-worked -->\n## 7. WHAT WORKED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it worked] (iteration N)\n<!-- /ANCHOR:what-worked -->\n\n---\n\n<!-- ANCHOR:what-failed -->\n## 8. WHAT FAILED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it failed] (iteration N)\n<!-- /ANCHOR:what-failed -->\n\n---\n\n<!-- ANCHOR:exhausted-approaches -->\n## 9. EXHAUSTED APPROACHES (do not retry)\n[Populated when an approach has been tried from multiple angles without success]\n\n### [Category Name] -- BLOCKED (iteration N, N attempts)\n- What was tried: [specific approaches attempted]\n- Why blocked: [root cause of exhaustion]\n- Do NOT retry: [explicit prohibition]\n\n### [Category Name] -- PRODUCTIVE (iteration N)\n- What worked: [successful approaches in this category]\n- Prefer for: [related questions where this category may help]\n<!-- /ANCHOR:exhausted-approaches -->\n\n---\n\n<!-- ANCHOR:ruled-out-directions -->\n## 10. RULED OUT DIRECTIONS\n[Approaches that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n- [Approach]: [Why ruled out] (iteration N, evidence: [source])\n<!-- /ANCHOR:ruled-out-directions -->\n\n---\n\n<!-- ANCHOR:carried-forward-open-questions -->\n## 11A. CARRIED-FORWARD OPEN QUESTIONS\n[Self-owned open questions from iteration write-back -- populated after iteration 1 completes]\n<!-- /ANCHOR:carried-forward-open-questions -->\n\n---\n\n<!-- ANCHOR:next-focus -->\n## 11. NEXT FOCUS\n[Recommended focus area for the next iteration -- updated at end of each iteration]\n<!-- /ANCHOR:next-focus -->\n\n---\n\n<!-- MACHINE-OWNED: END -->\n## 12. KNOWN CONTEXT\n[Populated during initialization from memory_context() results, if any prior work exists]\n\n### Bounded Context Snapshot\n\nPopulate during initialization when the target is codebase-scoped. Keep this pointer-based and small:\n\n- Source pointers: paths, symbols, or resource-map entries relevant to the topic.\n- Reuse candidates: existing utilities, patterns, docs, or agents worth extending.\n- Integration points: files or contracts the research is likely to touch.\n- Constraints and risks: scope limits, stale graph or memory gaps, and known non-goals.\n\nDo not inline full source bodies. Do not dispatch the retired standalone context loop. Use `@context` for one-shot retrieval, and use this snapshot only to seed the research loop.\n\n---\n\n## 13. RESEARCH BOUNDARIES\n- Max iterations: [from config]\n- Convergence threshold: [from config]\n- Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n- Progressive synthesis: true (default)\n- research/research.md ownership: workflow-owned canonical synthesis output\n- Lifecycle branches: `resume`, `restart` (live); `fork`, `completed-continue` (deferred, not runtime-wired)\n- Machine-owned sections: reducer controls Sections 3, 6, 7-11A\n- Question injection surface: `{spec_folder}/research/inbox.jsonl`\n- Question conflict owner: reducer registry; `question_conflict` events surface inbox/registry disagreements for operator decision\n- Canonical pause sentinel: `research/.deep-research-pause`\n- Capability matrix: `.opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json`\n- Capability matrix doc: `.opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md`\n- Capability resolver: `.opencode/skills/deep-loop-workflows/deep-research/scripts/runtime-capabilities.cjs`\n- Current generation: [from config.lineage.generation]\n- Started: [timestamp]","lineStart":1,"lineEnd":176,"totalLines":176,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_strategy.md","time":{"start":1783486581315,"end":1783486581319}},"metadata":{"openai":{"itemId":"fc_00b09cdc8d1ddb64016a4dd8753d848191941f5deeaad3d302"}},"id":"prt_f40158a42001If9iv0ZjppPrxE","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40156be30015xKmGAeLFLa3KG"}}
{"type":"step_finish","timestamp":1783486581827,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"id":"prt_f40158c42001R6jw7M8xKN1i61","reason":"tool-calls","snapshot":"1aefe6e3f18684fce5e209858ae6abafa93ea75a","messageID":"msg_f40156be30015xKmGAeLFLa3KG","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","type":"step-finish","tokens":{"total":69588,"input":30340,"output":309,"reasoning":27,"cache":{"write":0,"read":38912}},"cost":0}}
{"type":"step_start","timestamp":1783486583709,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"id":"prt_f4015939b001ur4d3b92vI7lj5","messageID":"msg_f40158e13001e7wTnUOZp0IOqc","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","snapshot":"1aefe6e3f18684fce5e209858ae6abafa93ea75a","type":"step-start"}}
{"type":"tool_use","timestamp":1783486585856,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_dLjHwG8zQawj1En2GGwaW0wc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":1437,"limit":400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n1437: \n1438:           function collectIterationFindingGroups(record) {\n1439:             if (!record || record.type !== 'iteration') return [];\n1440:             const structured = [record.keyFindings, record.findings]\n1441:               .find((value) => Array.isArray(value) && value.length > 0);\n1442:             if (!Array.isArray(structured)) return [];\n1443:             return structured\n1444:               .map(findingKeys)\n1445:               .filter((keys) => keys.length > 0);\n1446:           }\n1447: \n1448:           function collectRegistryFindingKeys(registry) {\n1449:             if (!Array.isArray(registry?.keyFindings)) return [];\n1450:             return registry.keyFindings\n1451:               .flatMap(findingKeys);\n1452:           }\n1453: \n1454:           function appendEvent(event) {\n1455:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1456:           }\n1457: \n1458:           const registry = readJson(paths.registry);\n1459:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1460:           const stateRecords = readJsonl(paths.stateLog);\n1461:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1462:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1463:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1464:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1465:           const identifiableFindingCount = identifiableFindingGroups.length;\n1466:           const missingArtifacts = [\n1467:             ['registry', paths.registry],\n1468:             ['research', paths.research],\n1469:             ['dashboard', paths.dashboard],\n1470:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1471:           const invariantFailures = [];\n1472:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1473:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1474:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1475:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1476:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1477: \n1478:           if (invariantFailures.length > 0) {\n1479:             appendEvent({\n1480:               type: 'event',\n1481:               event: 'synthesis_incomplete',\n1482:               mode: 'research',\n1483:               severity: 'warning',\n1484:               totalIterations: Number('{iteration_count}'),\n1485:               answeredCount: Number('{answered_count}'),\n1486:               totalQuestions: Number('{total_questions}'),\n1487:               stopReason: '{reason}',\n1488:               reason: 'synthesis_artifact_invariant_failed',\n1489:               invariantFailures,\n1490:               missingArtifacts,\n1491:               registryFindingCount,\n1492:               iterationFindingCount,\n1493:               identifiableFindingCount,\n1494:               missingStructuredFindingCount,\n1495:               timestamp: '{ISO_8601_NOW}',\n1496:             });\n1497:           } else {\n1498:             appendEvent({\n1499:               type: 'event',\n1500:               event: 'synthesis_complete',\n1501:               totalIterations: Number('{iteration_count}'),\n1502:               answeredCount: Number('{answered_count}'),\n1503:               totalQuestions: Number('{total_questions}'),\n1504:               stopReason: '{reason}',\n1505:               timestamp: '{ISO_8601_NOW}',\n1506:             });\n1507:           }\n1508:           EOF\n1509: \n1510:       step_writeback_spec_findings:\n1511:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1512:         edit: \"{spec_folder}/spec.md\"\n1513:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1514:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1515:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1516:         fail_closed_conflict_check:\n1517:           if_existing_generated_fence_present:\n1518:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1519:             on_manual_edit_conflict:\n1520:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1521:               halt: true\n1522:         instructions:\n1523:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1524:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1525:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1526:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1527:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1528:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1529: \n1530:       step_validate_post_synthesis_spec_doc:\n1531:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1532:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1533:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1534: \n1535:       step_update_config_status:\n1536:         action: \"Mark config as complete\"\n1537:         edit: \"{state_paths.config}\"\n1538:         set_field: { status: \"complete\" }\n1539: \n1540:       step_telemetry_heartbeat_terminal:\n1541:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1542:         skip_when: \"config.fanout is present\"\n1543:         terminal_events: [completed, failed, stopped]\n1544:         command: |\n1545:           node --experimental-strip-types --input-type=module <<'EOF'\n1546:           import { existsSync, readFileSync } from 'node:fs';\n1547: \n1548:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n1549:           import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n1550: \n1551:           const { appendObservabilityEvent } = observabilityEvents;\n1552:           const stateLogPath = '{state_paths.state_log}';\n1553:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1554:           const timestamp = '{ISO_8601_NOW}';\n1555:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1556:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1557:           const reason = '{reason}';\n1558:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1559: \n1560:           function readRecords(path) {\n1561:             if (!existsSync(path)) return [];\n1562:             return readFileSync(path, 'utf8')\n1563:               .split(/\\r?\\n/)\n1564:               .map((line) => line.trim())\n1565:               .filter(Boolean)\n1566:               .map((line) => JSON.parse(line));\n1567:           }\n1568: \n1569:           function elapsedSince(value) {\n1570:             const startedAtMs = Date.parse(String(value ?? ''));\n1571:             const nowMs = Date.parse(timestamp);\n1572:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1573:             return Math.max(0, nowMs - startedAtMs);\n1574:           }\n1575: \n1576:           function terminalEvent(stopReason) {\n1577:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1578:             if (stopReason === 'error') return 'failed';\n1579:             return 'completed';\n1580:           }\n1581: \n1582:           const records = readRecords(stateLogPath);\n1583:           const iterations = records.filter((record) => record.type === 'iteration');\n1584:           const latest = iterations.at(-1) ?? {};\n1585:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1586:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1587:             ?? timestamp;\n1588:           const elapsedMs = elapsedSince(startedAt);\n1589:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1590:           const event = terminalEvent(reason);\n1591:           const row = {\n1592:             event,\n1593:             label: 'single',\n1594:             terminal: true,\n1595:             reason,\n1596:             at: timestamp,\n1597:             duration_ms: elapsedMs,\n1598:             loop_type: 'research',\n1599:             sessionId,\n1600:             generation,\n1601:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1602:           };\n1603: \n1604:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1605:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1606:             diffField: 'state_hash',\n1607:           });\n1608:           if (appended) {\n1609:             try {\n1610:               appendObservabilityEvent(observabilityPath, row, {\n1611:                 producer: 'deep-research-auto',\n1612:                 stream: 'single-loop-telemetry',\n1613:                 subject: { label: row.label, sessionId, generation, reason },\n1614:                 event,\n1615:                 status: event,\n1616:               });\n1617:             } catch {}\n1618:           }\n1619:           EOF\n1620:         working_directory: \"{repo_root}\"\n1621:         outputs:\n1622:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1623: \n1624:       step_stage_artifact_dir:\n1625:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1626:         command: \"git add {state_paths.packet_dir}\"\n1627:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1628:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1629: \n1630:   # ═══════════════════════════════════════════════════════════════\n1631:   # PHASE 4: SAVE\n1632:   # ═══════════════════════════════════════════════════════════════\n1633:   phase_save:\n1634:     purpose: Preserve research context to memory system\n1635:     steps:\n1636: \n1637:       step_compose_save_payload:\n1638:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1639:         output: \"/tmp/save-context-data-<session-id>.json\"\n1640:         requirements:\n1641:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1642:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1643:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1644:         example_payload: |\n1645:           {\n1646:             \"specFolder\": \"{spec_folder}\",\n1647:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n1648:             \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n1649:             \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n1650:             \"exchanges\": [],\n1651:             \"toolCalls\": []\n1652:           }\n1653: \n1654:       step_generate_context:\n1655:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1656:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1657:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1658: \n1659:       step_index_memory:\n1660:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1661:         mcp_tool: memory_save\n1662:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1663:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1664: \n1665:       step_verify_save:\n1666:         action: \"Verify canonical save routed content into the correct spec document\"\n1667:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1668:         on_fail: \"Log warning but do not block completion\"\n1669: \n1670:       step_release_lock:\n1671:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1672:         command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1673:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1674: \n1675:   # ═══════════════════════════════════════════════════════════════\n1676:   # COMPLETION\n1677:   # ═══════════════════════════════════════════════════════════════\n1678:   completion:\n1679:     message: |\n1680:       Deep research complete.\n1681:       Iterations: {iteration_count} | Stop reason: {reason}\n1682:       Questions answered: {answered_count}/{total_questions}\n1683: \n1684:       Artifacts:\n1685:         - research/research.md (compiled from {iteration_count} iterations)\n1686:         - {iteration_count} iteration files in research/\n1687:         - State files: config.json, state.jsonl, strategy.md, deep-research-findings-registry.json, dashboard.md\n1688:         - Memory context saved\n1689: \n1690:       STATUS=OK PATH={spec_folder}\n1691:     next_steps:\n1692:       - \"/speckit:plan [feature-description]\"\n1693:       - \"/deep:research [new-topic] (for related deep research)\"\n1694:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1695: \n1696: # ─────────────────────────────────────────────────────────────────\n1697: # ERROR RECOVERY\n1698: # ─────────────────────────────────────────────────────────────────\n1699: error_recovery:\n1700:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n1701:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1702:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1703:   memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n1704: \n1705: # ─────────────────────────────────────────────────────────────────\n1706: # RULES\n1707: # ─────────────────────────────────────────────────────────────────\n1708: rules:\n1709:   ALWAYS:\n1710:     - follow_workflow_phases_in_order\n1711:     - dispatch_deep_research_agent_per_iteration\n1712:     - check_convergence_before_each_iteration\n1713:     - write_all_state_to_files\n1714:     - upsert_iteration_memory_after_reducer\n1715:     - refresh_memory_context_before_next_prompt\n1716:     - save_memory_context_after_synthesis\n1717:     - respect_max_iterations_cap\n1718:   NEVER:\n1719:     - skip_convergence_check\n1720:     - dispatch_non_leaf_agents\n1721:     - hold_iteration_findings_in_memory_only\n1722:     - modify_config_after_initialization\n1723:     - overwrite_jsonl_state_log\n1724:     - proceed_without_state_file_verification\n1725: \n1726: # ─────────────────────────────────────────────────────────────────\n1727: # REFERENCE-ONLY APPENDIX\n1728: # ─────────────────────────────────────────────────────────────────\n1729: reference_only_appendix:\n1730:   checkpoint_commit:\n1731:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n1732:     commands:\n1733:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n1734:       - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n1735:   wave_orchestration:\n1736:     note: \"Wave execution is intentionally excluded from workflow.steps.\"\n1737:     summary:\n1738:       - \"Check whether 3+ independent unanswered questions justify a wave.\"\n1739:       - \"Dispatch up to 3 parallel agents on distinct questions.\"\n1740:       - \"Score wave results by median newInfoRatio and promote top branches.\"\n\n(End of file - total 1740 lines)\n</content>","metadata":{"preview":"\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n            \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n            \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep research complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Questions answered: {answered_count}/{total_questions}\n\n      Artifacts:\n        - research/research.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in research/\n        - State files: config.json, state.jsonl, strategy.md, deep-research-findings-registry.json, dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [feature-description]\"\n      - \"/deep:research [new-topic] (for related deep research)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_research_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - upsert_iteration_memory_after_reducer\n    - refresh_memory_context_before_next_prompt\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n      - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n  wave_orchestration:\n    note: \"Wave execution is intentionally excluded from workflow.steps.\"\n    summary:\n      - \"Check whether 3+ independent unanswered questions justify a wave.\"\n      - \"Dispatch up to 3 parallel agents on distinct questions.\"\n      - \"Score wave results by median newInfoRatio and promote top branches.\"","lineStart":1437,"lineEnd":1740,"totalLines":1740,"truncated":false}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1783486585850,"end":1783486585854}},"metadata":{"openai":{"itemId":"fc_0f91b49c518ad078016a4dd878f2a881919c42ab847e966cb5"}},"id":"prt_f40159871001g9pXP0UukEm645","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40158e13001e7wTnUOZp0IOqc"}}
