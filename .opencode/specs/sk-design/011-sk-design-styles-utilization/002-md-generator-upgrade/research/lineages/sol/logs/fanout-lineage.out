{"type":"tool_use","timestamp":1784378059262,"sessionID":"ses_08acca7b4ffeXv97nbzMOKS10V","part":{"type":"tool","tool":"read","callID":"call_ncpA3GU3zQahkjzX0Ey3sI8Z","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Loop-Lock CLI Adapter                               ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Thin CLI front door over lib/deep-loop/loop-lock.ts so non-TS callers    ║\n7: // ║ (command YAML, shells, other runtimes) share one locking contract        ║\n8: // ║ instead of drifting per mode. Every subcommand is a direct pass-through  ║\n9: // ║ to the library; the adapter adds only argv parsing and JSON framing.     ║\n10: // ║                                                                          ║\n11: // ║ Subcommands:                                                             ║\n12: // ║   acquire --lock-path P --packet-id X [--ttl-ms N] [--runtime-kind K]    ║\n13: // ║           [--owner-pid PID]                                              ║\n14: // ║   status  --lock-path P                                                  ║\n15: // ║   refresh --lock-path P --owner-pid PID [--nonce N]                      ║\n16: // ║   release --lock-path P --owner-pid PID [--nonce N]                      ║\n17: // ║ Output: one JSON object on stdout.                                       ║\n18: // ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n19: // ║                                                                          ║\n20: // ║ deep_research / deep_review / deep_ai-council YAMLs call THIS adapter.    ║\n21: // ║ The retired standalone context loop used to keep a separate host wrapper; ║\n22: // ║ no active workflow should dispatch that wrapper or recreate that surface. ║\n23: // ╚══════════════════════════════════════════════════════════════════════════╝\n24: \n25: 'use strict';\n26: \n27: // ─────────────────────────────────────────────────────────────────────────────\n28: // 1. IMPORTS\n29: // ─────────────────────────────────────────────────────────────────────────────\n30: \n31: const fs = require('node:fs');\n32: const path = require('node:path');\n33: const { spawnSync } = require('node:child_process');\n34: \n35: // ─────────────────────────────────────────────────────────────────────────────\n36: // 2. CONSTANTS\n37: // ─────────────────────────────────────────────────────────────────────────────\n38: \n39: const TSX_LOADER = require.resolve('tsx');\n40: \n41: // ─────────────────────────────────────────────────────────────────────────────\n42: // 3. TSX BOOTSTRAP\n43: // ─────────────────────────────────────────────────────────────────────────────\n44: \n45: // loop-lock.ts is a TypeScript ESM module; re-exec under the tsx loader once so\n46: // the dynamic import below resolves it. Mirrors convergence.cjs.\n47: if (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n48:   const child = spawnSync(\n49:     process.execPath,\n50:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n51:     {\n52:       cwd: process.cwd(),\n53:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n54:       encoding: 'utf8',\n55:     },\n56:   );\n57:   if (child.stdout) process.stdout.write(child.stdout);\n58:   if (child.stderr) process.stderr.write(child.stderr);\n59:   process.exit(child.status === null ? 1 : child.status);\n60: }\n61: \n62: // ─────────────────────────────────────────────────────────────────────────────\n63: // 4. HELPERS\n64: // ─────────────────────────────────────────────────────────────────────────────\n65: \n66: function inputError(message) {\n67:   const err = new Error(message);\n68:   err.code = 'INPUT_VALIDATION';\n69:   return err;\n70: }\n71: \n72: function parseFlags(argv) {\n73:   const flags = {};\n74:   for (let i = 0; i < argv.length; i += 1) {\n75:     const token = argv[i];\n76:     if (!token.startsWith('--')) {\n77:       throw inputError(`Unexpected positional argument: ${token}`);\n78:     }\n79:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n80:     const next = argv[i + 1];\n81:     if (next === undefined || next.startsWith('--')) {\n82:       flags[key] = true;\n83:     } else {\n84:       flags[key] = next;\n85:       i += 1;\n86:     }\n87:   }\n88:   return flags;\n89: }\n90: \n91: function requireString(flags, key) {\n92:   const value = flags[key];\n93:   if (typeof value !== 'string' || !value) {\n94:     throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n95:   }\n96:   return value;\n97: }\n98: \n99: function resolveOwnerPid(flags) {\n100:   if (flags.ownerPid === undefined) {\n101:     return process.pid;\n102:   }\n103:   const pid = Number(flags.ownerPid);\n104:   if (!Number.isInteger(pid) || pid <= 0) {\n105:     throw inputError('--owner-pid must be a positive integer');\n106:   }\n107:   return pid;\n108: }\n109: \n110: // Nonce is optional on the CLI: nonce-less legacy locks still refresh/release\n111: // on pid match alone, so callers that never captured a nonce keep working.\n112: function resolveOptionalNonce(flags) {\n113:   if (flags.nonce === undefined) {\n114:     return undefined;\n115:   }\n116:   if (typeof flags.nonce !== 'string' || !flags.nonce) {\n117:     throw inputError('--nonce must be a non-empty string when provided');\n118:   }\n119:   return flags.nonce;\n120: }\n121: \n122: function jsonOut(payload) {\n123:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n124: }\n125: \n126: // Map the snake_case on-disk lock record to the camelCase LoopLockData shape so\n127: // status can run it through the same staleness check the library uses.\n128: function readDiskLock(lockPath) {\n129:   let raw;\n130:   try {\n131:     raw = JSON.parse(fs.readFileSync(lockPath, 'utf8'));\n132:   } catch {\n133:     return null;\n134:   }\n135:   if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {\n136:     return null;\n137:   }\n138:   return {\n139:     ownerPid: raw.owner_pid,\n140:     startedAtIso: raw.started_at_iso,\n141:     ttlMs: raw.ttl_ms,\n142:     lastHeartbeatIso: raw.last_heartbeat_iso,\n143:     packetId: raw.packet_id,\n144:     runtimeKind: raw.runtime_kind,\n145:   };\n146: }\n147: \n148: // ─────────────────────────────────────────────────────────────────────────────\n149: // 5. CORE LOGIC\n150: // ─────────────────────────────────────────────────────────────────────────────\n151: \n152: async function main() {\n153:   const argv = process.argv.slice(2);\n154:   const subcommand = argv[0];\n155:   if (!subcommand || subcommand.startsWith('--')) {\n156:     throw inputError('A subcommand is required: acquire | status | refresh | release');\n157:   }\n158:   const flags = parseFlags(argv.slice(1));\n159: \n160:   const lib = await import('../lib/deep-loop/loop-lock.ts');\n161: \n162:   if (subcommand === 'acquire') {\n163:     const lockPath = requireString(flags, 'lockPath');\n164:     const packetId = requireString(flags, 'packetId');\n165:     const ttlMs = flags.ttlMs === undefined ? 300000 : Number(flags.ttlMs);\n166:     if (!Number.isFinite(ttlMs) || ttlMs < 0) {\n167:       throw inputError('--ttl-ms must be a non-negative number');\n168:     }\n169:     const runtimeKind = typeof flags.runtimeKind === 'string' && flags.runtimeKind\n170:       ? flags.runtimeKind\n171:       : 'main';\n172:     const ownerPid = resolveOwnerPid(flags);\n173:     const now = new Date().toISOString();\n174:     const result = lib.acquireLoopLock(lockPath, {\n175:       ownerPid,\n176:       startedAtIso: now,\n177:       ttlMs,\n178:       lastHeartbeatIso: now,\n179:       packetId,\n180:       runtimeKind,\n181:     });\n182:     jsonOut({ command: 'acquire', ...result });\n183:     return;\n184:   }\n185: \n186:   if (subcommand === 'status') {\n187:     const lockPath = requireString(flags, 'lockPath');\n188:     const holder = fs.existsSync(lockPath) ? readDiskLock(lockPath) : null;\n189:     if (!holder) {\n190:       jsonOut({ command: 'status', exists: false, stale: false, alive: false, holder: null });\n191:       return;\n192:     }\n193:     const stale = lib.isStaleLoopLock(holder);\n194:     const alive = lib.processAlive(holder.ownerPid);\n195:     jsonOut({ command: 'status', exists: true, held: !stale, stale, alive, holder });\n196:     return;\n197:   }\n198: \n199:   if (subcommand === 'refresh') {\n200:     const lockPath = requireString(flags, 'lockPath');\n201:     const ownerPid = resolveOwnerPid(flags);\n202:     const acquireNonce = resolveOptionalNonce(flags);\n203:     const refreshed = lib.refreshLoopLock(lockPath, ownerPid, new Date(), { acquireNonce });\n204:     jsonOut({ command: 'refresh', refreshed });\n205:     return;\n206:   }\n207: \n208:   if (subcommand === 'release') {\n209:     const lockPath = requireString(flags, 'lockPath');\n210:     const ownerPid = resolveOwnerPid(flags);\n211:     const acquireNonce = resolveOptionalNonce(flags);\n212:     const released = lib.releaseLoopLock(lockPath, ownerPid, acquireNonce);\n213:     jsonOut({ command: 'release', released });\n214:     return;\n215:   }\n216: \n217:   throw inputError(`Unknown subcommand \"${subcommand}\": expected acquire | status | refresh | release`);\n218: }\n219: \n220: main().catch((err) => {\n221:   const code = err && err.code === 'INPUT_VALIDATION' ? 3 : 1;\n222:   jsonOut({\n223:     status: 'error',\n224:     error: err instanceof Error ? err.message : String(err),\n225:     code: err && err.code ? err.code : 'SCRIPT_ERROR',\n226:   });\n227:   process.exit(code);\n228: });\n\n(End of file - total 228 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Loop-Lock CLI Adapter                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Thin CLI front door over lib/deep-loop/loop-lock.ts so non-TS callers    ║\n// ║ (command YAML, shells, other runtimes) share one locking contract        ║\n// ║ instead of drifting per mode. Every subcommand is a direct pass-through  ║\n// ║ to the library; the adapter adds only argv parsing and JSON framing.     ║\n// ║                                                                          ║\n// ║ Subcommands:                                                             ║\n// ║   acquire --lock-path P --packet-id X [--ttl-ms N] [--runtime-kind K]    ║\n// ║           [--owner-pid PID]                                              ║\n// ║   status  --lock-path P                                                  ║\n// ║   refresh --lock-path P --owner-pid PID [--nonce N]                      ║\n// ║   release --lock-path P --owner-pid PID [--nonce N]                      ║\n// ║ Output: one JSON object on stdout.                                       ║\n// ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n// ║                                                                          ║\n// ║ deep_research / deep_review / deep_ai-council YAMLs call THIS adapter.    ║","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Loop-Lock CLI Adapter                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Thin CLI front door over lib/deep-loop/loop-lock.ts so non-TS callers    ║\n// ║ (command YAML, shells, other runtimes) share one locking contract        ║\n// ║ instead of drifting per mode. Every subcommand is a direct pass-through  ║\n// ║ to the library; the adapter adds only argv parsing and JSON framing.     ║\n// ║                                                                          ║\n// ║ Subcommands:                                                             ║\n// ║   acquire --lock-path P --packet-id X [--ttl-ms N] [--runtime-kind K]    ║\n// ║           [--owner-pid PID]                                              ║\n// ║   status  --lock-path P                                                  ║\n// ║   refresh --lock-path P --owner-pid PID [--nonce N]                      ║\n// ║   release --lock-path P --owner-pid PID [--nonce N]                      ║\n// ║ Output: one JSON object on stdout.                                       ║\n// ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n// ║                                                                          ║\n// ║ deep_research / deep_review / deep_ai-council YAMLs call THIS adapter.    ║\n// ║ The retired standalone context loop used to keep a separate host wrapper; ║\n// ║ no active workflow should dispatch that wrapper or recreate that surface. ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\n// loop-lock.ts is a TypeScript ESM module; re-exec under the tsx loader once so\n// the dynamic import below resolves it. Mirrors convergence.cjs.\nif (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  const child = spawnSync(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      encoding: 'utf8',\n    },\n  );\n  if (child.stdout) process.stdout.write(child.stdout);\n  if (child.stderr) process.stderr.write(child.stderr);\n  process.exit(child.status === null ? 1 : child.status);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction parseFlags(argv) {\n  const flags = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      flags[key] = true;\n    } else {\n      flags[key] = next;\n      i += 1;\n    }\n  }\n  return flags;\n}\n\nfunction requireString(flags, key) {\n  const value = flags[key];\n  if (typeof value !== 'string' || !value) {\n    throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n  }\n  return value;\n}\n\nfunction resolveOwnerPid(flags) {\n  if (flags.ownerPid === undefined) {\n    return process.pid;\n  }\n  const pid = Number(flags.ownerPid);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    throw inputError('--owner-pid must be a positive integer');\n  }\n  return pid;\n}\n\n// Nonce is optional on the CLI: nonce-less legacy locks still refresh/release\n// on pid match alone, so callers that never captured a nonce keep working.\nfunction resolveOptionalNonce(flags) {\n  if (flags.nonce === undefined) {\n    return undefined;\n  }\n  if (typeof flags.nonce !== 'string' || !flags.nonce) {\n    throw inputError('--nonce must be a non-empty string when provided');\n  }\n  return flags.nonce;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\n// Map the snake_case on-disk lock record to the camelCase LoopLockData shape so\n// status can run it through the same staleness check the library uses.\nfunction readDiskLock(lockPath) {\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(lockPath, 'utf8'));\n  } catch {\n    return null;\n  }\n  if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {\n    return null;\n  }\n  return {\n    ownerPid: raw.owner_pid,\n    startedAtIso: raw.started_at_iso,\n    ttlMs: raw.ttl_ms,\n    lastHeartbeatIso: raw.last_heartbeat_iso,\n    packetId: raw.packet_id,\n    runtimeKind: raw.runtime_kind,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const argv = process.argv.slice(2);\n  const subcommand = argv[0];\n  if (!subcommand || subcommand.startsWith('--')) {\n    throw inputError('A subcommand is required: acquire | status | refresh | release');\n  }\n  const flags = parseFlags(argv.slice(1));\n\n  const lib = await import('../lib/deep-loop/loop-lock.ts');\n\n  if (subcommand === 'acquire') {\n    const lockPath = requireString(flags, 'lockPath');\n    const packetId = requireString(flags, 'packetId');\n    const ttlMs = flags.ttlMs === undefined ? 300000 : Number(flags.ttlMs);\n    if (!Number.isFinite(ttlMs) || ttlMs < 0) {\n      throw inputError('--ttl-ms must be a non-negative number');\n    }\n    const runtimeKind = typeof flags.runtimeKind === 'string' && flags.runtimeKind\n      ? flags.runtimeKind\n      : 'main';\n    const ownerPid = resolveOwnerPid(flags);\n    const now = new Date().toISOString();\n    const result = lib.acquireLoopLock(lockPath, {\n      ownerPid,\n      startedAtIso: now,\n      ttlMs,\n      lastHeartbeatIso: now,\n      packetId,\n      runtimeKind,\n    });\n    jsonOut({ command: 'acquire', ...result });\n    return;\n  }\n\n  if (subcommand === 'status') {\n    const lockPath = requireString(flags, 'lockPath');\n    const holder = fs.existsSync(lockPath) ? readDiskLock(lockPath) : null;\n    if (!holder) {\n      jsonOut({ command: 'status', exists: false, stale: false, alive: false, holder: null });\n      return;\n    }\n    const stale = lib.isStaleLoopLock(holder);\n    const alive = lib.processAlive(holder.ownerPid);\n    jsonOut({ command: 'status', exists: true, held: !stale, stale, alive, holder });\n    return;\n  }\n\n  if (subcommand === 'refresh') {\n    const lockPath = requireString(flags, 'lockPath');\n    const ownerPid = resolveOwnerPid(flags);\n    const acquireNonce = resolveOptionalNonce(flags);\n    const refreshed = lib.refreshLoopLock(lockPath, ownerPid, new Date(), { acquireNonce });\n    jsonOut({ command: 'refresh', refreshed });\n    return;\n  }\n\n  if (subcommand === 'release') {\n    const lockPath = requireString(flags, 'lockPath');\n    const ownerPid = resolveOwnerPid(flags);\n    const acquireNonce = resolveOptionalNonce(flags);\n    const released = lib.releaseLoopLock(lockPath, ownerPid, acquireNonce);\n    jsonOut({ command: 'release', released });\n    return;\n  }\n\n  throw inputError(`Unknown subcommand \"${subcommand}\": expected acquire | status | refresh | release`);\n}\n\nmain().catch((err) => {\n  const code = err && err.code === 'INPUT_VALIDATION' ? 3 : 1;\n  jsonOut({\n    status: 'error',\n    error: err instanceof Error ? err.message : String(err),\n    code: err && err.code ? err.code : 'SCRIPT_ERROR',\n  });\n  process.exit(code);\n});","lineStart":1,"lineEnd":228,"totalLines":228,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs","time":{"start":1784378059253,"end":1784378059261}},"metadata":{"openai":{"itemId":"fc_0810ab18ecd3acad016a5b72cab3a88191b42dbd4b632b5486"}},"id":"prt_f753867db0012VlgMH4pLt98ZL","sessionID":"ses_08acca7b4ffeXv97nbzMOKS10V","messageID":"msg_f75380581001mmMq35X4nH6aei"}}
