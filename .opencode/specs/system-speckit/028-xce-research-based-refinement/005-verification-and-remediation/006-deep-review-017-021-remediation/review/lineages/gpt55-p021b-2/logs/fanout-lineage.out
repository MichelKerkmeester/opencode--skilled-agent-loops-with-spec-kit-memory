{"type":"tool_use","timestamp":1781755631175,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"type":"tool","tool":"read","callID":"call_xYheIVPFJDHS3HRagxq0bvBv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Index\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import { createHash } from 'node:crypto';\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. CORE AND UTILS IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\n13: import { beginMaintenance } from '../lib/storage/maintenance-marker.js';\n14: import { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\n15: import { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\n16: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* ───────────────────────────────────────────────────────────────\n24:    2. LIB MODULE IMPORTS\n25: ──────────────────────────────────────────────────────────────── */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* ───────────────────────────────────────────────────────────────\n82:    4. TYPES\n83: ──────────────────────────────────────────────────────────────── */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   nearDuplicateRepaired: number;\n161:   orphanSwept: number;\n162:   orphanSweepFailed: number;\n163:   orphanSweepScanned: number;\n164:   orphanSweepNextCursor: number | null;\n165:   moveReconciled?: number;\n166:   files: ScanFileEntry[];\n167:   constitutional: {\n168:     found: number;\n169:     indexed: number;\n170:     alreadyIndexed: number;\n171:   };\n172:   incremental: {\n173:     enabled: boolean;\n174:     fast_path_skips: number;\n175:     mtime_changed: number;\n176:     metadataPromoter: {\n177:       processed: number;\n178:       resolved: number;\n179:       inserted: number;\n180:       skippedManual: number;\n181:       staleTombstoned: number;\n182:       staleDeleted: number;\n183:       warnings: number;\n184:     };\n185:   };\n186:   dedup: {\n187:     inputTotal: number;\n188:     uniqueTotal: number;\n189:     duplicatesSkipped: number;\n190:   };\n191:   aliasConflicts: AliasConflictSummary;\n192:   divergenceReconcile: DivergenceReconcileSummary;\n193:   checkpointRepair: CheckpointRepairReport;\n194:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n195:   warnings: string[];\n196:   capExceeded: DiscoveryCapExceeded;\n197: }\n198: \n199: interface CategorizedFiles {\n200:   toIndex: string[];\n201:   toUpdate: string[];\n202:   toSkip: string[];\n203:   toDelete: string[];\n204: }\n205: \n206: interface ScanKeyOptions {\n207:   spec_folder: string | null;\n208:   force: boolean;\n209:   incremental: boolean;\n210:   include_constitutional: boolean;\n211:   include_spec_docs: boolean;\n212: }\n213: \n214: interface RecordDeleteResult {\n215:   deleted: number;\n216:   failed: number;\n217:   actions: StatediffAction[];\n218: }\n219: \n220: interface OrphanSweepDeleteResult {\n221:   swept: number;\n222:   failed: number;\n223:   scannedRows: number;\n224:   nextCursor: number | null;\n225:   actions: StatediffAction[];\n226: }\n227: \n228: interface OrphanSweepCandidates {\n229:   swept: number;\n230:   nextCursor: number | null;\n231:   scannedRows: number;\n232:   orphanRecordIds?: number[];\n233: }\n234: \n235: const ORPHAN_SWEEP_LIMIT = 200;\n236: \n237: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n238: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n239: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n240: // event-loop block from a phase that is merely slow but yields — the two need\n241: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n242: const LOOP_LAG_SAMPLE_MS = 250;\n243: const LOOP_LAG_WARN_MS = 1000;\n244: \n245: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n246:   return {\n247:     sentinelPresent: false,\n248:     attempted: false,\n249:     completed: 0,\n250:     failed: 0,\n251:     skipped: 0,\n252:     cleared: false,\n253:     error: null,\n254:   };\n255: }\n256: \n257: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n258:   try {\n259:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n260:       source: 'memory_index_scan',\n261:       actor: 'mcp:memory_index_scan',\n262:     });\n263:     return {\n264:       sentinelPresent: repair.sentinelPresent,\n265:       attempted: repair.attempted,\n266:       completed: repair.summary?.completed.length ?? 0,\n267:       failed: repair.summary?.failed.length ?? 0,\n268:       skipped: repair.summary?.skipped.length ?? 0,\n269:       cleared: repair.cleared,\n270:       error: repair.error,\n271:     };\n272:   } catch (error: unknown) {\n273:     return {\n274:       ...emptyCheckpointRepairReport(),\n275:       sentinelPresent: true,\n276:       attempted: true,\n277:       error: toErrorMessage(error),\n278:     };\n279:   }\n280: }\n281: \n282: function createScanKey(options: ScanKeyOptions): string {\n283:   const normalized = {\n284:     spec_folder: options.spec_folder ?? null,\n285:     force: !!options.force,\n286:     incremental: !!options.incremental,\n287:     include_constitutional: !!options.include_constitutional,\n288:     include_spec_docs: !!options.include_spec_docs,\n289:   };\n290: \n291:   return createHash('sha256')\n292:     .update(JSON.stringify(normalized))\n293:     .digest('hex')\n294:     .slice(0, 16);\n295: }\n296: \n297: interface ScanArgs {\n298:   specFolder?: string | null;\n299:   force?: boolean;\n300:   includeConstitutional?: boolean;\n301:   includeSpecDocs?: boolean;\n302:   incremental?: boolean;\n303:   // Opt-in: run the scan as a background job and return a jobId immediately.\n304:   background?: boolean;\n305:   tenantId?: string;\n306:   userId?: string;\n307:   agentId?: string;\n308:   sessionId?: string;\n309:   provenanceSource?: string;\n310:   provenanceActor?: string;\n311:   governedAt?: string;\n312:   retentionPolicy?: 'keep' | 'ephemeral';\n313:   deleteAfter?: string;\n314: }\n315: \n316: /* ───────────────────────────────────────────────────────────────\n317:    5. SHARED INDEXING LOGIC\n318: ──────────────────────────────────────────────────────────────── */\n319: \n320: import { indexMemoryFile } from './memory-save.js';\n321: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n322: import type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n323: \n324: /** Index a single memory file, delegating to the shared indexMemoryFile logic */\n325: async function indexSingleFile(\n326:   filePath: string,\n327:   force: boolean = false,\n328:   options?: {\n329:     qualityGateMode?: 'enforce' | 'warn-only';\n330:     fromScan?: boolean;\n331:     asyncEmbedding?: boolean;\n332:     governance?: GovernanceDecision;\n333:     provenance?: WriteProvenanceContext;\n334:   },\n335: ): Promise<IndexResult> {\n336:   return indexMemoryFile(filePath, {\n337:     force,\n338:     qualityGateMode: options?.qualityGateMode,\n339:     fromScan: options?.fromScan,\n340:     asyncEmbedding: options?.asyncEmbedding,\n341:     governance: options?.governance,\n342:     provenance: options?.provenance,\n343:   });\n344: }\n345: \n346: /* ───────────────────────────────────────────────────────────────\n347:    6. MEMORY INDEX SCAN HANDLER\n348: ──────────────────────────────────────────────────────────────── */\n349: \n350: // Hooks let a background runner observe cancellation and report phase/progress.\n351: // On the synchronous path every hook is undefined, so behavior is identical.\n352: interface ScanRunContext {\n353:   isCancelled?: () => boolean;\n354:   onPhase?: (phase: string) => void;\n355:   onProgress?: (progress: { processed: number; total: number }) => void;\n356: }\n357: \n358: // Pull the envelope.data field back out of an MCP response so status can echo it.\n359: function extractEnvelopeData(response: MCPResponse): unknown {\n360:   try {\n361:     const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n362:     if (typeof text !== 'string') return null;\n363:     const parsed = JSON.parse(text) as { data?: unknown };\n364:     return parsed?.data ?? null;\n365:   } catch (_error: unknown) {\n366:     return null;\n367:   }\n368: }\n369: \n370: // Persisted payload for debugging: scan shape only, no governance identifiers.\n371: function redactScanArgs(args: ScanArgs): Record<string, unknown> {\n372:   return {\n373:     specFolder: args.specFolder ?? null,\n374:     force: !!args.force,\n375:     includeConstitutional: args.includeConstitutional !== false,\n376:     includeSpecDocs: args.includeSpecDocs !== false,\n377:     incremental: args.incremental !== false,\n378:     background: true,\n379:   };\n380: }\n381: \n382: function cancelledScanEnvelope(scanKey: string): MCPResponse {\n383:   return createMCPSuccessResponse({\n384:     tool: 'memory_index_scan',\n385:     summary: 'Index scan cancelled before completion',\n386:     data: { status: 'cancelled', cancelled: true, scanKey },\n387:     hints: ['The scan was cancelled via memory_index_scan_cancel'],\n388:   });\n389: }\n390: \n391: /** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\n392: async function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n393:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n394:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n395:   if (restoreBarrier) {\n396:     recordMaintenanceRun('memory_index_scan', { status: 'error' });\n397:     return createMCPErrorResponse({\n398:       tool: 'memory_index_scan',\n399:       error: restoreBarrier.message,\n400:       code: restoreBarrier.code,\n401:       recovery: {\n402:         hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n403:         actions: ['Wait for the restore to finish', 'Retry the index scan'],\n404:         severity: 'warning',\n405:       },\n406:     });\n407:   }\n408: \n409:   const {\n410:     specFolder: spec_folder = null,\n411:     force = false,\n412:     includeConstitutional: include_constitutional = true,\n413:     includeSpecDocs: include_spec_docs = true,\n414:     incremental = true\n415:   } = args;\n416:   const scanKey = createScanKey({\n417:     spec_folder,\n418:     force,\n419:     incremental,\n420:     include_constitutional,\n421:     include_spec_docs,\n422:   });\n423:   const governedIngest = requiresGovernedIngest(args);\n424:   const governanceDecision = validateGovernedIngest(args);\n425:   if (!governanceDecision.allowed) {\n426:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n427:   }\n428: \n429:   // Pre-flight dimension check\n430:   try {\n431:     const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n432:     if (profile) {\n433:       console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n434:     }\n435:   } catch (dimCheckError: unknown) {\n436:     const message = toErrorMessage(dimCheckError);\n437:     console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n438:   }\n439: \n440:   await checkDatabaseUpdated();\n441: \n442:   // Atomic scan lease check.\n443:   // Reserve scan_started_at up front to avoid check-then-set race windows.\n444:   const now = Date.now();\n445:   const lease = await acquireIndexScanLease({\n446:     now,\n447:     cooldownMs: INDEX_SCAN_COOLDOWN,\n448:   });\n449:   if (!lease.acquired) {\n450:     let message: string;\n451:     if (lease.reason === 'lease_active') {\n452:       message = 'A scan is already in progress; this call coalesced onto it.';\n453:     } else if (lease.reason === 'contention') {\n454:       message = 'The index DB is briefly locked by another writer; retry shortly.';\n455:     } else {\n456:       message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n457:     }\n458:     recordMaintenanceRun('memory_index_scan', {\n459:       status: 'coalesced',\n460:       counts: { waitSeconds: lease.waitSeconds },\n461:       staleCandidates: 0,\n462:     });\n463:     return createMCPSuccessResponse({\n464:       tool: 'memory_index_scan',\n465:       summary: message,\n466:       data: {\n467:         success: true,\n468:         coalesced: true,\n469:         status: 'coalesced',\n470:         reason: lease.reason,\n471:         scanKey,\n472:         waitSeconds: lease.waitSeconds,\n473:         nextPollAfterMs: lease.waitSeconds * 1000,\n474:         message,\n475:       },\n476:       hints: [message],\n477:     });\n478:   }\n479: \n480:   let scanLeaseReleased = false;\n481:   const releaseScanLease = async (): Promise<void> => {\n482:     if (scanLeaseReleased) return;\n483:     scanLeaseReleased = true;\n484:     await completeIndexScanLease(Date.now());\n485:   };\n486: \n487:   const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n488: \n489:   // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n490:   // processBatches() runs all batches sequentially and may exceed the lease expiry\n491:   // window (each batch waits on embedding/API latency). Without a periodic refresh\n492:   // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n493:   // launch a second parallel scan. Refresh well inside the expiry window (a third of\n494:   // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n495:   // from holding the event loop open at shutdown; finally clears it before release.\n496:   const leaseExpiryMs = lease.leaseExpiryMs;\n497:   const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n498:   let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n499: \n500:   // Background scans pass an onPhase hook; the synchronous foreground path does not.\n501:   // Gate diagnostics on it so the synchronous path's behavior stays identical.\n502:   const instrument = typeof ctx.onPhase === 'function';\n503:   let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n504:   let maxLoopLagMs = 0;\n505: \n506:   try {\n507:   leaseHeartbeat = setInterval(() => {\n508:     refreshScanLease();\n509:   }, leaseHeartbeatMs);\n510:   leaseHeartbeat.unref?.();\n511: \n512:   if (instrument) {\n513:     let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n514:     loopLagTimer = setInterval(() => {\n515:       const sampledAt = Date.now();\n516:       const lag = sampledAt - loopLagExpectedAt;\n517:       loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n518:       if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n519:       if (lag > LOOP_LAG_WARN_MS) {\n520:         // A late sample means the loop was blocked since the prior tick; logged\n521:         // adjacent to the phase=... line of whatever phase just ran, so the daemon\n522:         // log timeline fingers the blocking phase.\n523:         console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n524:       }\n525:     }, LOOP_LAG_SAMPLE_MS);\n526:     loopLagTimer.unref?.();\n527:   }\n528: \n529:   if (ctx.isCancelled?.()) {\n530:     await releaseScanLease();\n531:     return cancelledScanEnvelope(scanKey);\n532:   }\n533:   ctx.onPhase?.('discovering');\n534: \n535:   const workspacePath: string = DEFAULT_BASE_PATH;\n536: \n537:   const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n538:   const specDocFiles = include_spec_docs\n539:     ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n540:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n541:   const graphMetadataFiles = include_spec_docs\n542:     ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n543:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n544:   const walkerWarnings = [\n545:     ...discoveryWarnings(specDocFiles),\n546:     ...discoveryWarnings(graphMetadataFiles),\n547:   ];\n548:   const walkerCapExceeded = mergeDiscoveryCapExceeded(\n549:     discoveryCaps(specDocFiles),\n550:     discoveryCaps(graphMetadataFiles),\n551:   );\n552: \n553:   const canonicalKeyCache = new Map<string, string>();\n554:   const getCachedKey = (filePath: string): string => {\n555:     const cached = canonicalKeyCache.get(filePath);\n556:     if (cached) {\n557:       return cached;\n558:     }\n559: \n560:     const canonicalKey = getCanonicalPathKey(filePath);\n561:     canonicalKeyCache.set(filePath, canonicalKey);\n562:     return canonicalKey;\n563:   };\n564: \n565:   const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n566:   const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n567:   const seenCanonicalFiles = new Set<string>();\n568:   const files: string[] = [];\n569: \n570:   for (const filePath of mergedFiles) {\n571:     const canonicalKey = getCachedKey(filePath);\n572:     if (seenCanonicalFiles.has(canonicalKey)) {\n573:       continue;\n574:     }\n575:     seenCanonicalFiles.add(canonicalKey);\n576:     files.push(filePath);\n577:   }\n578: \n579:   const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n580:   if (dedupDuplicatesSkipped > 0) {\n581:     console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n582:   }\n583: \n584:   const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n585:     if (recordIds.length === 0) {\n586:       return { deleted: 0, failed: 0, actions: [] };\n587:     }\n588: \n589:     let deleted = 0;\n590:     let failed = 0;\n591:     const actions: StatediffAction[] = [];\n592: \n593:     for (const staleRecordId of recordIds) {\n594:       try {\n595:         const database = vectorIndex.getDb();\n596:         const staleSnapshot = database?.prepare(\n597:           'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n598:         ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n599: \n600:         if (database) {\n601:           causalEdges.init(database);\n602:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n603:             reason: 'memory_index stale record cleanup',\n604:             command: 'memory-index.deleteIndexedRecordIds',\n605:             restoreContext: {\n606:               memoryId: staleRecordId,\n607:               specFolder: staleSnapshot?.spec_folder ?? null,\n608:               filePath: staleSnapshot?.file_path ?? null,\n609:             },\n610:           });\n611:         }\n612: \n613:         if (vectorIndex.deleteMemory(staleRecordId)) {\n614:           deleted++;\n615:           actions.push(createStatediffAction('delete', {\n616:             target: 'memory_index',\n617:             key: String(staleRecordId),\n618:             sourceOperation: 'scan',\n619:             oldStateHash: null,\n620:             newStateHash: null,\n621:             metadata: {\n622:               filePath: staleSnapshot?.file_path ?? null,\n623:               specFolder: staleSnapshot?.spec_folder ?? null,\n624:             },\n625:           }));\n626:           // Record DELETE history only after confirmed deletion.\n627:           try {\n628:             recordHistory(\n629:               staleRecordId,\n630:               'DELETE',\n631:               staleSnapshot?.file_path ?? null,\n632:               null,\n633:               'mcp:memory_index_scan',\n634:               staleSnapshot?.spec_folder ?? null,\n635:             );\n636:           } catch (_histErr: unknown) {\n637:             // History recording is best-effort\n638:           }\n639:         } else {\n640:           failed++;\n641:         }\n642:       } catch (_error: unknown) {\n643:         failed++;\n644:       }\n645:     }\n646: \n647:     return { deleted, failed, actions };\n648:   };\n649: \n650:   const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n651:     if (paths.length === 0) {\n652:       return { deleted: 0, failed: 0, actions: [] };\n653:     }\n654: \n655:     return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n656:   };\n657: \n658:   const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n659:     if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n660:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n661:     }\n662: \n663:     const sweepOrphanIndexRows = (incrementalIndex as {\n664:       sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n665:     }).sweepOrphanIndexRows;\n666: \n667:     if (typeof sweepOrphanIndexRows !== 'function') {\n668:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n669:     }\n670: \n671:     const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n672:     const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n673:     return {\n674:       swept: deleteResult.deleted,\n675:       failed: deleteResult.failed,\n676:       scannedRows: sweep.scannedRows,\n677:       nextCursor: sweep.nextCursor,\n678:       actions: deleteResult.actions,\n679:     };\n680:   };\n681: \n682:   const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n683:     try {\n684:       runPostMutationHooks('scan', { ...context, statediffActions: actions });\n685:     } catch (error: unknown) {\n686:       console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n687:     }\n688:   };\n689: \n690:   const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n691:     result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n692:   );\n693: \n694:   const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n695:     target: 'memory_index',\n696:     key: 'trigger-embedding-backfill',\n697:     sourceOperation: 'scan',\n698:     metadata: {\n699:       readyRows: result.readyRows,\n700:       failedRows: result.failedRows,\n701:       pendingRows: result.pendingRows,\n702:     },\n703:   });\n704: \n705:   const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n706:     if (actions.length === 0) {\n707:       return;\n708:     }\n709:     results.aliasConflicts = detectAliasConflictsFromIndex();\n710:     results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n711:   };\n712: \n713:   const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n714:     try {\n715:       const repairResult = await repairIncompleteMarkers(\n716:         { database: requireDb(), plannerMode: 'full-auto' },\n717:         { limit: BATCH_SIZE },\n718:       );\n719:       if (repairResult.failed > 0) {\n720:         console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n721:       }\n722:       return repairResult.repaired;\n723:     } catch (error: unknown) {\n724:       console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n725:       return 0;\n726:     }\n727:   };\n728: \n729:   const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n730:     if (!isMemoryIdempotencyEnabled()) {\n731:       return 0;\n732:     }\n733:     try {\n734:       const database = requireDb();\n735:       const rows = database.prepare(`\n736:         SELECT id, spec_folder, title, content_text, content_hash,\n737:                tenant_id, user_id, agent_id, session_id\n738:         FROM memory_index\n739:         WHERE parent_id IS NULL\n740:           AND embedding_status = 'success'\n741:           AND content_text IS NOT NULL\n742:           AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n743:         ORDER BY id ASC\n744:         LIMIT ?\n745:       `).all(BATCH_SIZE) as Array<{\n746:         id: number;\n747:         spec_folder: string;\n748:         title: string | null;\n749:         content_text: string;\n750:         content_hash: string | null;\n751:         tenant_id: string | null;\n752:         user_id: string | null;\n753:         agent_id: string | null;\n754:         session_id: string | null;\n755:       }>;\n756:       let repaired = 0;\n757:       for (const row of rows) {\n758:         try {\n759:           const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n760:           const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n761:           recordNearDuplicateCheck({\n762:             database,\n763:             memoryId: row.id,\n764:             specFolder: row.spec_folder,\n765:             contentHash: row.content_hash,\n766:             embedding,\n767:             scope: {\n768:               tenantId: row.tenant_id,\n769:               userId: row.user_id,\n770:               agentId: row.agent_id,\n771:               sessionId: row.session_id,\n772:             },\n773:           });\n774:           repaired++;\n775:         } catch (error: unknown) {\n776:           console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n777:         }\n778:       }\n779:       return repaired;\n780:     } catch (error: unknown) {\n781:       console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n782:       return 0;\n783:     }\n784:   };\n785: \n786:   // Time each un-yielded tail phase: because these phases do not yield, their\n787:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n788:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n789:   // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n790:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n791:     ctx.onPhase?.(phase);\n792:     if (!instrument) {\n793:       return await fn();\n794:     }\n795:     const startedAt = Date.now();\n796:     try {\n797:       return await fn();\n798:     } finally {\n799:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n800:     }\n801:   };\n802: \n803:   if (files.length === 0) {\n804:     let staleDeleted = 0;\n805:     let staleDeleteFailed = 0;\n806:     const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n807:     const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n808:     const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n809: \n810:     if (incremental && !force) {\n811:       const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n812:       const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n813:       staleDeleted = staleDeleteResult.deleted;\n814:       staleDeleteFailed = staleDeleteResult.failed;\n815:       if (staleDeleted > 0) {\n816:         runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n817:       }\n818:     }\n819: \n820:     const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n821:       runTriggerEmbeddingBackfill(requireDb(), {\n822:         isCancelled: () => ctx.isCancelled?.() ?? false,\n823:       }));\n824: \n825:     if (orphanSweepResult.swept > 0) {\n826:       runScanInvalidationHooks({\n827:         orphanSwept: orphanSweepResult.swept,\n828:         orphanSweepFailed: orphanSweepResult.failed,\n829:         operation: 'orphan-sweep',\n830:       }, orphanSweepResult.actions);\n831:     }\n832:     if (postInsertEnrichmentRepaired > 0) {\n833:       runScanInvalidationHooks({\n834:         postInsertEnrichmentRepaired,\n835:         operation: 'post-insert-enrichment-repair',\n836:       }, [createStatediffAction('upsert', {\n837:         target: 'graph_edge',\n838:         key: 'post-insert-enrichment-repair',\n839:         sourceOperation: 'scan',\n840:         metadata: { postInsertEnrichmentRepaired },\n841:       })]);\n842:     }\n843:     if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n844:       runScanInvalidationHooks({\n845:         triggerEmbeddingBackfill,\n846:         operation: 'trigger-embedding-backfill',\n847:       }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n848:     }\n849: \n850:     recordMaintenanceRun('memory_index_scan', {\n851:       status: 'success',\n852:       counts: {\n853:         scanned: 0,\n854:         indexed: 0,\n855:         updated: 0,\n856:         unchanged: 0,\n857:         failed: 0,\n858:         staleDeleted,\n859:         staleDeleteFailed,\n860:         orphanSwept: orphanSweepResult.swept,\n861:       },\n862:       staleCandidates: staleDeleted + staleDeleteFailed,\n863:     });\n864:     await releaseScanLease();\n865:     return createMCPSuccessResponse({\n866:       tool: 'memory_index_scan',\n867:       summary: 'No memory files found',\n868:       data: {\n869:         status: 'complete',\n870:         scanKey,\n871:         scanned: 0,\n872:         indexed: 0,\n873:         updated: 0,\n874:         unchanged: 0,\n875:         failed: 0,\n876:         staleDeleted,\n877:         staleDeleteFailed,\n878:         postInsertEnrichmentRepaired,\n879:         nearDuplicateRepaired,\n880:         triggerEmbeddingBackfill,\n881:         orphanSwept: orphanSweepResult.swept,\n882:         orphanSweepFailed: orphanSweepResult.failed,\n883:         orphanSweepScanned: orphanSweepResult.scannedRows,\n884:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n885:         checkpointRepair,\n886:         warnings: walkerWarnings,\n887:         capExceeded: walkerCapExceeded,\n888:       },\n889:       hints: [\n890:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n891:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n892:         ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n893:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n894:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n895:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n896:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n897:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n898:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n899:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n900:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n901:         'Constitutional files go in .opencode/skills/*/constitutional/'\n902:       ]\n903:     });\n904:   }\n905: \n906:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n907: \n908:   const results: ScanResults = {\n909:     scanned: files.length,\n910:     indexed: 0,\n911:     updated: 0,\n912:     unchanged: 0,\n913:     failed: 0,\n914:     deferred: 0,\n915:     skipped_mtime: 0,\n916:     mtimeUpdates: 0,\n917:     staleDeleted: 0,\n918:     staleDeleteFailed: 0,\n919:     postInsertEnrichmentRepaired: 0,\n920:     nearDuplicateRepaired: 0,\n921:     orphanSwept: 0,\n922:     orphanSweepFailed: 0,\n923:     orphanSweepScanned: 0,\n924:     orphanSweepNextCursor: null,\n925:     files: [],\n926:     constitutional: {\n927:       found: constitutionalFiles.length,\n928:       indexed: 0,\n929:       alreadyIndexed: 0\n930:     },\n931:     incremental: {\n932:       enabled: incremental && !force,\n933:       fast_path_skips: 0,\n934:       mtime_changed: 0,\n935:       metadataPromoter: {\n936:         processed: 0,\n937:         resolved: 0,\n938:         inserted: 0,\n939:         skippedManual: 0,\n940:         staleTombstoned: 0,\n941:         staleDeleted: 0,\n942:         warnings: 0,\n943:       }\n944:     },\n945:     dedup: {\n946:       inputTotal: mergedFiles.length,\n947:       uniqueTotal: files.length,\n948:       duplicatesSkipped: dedupDuplicatesSkipped,\n949:     },\n950:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n951:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n952:     checkpointRepair,\n953:     warnings: walkerWarnings,\n954:     capExceeded: walkerCapExceeded,\n955:   };\n956:   const scanAppliedActions: StatediffAction[] = [];\n957: \n958:   let filesToIndex: string[] = files;\n959:   let filesToDelete: string[] = [];\n960: \n961:   if (incremental && !force) {\n962:     const startCategorize = Date.now();\n963:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n964: \n965:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n966:     filesToDelete = categorized.toDelete;\n967: \n968:     results.unchanged = categorized.toSkip.length;\n969:     results.skipped_mtime = categorized.toSkip.length;\n970:     results.incremental.fast_path_skips = categorized.toSkip.length;\n971:     results.incremental.mtime_changed = categorized.toUpdate.length;\n972: \n973:     for (const unchangedPath of categorized.toSkip) {\n974:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n975:         results.constitutional.alreadyIndexed++;\n976:       }\n977:     }\n978: \n979:     const categorizeTime = Date.now() - startCategorize;\n980:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n981:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n982:   }\n983: \n984:   // Attempt move reconciliation before full delete+reindex cycle.\n985:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n986:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n987:   // stored-document_type cross-checks; the matched row is updated in place.\n988:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n989:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n990:     if (moveResult.reconciled.length > 0) {\n991:       results.moveReconciled = moveResult.reconciled.length;\n992:       filesToDelete = moveResult.filteredToDelete;\n993:       filesToIndex = moveResult.filteredToIndex;\n994:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n995:     }\n996:   }\n997: \n998:   const plannedScanActions = [\n999:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n1000:       target: 'memory_index',\n1001:       key: getCachedKey(filePath),\n1002:       sourceOperation: 'scan',\n1003:       metadata: { filePath },\n1004:     })),\n1005:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n1006:       target: 'memory_index',\n1007:       key: getCachedKey(filePath),\n1008:       sourceOperation: 'scan',\n1009:       metadata: { filePath },\n1010:     })),\n1011:   ];\n1012:   if (plannedScanActions.length > 0) {\n1013:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n1014:   }\n1015: \n1016:   // Track successfully indexed files for post-indexing mtime update.\n1017:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n1018:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n1019:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n1020:   // Before indexing would cause silent data loss — a failed file would be\n1021:   // Marked \"already indexed\" and permanently skipped.\n1022:   const successfullyIndexedFiles: string[] = [];\n1023:   const scanBatchSize = BATCH_SIZE;\n1024: \n1025:   ctx.onPhase?.('indexing');\n1026:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1027: \n1028:   if (filesToIndex.length > 0) {\n1029:     let processedInScan = 0;\n1030:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1031:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1032:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1033:       if (ctx.isCancelled?.()) {\n1034:         return { status: 'cancelled' } as IndexResult;\n1035:       }\n1036:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1037:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1038:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1039:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1040:       // spec docs and pass them through warn-only mode so they index against the same\n1041:       // pipeline without the document-evidence requirements.\n1042:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1043:       // During force reindex, use warn-only for all files — the goal is to index\n1044:       // everything that has valid frontmatter, not to enforce template contracts on\n1045:       // older files created before current templates were established.\n1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1047:       const indexResult = await indexSingleFile(filePath, force, {\n1048:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1049:         fromScan: true,\n1050:         asyncEmbedding: true,\n1051:         governance: governedIngest ? governanceDecision : undefined,\n1052:       });\n1053:       processedInScan += 1;\n1054:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1055:       return indexResult;\n1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1057: \n1058:     for (let i = 0; i < batchResults.length; i++) {\n1059:       const result = batchResults[i];\n1060:       const filePath = filesToIndex[i];\n1061:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1062: \n1063:       if (result.error) {\n1064:         results.failed++;\n1065:         results.files.push({\n1066:           file: path.basename(filePath),\n1067:           filePath,\n1068:           status: 'failed',\n1069:           error: result.error,\n1070:           errorDetail: result.errorDetail\n1071:         });\n1072:       } else if (isIndexResult(result)) {\n1073:         const isSuccessfulStatus =\n1074:           result.status === 'success' ||\n1075:           result.status === 'indexed' ||\n1076:           result.status === 'updated' ||\n1077:           result.status === 'unchanged' ||\n1078:           result.status === 'reinforced' ||\n1079:           result.status === 'duplicate' ||\n1080:           result.status === 'deferred';\n1081:         // A cancelled file was never indexed and was never going to be: counting it\n1082:         // as a failure would attribute an operator-requested stop to a file error.\n1083:         // It is neither success nor failure, so it falls through both tallies.\n1084:         if (!isSuccessfulStatus && result.status !== 'cancelled') {\n1085:           results.failed++;\n1086:         }\n1087: \n1088:         if (result.status === 'indexed') {\n1089:           results.indexed++;\n1090:           successfullyIndexedFiles.push(filePath);\n1091:           scanAppliedActions.push(createStatediffAction('insert', {\n1092:             target: 'memory_index',\n1093:             key: String(result.id ?? getCachedKey(filePath)),\n1094:             sourceOperation: 'scan',\n1095:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1096:           }));\n1097:         } else if (result.status === 'updated') {\n1098:           results.updated++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('upsert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         } else if (result.status === 'unchanged') {\n1107:           results.unchanged++;\n1108:           successfullyIndexedFiles.push(filePath);\n1109:         } else if (result.status === 'reinforced') {\n1110:           results.updated++;\n1111:           successfullyIndexedFiles.push(filePath);\n1112:           scanAppliedActions.push(createStatediffAction('upsert', {\n1113:             target: 'memory_index',\n1114:             key: String(result.id ?? getCachedKey(filePath)),\n1115:             sourceOperation: 'scan',\n1116:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1117:           }));\n1118:         } else if (result.status === 'duplicate') {\n1119:           results.unchanged++;\n1120:           successfullyIndexedFiles.push(filePath);\n1121:         } else if (result.status === 'deferred') {\n1122:           results.indexed++;\n1123:           results.deferred++;\n1124:           successfullyIndexedFiles.push(filePath);\n1125:           scanAppliedActions.push(createStatediffAction('insert', {\n1126:             target: 'memory_index',\n1127:             key: String(result.id ?? getCachedKey(filePath)),\n1128:             sourceOperation: 'scan',\n1129:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1130:           }));\n1131:         }\n1132: \n1133:         if (isConstitutional) {\n1134:           if (result.status === 'indexed') {\n1135:             results.constitutional.indexed++;\n1136:           } else if (result.status === 'unchanged') {\n1137:             results.constitutional.alreadyIndexed++;\n1138:           }\n1139:         }\n1140: \n1141:         if (result.status !== 'unchanged') {\n1142:           const rejectionDetail = !isSuccessfulStatus\n1143:             ? {\n1144:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1145:                   ? { rejectionCode: result.rejectionCode }\n1146:                   : {}),\n1147:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1148:                   ? { rejectionReason: result.rejectionReason }\n1149:                   : (typeof result.message === 'string' && result.message.length > 0\n1150:                     ? { rejectionReason: result.message }\n1151:                     : {})),\n1152:                 ...(typeof result.error === 'string' && result.error.length > 0\n1153:                   ? { error: result.error }\n1154:                   : {}),\n1155:               }\n1156:             : {};\n1157: \n1158:           results.files.push({\n1159:             file: path.basename(filePath),\n1160:             filePath,\n1161:             specFolder: result.specFolder,\n1162:             status: result.status,\n1163:             id: result.id,\n1164:             isConstitutional,\n1165:             ...rejectionDetail,\n1166:           });\n1167:         }\n1168:       } else {\n1169:         results.failed++;\n1170:         results.files.push({\n1171:           file: path.basename(filePath),\n1172:           filePath,\n1173:           status: 'failed',\n1174:           error: 'Unexpected batch result shape',\n1175:           errorDetail: JSON.stringify(result),\n1176:         });\n1177:       }\n1178:     }\n1179:   }\n1180: \n1181:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1182:   // Failed files keep their old mtime so they are retried on next scan.\n1183:   // This is the ONLY place where scan-triggered mtime updates occur.\n1184:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1185:   // Which rolls back atomically on failure — a complementary safety mechanism.\n1186:   if (successfullyIndexedFiles.length > 0) {\n1187:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1188:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1189:   }\n1190: \n1191:   if (include_spec_docs) {\n1192:     const database = requireDb();\n1193:     let promoterYieldCount = 0;\n1194:     for (const fileResult of results.files) {\n1195:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1196:       // that is the whole corpus, so without a periodic macrotask yield the event\n1197:       // loop is starved for the duration and no IPC (status, cancel, health,\n1198:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1199:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1200:       // inside one, so atomicity on the shared connection is preserved.\n1201:       if (++promoterYieldCount % 200 === 0) {\n1202:         if (ctx.isCancelled?.()) {\n1203:           return cancelledScanEnvelope(scanKey);\n1204:         }\n1205:         await new Promise<void>((resolve) => setImmediate(resolve));\n1206:       }\n1207:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1208:         continue;\n1209:       }\n1210:       try {\n1211:         const promotion = promoteMetadataEdges(database, {\n1212:           memoryId: fileResult.id,\n1213:           filePath: fileResult.filePath,\n1214:         });\n1215:         results.incremental.metadataPromoter.processed += promotion.processed;\n1216:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1217:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1218:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1219:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1220:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1221:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1222:         for (const warning of promotion.warnings) {\n1223:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1224:         }\n1225:       } catch (error: unknown) {\n1226:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1227:       }\n1228:     }\n1229:   }\n1230: \n1231:   if (ctx.isCancelled?.()) {\n1232:     return cancelledScanEnvelope(scanKey);\n1233:   }\n1234:   ctx.onPhase?.('post-processing');\n1235: \n1236:   if (filesToDelete.length > 0) {\n1237:     if (results.failed === 0) {\n1238:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1239:       results.staleDeleted = staleDeleteResult.deleted;\n1240:       results.staleDeleteFailed = staleDeleteResult.failed;\n1241:       scanAppliedActions.push(...staleDeleteResult.actions);\n1242:     } else {\n1243:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1244:     }\n1245:   }\n1246: \n1247:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1248:   results.orphanSwept = orphanSweepResult.swept;\n1249:   results.orphanSweepFailed = orphanSweepResult.failed;\n1250:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1251:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1252:   scanAppliedActions.push(...orphanSweepResult.actions);\n1253: \n1254:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1255:   if (results.postInsertEnrichmentRepaired > 0) {\n1256:     scanAppliedActions.push(createStatediffAction('upsert', {\n1257:       target: 'graph_edge',\n1258:       key: 'post-insert-enrichment-repair',\n1259:       sourceOperation: 'scan',\n1260:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1261:     }));\n1262:   }\n1263: \n1264:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1265:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1266:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1267:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1268:   }\n1269:   results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1270: \n1271:   // Create causal chains between spec folder documents.\n1272:   // Includes deferred indexing outcomes and incremental single-file updates.\n1273:   if (include_spec_docs) {\n1274:     try {\n1275:       // Determine which spec folders had spec document changes in this scan.\n1276:       // We use parsed document type (not basename) to avoid false positives\n1277:       // From memory/plan.md or similar filenames.\n1278:       const affectedSpecFolders = new Set<string>();\n1279:       for (const fileResult of results.files) {\n1280:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1281:           continue;\n1282:         }\n1283: \n1284:         if (!fileResult.filePath) {\n1285:           continue;\n1286:         }\n1287: \n1288:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1289:         if (\n1290:           docType !== 'memory' &&\n1291:           docType !== 'constitutional'\n1292:         ) {\n1293:           affectedSpecFolders.add(fileResult.specFolder);\n1294:         }\n1295:       }\n1296: \n1297:       if (affectedSpecFolders.size > 0) {\n1298:         const database = requireDb();\n1299:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1300:         initCausalEdges(database);\n1301: \n1302:         // Build full per-folder document map from DB (not just this scan's files).\n1303:         const selectDocIds = database.prepare(`\n1304:           SELECT document_type, MAX(id) AS id\n1305:           FROM memory_index\n1306:           WHERE spec_folder = ?\n1307:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1308:           GROUP BY document_type\n1309:         `);\n1310: \n1311:         let chainsCreated = 0;\n1312:         let foldersProcessed = 0;\n1313:         let chainYieldCount = 0;\n1314: \n1315:         for (const folder of affectedSpecFolders) {\n\n(Output capped at 50 KB. Showing lines 1-1315. Use offset=1316 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* ───────────────────────────────────────────────────────────────\n   4. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  nearDuplicateRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields — the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. SHARED INDEXING LOGIC\n──────────────────────────────────────────────────────────────── */\n\nimport { indexMemoryFile } from './memory-save.js';\nimport type { GovernanceDecision } from '../lib/governance/scope-governance.js';\nimport type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n\n/** Index a single memory file, delegating to the shared indexMemoryFile logic */\nasync function indexSingleFile(\n  filePath: string,\n  force: boolean = false,\n  options?: {\n    qualityGateMode?: 'enforce' | 'warn-only';\n    fromScan?: boolean;\n    asyncEmbedding?: boolean;\n    governance?: GovernanceDecision;\n    provenance?: WriteProvenanceContext;\n  },\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    force,\n    qualityGateMode: options?.qualityGateMode,\n    fromScan: options?.fromScan,\n    asyncEmbedding: options?.asyncEmbedding,\n    governance: options?.governance,\n    provenance: options?.provenance,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MEMORY INDEX SCAN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n// Hooks let a background runner observe cancellation and report phase/progress.\n// On the synchronous path every hook is undefined, so behavior is identical.\ninterface ScanRunContext {\n  isCancelled?: () => boolean;\n  onPhase?: (phase: string) => void;\n  onProgress?: (progress: { processed: number; total: number }) => void;\n}\n\n// Pull the envelope.data field back out of an MCP response so status can echo it.\nfunction extractEnvelopeData(response: MCPResponse): unknown {\n  try {\n    const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n    if (typeof text !== 'string') return null;\n    const parsed = JSON.parse(text) as { data?: unknown };\n    return parsed?.data ?? null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\n// Persisted payload for debugging: scan shape only, no governance identifiers.\nfunction redactScanArgs(args: ScanArgs): Record<string, unknown> {\n  return {\n    specFolder: args.specFolder ?? null,\n    force: !!args.force,\n    includeConstitutional: args.includeConstitutional !== false,\n    includeSpecDocs: args.includeSpecDocs !== false,\n    incremental: args.incremental !== false,\n    background: true,\n  };\n}\n\nfunction cancelledScanEnvelope(scanKey: string): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: 'Index scan cancelled before completion',\n    data: { status: 'cancelled', cancelled: true, scanKey },\n    hints: ['The scan was cancelled via memory_index_scan_cancel'],\n  });\n}\n\n/** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\nasync function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    recordMaintenanceRun('memory_index_scan', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      recovery: {\n        hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the index scan'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    specFolder: spec_folder = null,\n    force = false,\n    includeConstitutional: include_constitutional = true,\n    includeSpecDocs: include_spec_docs = true,\n    incremental = true\n  } = args;\n  const scanKey = createScanKey({\n    spec_folder,\n    force,\n    incremental,\n    include_constitutional,\n    include_spec_docs,\n  });\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  // Pre-flight dimension check\n  try {\n    const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n    if (profile) {\n      console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n    }\n  } catch (dimCheckError: unknown) {\n    const message = toErrorMessage(dimCheckError);\n    console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n  }\n\n  await checkDatabaseUpdated();\n\n  // Atomic scan lease check.\n  // Reserve scan_started_at up front to avoid check-then-set race windows.\n  const now = Date.now();\n  const lease = await acquireIndexScanLease({\n    now,\n    cooldownMs: INDEX_SCAN_COOLDOWN,\n  });\n  if (!lease.acquired) {\n    let message: string;\n    if (lease.reason === 'lease_active') {\n      message = 'A scan is already in progress; this call coalesced onto it.';\n    } else if (lease.reason === 'contention') {\n      message = 'The index DB is briefly locked by another writer; retry shortly.';\n    } else {\n      message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n    }\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'coalesced',\n      counts: { waitSeconds: lease.waitSeconds },\n      staleCandidates: 0,\n    });\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: message,\n      data: {\n        success: true,\n        coalesced: true,\n        status: 'coalesced',\n        reason: lease.reason,\n        scanKey,\n        waitSeconds: lease.waitSeconds,\n        nextPollAfterMs: lease.waitSeconds * 1000,\n        message,\n      },\n      hints: [message],\n    });\n  }\n\n  let scanLeaseReleased = false;\n  const releaseScanLease = async (): Promise<void> => {\n    if (scanLeaseReleased) return;\n    scanLeaseReleased = true;\n    await completeIndexScanLease(Date.now());\n  };\n\n  const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n\n  // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n  // processBatches() runs all batches sequentially and may exceed the lease expiry\n  // window (each batch waits on embedding/API latency). Without a periodic refresh\n  // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n  // launch a second parallel scan. Refresh well inside the expiry window (a third of\n  // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n  // from holding the event loop open at shutdown; finally clears it before release.\n  const leaseExpiryMs = lease.leaseExpiryMs;\n  const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n  let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n\n  // Background scans pass an onPhase hook; the synchronous foreground path does not.\n  // Gate diagnostics on it so the synchronous path's behavior stays identical.\n  const instrument = typeof ctx.onPhase === 'function';\n  let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n  let maxLoopLagMs = 0;\n\n  try {\n  leaseHeartbeat = setInterval(() => {\n    refreshScanLease();\n  }, leaseHeartbeatMs);\n  leaseHeartbeat.unref?.();\n\n  if (instrument) {\n    let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n    loopLagTimer = setInterval(() => {\n      const sampledAt = Date.now();\n      const lag = sampledAt - loopLagExpectedAt;\n      loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n      if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n      if (lag > LOOP_LAG_WARN_MS) {\n        // A late sample means the loop was blocked since the prior tick; logged\n        // adjacent to the phase=... line of whatever phase just ran, so the daemon\n        // log timeline fingers the blocking phase.\n        console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n      }\n    }, LOOP_LAG_SAMPLE_MS);\n    loopLagTimer.unref?.();\n  }\n\n  if (ctx.isCancelled?.()) {\n    await releaseScanLease();\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('discovering');\n\n  const workspacePath: string = DEFAULT_BASE_PATH;\n\n  const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n  const specDocFiles = include_spec_docs\n    ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const graphMetadataFiles = include_spec_docs\n    ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const walkerWarnings = [\n    ...discoveryWarnings(specDocFiles),\n    ...discoveryWarnings(graphMetadataFiles),\n  ];\n  const walkerCapExceeded = mergeDiscoveryCapExceeded(\n    discoveryCaps(specDocFiles),\n    discoveryCaps(graphMetadataFiles),\n  );\n\n  const canonicalKeyCache = new Map<string, string>();\n  const getCachedKey = (filePath: string): string => {\n    const cached = canonicalKeyCache.get(filePath);\n    if (cached) {\n      return cached;\n    }\n\n    const canonicalKey = getCanonicalPathKey(filePath);\n    canonicalKeyCache.set(filePath, canonicalKey);\n    return canonicalKey;\n  };\n\n  const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n  const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n  const seenCanonicalFiles = new Set<string>();\n  const files: string[] = [];\n\n  for (const filePath of mergedFiles) {\n    const canonicalKey = getCachedKey(filePath);\n    if (seenCanonicalFiles.has(canonicalKey)) {\n      continue;\n    }\n    seenCanonicalFiles.add(canonicalKey);\n    files.push(filePath);\n  }\n\n  const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n  if (dedupDuplicatesSkipped > 0) {\n    console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n  }\n\n  const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n    if (recordIds.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    let deleted = 0;\n    let failed = 0;\n    const actions: StatediffAction[] = [];\n\n    for (const staleRecordId of recordIds) {\n      try {\n        const database = vectorIndex.getDb();\n        const staleSnapshot = database?.prepare(\n          'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n        ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n\n        if (database) {\n          causalEdges.init(database);\n          causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n            reason: 'memory_index stale record cleanup',\n            command: 'memory-index.deleteIndexedRecordIds',\n            restoreContext: {\n              memoryId: staleRecordId,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n              filePath: staleSnapshot?.file_path ?? null,\n            },\n          });\n        }\n\n        if (vectorIndex.deleteMemory(staleRecordId)) {\n          deleted++;\n          actions.push(createStatediffAction('delete', {\n            target: 'memory_index',\n            key: String(staleRecordId),\n            sourceOperation: 'scan',\n            oldStateHash: null,\n            newStateHash: null,\n            metadata: {\n              filePath: staleSnapshot?.file_path ?? null,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n            },\n          }));\n          // Record DELETE history only after confirmed deletion.\n          try {\n            recordHistory(\n              staleRecordId,\n              'DELETE',\n              staleSnapshot?.file_path ?? null,\n              null,\n              'mcp:memory_index_scan',\n              staleSnapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort\n          }\n        } else {\n          failed++;\n        }\n      } catch (_error: unknown) {\n        failed++;\n      }\n    }\n\n    return { deleted, failed, actions };\n  };\n\n  const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n    if (paths.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n  };\n\n  const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n    if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweepOrphanIndexRows = (incrementalIndex as {\n      sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n    }).sweepOrphanIndexRows;\n\n    if (typeof sweepOrphanIndexRows !== 'function') {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n    const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n    return {\n      swept: deleteResult.deleted,\n      failed: deleteResult.failed,\n      scannedRows: sweep.scannedRows,\n      nextCursor: sweep.nextCursor,\n      actions: deleteResult.actions,\n    };\n  };\n\n  const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n    try {\n      runPostMutationHooks('scan', { ...context, statediffActions: actions });\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n    }\n  };\n\n  const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n    result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n  );\n\n  const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n    target: 'memory_index',\n    key: 'trigger-embedding-backfill',\n    sourceOperation: 'scan',\n    metadata: {\n      readyRows: result.readyRows,\n      failedRows: result.failedRows,\n      pendingRows: result.pendingRows,\n    },\n  });\n\n  const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n    if (actions.length === 0) {\n      return;\n    }\n    results.aliasConflicts = detectAliasConflictsFromIndex();\n    results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n  };\n\n  const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n    try {\n      const repairResult = await repairIncompleteMarkers(\n        { database: requireDb(), plannerMode: 'full-auto' },\n        { limit: BATCH_SIZE },\n      );\n      if (repairResult.failed > 0) {\n        console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n      }\n      return repairResult.repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n    if (!isMemoryIdempotencyEnabled()) {\n      return 0;\n    }\n    try {\n      const database = requireDb();\n      const rows = database.prepare(`\n        SELECT id, spec_folder, title, content_text, content_hash,\n               tenant_id, user_id, agent_id, session_id\n        FROM memory_index\n        WHERE parent_id IS NULL\n          AND embedding_status = 'success'\n          AND content_text IS NOT NULL\n          AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n        ORDER BY id ASC\n        LIMIT ?\n      `).all(BATCH_SIZE) as Array<{\n        id: number;\n        spec_folder: string;\n        title: string | null;\n        content_text: string;\n        content_hash: string | null;\n        tenant_id: string | null;\n        user_id: string | null;\n        agent_id: string | null;\n        session_id: string | null;\n      }>;\n      let repaired = 0;\n      for (const row of rows) {\n        try {\n          const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n          const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n          recordNearDuplicateCheck({\n            database,\n            memoryId: row.id,\n            specFolder: row.spec_folder,\n            contentHash: row.content_hash,\n            embedding,\n            scope: {\n              tenantId: row.tenant_id,\n              userId: row.user_id,\n              agentId: row.agent_id,\n              sessionId: row.session_id,\n            },\n          });\n          repaired++;\n        } catch (error: unknown) {\n          console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n        }\n      }\n      return repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  if (files.length === 0) {\n    let staleDeleted = 0;\n    let staleDeleteFailed = 0;\n    const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n    const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n    const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n    if (incremental && !force) {\n      const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n      const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n      staleDeleted = staleDeleteResult.deleted;\n      staleDeleteFailed = staleDeleteResult.failed;\n      if (staleDeleted > 0) {\n        runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n      }\n    }\n\n    const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n      runTriggerEmbeddingBackfill(requireDb(), {\n        isCancelled: () => ctx.isCancelled?.() ?? false,\n      }));\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        nearDuplicateRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    nearDuplicateRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files — the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        // A cancelled file was never indexed and was never going to be: counting it\n        // as a failure would attribute an operator-requested stop to a file error.\n        // It is neither success nor failure, so it falls through both tallies.\n        if (!isSuccessfulStatus && result.status !== 'cancelled') {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure — a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {","lineStart":1,"lineEnd":1315,"totalLines":1316,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781755631165,"end":1781755631173}},"metadata":{"openai":{"itemId":"fc_037f7296ff70a56b016a336eef164081919327f75da8a06545"}},"id":"prt_ed8e95614001QKPGsf3tYFONr7","sessionID":"ses_127185023ffen0qKKl1I08wyww","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4"}}
{"type":"tool_use","timestamp":1781755631200,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"type":"tool","tool":"read","callID":"call_qChabfAkVZuuhu5z978MROX1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Trigger Embedding Backfill\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: \n6: import {\n7:   computeContentHash,\n8:   getActiveEmbeddingProfileKey,\n9:   lookupEmbedding,\n10:   storeEmbedding,\n11: } from '../cache/embedding-cache.js';\n12: import { normalizeTriggerText } from '../parsing/trigger-matcher.js';\n13: import * as embeddings from '../providers/embeddings.js';\n14: import { sanitizeAndLogEmbeddingFailure } from '../providers/retry-manager.js';\n15: import { ensureMemoryTriggerEmbeddingsSchema } from './vector-index-schema.js';\n16: \n17: type TriggerEmbeddingInputKind = 'document';\n18: \n19: interface TriggerSourceRow {\n20:   id: number;\n21:   trigger_phrases: string | null;\n22: }\n23: \n24: interface PendingTriggerEmbeddingRow {\n25:   memory_id: number;\n26:   phrase_hash: string;\n27: }\n28: \n29: interface TriggerEmbeddingBackfillOptions {\n30:   enabled?: boolean;\n31:   limit?: number;\n32:   isCancelled?: () => boolean;\n33: }\n34: \n35: export interface TriggerEmbeddingBackfillResult {\n36:   enabled: boolean;\n37:   status: 'skipped_default_off' | 'complete' | 'complete_with_pending' | 'failed' | 'cancelled';\n38:   scannedMemories: number;\n39:   phrasesSeen: number;\n40:   pendingRows: number;\n41:   readyRows: number;\n42:   failedRows: number;\n43:   cacheHits: number;\n44:   generated: number;\n45:   pendingRemaining: number;\n46:   warnings: string[];\n47: }\n48: \n49: const DEFAULT_TRIGGER_BACKFILL_LIMIT = 100;\n50: // The phrase-sync upserts the entire eligible corpus. better-sqlite3 transactions\n51: // run synchronously, so the corpus is processed in chunks and the loop yields\n52: // between chunk transactions — never inside one, which would suspend an open write\n53: // transaction and risk a partial commit. Chunking keeps the daemon able to service\n54: // IPC (status, cancel, health, a competing launcher's probe) throughout the sync.\n55: const PHRASE_SYNC_CHUNK_ROWS = 200;\n56: const TRIGGER_BACKFILL_FLAG = 'SPECKIT_TRIGGER_EMBEDDING_BACKFILL';\n57: const TRIGGER_INPUT_KIND: TriggerEmbeddingInputKind = 'document';\n58: \n59: function isEnabledByEnv(): boolean {\n60:   return process.env[TRIGGER_BACKFILL_FLAG] === 'true';\n61: }\n62: \n63: function emptyResult(enabled: boolean, status: TriggerEmbeddingBackfillResult['status']): TriggerEmbeddingBackfillResult {\n64:   return {\n65:     enabled,\n66:     status,\n67:     scannedMemories: 0,\n68:     phrasesSeen: 0,\n69:     pendingRows: 0,\n70:     readyRows: 0,\n71:     failedRows: 0,\n72:     cacheHits: 0,\n73:     generated: 0,\n74:     pendingRemaining: 0,\n75:     warnings: [],\n76:   };\n77: }\n78: \n79: function parseStoredTriggerPhrases(raw: string | null, memoryId: number): { phrases: string[]; warning: string | null } {\n80:   if (typeof raw !== 'string' || raw.trim().length === 0) {\n81:     return { phrases: [], warning: null };\n82:   }\n83: \n84:   try {\n85:     const parsed = JSON.parse(raw) as unknown;\n86:     if (!Array.isArray(parsed)) {\n87:       return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not a JSON array` };\n88:     }\n89: \n90:     const phrases = new Set<string>();\n91:     for (const value of parsed) {\n92:       if (typeof value !== 'string') {\n93:         continue;\n94:       }\n95:       const normalized = normalizeTriggerText(value);\n96:       if (normalized) {\n97:         phrases.add(normalized);\n98:       }\n99:     }\n100:     return { phrases: [...phrases], warning: null };\n101:   } catch {\n102:     return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not valid JSON` };\n103:   }\n104: }\n105: \n106: function countPendingRows(database: Database.Database, profileKey: string, inputKind: TriggerEmbeddingInputKind): number {\n107:   const row = database.prepare(`\n108:     SELECT COUNT(*) AS count\n109:     FROM memory_trigger_embeddings\n110:     WHERE profile_key = ?\n111:       AND input_kind = ?\n112:       AND embedding_status = 'pending'\n113:   `).get(profileKey, inputKind) as { count: number };\n114:   return row.count;\n115: }\n116: \n117: // On a cancel return the per-pass counters were never finalized, so populate them\n118: // from the live committed-pending backlog. This keeps a cancelled envelope honest\n119: // about remaining work and lets the caller's change-detection (which keys on\n120: // pendingRows) emit a statediff action for rows committed as 'pending' before the cancel.\n121: function reportCommittedPending(\n122:   database: Database.Database,\n123:   profileKey: string,\n124:   inputKind: TriggerEmbeddingInputKind,\n125:   result: TriggerEmbeddingBackfillResult,\n126: ): void {\n127:   const pending = countPendingRows(database, profileKey, inputKind);\n128:   result.pendingRemaining = pending;\n129:   result.pendingRows = pending;\n130: }\n131: \n132: function markTriggerEmbeddingStatus(\n133:   database: Database.Database,\n134:   row: PendingTriggerEmbeddingRow,\n135:   profileKey: string,\n136:   inputKind: TriggerEmbeddingInputKind,\n137:   status: 'ready' | 'failed',\n138:   failureReason: string | null,\n139: ): void {\n140:   database.prepare(`\n141:     UPDATE memory_trigger_embeddings\n142:     SET embedding_status = ?,\n143:         failure_reason = ?,\n144:         updated_at = datetime('now')\n145:     WHERE memory_id = ?\n146:       AND phrase_hash = ?\n147:       AND profile_key = ?\n148:       AND input_kind = ?\n149:   `).run(status, failureReason, row.memory_id, row.phrase_hash, profileKey, inputKind);\n150: }\n151: \n152: export async function runTriggerEmbeddingBackfill(\n153:   database: Database.Database,\n154:   options: TriggerEmbeddingBackfillOptions = {},\n155: ): Promise<TriggerEmbeddingBackfillResult> {\n156:   const enabled = options.enabled ?? isEnabledByEnv();\n157:   if (!enabled) {\n158:     return emptyResult(false, 'skipped_default_off');\n159:   }\n160: \n161:   const result = emptyResult(true, 'complete');\n162:   const limit = Math.max(1, Math.floor(options.limit ?? DEFAULT_TRIGGER_BACKFILL_LIMIT));\n163: \n164:   try {\n165:     ensureMemoryTriggerEmbeddingsSchema(database, 'trigger_embedding_backfill');\n166: \n167:     const profile = embeddings.getEmbeddingProfile();\n168:     const modelId = profile?.model ?? embeddings.getModelName();\n169:     const dimensions = profile?.dim ?? embeddings.getEmbeddingDimension();\n170:     const profileKey = getActiveEmbeddingProfileKey(database, modelId, dimensions);\n171:     const phraseByHash = new Map<string, string>();\n172: \n173:     const sourceRows = database.prepare(`\n174:       SELECT id, trigger_phrases\n175:       FROM memory_index\n176:       WHERE trigger_phrases IS NOT NULL\n177:         AND trim(trigger_phrases) != ''\n178:         AND trim(trigger_phrases) != '[]'\n179:       ORDER BY id ASC\n180:     `).all() as TriggerSourceRow[];\n181: \n182:     result.scannedMemories = sourceRows.length;\n183: \n184:     const syncPhraseChunk = database.transaction((rows: TriggerSourceRow[]) => {\n185:       const upsertPending = database.prepare(`\n186:         INSERT INTO memory_trigger_embeddings (\n187:           memory_id,\n188:           phrase_hash,\n189:           profile_key,\n190:           input_kind,\n191:           model_id,\n192:           dimensions,\n193:           embedding_status,\n194:           failure_reason,\n195:           updated_at\n196:         ) VALUES (?, ?, ?, ?, ?, ?, 'pending', NULL, datetime('now'))\n197:         ON CONFLICT(memory_id, phrase_hash, profile_key, input_kind)\n198:         DO UPDATE SET\n199:           model_id = excluded.model_id,\n200:           dimensions = excluded.dimensions,\n201:           embedding_status = CASE\n202:             WHEN memory_trigger_embeddings.embedding_status = 'ready'\n203:               AND memory_trigger_embeddings.model_id = excluded.model_id\n204:               AND memory_trigger_embeddings.dimensions = excluded.dimensions\n205:             THEN memory_trigger_embeddings.embedding_status\n206:             ELSE 'pending'\n207:           END,\n208:           failure_reason = CASE\n209:             WHEN memory_trigger_embeddings.embedding_status = 'ready'\n210:               AND memory_trigger_embeddings.model_id = excluded.model_id\n211:               AND memory_trigger_embeddings.dimensions = excluded.dimensions\n212:             THEN memory_trigger_embeddings.failure_reason\n213:             ELSE NULL\n214:           END,\n215:           updated_at = CASE\n216:             WHEN memory_trigger_embeddings.embedding_status = 'ready'\n217:               AND memory_trigger_embeddings.model_id = excluded.model_id\n218:               AND memory_trigger_embeddings.dimensions = excluded.dimensions\n219:             THEN memory_trigger_embeddings.updated_at\n220:             ELSE datetime('now')\n221:           END\n222:       `);\n223:       const deleteStaleForMemory = (memoryId: number, phraseHashes: string[]): void => {\n224:         if (phraseHashes.length === 0) {\n225:           database.prepare(`\n226:             DELETE FROM memory_trigger_embeddings\n227:             WHERE memory_id = ?\n228:               AND profile_key = ?\n229:               AND input_kind = ?\n230:           `).run(memoryId, profileKey, TRIGGER_INPUT_KIND);\n231:           return;\n232:         }\n233: \n234:         database.prepare(`\n235:           DELETE FROM memory_trigger_embeddings\n236:           WHERE memory_id = ?\n237:             AND profile_key = ?\n238:             AND input_kind = ?\n239:             AND phrase_hash NOT IN (${phraseHashes.map(() => '?').join(', ')})\n240:         `).run(memoryId, profileKey, TRIGGER_INPUT_KIND, ...phraseHashes);\n241:       };\n242: \n243:       for (const row of rows) {\n244:         const parsed = parseStoredTriggerPhrases(row.trigger_phrases, row.id);\n245:         if (parsed.warning) {\n246:           result.warnings.push(parsed.warning);\n247:         }\n248: \n249:         const phraseHashes: string[] = [];\n250:         for (const phrase of parsed.phrases) {\n251:           const phraseHash = computeContentHash(phrase);\n252:           phraseByHash.set(phraseHash, phrase);\n253:           phraseHashes.push(phraseHash);\n254:           result.phrasesSeen += 1;\n255:           upsertPending.run(row.id, phraseHash, profileKey, TRIGGER_INPUT_KIND, modelId, dimensions);\n256:         }\n257: \n258:         deleteStaleForMemory(row.id, phraseHashes);\n259:       }\n260:     });\n261: \n262:     for (let offset = 0; offset < sourceRows.length; offset += PHRASE_SYNC_CHUNK_ROWS) {\n263:       if (options.isCancelled?.()) {\n264:         result.status = 'cancelled';\n265:         result.warnings.push('Trigger embedding backfill cancelled during phrase sync');\n266:         // Already-committed chunks may have inserted 'pending' rows. Report that\n267:         // backlog so a cancelled run does not under-report remaining work and so\n268:         // downstream change-detection sees the committed-but-pending rows. The\n269:         // rows stay inert until embedded and the next scan reconciles them.\n270:         reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n271:         return result;\n272:       }\n273:       syncPhraseChunk(sourceRows.slice(offset, offset + PHRASE_SYNC_CHUNK_ROWS));\n274:       // Yield between self-contained chunk transactions, never inside one. Per-chunk\n275:       // atomicity replaces whole-corpus atomicity; safe here because the upserts are\n276:       // idempotent (ON CONFLICT DO UPDATE) and the deletes are per-memory-id, so a\n277:       // mid-sync cancel leaves a consistent partial state the next scan reconciles.\n278:       await new Promise<void>((resolve) => setImmediate(resolve));\n279:     }\n280: \n281:     const pendingRows = database.prepare(`\n282:       SELECT memory_id, phrase_hash\n283:       FROM memory_trigger_embeddings\n284:       WHERE profile_key = ?\n285:         AND input_kind = ?\n286:         AND embedding_status = 'pending'\n287:       ORDER BY updated_at ASC, memory_id ASC, phrase_hash ASC\n288:       LIMIT ?\n289:     `).all(profileKey, TRIGGER_INPUT_KIND, limit) as PendingTriggerEmbeddingRow[];\n290: \n291:     result.pendingRows = pendingRows.length;\n292: \n293:     let processedSinceYield = 0;\n294:     for (const row of pendingRows) {\n295:       if (options.isCancelled?.()) {\n296:         result.status = 'cancelled';\n297:         result.warnings.push('Trigger embedding backfill cancelled during embedding generation');\n298:         // Some rows in this pass may already be 'ready' and others still 'pending'.\n299:         // Report the live pending backlog so the cancelled envelope reflects true\n300:         // remaining work; the next scan reconciles the rest.\n301:         reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n302:         return result;\n303:       }\n304:       // The cache-hit and missing-phrase branches below `continue` without awaiting\n305:       // network I/O, so a long run of them would starve the loop; yield periodically.\n306:       if (++processedSinceYield % 50 === 0) {\n307:         await new Promise<void>((resolve) => setImmediate(resolve));\n308:       }\n309:       const phrase = phraseByHash.get(row.phrase_hash);\n310:       if (!phrase) {\n311:         markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Trigger phrase source unavailable');\n312:         result.failedRows += 1;\n313:         continue;\n314:       }\n315: \n316:       const cached = lookupEmbedding(database, row.phrase_hash, modelId, dimensions, {\n317:         profileKey,\n318:         inputKind: TRIGGER_INPUT_KIND,\n319:       });\n320:       if (cached) {\n321:         markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n322:         result.cacheHits += 1;\n323:         result.readyRows += 1;\n324:         continue;\n325:       }\n326: \n327:       try {\n328:         const embedding = await embeddings.generateDocumentEmbedding(phrase);\n329:         if (!embedding) {\n330:           markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Embedding generation returned null');\n331:           result.failedRows += 1;\n332:           continue;\n333:         }\n334: \n335:         const durableStore = database.transaction(() => {\n336:           storeEmbedding(\n337:             database,\n338:             row.phrase_hash,\n339:             modelId,\n340:             Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n341:             embedding.length,\n342:             { profileKey, inputKind: TRIGGER_INPUT_KIND },\n343:           );\n344:           markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n345:         });\n346:         durableStore();\n347:         result.generated += 1;\n348:         result.readyRows += 1;\n349:       } catch (error: unknown) {\n350:         const sanitized = sanitizeAndLogEmbeddingFailure(\n351:           '[trigger-embedding-backfill] Embedding generation failed',\n352:           error,\n353:           { provider: modelId, force: false },\n354:         ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n355:         markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', sanitized);\n356:         result.failedRows += 1;\n357:       }\n358:     }\n359: \n360:     result.pendingRemaining = countPendingRows(database, profileKey, TRIGGER_INPUT_KIND);\n361:     result.status = result.pendingRemaining > 0 ? 'complete_with_pending' : 'complete';\n362:     return result;\n363:   } catch (error: unknown) {\n364:     result.status = 'failed';\n365:     result.warnings.push(error instanceof Error ? error.message : String(error));\n366:     return result;\n367:   }\n368: }\n\n(End of file - total 368 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Trigger Embedding Backfill\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\n\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport { normalizeTriggerText } from '../parsing/trigger-matcher.js';\nimport * as embeddings from '../providers/embeddings.js';\nimport { sanitizeAndLogEmbeddingFailure } from '../providers/retry-manager.js';\nimport { ensureMemoryTriggerEmbeddingsSchema } from './vector-index-schema.js';\n\ntype TriggerEmbeddingInputKind = 'document';\n\ninterface TriggerSourceRow {\n  id: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Trigger Embedding Backfill\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\n\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport { normalizeTriggerText } from '../parsing/trigger-matcher.js';\nimport * as embeddings from '../providers/embeddings.js';\nimport { sanitizeAndLogEmbeddingFailure } from '../providers/retry-manager.js';\nimport { ensureMemoryTriggerEmbeddingsSchema } from './vector-index-schema.js';\n\ntype TriggerEmbeddingInputKind = 'document';\n\ninterface TriggerSourceRow {\n  id: number;\n  trigger_phrases: string | null;\n}\n\ninterface PendingTriggerEmbeddingRow {\n  memory_id: number;\n  phrase_hash: string;\n}\n\ninterface TriggerEmbeddingBackfillOptions {\n  enabled?: boolean;\n  limit?: number;\n  isCancelled?: () => boolean;\n}\n\nexport interface TriggerEmbeddingBackfillResult {\n  enabled: boolean;\n  status: 'skipped_default_off' | 'complete' | 'complete_with_pending' | 'failed' | 'cancelled';\n  scannedMemories: number;\n  phrasesSeen: number;\n  pendingRows: number;\n  readyRows: number;\n  failedRows: number;\n  cacheHits: number;\n  generated: number;\n  pendingRemaining: number;\n  warnings: string[];\n}\n\nconst DEFAULT_TRIGGER_BACKFILL_LIMIT = 100;\n// The phrase-sync upserts the entire eligible corpus. better-sqlite3 transactions\n// run synchronously, so the corpus is processed in chunks and the loop yields\n// between chunk transactions — never inside one, which would suspend an open write\n// transaction and risk a partial commit. Chunking keeps the daemon able to service\n// IPC (status, cancel, health, a competing launcher's probe) throughout the sync.\nconst PHRASE_SYNC_CHUNK_ROWS = 200;\nconst TRIGGER_BACKFILL_FLAG = 'SPECKIT_TRIGGER_EMBEDDING_BACKFILL';\nconst TRIGGER_INPUT_KIND: TriggerEmbeddingInputKind = 'document';\n\nfunction isEnabledByEnv(): boolean {\n  return process.env[TRIGGER_BACKFILL_FLAG] === 'true';\n}\n\nfunction emptyResult(enabled: boolean, status: TriggerEmbeddingBackfillResult['status']): TriggerEmbeddingBackfillResult {\n  return {\n    enabled,\n    status,\n    scannedMemories: 0,\n    phrasesSeen: 0,\n    pendingRows: 0,\n    readyRows: 0,\n    failedRows: 0,\n    cacheHits: 0,\n    generated: 0,\n    pendingRemaining: 0,\n    warnings: [],\n  };\n}\n\nfunction parseStoredTriggerPhrases(raw: string | null, memoryId: number): { phrases: string[]; warning: string | null } {\n  if (typeof raw !== 'string' || raw.trim().length === 0) {\n    return { phrases: [], warning: null };\n  }\n\n  try {\n    const parsed = JSON.parse(raw) as unknown;\n    if (!Array.isArray(parsed)) {\n      return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not a JSON array` };\n    }\n\n    const phrases = new Set<string>();\n    for (const value of parsed) {\n      if (typeof value !== 'string') {\n        continue;\n      }\n      const normalized = normalizeTriggerText(value);\n      if (normalized) {\n        phrases.add(normalized);\n      }\n    }\n    return { phrases: [...phrases], warning: null };\n  } catch {\n    return { phrases: [], warning: `Memory ${memoryId} trigger_phrases is not valid JSON` };\n  }\n}\n\nfunction countPendingRows(database: Database.Database, profileKey: string, inputKind: TriggerEmbeddingInputKind): number {\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_trigger_embeddings\n    WHERE profile_key = ?\n      AND input_kind = ?\n      AND embedding_status = 'pending'\n  `).get(profileKey, inputKind) as { count: number };\n  return row.count;\n}\n\n// On a cancel return the per-pass counters were never finalized, so populate them\n// from the live committed-pending backlog. This keeps a cancelled envelope honest\n// about remaining work and lets the caller's change-detection (which keys on\n// pendingRows) emit a statediff action for rows committed as 'pending' before the cancel.\nfunction reportCommittedPending(\n  database: Database.Database,\n  profileKey: string,\n  inputKind: TriggerEmbeddingInputKind,\n  result: TriggerEmbeddingBackfillResult,\n): void {\n  const pending = countPendingRows(database, profileKey, inputKind);\n  result.pendingRemaining = pending;\n  result.pendingRows = pending;\n}\n\nfunction markTriggerEmbeddingStatus(\n  database: Database.Database,\n  row: PendingTriggerEmbeddingRow,\n  profileKey: string,\n  inputKind: TriggerEmbeddingInputKind,\n  status: 'ready' | 'failed',\n  failureReason: string | null,\n): void {\n  database.prepare(`\n    UPDATE memory_trigger_embeddings\n    SET embedding_status = ?,\n        failure_reason = ?,\n        updated_at = datetime('now')\n    WHERE memory_id = ?\n      AND phrase_hash = ?\n      AND profile_key = ?\n      AND input_kind = ?\n  `).run(status, failureReason, row.memory_id, row.phrase_hash, profileKey, inputKind);\n}\n\nexport async function runTriggerEmbeddingBackfill(\n  database: Database.Database,\n  options: TriggerEmbeddingBackfillOptions = {},\n): Promise<TriggerEmbeddingBackfillResult> {\n  const enabled = options.enabled ?? isEnabledByEnv();\n  if (!enabled) {\n    return emptyResult(false, 'skipped_default_off');\n  }\n\n  const result = emptyResult(true, 'complete');\n  const limit = Math.max(1, Math.floor(options.limit ?? DEFAULT_TRIGGER_BACKFILL_LIMIT));\n\n  try {\n    ensureMemoryTriggerEmbeddingsSchema(database, 'trigger_embedding_backfill');\n\n    const profile = embeddings.getEmbeddingProfile();\n    const modelId = profile?.model ?? embeddings.getModelName();\n    const dimensions = profile?.dim ?? embeddings.getEmbeddingDimension();\n    const profileKey = getActiveEmbeddingProfileKey(database, modelId, dimensions);\n    const phraseByHash = new Map<string, string>();\n\n    const sourceRows = database.prepare(`\n      SELECT id, trigger_phrases\n      FROM memory_index\n      WHERE trigger_phrases IS NOT NULL\n        AND trim(trigger_phrases) != ''\n        AND trim(trigger_phrases) != '[]'\n      ORDER BY id ASC\n    `).all() as TriggerSourceRow[];\n\n    result.scannedMemories = sourceRows.length;\n\n    const syncPhraseChunk = database.transaction((rows: TriggerSourceRow[]) => {\n      const upsertPending = database.prepare(`\n        INSERT INTO memory_trigger_embeddings (\n          memory_id,\n          phrase_hash,\n          profile_key,\n          input_kind,\n          model_id,\n          dimensions,\n          embedding_status,\n          failure_reason,\n          updated_at\n        ) VALUES (?, ?, ?, ?, ?, ?, 'pending', NULL, datetime('now'))\n        ON CONFLICT(memory_id, phrase_hash, profile_key, input_kind)\n        DO UPDATE SET\n          model_id = excluded.model_id,\n          dimensions = excluded.dimensions,\n          embedding_status = CASE\n            WHEN memory_trigger_embeddings.embedding_status = 'ready'\n              AND memory_trigger_embeddings.model_id = excluded.model_id\n              AND memory_trigger_embeddings.dimensions = excluded.dimensions\n            THEN memory_trigger_embeddings.embedding_status\n            ELSE 'pending'\n          END,\n          failure_reason = CASE\n            WHEN memory_trigger_embeddings.embedding_status = 'ready'\n              AND memory_trigger_embeddings.model_id = excluded.model_id\n              AND memory_trigger_embeddings.dimensions = excluded.dimensions\n            THEN memory_trigger_embeddings.failure_reason\n            ELSE NULL\n          END,\n          updated_at = CASE\n            WHEN memory_trigger_embeddings.embedding_status = 'ready'\n              AND memory_trigger_embeddings.model_id = excluded.model_id\n              AND memory_trigger_embeddings.dimensions = excluded.dimensions\n            THEN memory_trigger_embeddings.updated_at\n            ELSE datetime('now')\n          END\n      `);\n      const deleteStaleForMemory = (memoryId: number, phraseHashes: string[]): void => {\n        if (phraseHashes.length === 0) {\n          database.prepare(`\n            DELETE FROM memory_trigger_embeddings\n            WHERE memory_id = ?\n              AND profile_key = ?\n              AND input_kind = ?\n          `).run(memoryId, profileKey, TRIGGER_INPUT_KIND);\n          return;\n        }\n\n        database.prepare(`\n          DELETE FROM memory_trigger_embeddings\n          WHERE memory_id = ?\n            AND profile_key = ?\n            AND input_kind = ?\n            AND phrase_hash NOT IN (${phraseHashes.map(() => '?').join(', ')})\n        `).run(memoryId, profileKey, TRIGGER_INPUT_KIND, ...phraseHashes);\n      };\n\n      for (const row of rows) {\n        const parsed = parseStoredTriggerPhrases(row.trigger_phrases, row.id);\n        if (parsed.warning) {\n          result.warnings.push(parsed.warning);\n        }\n\n        const phraseHashes: string[] = [];\n        for (const phrase of parsed.phrases) {\n          const phraseHash = computeContentHash(phrase);\n          phraseByHash.set(phraseHash, phrase);\n          phraseHashes.push(phraseHash);\n          result.phrasesSeen += 1;\n          upsertPending.run(row.id, phraseHash, profileKey, TRIGGER_INPUT_KIND, modelId, dimensions);\n        }\n\n        deleteStaleForMemory(row.id, phraseHashes);\n      }\n    });\n\n    for (let offset = 0; offset < sourceRows.length; offset += PHRASE_SYNC_CHUNK_ROWS) {\n      if (options.isCancelled?.()) {\n        result.status = 'cancelled';\n        result.warnings.push('Trigger embedding backfill cancelled during phrase sync');\n        // Already-committed chunks may have inserted 'pending' rows. Report that\n        // backlog so a cancelled run does not under-report remaining work and so\n        // downstream change-detection sees the committed-but-pending rows. The\n        // rows stay inert until embedded and the next scan reconciles them.\n        reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n        return result;\n      }\n      syncPhraseChunk(sourceRows.slice(offset, offset + PHRASE_SYNC_CHUNK_ROWS));\n      // Yield between self-contained chunk transactions, never inside one. Per-chunk\n      // atomicity replaces whole-corpus atomicity; safe here because the upserts are\n      // idempotent (ON CONFLICT DO UPDATE) and the deletes are per-memory-id, so a\n      // mid-sync cancel leaves a consistent partial state the next scan reconciles.\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n\n    const pendingRows = database.prepare(`\n      SELECT memory_id, phrase_hash\n      FROM memory_trigger_embeddings\n      WHERE profile_key = ?\n        AND input_kind = ?\n        AND embedding_status = 'pending'\n      ORDER BY updated_at ASC, memory_id ASC, phrase_hash ASC\n      LIMIT ?\n    `).all(profileKey, TRIGGER_INPUT_KIND, limit) as PendingTriggerEmbeddingRow[];\n\n    result.pendingRows = pendingRows.length;\n\n    let processedSinceYield = 0;\n    for (const row of pendingRows) {\n      if (options.isCancelled?.()) {\n        result.status = 'cancelled';\n        result.warnings.push('Trigger embedding backfill cancelled during embedding generation');\n        // Some rows in this pass may already be 'ready' and others still 'pending'.\n        // Report the live pending backlog so the cancelled envelope reflects true\n        // remaining work; the next scan reconciles the rest.\n        reportCommittedPending(database, profileKey, TRIGGER_INPUT_KIND, result);\n        return result;\n      }\n      // The cache-hit and missing-phrase branches below `continue` without awaiting\n      // network I/O, so a long run of them would starve the loop; yield periodically.\n      if (++processedSinceYield % 50 === 0) {\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      const phrase = phraseByHash.get(row.phrase_hash);\n      if (!phrase) {\n        markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Trigger phrase source unavailable');\n        result.failedRows += 1;\n        continue;\n      }\n\n      const cached = lookupEmbedding(database, row.phrase_hash, modelId, dimensions, {\n        profileKey,\n        inputKind: TRIGGER_INPUT_KIND,\n      });\n      if (cached) {\n        markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n        result.cacheHits += 1;\n        result.readyRows += 1;\n        continue;\n      }\n\n      try {\n        const embedding = await embeddings.generateDocumentEmbedding(phrase);\n        if (!embedding) {\n          markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', 'Embedding generation returned null');\n          result.failedRows += 1;\n          continue;\n        }\n\n        const durableStore = database.transaction(() => {\n          storeEmbedding(\n            database,\n            row.phrase_hash,\n            modelId,\n            Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n            embedding.length,\n            { profileKey, inputKind: TRIGGER_INPUT_KIND },\n          );\n          markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'ready', null);\n        });\n        durableStore();\n        result.generated += 1;\n        result.readyRows += 1;\n      } catch (error: unknown) {\n        const sanitized = sanitizeAndLogEmbeddingFailure(\n          '[trigger-embedding-backfill] Embedding generation failed',\n          error,\n          { provider: modelId, force: false },\n        ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n        markTriggerEmbeddingStatus(database, row, profileKey, TRIGGER_INPUT_KIND, 'failed', sanitized);\n        result.failedRows += 1;\n      }\n    }\n\n    result.pendingRemaining = countPendingRows(database, profileKey, TRIGGER_INPUT_KIND);\n    result.status = result.pendingRemaining > 0 ? 'complete_with_pending' : 'complete';\n    return result;\n  } catch (error: unknown) {\n    result.status = 'failed';\n    result.warnings.push(error instanceof Error ? error.message : String(error));\n    return result;\n  }\n}","lineStart":1,"lineEnd":368,"totalLines":368,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/trigger-embedding-backfill.ts","time":{"start":1781755631187,"end":1781755631193}},"metadata":{"openai":{"itemId":"fc_037f7296ff70a56b016a336eef16548191b263f9db9ff8e85a"}},"id":"prt_ed8e956420015XESJneM7bArZZ","sessionID":"ses_127185023ffen0qKKl1I08wyww","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4"}}
{"type":"tool_use","timestamp":1781755631203,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"type":"tool","tool":"read","callID":"call_dh14qUEFFDTtbvvdprYgyPg8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n2: import Database from 'better-sqlite3';\n3: \n4: import {\n5:   createSchema,\n6:   ensureSchemaVersion,\n7: } from '../lib/search/vector-index-schema';\n8: import { runTriggerEmbeddingBackfill } from '../lib/search/trigger-embedding-backfill';\n9: \n10: const embeddingMocks = vi.hoisted(() => ({\n11:   generateDocumentEmbedding: vi.fn(),\n12:   getEmbeddingProfile: vi.fn(),\n13:   getEmbeddingDimension: vi.fn(),\n14:   getModelName: vi.fn(),\n15: }));\n16: \n17: vi.mock('../lib/providers/embeddings', () => embeddingMocks);\n18: \n19: function createBackfillDatabase(): Database.Database {\n20:   const database = new Database(':memory:');\n21:   createSchema(database, {\n22:     sqlite_vec_available: false,\n23:     get_embedding_dim: () => 3,\n24:   });\n25:   ensureSchemaVersion(database);\n26:   return database;\n27: }\n28: \n29: function insertMemory(database: Database.Database, id: number, phrases: string[]): void {\n30:   database.prepare(`\n31:     INSERT INTO memory_index (\n32:       id, spec_folder, file_path, title, trigger_phrases,\n33:       created_at, updated_at, importance_tier, context_type, embedding_status\n34:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n35:   `).run(\n36:     id,\n37:     'trigger/backfill',\n38:     `/workspace/trigger/backfill/${id}.md`,\n39:     `Memory ${id}`,\n40:     JSON.stringify(phrases),\n41:     '2026-06-10T00:00:00.000Z',\n42:     '2026-06-10T00:00:00.000Z',\n43:     'normal',\n44:     'implementation',\n45:     'pending',\n46:   );\n47: }\n48: \n49: describe('trigger embedding backfill', () => {\n50:   let database: Database.Database;\n51:   let previousFlag: string | undefined;\n52: \n53:   beforeEach(() => {\n54:     previousFlag = process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n55:     delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n56:     database = createBackfillDatabase();\n57:     embeddingMocks.generateDocumentEmbedding.mockReset();\n58:     embeddingMocks.generateDocumentEmbedding.mockResolvedValue(new Float32Array([0.1, 0.2, 0.3]));\n59:     embeddingMocks.getEmbeddingProfile.mockReset();\n60:     embeddingMocks.getEmbeddingProfile.mockReturnValue({ provider: 'test', model: 'test-model', dim: 3 });\n61:     embeddingMocks.getEmbeddingDimension.mockReset();\n62:     embeddingMocks.getEmbeddingDimension.mockReturnValue(3);\n63:     embeddingMocks.getModelName.mockReset();\n64:     embeddingMocks.getModelName.mockReturnValue('test-model');\n65:   });\n66: \n67:   afterEach(() => {\n68:     database.close();\n69:     if (previousFlag === undefined) {\n70:       delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n71:     } else {\n72:       process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL = previousFlag;\n73:     }\n74:   });\n75: \n76:   it('is default-off and does not create trigger embedding rows', async () => {\n77:     insertMemory(database, 1, ['save context']);\n78: \n79:     const result = await runTriggerEmbeddingBackfill(database);\n80: \n81:     const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n82:     expect(result).toMatchObject({ enabled: false, status: 'skipped_default_off' });\n83:     expect(derivedCount.count).toBe(0);\n84:     expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n85:   });\n86: \n87:   it('backfills ready rows once and re-runs without duplicate rows', async () => {\n88:     insertMemory(database, 1, ['save context', 'save the current state']);\n89: \n90:     const first = await runTriggerEmbeddingBackfill(database, { enabled: true });\n91:     const second = await runTriggerEmbeddingBackfill(database, { enabled: true });\n92: \n93:     const rows = database.prepare(`\n94:       SELECT memory_id, embedding_status, profile_key, input_kind, model_id, dimensions\n95:       FROM memory_trigger_embeddings\n96:       ORDER BY phrase_hash\n97:     `).all() as Array<{\n98:       memory_id: number;\n99:       embedding_status: string;\n100:       profile_key: string;\n101:       input_kind: string;\n102:       model_id: string;\n103:       dimensions: number;\n104:     }>;\n105:     const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n106: \n107:     expect(first).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 2, readyRows: 2, generated: 2 });\n108:     expect(second).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 0, readyRows: 0, generated: 0 });\n109:     expect(rows).toHaveLength(2);\n110:     expect(rows).toEqual(rows.map((row) => ({\n111:       ...row,\n112:       memory_id: 1,\n113:       embedding_status: 'ready',\n114:       profile_key: 'test-model:3',\n115:       input_kind: 'document',\n116:       model_id: 'test-model',\n117:       dimensions: 3,\n118:     })));\n119:     expect(cacheCount.count).toBe(2);\n120:     expect(embeddingMocks.generateDocumentEmbedding).toHaveBeenCalledTimes(2);\n121:   });\n122: \n123:   it('does not mark a row ready when the cache store fails', async () => {\n124:     insertMemory(database, 1, ['save context']);\n125:     database.exec(`\n126:       CREATE TRIGGER fail_embedding_cache_insert\n127:       BEFORE INSERT ON embedding_cache\n128:       BEGIN\n129:         SELECT RAISE(ABORT, 'store failed');\n130:       END;\n131:     `);\n132: \n133:     const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n134: \n135:     const row = database.prepare(`\n136:       SELECT embedding_status, failure_reason\n137:       FROM memory_trigger_embeddings\n138:       WHERE memory_id = 1\n139:     `).get() as { embedding_status: string; failure_reason: string | null };\n140:     const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n141: \n142:     expect(result).toMatchObject({ enabled: true, status: 'complete', pendingRows: 1, readyRows: 0, failedRows: 1 });\n143:     expect(row.embedding_status).toBe('failed');\n144:     expect(row.failure_reason).toContain('store failed');\n145:     expect(cacheCount.count).toBe(0);\n146:   });\n147: \n148:   // Returns false for the first `n` calls, then true. Lets a test cancel at a\n149:   // precise loop boundary (the cancel check sits at the top of each chunk/row).\n150:   function cancelAfter(n: number): () => boolean {\n151:     let calls = 0;\n152:     return () => ++calls > n;\n153:   }\n154: \n155:   it('cancels before any phrase sync when isCancelled is immediately true', async () => {\n156:     for (let id = 1; id <= 300; id++) {\n157:       insertMemory(database, id, [`trigger phrase ${id}`]);\n158:     }\n159: \n160:     const result = await runTriggerEmbeddingBackfill(database, {\n161:       enabled: true,\n162:       isCancelled: cancelAfter(0),\n163:     });\n164: \n165:     const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n166:     expect(result.status).toBe('cancelled');\n167:     expect(derivedCount.count).toBe(0);\n168:     // No chunk committed, so the cancelled run reports zero backlog and triggers\n169:     // no statediff action — the counter fix must not over-report on a no-work cancel.\n170:     expect(result.pendingRemaining).toBe(0);\n171:     expect(result.pendingRows).toBe(0);\n172:     expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n173:   });\n174: \n175:   it('cancels at a chunk boundary, leaving a partial sync and never reaching embedding generation', async () => {\n176:     // 300 rows span two 200-row phrase-sync chunks. Cancelling on the second chunk\n177:     // check proves the corpus is processed in self-contained chunks (whole-corpus\n178:     // atomicity would leave 0 or 300, never a clean chunk-sized partial).\n179:     for (let id = 1; id <= 300; id++) {\n180:       insertMemory(database, id, [`trigger phrase ${id}`]);\n181:     }\n182: \n183:     const result = await runTriggerEmbeddingBackfill(database, {\n184:       enabled: true,\n185:       isCancelled: cancelAfter(1),\n186:     });\n187: \n188:     const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n189:     expect(result.status).toBe('cancelled');\n190:     expect(derivedCount.count).toBe(200);\n191:     // The cancelled envelope must report the committed-but-pending backlog so it\n192:     // does not under-report remaining work and so the caller's pendingRows-keyed\n193:     // change-detection emits a statediff action for the 200 committed rows.\n194:     expect(result.pendingRemaining).toBe(200);\n195:     expect(result.pendingRows).toBe(200);\n196:     expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n197:   });\n198: \n199:   it('yields the event loop during a multi-chunk backfill so concurrent work can run', async () => {\n200:     for (let id = 1; id <= 500; id++) {\n201:       insertMemory(database, id, [`trigger phrase ${id}`]);\n202:     }\n203: \n204:     // A competing macrotask loop: it can only advance if the backfill releases the\n205:     // event loop. With a single blocking transaction it would never tick until the\n206:     // backfill returned; chunk-and-yield lets it interleave.\n207:     let ticks = 0;\n208:     let running = true;\n209:     const tick = (): void => {\n210:       if (running) {\n211:         ticks += 1;\n212:         setImmediate(tick);\n213:       }\n214:     };\n215:     setImmediate(tick);\n216: \n217:     const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n218:     running = false;\n219: \n220:     // 500 phrases exceed the default per-run limit, so a healthy run reports\n221:     // complete_with_pending; either success value proves it was not cancelled/failed.\n222:     expect(['complete', 'complete_with_pending']).toContain(result.status);\n223:     expect(ticks).toBeGreaterThan(0);\n224:   });\n225: });\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport {\n  createSchema,\n  ensureSchemaVersion,\n} from '../lib/search/vector-index-schema';\nimport { runTriggerEmbeddingBackfill } from '../lib/search/trigger-embedding-backfill';\n\nconst embeddingMocks = vi.hoisted(() => ({\n  generateDocumentEmbedding: vi.fn(),\n  getEmbeddingProfile: vi.fn(),\n  getEmbeddingDimension: vi.fn(),\n  getModelName: vi.fn(),\n}));\n\nvi.mock('../lib/providers/embeddings', () => embeddingMocks);\n\nfunction createBackfillDatabase(): Database.Database {\n  const database = new Database(':memory:');","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts","text":"import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport {\n  createSchema,\n  ensureSchemaVersion,\n} from '../lib/search/vector-index-schema';\nimport { runTriggerEmbeddingBackfill } from '../lib/search/trigger-embedding-backfill';\n\nconst embeddingMocks = vi.hoisted(() => ({\n  generateDocumentEmbedding: vi.fn(),\n  getEmbeddingProfile: vi.fn(),\n  getEmbeddingDimension: vi.fn(),\n  getModelName: vi.fn(),\n}));\n\nvi.mock('../lib/providers/embeddings', () => embeddingMocks);\n\nfunction createBackfillDatabase(): Database.Database {\n  const database = new Database(':memory:');\n  createSchema(database, {\n    sqlite_vec_available: false,\n    get_embedding_dim: () => 3,\n  });\n  ensureSchemaVersion(database);\n  return database;\n}\n\nfunction insertMemory(database: Database.Database, id: number, phrases: string[]): void {\n  database.prepare(`\n    INSERT INTO memory_index (\n      id, spec_folder, file_path, title, trigger_phrases,\n      created_at, updated_at, importance_tier, context_type, embedding_status\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    id,\n    'trigger/backfill',\n    `/workspace/trigger/backfill/${id}.md`,\n    `Memory ${id}`,\n    JSON.stringify(phrases),\n    '2026-06-10T00:00:00.000Z',\n    '2026-06-10T00:00:00.000Z',\n    'normal',\n    'implementation',\n    'pending',\n  );\n}\n\ndescribe('trigger embedding backfill', () => {\n  let database: Database.Database;\n  let previousFlag: string | undefined;\n\n  beforeEach(() => {\n    previousFlag = process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n    delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n    database = createBackfillDatabase();\n    embeddingMocks.generateDocumentEmbedding.mockReset();\n    embeddingMocks.generateDocumentEmbedding.mockResolvedValue(new Float32Array([0.1, 0.2, 0.3]));\n    embeddingMocks.getEmbeddingProfile.mockReset();\n    embeddingMocks.getEmbeddingProfile.mockReturnValue({ provider: 'test', model: 'test-model', dim: 3 });\n    embeddingMocks.getEmbeddingDimension.mockReset();\n    embeddingMocks.getEmbeddingDimension.mockReturnValue(3);\n    embeddingMocks.getModelName.mockReset();\n    embeddingMocks.getModelName.mockReturnValue('test-model');\n  });\n\n  afterEach(() => {\n    database.close();\n    if (previousFlag === undefined) {\n      delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n    } else {\n      process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL = previousFlag;\n    }\n  });\n\n  it('is default-off and does not create trigger embedding rows', async () => {\n    insertMemory(database, 1, ['save context']);\n\n    const result = await runTriggerEmbeddingBackfill(database);\n\n    const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n    expect(result).toMatchObject({ enabled: false, status: 'skipped_default_off' });\n    expect(derivedCount.count).toBe(0);\n    expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n  });\n\n  it('backfills ready rows once and re-runs without duplicate rows', async () => {\n    insertMemory(database, 1, ['save context', 'save the current state']);\n\n    const first = await runTriggerEmbeddingBackfill(database, { enabled: true });\n    const second = await runTriggerEmbeddingBackfill(database, { enabled: true });\n\n    const rows = database.prepare(`\n      SELECT memory_id, embedding_status, profile_key, input_kind, model_id, dimensions\n      FROM memory_trigger_embeddings\n      ORDER BY phrase_hash\n    `).all() as Array<{\n      memory_id: number;\n      embedding_status: string;\n      profile_key: string;\n      input_kind: string;\n      model_id: string;\n      dimensions: number;\n    }>;\n    const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n\n    expect(first).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 2, readyRows: 2, generated: 2 });\n    expect(second).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 0, readyRows: 0, generated: 0 });\n    expect(rows).toHaveLength(2);\n    expect(rows).toEqual(rows.map((row) => ({\n      ...row,\n      memory_id: 1,\n      embedding_status: 'ready',\n      profile_key: 'test-model:3',\n      input_kind: 'document',\n      model_id: 'test-model',\n      dimensions: 3,\n    })));\n    expect(cacheCount.count).toBe(2);\n    expect(embeddingMocks.generateDocumentEmbedding).toHaveBeenCalledTimes(2);\n  });\n\n  it('does not mark a row ready when the cache store fails', async () => {\n    insertMemory(database, 1, ['save context']);\n    database.exec(`\n      CREATE TRIGGER fail_embedding_cache_insert\n      BEFORE INSERT ON embedding_cache\n      BEGIN\n        SELECT RAISE(ABORT, 'store failed');\n      END;\n    `);\n\n    const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n\n    const row = database.prepare(`\n      SELECT embedding_status, failure_reason\n      FROM memory_trigger_embeddings\n      WHERE memory_id = 1\n    `).get() as { embedding_status: string; failure_reason: string | null };\n    const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n\n    expect(result).toMatchObject({ enabled: true, status: 'complete', pendingRows: 1, readyRows: 0, failedRows: 1 });\n    expect(row.embedding_status).toBe('failed');\n    expect(row.failure_reason).toContain('store failed');\n    expect(cacheCount.count).toBe(0);\n  });\n\n  // Returns false for the first `n` calls, then true. Lets a test cancel at a\n  // precise loop boundary (the cancel check sits at the top of each chunk/row).\n  function cancelAfter(n: number): () => boolean {\n    let calls = 0;\n    return () => ++calls > n;\n  }\n\n  it('cancels before any phrase sync when isCancelled is immediately true', async () => {\n    for (let id = 1; id <= 300; id++) {\n      insertMemory(database, id, [`trigger phrase ${id}`]);\n    }\n\n    const result = await runTriggerEmbeddingBackfill(database, {\n      enabled: true,\n      isCancelled: cancelAfter(0),\n    });\n\n    const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n    expect(result.status).toBe('cancelled');\n    expect(derivedCount.count).toBe(0);\n    // No chunk committed, so the cancelled run reports zero backlog and triggers\n    // no statediff action — the counter fix must not over-report on a no-work cancel.\n    expect(result.pendingRemaining).toBe(0);\n    expect(result.pendingRows).toBe(0);\n    expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n  });\n\n  it('cancels at a chunk boundary, leaving a partial sync and never reaching embedding generation', async () => {\n    // 300 rows span two 200-row phrase-sync chunks. Cancelling on the second chunk\n    // check proves the corpus is processed in self-contained chunks (whole-corpus\n    // atomicity would leave 0 or 300, never a clean chunk-sized partial).\n    for (let id = 1; id <= 300; id++) {\n      insertMemory(database, id, [`trigger phrase ${id}`]);\n    }\n\n    const result = await runTriggerEmbeddingBackfill(database, {\n      enabled: true,\n      isCancelled: cancelAfter(1),\n    });\n\n    const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n    expect(result.status).toBe('cancelled');\n    expect(derivedCount.count).toBe(200);\n    // The cancelled envelope must report the committed-but-pending backlog so it\n    // does not under-report remaining work and so the caller's pendingRows-keyed\n    // change-detection emits a statediff action for the 200 committed rows.\n    expect(result.pendingRemaining).toBe(200);\n    expect(result.pendingRows).toBe(200);\n    expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n  });\n\n  it('yields the event loop during a multi-chunk backfill so concurrent work can run', async () => {\n    for (let id = 1; id <= 500; id++) {\n      insertMemory(database, id, [`trigger phrase ${id}`]);\n    }\n\n    // A competing macrotask loop: it can only advance if the backfill releases the\n    // event loop. With a single blocking transaction it would never tick until the\n    // backfill returned; chunk-and-yield lets it interleave.\n    let ticks = 0;\n    let running = true;\n    const tick = (): void => {\n      if (running) {\n        ticks += 1;\n        setImmediate(tick);\n      }\n    };\n    setImmediate(tick);\n\n    const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n    running = false;\n\n    // 500 phrases exceed the default per-run limit, so a healthy run reports\n    // complete_with_pending; either success value proves it was not cancelled/failed.\n    expect(['complete', 'complete_with_pending']).toContain(result.status);\n    expect(ticks).toBeGreaterThan(0);\n  });\n});","lineStart":1,"lineEnd":225,"totalLines":225,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts","time":{"start":1781755631195,"end":1781755631201}},"metadata":{"openai":{"itemId":"fc_037f7296ff70a56b016a336eef165c8191b90be635a2d9c308"}},"id":"prt_ed8e95654001iGpjVFIhbFy85z","sessionID":"ses_127185023ffen0qKKl1I08wyww","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4"}}
{"type":"tool_use","timestamp":1781755631203,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"type":"tool","tool":"read","callID":"call_PsR0tuFG4JaMYtNjh7AmQPbA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: Background index scan dispatch + status/cancel handlers\n3: // ───────────────────────────────────────────────────────────────\n4: import { beforeEach, describe, expect, it, vi } from 'vitest';\n5: import { setTimeout as delay } from 'node:timers/promises';\n6: \n7: // ──────────────────────────────────────────────────────────────\n8: // 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n9: // ──────────────────────────────────────────────────────────────\n10: \n11: const mocks = vi.hoisted(() => ({\n12:   mockAcquireIndexScanLease: vi.fn(),\n13:   mockCompleteIndexScanLease: vi.fn(),\n14:   mockCheckDatabaseUpdated: vi.fn(),\n15:   mockProcessBatches: vi.fn(),\n16:   mockFindSpecDocuments: vi.fn((): string[] => []),\n17:   mockFindConstitutionalFiles: vi.fn((): string[] => []),\n18:   mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n19:   mockRequireDb: vi.fn(() => ({\n20:     prepare: vi.fn(() => ({\n21:       all: vi.fn(() => []),\n22:       get: vi.fn(() => undefined),\n23:     })),\n24:   })),\n25:   mockCategorizeFilesForIndexing: vi.fn((files: string[]) => ({\n26:     toIndex: files,\n27:     toUpdate: [] as string[],\n28:     toSkip: [] as string[],\n29:     toDelete: [] as string[],\n30:   })),\n31:   mockBatchUpdateMtimes: vi.fn(() => ({ updated: 0 })),\n32:   mockListIndexedRecordIdsForDeletedPaths: vi.fn((): number[] => []),\n33:   mockDeleteMemory: vi.fn((): boolean => true),\n34:   mockGetDb: vi.fn(() => ({\n35:     prepare: vi.fn(() => ({\n36:       get: vi.fn(() => undefined),\n37:     })),\n38:   })),\n39:   mockRunPostMutationHooks: vi.fn(() => ({ latencyMs: 0 })),\n40:   mockIndexMemoryFile: vi.fn(async () => ({ status: 'indexed', id: 1, specFolder: 'specs/test' })),\n41: }));\n42: \n43: // In-memory maintenance job store standing in for the persisted SQLite store.\n44: const jobStore = vi.hoisted(() => {\n45:   interface FakeJob {\n46:     id: string;\n47:     kind: string;\n48:     state: string;\n49:     phase: string | null;\n50:     progressTotal: number;\n51:     progressProcessed: number;\n52:     cancelRequested: boolean;\n53:     errors: Array<{ source: string; message: string; timestamp: string }>;\n54:     result: unknown;\n55:     payload: unknown;\n56:     createdAt: string;\n57:     updatedAt: string;\n58:   }\n59:   const jobs = new Map<string, FakeJob>();\n60:   let counter = 0;\n61:   return {\n62:     jobs,\n63:     createJobId: vi.fn(() => { counter += 1; return `job_test_${counter}`; }),\n64:     ensureMaintenanceJobsTable: vi.fn(),\n65:     createMaintenanceJob: vi.fn(async (args: { id: string; kind: string; payload?: unknown }) => {\n66:       const job: FakeJob = {\n67:         id: args.id,\n68:         kind: args.kind,\n69:         state: 'queued',\n70:         phase: null,\n71:         progressTotal: 0,\n72:         progressProcessed: 0,\n73:         cancelRequested: false,\n74:         errors: [],\n75:         result: null,\n76:         payload: args.payload ?? null,\n77:         createdAt: 'seed',\n78:         updatedAt: 'seed',\n79:       };\n80:       jobs.set(args.id, job);\n81:       return job;\n82:     }),\n83:     getMaintenanceJob: vi.fn((id: string) => jobs.get(id) ?? null),\n84:     setJobState: vi.fn(async (id: string, state: string) => {\n85:       const job = jobs.get(id);\n86:       if (job) job.state = state;\n87:       return job ?? null;\n88:     }),\n89:     setJobPhase: vi.fn(async (id: string, phase: string) => {\n90:       const job = jobs.get(id);\n91:       if (job) job.phase = phase;\n92:     }),\n93:     setJobProgress: vi.fn(async (id: string, progress: { processed: number; total: number }) => {\n94:       const job = jobs.get(id);\n95:       if (job) { job.progressProcessed = progress.processed; job.progressTotal = progress.total; }\n96:     }),\n97:     appendJobError: vi.fn(async (id: string, source: string, error: unknown) => {\n98:       const job = jobs.get(id);\n99:       if (job) job.errors.push({ source, message: String(error), timestamp: 'seed' });\n100:       return job ?? null;\n101:     }),\n102:     requestCancel: vi.fn(async (id: string) => {\n103:       const job = jobs.get(id);\n104:       if (job) job.cancelRequested = true;\n105:     }),\n106:     isCancelRequested: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n107:     isCancelRequestedFast: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n108:     completeJob: vi.fn(async (id: string, options: { state: string; result?: unknown }) => {\n109:       const job = jobs.get(id);\n110:       if (job) { job.state = options.state; job.result = options.result ?? null; }\n111:       return job ?? null;\n112:     }),\n113:     resetRunningJobsForKind: vi.fn(() => [] as string[]),\n114:     isTerminalJobState: vi.fn((state: string) => state === 'complete' || state === 'failed' || state === 'cancelled'),\n115:     MAX_STORED_ERRORS: 50,\n116:   };\n117: });\n118: \n119: // ──────────────────────────────────────────────────────────────\n120: // 2. MODULE MOCKS\n121: // ──────────────────────────────────────────────────────────────\n122: \n123: vi.mock('../lib/ops/job-store', () => jobStore);\n124: \n125: vi.mock('../core', () => ({\n126:   checkDatabaseUpdated: mocks.mockCheckDatabaseUpdated,\n127: }));\n128: \n129: vi.mock('../core/db-state', async (importOriginal) => {\n130:   const actual = await importOriginal<typeof import('../core/db-state')>();\n131:   return {\n132:     ...actual,\n133:     acquireIndexScanLease: mocks.mockAcquireIndexScanLease,\n134:     completeIndexScanLease: mocks.mockCompleteIndexScanLease,\n135:   };\n136: });\n137: \n138: vi.mock('../core/config', async (importOriginal) => {\n139:   const actual = await importOriginal<typeof import('../core/config')>();\n140:   return {\n141:     ...actual,\n142:     INDEX_SCAN_COOLDOWN: 60000,\n143:     DEFAULT_BASE_PATH: '/tmp/mock-workspace',\n144:     BATCH_SIZE: 5,\n145:     SERVER_DIR: '/tmp/mock-server',\n146:   };\n147: });\n148: \n149: vi.mock('../utils', () => ({\n150:   processBatches: mocks.mockProcessBatches,\n151:   requireDb: mocks.mockRequireDb,\n152:   toErrorMessage: (error: unknown) => error instanceof Error ? error.message : String(error),\n153: }));\n154: \n155: vi.mock('../handlers/memory-index-discovery', () => ({\n156:   findSpecDocuments: mocks.mockFindSpecDocuments,\n157:   findConstitutionalFiles: mocks.mockFindConstitutionalFiles,\n158:   findGraphMetadataFiles: mocks.mockFindGraphMetadataFiles,\n159:   detectSpecLevel: vi.fn(() => null),\n160: }));\n161: \n162: vi.mock('../lib/providers/embeddings', () => ({\n163:   getEmbeddingProfile: vi.fn(() => null),\n164: }));\n165: \n166: vi.mock('../lib/storage/incremental-index', () => ({\n167:   categorizeFilesForIndexing: mocks.mockCategorizeFilesForIndexing,\n168:   batchUpdateMtimes: mocks.mockBatchUpdateMtimes,\n169:   listIndexedRecordIdsForDeletedPaths: mocks.mockListIndexedRecordIdsForDeletedPaths,\n170: }));\n171: \n172: vi.mock('../lib/search/vector-index', () => ({\n173:   deleteMemory: mocks.mockDeleteMemory,\n174:   getDb: mocks.mockGetDb,\n175: }));\n176: \n177: vi.mock('../handlers/mutation-hooks', () => ({\n178:   runPostMutationHooks: mocks.mockRunPostMutationHooks,\n179: }));\n180: \n181: vi.mock('../lib/response/envelope', () => ({\n182:   createMCPSuccessResponse: (payload: unknown) => ({\n183:     content: [{ type: 'text', text: JSON.stringify(payload) }],\n184:   }),\n185:   createMCPErrorResponse: (payload: unknown) => ({\n186:     content: [{ type: 'text', text: JSON.stringify(payload) }],\n187:   }),\n188: }));\n189: \n190: vi.mock('../handlers/memory-save', () => ({\n191:   indexMemoryFile: mocks.mockIndexMemoryFile,\n192: }));\n193: \n194: vi.mock('../lib/governance/scope-governance', () => ({\n195:   requiresGovernedIngest: vi.fn(() => false),\n196:   validateGovernedIngest: vi.fn(() => ({ allowed: true, issues: [] })),\n197: }));\n198: \n199: vi.mock('../lib/runtime/memory-runtime-guard', () => ({\n200:   ensureMemoryRuntimeInitialized: vi.fn(async () => undefined),\n201: }));\n202: \n203: vi.mock('../lib/utils/canonical-path', () => ({\n204:   getCanonicalPathKey: (p: string) => p,\n205: }));\n206: \n207: vi.mock('../handlers/memory-index-alias', () => ({\n208:   EMPTY_ALIAS_CONFLICT_SUMMARY: { groups: 0, divergentHashGroups: 0 },\n209:   createDefaultDivergenceReconcileSummary: () => ({ retriesScheduled: 0, escalated: 0, errors: [] }),\n210:   detectAliasConflictsFromIndex: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n211:   summarizeAliasConflicts: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n212:   runDivergenceReconcileHooks: vi.fn(() => ({ retriesScheduled: 0, escalated: 0, errors: [] })),\n213: }));\n214: \n215: vi.mock('../lib/storage/checkpoints', () => ({\n216:   getRestoreBarrierStatus: vi.fn(() => null),\n217:   repairNeedsRebuildSentinel: vi.fn(() => ({\n218:     sentinelPresent: false,\n219:     attempted: false,\n220:     cleared: false,\n221:     summary: null,\n222:     error: null,\n223:   })),\n224: }));\n225: \n226: // ──────────────────────────────────────────────────────────────\n227: // 3. MODULES UNDER TEST (imported after all vi.mock() calls)\n228: // ──────────────────────────────────────────────────────────────\n229: \n230: import * as scanHandler from '../handlers/memory-index';\n231: import * as scanJobHandlers from '../handlers/memory-index-scan-jobs';\n232: \n233: // ──────────────────────────────────────────────────────────────\n234: // 4. HELPERS\n235: // ──────────────────────────────────────────────────────────────\n236: \n237: const TEST_FILE = '/tmp/mock-workspace/.opencode/specs/test/spec.md';\n238: \n239: async function waitFor(predicate: () => boolean, timeoutMs = 3000): Promise<void> {\n240:   const deadline = Date.now() + timeoutMs;\n241:   while (Date.now() < deadline) {\n242:     if (predicate()) return;\n243:     await delay(10);\n244:   }\n245:   throw new Error('Timed out waiting for condition');\n246: }\n247: \n248: function parseEnvelope(response: { content: Array<{ text: string }> }): { data: Record<string, unknown> } {\n249:   return JSON.parse(response.content[0].text) as { data: Record<string, unknown> };\n250: }\n251: \n252: function createBatchGate(): { gate: Promise<void>; release: () => void } {\n253:   let release = (): void => {};\n254:   const gate = new Promise<void>((resolve) => { release = resolve; });\n255:   return { gate, release };\n256: }\n257: \n258: // ──────────────────────────────────────────────────────────────\n259: // 5. TESTS\n260: // ──────────────────────────────────────────────────────────────\n261: \n262: describe('memory_index_scan background dispatch', () => {\n263:   beforeEach(() => {\n264:     vi.clearAllMocks();\n265:     jobStore.jobs.clear();\n266: \n267:     mocks.mockAcquireIndexScanLease.mockResolvedValue({\n268:       acquired: true,\n269:       reason: 'ok',\n270:       waitSeconds: 0,\n271:       lastIndexScan: 0,\n272:       scanStartedAt: 0,\n273:       leaseExpiryMs: 120000,\n274:       cooldownMs: 60000,\n275:     });\n276:     mocks.mockCompleteIndexScanLease.mockResolvedValue(undefined);\n277:     mocks.mockCheckDatabaseUpdated.mockResolvedValue(false);\n278:     mocks.mockFindSpecDocuments.mockReturnValue([TEST_FILE]);\n279:     mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n280:     mocks.mockFindGraphMetadataFiles.mockReturnValue([]);\n281:     mocks.mockCategorizeFilesForIndexing.mockReturnValue({\n282:       toIndex: [TEST_FILE],\n283:       toUpdate: [],\n284:       toSkip: [],\n285:       toDelete: [],\n286:     });\n287:     mocks.mockBatchUpdateMtimes.mockReturnValue({ updated: 0 });\n288:     mocks.mockListIndexedRecordIdsForDeletedPaths.mockReturnValue([]);\n289:     mocks.mockDeleteMemory.mockReturnValue(true);\n290:     mocks.mockGetDb.mockReturnValue({\n291:       prepare: vi.fn(() => ({ get: vi.fn(() => undefined), all: vi.fn(() => []) })),\n292:     });\n293:     mocks.mockRunPostMutationHooks.mockReturnValue({ latencyMs: 0 });\n294:     mocks.mockRequireDb.mockReturnValue({\n295:       prepare: vi.fn(() => ({ all: vi.fn(() => []), get: vi.fn(() => undefined) })),\n296:     });\n297:     mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'indexed', id: 1, specFolder: 'specs/test' });\n298:     mocks.mockProcessBatches.mockImplementation(\n299:       async (files: string[], worker: (file: string) => Promise<unknown>) => Promise.all(files.map(worker)),\n300:     );\n301:   });\n302: \n303:   it('background:true returns a queued jobId immediately without blocking on the scan', async () => {\n304:     const { gate, release } = createBatchGate();\n305:     mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n306:       await gate;\n307:       return Promise.all(files.map(worker));\n308:     });\n309: \n310:     const result = await scanHandler.handleMemoryIndexScan({\n311:       background: true,\n312:       includeConstitutional: false,\n313:       includeSpecDocs: true,\n314:       incremental: false,\n315:       force: false,\n316:     });\n317: \n318:     const { data } = parseEnvelope(result);\n319:     expect(data.background).toBe(true);\n320:     expect(data.state).toBe('queued');\n321:     expect(typeof data.jobId).toBe('string');\n322: \n323:     const jobId = data.jobId as string;\n324:     // The runner advances to 'running' but parks at the gated batch loop — the\n325:     // handler already returned, proving the call did not block on the scan.\n326:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'running');\n327:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n328: \n329:     release();\n330:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n331:     expect(mocks.mockIndexMemoryFile).toHaveBeenCalledTimes(1);\n332:   });\n333: \n334:   it('without background runs synchronously and never creates a job', async () => {\n335:     const result = await scanHandler.handleMemoryIndexScan({\n336:       includeConstitutional: false,\n337:       includeSpecDocs: true,\n338:       incremental: false,\n339:       force: false,\n340:     });\n341: \n342:     const { data } = parseEnvelope(result);\n343:     expect(data.status).toBe('complete');\n344:     expect(data.jobId).toBeUndefined();\n345:     expect(jobStore.createMaintenanceJob).not.toHaveBeenCalled();\n346:   });\n347: \n348:   it('memory_index_scan_status echoes the terminal result and returns E404 for unknown ids', async () => {\n349:     const started = await scanHandler.handleMemoryIndexScan({\n350:       background: true,\n351:       includeConstitutional: false,\n352:       includeSpecDocs: true,\n353:       incremental: false,\n354:       force: false,\n355:     });\n356:     const jobId = parseEnvelope(started).data.jobId as string;\n357:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n358: \n359:     const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n360:     const statusData = parseEnvelope(statusRes).data;\n361:     expect(statusData.state).toBe('complete');\n362:     const echoed = statusData.result as Record<string, unknown>;\n363:     expect(echoed.status).toBe('complete');\n364: \n365:     const missing = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId: 'job_missing' });\n366:     // The error envelope carries the code at the top level of the payload.\n367:     const missingPayload = JSON.parse(missing.content[0].text) as { code?: string };\n368:     expect(missingPayload.code).toBe('E404');\n369:   });\n370: \n371:   it('counts a cancelled file as neither failed nor success', async () => {\n372:     // A file whose worker returns 'cancelled' (operator-requested stop mid-batch)\n373:     // must not inflate the failure tally — the cancel is not a file error.\n374:     mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'cancelled' });\n375: \n376:     const result = await scanHandler.handleMemoryIndexScan({\n377:       includeConstitutional: false,\n378:       includeSpecDocs: true,\n379:       incremental: false,\n380:       force: false,\n381:     });\n382: \n383:     const { data } = parseEnvelope(result);\n384:     expect(data.failed).toBe(0);\n385:     expect(data.indexed).toBe(0);\n386:     expect(data.updated).toBe(0);\n387:   });\n388: \n389:   it('instruments the empty-files tail phases via timedPhase (onPhase markers)', async () => {\n390:     // No discoverable files routes through the empty-files branch; that branch must\n391:     // still fire onPhase for each tail maintenance phase so the busy marker refreshes\n392:     // and per-phase timing is emitted — symmetry with the main scan path.\n393:     mocks.mockFindSpecDocuments.mockReturnValue([]);\n394:     mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n395: \n396:     const started = await scanHandler.handleMemoryIndexScan({\n397:       background: true,\n398:       includeConstitutional: false,\n399:       includeSpecDocs: true,\n400:       incremental: false,\n401:       force: false,\n402:     });\n403:     const jobId = parseEnvelope(started).data.jobId as string;\n404:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n405: \n406:     const phases = jobStore.setJobPhase.mock.calls.map((call) => call[1]);\n407:     expect(phases).toContain('orphan-sweep');\n408:     expect(phases).toContain('enrichment-repair');\n409:     expect(phases).toContain('near-dup-repair');\n410:     expect(phases).toContain('trigger-backfill');\n411: \n412:     // The empty-files branch never enters the indexing loop.\n413:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n414:     const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n415:     const echoed = parseEnvelope(statusRes).data.result as Record<string, unknown>;\n416:     expect(echoed.status).toBe('complete');\n417:   });\n418: \n419:   it('cancel stops the runner at a phase boundary, releases the lease, and is idempotent', async () => {\n420:     const { gate, release } = createBatchGate();\n421:     mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n422:       await gate;\n423:       return Promise.all(files.map(worker));\n424:     });\n425: \n426:     const started = await scanHandler.handleMemoryIndexScan({\n427:       background: true,\n428:       includeConstitutional: false,\n429:       includeSpecDocs: true,\n430:       incremental: false,\n431:       force: false,\n432:     });\n433:     const jobId = parseEnvelope(started).data.jobId as string;\n434: \n435:     // Runner parks in the indexing phase, before any file work.\n436:     await waitFor(() => jobStore.jobs.get(jobId)?.phase === 'indexing');\n437: \n438:     const cancelRes = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n439:     expect(parseEnvelope(cancelRes).data.cancelRequested).toBe(true);\n440: \n441:     release();\n442:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'cancelled');\n443:     expect(mocks.mockCompleteIndexScanLease).toHaveBeenCalled();\n444:     // Cancellation at the phase boundary must prevent the indexing work itself.\n445:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n446: \n447:     // Cancelling an already-terminal job is a no-op success.\n448:     const again = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n449:     expect(parseEnvelope(again).data.state).toBe('cancelled');\n450:   });\n451: });\n\n(End of file - total 451 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: Background index scan dispatch + status/cancel handlers\n// ───────────────────────────────────────────────────────────────\nimport { beforeEach, describe, expect, it, vi } from 'vitest';\nimport { setTimeout as delay } from 'node:timers/promises';\n\n// ──────────────────────────────────────────────────────────────\n// 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n// ──────────────────────────────────────────────────────────────\n\nconst mocks = vi.hoisted(() => ({\n  mockAcquireIndexScanLease: vi.fn(),\n  mockCompleteIndexScanLease: vi.fn(),\n  mockCheckDatabaseUpdated: vi.fn(),\n  mockProcessBatches: vi.fn(),\n  mockFindSpecDocuments: vi.fn((): string[] => []),\n  mockFindConstitutionalFiles: vi.fn((): string[] => []),\n  mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n  mockRequireDb: vi.fn(() => ({\n    prepare: vi.fn(() => ({","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: Background index scan dispatch + status/cancel handlers\n// ───────────────────────────────────────────────────────────────\nimport { beforeEach, describe, expect, it, vi } from 'vitest';\nimport { setTimeout as delay } from 'node:timers/promises';\n\n// ──────────────────────────────────────────────────────────────\n// 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n// ──────────────────────────────────────────────────────────────\n\nconst mocks = vi.hoisted(() => ({\n  mockAcquireIndexScanLease: vi.fn(),\n  mockCompleteIndexScanLease: vi.fn(),\n  mockCheckDatabaseUpdated: vi.fn(),\n  mockProcessBatches: vi.fn(),\n  mockFindSpecDocuments: vi.fn((): string[] => []),\n  mockFindConstitutionalFiles: vi.fn((): string[] => []),\n  mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n  mockRequireDb: vi.fn(() => ({\n    prepare: vi.fn(() => ({\n      all: vi.fn(() => []),\n      get: vi.fn(() => undefined),\n    })),\n  })),\n  mockCategorizeFilesForIndexing: vi.fn((files: string[]) => ({\n    toIndex: files,\n    toUpdate: [] as string[],\n    toSkip: [] as string[],\n    toDelete: [] as string[],\n  })),\n  mockBatchUpdateMtimes: vi.fn(() => ({ updated: 0 })),\n  mockListIndexedRecordIdsForDeletedPaths: vi.fn((): number[] => []),\n  mockDeleteMemory: vi.fn((): boolean => true),\n  mockGetDb: vi.fn(() => ({\n    prepare: vi.fn(() => ({\n      get: vi.fn(() => undefined),\n    })),\n  })),\n  mockRunPostMutationHooks: vi.fn(() => ({ latencyMs: 0 })),\n  mockIndexMemoryFile: vi.fn(async () => ({ status: 'indexed', id: 1, specFolder: 'specs/test' })),\n}));\n\n// In-memory maintenance job store standing in for the persisted SQLite store.\nconst jobStore = vi.hoisted(() => {\n  interface FakeJob {\n    id: string;\n    kind: string;\n    state: string;\n    phase: string | null;\n    progressTotal: number;\n    progressProcessed: number;\n    cancelRequested: boolean;\n    errors: Array<{ source: string; message: string; timestamp: string }>;\n    result: unknown;\n    payload: unknown;\n    createdAt: string;\n    updatedAt: string;\n  }\n  const jobs = new Map<string, FakeJob>();\n  let counter = 0;\n  return {\n    jobs,\n    createJobId: vi.fn(() => { counter += 1; return `job_test_${counter}`; }),\n    ensureMaintenanceJobsTable: vi.fn(),\n    createMaintenanceJob: vi.fn(async (args: { id: string; kind: string; payload?: unknown }) => {\n      const job: FakeJob = {\n        id: args.id,\n        kind: args.kind,\n        state: 'queued',\n        phase: null,\n        progressTotal: 0,\n        progressProcessed: 0,\n        cancelRequested: false,\n        errors: [],\n        result: null,\n        payload: args.payload ?? null,\n        createdAt: 'seed',\n        updatedAt: 'seed',\n      };\n      jobs.set(args.id, job);\n      return job;\n    }),\n    getMaintenanceJob: vi.fn((id: string) => jobs.get(id) ?? null),\n    setJobState: vi.fn(async (id: string, state: string) => {\n      const job = jobs.get(id);\n      if (job) job.state = state;\n      return job ?? null;\n    }),\n    setJobPhase: vi.fn(async (id: string, phase: string) => {\n      const job = jobs.get(id);\n      if (job) job.phase = phase;\n    }),\n    setJobProgress: vi.fn(async (id: string, progress: { processed: number; total: number }) => {\n      const job = jobs.get(id);\n      if (job) { job.progressProcessed = progress.processed; job.progressTotal = progress.total; }\n    }),\n    appendJobError: vi.fn(async (id: string, source: string, error: unknown) => {\n      const job = jobs.get(id);\n      if (job) job.errors.push({ source, message: String(error), timestamp: 'seed' });\n      return job ?? null;\n    }),\n    requestCancel: vi.fn(async (id: string) => {\n      const job = jobs.get(id);\n      if (job) job.cancelRequested = true;\n    }),\n    isCancelRequested: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n    isCancelRequestedFast: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n    completeJob: vi.fn(async (id: string, options: { state: string; result?: unknown }) => {\n      const job = jobs.get(id);\n      if (job) { job.state = options.state; job.result = options.result ?? null; }\n      return job ?? null;\n    }),\n    resetRunningJobsForKind: vi.fn(() => [] as string[]),\n    isTerminalJobState: vi.fn((state: string) => state === 'complete' || state === 'failed' || state === 'cancelled'),\n    MAX_STORED_ERRORS: 50,\n  };\n});\n\n// ──────────────────────────────────────────────────────────────\n// 2. MODULE MOCKS\n// ──────────────────────────────────────────────────────────────\n\nvi.mock('../lib/ops/job-store', () => jobStore);\n\nvi.mock('../core', () => ({\n  checkDatabaseUpdated: mocks.mockCheckDatabaseUpdated,\n}));\n\nvi.mock('../core/db-state', async (importOriginal) => {\n  const actual = await importOriginal<typeof import('../core/db-state')>();\n  return {\n    ...actual,\n    acquireIndexScanLease: mocks.mockAcquireIndexScanLease,\n    completeIndexScanLease: mocks.mockCompleteIndexScanLease,\n  };\n});\n\nvi.mock('../core/config', async (importOriginal) => {\n  const actual = await importOriginal<typeof import('../core/config')>();\n  return {\n    ...actual,\n    INDEX_SCAN_COOLDOWN: 60000,\n    DEFAULT_BASE_PATH: '/tmp/mock-workspace',\n    BATCH_SIZE: 5,\n    SERVER_DIR: '/tmp/mock-server',\n  };\n});\n\nvi.mock('../utils', () => ({\n  processBatches: mocks.mockProcessBatches,\n  requireDb: mocks.mockRequireDb,\n  toErrorMessage: (error: unknown) => error instanceof Error ? error.message : String(error),\n}));\n\nvi.mock('../handlers/memory-index-discovery', () => ({\n  findSpecDocuments: mocks.mockFindSpecDocuments,\n  findConstitutionalFiles: mocks.mockFindConstitutionalFiles,\n  findGraphMetadataFiles: mocks.mockFindGraphMetadataFiles,\n  detectSpecLevel: vi.fn(() => null),\n}));\n\nvi.mock('../lib/providers/embeddings', () => ({\n  getEmbeddingProfile: vi.fn(() => null),\n}));\n\nvi.mock('../lib/storage/incremental-index', () => ({\n  categorizeFilesForIndexing: mocks.mockCategorizeFilesForIndexing,\n  batchUpdateMtimes: mocks.mockBatchUpdateMtimes,\n  listIndexedRecordIdsForDeletedPaths: mocks.mockListIndexedRecordIdsForDeletedPaths,\n}));\n\nvi.mock('../lib/search/vector-index', () => ({\n  deleteMemory: mocks.mockDeleteMemory,\n  getDb: mocks.mockGetDb,\n}));\n\nvi.mock('../handlers/mutation-hooks', () => ({\n  runPostMutationHooks: mocks.mockRunPostMutationHooks,\n}));\n\nvi.mock('../lib/response/envelope', () => ({\n  createMCPSuccessResponse: (payload: unknown) => ({\n    content: [{ type: 'text', text: JSON.stringify(payload) }],\n  }),\n  createMCPErrorResponse: (payload: unknown) => ({\n    content: [{ type: 'text', text: JSON.stringify(payload) }],\n  }),\n}));\n\nvi.mock('../handlers/memory-save', () => ({\n  indexMemoryFile: mocks.mockIndexMemoryFile,\n}));\n\nvi.mock('../lib/governance/scope-governance', () => ({\n  requiresGovernedIngest: vi.fn(() => false),\n  validateGovernedIngest: vi.fn(() => ({ allowed: true, issues: [] })),\n}));\n\nvi.mock('../lib/runtime/memory-runtime-guard', () => ({\n  ensureMemoryRuntimeInitialized: vi.fn(async () => undefined),\n}));\n\nvi.mock('../lib/utils/canonical-path', () => ({\n  getCanonicalPathKey: (p: string) => p,\n}));\n\nvi.mock('../handlers/memory-index-alias', () => ({\n  EMPTY_ALIAS_CONFLICT_SUMMARY: { groups: 0, divergentHashGroups: 0 },\n  createDefaultDivergenceReconcileSummary: () => ({ retriesScheduled: 0, escalated: 0, errors: [] }),\n  detectAliasConflictsFromIndex: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n  summarizeAliasConflicts: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n  runDivergenceReconcileHooks: vi.fn(() => ({ retriesScheduled: 0, escalated: 0, errors: [] })),\n}));\n\nvi.mock('../lib/storage/checkpoints', () => ({\n  getRestoreBarrierStatus: vi.fn(() => null),\n  repairNeedsRebuildSentinel: vi.fn(() => ({\n    sentinelPresent: false,\n    attempted: false,\n    cleared: false,\n    summary: null,\n    error: null,\n  })),\n}));\n\n// ──────────────────────────────────────────────────────────────\n// 3. MODULES UNDER TEST (imported after all vi.mock() calls)\n// ──────────────────────────────────────────────────────────────\n\nimport * as scanHandler from '../handlers/memory-index';\nimport * as scanJobHandlers from '../handlers/memory-index-scan-jobs';\n\n// ──────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ──────────────────────────────────────────────────────────────\n\nconst TEST_FILE = '/tmp/mock-workspace/.opencode/specs/test/spec.md';\n\nasync function waitFor(predicate: () => boolean, timeoutMs = 3000): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() < deadline) {\n    if (predicate()) return;\n    await delay(10);\n  }\n  throw new Error('Timed out waiting for condition');\n}\n\nfunction parseEnvelope(response: { content: Array<{ text: string }> }): { data: Record<string, unknown> } {\n  return JSON.parse(response.content[0].text) as { data: Record<string, unknown> };\n}\n\nfunction createBatchGate(): { gate: Promise<void>; release: () => void } {\n  let release = (): void => {};\n  const gate = new Promise<void>((resolve) => { release = resolve; });\n  return { gate, release };\n}\n\n// ──────────────────────────────────────────────────────────────\n// 5. TESTS\n// ──────────────────────────────────────────────────────────────\n\ndescribe('memory_index_scan background dispatch', () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n    jobStore.jobs.clear();\n\n    mocks.mockAcquireIndexScanLease.mockResolvedValue({\n      acquired: true,\n      reason: 'ok',\n      waitSeconds: 0,\n      lastIndexScan: 0,\n      scanStartedAt: 0,\n      leaseExpiryMs: 120000,\n      cooldownMs: 60000,\n    });\n    mocks.mockCompleteIndexScanLease.mockResolvedValue(undefined);\n    mocks.mockCheckDatabaseUpdated.mockResolvedValue(false);\n    mocks.mockFindSpecDocuments.mockReturnValue([TEST_FILE]);\n    mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n    mocks.mockFindGraphMetadataFiles.mockReturnValue([]);\n    mocks.mockCategorizeFilesForIndexing.mockReturnValue({\n      toIndex: [TEST_FILE],\n      toUpdate: [],\n      toSkip: [],\n      toDelete: [],\n    });\n    mocks.mockBatchUpdateMtimes.mockReturnValue({ updated: 0 });\n    mocks.mockListIndexedRecordIdsForDeletedPaths.mockReturnValue([]);\n    mocks.mockDeleteMemory.mockReturnValue(true);\n    mocks.mockGetDb.mockReturnValue({\n      prepare: vi.fn(() => ({ get: vi.fn(() => undefined), all: vi.fn(() => []) })),\n    });\n    mocks.mockRunPostMutationHooks.mockReturnValue({ latencyMs: 0 });\n    mocks.mockRequireDb.mockReturnValue({\n      prepare: vi.fn(() => ({ all: vi.fn(() => []), get: vi.fn(() => undefined) })),\n    });\n    mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'indexed', id: 1, specFolder: 'specs/test' });\n    mocks.mockProcessBatches.mockImplementation(\n      async (files: string[], worker: (file: string) => Promise<unknown>) => Promise.all(files.map(worker)),\n    );\n  });\n\n  it('background:true returns a queued jobId immediately without blocking on the scan', async () => {\n    const { gate, release } = createBatchGate();\n    mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n      await gate;\n      return Promise.all(files.map(worker));\n    });\n\n    const result = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.background).toBe(true);\n    expect(data.state).toBe('queued');\n    expect(typeof data.jobId).toBe('string');\n\n    const jobId = data.jobId as string;\n    // The runner advances to 'running' but parks at the gated batch loop — the\n    // handler already returned, proving the call did not block on the scan.\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'running');\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n\n    release();\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n    expect(mocks.mockIndexMemoryFile).toHaveBeenCalledTimes(1);\n  });\n\n  it('without background runs synchronously and never creates a job', async () => {\n    const result = await scanHandler.handleMemoryIndexScan({\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.status).toBe('complete');\n    expect(data.jobId).toBeUndefined();\n    expect(jobStore.createMaintenanceJob).not.toHaveBeenCalled();\n  });\n\n  it('memory_index_scan_status echoes the terminal result and returns E404 for unknown ids', async () => {\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n\n    const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n    const statusData = parseEnvelope(statusRes).data;\n    expect(statusData.state).toBe('complete');\n    const echoed = statusData.result as Record<string, unknown>;\n    expect(echoed.status).toBe('complete');\n\n    const missing = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId: 'job_missing' });\n    // The error envelope carries the code at the top level of the payload.\n    const missingPayload = JSON.parse(missing.content[0].text) as { code?: string };\n    expect(missingPayload.code).toBe('E404');\n  });\n\n  it('counts a cancelled file as neither failed nor success', async () => {\n    // A file whose worker returns 'cancelled' (operator-requested stop mid-batch)\n    // must not inflate the failure tally — the cancel is not a file error.\n    mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'cancelled' });\n\n    const result = await scanHandler.handleMemoryIndexScan({\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.failed).toBe(0);\n    expect(data.indexed).toBe(0);\n    expect(data.updated).toBe(0);\n  });\n\n  it('instruments the empty-files tail phases via timedPhase (onPhase markers)', async () => {\n    // No discoverable files routes through the empty-files branch; that branch must\n    // still fire onPhase for each tail maintenance phase so the busy marker refreshes\n    // and per-phase timing is emitted — symmetry with the main scan path.\n    mocks.mockFindSpecDocuments.mockReturnValue([]);\n    mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n\n    const phases = jobStore.setJobPhase.mock.calls.map((call) => call[1]);\n    expect(phases).toContain('orphan-sweep');\n    expect(phases).toContain('enrichment-repair');\n    expect(phases).toContain('near-dup-repair');\n    expect(phases).toContain('trigger-backfill');\n\n    // The empty-files branch never enters the indexing loop.\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n    const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n    const echoed = parseEnvelope(statusRes).data.result as Record<string, unknown>;\n    expect(echoed.status).toBe('complete');\n  });\n\n  it('cancel stops the runner at a phase boundary, releases the lease, and is idempotent', async () => {\n    const { gate, release } = createBatchGate();\n    mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n      await gate;\n      return Promise.all(files.map(worker));\n    });\n\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n\n    // Runner parks in the indexing phase, before any file work.\n    await waitFor(() => jobStore.jobs.get(jobId)?.phase === 'indexing');\n\n    const cancelRes = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n    expect(parseEnvelope(cancelRes).data.cancelRequested).toBe(true);\n\n    release();\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'cancelled');\n    expect(mocks.mockCompleteIndexScanLease).toHaveBeenCalled();\n    // Cancellation at the phase boundary must prevent the indexing work itself.\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n\n    // Cancelling an already-terminal job is a no-op success.\n    const again = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n    expect(parseEnvelope(again).data.state).toBe('cancelled');\n  });\n});","lineStart":1,"lineEnd":451,"totalLines":451,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","time":{"start":1781755631197,"end":1781755631202}},"metadata":{"openai":{"itemId":"fc_037f7296ff70a56b016a336eef1660819183ee360041ce9b1b"}},"id":"prt_ed8e9565b0014h4cGDXLg8yQiP","sessionID":"ses_127185023ffen0qKKl1I08wyww","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4"}}
{"type":"tool_use","timestamp":1781755631218,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"type":"tool","tool":"read","callID":"call_RfomdGYdMRxbk0Pr9KVwRL9z","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   readMaintenanceMarker,\n37:   shouldAdoptDespiteProbe,\n38:   releaseRespawnLockFile,\n39:   sampleProcessTreeRssMb,\n40:   shouldAbortRelaunchOnFire,\n41:   shouldSkipLaunch,\n42:   signalProcess,\n43:   superviseChildExit,\n44:   waitForPidExit,\n45: } = mss;\n46: \n47: const root = path.resolve(__dirname, '..', '..');\n48: const opencodeDir = path.join(root, '.opencode');\n49: \n50: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n51: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n52: // Minimal parser — no external dependency.\n53: function loadEnvFile(filePath) {\n54:   if (!fs.existsSync(filePath)) return 0;\n55:   let count = 0;\n56:   const raw = fs.readFileSync(filePath, 'utf8');\n57:   for (const line of raw.split('\\n')) {\n58:     const trimmed = line.trim();\n59:     if (!trimmed || trimmed.startsWith('#')) continue;\n60:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n61:     if (!m) continue;\n62:     const key = m[1];\n63:     let val = m[2];\n64:     // Strip matching outer quotes (single or double)\n65:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n66:       val = val.slice(1, -1);\n67:     }\n68:     if (!(key in process.env)) {\n69:       process.env[key] = val;\n70:       count++;\n71:     }\n72:   }\n73:   return count;\n74: }\n75: \n76: function isStrictModeDisabled(value) {\n77:   if (value === undefined || value === null) return false;\n78:   const v = String(value).trim().toLowerCase();\n79:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n80: }\n81: \n82: let skillsDir = path.join(opencodeDir, 'skills');\n83: let legacySkillDir = path.join(opencodeDir, 'skill');\n84: let kitDir = path.join(skillsDir, 'system-spec-kit');\n85: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n86: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n87: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n88: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n89: let stateFile = path.join(dbDir, PID_FILE_NAME);\n90: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n91: \n92: const rel = (p) => path.relative(root, p) || '.';\n93: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n94: const now = () => new Date().toISOString();\n95: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n96: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n97: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n98: let childProcess = null;\n99: let ownerLeasePid = null;\n100: let leaseStartedAt = null;\n101: let launcherShutdownInProgress = false;\n102: let rssBreachSelfExitInProgress = false;\n103: let rssWatchdogTimer = null;\n104: let crashLoopGuard = null;\n105: let supervisorRelaunchTimer = null;\n106: // The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n107: // launcher's parent. When the host disposes its session the launcher is orphaned and its\n108: // ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n109: // path can tell \"owning runtime went away\" apart from a genuine daemon crash.\n110: const LAUNCHER_INITIAL_PPID = process.ppid;\n111: let ownerLeaseHeartbeatTimer = null;\n112: let ownerLeaseRequired = true;\n113: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n114: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n115: // orphaned sidecar after the child has already exited.\n116: let lastKnownDescendantPids = [];\n117: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n118: const durableWriteWarnings = new Set();\n119: // Daemon exit code meaning \"another live process holds the database\n120: // single-writer lock\". Never counts toward the crash loop: the right move is\n121: // bridging to the live owner (or a bounded retry while a maintenance script\n122: // finishes), not relaunching a doomed second writer. Mirrored in\n123: // mcp_server context-server (EXIT_DB_LOCK_HELD).\n124: const EXIT_DB_LOCK_HELD = 86;\n125: const DB_LOCK_HELD_MAX_RETRIES = 3;\n126: let dbLockHeldRetries = 0;\n127: \n128: function log(message) {\n129:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n130:   persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n131: }\n132: \n133: function isDurableWriteUnavailable(error) {\n134:   const code = error && typeof error === 'object' ? error.code : undefined;\n135:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n136: }\n137: \n138: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n139:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n140:   const key = `${operation}:${targetPath}:${code}`;\n141:   if (durableWriteWarnings.has(key)) return;\n142:   durableWriteWarnings.add(key);\n143:   const detail = error instanceof Error ? error.message : String(error ?? code);\n144:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n145: }\n146: \n147: // Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n148: // ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n149: // durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n150: // launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n151: // grow without bound.\n152: function launcherLogIsEnabled(env = process.env) {\n153:   return env.SPECKIT_LAUNCHER_LOG !== '0';\n154: }\n155: function launcherLogMaxBytes(env = process.env) {\n156:   return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n157: }\n158: function resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n159:   const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n160:   return typeof override === 'string' && override.trim()\n161:     ? override.trim()\n162:     : path.join(baseDir, '.mk-spec-memory-launcher.log');\n163: }\n164: function shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n165:   return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n166: }\n167: function persistLauncherLogLine(line) {\n168:   if (!launcherLogIsEnabled()) return;\n169:   let target;\n170:   try {\n171:     target = resolveLauncherLogPath();\n172:     try {\n173:       const { size } = fs.statSync(target);\n174:       if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n175:         try {\n176:           // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n177:           // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n178:           // suffix still rotates instead of renaming the file onto itself and growing without bound.\n179:           const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n180:           fs.renameSync(target, rotated);\n181:         } catch {\n182:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n183:         }\n184:       }\n185:     } catch (statErr) {\n186:       if (statErr.code !== 'ENOENT') throw statErr;\n187:     }\n188:     fs.appendFileSync(target, line, { mode: 0o600 });\n189:   } catch (error) {\n190:     if (target && isDurableWriteUnavailable(error)) {\n191:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n192:       return;\n193:     }\n194:     // Logging must never break the launcher.\n195:   }\n196: }\n197: \n198: // Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n199: // When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n200: // (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n201: // not tear the shared backend out from under other sessions. A fresh session that finds the released\n202: // daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n203: // it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n204: // writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n205: // killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n206: // sweeper bounds any leak.\n207: function daemonReelectionEnabled(env = process.env) {\n208:   return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n209: }\n210: function contextServerSpawnIo(reelectionEnabled) {\n211:   return reelectionEnabled\n212:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n213:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n214: }\n215: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n216:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n217: }\n218: \n219: function cleanupTmpFile(tmpPath) {\n220:   try {\n221:     fs.unlinkSync(tmpPath);\n222:   } catch (error) {\n223:     if (error.code !== 'ENOENT') {\n224:       // Best-effort cleanup only; the original durable-write failure is more useful.\n225:     }\n226:   }\n227: }\n228: \n229: function writeAtomicJsonFile(targetPath, payload, operation) {\n230:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n231:   const tmp = `${currentPath}.tmp.${process.pid}`;\n232:   try {\n233:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n234:     fs.renameSync(tmp, currentPath);\n235:     return true;\n236:   } catch (error) {\n237:     cleanupTmpFile(tmp);\n238:     if (isDurableWriteUnavailable(error)) {\n239:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n240:       return false;\n241:     }\n242:     throw error;\n243:   }\n244: }\n245: \n246: function loadProjectEnvFiles() {\n247:   for (const fname of ['.env.local', '.env']) {\n248:     const p = path.join(root, fname);\n249:     if (fs.existsSync(p)) {\n250:       const n = loadEnvFile(p);\n251:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n252:     }\n253:   }\n254: }\n255: \n256: function parsePositiveInteger(value, fallback) {\n257:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n258:   const parsed = Number.parseInt(String(value).trim(), 10);\n259:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n260: }\n261: \n262: function loadBridgeModule() {\n263:   try {\n264:     return require('./lib/launcher-ipc-bridge.cjs');\n265:   } catch (error) {\n266:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n267:     return {\n268:       async maybeBridgeLeaseHolder({ leaseResult }) {\n269:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n270:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n271:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n272:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n273:         return { action: 'report', reason: 'bridge-module-missing' };\n274:       },\n275:     };\n276:   }\n277: }\n278: \n279: function resolveSessionProxySocketPath() {\n280:   const { getIpcSocketPath } = loadBridgeModule();\n281:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n282: }\n283: \n284: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n285: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n286: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n287: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n288: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n289: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n290: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n291: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n292:   const createProxy = options.createProxy ?? createSessionProxy;\n293:   const sessionProxy = createProxy({\n294:     socketPath,\n295:     stdin: options.stdin ?? process.stdin,\n296:     stdout: options.stdout ?? process.stdout,\n297:     log,\n298:   });\n299:   return sessionProxy.start();\n300: }\n301: \n302: function refreshPaths() {\n303:   skillsDir = path.join(opencodeDir, 'skills');\n304:   legacySkillDir = path.join(opencodeDir, 'skill');\n305:   kitDir = path.join(skillsDir, 'system-spec-kit');\n306:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n307:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n308:   stateFile = path.join(dbDir, PID_FILE_NAME);\n309:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n310: }\n311: \n312: function exists(p) {\n313:   return fs.existsSync(p);\n314: }\n315: \n316: function writeState(payload) {\n317:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n318:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n319: }\n320: \n321: function resolvedDbDir() {\n322:   return canonicalizePath(dbDir);\n323: }\n324: \n325: // Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n326: // daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n327: // resolved against cwd, else the default DB dir) so both sides agree on the path\n328: // even under a test fake-root that sets SPEC_KIT_DB_DIR.\n329: function maintenanceMarkerDir() {\n330:   const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n331:   if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n332:   return resolvedDbDir();\n333: }\n334: \n335: function leasePath() {\n336:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n337: }\n338: \n339: function ownerLeasePath() {\n340:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n341: }\n342: \n343: function legacyLeasePaths() {\n344:   return [\n345:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n346:   ].map(canonicalizePath);\n347: }\n348: \n349: function readLeaseFile(filePath = leasePath()) {\n350:   try {\n351:     const raw = fs.readFileSync(filePath, 'utf8');\n352:     const parsed = JSON.parse(raw);\n353:     if (typeof parsed.pid === 'number') return parsed;\n354:   } catch {\n355:     // Missing or corrupt lease files are treated as no active lease.\n356:   }\n357:   return null;\n358: }\n359: \n360: function readOwnerLeaseFile(filePath = ownerLeasePath()) {\n361:   try {\n362:     const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n363:     if (\n364:       Number.isInteger(parsed.ownerPid) &&\n365:       Number.isInteger(parsed.ppid) &&\n366:       typeof parsed.executablePath === 'string' &&\n367:       typeof parsed.startedAtIso === 'string' &&\n368:       typeof parsed.lastHeartbeatIso === 'string' &&\n369:       Number.isInteger(parsed.ttlMs) &&\n370:       typeof parsed.canonicalDbDir === 'string'\n371:     ) {\n372:       return parsed;\n373:     }\n374:   } catch {\n375:     // Missing or corrupt owner leases are treated as no active owner.\n376:   }\n377:   return null;\n378: }\n379: \n380: function writeOwnerLeaseFile(lease) {\n381:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n382:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n383:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n384:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n385:   // after power loss and break ownership detection.\n386:   let fd;\n387:   try {\n388:     fd = fs.openSync(tmp, 'wx', 0o600);\n389:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n390:     fs.fsyncSync(fd);\n391:   } finally {\n392:     if (typeof fd === 'number') fs.closeSync(fd);\n393:   }\n394:   fs.renameSync(tmp, currentLeasePath);\n395: }\n396: \n397: function writeOwnerLeaseFileExclusive(lease) {\n398:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n399:   let fd;\n400:   try {\n401:     fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n402:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n403:     fs.fsyncSync(fd);\n404:     return true;\n405:   } catch (error) {\n406:     if (error.code === 'EEXIST') return false;\n407:     throw error;\n408:   } finally {\n409:     if (typeof fd === 'number') fs.closeSync(fd);\n410:   }\n411: }\n412: \n413: function buildOwnerLease(ownerPid = process.pid) {\n414:   return {\n415:     ownerPid,\n416:     ppid: process.ppid,\n417:     executablePath: process.execPath,\n418:     startedAtIso: new Date().toISOString(),\n419:     lastHeartbeatIso: new Date().toISOString(),\n420:     ttlMs: 60000,\n421:     canonicalDbDir: resolvedDbDir(),\n422:   };\n423: }\n424: \n425: function readParentPid(pid) {\n426:   if (!Number.isInteger(pid) || pid <= 0) return null;\n427:   if (process.platform === 'linux') {\n428:     try {\n429:       const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n430:       const match = status.match(/^PPid:\\s+(\\d+)$/m);\n431:       return match ? Number.parseInt(match[1], 10) : null;\n432:     } catch {\n433:       return null;\n434:     }\n435:   }\n436:   const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n437:     encoding: 'utf8',\n438:     stdio: ['ignore', 'pipe', 'ignore'],\n439:   });\n440:   if (result.status !== 0 || !result.stdout) return null;\n441:   const parsed = Number.parseInt(result.stdout.trim(), 10);\n442:   return Number.isInteger(parsed) ? parsed : null;\n443: }\n444: \n445: function classifyOwnerLease(lease) {\n446:   const liveness = processLiveness(lease.ownerPid);\n447:   if (liveness === 'dead') return 'stale-pid';\n448:   if (liveness === 'unknown-eperm') return 'unknown-eperm';\n449: \n450:   const actualPpid = readParentPid(lease.ownerPid);\n451:   if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n452:     return 'ppid-1-orphan';\n453:   }\n454: \n455:   const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n456:   const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n457:   if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n458:     return 'stale-heartbeat-reclaim';\n459:   }\n460: \n461:   return 'live-owner';\n462: }\n463: \n464: function acquireOwnerLeaseFile() {\n465:   const currentOwnerLeasePath = ownerLeasePath();\n466:   const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n467: \n468:   if (existing) {\n469:     const classification = classifyOwnerLease(existing);\n470:     if (classification === 'live-owner' || classification === 'unknown-eperm') {\n471:       return { acquired: false, holder: existing, classification };\n472:     }\n473:     log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n474:   }\n475: \n476:   const lease = buildOwnerLease(process.pid);\n477:   // Reclaim a stale lease by removing it first, then claim exclusively (O_EXCL).\n478:   // This collapses the fresh-acquire and stale-reclaim paths into a single CAS so\n479:   // only one racer can win: the loser's exclusive create hits EEXIST and returns\n480:   // acquired:false instead of last-writer-wins overwriting the winner's lease.\n481:   if (existing) {\n482:     try {\n483:       fs.unlinkSync(currentOwnerLeasePath);\n484:     } catch (error) {\n485:       if (error.code !== 'ENOENT') throw error;\n486:     }\n487:   }\n488:   if (!writeOwnerLeaseFileExclusive(lease)) {\n489:     const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n490:     return {\n491:       acquired: false,\n492:       holder: holder || lease,\n493:       classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n494:     };\n495:   }\n496:   ownerLeasePid = process.pid;\n497:   return { acquired: true, lease, reclaimed: existing };\n498: }\n499: \n500: function refreshOwnerLeaseFile(ownerPid, patch = {}) {\n501:   const lease = readOwnerLeaseFile();\n502:   if (!lease || lease.ownerPid !== ownerPid) return false;\n503:   const nextOwnerPid = patch.ownerPid ?? ownerPid;\n504:   writeOwnerLeaseFile({\n505:     ...lease,\n506:     ...patch,\n507:     lastHeartbeatIso: new Date().toISOString(),\n508:   });\n509:   const reread = readOwnerLeaseFile();\n510:   if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n511:   ownerLeasePid = nextOwnerPid;\n512:   return true;\n513: }\n514: \n515: function clearOwnerLeaseHeartbeat() {\n516:   if (ownerLeaseHeartbeatTimer) {\n517:     clearInterval(ownerLeaseHeartbeatTimer);\n518:     ownerLeaseHeartbeatTimer = null;\n519:   }\n520: }\n521: \n522: function startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n523:   clearOwnerLeaseHeartbeat();\n524:   const lease = readOwnerLeaseFile();\n525:   const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n526:   const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n527:   ownerLeaseHeartbeatTimer = setInterval(() => {\n528:     if (refreshOwnerLeaseFile(ownerPid)) return;\n529:     log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n530:     clearOwnerLeaseHeartbeat();\n531:     void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n532:       log(error.stack || error.message);\n533:       clearAllLeaseFiles();\n534:       process.exit(128);\n535:     });\n536:   }, intervalMs);\n537:   ownerLeaseHeartbeatTimer.unref?.();\n538: }\n539: \n540: function ownsOwnerLeaseFile(ownerPid = process.pid) {\n541:   const lease = readOwnerLeaseFile();\n542:   return lease?.ownerPid === ownerPid;\n543: }\n544: \n545: function clearOwnerLeaseFile() {\n546:   if (!Number.isInteger(ownerLeasePid)) return;\n547:   try {\n548:     const lease = readOwnerLeaseFile();\n549:     if (lease && lease.ownerPid === ownerLeasePid\n550:         && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n551:       fs.unlinkSync(ownerLeasePath());\n552:     }\n553:   } catch {\n554:     // Idempotent cleanup.\n555:   } finally {\n556:     clearOwnerLeaseHeartbeat();\n557:     ownerLeasePid = null;\n558:   }\n559: }\n560: \n561: function clearOwnerLeaseFileIfOwner(ownerPid) {\n562:   try {\n563:     const lease = readOwnerLeaseFile();\n564:     if (lease && lease.ownerPid === ownerPid\n565:         && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n566:       fs.unlinkSync(ownerLeasePath());\n567:     }\n568:   } catch {\n569:     // Idempotent cleanup.\n570:   }\n571: }\n572: \n573: function leaseHeldFromFile(filePath, legacyPath = null) {\n574:   const lease = readLeaseFile(filePath);\n575:   if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };\n576:   const startedAt = lease.startedAt ?? new Date(0).toISOString();\n577:   // Surface the owner-recorded socket path so the bridge can prefer it over recomputing one that\n578:   // may diverge under a different SPECKIT_IPC_SOCKET_DIR. Null when the lease predates this field.\n579:   const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;\n580:   try {\n581:     process.kill(lease.pid, 0);\n582:     return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n583:   } catch (error) {\n584:     if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };\n585:     // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n586:     if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n587:     throw error;\n588:   }\n589: }\n590: \n591: function isLeaseHeld() {\n592:   const primary = leaseHeldFromFile(leasePath());\n593:   if (primary.held) return primary;\n594: \n595:   for (const legacyPath of legacyLeasePaths()) {\n596:     if (legacyPath === leasePath()) continue;\n597:     const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n598:     if (legacy.held || legacy.staleReclaimable) return legacy;\n599:   }\n600: \n601:   return primary;\n602: }\n603: \n604: function writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n605:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n606:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n607:   process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n608: }\n609: \n610: function writeLeaseHeldJsonRpcError(leaseResult, reason) {\n611:   process.stdout.write(`${JSON.stringify({\n612:     jsonrpc: '2.0',\n613:     id: null,\n614:     error: {\n615:       code: -32001,\n616:       message: `mk-spec-memory: lease held by pid ${leaseResult.ownerPid} but session bridge unavailable (${reason}); reconnect`,\n617:       data: { retryable: true },\n618:     },\n619:   })}\\n`);\n620: }\n621: \n622: function bridgeReadiness(leaseResult) {\n623:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n624:     return { ready: false, reason: 'bridge-disabled' };\n625:   }\n626:   const storedSocketPath = leaseResult.socketPath;\n627:   if (\n628:     typeof storedSocketPath === 'string' &&\n629:     storedSocketPath.length > 0 &&\n630:     (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n631:   ) {\n632:     return { ready: true, socketPath: storedSocketPath };\n633:   }\n634:   const { getIpcSocketPath } = loadBridgeModule();\n635:   if (typeof getIpcSocketPath !== 'function') {\n636:     return { ready: false, reason: 'bridge-module-missing' };\n637:   }\n638:   const socketPath = getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n639:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n640:     return { ready: false, reason: 'no-bridge-socket' };\n641:   }\n642:   return { ready: true, socketPath };\n643: }\n644: \n645: function leaseResultForOwnerLease(ownerLease) {\n646:   const pidLeaseResult = isLeaseHeld();\n647:   if (pidLeaseResult.held && pidLeaseResult.ownerPid === ownerLease.ownerPid) {\n648:     return pidLeaseResult;\n649:   }\n650:   return {\n651:     held: true,\n652:     ownerPid: ownerLease.ownerPid,\n653:     staleReclaimable: false,\n654:     startedAt: ownerLease.startedAtIso,\n655:     legacyPath: null,\n656:     socketPath: null,\n657:   };\n658: }\n659: \n660: function respawnLockPath() {\n661:   return path.join(resolvedDbDir(), '.mk-spec-memory-respawn.lock');\n662: }\n663: \n664: function modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath()) {\n665:   return mss.modelServerRespawnLockPath(socketPath, { dbDir: resolvedDbDir });\n666: }\n667: \n668: function acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n669:   return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n670: }\n671: \n672: function acquireRespawnLockFile() {\n673:   return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n674: }\n675: \n676: function acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n677:   return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n678: }\n679: \n680: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n681: \n682: // The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n683: // successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n684: // child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n685: // DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n686: // guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\n687: function uncleanShutdownMarkerPath() {\n688:   // Mirror the daemon's full path precedence, not just MEMORY_DB_PATH:\n689:   // the daemon resolves its database dir from SPEC_KIT_DB_DIR /\n690:   // SPECKIT_DB_DIR before falling back to the packaged default, and the\n691:   // marker lives beside whatever database it actually opened. Checking the\n692:   // static dir under a dir override silently forfeits clean-close detection.\n693:   const fileOverride = process.env.MEMORY_DB_PATH?.trim();\n694:   if (fileOverride) {\n695:     return path.join(path.dirname(fileOverride), UNCLEAN_SHUTDOWN_MARKER);\n696:   }\n697:   const dirOverride = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n698:   const dir = dirOverride ? path.resolve(root, dirOverride) : resolvedDbDir();\n699:   return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n700: }\n701: \n702: function uncleanMarkerPresent() {\n703:   try {\n704:     return fs.existsSync(uncleanShutdownMarkerPath());\n705:   } catch {\n706:     return false;\n707:   }\n708: }\n709: \n710: // A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n711: // clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n712: // replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\n713: function cleanCloseAfterReap({ killed, markerPresent }) {\n714:   return !killed && !markerPresent;\n715: }\n716: \n717: async function reapLeaseChildBeforeRespawn(childPid) {\n718:   const liveness = processLiveness(childPid);\n719:   if (liveness === 'unknown-eperm') {\n720:     return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n721:   }\n722:   if (liveness === 'dead') {\n723:     return {\n724:       allowed: true,\n725:       reaped: false,\n726:       cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n727:       reason: 'child-already-dead',\n728:     };\n729:   }\n730: \n731:   log(`reaping recorded context-server child pid ${childPid} before respawn`);\n732:   signalProcess(childPid, 'SIGTERM');\n733:   reapProcessTreeGroups(childPid, { signal: signalProcess });\n734:   const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n735:   let killed = false;\n736:   if (!exitedAfterTerm) {\n737:     log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n738:     signalProcess(childPid, 'SIGKILL');\n739:     const exitedAfterKill = await waitForPidExit(childPid, 1000);\n740:     killed = true;\n741:     if (!exitedAfterKill) {\n742:       // The child outlived SIGKILL within the grace window (uninterruptible state, or a pid we can\n743:       // no longer confirm). Refuse to hand the database to a replacement while the recorded writer\n744:       // may still be alive, so a caller never spawns a second writer onto the same WAL.\n745:       log(`context-server child pid ${childPid} did not exit after SIGKILL within grace; refusing respawn`);\n746:       return { allowed: false, reason: 'child-kill-unconfirmed' };\n747:     }\n748:   }\n749: \n750:   // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n751:   // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n752:   // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n753:   // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n754:   const markerPresent = uncleanMarkerPresent();\n755:   const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n756:   if (!cleanClose) {\n757:     log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n758:   }\n759:   return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n760: }\n761: \n762: async function reapOwnerBeforeRespawn(ownerPid) {\n763:   const liveness = processLiveness(ownerPid);\n764:   if (liveness === 'unknown-eperm') {\n765:     return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n766:   }\n767:   if (liveness === 'dead') {\n768:     return { allowed: true, reason: 'owner-already-dead' };\n769:   }\n770: \n771:   // A socket probe cannot distinguish a genuinely-dead daemon from one that merely\n772:   // refused the connection at its client cap (both look \"closed before reply\"). Before\n773:   // killing a process that is still ALIVE, require the owner lease to be heartbeat-stale\n774:   // too: a daemon that has refreshed its lease within its TTL is serving clients, not\n775:   // dead, and must never be reaped on a socket-probe-only verdict regardless of cap.\n776:   const currentOwner = readOwnerLeaseFile();\n777:   if (currentOwner?.ownerPid === ownerPid && classifyOwnerLease(currentOwner) === 'live-owner') {\n778:     log(`spec-memory owner pid ${ownerPid} is heartbeat-fresh (live-owner); refusing socket-probe reap (likely cap-refusal, not death)`);\n779:     return { allowed: false, reason: 'owner-heartbeat-fresh' };\n780:   }\n781: \n782:   log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n783:   signalProcess(ownerPid, 'SIGTERM');\n784:   const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n785:   if (!exitedAfterTerm) {\n786:     log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n787:     signalProcess(ownerPid, 'SIGKILL');\n788:     await waitForPidExit(ownerPid, 1000);\n789:   }\n790:   return { allowed: true, reason: 'owner-reaped' };\n791: }\n792: \n793: async function respawnAfterDeadSocket(leaseResult, decision) {\n794:   if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n795:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n796:     return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n797:   }\n798: \n799:   const ownerPid = leaseResult.ownerPid;\n800:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n801:     log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n802:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n803:     return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n804:   }\n805: \n806:   const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n807:   const childPid = lease?.childPid;\n808:   if (!Number.isInteger(childPid) || childPid <= 0) {\n809:     log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n810:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n811:     return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n812:   }\n813: \n814:   // A daemon mid-maintenance (e.g. a background index scan) legitimately fails the\n815:   // deep liveness probe because its event loop is busy, not dead. If it holds a\n816:   // fresh marker naming this exact live child, refuse the respawn and leave it\n817:   // running. The marker lapses if the daemon is genuinely wedged (it can no longer\n818:   // refresh it), so a real death still respawns once the marker expires. Checked\n819:   // before the respawn lock and any reap so a bail unwinds nothing.\n820:   const deadSocketMarker = readMaintenanceMarker(maintenanceMarkerDir());\n821:   if (shouldAdoptDespiteProbe({ marker: deadSocketMarker, childPid, childLiveness: processLiveness(childPid) })) {\n822:     log(`confirmed-dead socket but child pid ${childPid} holds a fresh maintenance marker (activeUntil ${new Date(deadSocketMarker.activeUntilMs).toISOString()}); refusing respawn (busy, not dead)`);\n823:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-maintenance-active)');\n824:     return { action: 'report', reason: 'maintenance-active', socketPath: decision.socketPath };\n825:   }\n826: \n827:   let bootstrapLockHeld = false;\n828:   let respawnLock = null;\n829:   try {\n830:     bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n831:     respawnLock = acquireRespawnLockFile();\n832:     if (!respawnLock.acquired) {\n833:       log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n834:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n835:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n836:     }\n837: \n838:     const currentOwner = readOwnerLeaseFile();\n839:     if (currentOwner?.ownerPid !== ownerPid) {\n840:       log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n841:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n842:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n843:     }\n844: \n845:     const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n846:     if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n847:       log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n848:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n849:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n850:     }\n851: \n852:     const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n853:     if (!ownerReapResult.allowed) {\n854:       log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n855:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n856:       return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n857:     }\n858: \n859:     clearOwnerLeaseFileIfOwner(ownerPid);\n860:     const ownerLease = buildOwnerLease(process.pid);\n861:     if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n862:       const holder = readOwnerLeaseFile();\n863:       log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n864:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n865:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n866:     }\n867:     ownerLeasePid = process.pid;\n868: \n869:     const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n870:     if (!reapResult.allowed) {\n871:       log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n872:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n873:       return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n874:     }\n875: \n876:     buildIfNeeded([]);\n877:     leaseStartedAt = new Date().toISOString();\n878:     writeLeaseFile();\n879:     launchServer();\n880:     return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n881:   } finally {\n882:     releaseRespawnLockFile(respawnLock);\n883:     if (bootstrapLockHeld) {\n884:       fs.rmSync(lockDir, { recursive: true, force: true });\n885:     }\n886:   }\n887: }\n888: \n889: async function bridgeOrReportLeaseHeld(leaseResult) {\n890:   const readiness = bridgeReadiness(leaseResult);\n891:   if (!readiness.ready) {\n892:     writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n893:     return { action: 'report', reason: readiness.reason };\n894:   }\n895:   const { maybeBridgeLeaseHolder } = loadBridgeModule();\n896:   const decision = await maybeBridgeLeaseHolder({\n897:     serviceName: 'mk-spec-memory',\n898:     leaseResult,\n899:     loggerPrefix: 'mk-spec-memory-launcher',\n900:     dbDir: resolvedDbDir(),\n901:     bridge: bridgeStdioThroughSessionProxy,\n902:   });\n903:   if (decision && decision.action === 'respawn') {\n904:     return await respawnAfterDeadSocket(leaseResult, decision);\n905:   }\n906:   return decision;\n907: }\n908: \n909: async function bridgeOrReportLeaseHeldAndExit(leaseResult) {\n910:   const decision = await bridgeOrReportLeaseHeld(leaseResult);\n911:   if (!decision || decision.action === 'report') {\n912:     clearOwnerLeaseFile();\n913:     process.exit(0);\n914:   }\n915:   return decision;\n916: }\n917: \n918: function resolveModelServerSocketPath(env = process.env, options = {}) {\n919:   return mss.resolveModelServerSocketPath(env, {\n920:     ...options,\n921:     dbDir: options.dbDir || resolvedDbDir,\n922:   });\n923: }\n924: \n925: function getContextServerPid() {\n926:   return isChildRunning(childProcess) ? childProcess.pid : null;\n927: }\n928: \n929: // Pure lease-payload builder (exported for tests). `childPid`, `modelServerPid`, and `socketPath`\n930: // are ADDITIVE fields; existing readers consume only pid/startedAt/ownerPid and ignore the extras.\n931: // `socketPath` records the IPC path this owner actually listens on so a secondary launcher prefers\n932: // it over recomputing one that can diverge under a different SPECKIT_IPC_SOCKET_DIR.\n933: function buildLeaseObject(childPid = null, startedAt = leaseStartedAt, modelServerPid = null, socketPath = null) {\n934:   return buildSharedLeaseObject(childPid, startedAt || new Date().toISOString(), modelServerPid, socketPath);\n935: }\n936: \n937: function writeLeaseFile(childPid = getContextServerPid(), modelServerPid = hfControl.getPid()) {\n938:   if (!leaseStartedAt) leaseStartedAt = new Date().toISOString();\n939:   const payload = buildLeaseObject(childPid, leaseStartedAt, modelServerPid, resolveSessionProxySocketPath());\n940:   return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n941: }\n942: \n943: function sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n944:   const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n945:   return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n946: }\n947: \n948: function writeSharedModelServerPid(pid) {\n949:   const socketPath = resolveModelServerSocketPath();\n950:   const pidPath = sharedModelServerPidPath(socketPath);\n951:   if (!Number.isInteger(pid) || pid <= 0) {\n952:     try {\n953:       fs.unlinkSync(pidPath);\n954:     } catch (error) {\n955:       if (error.code === 'ENOENT') return true;\n956:       if (isDurableWriteUnavailable(error)) {\n957:         logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n958:         return false;\n959:       }\n960:       throw error;\n961:     }\n962:     return true;\n963:   }\n964: \n965:   return writeAtomicJsonFile(pidPath, {\n966:     pid,\n967:     startedAt: new Date().toISOString(),\n968:     ownerLauncher: 'mk-spec-memory',\n969:     socketPath,\n970:   }, 'shared model-server pid write');\n971: }\n972: \n973: function readSharedModelServerPid() {\n974:   const pidPath = sharedModelServerPidPath();\n975:   try {\n976:     const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n977:     if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n978:   } catch (error) {\n979:     if (error.code !== 'ENOENT') {\n980:       // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n981:     }\n982:   }\n983: \n984:   const lease = readLeaseFile();\n985:   return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n986: }\n987: \n988: const hfControl = mss.createModelServerControl({\n989:   log,\n990:   env: process.env,\n991:   rootDir: root,\n992:   opencodeDir,\n993:   dbDir: resolvedDbDir,\n994:   getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n995:   onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n996:   bridge: loadBridgeModule(),\n997:   writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n998:   readModelServerPid: () => readSharedModelServerPid(),\n999:   writeLease: () => writeLeaseFile(),\n1000: });\n1001: \n1002: function clearLeaseFile() {\n1003:   try {\n1004:     const lease = readLeaseFile();\n1005:     if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n1006:       try {\n1007:         hfControl.reapProcessTree(lease.modelServerPid);\n1008:       } catch {\n1009:         // Lease cleanup must remain best-effort even if a final process-tree read fails.\n1010:       }\n1011:     }\n1012:     if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n1013:   } catch {\n1014:     // Idempotent cleanup.\n1015:   }\n1016: }\n1017: \n1018: function clearAllLeaseFiles() {\n1019:   clearLeaseFile();\n1020:   clearOwnerLeaseFile();\n1021: }\n1022: \n1023: function isInside(parent, child) {\n1024:   const relative = path.relative(parent, child);\n1025:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n1026: }\n1027: \n1028: function enforceStandaloneCodeGraphDb(actions) {\n1029:   const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n1030:   const resolvedCurrent = current ? path.resolve(current) : null;\n1031:   const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n1032:   const specKitRoot = path.resolve(kitDir);\n1033: \n1034:   if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n1035:     process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n1036:     actions.push(\n1037:       `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n1038:     );\n1039:   }\n1040: }\n1041: \n1042: function run(command, args, options = {}) {\n1043:   const result = spawnSync(command, args, {\n1044:     cwd: options.cwd || root,\n1045:     env: process.env,\n1046:     encoding: 'utf8',\n1047:     stdio: ['ignore', 'pipe', 'pipe'],\n1048:   });\n1049: \n1050:   if (result.stdout) {\n1051:     process.stderr.write(result.stdout);\n1052:   }\n1053:   if (result.stderr) {\n1054:     process.stderr.write(result.stderr);\n1055:   }\n1056:   if (result.error) {\n1057:     throw result.error;\n1058:   }\n1059:   if (result.status !== 0) {\n1060:     throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n1061:   }\n1062: }\n1063: \n1064: function ensureLayout(actions) {\n1065:   if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n1066:     fs.renameSync(legacySkillDir, skillsDir);\n1067:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n1068:     actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n1069:     refreshPaths();\n1070:     return;\n1071:   }\n1072: \n1073:   if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n1074:     const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n1075:     fs.renameSync(legacySkillDir, backup);\n1076:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n1077:     actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n1078:     refreshPaths();\n1079:     return;\n1080:   }\n1081: \n1082:   // Compatibility symlink `.opencode/skill -> skills` removed; a prior cleanup cleaned\n1083:   // up consumers of the singular path, so the bridge no longer needs to be\n1084:   // recreated on every MCP startup. Migration paths above (rename / move-aside)\n1085:   // still create the symlink when an actual legacy singular dir is present.\n1086: }\n1087: \n1088: function requiredArtifacts() {\n1089:   return [\n1090:     path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n1091:     path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n1092:     path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n1093:   ];\n1094: }\n1095: \n1096: function artifactsReady() {\n1097:   return requiredArtifacts().every(exists);\n1098: }\n1099: \n1100: function buildIfNeeded(actions) {\n1101:   if (artifactsReady()) {\n1102:     return;\n1103:   }\n1104: \n1105:   if (!exists(kitDir)) {\n1106:     throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n1107:   }\n1108: \n1109:   actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n1110:   const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n1111:   run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n1112:   run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n1113:   run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n1114: \n1115:   const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n1116:   if (missing.length > 0) {\n1117:     throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n1118:   }\n1119: }\n1120: \n1121: function getContextServerNodeArgs() {\n1122:   const nodeArgs = [];\n1123:   const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n1124:   if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n1125:     return nodeArgs;\n1126:   }\n1127: \n1128:   const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n1129:   if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n1130:     log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n1131:     return nodeArgs;\n1132:   }\n1133: \n1134:   nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n1135:   log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n1136:   return nodeArgs;\n1137: }\n1138: \n1139: function waitForChildExit(child, timeoutMs) {\n1140:   if (!isChildRunning(child)) return Promise.resolve(true);\n1141:   return new Promise((resolve) => {\n1142:     let settled = false;\n1143:     const finish = (exited) => {\n1144:       if (settled) return;\n1145:       settled = true;\n1146:       clearTimeout(timer);\n1147:       child.off('exit', onExit);\n1148:       resolve(exited);\n1149:     };\n1150:     const onExit = () => finish(true);\n1151:     const timer = setTimeout(() => finish(false), timeoutMs);\n1152:     timer.unref?.();\n1153:     child.once('exit', onExit);\n1154:   });\n1155: }\n1156: \n1157: // Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n1158: // the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n1159: // snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\n1160: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n1161:   return mss.refreshDescendantSnapshot(childPid, runner, {\n1162:     snapshotPids: lastKnownDescendantPids,\n1163:     snapshot: {\n1164:       set: (pids) => {\n1165:         lastKnownDescendantPids = pids;\n1166:       },\n1167:     },\n1168:   });\n1169: }\n1170: \n1171: // Reap an orphaned sidecar on crash-loop give-up. The dominant RSS risk lives in a\n1172: // forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n1173: // anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n1174: // still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n1175: // (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n1176: // bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\n1177: function reapProcessTreeGroups(childPid, options = {}) {\n1178:   return mss.reapProcessTreeGroups(childPid, {\n1179:     ...options,\n1180:     snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n1181:     signal: options.signal || signalProcess,\n1182:   });\n1183: }\n1184: \n1185: // Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n1186: // reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n1187: // closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\n1188: async function recycleDaemonInPlace(graceMs, deps = {}) {\n1189:   const ctx = {\n1190:     getContextChild: deps.getContextChild ?? (() => childProcess),\n1191:     hfControl: deps.hfControl ?? hfControl,\n1192:     isChildRunning: deps.isChildRunning ?? isChildRunning,\n1193:     waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n1194:     clearLease: deps.clearLease ?? clearLeaseFile,\n1195:     clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n1196:     isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n1197:     setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n1198:     log: deps.log ?? log,\n1199:   };\n1200:   if (ctx.isRecycleInProgress()) return;\n1201:   ctx.setRecycleInProgress(true);\n1202:   ctx.clearWatchdog();\n1203:   ctx.hfControl.clearTimers();\n1204:   await ctx.hfControl.stopDemandListener();\n1205:   const modelServerChild = ctx.hfControl.getChild();\n1206:   if (ctx.isChildRunning(modelServerChild)) {\n1207:     ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n1208:     modelServerChild.kill('SIGTERM');\n1209:     ctx.hfControl.reapProcessTree(modelServerChild.pid);\n1210:     const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n1211:     if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n1212:       ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1213:       modelServerChild.kill('SIGKILL');\n1214:       await ctx.waitForChildExit(modelServerChild, 1000);\n1215:     }\n1216:   }\n1217:   const contextChild = ctx.getContextChild();\n1218:   if (!ctx.isChildRunning(contextChild)) {\n1219:     ctx.clearLease();\n1220:     ctx.setRecycleInProgress(false);\n1221:     return;\n1222:   }\n1223: \n1224:   ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n1225:   contextChild.kill('SIGTERM');\n1226:   const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n1227:   if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n1228:     ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1229:     contextChild.kill('SIGKILL');\n1230:     await ctx.waitForChildExit(contextChild, 1000);\n1231:   }\n1232:   // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n1233:   // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n1234:   // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until\n1235:   // relaunch rewrites childPid — where a concurrent launcher reads no lease and passes the\n1236:   // single-writer gate, producing a competing daemon. Relaunch (writeLeaseFile) rewrites childPid.\n1237: }\n1238: \n1239: function startRssWatchdog(childPid, options = {}) {\n1240:   return mss.startRssWatchdog(childPid, {\n1241:     ...options,\n1242:     timerState: options.timerState || {\n1243:       get: () => rssWatchdogTimer,\n1244:       set: (timer) => {\n1245:         rssWatchdogTimer = timer;\n1246:       },\n1247:     },\n1248:     snapshot: options.snapshot || {\n1249:       set: (pids) => {\n1250:         lastKnownDescendantPids = pids;\n1251:       },\n1252:     },\n1253:     log: options.log || log,\n1254:     onBreach: options.onBreach || ((breachConfig) => recycleDaemonInPlace(breachConfig.graceMs)),\n1255:   });\n1256: }\n1257: \n\n(Output capped at 50 KB. Showing lines 1-1257. Use offset=1258 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;\nlet crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\n// The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n// launcher's parent. When the host disposes its session the launcher is orphaned and its\n// ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n// path can tell \"owning runtime went away\" apart from a genuine daemon crash.\nconst LAUNCHER_INITIAL_PPID = process.ppid;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n// Daemon exit code meaning \"another live process holds the database\n// single-writer lock\". Never counts toward the crash loop: the right move is\n// bridging to the live owner (or a bounded retry while a maintenance script\n// finishes), not relaunching a doomed second writer. Mirrored in\n// mcp_server context-server (EXIT_DB_LOCK_HELD).\nconst EXIT_DB_LOCK_HELD = 86;\nconst DB_LOCK_HELD_MAX_RETRIES = 3;\nlet dbLockHeldRetries = 0;\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n  persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\n// Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n// ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n// durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n// launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n// grow without bound.\nfunction launcherLogIsEnabled(env = process.env) {\n  return env.SPECKIT_LAUNCHER_LOG !== '0';\n}\nfunction launcherLogMaxBytes(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n}\nfunction resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n  const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n  return typeof override === 'string' && override.trim()\n    ? override.trim()\n    : path.join(baseDir, '.mk-spec-memory-launcher.log');\n}\nfunction shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n  return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n}\nfunction persistLauncherLogLine(line) {\n  if (!launcherLogIsEnabled()) return;\n  let target;\n  try {\n    target = resolveLauncherLogPath();\n    try {\n      const { size } = fs.statSync(target);\n      if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n        try {\n          // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n          // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n          // suffix still rotates instead of renaming the file onto itself and growing without bound.\n          const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n// (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n// not tear the shared backend out from under other sessions. A fresh session that finds the released\n// daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n// it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n// writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n// killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n// sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-spec-kit');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n  canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\n// Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n// daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n// resolved against cwd, else the default DB dir) so both sides agree on the path\n// even under a test fake-root that sets SPEC_KIT_DB_DIR.\nfunction maintenanceMarkerDir() {\n  const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n  return resolvedDbDir();\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n\nfunction readOwnerLeaseFile(filePath = ownerLeasePath()) {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    if (\n      Number.isInteger(parsed.ownerPid) &&\n      Number.isInteger(parsed.ppid) &&\n      typeof parsed.executablePath === 'string' &&\n      typeof parsed.startedAtIso === 'string' &&\n      typeof parsed.lastHeartbeatIso === 'string' &&\n      Number.isInteger(parsed.ttlMs) &&\n      typeof parsed.canonicalDbDir === 'string'\n    ) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt owner leases are treated as no active owner.\n  }\n  return null;\n}\n\nfunction writeOwnerLeaseFile(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n  // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n  // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n  // after power loss and break ownership detection.\n  let fd;\n  try {\n    fd = fs.openSync(tmp, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction writeOwnerLeaseFileExclusive(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  let fd;\n  try {\n    fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n    return true;\n  } catch (error) {\n    if (error.code === 'EEXIST') return false;\n    throw error;\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n}\n\nfunction buildOwnerLease(ownerPid = process.pid) {\n  return {\n    ownerPid,\n    ppid: process.ppid,\n    executablePath: process.execPath,\n    startedAtIso: new Date().toISOString(),\n    lastHeartbeatIso: new Date().toISOString(),\n    ttlMs: 60000,\n    canonicalDbDir: resolvedDbDir(),\n  };\n}\n\nfunction readParentPid(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return null;\n  if (process.platform === 'linux') {\n    try {\n      const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n      const match = status.match(/^PPid:\\s+(\\d+)$/m);\n      return match ? Number.parseInt(match[1], 10) : null;\n    } catch {\n      return null;\n    }\n  }\n  const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'ignore'],\n  });\n  if (result.status !== 0 || !result.stdout) return null;\n  const parsed = Number.parseInt(result.stdout.trim(), 10);\n  return Number.isInteger(parsed) ? parsed : null;\n}\n\nfunction classifyOwnerLease(lease) {\n  const liveness = processLiveness(lease.ownerPid);\n  if (liveness === 'dead') return 'stale-pid';\n  if (liveness === 'unknown-eperm') return 'unknown-eperm';\n\n  const actualPpid = readParentPid(lease.ownerPid);\n  if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n    return 'ppid-1-orphan';\n  }\n\n  const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n  const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n  if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n    return 'stale-heartbeat-reclaim';\n  }\n\n  return 'live-owner';\n}\n\nfunction acquireOwnerLeaseFile() {\n  const currentOwnerLeasePath = ownerLeasePath();\n  const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n\n  if (existing) {\n    const classification = classifyOwnerLease(existing);\n    if (classification === 'live-owner' || classification === 'unknown-eperm') {\n      return { acquired: false, holder: existing, classification };\n    }\n    log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n  }\n\n  const lease = buildOwnerLease(process.pid);\n  // Reclaim a stale lease by removing it first, then claim exclusively (O_EXCL).\n  // This collapses the fresh-acquire and stale-reclaim paths into a single CAS so\n  // only one racer can win: the loser's exclusive create hits EEXIST and returns\n  // acquired:false instead of last-writer-wins overwriting the winner's lease.\n  if (existing) {\n    try {\n      fs.unlinkSync(currentOwnerLeasePath);\n    } catch (error) {\n      if (error.code !== 'ENOENT') throw error;\n    }\n  }\n  if (!writeOwnerLeaseFileExclusive(lease)) {\n    const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n    return {\n      acquired: false,\n      holder: holder || lease,\n      classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n    };\n  }\n  ownerLeasePid = process.pid;\n  return { acquired: true, lease, reclaimed: existing };\n}\n\nfunction refreshOwnerLeaseFile(ownerPid, patch = {}) {\n  const lease = readOwnerLeaseFile();\n  if (!lease || lease.ownerPid !== ownerPid) return false;\n  const nextOwnerPid = patch.ownerPid ?? ownerPid;\n  writeOwnerLeaseFile({\n    ...lease,\n    ...patch,\n    lastHeartbeatIso: new Date().toISOString(),\n  });\n  const reread = readOwnerLeaseFile();\n  if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n  ownerLeasePid = nextOwnerPid;\n  return true;\n}\n\nfunction clearOwnerLeaseHeartbeat() {\n  if (ownerLeaseHeartbeatTimer) {\n    clearInterval(ownerLeaseHeartbeatTimer);\n    ownerLeaseHeartbeatTimer = null;\n  }\n}\n\nfunction startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n  clearOwnerLeaseHeartbeat();\n  const lease = readOwnerLeaseFile();\n  const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n  const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n  ownerLeaseHeartbeatTimer = setInterval(() => {\n    if (refreshOwnerLeaseFile(ownerPid)) return;\n    log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n    clearOwnerLeaseHeartbeat();\n    void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n      log(error.stack || error.message);\n      clearAllLeaseFiles();\n      process.exit(128);\n    });\n  }, intervalMs);\n  ownerLeaseHeartbeatTimer.unref?.();\n}\n\nfunction ownsOwnerLeaseFile(ownerPid = process.pid) {\n  const lease = readOwnerLeaseFile();\n  return lease?.ownerPid === ownerPid;\n}\n\nfunction clearOwnerLeaseFile() {\n  if (!Number.isInteger(ownerLeasePid)) return;\n  try {\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerLeasePid\n        && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  } finally {\n    clearOwnerLeaseHeartbeat();\n    ownerLeasePid = null;\n  }\n}\n\nfunction clearOwnerLeaseFileIfOwner(ownerPid) {\n  try {\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerPid\n        && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction leaseHeldFromFile(filePath, legacyPath = null) {\n  const lease = readLeaseFile(filePath);\n  if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };\n  const startedAt = lease.startedAt ?? new Date(0).toISOString();\n  // Surface the owner-recorded socket path so the bridge can prefer it over recomputing one that\n  // may diverge under a different SPECKIT_IPC_SOCKET_DIR. Null when the lease predates this field.\n  const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;\n  try {\n    process.kill(lease.pid, 0);\n    return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n  } catch (error) {\n    if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };\n    // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n    if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n    throw error;\n  }\n}\n\nfunction isLeaseHeld() {\n  const primary = leaseHeldFromFile(leasePath());\n  if (primary.held) return primary;\n\n  for (const legacyPath of legacyLeasePaths()) {\n    if (legacyPath === leasePath()) continue;\n    const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n    if (legacy.held || legacy.staleReclaimable) return legacy;\n  }\n\n  return primary;\n}\n\nfunction writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n}\n\nfunction writeLeaseHeldJsonRpcError(leaseResult, reason) {\n  process.stdout.write(`${JSON.stringify({\n    jsonrpc: '2.0',\n    id: null,\n    error: {\n      code: -32001,\n      message: `mk-spec-memory: lease held by pid ${leaseResult.ownerPid} but session bridge unavailable (${reason}); reconnect`,\n      data: { retryable: true },\n    },\n  })}\\n`);\n}\n\nfunction bridgeReadiness(leaseResult) {\n  if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n    return { ready: false, reason: 'bridge-disabled' };\n  }\n  const storedSocketPath = leaseResult.socketPath;\n  if (\n    typeof storedSocketPath === 'string' &&\n    storedSocketPath.length > 0 &&\n    (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n  ) {\n    return { ready: true, socketPath: storedSocketPath };\n  }\n  const { getIpcSocketPath } = loadBridgeModule();\n  if (typeof getIpcSocketPath !== 'function') {\n    return { ready: false, reason: 'bridge-module-missing' };\n  }\n  const socketPath = getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n  if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n    return { ready: false, reason: 'no-bridge-socket' };\n  }\n  return { ready: true, socketPath };\n}\n\nfunction leaseResultForOwnerLease(ownerLease) {\n  const pidLeaseResult = isLeaseHeld();\n  if (pidLeaseResult.held && pidLeaseResult.ownerPid === ownerLease.ownerPid) {\n    return pidLeaseResult;\n  }\n  return {\n    held: true,\n    ownerPid: ownerLease.ownerPid,\n    staleReclaimable: false,\n    startedAt: ownerLease.startedAtIso,\n    legacyPath: null,\n    socketPath: null,\n  };\n}\n\nfunction respawnLockPath() {\n  return path.join(resolvedDbDir(), '.mk-spec-memory-respawn.lock');\n}\n\nfunction modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath()) {\n  return mss.modelServerRespawnLockPath(socketPath, { dbDir: resolvedDbDir });\n}\n\nfunction acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n  return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n}\n\nfunction acquireRespawnLockFile() {\n  return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n}\n\nfunction acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n  return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n}\n\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n\n// The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n// successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n// child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n// DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n// guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\nfunction uncleanShutdownMarkerPath() {\n  // Mirror the daemon's full path precedence, not just MEMORY_DB_PATH:\n  // the daemon resolves its database dir from SPEC_KIT_DB_DIR /\n  // SPECKIT_DB_DIR before falling back to the packaged default, and the\n  // marker lives beside whatever database it actually opened. Checking the\n  // static dir under a dir override silently forfeits clean-close detection.\n  const fileOverride = process.env.MEMORY_DB_PATH?.trim();\n  if (fileOverride) {\n    return path.join(path.dirname(fileOverride), UNCLEAN_SHUTDOWN_MARKER);\n  }\n  const dirOverride = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  const dir = dirOverride ? path.resolve(root, dirOverride) : resolvedDbDir();\n  return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n}\n\nfunction uncleanMarkerPresent() {\n  try {\n    return fs.existsSync(uncleanShutdownMarkerPath());\n  } catch {\n    return false;\n  }\n}\n\n// A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n// clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n// replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\nfunction cleanCloseAfterReap({ killed, markerPresent }) {\n  return !killed && !markerPresent;\n}\n\nasync function reapLeaseChildBeforeRespawn(childPid) {\n  const liveness = processLiveness(childPid);\n  if (liveness === 'unknown-eperm') {\n    return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n  }\n  if (liveness === 'dead') {\n    return {\n      allowed: true,\n      reaped: false,\n      cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n      reason: 'child-already-dead',\n    };\n  }\n\n  log(`reaping recorded context-server child pid ${childPid} before respawn`);\n  signalProcess(childPid, 'SIGTERM');\n  reapProcessTreeGroups(childPid, { signal: signalProcess });\n  const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n  let killed = false;\n  if (!exitedAfterTerm) {\n    log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(childPid, 'SIGKILL');\n    const exitedAfterKill = await waitForPidExit(childPid, 1000);\n    killed = true;\n    if (!exitedAfterKill) {\n      // The child outlived SIGKILL within the grace window (uninterruptible state, or a pid we can\n      // no longer confirm). Refuse to hand the database to a replacement while the recorded writer\n      // may still be alive, so a caller never spawns a second writer onto the same WAL.\n      log(`context-server child pid ${childPid} did not exit after SIGKILL within grace; refusing respawn`);\n      return { allowed: false, reason: 'child-kill-unconfirmed' };\n    }\n  }\n\n  // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n  // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n  // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n  // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n  const markerPresent = uncleanMarkerPresent();\n  const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n  if (!cleanClose) {\n    log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n  }\n  return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n}\n\nasync function reapOwnerBeforeRespawn(ownerPid) {\n  const liveness = processLiveness(ownerPid);\n  if (liveness === 'unknown-eperm') {\n    return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n  }\n  if (liveness === 'dead') {\n    return { allowed: true, reason: 'owner-already-dead' };\n  }\n\n  // A socket probe cannot distinguish a genuinely-dead daemon from one that merely\n  // refused the connection at its client cap (both look \"closed before reply\"). Before\n  // killing a process that is still ALIVE, require the owner lease to be heartbeat-stale\n  // too: a daemon that has refreshed its lease within its TTL is serving clients, not\n  // dead, and must never be reaped on a socket-probe-only verdict regardless of cap.\n  const currentOwner = readOwnerLeaseFile();\n  if (currentOwner?.ownerPid === ownerPid && classifyOwnerLease(currentOwner) === 'live-owner') {\n    log(`spec-memory owner pid ${ownerPid} is heartbeat-fresh (live-owner); refusing socket-probe reap (likely cap-refusal, not death)`);\n    return { allowed: false, reason: 'owner-heartbeat-fresh' };\n  }\n\n  log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n  signalProcess(ownerPid, 'SIGTERM');\n  const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n  if (!exitedAfterTerm) {\n    log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(ownerPid, 'SIGKILL');\n    await waitForPidExit(ownerPid, 1000);\n  }\n  return { allowed: true, reason: 'owner-reaped' };\n}\n\nasync function respawnAfterDeadSocket(leaseResult, decision) {\n  if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n    return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n  }\n\n  const ownerPid = leaseResult.ownerPid;\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n    return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n  }\n\n  const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n  const childPid = lease?.childPid;\n  if (!Number.isInteger(childPid) || childPid <= 0) {\n    log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n    return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n  }\n\n  // A daemon mid-maintenance (e.g. a background index scan) legitimately fails the\n  // deep liveness probe because its event loop is busy, not dead. If it holds a\n  // fresh marker naming this exact live child, refuse the respawn and leave it\n  // running. The marker lapses if the daemon is genuinely wedged (it can no longer\n  // refresh it), so a real death still respawns once the marker expires. Checked\n  // before the respawn lock and any reap so a bail unwinds nothing.\n  const deadSocketMarker = readMaintenanceMarker(maintenanceMarkerDir());\n  if (shouldAdoptDespiteProbe({ marker: deadSocketMarker, childPid, childLiveness: processLiveness(childPid) })) {\n    log(`confirmed-dead socket but child pid ${childPid} holds a fresh maintenance marker (activeUntil ${new Date(deadSocketMarker.activeUntilMs).toISOString()}); refusing respawn (busy, not dead)`);\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-maintenance-active)');\n    return { action: 'report', reason: 'maintenance-active', socketPath: decision.socketPath };\n  }\n\n  let bootstrapLockHeld = false;\n  let respawnLock = null;\n  try {\n    bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n    respawnLock = acquireRespawnLockFile();\n    if (!respawnLock.acquired) {\n      log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n      return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n    }\n\n    const currentOwner = readOwnerLeaseFile();\n    if (currentOwner?.ownerPid !== ownerPid) {\n      log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n      return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n    }\n\n    const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n    if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n      log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n      return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n    }\n\n    const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n    if (!ownerReapResult.allowed) {\n      log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n      writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n      return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n    }\n\n    clearOwnerLeaseFileIfOwner(ownerPid);\n    const ownerLease = buildOwnerLease(process.pid);\n    if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n      const holder = readOwnerLeaseFile();\n      log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n      return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n    }\n    ownerLeasePid = process.pid;\n\n    const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n    if (!reapResult.allowed) {\n      log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n      writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n      return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n    }\n\n    buildIfNeeded([]);\n    leaseStartedAt = new Date().toISOString();\n    writeLeaseFile();\n    launchServer();\n    return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n  } finally {\n    releaseRespawnLockFile(respawnLock);\n    if (bootstrapLockHeld) {\n      fs.rmSync(lockDir, { recursive: true, force: true });\n    }\n  }\n}\n\nasync function bridgeOrReportLeaseHeld(leaseResult) {\n  const readiness = bridgeReadiness(leaseResult);\n  if (!readiness.ready) {\n    writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n    return { action: 'report', reason: readiness.reason };\n  }\n  const { maybeBridgeLeaseHolder } = loadBridgeModule();\n  const decision = await maybeBridgeLeaseHolder({\n    serviceName: 'mk-spec-memory',\n    leaseResult,\n    loggerPrefix: 'mk-spec-memory-launcher',\n    dbDir: resolvedDbDir(),\n    bridge: bridgeStdioThroughSessionProxy,\n  });\n  if (decision && decision.action === 'respawn') {\n    return await respawnAfterDeadSocket(leaseResult, decision);\n  }\n  return decision;\n}\n\nasync function bridgeOrReportLeaseHeldAndExit(leaseResult) {\n  const decision = await bridgeOrReportLeaseHeld(leaseResult);\n  if (!decision || decision.action === 'report') {\n    clearOwnerLeaseFile();\n    process.exit(0);\n  }\n  return decision;\n}\n\nfunction resolveModelServerSocketPath(env = process.env, options = {}) {\n  return mss.resolveModelServerSocketPath(env, {\n    ...options,\n    dbDir: options.dbDir || resolvedDbDir,\n  });\n}\n\nfunction getContextServerPid() {\n  return isChildRunning(childProcess) ? childProcess.pid : null;\n}\n\n// Pure lease-payload builder (exported for tests). `childPid`, `modelServerPid`, and `socketPath`\n// are ADDITIVE fields; existing readers consume only pid/startedAt/ownerPid and ignore the extras.\n// `socketPath` records the IPC path this owner actually listens on so a secondary launcher prefers\n// it over recomputing one that can diverge under a different SPECKIT_IPC_SOCKET_DIR.\nfunction buildLeaseObject(childPid = null, startedAt = leaseStartedAt, modelServerPid = null, socketPath = null) {\n  return buildSharedLeaseObject(childPid, startedAt || new Date().toISOString(), modelServerPid, socketPath);\n}\n\nfunction writeLeaseFile(childPid = getContextServerPid(), modelServerPid = hfControl.getPid()) {\n  if (!leaseStartedAt) leaseStartedAt = new Date().toISOString();\n  const payload = buildLeaseObject(childPid, leaseStartedAt, modelServerPid, resolveSessionProxySocketPath());\n  return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n}\n\nfunction sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n  const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n  return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n}\n\nfunction writeSharedModelServerPid(pid) {\n  const socketPath = resolveModelServerSocketPath();\n  const pidPath = sharedModelServerPidPath(socketPath);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    try {\n      fs.unlinkSync(pidPath);\n    } catch (error) {\n      if (error.code === 'ENOENT') return true;\n      if (isDurableWriteUnavailable(error)) {\n        logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n        return false;\n      }\n      throw error;\n    }\n    return true;\n  }\n\n  return writeAtomicJsonFile(pidPath, {\n    pid,\n    startedAt: new Date().toISOString(),\n    ownerLauncher: 'mk-spec-memory',\n    socketPath,\n  }, 'shared model-server pid write');\n}\n\nfunction readSharedModelServerPid() {\n  const pidPath = sharedModelServerPidPath();\n  try {\n    const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n    if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n    }\n  }\n\n  const lease = readLeaseFile();\n  return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n}\n\nconst hfControl = mss.createModelServerControl({\n  log,\n  env: process.env,\n  rootDir: root,\n  opencodeDir,\n  dbDir: resolvedDbDir,\n  getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n  onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n  bridge: loadBridgeModule(),\n  writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n  readModelServerPid: () => readSharedModelServerPid(),\n  writeLease: () => writeLeaseFile(),\n});\n\nfunction clearLeaseFile() {\n  try {\n    const lease = readLeaseFile();\n    if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n      try {\n        hfControl.reapProcessTree(lease.modelServerPid);\n      } catch {\n        // Lease cleanup must remain best-effort even if a final process-tree read fails.\n      }\n    }\n    if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction clearAllLeaseFiles() {\n  clearLeaseFile();\n  clearOwnerLeaseFile();\n}\n\nfunction isInside(parent, child) {\n  const relative = path.relative(parent, child);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction enforceStandaloneCodeGraphDb(actions) {\n  const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n  const resolvedCurrent = current ? path.resolve(current) : null;\n  const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n  const specKitRoot = path.resolve(kitDir);\n\n  if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n    process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n    actions.push(\n      `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n    );\n  }\n}\n\nfunction run(command, args, options = {}) {\n  const result = spawnSync(command, args, {\n    cwd: options.cwd || root,\n    env: process.env,\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n\n  if (result.stdout) {\n    process.stderr.write(result.stdout);\n  }\n  if (result.stderr) {\n    process.stderr.write(result.stderr);\n  }\n  if (result.error) {\n    throw result.error;\n  }\n  if (result.status !== 0) {\n    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n  }\n}\n\nfunction ensureLayout(actions) {\n  if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    fs.renameSync(legacySkillDir, skillsDir);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n    refreshPaths();\n    return;\n  }\n\n  if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n    fs.renameSync(legacySkillDir, backup);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n    refreshPaths();\n    return;\n  }\n\n  // Compatibility symlink `.opencode/skill -> skills` removed; a prior cleanup cleaned\n  // up consumers of the singular path, so the bridge no longer needs to be\n  // recreated on every MCP startup. Migration paths above (rename / move-aside)\n  // still create the symlink when an actual legacy singular dir is present.\n}\n\nfunction requiredArtifacts() {\n  return [\n    path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n    path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n    path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n  ];\n}\n\nfunction artifactsReady() {\n  return requiredArtifacts().every(exists);\n}\n\nfunction buildIfNeeded(actions) {\n  if (artifactsReady()) {\n    return;\n  }\n\n  if (!exists(kitDir)) {\n    throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n  }\n\n  actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n  const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n  run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n\n  const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n  if (missing.length > 0) {\n    throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n  }\n}\n\nfunction getContextServerNodeArgs() {\n  const nodeArgs = [];\n  const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n  if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n    return nodeArgs;\n  }\n\n  const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n  if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n    log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n    return nodeArgs;\n  }\n\n  nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n  log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n  return nodeArgs;\n}\n\nfunction waitForChildExit(child, timeoutMs) {\n  if (!isChildRunning(child)) return Promise.resolve(true);\n  return new Promise((resolve) => {\n    let settled = false;\n    const finish = (exited) => {\n      if (settled) return;\n      settled = true;\n      clearTimeout(timer);\n      child.off('exit', onExit);\n      resolve(exited);\n    };\n    const onExit = () => finish(true);\n    const timer = setTimeout(() => finish(false), timeoutMs);\n    timer.unref?.();\n    child.once('exit', onExit);\n  });\n}\n\n// Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n// the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n// snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n  return mss.refreshDescendantSnapshot(childPid, runner, {\n    snapshotPids: lastKnownDescendantPids,\n    snapshot: {\n      set: (pids) => {\n        lastKnownDescendantPids = pids;\n      },\n    },\n  });\n}\n\n// Reap an orphaned sidecar on crash-loop give-up. The dominant RSS risk lives in a\n// forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n// anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n// still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n// (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n// bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  return mss.reapProcessTreeGroups(childPid, {\n    ...options,\n    snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n    signal: options.signal || signalProcess,\n  });\n}\n\n// Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n// reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n// closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\nasync function recycleDaemonInPlace(graceMs, deps = {}) {\n  const ctx = {\n    getContextChild: deps.getContextChild ?? (() => childProcess),\n    hfControl: deps.hfControl ?? hfControl,\n    isChildRunning: deps.isChildRunning ?? isChildRunning,\n    waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n    clearLease: deps.clearLease ?? clearLeaseFile,\n    clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n    isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n    setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n    log: deps.log ?? log,\n  };\n  if (ctx.isRecycleInProgress()) return;\n  ctx.setRecycleInProgress(true);\n  ctx.clearWatchdog();\n  ctx.hfControl.clearTimers();\n  await ctx.hfControl.stopDemandListener();\n  const modelServerChild = ctx.hfControl.getChild();\n  if (ctx.isChildRunning(modelServerChild)) {\n    ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n    modelServerChild.kill('SIGTERM');\n    ctx.hfControl.reapProcessTree(modelServerChild.pid);\n    const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n    if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n      ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n      modelServerChild.kill('SIGKILL');\n      await ctx.waitForChildExit(modelServerChild, 1000);\n    }\n  }\n  const contextChild = ctx.getContextChild();\n  if (!ctx.isChildRunning(contextChild)) {\n    ctx.clearLease();\n    ctx.setRecycleInProgress(false);\n    return;\n  }\n\n  ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n  contextChild.kill('SIGTERM');\n  const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n  if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n    ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n    contextChild.kill('SIGKILL');\n    await ctx.waitForChildExit(contextChild, 1000);\n  }\n  // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n  // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n  // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until\n  // relaunch rewrites childPid — where a concurrent launcher reads no lease and passes the\n  // single-writer gate, producing a competing daemon. Relaunch (writeLeaseFile) rewrites childPid.\n}\n\nfunction startRssWatchdog(childPid, options = {}) {\n  return mss.startRssWatchdog(childPid, {\n    ...options,\n    timerState: options.timerState || {\n      get: () => rssWatchdogTimer,\n      set: (timer) => {\n        rssWatchdogTimer = timer;\n      },\n    },\n    snapshot: options.snapshot || {\n      set: (pids) => {\n        lastKnownDescendantPids = pids;\n      },\n    },\n    log: options.log || log,\n    onBreach: options.onBreach || ((breachConfig) => recycleDaemonInPlace(breachConfig.graceMs)),\n  });\n}\n","lineStart":1,"lineEnd":1257,"totalLines":1258,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781755631209,"end":1781755631216}},"metadata":{"openai":{"itemId":"fc_037f7296ff70a56b016a336eef166c81919af76fe90984990d"}},"id":"prt_ed8e956680010qc9jIv3BCgjEN","sessionID":"ses_127185023ffen0qKKl1I08wyww","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4"}}
{"type":"tool_use","timestamp":1781755631220,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"type":"tool","tool":"read","callID":"call_8MAPP45QMi4Mz2xDdscbN8U4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // The sibling release-integration test proves the OS-level release-vs-kill\n6: // DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n7: // feature actually promises: with the flag ON, when an OWNER session disposes the\n8: // shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n9: // flag OFF the daemon DIES with its owner and the secondary loses transport.\n10: //\n11: // It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n12: // isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n13: // SIGTERM (what a host does on session end), and observes the shared daemon's pid\n14: // and the secondary's next call.\n15: //\n16: // SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n17: // launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n18: // the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n19: // guard resolves to the fake root, never the production tree); node_modules and\n20: // scripts are symlinked; the IPC socket lives in a short isolated dir. No\n21: // production lease, DB, or socket is read or written. Only processes this test\n22: // starts are signalled, tracked by pid, and force-reaped in teardown.\n23: \n24: import { spawn, spawnSync, type ChildProcess } from 'node:child_process';\n25: import { cpSync, copyFileSync, existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync, writeFileSync } from 'node:fs';\n26: import { tmpdir } from 'node:os';\n27: import { dirname, join, resolve } from 'node:path';\n28: import { fileURLToPath } from 'node:url';\n29: \n30: import { afterEach, describe, expect, it } from 'vitest';\n31: \n32: // stress_test/durability/<file> -> repo root is six levels up.\n33: const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\n34: const realBin = join(repoRoot, '.opencode/bin');\n35: const realKit = join(repoRoot, '.opencode/skills/system-spec-kit');\n36: const realMcp = join(realKit, 'mcp_server');\n37: \n38: const trackedPids = new Set<number>();\n39: const tempDirs = new Set<string>();\n40: \n41: function track(pid: number | undefined): void {\n42:   if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n43: }\n44: function isAlive(pid: number): boolean {\n45:   try { process.kill(pid, 0); return true; }\n46:   catch (e) { return (e as NodeJS.ErrnoException).code === 'EPERM'; }\n47: }\n48: function delay(ms: number): Promise<void> { return new Promise((r) => setTimeout(r, ms)); }\n49: \n50: // spawnSync (no shell) so the temp-dir argument is never interpreted by a shell. pgrep exits\n51: // non-zero with empty stdout when nothing matches, which yields an empty list.\n52: function pgrepContains(needle: string): number[] {\n53:   const res = spawnSync('pgrep', ['-f', needle], { encoding: 'utf8' });\n54:   const out = (res.stdout || '').trim();\n55:   return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n56: }\n57: \n58: // Distinct pids holding any *.sqlite* file open under dbDir. One = single writer. spawnSync (no\n59: // shell) plus JS parsing, so dbDir is never interpolated into a shell command. We parse stdout\n60: // regardless of exit status because `lsof +D` often exits non-zero on benign warnings while still\n61: // listing the open files.\n62: function sqliteOpenerPids(dbDir: string): number[] {\n63:   const res = spawnSync('lsof', ['+D', dbDir], { encoding: 'utf8' });\n64:   const out = res.stdout || '';\n65:   const pids = new Set<number>();\n66:   for (const line of out.split('\\n').slice(1)) {\n67:     const cols = line.split(/\\s+/);\n68:     const name = cols[8] || '';\n69:     if (/\\.(db|sqlite|sqlite3)/.test(name)) {\n70:       const pid = Number(cols[1]);\n71:       if (Number.isInteger(pid) && pid > 0) pids.add(pid);\n72:     }\n73:   }\n74:   return [...pids];\n75: }\n76: \n77: // Build an isolated fake-root: real-copied launcher + daemon dist, symlinked deps,\n78: // fresh lease/db dir. Returns the paths the two sessions share.\n79: function buildFakeRoot(): { base: string; sockDir: string; dbDir: string; launcher: string } {\n80:   const base = mkdtempSync(join(tmpdir(), 'rladopt.'));\n81:   tempDirs.add(base);\n82:   const fbin = join(base, '.opencode/bin');\n83:   const fkit = join(base, '.opencode/skills/system-spec-kit');\n84:   const fmcp = join(fkit, 'mcp_server');\n85:   mkdirSync(fbin, { recursive: true });\n86:   mkdirSync(fmcp, { recursive: true });\n87:   copyFileSync(join(realBin, 'mk-spec-memory-launcher.cjs'), join(fbin, 'mk-spec-memory-launcher.cjs'));\n88:   symlinkSync(join(realBin, 'lib'), join(fbin, 'lib'));\n89:   cpSync(join(realMcp, 'dist'), join(fmcp, 'dist'), { recursive: true });\n90:   symlinkSync(join(realMcp, 'node_modules'), join(fmcp, 'node_modules'));\n91:   if (existsSync(join(realKit, 'node_modules'))) symlinkSync(join(realKit, 'node_modules'), join(fkit, 'node_modules'));\n92:   symlinkSync(join(realMcp, 'package.json'), join(fmcp, 'package.json'));\n93:   symlinkSync(join(realKit, 'scripts'), join(fkit, 'scripts'));\n94:   const dbDir = join(fmcp, 'database');\n95:   mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n96:   const sockDir = mkdtempSync(join(tmpdir(), 'rladsk.'));\n97:   tempDirs.add(sockDir);\n98:   return { base, sockDir, dbDir, launcher: join(fbin, 'mk-spec-memory-launcher.cjs') };\n99: }\n100: \n101: type RpcResponse = { result?: unknown; error?: unknown; id?: number | null };\n102: \n103: // A minimal newline-delimited MCP JSON-RPC client over a launcher's stdio.\n104: function makeClient(child: ChildProcess) {\n105:   let buf = '';\n106:   const pending = new Map<number, (m: RpcResponse) => void>();\n107:   child.stdout!.setEncoding('utf8');\n108:   child.stdout!.on('data', (chunk: string) => {\n109:     buf += chunk;\n110:     let nl: number;\n111:     while ((nl = buf.indexOf('\\n')) >= 0) {\n112:       const line = buf.slice(0, nl).trim();\n113:       buf = buf.slice(nl + 1);\n114:       if (!line) continue;\n115:       let msg: RpcResponse;\n116:       try { msg = JSON.parse(line); } catch { continue; }\n117:       if (msg.id != null && pending.has(msg.id)) { pending.get(msg.id)!(msg); pending.delete(msg.id); }\n118:     }\n119:   });\n120:   child.stderr!.setEncoding('utf8');\n121:   child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n122:   let nextId = 1;\n123:   function request(method: string, params: unknown, timeoutMs = 30_000): Promise<RpcResponse> {\n124:     const id = nextId++;\n125:     return new Promise((resolveReq, rejectReq) => {\n126:       const timer = setTimeout(() => { pending.delete(id); rejectReq(new Error(`${method} timed out`)); }, timeoutMs);\n127:       pending.set(id, (m) => { clearTimeout(timer); resolveReq(m); });\n128:       try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', id, method, params }) + '\\n'); }\n129:       catch (e) { clearTimeout(timer); pending.delete(id); rejectReq(e as Error); }\n130:     });\n131:   }\n132:   function notify(method: string, params: unknown): void {\n133:     try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n134:   }\n135:   return { request, notify };\n136: }\n137: \n138: async function startSession(\n139:   paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n140:   enabled: boolean,\n141:   extraEnv: Record<string, string> = {},\n142: ): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n143:   const child = spawn(process.execPath, [paths.launcher], {\n144:     cwd: paths.base,\n145:     env: {\n146:       ...process.env,\n147:       SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n148:       SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n149:       SPEC_KIT_DB_DIR: paths.dbDir,\n150:       SPECKIT_LAUNCHER_LOG: '1',\n151:       AI_SESSION_CHILD: '1',\n152:       ...extraEnv,\n153:     },\n154:     stdio: ['pipe', 'pipe', 'pipe'],\n155:   });\n156:   track(child.pid);\n157:   const client = makeClient(child);\n158:   const init = await client.request('initialize', {\n159:     protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n160:   }, 30_000);\n161:   if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n162:   client.notify('notifications/initialized', {});\n163:   return { child, client };\n164: }\n165: \n166: // Spawn a competing launcher and send it an initialize WITHOUT requiring a completed MCP handshake.\n167: // When the marked daemon is busy-but-healthy, the launcher's contract is to refuse the respawn and\n168: // report lease-held on stdout, then exit 0 — it does NOT bridge the contending session into a live\n169: // transport (that session is told to back off, not adopted). So this helper observes the launcher's\n170: // decision (its stdout report + exit) rather than driving real MCP calls through it.\n171: async function spawnCompetingLauncher(\n172:   paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n173:   extraEnv: Record<string, string> = {},\n174: ): Promise<{ child: ChildProcess; settled: () => { exited: boolean; code: number | null; stdout: string } }> {\n175:   const child = spawn(process.execPath, [paths.launcher], {\n176:     cwd: paths.base,\n177:     env: {\n178:       ...process.env,\n179:       SPECKIT_DAEMON_REELECTION: '1',\n180:       SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n181:       SPEC_KIT_DB_DIR: paths.dbDir,\n182:       SPECKIT_LAUNCHER_LOG: '1',\n183:       AI_SESSION_CHILD: '1',\n184:       ...extraEnv,\n185:     },\n186:     stdio: ['pipe', 'pipe', 'pipe'],\n187:   });\n188:   track(child.pid);\n189:   let stdout = '';\n190:   let exited = false;\n191:   let code: number | null = null;\n192:   child.stdout!.setEncoding('utf8');\n193:   child.stdout!.on('data', (c: string) => { stdout += c; });\n194:   child.stderr!.setEncoding('utf8');\n195:   child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n196:   child.on('exit', (c) => { exited = true; code = c; });\n197:   // A bare initialize so a launcher that DID hand us a transport would answer; under refusal it\n198:   // instead emits its lease-held report and exits.\n199:   try {\n200:     child.stdin!.write(JSON.stringify({\n201:       jsonrpc: '2.0', id: 1, method: 'initialize',\n202:       params: { protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-compete', version: '1.0' } },\n203:     }) + '\\n');\n204:   } catch { /* launcher may already be exiting */ }\n205:   return { child, settled: () => ({ exited, code, stdout }) };\n206: }\n207: \n208: function leaseDaemonPid(base: string): number | null {\n209:   const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n210:   try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n211: }\n212: async function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n213:   try {\n214:     const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n215:     return !r.error;\n216:   } catch { return false; }\n217: }\n218: async function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n219:   const deadline = Date.now() + timeoutMs;\n220:   while (isAlive(pid) && Date.now() < deadline) await delay(50);\n221: }\n222: \n223: afterEach(async () => {\n224:   for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n225:   await delay(150);\n226:   // Sweep any detached daemon / embed sidecar that reparented to init.\n227:   for (const dir of tempDirs) {\n228:     for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n229:   }\n230:   await delay(150);\n231:   trackedPids.clear();\n232:   for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n233:   tempDirs.clear();\n234: });\n235: \n236: describe('daemon re-election: live two-session adoption', () => {\n237:   it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n238:     const paths = buildFakeRoot();\n239: \n240:     const owner = await startSession(paths, true);\n241:     expect(await statsOk(owner.client)).toBe(true);\n242:     const daemonPid = leaseDaemonPid(paths.base);\n243:     expect(daemonPid).toBeTypeOf('number');\n244:     track(daemonPid!);\n245:     expect(isAlive(daemonPid!)).toBe(true);\n246: \n247:     // Secondary joins while the owner holds the lease and the socket is live.\n248:     const secondary = await startSession(paths, true);\n249:     expect(await statsOk(secondary.client)).toBe(true);\n250:     // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n251:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n252: \n253:     // Dispose the owner.\n254:     owner.child.kill('SIGTERM');\n255:     await waitForExit(owner.child.pid!, 8_000);\n256:     expect(isAlive(owner.child.pid!)).toBe(false);\n257:     await delay(1_200);\n258: \n259:     // The released daemon outlives its owner and the secondary keeps transport.\n260:     expect(isAlive(daemonPid!)).toBe(true);\n261:     expect(await statsOk(secondary.client)).toBe(true);\n262:   });\n263: \n264:   it('flag ON: a FRESH session after owner disposal ADOPTS the released daemon (single writer)', async () => {\n265:     const paths = buildFakeRoot();\n266: \n267:     const owner = await startSession(paths, true);\n268:     expect(await statsOk(owner.client)).toBe(true);\n269:     const orphanPid = leaseDaemonPid(paths.base);\n270:     expect(orphanPid).toBeTypeOf('number');\n271:     track(orphanPid!);\n272: \n273:     // Dispose the owner: the daemon is RELEASED (survives), not killed.\n274:     owner.child.kill('SIGTERM');\n275:     await waitForExit(owner.child.pid!, 8_000);\n276:     await delay(1_200);\n277:     expect(isAlive(orphanPid!)).toBe(true);\n278: \n279:     // A brand-new session starts AFTER disposal. With true adoption it bridges to the still-live\n280:     // released daemon instead of reaping and respawning, so the warm daemon is reused and there is\n281:     // never a second writer.\n282:     const fresh = await startSession(paths, true);\n283:     expect(await statsOk(fresh.client)).toBe(true);\n284:     const newPid = leaseDaemonPid(paths.base);\n285:     expect(newPid).toBeTypeOf('number');\n286:     track(newPid!);\n287:     await delay(800);\n288: \n289:     // Adoption invariant: the released daemon is reused (same pid, still alive), not respawned.\n290:     expect(isAlive(orphanPid!)).toBe(true);\n291:     expect(newPid).toBe(orphanPid);\n292: \n293:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n294:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n295:     expect(dbWriters.length).toBe(1);\n296:   });\n297: \n298:   it('flag ON: a FRESH session does NOT adopt a WEDGED released daemon; it reaps and respawns (single writer)', async () => {\n299:     const paths = buildFakeRoot();\n300: \n301:     const owner = await startSession(paths, true);\n302:     expect(await statsOk(owner.client)).toBe(true);\n303:     const orphanPid = leaseDaemonPid(paths.base);\n304:     expect(orphanPid).toBeTypeOf('number');\n305:     track(orphanPid!);\n306: \n307:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n308:     owner.child.kill('SIGTERM');\n309:     await waitForExit(owner.child.pid!, 8_000);\n310:     await delay(1_200);\n311:     expect(isAlive(orphanPid!)).toBe(true);\n312: \n313:     // WEDGE the released daemon. SIGSTOP freezes its event loop, so it stays 'alive' to kill(pid,0)\n314:     // and still owns its listening socket, but it never services a JSON-RPC request — the exact\n315:     // observable state of a busy-loop / deadlock. A pre-fix launcher adopts on socket-existence alone\n316:     // and bridges the fresh session into a dead end; the fix must deep-probe, fail, and reap+respawn.\n317:     process.kill(orphanPid!, 'SIGSTOP');\n318: \n319:     // Fresh session with a short probe so the not-alive verdict is fast and deterministic. The reap\n320:     // grace (SIGTERM is ignored by a stopped process, then SIGKILL) is a fixed 7s, so allow generous\n321:     // startup time before the launcher answers initialize.\n322:     const fresh = await startSession(paths, true, {\n323:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n324:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n325:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n326:     });\n327:     expect(await statsOk(fresh.client, 20_000)).toBe(true);\n328:     const newPid = leaseDaemonPid(paths.base);\n329:     expect(newPid).toBeTypeOf('number');\n330:     track(newPid!);\n331: \n332:     // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n333:     expect(newPid).not.toBe(orphanPid);\n334:     await waitForExit(orphanPid!, 10_000);\n335:     expect(isAlive(orphanPid!)).toBe(false);\n336:     await delay(800);\n337: \n338:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n339:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n340:     expect(dbWriters.length).toBe(1);\n341:   }, 60_000);\n342: \n343:   it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n344:     const paths = buildFakeRoot();\n345: \n346:     const owner = await startSession(paths, true);\n347:     expect(await statsOk(owner.client)).toBe(true);\n348:     const orphanPid = leaseDaemonPid(paths.base);\n349:     expect(orphanPid).toBeTypeOf('number');\n350:     track(orphanPid!);\n351: \n352:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n353:     owner.child.kill('SIGTERM');\n354:     await waitForExit(owner.child.pid!, 8_000);\n355:     await delay(1_200);\n356:     expect(isAlive(orphanPid!)).toBe(true);\n357: \n358:     // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n359:     // intentionally too busy to service the probe. The launcher resolves the marker dir from\n360:     // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n361:     writeFileSync(\n362:       join(paths.dbDir, '.maintenance-active.json'),\n363:       JSON.stringify({\n364:         childPid: orphanPid,\n365:         activeUntilMs: Date.now() + 60_000,\n366:         jobId: 'test',\n367:         refreshedAtIso: new Date().toISOString(),\n368:       }),\n369:     );\n370: \n371:     // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n372:     // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n373:     // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n374:     // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n375:     process.kill(orphanPid!, 'SIGSTOP');\n376: \n377:     // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n378:     // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n379:     // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n380:     // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n381:     const compete = await spawnCompetingLauncher(paths, {\n382:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n383:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n384:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n385:     });\n386:     await waitForExit(compete.child.pid!, 20_000);\n387:     const settled = compete.settled();\n388:     // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n389:     expect(settled.exited).toBe(true);\n390:     expect(settled.code).toBe(0);\n391:     expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n392:     expect(settled.stdout).toMatch(/maintenance-active/);\n393: \n394:     // Let the marked daemon run again so teardown and the writer checks see a normal process.\n395:     process.kill(orphanPid!, 'SIGCONT');\n396:     await delay(800);\n397: \n398:     // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n399:     // never reaped and respawned, despite the probe failing while it was stopped.\n400:     expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n401:     expect(isAlive(orphanPid!)).toBe(true);\n402: \n403:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n404:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n405:     expect(dbWriters.length).toBe(1);\n406:   }, 60_000);\n407: \n408:   it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n409:     const paths = buildFakeRoot();\n410: \n411:     const owner = await startSession(paths, true);\n412:     expect(await statsOk(owner.client)).toBe(true);\n413:     const orphanPid = leaseDaemonPid(paths.base);\n414:     expect(orphanPid).toBeTypeOf('number');\n415:     track(orphanPid!);\n416: \n417:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n418:     owner.child.kill('SIGTERM');\n419:     await waitForExit(owner.child.pid!, 8_000);\n420:     await delay(1_200);\n421:     expect(isAlive(orphanPid!)).toBe(true);\n422: \n423:     // Publish a STALE maintenance marker (already expired): it names the live child but its\n424:     // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n425:     writeFileSync(\n426:       join(paths.dbDir, '.maintenance-active.json'),\n427:       JSON.stringify({\n428:         childPid: orphanPid,\n429:         activeUntilMs: Date.now() - 1_000,\n430:         jobId: 'test',\n431:         refreshedAtIso: new Date().toISOString(),\n432:       }),\n433:     );\n434: \n435:     // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n436:     process.kill(orphanPid!, 'SIGSTOP');\n437: \n438:     // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n439:     const fresh = await startSession(paths, true, {\n440:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n441:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n442:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n443:     });\n444:     expect(await statsOk(fresh.client, 20_000)).toBe(true);\n445:     const newPid = leaseDaemonPid(paths.base);\n446:     expect(newPid).toBeTypeOf('number');\n447:     track(newPid!);\n448: \n449:     // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n450:     // and a fresh daemon replaced it.\n451:     expect(newPid).not.toBe(orphanPid);\n452:     // The reap SIGKILLs the stopped orphan, so it may already be gone — SIGCONT only to be sure a\n453:     // surviving stopped process is resumable for teardown; tolerate ESRCH when it is already reaped.\n454:     try { process.kill(orphanPid!, 'SIGCONT'); } catch { /* already reaped */ }\n455:     await waitForExit(orphanPid!, 10_000);\n456:     expect(isAlive(orphanPid!)).toBe(false);\n457:     await delay(800);\n458: \n459:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n460:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n461:     expect(dbWriters.length).toBe(1);\n462:   }, 60_000);\n463: \n464:   it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n465:     const paths = buildFakeRoot();\n466: \n467:     const owner = await startSession(paths, false);\n468:     expect(await statsOk(owner.client)).toBe(true);\n469:     const daemonPid = leaseDaemonPid(paths.base);\n470:     expect(daemonPid).toBeTypeOf('number');\n471:     track(daemonPid!);\n472:     expect(isAlive(daemonPid!)).toBe(true);\n473: \n474:     const secondary = await startSession(paths, false);\n475:     expect(await statsOk(secondary.client)).toBe(true);\n476:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n477: \n478:     owner.child.kill('SIGTERM');\n479:     await waitForExit(owner.child.pid!, 8_000);\n480:     expect(isAlive(owner.child.pid!)).toBe(false);\n481:     await delay(1_200);\n482: \n483:     // With the flag off, the daemon dies with its owner and the secondary's next\n484:     // call fails (no surviving daemon to serve it) within a short window.\n485:     expect(isAlive(daemonPid!)).toBe(false);\n486:     expect(await statsOk(secondary.client, 6_000)).toBe(false);\n487:   });\n488: });\n\n(End of file - total 488 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n// ───────────────────────────────────────────────────────────────\n//\n// The sibling release-integration test proves the OS-level release-vs-kill\n// DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n// feature actually promises: with the flag ON, when an OWNER session disposes the\n// shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n// flag OFF the daemon DIES with its owner and the secondary loses transport.\n//\n// It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n// isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n// SIGTERM (what a host does on session end), and observes the shared daemon's pid\n// and the secondary's next call.\n//\n// SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n// launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n// the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n// guard resolves to the fake root, never the production tree); node_modules and\n// scripts are symlinked; the IPC socket lives in a short isolated dir. No","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n// ───────────────────────────────────────────────────────────────\n//\n// The sibling release-integration test proves the OS-level release-vs-kill\n// DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n// feature actually promises: with the flag ON, when an OWNER session disposes the\n// shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n// flag OFF the daemon DIES with its owner and the secondary loses transport.\n//\n// It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n// isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n// SIGTERM (what a host does on session end), and observes the shared daemon's pid\n// and the secondary's next call.\n//\n// SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n// launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n// the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n// guard resolves to the fake root, never the production tree); node_modules and\n// scripts are symlinked; the IPC socket lives in a short isolated dir. No\n// production lease, DB, or socket is read or written. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, spawnSync, type ChildProcess } from 'node:child_process';\nimport { cpSync, copyFileSync, existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { afterEach, describe, expect, it } from 'vitest';\n\n// stress_test/durability/<file> -> repo root is six levels up.\nconst repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\nconst realBin = join(repoRoot, '.opencode/bin');\nconst realKit = join(repoRoot, '.opencode/skills/system-spec-kit');\nconst realMcp = join(realKit, 'mcp_server');\n\nconst trackedPids = new Set<number>();\nconst tempDirs = new Set<string>();\n\nfunction track(pid: number | undefined): void {\n  if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n}\nfunction isAlive(pid: number): boolean {\n  try { process.kill(pid, 0); return true; }\n  catch (e) { return (e as NodeJS.ErrnoException).code === 'EPERM'; }\n}\nfunction delay(ms: number): Promise<void> { return new Promise((r) => setTimeout(r, ms)); }\n\n// spawnSync (no shell) so the temp-dir argument is never interpreted by a shell. pgrep exits\n// non-zero with empty stdout when nothing matches, which yields an empty list.\nfunction pgrepContains(needle: string): number[] {\n  const res = spawnSync('pgrep', ['-f', needle], { encoding: 'utf8' });\n  const out = (res.stdout || '').trim();\n  return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n}\n\n// Distinct pids holding any *.sqlite* file open under dbDir. One = single writer. spawnSync (no\n// shell) plus JS parsing, so dbDir is never interpolated into a shell command. We parse stdout\n// regardless of exit status because `lsof +D` often exits non-zero on benign warnings while still\n// listing the open files.\nfunction sqliteOpenerPids(dbDir: string): number[] {\n  const res = spawnSync('lsof', ['+D', dbDir], { encoding: 'utf8' });\n  const out = res.stdout || '';\n  const pids = new Set<number>();\n  for (const line of out.split('\\n').slice(1)) {\n    const cols = line.split(/\\s+/);\n    const name = cols[8] || '';\n    if (/\\.(db|sqlite|sqlite3)/.test(name)) {\n      const pid = Number(cols[1]);\n      if (Number.isInteger(pid) && pid > 0) pids.add(pid);\n    }\n  }\n  return [...pids];\n}\n\n// Build an isolated fake-root: real-copied launcher + daemon dist, symlinked deps,\n// fresh lease/db dir. Returns the paths the two sessions share.\nfunction buildFakeRoot(): { base: string; sockDir: string; dbDir: string; launcher: string } {\n  const base = mkdtempSync(join(tmpdir(), 'rladopt.'));\n  tempDirs.add(base);\n  const fbin = join(base, '.opencode/bin');\n  const fkit = join(base, '.opencode/skills/system-spec-kit');\n  const fmcp = join(fkit, 'mcp_server');\n  mkdirSync(fbin, { recursive: true });\n  mkdirSync(fmcp, { recursive: true });\n  copyFileSync(join(realBin, 'mk-spec-memory-launcher.cjs'), join(fbin, 'mk-spec-memory-launcher.cjs'));\n  symlinkSync(join(realBin, 'lib'), join(fbin, 'lib'));\n  cpSync(join(realMcp, 'dist'), join(fmcp, 'dist'), { recursive: true });\n  symlinkSync(join(realMcp, 'node_modules'), join(fmcp, 'node_modules'));\n  if (existsSync(join(realKit, 'node_modules'))) symlinkSync(join(realKit, 'node_modules'), join(fkit, 'node_modules'));\n  symlinkSync(join(realMcp, 'package.json'), join(fmcp, 'package.json'));\n  symlinkSync(join(realKit, 'scripts'), join(fkit, 'scripts'));\n  const dbDir = join(fmcp, 'database');\n  mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  const sockDir = mkdtempSync(join(tmpdir(), 'rladsk.'));\n  tempDirs.add(sockDir);\n  return { base, sockDir, dbDir, launcher: join(fbin, 'mk-spec-memory-launcher.cjs') };\n}\n\ntype RpcResponse = { result?: unknown; error?: unknown; id?: number | null };\n\n// A minimal newline-delimited MCP JSON-RPC client over a launcher's stdio.\nfunction makeClient(child: ChildProcess) {\n  let buf = '';\n  const pending = new Map<number, (m: RpcResponse) => void>();\n  child.stdout!.setEncoding('utf8');\n  child.stdout!.on('data', (chunk: string) => {\n    buf += chunk;\n    let nl: number;\n    while ((nl = buf.indexOf('\\n')) >= 0) {\n      const line = buf.slice(0, nl).trim();\n      buf = buf.slice(nl + 1);\n      if (!line) continue;\n      let msg: RpcResponse;\n      try { msg = JSON.parse(line); } catch { continue; }\n      if (msg.id != null && pending.has(msg.id)) { pending.get(msg.id)!(msg); pending.delete(msg.id); }\n    }\n  });\n  child.stderr!.setEncoding('utf8');\n  child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n  let nextId = 1;\n  function request(method: string, params: unknown, timeoutMs = 30_000): Promise<RpcResponse> {\n    const id = nextId++;\n    return new Promise((resolveReq, rejectReq) => {\n      const timer = setTimeout(() => { pending.delete(id); rejectReq(new Error(`${method} timed out`)); }, timeoutMs);\n      pending.set(id, (m) => { clearTimeout(timer); resolveReq(m); });\n      try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', id, method, params }) + '\\n'); }\n      catch (e) { clearTimeout(timer); pending.delete(id); rejectReq(e as Error); }\n    });\n  }\n  function notify(method: string, params: unknown): void {\n    try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n  }\n  return { request, notify };\n}\n\nasync function startSession(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  enabled: boolean,\n  extraEnv: Record<string, string> = {},\n): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',\n      AI_SESSION_CHILD: '1',\n      ...extraEnv,\n    },\n    stdio: ['pipe', 'pipe', 'pipe'],\n  });\n  track(child.pid);\n  const client = makeClient(child);\n  const init = await client.request('initialize', {\n    protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n  }, 30_000);\n  if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n  client.notify('notifications/initialized', {});\n  return { child, client };\n}\n\n// Spawn a competing launcher and send it an initialize WITHOUT requiring a completed MCP handshake.\n// When the marked daemon is busy-but-healthy, the launcher's contract is to refuse the respawn and\n// report lease-held on stdout, then exit 0 — it does NOT bridge the contending session into a live\n// transport (that session is told to back off, not adopted). So this helper observes the launcher's\n// decision (its stdout report + exit) rather than driving real MCP calls through it.\nasync function spawnCompetingLauncher(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  extraEnv: Record<string, string> = {},\n): Promise<{ child: ChildProcess; settled: () => { exited: boolean; code: number | null; stdout: string } }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: '1',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',\n      AI_SESSION_CHILD: '1',\n      ...extraEnv,\n    },\n    stdio: ['pipe', 'pipe', 'pipe'],\n  });\n  track(child.pid);\n  let stdout = '';\n  let exited = false;\n  let code: number | null = null;\n  child.stdout!.setEncoding('utf8');\n  child.stdout!.on('data', (c: string) => { stdout += c; });\n  child.stderr!.setEncoding('utf8');\n  child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n  child.on('exit', (c) => { exited = true; code = c; });\n  // A bare initialize so a launcher that DID hand us a transport would answer; under refusal it\n  // instead emits its lease-held report and exits.\n  try {\n    child.stdin!.write(JSON.stringify({\n      jsonrpc: '2.0', id: 1, method: 'initialize',\n      params: { protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-compete', version: '1.0' } },\n    }) + '\\n');\n  } catch { /* launcher may already be exiting */ }\n  return { child, settled: () => ({ exited, code, stdout }) };\n}\n\nfunction leaseDaemonPid(base: string): number | null {\n  const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n  try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n}\nasync function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n  try {\n    const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n    return !r.error;\n  } catch { return false; }\n}\nasync function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  while (isAlive(pid) && Date.now() < deadline) await delay(50);\n}\n\nafterEach(async () => {\n  for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  await delay(150);\n  // Sweep any detached daemon / embed sidecar that reparented to init.\n  for (const dir of tempDirs) {\n    for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  }\n  await delay(150);\n  trackedPids.clear();\n  for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n  tempDirs.clear();\n});\n\ndescribe('daemon re-election: live two-session adoption', () => {\n  it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    // Secondary joins while the owner holds the lease and the socket is live.\n    const secondary = await startSession(paths, true);\n    expect(await statsOk(secondary.client)).toBe(true);\n    // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    // Dispose the owner.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // The released daemon outlives its owner and the secondary keeps transport.\n    expect(isAlive(daemonPid!)).toBe(true);\n    expect(await statsOk(secondary.client)).toBe(true);\n  });\n\n  it('flag ON: a FRESH session after owner disposal ADOPTS the released daemon (single writer)', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // A brand-new session starts AFTER disposal. With true adoption it bridges to the still-live\n    // released daemon instead of reaping and respawning, so the warm daemon is reused and there is\n    // never a second writer.\n    const fresh = await startSession(paths, true);\n    expect(await statsOk(fresh.client)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n    await delay(800);\n\n    // Adoption invariant: the released daemon is reused (same pid, still alive), not respawned.\n    expect(isAlive(orphanPid!)).toBe(true);\n    expect(newPid).toBe(orphanPid);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  });\n\n  it('flag ON: a FRESH session does NOT adopt a WEDGED released daemon; it reaps and respawns (single writer)', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // WEDGE the released daemon. SIGSTOP freezes its event loop, so it stays 'alive' to kill(pid,0)\n    // and still owns its listening socket, but it never services a JSON-RPC request — the exact\n    // observable state of a busy-loop / deadlock. A pre-fix launcher adopts on socket-existence alone\n    // and bridges the fresh session into a dead end; the fix must deep-probe, fail, and reap+respawn.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // Fresh session with a short probe so the not-alive verdict is fast and deterministic. The reap\n    // grace (SIGTERM is ignored by a stopped process, then SIGKILL) is a fixed 7s, so allow generous\n    // startup time before the launcher answers initialize.\n    const fresh = await startSession(paths, true, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    expect(await statsOk(fresh.client, 20_000)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n\n    // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n    // intentionally too busy to service the probe. The launcher resolves the marker dir from\n    // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() + 60_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n    // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n    // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n    // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n    // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n    // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n    // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n    const compete = await spawnCompetingLauncher(paths, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    await waitForExit(compete.child.pid!, 20_000);\n    const settled = compete.settled();\n    // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n    expect(settled.exited).toBe(true);\n    expect(settled.code).toBe(0);\n    expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n    expect(settled.stdout).toMatch(/maintenance-active/);\n\n    // Let the marked daemon run again so teardown and the writer checks see a normal process.\n    process.kill(orphanPid!, 'SIGCONT');\n    await delay(800);\n\n    // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n    // never reaped and respawned, despite the probe failing while it was stopped.\n    expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a STALE maintenance marker (already expired): it names the live child but its\n    // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() - 1_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n    const fresh = await startSession(paths, true, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    expect(await statsOk(fresh.client, 20_000)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n\n    // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n    // and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    // The reap SIGKILLs the stopped orphan, so it may already be gone — SIGCONT only to be sure a\n    // surviving stopped process is resumable for teardown; tolerate ESRCH when it is already reaped.\n    try { process.kill(orphanPid!, 'SIGCONT'); } catch { /* already reaped */ }\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, false);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    const secondary = await startSession(paths, false);\n    expect(await statsOk(secondary.client)).toBe(true);\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // With the flag off, the daemon dies with its owner and the secondary's next\n    // call fails (no surviving daemon to serve it) within a short window.\n    expect(isAlive(daemonPid!)).toBe(false);\n    expect(await statsOk(secondary.client, 6_000)).toBe(false);\n  });\n});","lineStart":1,"lineEnd":488,"totalLines":488,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","time":{"start":1781755631207,"end":1781755631219}},"metadata":{"openai":{"itemId":"fc_037f7296ff70a56b016a336eef1664819198a05b3e0e63a916"}},"id":"prt_ed8e9565e001JgnJ5yOtuXlHEZ","sessionID":"ses_127185023ffen0qKKl1I08wyww","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4"}}
{"type":"step_finish","timestamp":1781755631545,"sessionID":"ses_127185023ffen0qKKl1I08wyww","part":{"id":"prt_ed8e957b6001WUBt4lGfVikXN0","reason":"tool-calls","snapshot":"ca382f8195c50f47fe0a7852c1b5a0ed88c37e99","messageID":"msg_ed8e9287c001qw4g8Kjfj0PRF4","sessionID":"ses_127185023ffen0qKKl1I08wyww","type":"step-finish","tokens":{"total":107750,"input":14633,"output":410,"reasoning":35,"cache":{"write":0,"read":92672}},"cost":0}}
