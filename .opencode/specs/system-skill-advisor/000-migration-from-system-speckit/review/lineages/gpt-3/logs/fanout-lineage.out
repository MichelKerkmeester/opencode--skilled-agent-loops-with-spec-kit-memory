{"type":"tool_use","timestamp":1783433231957,"sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","part":{"type":"tool","tool":"glob","callID":"call_jAITLdHWx9GpuUohnfaMrWF0","state":{"status":"completed","input":{"pattern":".opencode/specs/system-skill-advisor/000-migration-from-system-speckit/**/*","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/decision-record.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/spec.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/plan.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/review/iterations/iteration-001.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/review/orchestration-status.log\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/review/deep-review-state.jsonl\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/review/deep-review-strategy.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/review/observability-events.jsonl\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/review/review-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/checklist.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/tasks.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/description.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/implementation-summary.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/000-migration-from-system-speckit/graph-metadata.json","metadata":{"count":14,"truncated":false},"title":"","time":{"start":1783433231768,"end":1783433231956}},"metadata":{"openai":{"itemId":"fc_0613d0a725572f6c016a4d080f93108197a91c33ea31b7cd7e"}},"id":"prt_f3ce77d97001XX6MBt7CiYGQNP","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","messageID":"msg_f3ce73240001TR6ulaRtj8n64q"}}
{"type":"step_finish","timestamp":1783433232339,"sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","part":{"id":"prt_f3ce77fcf0013xcR1ytubc5HGx","reason":"tool-calls","snapshot":"5b12e178c67627480e14766c6a0fa2cc809bc0ac","messageID":"msg_f3ce73240001TR6ulaRtj8n64q","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","type":"step-finish","tokens":{"total":46639,"input":16601,"output":515,"reasoning":339,"cache":{"write":0,"read":29184}},"cost":0}}
{"type":"step_start","timestamp":1783433236688,"sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","part":{"id":"prt_f3ce790ce001gif6Wxyk7M9ZR6","messageID":"msg_f3ce78108001vpvWPy5TsYcdSF","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","snapshot":"5b12e178c67627480e14766c6a0fa2cc809bc0ac","type":"step-start"}}
{"type":"tool_use","timestamp":1783433250594,"sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","part":{"type":"tool","tool":"read","callID":"call_h7ZJHGtNUYuTnODHSQ2VAfKd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/SKILL.md","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/SKILL.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: cli-opencode\n3: description: \"OpenCode CLI orchestrator: external dispatch, in-OpenCode parallel sessions, cross-AI handback with full runtime context.\"\n4: allowed-tools: [Bash, Read, Glob, Grep]\n5: version: 1.3.15.1\n6: hard_rules:\n7:   - id: stdin-redirect-required\n8:     check: stdin-redirect-required\n9:     message: \"Ad-hoc `opencode run` MUST close/redirect stdin (`</dev/null`) — omitting it can hang indefinitely at 0% CPU with zero output.\"\n10:     severity: warn\n11:   - id: no-bare-agent-general\n12:     check: no-bare-agent-general\n13:     message: \"Never pass a bare top-level `--agent general`; opencode rejects it on run.\"\n14:     severity: warn\n15:   - id: command-flag-for-slash-prompt\n16:     check: command-flag-for-slash-prompt\n17:     message: \"A slash-command-shaped prompt (`/family:name ...`) needs `--command <family>/<name>`, else opencode silently delivers the slash text as raw prose.\"\n18:     severity: warn\n19:   - id: share-requires-confirmation\n20:     check: share-requires-confirmation\n21:     message: \"`--share` publishes the session and requires prior operator confirmation.\"\n22:     severity: warn\n23: ---\n24: \n25: <!-- Keywords: opencode, opencode-cli, opencode-run, cross-ai, spec-kit-runtime, plugin-runtime, parallel-sessions, share-url, detached-session, agent-delegation, deepseek, openai, minimax, minimax-coding-plan, minimax-m3, token-plan, xiaomi, xiaomi-token-plan, xiaomi-token-plan-ams, xiaomi-api, xiaomi-direct, mimo, mimo-v2.5-pro, mimo-v2.5-pro-ultraspeed, ultraspeed, glm-5.2, zai-coding-plan, z.ai-coding-plan, glm-coding-plan -->\n26: \n27: # OpenCode CLI Orchestrator - Full-Runtime Cross-AI Dispatch\n28: \n29: > **CRITICAL — SELF-INVOCATION PROHIBITED**\n30: >\n31: > This skill dispatches to the OpenCode CLI binary (`opencode`). If the agent currently reading this skill is itself running inside OpenCode (TUI / acp / serve / run modes — detection signals listed in §2), the skill MUST refuse to load and return the documented error message instead of generating any `opencode` invocation. The only exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session with its own session id and state directory.\n32: >\n33: > A running CLI skill never dispatches itself. The cli-X skills are for **cross-AI delegation only** — never self-invocation.\n34: \n35: Orchestrate OpenCode's `opencode run` from external AI assistants (Claude Code, OpenCode, raw shell) AND from inside an existing OpenCode session for parallel detached workers. Three documented use cases keep the cycle risk explicit while giving every dispatch path a copy-paste invocation shape.\n36: \n37: **Core Principle**: The calling AI stays the conductor. Delegate to OpenCode for what it does best — full plugin, skill, MCP, and Spec Kit Memory runtime in a one-shot dispatch. Validate and integrate the output.\n38: \n39: ---\n40: \n41: ## 1. WHEN TO USE\n42: \n43: ### Activation Triggers\n44: \n45: - **Full plugin / skill / MCP runtime** (use case 1) — calling AI is Claude Code / OpenCode / Copilot / raw shell AND the task needs the project's full Spec Kit Memory database, Code Graph semantic index, structural code graph, or every plugin/skill/MCP tool in a one-shot dispatch. Includes `@deep-research` / `@deep-review` agent loops with externalized state under `.opencode/specs/`.\n46: - **Parallel detached session** (use case 2) — operator already inside OpenCode (TUI / web / serve / acp) AND wants a SEPARATE session with its own session id and state directory for ablation, worker farm, or parallel research. Prompt explicitly mentions \"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", or \"share URL\".\n47: - **Cross-AI orchestration handback** (use case 3) — calling AI is non-Anthropic (OpenCode / Copilot), task targets a project-specific subsystem (spec-kit, memory, code-graph, advisor), and the non-Anthropic CLI cannot load the project's plugin/skill/MCP runtime on its own and needs OpenCode as a bridge. When the caller only needs a daemon-backed tool call, prefer the shipped front doors (`spec-memory.cjs`, `code-index.cjs`, `skill-advisor.cjs`) over a full `opencode run` delegation.\n48: - **Agent dispatch** — task matches a specialized OpenCode agent. Primary agents (directly invokable via `--agent`): `general`, `plan` (built-in), `orchestrate`. Generic subagents fully dispatched via the orchestrate primary: `context`, `review`, `write`, `debug`, `ai-council`. Command-owned loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are owned end-to-end by their parent `/deep:*` command; `orchestrate` may perform exactly one bounded hand-off dispatch to a recognized loop request, but never manages the loop itself. See §3 \"OpenCode Agent Delegation\" for the full contract.\n49: - **Cross-repo dispatch** — session in repo A dispatches into repo B's plugin/skill/MCP runtime via `--dir <path>` or remote OpenCode server via `--attach <url>`.\n50: \n51: ### When NOT to Use\n52: \n53: - **You ARE OpenCode already.** If your runtime is OpenCode (detection signal: `$OPENCODE_CONFIG_DIR` or any `OPENCODE_*` env var set, `opencode` in process ancestry, or `~/.opencode/state/<id>/lock` present), this skill refuses to load. Self-invocation creates a circular dispatch loop and burns tokens for no value. The cli-X family is exclusively for cross-AI delegation. The single legitimate exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session id and state directory (use case 2); without that qualifier, the smart router refuses per ADR-001.\n54: - Simple, quick tasks where `opencode run` overhead is not worth it.\n55: - Tasks that only need a raw model dispatch — use a sibling cli-* skill.\n56: - Tasks requiring interactive TUI or web UI (use `opencode` directly instead of `opencode run`).\n57: - Context already loaded and understood by the calling AI.\n58: - Tasks where the OpenCode binary is not installed at the expected path.\n59: \n60: ---\n61: \n62: ## 2. SMART ROUTING\n63: \n64: \n65: ### Prerequisite Detection\n66: \n67: ```bash\n68: # Verify OpenCode CLI is available\n69: command -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n70: \n71: # SELF-INVOCATION GUARD (ADR-001 layered detection)\n72: # Layer 1: env var lookup — any OPENCODE_* variable\n73: env | grep -q '^OPENCODE_' && echo \"ERROR: OPENCODE_* env detected — already inside OpenCode.\"\n74: # Layer 2: process ancestry — opencode in parent tree\n75: ps -o command= -p \"$PPID\" | grep -q opencode && echo \"ERROR: opencode parent process detected.\"\n76: # Layer 3: state lock-file probe\n77: ls ~/.opencode/state/*/lock 2>/dev/null | head -1 | grep -q lock && echo \"ERROR: live OpenCode session lock detected.\"\n78: ```\n79: \n80: ### Self-Invocation Guard (ADR-001)\n81: \n82: ```python\n83: def detect_self_invocation():\n84:     \"\"\"Returns a non-None signal when the orchestrator is already running inside OpenCode.\"\"\"\n85:     # Layer 1: env var lookup — OpenCode sets OPENCODE_CONFIG_DIR and OPENCODE_* vars\n86:     for key in os.environ:\n87:         if key == 'OPENCODE_CONFIG_DIR' or key.startswith('OPENCODE_'):\n88:             return ('env', key)\n89:     # Layer 2: process ancestry — opencode in parent tree\n90:     try:\n91:         ancestry = subprocess.check_output(['ps', '-o', 'command=', '-p', str(os.getppid())]).decode()\n92:         if '/opencode' in ancestry or 'opencode ' in ancestry:\n93:             return ('ancestry', 'opencode')\n94:     except subprocess.SubprocessError:\n95:         pass\n96:     # Layer 3: state lock-file probe\n97:     state_dir = os.path.expanduser('~/.opencode/state')\n98:     if os.path.isdir(state_dir):\n99:         for entry in os.listdir(state_dir):\n100:             if os.path.exists(os.path.join(state_dir, entry, 'lock')):\n101:                 return ('lockfile', entry)\n102:     return None\n103: \n104: if detect_self_invocation():\n105:     # Single legitimate exception: explicit \"parallel detached\" keywords (use case 2)\n106:     # spawn a SEPARATE session id and state directory, not a self-dispatch.\n107:     if not has_parallel_session_keywords(prompt):\n108:         refuse(\n109:             \"Self-invocation refused: this agent is already running inside OpenCode. \"\n110:             \"Use a sibling cli-* skill or a fresh shell session in a different runtime to dispatch a different model. \"\n111:             \"For a parallel detached session, restate with explicit parallel-session keywords.\"\n112:         )\n113: ```\n114: \n115: ### Resource Loading Levels\n116: \n117: | Level       | When to Load            | Resources                      |\n118: | ----------- | ----------------------- | ------------------------------ |\n119: | ALWAYS      | Every skill invocation  | `references/cli_reference.md`, `assets/prompt_quality_card.md` |\n120: | CONDITIONAL | If intent signals match | Intent-mapped reference docs   |\n121: | ON_DEMAND   | Only on explicit request| Extended templates and patterns |\n122: \n123: ### Smart Router\n124: \n125: Intent-specific dictionaries (used by the shared helper functions in [`system-spec-kit/references/cli/shared_smart_router.md`](../system-spec-kit/references/cli/shared_smart_router.md)):\n126: \n127: - Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans existing `references/` and `assets/` folders with `base.exists()` safeguards.\n128: - Pattern 2: Existence-Check Before Load - `load_if_available()` uses `_guard_in_skill()`, `inventory`, and `seen` so raw loads, missing files, duplicate loads, and path escapes are rejected.\n129: - Pattern 3: Not applicable here - `cli-opencode` has flat resource folders, not keyed `references/<key>/` or `assets/<key>/` subdirectories. Routing selects from `RESOURCE_MAP` by intent signal rather than by runtime resource key.\n130: - Pattern 4: Multi-Tier Graceful Fallback - low-confidence intent scores return `UNKNOWN_FALLBACK` with a disambiguation checklist; missing intent resources still return always-load baseline docs plus a clear notice.\n131: \n132: ```python\n133: INTENT_SIGNALS = {\n134:     \"EXTERNAL_DISPATCH\":  {\"weight\": 4, \"keywords\": [\"delegate to opencode\", \"opencode run\", \"from claude code\", \"from opencode\", \"from copilot\", \"external runtime\", \"full plugin runtime\"]},\n135:     \"PARALLEL_DETACHED\":  {\"weight\": 4, \"keywords\": [\"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", \"share url\", \"share-url\", \"detached session\"]},\n136:     \"CROSS_AI_HANDBACK\":  {\"weight\": 4, \"keywords\": [\"spec kit\", \"spec-kit\", \"spec_kit\", \"code graph\", \"memory_search\", \"session_bootstrap\", \"skill advisor\", \"cross-ai handback\"]},\n137:     \"AGENT_DISPATCH\":     {\"weight\": 4, \"keywords\": [\"delegate\", \"agent\", \"deep-research\", \"deep-review\", \"ai-council\", \"review agent\", \"context agent\"]},\n138:     \"CROSS_REPO\":         {\"weight\": 3, \"keywords\": [\"cross-repo\", \"different repo\", \"--dir\", \"another repository\", \"remote opencode\"]},\n139:     \"TEMPLATES\":          {\"weight\": 3, \"keywords\": [\"template\", \"prompt\", \"how to ask\", \"opencode prompt\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\", \"prompt framework\"]},\n140:     \"PATTERNS\":           {\"weight\": 3, \"keywords\": [\"pattern\", \"workflow\", \"orchestrate\", \"session continue\", \"resume session\"]},\n141:     # WHY: DESIGN is an intent signal only. The durable sk-design loading contract lives in the\n142:     # always-fires Design Standards Loading rule and the dispatch manifest; RESOURCE_MAP stays\n143:     # limited to same-skill markdown paths.\n144:     \"DESIGN\":             {\"weight\": 4, \"keywords\": [\"sk-design\", \"interface design\", \"frontend design\", \"visual design\", \"redesign the ui\", \"design foundations\", \"design tokens\", \"motion design\", \"micro-interactions\", \"design audit\", \"ui critique\", \"extract design system\", \"generate design.md\"]},\n145: }\n146: \n147: RESOURCE_MAP = {\n148:     \"EXTERNAL_DISPATCH\":  [\"references/cli_reference.md\", \"references/integration_patterns.md\"],\n149:     \"PARALLEL_DETACHED\":  [\"references/integration_patterns.md\", \"assets/prompt_templates.md\"],\n150:     \"CROSS_AI_HANDBACK\":  [\"references/integration_patterns.md\", \"references/opencode_tools.md\"],\n151:     \"AGENT_DISPATCH\":     [\"references/agent_delegation.md\", \"assets/prompt_templates.md\"],\n152:     \"CROSS_REPO\":         [\"references/cli_reference.md\", \"references/opencode_tools.md\"],\n153:     \"TEMPLATES\":          [\"assets/prompt_templates.md\", \"references/cli_reference.md\"],\n154:     \"PATTERNS\":           [\"references/integration_patterns.md\", \"references/cli_reference.md\"],\n155: }\n156: \n157: LOADING_LEVELS = {\n158:     \"ALWAYS\": [\"references/cli_reference.md\", \"assets/prompt_quality_card.md\"],\n159:     \"ON_DEMAND_KEYWORDS\": [\"full reference\", \"all templates\", \"deep dive\", \"complete guide\", \"opencode agent\", \"opencode prompt\", \"share url\", \"ablation\", \"worker farm\", \"self-invocation\", \"memory handback\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\"],\n160:     \"ON_DEMAND\": [\"references/opencode_tools.md\", \"assets/prompt_templates.md\"],\n161: }\n162: \n163: UNKNOWN_FALLBACK_CHECKLIST = [\n164:     \"Is the user asking about OpenCode CLI specifically?\",\n165:     \"Does the task need the project's full plugin / skill / MCP runtime?\",\n166:     \"Is a parallel detached session what they want?\",\n167:     \"Is a non-Anthropic CLI handing back to OpenCode for a spec-kit workflow?\",\n168: ]\n169: ```\n170: \n171: **Call sequence** (using shared helpers from `shared_smart_router.md`):\n172: \n173: 1. `discover_markdown_resources()` — recursively enumerate current `.md` files under existing `references/` and `assets/` folders at routing time.\n174: 2. `_guard_in_skill()` + `load_if_available()` — sandbox paths to this skill, reject non-markdown loads, skip missing files, and suppress duplicates.\n175: 3. `score_intents(task)` and `select_intents(scores, ambiguity_delta=1.0)` — preserve provider-specific weighted intent scoring and top-2 ambiguity handling.\n176: 4. ALWAYS-load `LOADING_LEVELS[\"ALWAYS\"]`, then return `UNKNOWN_FALLBACK` with `UNKNOWN_FALLBACK_CHECKLIST` when max score is 0.\n177: 5. CONDITIONAL-load existing `RESOURCE_MAP[intent]` entries via `load_if_available()`, ON_DEMAND-load keyword matches, and return a notice when no intent-specific knowledge base is available beyond always-load resources.\n178: \n179: The `route_opencode_resources(task)` function body lives in [`shared_smart_router.md`](../system-spec-kit/references/cli/shared_smart_router.md) — substitute `<PROVIDER>` = `opencode`.\n180: \n181: ---\n182: \n183: ## 3. HOW IT WORKS\n184: \n185: ### Prerequisites\n186: \n187: ```bash\n188: # Verify installation (cli-opencode v1.0.0 is pinned to opencode v1.3.17)\n189: opencode --version | grep -q '^1\\.' || echo \"Not installed or version drift. See references/cli_reference.md §9.\"\n190: \n191: # Self-invocation guard\n192: env | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n193: \n194: # Authentication — providers configured via opencode providers (alias auth)\n195: opencode providers\n196: ```\n197: \n198: **Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans) for OAuth and API key flows. Configured providers on a typical install: `deepseek` (api, DEFAULT), `minimax-coding-plan` (MiniMax Token Plan subscription — **DEFAULT MiniMax path**; `opencode auth login`; model `minimax-coding-plan/MiniMax-M3`), `minimax` (MiniMax Direct API, pay-per-token — `opencode providers login minimax`; model `minimax/MiniMax-M3`), `xiaomi` (Xiaomi Direct API, pay-per-token — `opencode providers login xiaomi`; models `xiaomi/mimo-v2.5-pro` and the low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe; `opencode auth login`; model `xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), `openai` (api, premium alternative for `gpt-5.5`/`gpt-5.5-pro`/`gpt-5.5-fast`).\n199: \n200: ### Provider Auth Pre-Flight (Smart Fallback)\n201: \n202: **MANDATORY before any first dispatch in a session.** The default provider may not be logged in on this machine — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run this check once per session, cache the result, and re-run it only if a dispatch fails with an auth error.\n203: \n204: ```bash\n205: # One-shot pre-flight: list configured providers, capture for routing\n206: PROVIDERS=$(opencode providers list 2>&1)\n207: echo \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\n208: echo \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\n209: echo \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\n210: echo \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\n211: echo \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\n212: echo \"$PROVIDERS\" | grep -q \"openai\"              && OPENAI_OK=1         || OPENAI_OK=0\n213: ```\n214: \n215: **Decision tree** (apply in order — first match wins):\n216: \n217: | State | DEEPSEEK_OK | OPENAI_OK | Action |\n218: |-------|-------------|-----------|--------|\n219: | Default available | 1 | * | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n220: | Default missing, openai ready | 0 | 1 | **ASK user** before substituting to OpenAI — surface options A/B/C/D below; OpenAI is a paid premium fallback. |\n221: | All missing | 0 | 0 | **ASK user** to configure a provider — surface the login commands, do NOT dispatch. |\n222: \n223: **MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative — first match wins):\n224: \n225: | State | Condition | Action |\n226: |-------|-----------|--------|\n227: | MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n228: | Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n229: | Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n230: | Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to run `opencode providers login minimax` (needs `MINIMAX_API_KEY`) — never substitute silently |\n231: \n232: **MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n233: \n234: | State | Condition | Action |\n235: |-------|-----------|--------|\n236: | MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro --variant high` (high reasoning is the standing default — opencode maps low/medium/high to MiMo's reasoning effort) — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13); confirm the live id via `opencode models xiaomi` |\n237: | MiMo speed variant requested (\"ultraspeed\", latency-sensitive checks/smokes) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed --variant high` — low-latency MiMo-V2.5-Pro serving tier, same COSTAR prompt contract as the standard model |\n238: | Direct API not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n239: | Token Plan explicitly requested | `XIAOMI_OK=1` | Proceed with `--model xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n240: | Token Plan requested, not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n241: \n242: **User prompt template — default missing, fallback configured:**\n243: \n244: ```\n245: The skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\n246: A configured fallback is available. Pick one:\n247:   A) Use `openai/gpt-5.5-pro --variant high` (OpenAI premium, configured now — paid)\n248:   B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n249:   C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n250:   D) Run `opencode providers login deepseek` first, then retry the original dispatch\n251:   E) Name a different model — paste the `--model <provider/model>` you want to use\n252: ```\n253: \n254: **User prompt template — all providers missing:**\n255: \n256: ```\n257: No supported providers are configured on this machine. Run one:\n258:   - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n259:   - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n260:   - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n261:   - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n262:   - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n263:   - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n264:   - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n265:   - `opencode providers login openai`       (OpenAI premium alternative — paid)\n266: Which would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n267: ```\n268: \n269: **Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n270: \n271: ### Default Invocation (Skill Default)\n272: \n273: **Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>`. The repo root pin avoids CWD ambiguity. Direct DeepSeek is the default provider — it gives elevated reasoning at low cost for routine cli-opencode dispatches.\n274: \n275: Use `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n276: \n277: > **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run`. Current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails the dispatch outright. When no `--agent` is given, the default agent runs — which is what you want for almost every dispatch. **To run as a specific agent profile, describe the role in the prompt body** (for example, open the prompt with \"Act as a code-review agent: …\"), not via `--agent`. Only pass `--agent <name>` if you have confirmed against `opencode run --help` on the installed version that it accepts that agent at the top level.\n278: \n279: Honor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n280: \n281: ### Core Invocation Pattern\n282: \n283: Core flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n284: \n285: > **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation. Without it, opencode can inherit parent-terminal stdin and trigger the reactive-EOF exit path when that stream closes. See `references/integration_patterns.md` §6.\n286: \n287: > **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text to the model as raw prose, and the command template (router contract, presentation assets, MUST-render envelopes) never enters the session. To execute a registered command non-interactively: `opencode run --command <family>/<name> [flags] \"<args>\"` — the message becomes `$ARGUMENTS`. Registry names are slash-namespaced: `memory/search` for `/memory:search` (a wrong `--command` name fails with the full registry list). Verified on opencode 1.17.4. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n288: \n289: ### Model Selection\n290: \n291: Run `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default to `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API); the MiniMax Token Plan default `minimax-coding-plan/MiniMax-M3` (omit `--agent`), the pay-per-token `minimax/MiniMax-M3` (Direct API), `xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` (Xiaomi Token Plan Europe — MiMo; high reasoning preset; omit `--agent`), `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API — MiMo; pay-per-token) and `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` (low-latency MiMo tier, same prompt contract) remain available. The Kimi For Coding plan model `kimi-for-coding/k2p7` (\"Kimi K2.7 Code\"; 256k / 262,144-token context; subscription billing — dispatch cost 0; omit `--agent`; `--variant high` accepted but effect benchmark-unverified) is the coding-optimized large-context Kimi path. **Operational caveat (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`. The Z.AI GLM Coding Plan model `zai-coding-plan/glm-5.2` (\"GLM-5.2\"; flagship long-horizon coding; 1,000,000-token context / 131,072 output per Z.AI docs; subscription billing; omit `--agent`; `--variant`↔`reasoning_effort` mapping unverified — GLM has native high/max, smoke-test before relying on it; thinking on by default + preserved on the Coding Plan endpoint) is the Z.AI direct-provider GLM path, superseding the gateway-only `glm-5.1` removed in v1.3.15.0; confirm the live slug via `opencode models zai-coding-plan`. **Operational (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45... (line truncated to 2000 chars)\n292: \n293: Shared small-model facts, context defaults, quota pools, and fallback targets live in `../sk-prompt-models/assets/model_profiles.json`.\n294: \n295: ### OpenCode Agent Delegation\n296: \n297: The calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n298: \n299: #### Primary agents — directly invokable via `--agent`\n300: \n301: OpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Caveat — never pass `--agent general`:** the current opencode treats `general` as a subagent and rejects it at the top level, and the default agent (used when no `--agent` is given) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` on the installed version confirms top-level acceptance; otherwise state the role in the prompt body.\n302: \n303: #### Subagents — dispatched as Task subagents from a primary\n304: \n305: These live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n306: \n307: 1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by a primary (`orchestrate`) using the Task tool. To exercise via the opencode CLI, route through `--agent orchestrate` and let it dispatch the relevant subagent.\n308: 2. **`ai-council`** — dispatched either via its own `/deep:ai-council` command or via `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`); route through `/deep:ai-council` or `--agent orchestrate` with an ai-council-shaped prompt.\n309: 3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>` from the CLI. `orchestrate` is an authorized **caller/coordinator only** for these agents (e.g. its registry-backed `/deep:review` Priority row) — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop (no iterating, no convergence checks, no continuity tracking); that remains the parent command's job.\n310: \n311: Generic subagents (`context`, `review`, `write`, `debug`) and `ai-council` route through `orchestrate` for full Task-tool dispatch; loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are loop-owned by their parent commands, with `orchestrate` limited to a single bounded hand-off when it recognizes one of these as the target.\n312: \n313: See [agent_delegation.md](./references/agent_delegation.md) for the complete agent roster and dispatch patterns.\n314: \n315: ### Unique OpenCode Strengths\n316: \n317: OpenCode dispatch provides full project runtime loading, detached sessions, JSON event streams, agent routing, cross-repo/server dispatch, session continuation, and plugin-disable debugging.\n318: \n319: ### Essential Commands\n320: \n321: Use the default invocation for external runtime handback, append `--share --port <N>` only for explicit detached sessions, select `--agent orchestrate` for generic subagent routing, and change `--dir` for cross-repo dispatch.\n322: \n323: ### Error Handling\n324: \n325: Install missing binaries, refuse ambiguous self-invocation, run provider pre-flight for model/auth errors, check version drift for unknown flags, force `--format json` for empty streams, add `</dev/null` for background loops, confirm `--share`, use `--pure` only for plugin crashes, and inspect state logs for stuck sessions.\n326: \n327: ---\n328: \n329: ## 4. RULES\n330: \n331: ### ✅ ALWAYS\n332: \n333: 1. Verify OpenCode CLI is installed before first invocation; confirm version baseline against v1.3.17 (drift handling per `references/cli_reference.md` §9).\n334: 2. **Run the self-invocation guard before dispatch** (ADR-001): Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for `opencode` parent, Layer 3 `~/.opencode/state/<id>/lock` probe. Trip on ANY positive — refuse unless prompt has explicit parallel-session keywords.\n335: 3. Pin model + variant + format + dir explicitly — **no `--agent`** (see the Default Invocation note: current opencode rejects a top-level `--agent general`; put any agent-profile request in the prompt body). Default: `--model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root>`. Honor user overrides verbatim (e.g. `deepseek/deepseek-v4-pro`, `minimax-coding-plan/MiniMax-M3`, `minimax/MiniMax-M3`, `xiaomi-token-plan-ams/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro-ultraspeed`, `openai/gpt-5.5-pro`).\n336: 4. Pass `--format json` unless the calling AI explicitly wants formatted output — JSON event stream is what external runtimes parse incrementally.\n337: 5. **Append `</dev/null` to every non-interactive `opencode run` invocation** that redirects stdout and/or stderr to files OR runs inside `while read` loops. opencode v1.14.39 reads stdin at startup before session creation; without explicit closed stdin, automation hangs forever at 0% CPU after the `+60s service=snapshot prune=7.days cleanup` log line. Position: AFTER the prompt positional argument, BEFORE the `> stdout 2> stderr` redirects. Foreground `| tail` happens to provide closed stdin (pipe stage upstream is empty) and accidentally bypasses the bug, but `> stdout.log 2> stderr.log` does not. The 9-character `</dev/null` redirect provides immediate EOF on stdin, unblocking the dispatch. **DO NOT auto-kill external operator-owned opencode sessions** when sweeping orphans between dispatches; exclude `opencode run` from pkill (per 2026-05-23 operator directive captured in memory `feedback_proactive_orphan_cleanup.md`). See `references/integration_patterns.md` §6 + memory `feedback_opencode_run_requires_dev_null_stdin.md` + CHANGELOG-2026-05-08-tool-name-regex-fix.md §Fix 4.\n338: 6. **Pass the spec folder to the dispatched session** in the prompt: if the calling AI has an active Gate-3 spec folder, include `Spec folder: <path> (pre-approved, skip Gate 3)`. If none, ASK the user before delegating — the dispatched session cannot answer Gate 3 interactively in non-interactive `run` mode.\n339: 7. **Prompt construction & model-craft (cli-* family precedence).** Compose every dispatch prompt via the 3-tier rule canonical in `../sk-prompt-models/assets/cli_prompt_quality_card.md`:\n340:    1. **Fast path (default).** Build from the local `assets/prompt_quality_card.md`, which delegates the framework table + CLEAR check to the canonical card.\n341:    2. **Model override (mandatory for a profiled model).** If the target model has a profile at `../sk-prompt-models/references/models/<id>.md`, that profile OVERRIDES the cross-model default. The **sk-prompt-models** hub owns per-model prompt-craft (framework + scaffold + gotchas, mirroring `sk-prompt-models/assets/model_profiles.json` `recommended_frameworks`); consult it before composing for any small model.\n342:    3. **Deep path (escalation).** Dispatch `@prompt-improver` via the Task tool (never load full `sk-prompt` inline) when any canonical **Tier 3** trigger applies — the trigger list lives in `../sk-prompt-models/assets/cli_prompt_quality_card.md` under \"Tier 3 — Deep path\"; do not re-enumerate it here.\n343: 8. Validate dispatched session output: parse JSON events incrementally (tool calls, partial messages, final summary), run syntax checks if code generated, and cross-reference against project standards via `sk-code` surface detection plus its code-review mode when findings-first review is requested (see ALWAYS rule 12).\n344: 9. Capture stderr (`2>&1`) to catch tool errors and warnings.\n345: 10. Classify the use case (1 / 2 / 3) before dispatching — the smart router refuses dispatches that do not map to one of the three.\n346: 11. **Run the Provider Auth Pre-Flight once per session** (see §3 Provider Auth Pre-Flight). Cache the configured-providers list. If the default `deepseek` is missing, ASK the user — never silently substitute the model. If a later dispatch returns an auth error, invalidate the cache and rerun the pre-flight before retrying.\n347: 12. **Code Standards Loading (surface-aware contract)** — When dispatching for code review or code generation, instruct the dispatched session to: (1) load `sk-code`; (2) let `sk-code` emit a surface tag matching the detected stack from markers and target files; (3) load the selected surface resources and run its verification commands; (4) load `sk-code`'s code-review mode only for formal findings-first review output. Fallback: if the surface cannot be determined confidently, ask for the runtime surface and verification command set. NEVER hardcode obsolete sibling code skills in dispatch prompts.\n348: 13. **Design Standards Loading (surface-aware contract)** — When dispatching for design or UI work, instruct the dispatched session to: (1) load `sk-design` (the hub); (2) let the hub resolve a `workflowMode` through `mode-registry.json` (interface / foundations / motion / audit / md-generator / design-mcp-open-design); (3) load the selected mode packet, set the design register, and run that mode's design verification; (4) if the work feeds Open Design, carry the `design-mcp-open-design` pairing (a nested transport packet of the hub) — the transport never decides taste. Fallback: if the design mode cannot be determined confidently, ask for the surface and design intent. NEVER treat `mcp-figma` or `design-mcp-open-design` as the taste authority, or hardcode obsolete flat design skills in dispatch prompts.\n349: 14. **Pass the design dispatch manifest to the dispatched session** — when dispatching design or UI work, inline a `DESIGN_DISPATCH_MANIFEST v1` block in the prompt (the child cannot resolve skill paths, so the manifest travels in the payload, not by reference): `skDesignLoaded` true, `register` resolved to `Brand` or `Product` (never `unknown`), registry-valid `workflowModes`, `dials`, `loadedFiles`, and `proofDemandBack`. If the manifest cannot be assembled — `sk-design` not loaded, register unresolved, or no registry-valid mode — ASK before launching the child rather than starting a silent design dispatch. The child returns the demanded proof; the parent reconciles it on the return path.\n350: 15. **Destructive-scope-violation prevention (RM-8) for deep-loop dispatches** — If a permissions-matrix config is loaded (via `--permissions-matrix <path>` flag or recipe field), the structured gate applies and the four-layer prose mitigation is bypassed; see `references/permissions-matrix.md`. Without a loaded matrix, any non-interactive `opencode run` with `--dangerously-skip-permissions` against a populated worktree MUST apply the four-layer mitigation as a legacy fallback, deprecated-but-supported during transition: (L1) rendered prompt contains literal `BANNED OPERATIONS` and `ALLOWED WRITE PATHS`; (L2) `--dir` points at a fresh `git worktree`; (L3) main `git status` clean OR committed, recovery-baseline commit hash recorded; (L4) for multi-phase / phase-parent targets, prefer `cli-copilot` + `gpt-5.5 --reasoning-effort high` over `deepseek-v4-pro`. Background: on 2026-05-04 an `opencode-go/deepseek-v4-pro` dispatch under `/deep:review:auto` deleted 44 files across two phase folders because the only safeguard was prose and `--dangerously-skip-permissions` granted unrestricted FS write. Full incident + root cause + checklist: `references/destructive_scope_violations.md`.\n351: 16. **Single-dispatch discipline (operator-gated, session-scoped)** — Default: launch ONE cli-* dispatch at a time across the cli-* family (cli-opencode, cli-claude-code). Wait for the dispatched agent's work to return, verify outputs exist, then SIGKILL the dispatcher process + any orphan children (`pkill -9 -f \"opencode run\"` for this skill, plus `gtimeout` / `positional_scoring_fallback:app` cleanup). Only launch the next dispatch (this skill OR a sibling) after the prior one is dead and RSS has dropped. **Within a deep-flow session** (deep-review / deep-research): the operator authorizes the whole multi-iteration session at start — iterations chain back-to-back with kill-between as the safety mechanism, NOT a per-iteration operator confirmation prompt. **Exception (cross-skill parallel)**: when the operator explicitly authorizes N parallel dispatches, run N concurrently — but still SIGKILL each as its work returns.\n352: 17. **Set `AI_SESSION_CHILD=1` in the dispatched session's env** when sessions may be launched through the per-session worktree wrapper (`.opencode/bin/worktree-session.sh`). A dispatched `opencode run` is an orchestrated sub-session, not a new top-level session, so it must SHARE the parent's worktree rather than allocate its own. The wrapper checks `AI_SESSION_CHILD` (plus a `git --git-common-dir` structural backstop) and exec's in place when set. Pattern: `AI_SESSION_CHILD=1 opencode run ... </dev/null`. Harmless when the wrapper is not in use. See `.opencode/bin/README.md` → \"Worktree session isolation\".\n353: \n354: ### ❌ NEVER\n355: \n356: 1. Invoke this skill from within OpenCode itself for a self-dispatch — refuse with the documented error message; use a sibling cli-* / fresh shell / parallel-session keywords.\n357: 2. Pass `--share` without operator confirmation (CHK-033) — share URL exposes session contents.\n358: 3. Trust dispatched session output blindly for security-sensitive code, send sensitive data (API keys, passwords, credentials) in prompts, or hammer the API with rapid sequential calls.\n359: 4. Use `--pure` outside of plugin debugging (disabling plugins removes the entire point of cli-opencode dispatch).\n360: 5. Nest `opencode run` inside a dispatched session's tool calls — use OpenCode's native Task tool for sub-agent dispatch.\n361: \n362: ### ⚠️ ESCALATE IF\n363: \n364: 1. OpenCode CLI is not installed and user has not acknowledged (provide `brew install opencode` or `curl -fsSL https://opencode.ai/install | bash`).\n365: 2. Operator wants to publish a `--share` URL — get explicit confirmation per CHK-033.\n366: 3. Binary version differs from the v1.3.17 baseline — run `opencode --version` and `opencode run --help`; surface drift and fall back or require approval.\n367: 4. Smart router cannot map the prompt to one of the three use cases — surface the disambiguation checklist from UNKNOWN_FALLBACK.\n368: 5. Self-invocation guard trips AND the prompt is ambiguous — surface the refusal with three remediation options (sibling cli-* / fresh shell / parallel-session keywords).\n369: \n370: ### Memory Handback Protocol\n371: \n372: When the calling AI needs to preserve session context from an OpenCode CLI delegation, run the canonical 7-step procedure (extract `MEMORY_HANDBACK` section → build structured JSON → scrub secrets → invoke `generate-context.js` via `--stdin`/`--json`/temp-file → `memory_index_scan`). Full procedure and caveats: [`system-spec-kit/references/cli/memory_handback.md`](../system-spec-kit/references/cli/memory_handback.md).\n373: \n374: For read-only or hook-style recovery, use the daemon-backed CLI front doors instead of spawning OpenCode: `node .opencode/bin/spec-memory.cjs <tool>`, `node .opencode/bin/code-index.cjs <tool>`, or `node .opencode/bin/skill-advisor.cjs <tool>`. Prompt-time paths must probe warm sockets or pass `--warm-only`; exit `75` is retryable daemon/IPC unavailability, not a model failure.\n375: \n376: OpenCode-specific Memory Epilogue template: see [assets/prompt_templates.md](./assets/prompt_templates.md) §14.\n377: \n378: Example invocation:\n379: ```bash\n380: printf '%s' \"$JSON_PAYLOAD\" | node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --stdin [spec-folder]\n381: ```\n382: \n383: ---\n384: \n385: ## 5. REFERENCES\n386: \n387: ### Core References\n388: \n389: - [cli_reference.md](./references/cli_reference.md) - Full subcommand and flag reference, models, version drift handling\n390: - [integration_patterns.md](./references/integration_patterns.md) - 3 use cases, decision tree, self-invocation guard, silent stdin\n391: - [opencode_tools.md](./references/opencode_tools.md) - Unique value props vs sibling cli-* skills\n392: - [agent_delegation.md](./references/agent_delegation.md) - Agent routing matrix, leaf-agent constraints\n393: - [destructive_scope_violations.md](./references/destructive_scope_violations.md) - RM-8 incident (2026-05-04, 44 files deleted), root cause analysis, four-layer prevention playbook\n394: \n395: ### Templates and Assets\n396: \n397: - [prompt_templates.md](./assets/prompt_templates.md) - 13 numbered copy-paste templates per use case + agent + handback\n398: - [prompt_quality_card.md](./assets/prompt_quality_card.md) - Executor-specific model overrides (MiniMax, MiMo); delegates shared framework table and CLEAR check to canonical card\n399: \n400: ### Shared (cli-* family)\n401: - [shared_smart_router.md](../system-spec-kit/references/cli/shared_smart_router.md) - Helper-function bodies for the smart router.\n402: - [memory_handback.md](../system-spec-kit/references/cli/memory_handback.md) - Canonical 7-step Memory Handback procedure.\n403: \n404: ### External\n405: - [OpenCode GitHub](https://github.com/sst/opencode) - Official repository\n406: - [OpenCode Install](https://opencode.ai/install) - Standalone installer entry point\n407: - [OpenCode Documentation](https://opencode.ai/docs) - Official docs\n408: \n409: ### Reference Loading Notes\n410: \n411: - Load only references needed for current intent.\n412: - Smart Routing (Section 2) is the single routing authority.\n413: - `cli_reference.md` and `prompt_quality_card.md` are ALWAYS loaded as baseline.\n414: \n415: ---\n416: \n417: ## 6. SUCCESS CRITERIA\n418: \n419: ### Task Completion\n420: \n421: - OpenCode CLI invoked with the correct subcommand, flags, model, agent, variant, format, and dir.\n422: - Self-invocation guard checked before dispatch — refused when appropriate.\n423: - Use case (1 / 2 / 3) classified explicitly before invocation.\n424: - JSON event stream captured, parsed incrementally, validated, integrated.\n425: - No security vulnerabilities introduced from generated code.\n426: - `--share` URLs opt-in with operator confirmation per CHK-033.\n427: - Background dispatches in `while read` loops include `</dev/null` redirect.\n428: - Memory Handback extracted and saved through `generate-context.js` when applicable.\n429: \n430: ### Skill Quality\n431: \n432: - All 8 sections present with proper anchor comments.\n433: - Smart routing covers all intent signals with UNKNOWN_FALLBACK.\n434: - Reference files provide deep-dive content without duplication.\n435: - Self-invocation guard pseudocode reproduced in Section 2 mirrors ADR-001.\n436: \n437: ---\n438: \n439: ## 7. INTEGRATION POINTS\n440: \n441: ### Framework Integration\n442: \n443: This skill operates within the behavioral framework defined in [AGENTS.md](../../../AGENTS.md).\n444: \n445: Key integrations:\n446: - **Gate 2**: Skill routing via the Skill Advisor Hook (or `skill_advisor.py` fallback)\n447: - **Tool Routing**: Per AGENTS.md Section 6 decision tree\n448: - **Memory**: Context preserved via Spec Kit Memory MCP (`generate-context.js`)\n449: - **Validation**: `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh` for spec-folder workflows\n450: \n451: **Tool roles**: Bash dispatches the CLI; Read/Glob/Grep validate output and probe `~/.opencode/state/` for session locks.\n452: \n453: ---\n454: \n455: ## 8. REFERENCES AND RELATED RESOURCES\n456: \n457: The router discovers reference, asset, and script docs dynamically. Start with `references/cli_reference.md`, `references/integration_patterns.md`, `assets/prompt_quality_card.md`, `assets/prompt_templates.md`, `references/agent_delegation.md`, `references/opencode_tools.md`, then load task-specific resources from `references/`, templates from `assets/`, and automation from `scripts/` when present.\n458: \n459: Related skills: `cli-claude-code` and `cli-opencode` for sibling cross-AI dispatch; `system-spec-kit` for handback; `sk-code` plus the selected overlay for generated code; `deep-loop-workflows` for loop execution (its `research` and `review` modes); and `mcp-code-mode` for MCP-backed tools.\n\n(End of file - total 459 lines)\n</content>","metadata":{"preview":"---\nname: cli-opencode\ndescription: \"OpenCode CLI orchestrator: external dispatch, in-OpenCode parallel sessions, cross-AI handback with full runtime context.\"\nallowed-tools: [Bash, Read, Glob, Grep]\nversion: 1.3.15.1\nhard_rules:\n  - id: stdin-redirect-required\n    check: stdin-redirect-required\n    message: \"Ad-hoc `opencode run` MUST close/redirect stdin (`</dev/null`) — omitting it can hang indefinitely at 0% CPU with zero output.\"\n    severity: warn\n  - id: no-bare-agent-general\n    check: no-bare-agent-general\n    message: \"Never pass a bare top-level `--agent general`; opencode rejects it on run.\"\n    severity: warn\n  - id: command-flag-for-slash-prompt\n    check: command-flag-for-slash-prompt\n    message: \"A slash-command-shaped prompt (`/family:name ...`) needs `--command <family>/<name>`, else opencode silently delivers the slash text as raw prose.\"\n    severity: warn\n  - id: share-requires-confirmation\n    check: share-requires-confirmation","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/SKILL.md","text":"---\nname: cli-opencode\ndescription: \"OpenCode CLI orchestrator: external dispatch, in-OpenCode parallel sessions, cross-AI handback with full runtime context.\"\nallowed-tools: [Bash, Read, Glob, Grep]\nversion: 1.3.15.1\nhard_rules:\n  - id: stdin-redirect-required\n    check: stdin-redirect-required\n    message: \"Ad-hoc `opencode run` MUST close/redirect stdin (`</dev/null`) — omitting it can hang indefinitely at 0% CPU with zero output.\"\n    severity: warn\n  - id: no-bare-agent-general\n    check: no-bare-agent-general\n    message: \"Never pass a bare top-level `--agent general`; opencode rejects it on run.\"\n    severity: warn\n  - id: command-flag-for-slash-prompt\n    check: command-flag-for-slash-prompt\n    message: \"A slash-command-shaped prompt (`/family:name ...`) needs `--command <family>/<name>`, else opencode silently delivers the slash text as raw prose.\"\n    severity: warn\n  - id: share-requires-confirmation\n    check: share-requires-confirmation\n    message: \"`--share` publishes the session and requires prior operator confirmation.\"\n    severity: warn\n---\n\n<!-- Keywords: opencode, opencode-cli, opencode-run, cross-ai, spec-kit-runtime, plugin-runtime, parallel-sessions, share-url, detached-session, agent-delegation, deepseek, openai, minimax, minimax-coding-plan, minimax-m3, token-plan, xiaomi, xiaomi-token-plan, xiaomi-token-plan-ams, xiaomi-api, xiaomi-direct, mimo, mimo-v2.5-pro, mimo-v2.5-pro-ultraspeed, ultraspeed, glm-5.2, zai-coding-plan, z.ai-coding-plan, glm-coding-plan -->\n\n# OpenCode CLI Orchestrator - Full-Runtime Cross-AI Dispatch\n\n> **CRITICAL — SELF-INVOCATION PROHIBITED**\n>\n> This skill dispatches to the OpenCode CLI binary (`opencode`). If the agent currently reading this skill is itself running inside OpenCode (TUI / acp / serve / run modes — detection signals listed in §2), the skill MUST refuse to load and return the documented error message instead of generating any `opencode` invocation. The only exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session with its own session id and state directory.\n>\n> A running CLI skill never dispatches itself. The cli-X skills are for **cross-AI delegation only** — never self-invocation.\n\nOrchestrate OpenCode's `opencode run` from external AI assistants (Claude Code, OpenCode, raw shell) AND from inside an existing OpenCode session for parallel detached workers. Three documented use cases keep the cycle risk explicit while giving every dispatch path a copy-paste invocation shape.\n\n**Core Principle**: The calling AI stays the conductor. Delegate to OpenCode for what it does best — full plugin, skill, MCP, and Spec Kit Memory runtime in a one-shot dispatch. Validate and integrate the output.\n\n---\n\n## 1. WHEN TO USE\n\n### Activation Triggers\n\n- **Full plugin / skill / MCP runtime** (use case 1) — calling AI is Claude Code / OpenCode / Copilot / raw shell AND the task needs the project's full Spec Kit Memory database, Code Graph semantic index, structural code graph, or every plugin/skill/MCP tool in a one-shot dispatch. Includes `@deep-research` / `@deep-review` agent loops with externalized state under `.opencode/specs/`.\n- **Parallel detached session** (use case 2) — operator already inside OpenCode (TUI / web / serve / acp) AND wants a SEPARATE session with its own session id and state directory for ablation, worker farm, or parallel research. Prompt explicitly mentions \"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", or \"share URL\".\n- **Cross-AI orchestration handback** (use case 3) — calling AI is non-Anthropic (OpenCode / Copilot), task targets a project-specific subsystem (spec-kit, memory, code-graph, advisor), and the non-Anthropic CLI cannot load the project's plugin/skill/MCP runtime on its own and needs OpenCode as a bridge. When the caller only needs a daemon-backed tool call, prefer the shipped front doors (`spec-memory.cjs`, `code-index.cjs`, `skill-advisor.cjs`) over a full `opencode run` delegation.\n- **Agent dispatch** — task matches a specialized OpenCode agent. Primary agents (directly invokable via `--agent`): `general`, `plan` (built-in), `orchestrate`. Generic subagents fully dispatched via the orchestrate primary: `context`, `review`, `write`, `debug`, `ai-council`. Command-owned loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are owned end-to-end by their parent `/deep:*` command; `orchestrate` may perform exactly one bounded hand-off dispatch to a recognized loop request, but never manages the loop itself. See §3 \"OpenCode Agent Delegation\" for the full contract.\n- **Cross-repo dispatch** — session in repo A dispatches into repo B's plugin/skill/MCP runtime via `--dir <path>` or remote OpenCode server via `--attach <url>`.\n\n### When NOT to Use\n\n- **You ARE OpenCode already.** If your runtime is OpenCode (detection signal: `$OPENCODE_CONFIG_DIR` or any `OPENCODE_*` env var set, `opencode` in process ancestry, or `~/.opencode/state/<id>/lock` present), this skill refuses to load. Self-invocation creates a circular dispatch loop and burns tokens for no value. The cli-X family is exclusively for cross-AI delegation. The single legitimate exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session id and state directory (use case 2); without that qualifier, the smart router refuses per ADR-001.\n- Simple, quick tasks where `opencode run` overhead is not worth it.\n- Tasks that only need a raw model dispatch — use a sibling cli-* skill.\n- Tasks requiring interactive TUI or web UI (use `opencode` directly instead of `opencode run`).\n- Context already loaded and understood by the calling AI.\n- Tasks where the OpenCode binary is not installed at the expected path.\n\n---\n\n## 2. SMART ROUTING\n\n\n### Prerequisite Detection\n\n```bash\n# Verify OpenCode CLI is available\ncommand -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n\n# SELF-INVOCATION GUARD (ADR-001 layered detection)\n# Layer 1: env var lookup — any OPENCODE_* variable\nenv | grep -q '^OPENCODE_' && echo \"ERROR: OPENCODE_* env detected — already inside OpenCode.\"\n# Layer 2: process ancestry — opencode in parent tree\nps -o command= -p \"$PPID\" | grep -q opencode && echo \"ERROR: opencode parent process detected.\"\n# Layer 3: state lock-file probe\nls ~/.opencode/state/*/lock 2>/dev/null | head -1 | grep -q lock && echo \"ERROR: live OpenCode session lock detected.\"\n```\n\n### Self-Invocation Guard (ADR-001)\n\n```python\ndef detect_self_invocation():\n    \"\"\"Returns a non-None signal when the orchestrator is already running inside OpenCode.\"\"\"\n    # Layer 1: env var lookup — OpenCode sets OPENCODE_CONFIG_DIR and OPENCODE_* vars\n    for key in os.environ:\n        if key == 'OPENCODE_CONFIG_DIR' or key.startswith('OPENCODE_'):\n            return ('env', key)\n    # Layer 2: process ancestry — opencode in parent tree\n    try:\n        ancestry = subprocess.check_output(['ps', '-o', 'command=', '-p', str(os.getppid())]).decode()\n        if '/opencode' in ancestry or 'opencode ' in ancestry:\n            return ('ancestry', 'opencode')\n    except subprocess.SubprocessError:\n        pass\n    # Layer 3: state lock-file probe\n    state_dir = os.path.expanduser('~/.opencode/state')\n    if os.path.isdir(state_dir):\n        for entry in os.listdir(state_dir):\n            if os.path.exists(os.path.join(state_dir, entry, 'lock')):\n                return ('lockfile', entry)\n    return None\n\nif detect_self_invocation():\n    # Single legitimate exception: explicit \"parallel detached\" keywords (use case 2)\n    # spawn a SEPARATE session id and state directory, not a self-dispatch.\n    if not has_parallel_session_keywords(prompt):\n        refuse(\n            \"Self-invocation refused: this agent is already running inside OpenCode. \"\n            \"Use a sibling cli-* skill or a fresh shell session in a different runtime to dispatch a different model. \"\n            \"For a parallel detached session, restate with explicit parallel-session keywords.\"\n        )\n```\n\n### Resource Loading Levels\n\n| Level       | When to Load            | Resources                      |\n| ----------- | ----------------------- | ------------------------------ |\n| ALWAYS      | Every skill invocation  | `references/cli_reference.md`, `assets/prompt_quality_card.md` |\n| CONDITIONAL | If intent signals match | Intent-mapped reference docs   |\n| ON_DEMAND   | Only on explicit request| Extended templates and patterns |\n\n### Smart Router\n\nIntent-specific dictionaries (used by the shared helper functions in [`system-spec-kit/references/cli/shared_smart_router.md`](../system-spec-kit/references/cli/shared_smart_router.md)):\n\n- Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans existing `references/` and `assets/` folders with `base.exists()` safeguards.\n- Pattern 2: Existence-Check Before Load - `load_if_available()` uses `_guard_in_skill()`, `inventory`, and `seen` so raw loads, missing files, duplicate loads, and path escapes are rejected.\n- Pattern 3: Not applicable here - `cli-opencode` has flat resource folders, not keyed `references/<key>/` or `assets/<key>/` subdirectories. Routing selects from `RESOURCE_MAP` by intent signal rather than by runtime resource key.\n- Pattern 4: Multi-Tier Graceful Fallback - low-confidence intent scores return `UNKNOWN_FALLBACK` with a disambiguation checklist; missing intent resources still return always-load baseline docs plus a clear notice.\n\n```python\nINTENT_SIGNALS = {\n    \"EXTERNAL_DISPATCH\":  {\"weight\": 4, \"keywords\": [\"delegate to opencode\", \"opencode run\", \"from claude code\", \"from opencode\", \"from copilot\", \"external runtime\", \"full plugin runtime\"]},\n    \"PARALLEL_DETACHED\":  {\"weight\": 4, \"keywords\": [\"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", \"share url\", \"share-url\", \"detached session\"]},\n    \"CROSS_AI_HANDBACK\":  {\"weight\": 4, \"keywords\": [\"spec kit\", \"spec-kit\", \"spec_kit\", \"code graph\", \"memory_search\", \"session_bootstrap\", \"skill advisor\", \"cross-ai handback\"]},\n    \"AGENT_DISPATCH\":     {\"weight\": 4, \"keywords\": [\"delegate\", \"agent\", \"deep-research\", \"deep-review\", \"ai-council\", \"review agent\", \"context agent\"]},\n    \"CROSS_REPO\":         {\"weight\": 3, \"keywords\": [\"cross-repo\", \"different repo\", \"--dir\", \"another repository\", \"remote opencode\"]},\n    \"TEMPLATES\":          {\"weight\": 3, \"keywords\": [\"template\", \"prompt\", \"how to ask\", \"opencode prompt\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\", \"prompt framework\"]},\n    \"PATTERNS\":           {\"weight\": 3, \"keywords\": [\"pattern\", \"workflow\", \"orchestrate\", \"session continue\", \"resume session\"]},\n    # WHY: DESIGN is an intent signal only. The durable sk-design loading contract lives in the\n    # always-fires Design Standards Loading rule and the dispatch manifest; RESOURCE_MAP stays\n    # limited to same-skill markdown paths.\n    \"DESIGN\":             {\"weight\": 4, \"keywords\": [\"sk-design\", \"interface design\", \"frontend design\", \"visual design\", \"redesign the ui\", \"design foundations\", \"design tokens\", \"motion design\", \"micro-interactions\", \"design audit\", \"ui critique\", \"extract design system\", \"generate design.md\"]},\n}\n\nRESOURCE_MAP = {\n    \"EXTERNAL_DISPATCH\":  [\"references/cli_reference.md\", \"references/integration_patterns.md\"],\n    \"PARALLEL_DETACHED\":  [\"references/integration_patterns.md\", \"assets/prompt_templates.md\"],\n    \"CROSS_AI_HANDBACK\":  [\"references/integration_patterns.md\", \"references/opencode_tools.md\"],\n    \"AGENT_DISPATCH\":     [\"references/agent_delegation.md\", \"assets/prompt_templates.md\"],\n    \"CROSS_REPO\":         [\"references/cli_reference.md\", \"references/opencode_tools.md\"],\n    \"TEMPLATES\":          [\"assets/prompt_templates.md\", \"references/cli_reference.md\"],\n    \"PATTERNS\":           [\"references/integration_patterns.md\", \"references/cli_reference.md\"],\n}\n\nLOADING_LEVELS = {\n    \"ALWAYS\": [\"references/cli_reference.md\", \"assets/prompt_quality_card.md\"],\n    \"ON_DEMAND_KEYWORDS\": [\"full reference\", \"all templates\", \"deep dive\", \"complete guide\", \"opencode agent\", \"opencode prompt\", \"share url\", \"ablation\", \"worker farm\", \"self-invocation\", \"memory handback\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\"],\n    \"ON_DEMAND\": [\"references/opencode_tools.md\", \"assets/prompt_templates.md\"],\n}\n\nUNKNOWN_FALLBACK_CHECKLIST = [\n    \"Is the user asking about OpenCode CLI specifically?\",\n    \"Does the task need the project's full plugin / skill / MCP runtime?\",\n    \"Is a parallel detached session what they want?\",\n    \"Is a non-Anthropic CLI handing back to OpenCode for a spec-kit workflow?\",\n]\n```\n\n**Call sequence** (using shared helpers from `shared_smart_router.md`):\n\n1. `discover_markdown_resources()` — recursively enumerate current `.md` files under existing `references/` and `assets/` folders at routing time.\n2. `_guard_in_skill()` + `load_if_available()` — sandbox paths to this skill, reject non-markdown loads, skip missing files, and suppress duplicates.\n3. `score_intents(task)` and `select_intents(scores, ambiguity_delta=1.0)` — preserve provider-specific weighted intent scoring and top-2 ambiguity handling.\n4. ALWAYS-load `LOADING_LEVELS[\"ALWAYS\"]`, then return `UNKNOWN_FALLBACK` with `UNKNOWN_FALLBACK_CHECKLIST` when max score is 0.\n5. CONDITIONAL-load existing `RESOURCE_MAP[intent]` entries via `load_if_available()`, ON_DEMAND-load keyword matches, and return a notice when no intent-specific knowledge base is available beyond always-load resources.\n\nThe `route_opencode_resources(task)` function body lives in [`shared_smart_router.md`](../system-spec-kit/references/cli/shared_smart_router.md) — substitute `<PROVIDER>` = `opencode`.\n\n---\n\n## 3. HOW IT WORKS\n\n### Prerequisites\n\n```bash\n# Verify installation (cli-opencode v1.0.0 is pinned to opencode v1.3.17)\nopencode --version | grep -q '^1\\.' || echo \"Not installed or version drift. See references/cli_reference.md §9.\"\n\n# Self-invocation guard\nenv | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n\n# Authentication — providers configured via opencode providers (alias auth)\nopencode providers\n```\n\n**Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans) for OAuth and API key flows. Configured providers on a typical install: `deepseek` (api, DEFAULT), `minimax-coding-plan` (MiniMax Token Plan subscription — **DEFAULT MiniMax path**; `opencode auth login`; model `minimax-coding-plan/MiniMax-M3`), `minimax` (MiniMax Direct API, pay-per-token — `opencode providers login minimax`; model `minimax/MiniMax-M3`), `xiaomi` (Xiaomi Direct API, pay-per-token — `opencode providers login xiaomi`; models `xiaomi/mimo-v2.5-pro` and the low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe; `opencode auth login`; model `xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), `openai` (api, premium alternative for `gpt-5.5`/`gpt-5.5-pro`/`gpt-5.5-fast`).\n\n### Provider Auth Pre-Flight (Smart Fallback)\n\n**MANDATORY before any first dispatch in a session.** The default provider may not be logged in on this machine — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run this check once per session, cache the result, and re-run it only if a dispatch fails with an auth error.\n\n```bash\n# One-shot pre-flight: list configured providers, capture for routing\nPROVIDERS=$(opencode providers list 2>&1)\necho \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\necho \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\necho \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\necho \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\necho \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\necho \"$PROVIDERS\" | grep -q \"openai\"              && OPENAI_OK=1         || OPENAI_OK=0\n```\n\n**Decision tree** (apply in order — first match wins):\n\n| State | DEEPSEEK_OK | OPENAI_OK | Action |\n|-------|-------------|-----------|--------|\n| Default available | 1 | * | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n| Default missing, openai ready | 0 | 1 | **ASK user** before substituting to OpenAI — surface options A/B/C/D below; OpenAI is a paid premium fallback. |\n| All missing | 0 | 0 | **ASK user** to configure a provider — surface the login commands, do NOT dispatch. |\n\n**MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n| Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n| Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n| Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to run `opencode providers login minimax` (needs `MINIMAX_API_KEY`) — never substitute silently |\n\n**MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro --variant high` (high reasoning is the standing default — opencode maps low/medium/high to MiMo's reasoning effort) — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13); confirm the live id via `opencode models xiaomi` |\n| MiMo speed variant requested (\"ultraspeed\", latency-sensitive checks/smokes) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed --variant high` — low-latency MiMo-V2.5-Pro serving tier, same COSTAR prompt contract as the standard model |\n| Direct API not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n| Token Plan explicitly requested | `XIAOMI_OK=1` | Proceed with `--model xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n| Token Plan requested, not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n\n**User prompt template — default missing, fallback configured:**\n\n```\nThe skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\nA configured fallback is available. Pick one:\n  A) Use `openai/gpt-5.5-pro --variant high` (OpenAI premium, configured now — paid)\n  B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n  C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n  D) Run `opencode providers login deepseek` first, then retry the original dispatch\n  E) Name a different model — paste the `--model <provider/model>` you want to use\n```\n\n**User prompt template — all providers missing:**\n\n```\nNo supported providers are configured on this machine. Run one:\n  - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n  - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n  - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n  - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n  - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n  - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n  - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n  - `opencode providers login openai`       (OpenAI premium alternative — paid)\nWhich would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n```\n\n**Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n### Default Invocation (Skill Default)\n\n**Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>`. The repo root pin avoids CWD ambiguity. Direct DeepSeek is the default provider — it gives elevated reasoning at low cost for routine cli-opencode dispatches.\n\nUse `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n\n> **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run`. Current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails the dispatch outright. When no `--agent` is given, the default agent runs — which is what you want for almost every dispatch. **To run as a specific agent profile, describe the role in the prompt body** (for example, open the prompt with \"Act as a code-review agent: …\"), not via `--agent`. Only pass `--agent <name>` if you have confirmed against `opencode run --help` on the installed version that it accepts that agent at the top level.\n\nHonor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n\n### Core Invocation Pattern\n\nCore flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n\n> **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation. Without it, opencode can inherit parent-terminal stdin and trigger the reactive-EOF exit path when that stream closes. See `references/integration_patterns.md` §6.\n\n> **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text to the model as raw prose, and the command template (router contract, presentation assets, MUST-render envelopes) never enters the session. To execute a registered command non-interactively: `opencode run --command <family>/<name> [flags] \"<args>\"` — the message becomes `$ARGUMENTS`. Registry names are slash-namespaced: `memory/search` for `/memory:search` (a wrong `--command` name fails with the full registry list). Verified on opencode 1.17.4. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n\n### Model Selection\n\nRun `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default to `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API); the MiniMax Token Plan default `minimax-coding-plan/MiniMax-M3` (omit `--agent`), the pay-per-token `minimax/MiniMax-M3` (Direct API), `xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` (Xiaomi Token Plan Europe — MiMo; high reasoning preset; omit `--agent`), `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API — MiMo; pay-per-token) and `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` (low-latency MiMo tier, same prompt contract) remain available. The Kimi For Coding plan model `kimi-for-coding/k2p7` (\"Kimi K2.7 Code\"; 256k / 262,144-token context; subscription billing — dispatch cost 0; omit `--agent`; `--variant high` accepted but effect benchmark-unverified) is the coding-optimized large-context Kimi path. **Operational caveat (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`. The Z.AI GLM Coding Plan model `zai-coding-plan/glm-5.2` (\"GLM-5.2\"; flagship long-horizon coding; 1,000,000-token context / 131,072 output per Z.AI docs; subscription billing; omit `--agent`; `--variant`↔`reasoning_effort` mapping unverified — GLM has native high/max, smoke-test before relying on it; thinking on by default + preserved on the Coding Plan endpoint) is the Z.AI direct-provider GLM path, superseding the gateway-only `glm-5.1` removed in v1.3.15.0; confirm the live slug via `opencode models zai-coding-plan`. **Operational (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45... (line truncated to 2000 chars)\n\nShared small-model facts, context defaults, quota pools, and fallback targets live in `../sk-prompt-models/assets/model_profiles.json`.\n\n### OpenCode Agent Delegation\n\nThe calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n\n#### Primary agents — directly invokable via `--agent`\n\nOpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Caveat — never pass `--agent general`:** the current opencode treats `general` as a subagent and rejects it at the top level, and the default agent (used when no `--agent` is given) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` on the installed version confirms top-level acceptance; otherwise state the role in the prompt body.\n\n#### Subagents — dispatched as Task subagents from a primary\n\nThese live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n\n1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by a primary (`orchestrate`) using the Task tool. To exercise via the opencode CLI, route through `--agent orchestrate` and let it dispatch the relevant subagent.\n2. **`ai-council`** — dispatched either via its own `/deep:ai-council` command or via `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`); route through `/deep:ai-council` or `--agent orchestrate` with an ai-council-shaped prompt.\n3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>` from the CLI. `orchestrate` is an authorized **caller/coordinator only** for these agents (e.g. its registry-backed `/deep:review` Priority row) — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop (no iterating, no convergence checks, no continuity tracking); that remains the parent command's job.\n\nGeneric subagents (`context`, `review`, `write`, `debug`) and `ai-council` route through `orchestrate` for full Task-tool dispatch; loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are loop-owned by their parent commands, with `orchestrate` limited to a single bounded hand-off when it recognizes one of these as the target.\n\nSee [agent_delegation.md](./references/agent_delegation.md) for the complete agent roster and dispatch patterns.\n\n### Unique OpenCode Strengths\n\nOpenCode dispatch provides full project runtime loading, detached sessions, JSON event streams, agent routing, cross-repo/server dispatch, session continuation, and plugin-disable debugging.\n\n### Essential Commands\n\nUse the default invocation for external runtime handback, append `--share --port <N>` only for explicit detached sessions, select `--agent orchestrate` for generic subagent routing, and change `--dir` for cross-repo dispatch.\n\n### Error Handling\n\nInstall missing binaries, refuse ambiguous self-invocation, run provider pre-flight for model/auth errors, check version drift for unknown flags, force `--format json` for empty streams, add `</dev/null` for background loops, confirm `--share`, use `--pure` only for plugin crashes, and inspect state logs for stuck sessions.\n\n---\n\n## 4. RULES\n\n### ✅ ALWAYS\n\n1. Verify OpenCode CLI is installed before first invocation; confirm version baseline against v1.3.17 (drift handling per `references/cli_reference.md` §9).\n2. **Run the self-invocation guard before dispatch** (ADR-001): Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for `opencode` parent, Layer 3 `~/.opencode/state/<id>/lock` probe. Trip on ANY positive — refuse unless prompt has explicit parallel-session keywords.\n3. Pin model + variant + format + dir explicitly — **no `--agent`** (see the Default Invocation note: current opencode rejects a top-level `--agent general`; put any agent-profile request in the prompt body). Default: `--model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root>`. Honor user overrides verbatim (e.g. `deepseek/deepseek-v4-pro`, `minimax-coding-plan/MiniMax-M3`, `minimax/MiniMax-M3`, `xiaomi-token-plan-ams/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro-ultraspeed`, `openai/gpt-5.5-pro`).\n4. Pass `--format json` unless the calling AI explicitly wants formatted output — JSON event stream is what external runtimes parse incrementally.\n5. **Append `</dev/null` to every non-interactive `opencode run` invocation** that redirects stdout and/or stderr to files OR runs inside `while read` loops. opencode v1.14.39 reads stdin at startup before session creation; without explicit closed stdin, automation hangs forever at 0% CPU after the `+60s service=snapshot prune=7.days cleanup` log line. Position: AFTER the prompt positional argument, BEFORE the `> stdout 2> stderr` redirects. Foreground `| tail` happens to provide closed stdin (pipe stage upstream is empty) and accidentally bypasses the bug, but `> stdout.log 2> stderr.log` does not. The 9-character `</dev/null` redirect provides immediate EOF on stdin, unblocking the dispatch. **DO NOT auto-kill external operator-owned opencode sessions** when sweeping orphans between dispatches; exclude `opencode run` from pkill (per 2026-05-23 operator directive captured in memory `feedback_proactive_orphan_cleanup.md`). See `references/integration_patterns.md` §6 + memory `feedback_opencode_run_requires_dev_null_stdin.md` + CHANGELOG-2026-05-08-tool-name-regex-fix.md §Fix 4.\n6. **Pass the spec folder to the dispatched session** in the prompt: if the calling AI has an active Gate-3 spec folder, include `Spec folder: <path> (pre-approved, skip Gate 3)`. If none, ASK the user before delegating — the dispatched session cannot answer Gate 3 interactively in non-interactive `run` mode.\n7. **Prompt construction & model-craft (cli-* family precedence).** Compose every dispatch prompt via the 3-tier rule canonical in `../sk-prompt-models/assets/cli_prompt_quality_card.md`:\n   1. **Fast path (default).** Build from the local `assets/prompt_quality_card.md`, which delegates the framework table + CLEAR check to the canonical card.\n   2. **Model override (mandatory for a profiled model).** If the target model has a profile at `../sk-prompt-models/references/models/<id>.md`, that profile OVERRIDES the cross-model default. The **sk-prompt-models** hub owns per-model prompt-craft (framework + scaffold + gotchas, mirroring `sk-prompt-models/assets/model_profiles.json` `recommended_frameworks`); consult it before composing for any small model.\n   3. **Deep path (escalation).** Dispatch `@prompt-improver` via the Task tool (never load full `sk-prompt` inline) when any canonical **Tier 3** trigger applies — the trigger list lives in `../sk-prompt-models/assets/cli_prompt_quality_card.md` under \"Tier 3 — Deep path\"; do not re-enumerate it here.\n8. Validate dispatched session output: parse JSON events incrementally (tool calls, partial messages, final summary), run syntax checks if code generated, and cross-reference against project standards via `sk-code` surface detection plus its code-review mode when findings-first review is requested (see ALWAYS rule 12).\n9. Capture stderr (`2>&1`) to catch tool errors and warnings.\n10. Classify the use case (1 / 2 / 3) before dispatching — the smart router refuses dispatches that do not map to one of the three.\n11. **Run the Provider Auth Pre-Flight once per session** (see §3 Provider Auth Pre-Flight). Cache the configured-providers list. If the default `deepseek` is missing, ASK the user — never silently substitute the model. If a later dispatch returns an auth error, invalidate the cache and rerun the pre-flight before retrying.\n12. **Code Standards Loading (surface-aware contract)** — When dispatching for code review or code generation, instruct the dispatched session to: (1) load `sk-code`; (2) let `sk-code` emit a surface tag matching the detected stack from markers and target files; (3) load the selected surface resources and run its verification commands; (4) load `sk-code`'s code-review mode only for formal findings-first review output. Fallback: if the surface cannot be determined confidently, ask for the runtime surface and verification command set. NEVER hardcode obsolete sibling code skills in dispatch prompts.\n13. **Design Standards Loading (surface-aware contract)** — When dispatching for design or UI work, instruct the dispatched session to: (1) load `sk-design` (the hub); (2) let the hub resolve a `workflowMode` through `mode-registry.json` (interface / foundations / motion / audit / md-generator / design-mcp-open-design); (3) load the selected mode packet, set the design register, and run that mode's design verification; (4) if the work feeds Open Design, carry the `design-mcp-open-design` pairing (a nested transport packet of the hub) — the transport never decides taste. Fallback: if the design mode cannot be determined confidently, ask for the surface and design intent. NEVER treat `mcp-figma` or `design-mcp-open-design` as the taste authority, or hardcode obsolete flat design skills in dispatch prompts.\n14. **Pass the design dispatch manifest to the dispatched session** — when dispatching design or UI work, inline a `DESIGN_DISPATCH_MANIFEST v1` block in the prompt (the child cannot resolve skill paths, so the manifest travels in the payload, not by reference): `skDesignLoaded` true, `register` resolved to `Brand` or `Product` (never `unknown`), registry-valid `workflowModes`, `dials`, `loadedFiles`, and `proofDemandBack`. If the manifest cannot be assembled — `sk-design` not loaded, register unresolved, or no registry-valid mode — ASK before launching the child rather than starting a silent design dispatch. The child returns the demanded proof; the parent reconciles it on the return path.\n15. **Destructive-scope-violation prevention (RM-8) for deep-loop dispatches** — If a permissions-matrix config is loaded (via `--permissions-matrix <path>` flag or recipe field), the structured gate applies and the four-layer prose mitigation is bypassed; see `references/permissions-matrix.md`. Without a loaded matrix, any non-interactive `opencode run` with `--dangerously-skip-permissions` against a populated worktree MUST apply the four-layer mitigation as a legacy fallback, deprecated-but-supported during transition: (L1) rendered prompt contains literal `BANNED OPERATIONS` and `ALLOWED WRITE PATHS`; (L2) `--dir` points at a fresh `git worktree`; (L3) main `git status` clean OR committed, recovery-baseline commit hash recorded; (L4) for multi-phase / phase-parent targets, prefer `cli-copilot` + `gpt-5.5 --reasoning-effort high` over `deepseek-v4-pro`. Background: on 2026-05-04 an `opencode-go/deepseek-v4-pro` dispatch under `/deep:review:auto` deleted 44 files across two phase folders because the only safeguard was prose and `--dangerously-skip-permissions` granted unrestricted FS write. Full incident + root cause + checklist: `references/destructive_scope_violations.md`.\n16. **Single-dispatch discipline (operator-gated, session-scoped)** — Default: launch ONE cli-* dispatch at a time across the cli-* family (cli-opencode, cli-claude-code). Wait for the dispatched agent's work to return, verify outputs exist, then SIGKILL the dispatcher process + any orphan children (`pkill -9 -f \"opencode run\"` for this skill, plus `gtimeout` / `positional_scoring_fallback:app` cleanup). Only launch the next dispatch (this skill OR a sibling) after the prior one is dead and RSS has dropped. **Within a deep-flow session** (deep-review / deep-research): the operator authorizes the whole multi-iteration session at start — iterations chain back-to-back with kill-between as the safety mechanism, NOT a per-iteration operator confirmation prompt. **Exception (cross-skill parallel)**: when the operator explicitly authorizes N parallel dispatches, run N concurrently — but still SIGKILL each as its work returns.\n17. **Set `AI_SESSION_CHILD=1` in the dispatched session's env** when sessions may be launched through the per-session worktree wrapper (`.opencode/bin/worktree-session.sh`). A dispatched `opencode run` is an orchestrated sub-session, not a new top-level session, so it must SHARE the parent's worktree rather than allocate its own. The wrapper checks `AI_SESSION_CHILD` (plus a `git --git-common-dir` structural backstop) and exec's in place when set. Pattern: `AI_SESSION_CHILD=1 opencode run ... </dev/null`. Harmless when the wrapper is not in use. See `.opencode/bin/README.md` → \"Worktree session isolation\".\n\n### ❌ NEVER\n\n1. Invoke this skill from within OpenCode itself for a self-dispatch — refuse with the documented error message; use a sibling cli-* / fresh shell / parallel-session keywords.\n2. Pass `--share` without operator confirmation (CHK-033) — share URL exposes session contents.\n3. Trust dispatched session output blindly for security-sensitive code, send sensitive data (API keys, passwords, credentials) in prompts, or hammer the API with rapid sequential calls.\n4. Use `--pure` outside of plugin debugging (disabling plugins removes the entire point of cli-opencode dispatch).\n5. Nest `opencode run` inside a dispatched session's tool calls — use OpenCode's native Task tool for sub-agent dispatch.\n\n### ⚠️ ESCALATE IF\n\n1. OpenCode CLI is not installed and user has not acknowledged (provide `brew install opencode` or `curl -fsSL https://opencode.ai/install | bash`).\n2. Operator wants to publish a `--share` URL — get explicit confirmation per CHK-033.\n3. Binary version differs from the v1.3.17 baseline — run `opencode --version` and `opencode run --help`; surface drift and fall back or require approval.\n4. Smart router cannot map the prompt to one of the three use cases — surface the disambiguation checklist from UNKNOWN_FALLBACK.\n5. Self-invocation guard trips AND the prompt is ambiguous — surface the refusal with three remediation options (sibling cli-* / fresh shell / parallel-session keywords).\n\n### Memory Handback Protocol\n\nWhen the calling AI needs to preserve session context from an OpenCode CLI delegation, run the canonical 7-step procedure (extract `MEMORY_HANDBACK` section → build structured JSON → scrub secrets → invoke `generate-context.js` via `--stdin`/`--json`/temp-file → `memory_index_scan`). Full procedure and caveats: [`system-spec-kit/references/cli/memory_handback.md`](../system-spec-kit/references/cli/memory_handback.md).\n\nFor read-only or hook-style recovery, use the daemon-backed CLI front doors instead of spawning OpenCode: `node .opencode/bin/spec-memory.cjs <tool>`, `node .opencode/bin/code-index.cjs <tool>`, or `node .opencode/bin/skill-advisor.cjs <tool>`. Prompt-time paths must probe warm sockets or pass `--warm-only`; exit `75` is retryable daemon/IPC unavailability, not a model failure.\n\nOpenCode-specific Memory Epilogue template: see [assets/prompt_templates.md](./assets/prompt_templates.md) §14.\n\nExample invocation:\n```bash\nprintf '%s' \"$JSON_PAYLOAD\" | node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --stdin [spec-folder]\n```\n\n---\n\n## 5. REFERENCES\n\n### Core References\n\n- [cli_reference.md](./references/cli_reference.md) - Full subcommand and flag reference, models, version drift handling\n- [integration_patterns.md](./references/integration_patterns.md) - 3 use cases, decision tree, self-invocation guard, silent stdin\n- [opencode_tools.md](./references/opencode_tools.md) - Unique value props vs sibling cli-* skills\n- [agent_delegation.md](./references/agent_delegation.md) - Agent routing matrix, leaf-agent constraints\n- [destructive_scope_violations.md](./references/destructive_scope_violations.md) - RM-8 incident (2026-05-04, 44 files deleted), root cause analysis, four-layer prevention playbook\n\n### Templates and Assets\n\n- [prompt_templates.md](./assets/prompt_templates.md) - 13 numbered copy-paste templates per use case + agent + handback\n- [prompt_quality_card.md](./assets/prompt_quality_card.md) - Executor-specific model overrides (MiniMax, MiMo); delegates shared framework table and CLEAR check to canonical card\n\n### Shared (cli-* family)\n- [shared_smart_router.md](../system-spec-kit/references/cli/shared_smart_router.md) - Helper-function bodies for the smart router.\n- [memory_handback.md](../system-spec-kit/references/cli/memory_handback.md) - Canonical 7-step Memory Handback procedure.\n\n### External\n- [OpenCode GitHub](https://github.com/sst/opencode) - Official repository\n- [OpenCode Install](https://opencode.ai/install) - Standalone installer entry point\n- [OpenCode Documentation](https://opencode.ai/docs) - Official docs\n\n### Reference Loading Notes\n\n- Load only references needed for current intent.\n- Smart Routing (Section 2) is the single routing authority.\n- `cli_reference.md` and `prompt_quality_card.md` are ALWAYS loaded as baseline.\n\n---\n\n## 6. SUCCESS CRITERIA\n\n### Task Completion\n\n- OpenCode CLI invoked with the correct subcommand, flags, model, agent, variant, format, and dir.\n- Self-invocation guard checked before dispatch — refused when appropriate.\n- Use case (1 / 2 / 3) classified explicitly before invocation.\n- JSON event stream captured, parsed incrementally, validated, integrated.\n- No security vulnerabilities introduced from generated code.\n- `--share` URLs opt-in with operator confirmation per CHK-033.\n- Background dispatches in `while read` loops include `</dev/null` redirect.\n- Memory Handback extracted and saved through `generate-context.js` when applicable.\n\n### Skill Quality\n\n- All 8 sections present with proper anchor comments.\n- Smart routing covers all intent signals with UNKNOWN_FALLBACK.\n- Reference files provide deep-dive content without duplication.\n- Self-invocation guard pseudocode reproduced in Section 2 mirrors ADR-001.\n\n---\n\n## 7. INTEGRATION POINTS\n\n### Framework Integration\n\nThis skill operates within the behavioral framework defined in [AGENTS.md](../../../AGENTS.md).\n\nKey integrations:\n- **Gate 2**: Skill routing via the Skill Advisor Hook (or `skill_advisor.py` fallback)\n- **Tool Routing**: Per AGENTS.md Section 6 decision tree\n- **Memory**: Context preserved via Spec Kit Memory MCP (`generate-context.js`)\n- **Validation**: `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh` for spec-folder workflows\n\n**Tool roles**: Bash dispatches the CLI; Read/Glob/Grep validate output and probe `~/.opencode/state/` for session locks.\n\n---\n\n## 8. REFERENCES AND RELATED RESOURCES\n\nThe router discovers reference, asset, and script docs dynamically. Start with `references/cli_reference.md`, `references/integration_patterns.md`, `assets/prompt_quality_card.md`, `assets/prompt_templates.md`, `references/agent_delegation.md`, `references/opencode_tools.md`, then load task-specific resources from `references/`, templates from `assets/`, and automation from `scripts/` when present.\n\nRelated skills: `cli-claude-code` and `cli-opencode` for sibling cross-AI dispatch; `system-spec-kit` for handback; `sk-code` plus the selected overlay for generated code; `deep-loop-workflows` for loop execution (its `research` and `review` modes); and `mcp-code-mode` for MCP-backed tools.","lineStart":1,"lineEnd":459,"totalLines":459,"truncated":false}},"title":".opencode/skills/cli-opencode/SKILL.md","time":{"start":1783433250589,"end":1783433250592}},"metadata":{"openai":{"itemId":"fc_00e23ee13638bdd5016a4d082285708190bc6238fa300e6ff8"}},"id":"prt_f3ce7c718001EhaA8jTSsY8sKB","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","messageID":"msg_f3ce78108001vpvWPy5TsYcdSF"}}
{"type":"tool_use","timestamp":1783433250677,"sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","part":{"type":"tool","tool":"read","callID":"call_vfNvDlShq47Lb8HcGcFMWHUC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":636,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n636:                     # Blocked-stop closure: blockedBy must be string[] per the\n637:                     # published review blocked-stop contract. Extract the `.type`\n638:                     # field from each structured graph blocker; preserve the full\n639:                     # objects in graph_blocker_detail_json for operator inspection.\n640:                     blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n641:                     blocked_by_csv = graph_blockers_csv\n642:                     graph_blocker_detail_json = graph_blockers_json\n643:                     recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n644:                c) if STOP is legal AND graph_decision == \"CONTINUE\":\n645:                     decision = \"CONTINUE\"\n646:                     stop_blocked = false\n647:                     reason = \"graph_convergence_continue\"\n648:                d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n649:         outputs:\n650:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n651:           - reason: \"Human-readable stop reason\"\n652:           - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n653:           - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n654:           - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n655:           - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n656:           - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n657:           - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n658:           - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n659:           - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n660:           - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n661:           - active_p0_count: \"Active P0 finding count at stop-check time\"\n662:           - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n663:           - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n664:           - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n665:           - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n666:           - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n667:           - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n668:           - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n669:           - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n670:           - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n671:           - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n672:           - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n673:           - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n674:           - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n675:           - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n676:           - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n677:           - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n678:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n679:           - graph_signals_json: \"JSON object returned by graph convergence\"\n680:           - graph_blockers_json: \"JSON array of graph blockers\"\n681:           - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n682:           - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n683: \n684:       step_emit_blocked_stop:\n685:         action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n686:         if_blocked:\n687:           append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n688:           log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n689:         if_not_blocked:\n690:           proceed: true\n691: \n692:       step_handle_convergence:\n693:         action: \"Act on convergence decision\"\n694:         if_stop:\n695:           log: \"Loop stopping. Reason: {reason}\"\n696:           skip_to: phase_synthesis\n697:         if_blocked:\n698:           log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n699:         if_stuck_recovery:\n700:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n701:           recovery_strategies:\n702:             - \"Change granularity: file-level → function-level → line-level review\"\n703:             - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n704:             - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n705:           pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n706:           set:\n707:             next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n708:             pending_stop_event: \"stuck_recovery\"\n709:             pending_stop_reason: \"stuckRecovery\"\n710:             pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n711:           reset: { stuck_count: 0 }\n712:         if_continue:\n713:           log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n714: \n715:       step_normalize_pause_events:\n716:         action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n717:         if_pending_pause_event:\n718:           append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n719:           message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n720:           reset:\n721:             pending_stop_event: null\n722:             pending_stop_reason: null\n723:             pending_stop_detail: null\n724:           halt: true\n725:         if_pending_stuck_recovery:\n726:           append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n727:           reset:\n728:             pending_stop_event: null\n729:             pending_stop_reason: null\n730:             pending_stop_detail: null\n731:         if_no_pending_event:\n732:           proceed: true\n733: \n734:       step_generate_state_summary:\n735:         action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n736:         generate: |\n737:           STATE SUMMARY (auto-generated):\n738:           Iteration: {current_iteration} of {max_iterations}\n739:           Dimension: {next_dimension}\n740:           Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n741:           Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n742:           Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n743:           {resource_map_prompt_line}\n744:           Coverage Age: {coverage_age}\n745:           Last 2 ratios: {ratio_prev} -> {ratio_latest}\n746:           Stuck count: {stuck_count}\n747:           Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n748: \n749:       step_marker_scan:\n750:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n751:         algorithm: |\n752:           if current_iteration > 1:\n753:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n754:             if file_exists(PREV_PROMPT_PATH):\n755:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n756:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n757:                 log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n758:                 halt with exit code 2\n759:         note: |\n760:           False-positive prevention: only matches when the first line is exactly one of the\n761:           three canonical markers. Markers appearing in comments or body text are ignored.\n762:           True-positive triggers only when a previous iteration's rendered prompt literally\n763:           starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n764: \n765:       step_dispatch_iteration:\n766:         action: \"Dispatch @deep-review agent for one review iteration\"\n767:         resolve_executor:\n768:           source: \"config.executor\"\n769:           loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n770:         pre_dispatch:\n771:           generate_summary: |\n772:             STATE SUMMARY (auto-generated):\n773:             Iteration: {current_iteration} of {max_iterations}\n774:             Dimension: {next_dimension}\n775:             Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n776:             Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n777:             Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n778:             {resource_map_prompt_line}\n779:             Coverage Age: {coverage_age}\n780:             Last 2 ratios: {ratio_prev} -> {ratio_latest}\n781:             Stuck count: {stuck_count}\n782:             Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n783:           render_prompt_pack:\n784:             template_path: \".opencode/skills/deep-loop-workflows/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n785:             renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n786:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n787:             variables:\n788:               state_summary: \"{state_summary}\"\n789:               current_iteration: \"{current_iteration}\"\n790:               max_iterations: \"{max_iterations}\"\n791:               next_dimension: \"{next_dimension}\"\n792:               review_target: \"{review_target}\"\n793:               review_scope_files: \"{review_scope_files}\"\n794:               p0_count: \"{p0_count}\"\n795:               p1_count: \"{p1_count}\"\n796:               p2_count: \"{p2_count}\"\n797:               state_paths_config: \"{state_paths.config}\"\n798:               state_paths_state_log: \"{state_paths.state_log}\"\n799:               state_paths_findings_registry: \"{state_paths.findings_registry}\"\n800:               state_paths_strategy: \"{state_paths.strategy}\"\n801:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n802:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n803:         pre_dispatch_audit:\n804:           skip_when: \"config.executor.kind == 'native'\"\n805:           call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n806:           args:\n807:             stateLogPath: \"{state_paths.state_log}\"\n808:             executor: \"{config.executor}\"\n809:             iteration: \"{current_iteration}\"\n810:         branch_on: \"config.executor.kind\"\n811:         if_native:\n812:           dispatch:\n813:             agent: deep-review\n814:             model: opus\n815:             context_source: \"rendered_prompt_pack\"\n816:           wait_for_completion: true\n817:         if_cli_copilot:\n818:           command: |\n819:             node --experimental-strip-types --input-type=module <<'EOF'\n820:             import { readFileSync, writeFileSync } from 'node:fs';\n821:             import { createHash } from 'node:crypto';\n822: \n823:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n824:             import { buildCopilotPromptArg } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n825: \n826:             const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n827:             const prompt = readFileSync(promptPath, 'utf8');\n828: \n829:             // Workflow-resolved spec folder is the only legal write authority.\n830:             // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n831:             // is the single source of truth for rejecting empty / unresolved\n832:             // template / whitespace-only / string-coerced empty values. The\n833:             // YAML hands the raw `{spec_folder}` directly; on rejection the\n834:             // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n835:             // enforcement, --allow-all-tools stripped).\n836:             const specFolderRaw = '{spec_folder}';\n837:             const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n838: \n839:             const baseArgs = [\n840:               '-p',\n841:               prompt,\n842:               '--model',\n843:               '{config.executor.model}',\n844:               '--allow-all-tools',\n845:               '--no-ask-user',\n846:             ];\n847: \n848:             const built = buildCopilotPromptArg({\n849:               promptPath,\n850:               prompt,\n851:               targetAuthority,\n852:               baseArgv: baseArgs,\n853:             });\n854: \n855:             // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n856:             // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n857:             // Write it to disk so the file Copilot reads via @path opens with\n858:             // the authority block. Without this, recovered/bootstrap folder\n859:             // mentions inside the file could still anchor the model.\n860:             if (built.promptFileBody !== undefined) {\n861:               writeFileSync(promptPath, built.promptFileBody, 'utf8');\n862:             }\n863: \n864:             // Copilot is routed through the audited executor wrapper so it produces\n865:             // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n866:             // There is no cli-copilot kind in the executor schema, so it\n867:             // dispatches as kind:'native' (full env passthrough, no recursion-guard\n868:             // layer configured for copilot); the receipt still records the real\n869:             // 'copilot' command + built.argv as facts.\n870:             const dispatchFacts = {\n871:               command: 'deep/review',\n872:               mode: 'review',\n873:               specFolder: '{spec_folder}',\n874:               artifactDir: '{state_paths.packet_dir}',\n875:               iteration: Number('{current_iteration}'),\n876:               executorKind: '{config.executor.kind}',\n877:               branchId: '{config.executor.kind}',\n878:               sessionId: '{session_id}',\n879:               generation: Number('{generation}'),\n880:             };\n881:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n882:             process.exit(\n883:               runAuditedExecutorCommand({\n884:                 command: 'copilot',\n885:                 args: built.argv,\n886:                 cwd: '{repo_root}',\n887:                 timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n888:                 stateLogPath: '{state_paths.state_log}',\n889:                 executor: {\n890:                   kind: 'native',\n891:                   model: '{config.executor.model}',\n892:                   configDir: null,\n893:                   reasoningEffort: null,\n894:                   serviceTier: null,\n895:                   sandboxMode: null,\n896:                   timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n897:                   governor: null,\n898:                 },\n899:                 iteration: Number('{current_iteration}'),\n900:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n901:                 dispatchId,\n902:               }),\n903:             );\n904:             EOF\n905:           working_directory: \"{repo_root}\"\n906:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n907:           wait_for_completion: true\n908:           notes:\n909:             - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n910:             - \"copilot has no stdin support; prompt is positional\"\n911:             - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n912:             - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n913:             - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n914:             - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n915:             - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n916:         if_cli_claude_code:\n917:           command: |\n918:             node --experimental-strip-types --input-type=module <<'EOF'\n919:             import { readFileSync } from 'node:fs';\n920:             import { createHash } from 'node:crypto';\n921: \n922:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n923: \n924:             const configDir = '{optional_claude_config_dir}';\n925:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n926:             const executor = {\n927:               kind: 'cli-claude-code',\n928:               model: '{config.executor.model}',\n929:               configDir: configDir || null,\n930:               reasoningEffort,\n931:               serviceTier: null,\n932:               sandboxMode: null,\n933:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n934:               governor: null,\n935:             };\n936:             const args = [\n937:               '-p',\n938:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n939:               '--model',\n940:               executor.model,\n941:               '--permission-mode',\n942:               'acceptEdits',\n943:               '--output-format',\n944:               'text',\n945:             ];\n946:             if (executor.reasoningEffort) {\n947:               args.push('--effort', executor.reasoningEffort);\n948:             }\n949: \n950:             // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n951:             // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n952:             const parentEnv = { ...process.env };\n953:             if (configDir) {\n954:               parentEnv.CLAUDE_CONFIG_DIR = configDir;\n955:             }\n956: \n957:             const dispatchFacts = {\n958:               command: 'deep/review',\n959:               mode: 'review',\n960:               specFolder: '{spec_folder}',\n961:               artifactDir: '{state_paths.packet_dir}',\n962:               iteration: Number('{current_iteration}'),\n963:               executorKind: '{config.executor.kind}',\n964:               branchId: '{config.executor.kind}',\n965:               sessionId: '{session_id}',\n966:               generation: Number('{generation}'),\n967:             };\n968:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n969:             process.exit(\n970:               runAuditedExecutorCommand({\n971:                 command: 'claude',\n972:                 args,\n973:                 cwd: '{repo_root}',\n974:                 timeoutSeconds: executor.timeoutSeconds,\n975:                 stateLogPath: '{state_paths.state_log}',\n976:                 executor,\n977:                 iteration: Number('{current_iteration}'),\n978:                 guardContext: { env: parentEnv },\n979:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n980:                 dispatchId,\n981:               }),\n982:             );\n983:             EOF\n984:           working_directory: \"{repo_root}\"\n985:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n986:           wait_for_completion: true\n987:           render_hint:\n988:             optional_claude_config_dir: |\n989:               If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n990:               Otherwise expand to empty string.\n991:           notes:\n992:             - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n993:             - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n994:             - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n995:             - \"claude-code supports --effort for reasoning depth\"\n996:         if_cli_opencode:\n997:           command: |\n998:             node --experimental-strip-types --input-type=module <<'EOF'\n999:             import { readFileSync } from 'node:fs';\n1000:             import { createHash } from 'node:crypto';\n1001: \n1002:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n1003: \n1004:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1005:             const executor = {\n1006:               kind: 'cli-opencode',\n1007:               model: '{config.executor.model}',\n1008:               configDir: null,\n1009:               reasoningEffort,\n1010:               serviceTier: null,\n1011:               sandboxMode: null,\n1012:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1013:               governor: null,\n1014:             };\n1015:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1016:             const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n1017:               + '\\n\\n'\n1018:               + promptBody;\n1019:             const args = [\n1020:               'run',\n1021:               '--model',\n1022:               executor.model,\n1023:               '--format',\n1024:               'json',\n1025:               '--dangerously-skip-permissions',\n1026:               '--pure',\n1027:               '--dir',\n1028:               '{repo_root}',\n1029:             ];\n1030:             if (executor.reasoningEffort) {\n1031:               args.push('--variant', executor.reasoningEffort);\n1032:             }\n1033:             args.push(message);\n1034: \n1035:             const dispatchFacts = {\n1036:               command: 'deep/review',\n1037:               mode: 'review',\n1038:               specFolder: '{spec_folder}',\n1039:               artifactDir: '{state_paths.packet_dir}',\n1040:               iteration: Number('{current_iteration}'),\n1041:               executorKind: '{config.executor.kind}',\n1042:               branchId: '{config.executor.kind}',\n1043:               sessionId: '{session_id}',\n1044:               generation: Number('{generation}'),\n1045:             };\n1046:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1047:             process.exit(\n1048:               runAuditedExecutorCommand({\n1049:                 command: 'opencode',\n1050:                 args,\n1051:                 cwd: '{repo_root}',\n1052:                 timeoutSeconds: executor.timeoutSeconds,\n1053:                 stateLogPath: '{state_paths.state_log}',\n1054:                 executor,\n1055:                 iteration: Number('{current_iteration}'),\n1056:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1057:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1058:                 input: '',\n1059:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1060:                 dispatchId,\n1061:               }),\n1062:             );\n1063:             EOF\n1064:           working_directory: \"{repo_root}\"\n1065:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1066:           wait_for_completion: true\n1067:           notes:\n1068:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1069:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (cli-opencode SKILL.md §4 ALWAYS rule)\"\n1070:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1071:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1072:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1073:             - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1074:         post_dispatch_validate:\n1075:           validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1076:           command: \"node .opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1077:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1078:           assert_exists: \"{state_paths.iteration_pattern}\"\n1079:           assert_appended: \"{state_paths.state_log}\"\n1080:           assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n1081:           route_proof:\n1082:             mode: review\n1083:             target_agent: deep-review\n1084:             agent_definition_loaded: true\n1085:             resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n1086:           dispatchReceipt:\n1087:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1088:             dispatchId: \"review-i{current_iteration}-g{generation}\"\n1089:           assert_canonical_type: \"iteration\"\n1090:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1091:           assert_delta_file_has_iteration_record: true\n1092:           failure_reasons:\n1093:             - iteration_file_missing\n1094:             - iteration_file_empty\n1095:             - jsonl_not_appended\n1096:             - jsonl_missing_fields\n1097:             - jsonl_parse_error\n1098:             - jsonl_wrong_type\n1099:             - delta_file_missing\n1100:             - delta_file_empty\n1101:             - delta_file_missing_iteration_record\n1102:             - executor_missing\n1103:             - dispatch_failure_logged\n1104:             - v2_missing_ledger\n1105:             - v2_uncited_ledger_row\n1106:             - v2_broken_linked_finding\n1107:             - v2_shallow_finding_details\n1108:             - delta_iteration_id_mismatch\n1109:             - state_delta_iteration_mismatch\n1110:             - route_proof_missing\n1111:             - route_proof_mismatch\n1112:           warning_surface:\n1113:             source: \"result.warnings\"\n1114:             action: \"emit schema_advisory canonical conflict event\"\n1115:             severity: \"advisory\"\n1116:             event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1117:             note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n1118:           on_failure:\n1119:             action: \"emit schema_mismatch canonical conflict event\"\n1120:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n1121:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1122:         record_executor_audit:\n1123:           skip_when: \"config.executor.kind == 'native'\"\n1124:           target: \"{state_paths.state_log}\"\n1125:           field: \"executor\"\n1126:           value:\n1127:             kind: \"{config.executor.kind}\"\n1128:             model: \"{config.executor.model}\"\n1129:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1130:             serviceTier: \"{config.executor.serviceTier}\"\n1131: \n1132:       step_evaluate_results:\n1133:         action: \"Verify iteration outputs and extract metrics\"\n1134:         verify:\n1135:           - file_exists: \"{state_paths.iteration_pattern}\"\n1136:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1137:           - strategy_updated: \"Strategy.md has been modified\"\n1138:         extract:\n1139:           - newFindingsRatio: \"From latest JSONL iteration record\"\n1140:           - findings_count: \"From latest JSONL iteration record\"\n1141:           - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n1142:           - dimensions: \"From latest JSONL iteration record\"\n1143:           - files_reviewed: \"From latest JSONL iteration record\"\n1144:           - status: \"From latest JSONL iteration record\"\n1145:           - reviewed_artifacts: \"From latest JSONL iteration record\"\n1146:           - traceability_checks: \"From latest JSONL iteration record when present\"\n1147:         on_missing_outputs:\n1148:           action: \"Mark iteration as 'error', continue to next\"\n1149:           # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n1150:           # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1151:           append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n1152: \n1153:       step_post_iteration_claim_adjudication:\n1154:         action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n1155:         verify:\n1156:           - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n1157:           - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n1158:           - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n1159:         on_pass:\n1160:           set:\n1161:             claim_adjudication_passed: true\n1162:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1163:           log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n1164:         on_fail:\n1165:           action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n1166:           set:\n1167:             claim_adjudication_passed: false\n1168:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1169:           log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n1170: \n1171:       step_reduce_review_state:\n1172:         action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n1173:         command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder}\"\n1174:         read:\n1175:           - \"{state_paths.state_log}\"\n1176:           - \"{state_paths.iteration_pattern}\"\n1177:           - \"{state_paths.findings_registry}\"\n1178:           - \"{state_paths.strategy}\"\n1179:         write:\n1180:           - \"{state_paths.findings_registry}\"\n1181:           - \"{state_paths.dashboard}\"\n1182:           - \"{state_paths.strategy}\"\n1183:         failure_modes:\n1184:           malformed_delta: \"skip + warn\"\n1185:           missing_iteration_file: \"no-op + error\"\n1186:           schema_mismatch: \"reject + conflict event\"\n1187:         guarantee: \"Idempotent for identical inputs\"\n1188:         note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n1189: \n1190:       step_graph_upsert:\n1191:         action: \"Transform the latest iteration graphEvents delta into review graph nodes and edges, then upsert it\"\n1192:         read:\n1193:           - \"{state_paths.state_log}\"\n1194:           - \"{state_paths.findings_registry}\"\n1195:         transform: |\n1196:           1. Read the latest iteration JSONL record after reducer completion.\n1197:           2. If graphEvents is absent or empty, set graph_nodes_json = [] and graph_edges_json = [] and skip the upsert.\n1198:           3. For each graph event without relation/source/target, normalize type = uppercase(event.type || event.nodeKind || event.type) and keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n1199:           4. Emit nodes as { id, type, name, iteration, metadata } using the event label (or id fallback) and review metadata for run/current focus.\n1200:           5. For each graph event with relation + source + target, normalize relation = uppercase(event.relation) and keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n1201:           6. Emit edges as { id, relation, sourceId, targetId, metadata } and deduplicate the batch by id.\n1202:           7. Discard malformed or unknown graph events instead of failing the review iteration.\n1203:         bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n1204:         note: \"Invoke the runtime script directly. Upsert only the latest iteration graph delta.\"\n1205:         outputs:\n1206:           - graph_nodes_json: \"JSON array of normalized review graph nodes for the latest iteration\"\n1207:           - graph_edges_json: \"JSON array of normalized review graph edges for the latest iteration\"\n1208:         skip_conditions:\n1209:           - \"Latest iteration record has no graphEvents array\"\n1210: \n1211:       step_generate_dashboard:\n1212:         action: \"Generate or refresh the review dashboard\"\n1213:         read:\n1214:           - \"{state_paths.state_log}\"\n1215:           - \"{state_paths.findings_registry}\"\n1216:           - \"{state_paths.strategy}\"\n1217:         content: |\n1218:           # Deep Review Dashboard - Session Overview\n1219: \n1220:           Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n1221: \n1222:           ## Status\n1223:           - Review Target: {review_target} ({review_target_type})\n1224:           - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n1225:           - Iteration: {current_iteration} of {max_iterations}\n1226:           - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n1227:           - hasAdvisories: {has_advisories}\n1228: \n1229:           ## Findings Summary\n1230:           | Severity | Count | Trend |\n1231:           |----------|------:|-------|\n1232:           | P0 (Blockers) | {p0_count} | {p0_trend} |\n1233:           | P1 (Required) | {p1_count} | {p1_trend} |\n1234:           | P2 (Suggestions) | {p2_count} | {p2_trend} |\n1235: \n1236:           ## Dimension Coverage\n1237:           | Dimension | Status | Iteration | Findings |\n1238:           |-----------|--------|-----------|----------|\n1239:           | [per dimension from strategy + JSONL] |\n1240: \n1241:           ## Traceability Coverage\n1242:           | Protocol | Level | Status | Findings |\n1243:           |----------|-------|--------|----------|\n1244:           | [per protocol from traceabilityChecks] |\n1245: \n1246:           ## Progress\n1247:           | # | Dimension | Ratio | P0/P1/P2 | Status |\n1248:           |---|-----------|-------|----------|--------|\n1249:           | [per iteration from JSONL] |\n1250: \n1251:           ## Trend\n1252:           - Last 3 ratios: [{ratios}] [{trend}]\n1253:           - Stuck count: {stuck_count}\n1254:           - Gate violations: {guard_violations}\n1255: \n1256:           ## Next Focus\n1257:           {next_dimension}\n1258:         output: \"{state_paths.dashboard}\"\n1259:         note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n1260: \n1261:       step_update_tracking:\n1262:         action: \"Update loop tracking variables\"\n1263:         set:\n1264:           current_iteration: \"{current_iteration + 1}\"\n1265:           p0_count: \"Accumulate from severity_counts\"\n1266:           p1_count: \"Accumulate from severity_counts\"\n1267:           p2_count: \"Accumulate from severity_counts\"\n1268:           stuck_count: |\n1269:             if status == 'thought': unchanged (skip)\n1270:             if status == 'insight': 0 (reset)\n1271:             if newFindingsRatio <= 0.05: stuck_count + 1\n1272:             else: 0\n1273:         log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n1274: \n1275:       step_loop_decision:\n1276:         action: \"Return to step_read_state for next iteration\"\n1277:         goto: step_read_state\n1278: \n1279:   # ═══════════════════════════════════════════════════════════════\n1280:   # PHASE 3: SYNTHESIS\n1281:   # ═══════════════════════════════════════════════════════════════\n1282:   phase_synthesis:\n1283:     purpose: Compile all iteration findings into review/review-report.md\n1284:     steps:\n1285: \n1286:       step_fanout_merge:\n1287:         description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n1288:         skip_when: \"config.fanout is absent\"\n1289:         command: |\n1290:           node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n1291:             --loop-type review \\\n1292:             --artifact-dir {artifact_dir}\n1293:         working_directory: \"{repo_root}\"\n1294:         wait_for_completion: true\n1295:         bind_from_output:\n1296:           p0_count: \"active_p0\"\n1297:           p1_count: \"active_p1\"\n1298:           p2_count: \"active_p2\"\n1299: \n1300:       step_hydrate_summary_metrics:\n1301:         action: \"Hydrate summary metrics before synthesis\"\n1302:         read:\n1303:           - \"{state_paths.config}\"\n1304:           - \"{state_paths.state_log}\"\n1305:           - \"{state_paths.findings_registry}\"\n1306:           - \"{state_paths.strategy}\"\n1307:         extract:\n1308:           - iteration_count: \"Count lines where type === 'iteration'\"\n1309:           - p0_count: \"Total P0 findings across all iterations (deduped)\"\n1310:           - p1_count: \"Total P1 findings across all iterations (deduped)\"\n1311:           - p2_count: \"Total P2 findings across all iterations (deduped)\"\n1312:           - dimensions_covered: \"List of reviewed dimensions\"\n1313:           - dimension_coverage: \"covered / total\"\n1314:           - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n1315:           - last_3_summaries: \"Summarize the latest 3 iteration records\"\n1316:           - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1317: \n1318:       # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n1319:       # - PASS: no P0 or P1 findings (P2-only or clean)\n1320:       # - CONDITIONAL: any P1 findings (no P0)\n1321:       # - FAIL: any P0 findings\n1322:       # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n1323:       step_derive_verdict:\n1324:         action: \"Derive review verdict from accumulated findings\"\n1325:         algorithm: |\n1326:           if p0_count > 0:\n1327:             verdict = \"FAIL\"\n1328:           elif p1_count > 0:\n1329:             verdict = \"CONDITIONAL\"\n1330:           else:\n1331:             verdict = \"PASS\"\n1332:           has_advisories = (verdict == \"PASS\" and p2_count > 0)\n1333:           ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n1334:         outputs:\n1335:           - verdict: \"PASS | CONDITIONAL | FAIL\"\n1336:           - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n1337:           - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n1338:         contract: |\n1339:           Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n1340:           Downstream automation parses this final line via exact string match — do not vary the format.\n1341: \n1342:       step_read_all_iterations:\n1343:         action: \"Read all iteration files and strategy\"\n1344:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1345:         read_also: \"{state_paths.strategy}\"\n1346: \n1347:       step_build_finding_registry:\n1348:         action: \"Build deduplicated finding registry from all iterations\"\n1349:         algorithm: |\n1350:           1. Extract all findings from iteration JSONL delta files\n1351:           2. Compute content_hash for each finding (emission requirement):\n1352:              content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n1353:              Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n1354:           3. Two-tier dedup:\n1355:              PRIMARY: group by content_hash field\n1356:                - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n1357:                - Keep highest severity on duplicates\n1358:              FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n1359:                - Same file:line, multiple dimensions → single finding, multiple dimension tags\n1360:                - Keep highest severity on duplicates\n1361:           4. Track finding lifecycle:\n1362:              - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n1363:              - Record first_seen, upgraded_in, previous_severity for severity changes\n1364:              - Record dimensions array reflecting all dimensions that emitted this finding\n1365:           5. Resolve contradictions:\n1366:              - Findings marked contested across iterations → referee pass\n1367:              - Determine final severity and status\n1368:           6. Count only 'active' findings for totals\n1369:         outputs:\n1370:           - finding_registry: \"Deduplicated list of all findings with metadata\"\n1371:           - active_p0: \"Count of active P0 findings\"\n1372:           - active_p1: \"Count of active P1 findings\"\n1373:           - active_p2: \"Count of active P2 findings\"\n1374: \n1375:       step_adversarial_selfcheck:\n1376:         action: \"Final adversarial self-check on all P0 and P1 findings\"\n1377:         algorithm: |\n1378:           For each active P0/P1 finding:\n1379:             1. Hunter: Re-verify finding against source code (re-read file:line)\n1380:             2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n1381:             3. Referee: Final call — confirm, downgrade, or mark false_positive\n1382:           Update finding_registry with adjudicated results.\n1383: \n1384:       step_emit_resource_map:\n1385:         action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n1386:         command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1387:         read:\n1388:           - \"{state_paths.config}\"\n1389:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1390:         write:\n1391:           - \"{state_paths.resource_map_output}\"\n1392:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1393: \n1394:       step_resource_map_coverage_gate:\n1395:         action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n1396:         note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n1397: \n1398:       step_compile_review_report:\n1399:         action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n1400:         instructions: |\n1401:           Create review/review-report.md with the following sections:\n1402: \n1403:           1. **Executive Summary**\n1404:              - Overall verdict: PASS | CONDITIONAL | FAIL\n1405:              - hasAdvisories: true when PASS carries active P2 items\n1406:              - P0/P1/P2 counts (active only)\n1407:              - Review scope summary\n1408: \n1409:           2. **Planning Trigger**\n1410:              - State whether `/speckit:plan` is required\n1411:              - Include a fenced `json` block labeled `Planning Packet`\n1412:              - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n1413:              - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n1414: \n1415:           3. **Active Finding Registry**\n1416:              - Unified registry for active P0/P1/P2 findings\n1417:              - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n1418: \n1419:           4. **Remediation Workstreams**\n1420:              - Ordered action groups: P0 first, then P1, with P2 advisories separated\n1421: \n1422:           5. **Spec Seed**\n1423:              - Concrete seed bullets for follow-on spec updates\n1424: \n1425:           6. **Plan Seed**\n1426:              - Concrete starter tasks for `/speckit:plan`\n1427: \n1428:            7. **Traceability Status**\n1429:               - Summarize required core protocols first, then applicable overlay protocols\n1430:               - Include status, evidence, and any unresolved drift per protocol\n1431:               - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n1432: \n1433:           If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n1434:              - `Entries touched`: count of resource-map paths that appear in applied reports\n1435:              - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n1436:              - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n1437: \n1438:           8. **Deferred Items**\n1439:              - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n1440: \n1441:           9. **Search Ledger**\n1442:              - Always include this section before the appendix.\n1443:              - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n1444:              - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n1445:              - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n1446: \n1447:           10. **Audit Appendix**\n1448:              - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n1449:              - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n1450: \n1451:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n1452:         output: \"{state_paths.review_output}\"\n1453: \n1454:       step_convergence_report:\n1455:         action: \"Append convergence report to JSONL\"\n1456:         command: |\n\n(Output capped at 50 KB. Showing lines 636-1456. Use offset=1457 to continue.)\n</content>","metadata":{"preview":"                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n                    blocked_by_csv = graph_blockers_csv\n                    graph_blocker_detail_json = graph_blockers_json\n                    recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n               c) if STOP is legal AND graph_decision == \"CONTINUE\":\n                    decision = \"CONTINUE\"\n                    stop_blocked = false\n                    reason = \"graph_convergence_continue\"\n               d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n          - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n          - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n                    blocked_by_csv = graph_blockers_csv\n                    graph_blocker_detail_json = graph_blockers_json\n                    recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n               c) if STOP is legal AND graph_decision == \"CONTINUE\":\n                    decision = \"CONTINUE\"\n                    stop_blocked = false\n                    reason = \"graph_convergence_continue\"\n               d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n          - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n          - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n          - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n          - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n          - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n          - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n          - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n          - active_p0_count: \"Active P0 finding count at stop-check time\"\n          - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n          - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n          - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n          - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n          - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n          - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n          - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:\n        action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n        if_blocked:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          log: \"Loop stopping. Reason: {reason}\"\n          skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:\n            next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n            pending_stop_event: \"stuck_recovery\"\n            pending_stop_reason: \"stuckRecovery\"\n            pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n\n      step_normalize_pause_events:\n        action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n        if_pending_pause_event:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n          halt: true\n        if_pending_stuck_recovery:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n        if_no_pending_event:\n          proceed: true\n\n      step_generate_state_summary:\n        action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n        generate: |\n          STATE SUMMARY (auto-generated):\n          Iteration: {current_iteration} of {max_iterations}\n          Dimension: {next_dimension}\n          Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n          Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n          Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n          {resource_map_prompt_line}\n          Coverage Age: {coverage_age}\n          Last 2 ratios: {ratio_prev} -> {ratio_latest}\n          Stuck count: {stuck_count}\n          Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch @deep-review agent for one review iteration\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Iteration: {current_iteration} of {max_iterations}\n            Dimension: {next_dimension}\n            Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n            Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n            Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n            {resource_map_prompt_line}\n            Coverage Age: {coverage_age}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest}\n            Stuck count: {stuck_count}\n            Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n          render_prompt_pack:\n            template_path: \".opencode/skills/deep-loop-workflows/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_dimension: \"{next_dimension}\"\n              review_target: \"{review_target}\"\n              review_scope_files: \"{review_scope_files}\"\n              p0_count: \"{p0_count}\"\n              p1_count: \"{p1_count}\"\n              p2_count: \"{p2_count}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_findings_registry: \"{state_paths.findings_registry}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.kind\"\n        if_native:\n          dispatch:\n            agent: deep-review\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_copilot:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync, writeFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n            import { buildCopilotPromptArg } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n            const prompt = readFileSync(promptPath, 'utf8');\n\n            // Workflow-resolved spec folder is the only legal write authority.\n            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n            // is the single source of truth for rejecting empty / unresolved\n            // template / whitespace-only / string-coerced empty values. The\n            // YAML hands the raw `{spec_folder}` directly; on rejection the\n            // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n            // enforcement, --allow-all-tools stripped).\n            const specFolderRaw = '{spec_folder}';\n            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n\n            const baseArgs = [\n              '-p',\n              prompt,\n              '--model',\n              '{config.executor.model}',\n              '--allow-all-tools',\n              '--no-ask-user',\n            ];\n\n            const built = buildCopilotPromptArg({\n              promptPath,\n              prompt,\n              targetAuthority,\n              baseArgv: baseArgs,\n            });\n\n            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n            // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n            // Write it to disk so the file Copilot reads via @path opens with\n            // the authority block. Without this, recovered/bootstrap folder\n            // mentions inside the file could still anchor the model.\n            if (built.promptFileBody !== undefined) {\n              writeFileSync(promptPath, built.promptFileBody, 'utf8');\n            }\n\n            // Copilot is routed through the audited executor wrapper so it produces\n            // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n            // There is no cli-copilot kind in the executor schema, so it\n            // dispatches as kind:'native' (full env passthrough, no recursion-guard\n            // layer configured for copilot); the receipt still records the real\n            // 'copilot' command + built.argv as facts.\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'copilot',\n                args: built.argv,\n                cwd: '{repo_root}',\n                timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                stateLogPath: '{state_paths.state_log}',\n                executor: {\n                  kind: 'native',\n                  model: '{config.executor.model}',\n                  configDir: null,\n                  reasoningEffort: null,\n                  serviceTier: null,\n                  sandboxMode: null,\n                  timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                  governor: null,\n                },\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n            - \"copilot has no stdin support; prompt is positional\"\n            - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n            - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n            - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n            - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n            - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n\n            const configDir = '{optional_claude_config_dir}';\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              configDir: configDir || null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              'acceptEdits',\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n            // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n            const parentEnv = { ...process.env };\n            if (configDir) {\n              parentEnv.CLAUDE_CONFIG_DIR = configDir;\n            }\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                guardContext: { env: parentEnv },\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_claude_config_dir: |\n              If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n              Otherwise expand to empty string.\n          notes:\n            - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n            - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (cli-opencode SKILL.md §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          route_proof:\n            mode: review\n            target_agent: deep-review\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"review-i{current_iteration}-g{generation}\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:\n            - iteration_file_missing\n            - iteration_file_empty\n            - jsonl_not_appended\n            - jsonl_missing_fields\n            - jsonl_parse_error\n            - jsonl_wrong_type\n            - delta_file_missing\n            - delta_file_empty\n            - delta_file_missing_iteration_record\n            - executor_missing\n            - dispatch_failure_logged\n            - v2_missing_ledger\n            - v2_uncited_ledger_row\n            - v2_broken_linked_finding\n            - v2_shallow_finding_details\n            - delta_iteration_id_mismatch\n            - state_delta_iteration_mismatch\n            - route_proof_missing\n            - route_proof_mismatch\n          warning_surface:\n            source: \"result.warnings\"\n            action: \"emit schema_advisory canonical conflict event\"\n            severity: \"advisory\"\n            event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n        record_executor_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.kind}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Strategy.md has been modified\"\n        extract:\n          - newFindingsRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n          - dimensions: \"From latest JSONL iteration record\"\n          - files_reviewed: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - reviewed_artifacts: \"From latest JSONL iteration record\"\n          - traceability_checks: \"From latest JSONL iteration record when present\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n          # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n\n      step_post_iteration_claim_adjudication:\n        action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n        verify:\n          - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n          - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n          - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n        on_pass:\n          set:\n            claim_adjudication_passed: true\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n        on_fail:\n          action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n          set:\n            claim_adjudication_passed: false\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n\n      step_reduce_review_state:\n        action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder}\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.iteration_pattern}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        write:\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n        guarantee: \"Idempotent for identical inputs\"\n        note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n\n      step_graph_upsert:\n        action: \"Transform the latest iteration graphEvents delta into review graph nodes and edges, then upsert it\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Read the latest iteration JSONL record after reducer completion.\n          2. If graphEvents is absent or empty, set graph_nodes_json = [] and graph_edges_json = [] and skip the upsert.\n          3. For each graph event without relation/source/target, normalize type = uppercase(event.type || event.nodeKind || event.type) and keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n          4. Emit nodes as { id, type, name, iteration, metadata } using the event label (or id fallback) and review metadata for run/current focus.\n          5. For each graph event with relation + source + target, normalize relation = uppercase(event.relation) and keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n          6. Emit edges as { id, relation, sourceId, targetId, metadata } and deduplicate the batch by id.\n          7. Discard malformed or unknown graph events instead of failing the review iteration.\n        bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n        note: \"Invoke the runtime script directly. Upsert only the latest iteration graph delta.\"\n        outputs:\n          - graph_nodes_json: \"JSON array of normalized review graph nodes for the latest iteration\"\n          - graph_edges_json: \"JSON array of normalized review graph edges for the latest iteration\"\n        skip_conditions:\n          - \"Latest iteration record has no graphEvents array\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the review dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        content: |\n          # Deep Review Dashboard - Session Overview\n\n          Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n\n          ## Status\n          - Review Target: {review_target} ({review_target_type})\n          - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n          - Iteration: {current_iteration} of {max_iterations}\n          - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n          - hasAdvisories: {has_advisories}\n\n          ## Findings Summary\n          | Severity | Count | Trend |\n          |----------|------:|-------|\n          | P0 (Blockers) | {p0_count} | {p0_trend} |\n          | P1 (Required) | {p1_count} | {p1_trend} |\n          | P2 (Suggestions) | {p2_count} | {p2_trend} |\n\n          ## Dimension Coverage\n          | Dimension | Status | Iteration | Findings |\n          |-----------|--------|-----------|----------|\n          | [per dimension from strategy + JSONL] |\n\n          ## Traceability Coverage\n          | Protocol | Level | Status | Findings |\n          |----------|-------|--------|----------|\n          | [per protocol from traceabilityChecks] |\n\n          ## Progress\n          | # | Dimension | Ratio | P0/P1/P2 | Status |\n          |---|-----------|-------|----------|--------|\n          | [per iteration from JSONL] |\n\n          ## Trend\n          - Last 3 ratios: [{ratios}] [{trend}]\n          - Stuck count: {stuck_count}\n          - Gate violations: {guard_violations}\n\n          ## Next Focus\n          {next_dimension}\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          p0_count: \"Accumulate from severity_counts\"\n          p1_count: \"Accumulate from severity_counts\"\n          p2_count: \"Accumulate from severity_counts\"\n          stuck_count: |\n            if status == 'thought': unchanged (skip)\n            if status == 'insight': 0 (reset)\n            if newFindingsRatio <= 0.05: stuck_count + 1\n            else: 0\n        log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into review/review-report.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n            --loop-type review \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n        bind_from_output:\n          p0_count: \"active_p0\"\n          p1_count: \"active_p1\"\n          p2_count: \"active_p2\"\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - p0_count: \"Total P0 findings across all iterations (deduped)\"\n          - p1_count: \"Total P1 findings across all iterations (deduped)\"\n          - p2_count: \"Total P2 findings across all iterations (deduped)\"\n          - dimensions_covered: \"List of reviewed dimensions\"\n          - dimension_coverage: \"covered / total\"\n          - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records\"\n          - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n      # - PASS: no P0 or P1 findings (P2-only or clean)\n      # - CONDITIONAL: any P1 findings (no P0)\n      # - FAIL: any P0 findings\n      # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n      step_derive_verdict:\n        action: \"Derive review verdict from accumulated findings\"\n        algorithm: |\n          if p0_count > 0:\n            verdict = \"FAIL\"\n          elif p1_count > 0:\n            verdict = \"CONDITIONAL\"\n          else:\n            verdict = \"PASS\"\n          has_advisories = (verdict == \"PASS\" and p2_count > 0)\n          ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n        outputs:\n          - verdict: \"PASS | CONDITIONAL | FAIL\"\n          - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n          - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n        contract: |\n          Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n          Downstream automation parses this final line via exact string match — do not vary the format.\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_build_finding_registry:\n        action: \"Build deduplicated finding registry from all iterations\"\n        algorithm: |\n          1. Extract all findings from iteration JSONL delta files\n          2. Compute content_hash for each finding (emission requirement):\n             content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n             Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n          3. Two-tier dedup:\n             PRIMARY: group by content_hash field\n               - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n               - Keep highest severity on duplicates\n             FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n               - Same file:line, multiple dimensions → single finding, multiple dimension tags\n               - Keep highest severity on duplicates\n          4. Track finding lifecycle:\n             - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n             - Record first_seen, upgraded_in, previous_severity for severity changes\n             - Record dimensions array reflecting all dimensions that emitted this finding\n          5. Resolve contradictions:\n             - Findings marked contested across iterations → referee pass\n             - Determine final severity and status\n          6. Count only 'active' findings for totals\n        outputs:\n          - finding_registry: \"Deduplicated list of all findings with metadata\"\n          - active_p0: \"Count of active P0 findings\"\n          - active_p1: \"Count of active P1 findings\"\n          - active_p2: \"Count of active P2 findings\"\n\n      step_adversarial_selfcheck:\n        action: \"Final adversarial self-check on all P0 and P1 findings\"\n        algorithm: |\n          For each active P0/P1 finding:\n            1. Hunter: Re-verify finding against source code (re-read file:line)\n            2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n            3. Referee: Final call — confirm, downgrade, or mark false_positive\n          Update finding_registry with adjudicated results.\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_resource_map_coverage_gate:\n        action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n        note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n\n      step_compile_review_report:\n        action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n        instructions: |\n          Create review/review-report.md with the following sections:\n\n          1. **Executive Summary**\n             - Overall verdict: PASS | CONDITIONAL | FAIL\n             - hasAdvisories: true when PASS carries active P2 items\n             - P0/P1/P2 counts (active only)\n             - Review scope summary\n\n          2. **Planning Trigger**\n             - State whether `/speckit:plan` is required\n             - Include a fenced `json` block labeled `Planning Packet`\n             - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n             - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n\n          3. **Active Finding Registry**\n             - Unified registry for active P0/P1/P2 findings\n             - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n\n          4. **Remediation Workstreams**\n             - Ordered action groups: P0 first, then P1, with P2 advisories separated\n\n          5. **Spec Seed**\n             - Concrete seed bullets for follow-on spec updates\n\n          6. **Plan Seed**\n             - Concrete starter tasks for `/speckit:plan`\n\n           7. **Traceability Status**\n              - Summarize required core protocols first, then applicable overlay protocols\n              - Include status, evidence, and any unresolved drift per protocol\n              - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n\n          If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n             - `Entries touched`: count of resource-map paths that appear in applied reports\n             - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n             - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n\n          8. **Deferred Items**\n             - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n\n          9. **Search Ledger**\n             - Always include this section before the appendix.\n             - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n             - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n             - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n\n          10. **Audit Appendix**\n             - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n             - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n        output: \"{state_paths.review_output}\"\n\n      step_convergence_report:\n        action: \"Append convergence report to JSONL\"\n        command: |","lineStart":636,"lineEnd":1456,"totalLines":1457,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1783433250667,"end":1783433250674}},"metadata":{"openai":{"itemId":"fc_00e23ee13638bdd5016a4d0822857c81909beb38aee8f960d6"}},"id":"prt_f3ce7c74c001IJFJlmmFnDqRze","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","messageID":"msg_f3ce78108001vpvWPy5TsYcdSF"}}
{"type":"tool_use","timestamp":1783433250726,"sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","part":{"type":"tool","tool":"read","callID":"call_QnjdHHFiKYnuddaSaX5TC7Bo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml</path>\n<type>file</type>\n<content>\n1: # Canonical review-mode contract for deep-review.\n2: # This file is the single source of truth for review-mode taxonomy,\n3: # convergence settings, cross-reference protocols, downstream render targets,\n4: # and validation expectations.\n5: \n6: meta:\n7:   ownerSkill: deep-review\n8:   reviewModeVersion: 2\n9:   generatedNotice:\n10:     warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n11:     beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n12:     endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n13:   sourceOfTruth: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml\n14: \n15: # Core contract definitions consumed by workflows, agents, docs, and validators.\n16: contract:\n17:   defaultTargetType: spec-folder\n18: \n19:   contextSnapshot:\n20:     requiredAtInit: true\n21:     ownerArtifact: deep-review-strategy.md\n22:     section: Known Context\n23:     source: bounded-review-context-snapshot\n24:     bounded: true\n25:     pointerBased: true\n26:     includes:\n27:       - targetPointers\n28:       - behaviorClaims\n29:       - reuseAndConventionPointers\n30:       - riskAreasAndContextGaps\n31:     forbids:\n32:       - deepContextDispatch\n33:       - fullSourceBodyInlining\n34:       - contextLoopReportCreation\n35:       - scopeWideningBeyondReviewTarget\n36: \n37:   # Review target taxonomy.\n38:   targetTypes:\n39:     - id: spec-folder\n40:       cliValue: spec-folder\n41:       label: Spec Folder\n42:       description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n43:     - id: skill\n44:       cliValue: skill\n45:       label: Skill\n46:       description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n47:     - id: agent\n48:       cliValue: agent\n49:       label: Agent\n50:       description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n51:     - id: track\n52:       cliValue: track\n53:       label: Track\n54:       description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n55:     - id: files\n56:       cliValue: files\n57:       label: Files\n58:       description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n59: \n60:   # Simplified review dimensions. Traceability and maintainability absorb the\n61:   # prior seven-dimension model's overlap.\n62:   dimensions:\n63:     - id: correctness\n64:       priority: 1\n65:       label: Correctness\n66:       checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n67:       requiredForSeverityCoverage: true\n68:     - id: security\n69:       priority: 2\n70:       label: Security\n71:       checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n72:       requiredForSeverityCoverage: true\n73:     - id: traceability\n74:       priority: 3\n75:       label: Traceability\n76:       checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n77:       requiredForSeverityCoverage: false\n78:     - id: maintainability\n79:       priority: 4\n80:       label: Maintainability\n81:       checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n82:       requiredForSeverityCoverage: false\n83: \n84:   # Severity contract stays stable across review outputs.\n85:   severities:\n86:     - id: P0\n87:       weight: 10.0\n88:       label: Blocker\n89:       requiresFileLineEvidence: true\n90:     - id: P1\n91:       weight: 5.0\n92:       label: Required\n93:       requiresFileLineEvidence: true\n94:     - id: P2\n95:       weight: 1.0\n96:       label: Suggestion\n97:       requiresFileLineEvidence: true\n98: \n99:   # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n100:   verdicts:\n101:     - id: FAIL\n102:       label: Fail\n103:       condition: \"activeP0 > 0 OR any required quality gate fails\"\n104:       nextCommand: /speckit:plan\n105:     - id: CONDITIONAL\n106:       label: Conditional\n107:       condition: \"activeP0 == 0 AND activeP1 > 0\"\n108:       nextCommand: /speckit:plan\n109:     - id: PASS\n110:       label: Pass\n111:       condition: \"activeP0 == 0 AND activeP1 == 0\"\n112:       hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n113:       nextCommand: /create:changelog\n114: \n115:   # Binary gates applied after convergence math votes STOP.\n116:   qualityGates:\n117:     - id: evidence\n118:       label: Evidence\n119:       binary: true\n120:       combines:\n121:         - evidence-completeness\n122:         - no-inference-only\n123:       rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n124:     - id: scope\n125:       label: Scope\n126:       binary: true\n127:       combines:\n128:         - scope-alignment\n129:       rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n130:     - id: coverage\n131:       label: Coverage\n132:       binary: true\n133:       combines:\n134:         - severity-coverage\n135:         - cross-reference\n136:       rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n137: \n138:   # Review-specific convergence settings calibrated from the v2 research.\n139:   convergence:\n140:     defaults:\n141:       maxIterations: 7\n142:       convergenceThreshold: 0.10\n143:       stuckThreshold: 2\n144:     signals:\n145:       - id: rolling-average\n146:         weight: 0.30\n147:         description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n148:       - id: mad-noise-floor\n149:         weight: 0.25\n150:         description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n151:       - id: dimension-coverage\n152:         weight: 0.45\n153:         description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n154:     severityMath:\n155:       refinementMultiplier: 0.5\n156:       p0OverrideMinRatio: 0.50\n157:       noFindingsRatio: 0.0\n158:     coverageAge:\n159:       minStabilizationPasses: 1\n160:     thresholds:\n161:       rollingStopThreshold: 0.08\n162:       noProgressThreshold: 0.05\n163:       compositeStopScore: 0.60\n164: \n165:   lifecycleModes:\n166:     - id: new\n167:       description: Create a brand-new review lineage with generation 1 and no parent session.\n168:     - id: resume\n169:       description: Continue the current review lineage without changing generation.\n170:     - id: restart\n171:       description: Start a new generation for the same target and archive the prior review packet state.\n172:     - id: fork\n173:       status: deferred\n174:       description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n175:     - id: completed-continue\n176:       status: deferred\n177:       description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n178: \n179:   lineageFields:\n180:     - sessionId\n181:     - parentSessionId\n182:     - lineageMode\n183:     - generation\n184:     - continuedFromRun\n185: \n186:   reducer:\n187:     enabled: true\n188:     inputs:\n189:       - latestJSONLDelta\n190:       - newIterationFile\n191:       - priorReducedState\n192:     outputs:\n193:       - findingsRegistry\n194:       - dashboardMetrics\n195:       - strategyUpdates\n196:     failureModes:\n197:       malformedDelta: skip-and-warn\n198:       missingIterationFile: no-op-with-error\n199:       schemaMismatch: reject-with-conflict-event\n200:     idempotent: true\n201: \n202:   releaseReadinessStates:\n203:     - id: in-progress\n204:       description: Review is ongoing or coverage is incomplete.\n205:     - id: converged\n206:       description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n207:     - id: release-blocking\n208:       description: At least one unresolved P0 finding is present.\n209: \n210:   # Cross-reference protocols are typed traceability checks. Core protocols are\n211:   # hard gates; overlay protocols apply only to matching target types.\n212:   crossReferenceProtocols:\n213:     - id: spec_code\n214:       dimension: traceability\n215:       level: core\n216:       appliesTo: [spec-folder, skill, agent, track, files]\n217:       gateClass: hard\n218:       passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n219:       partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n220:       failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n221:     - id: checklist_evidence\n222:       dimension: traceability\n223:       level: core\n224:       appliesTo: [spec-folder, skill, agent, track, files]\n225:       gateClass: hard\n226:       passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n227:       partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n228:       failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n229:     - id: skill_agent\n230:       dimension: traceability\n231:       level: overlay\n232:       appliesTo: [skill]\n233:       gateClass: advisory\n234:       passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n235:       partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n236:       failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n237:     - id: agent_cross_runtime\n238:       dimension: traceability\n239:       level: overlay\n240:       appliesTo: [agent]\n241:       gateClass: advisory\n242:       passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n243:       partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n244:       failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n245:     - id: feature_catalog_code\n246:       dimension: traceability\n247:       level: overlay\n248:       appliesTo: [skill, spec-folder, track, files]\n249:       gateClass: advisory\n250:       passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n251:       partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n252:       failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n253:     - id: playbook_capability\n254:       dimension: traceability\n255:       level: overlay\n256:       appliesTo: [skill, agent, spec-folder]\n257:       gateClass: advisory\n258:       passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n259:       partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n260:       failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n261: \n262:   # Output contracts consumed by synthesis and replay tooling.\n263:   outputs:\n264:     config:\n265:       pathPattern: \"{artifact_dir}/deep-review-config.json\"\n266:       machineOwned: false\n267:       fields:\n268:         - sessionId\n269:         - parentSessionId\n270:         - lineageMode\n271:         - generation\n272:         - continuedFromRun\n273:         - releaseReadinessState\n274:     findingsRegistry:\n275:       pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n276:       machineOwned: true\n277:       sections:\n278:         - openFindings\n279:         - resolvedFindings\n280:         - repeatedFindings\n281:         - dimensionCoverage\n282:         - findingsBySeverity\n283:         - convergenceScore\n284:     reviewReport:\n285:       pathPattern: \"{artifact_dir}/review-report.md\"\n286:       sections:\n287:         - executive-summary\n288:         - planning-trigger\n289:         - active-finding-registry\n290:         - remediation-workstreams\n291:         - spec-seed\n292:         - plan-seed\n293:         - traceability-status\n294:         - deferred-items\n295:         - audit-appendix\n296:     strategy:\n297:       pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n298:       requiredSections:\n299:         - topic\n300:         - review-dimensions\n301:         - completed-dimensions\n302:         - running-findings\n303:         - what-worked\n304:         - what-failed\n305:         - exhausted-approaches\n306:         - ruled-out-directions\n307:         - next-focus\n308:         - known-context\n309:         - cross-reference-status\n310:         - files-under-review\n311:         - review-boundaries\n312:     dashboard:\n313:       pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n314:       machineOwned: true\n315:       sections:\n316:         - status\n317:         - findings-summary\n318:         - dimension-coverage\n319:         - progress\n320:         - next-focus\n321:     pauseSentinel:\n322:       pathPattern: \"{artifact_dir}/.deep-review-pause\"\n323:       machineOwned: false\n324:       description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n325:     jsonl:\n326:       pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n327:       iterationRecord:\n328:         required:\n329:           - type\n330:           - mode\n331:           - run\n332:           - status\n333:           - focus\n334:           - dimensions\n335:           - filesReviewed\n336:           - findingsCount\n337:           - findingsSummary\n338:           - findingsNew\n339:           - findingDetails\n340:           - newFindingsRatio\n341:           - sessionId\n342:           - generation\n343:           - lineageMode\n344:           - timestamp\n345:           - durationMs\n346:         optional:\n347:           - parentSessionId\n348:           - continuedFromRun\n349:           - findingsRefined\n350:           - findingRefs\n351:           - traceabilityChecks\n352:           - coverage\n353:           - noveltyJustification\n354:           - ruledOut\n355:           - focusTrack\n356:           - scoreEstimate\n357:           - segment\n358:           - convergenceSignals\n359:           - graphEvents\n360:       synthesisEvent:\n361:         required:\n362:           - type\n363:           - event\n364:           - mode\n365:           - totalIterations\n366:           - verdict\n367:           - activeP0\n368:           - activeP1\n369:           - activeP2\n370:           - dimensionCoverage\n371:           - stopReason\n372:           - timestamp\n373: \n374: # Render targets define where generated or mixed-authored contract fragments land.\n375: render:\n376:   artifacts:\n377:     - id: workflow-auto\n378:       path: .opencode/commands/deep/assets/deep_review_auto.yaml\n379:       ownership: mixed\n380:       format: yaml\n381:       markers:\n382:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-auto -->\"\n383:         end: \"<!-- END GENERATED: review-mode-contract/workflow-auto -->\"\n384:       sections:\n385:         - target-types\n386:         - dimensions\n387:         - verdicts\n388:         - quality-gates\n389:         - convergence\n390:         - cross-reference-protocols\n391:     - id: workflow-confirm\n392:       path: .opencode/commands/deep/assets/deep_review_confirm.yaml\n393:       ownership: mixed\n394:       format: yaml\n395:       markers:\n396:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-confirm -->\"\n397:         end: \"<!-- END GENERATED: review-mode-contract/workflow-confirm -->\"\n398:       sections:\n399:         - target-types\n400:         - dimensions\n401:         - verdicts\n402:         - quality-gates\n403:         - convergence\n404:         - cross-reference-protocols\n405:     - id: agent-opencode\n406:       path: .opencode/agents/deep-review.md\n407:       ownership: mixed\n408:       format: markdown\n409:       markers:\n410:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-opencode -->\"\n411:         end: \"<!-- END GENERATED: review-mode-contract/agent-opencode -->\"\n412:       sections:\n413:         - dimensions\n414:         - severities\n415:         - quality-gates\n416:         - cross-reference-protocols\n417:         - outputs\n418:     - id: agent-claude\n419:       path: .claude/agents/deep-review.md\n420:       ownership: mixed\n421:       format: markdown\n422:       markers:\n423:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-claude -->\"\n424:         end: \"<!-- END GENERATED: review-mode-contract/agent-claude -->\"\n425:       sections:\n426:         - dimensions\n427:         - severities\n428:         - quality-gates\n429:         - cross-reference-protocols\n430:         - outputs\n431:     - id: quick-reference-review-mode\n432:       path: .opencode/skills/deep-loop-workflows/deep-review/references/protocol/quick_reference.md\n433:       ownership: mixed\n434:       format: markdown\n435:       markers:\n436:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n437:         end: \"<!-- END GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n438:       sections:\n439:         - target-types\n440:         - dimensions\n441:         - verdicts\n442:         - quality-gates\n443:         - outputs\n444:     - id: review-contract-snapshot\n445:       path: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract_snapshot.md\n446:       ownership: generated\n447:       format: markdown\n448:       markers:\n449:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n450:         end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n451:       sections:\n452:         - meta\n453:         - target-types\n454:         - dimensions\n455:         - severities\n456:         - verdicts\n457:         - quality-gates\n458:         - convergence\n459:         - cross-reference-protocols\n460:         - outputs\n461:         - validation\n462: \n463: # Validator contract for CI, render verification, and drift detection.\n464: validation:\n465:   schemaVersion: 1\n466:   checks:\n467:     - id: schema\n468:       description: Validate this manifest against the canonical review-mode contract schema.\n469:     - id: render-verify\n470:       description: Re-render downstream artifacts in verify mode and fail on drift.\n471:     - id: marker-integrity\n472:       description: Ensure every render target contains intact begin/end markers with no overlapping generated blocks.\n473:     - id: enum-parity\n474:       description: Ensure target types, dimensions, severities, verdicts, and quality gates match across rendered artifacts.\n475:     - id: jsonl-parity\n476:       description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n477:     - id: lifecycle-parity\n478:       description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n479:     - id: reducer-contract\n480:       description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n481:     - id: duplicate-literal-lint\n482:       description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n483:     - id: runtime-coverage\n484:       description: Ensure every supported runtime deep-review agent has a declared render artifact and parity coverage.\n485:     - id: playbook-assertions\n486:       description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.\n\n(End of file - total 486 lines)\n</content>","metadata":{"preview":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n    beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n    endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n  sourceOfTruth: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  contextSnapshot:\n    requiredAtInit: true","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml","text":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n    beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n    endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n  sourceOfTruth: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  contextSnapshot:\n    requiredAtInit: true\n    ownerArtifact: deep-review-strategy.md\n    section: Known Context\n    source: bounded-review-context-snapshot\n    bounded: true\n    pointerBased: true\n    includes:\n      - targetPointers\n      - behaviorClaims\n      - reuseAndConventionPointers\n      - riskAreasAndContextGaps\n    forbids:\n      - deepContextDispatch\n      - fullSourceBodyInlining\n      - contextLoopReportCreation\n      - scopeWideningBeyondReviewTarget\n\n  # Review target taxonomy.\n  targetTypes:\n    - id: spec-folder\n      cliValue: spec-folder\n      label: Spec Folder\n      description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n    - id: skill\n      cliValue: skill\n      label: Skill\n      description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n    - id: agent\n      cliValue: agent\n      label: Agent\n      description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n    - id: track\n      cliValue: track\n      label: Track\n      description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n    - id: files\n      cliValue: files\n      label: Files\n      description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n\n  # Simplified review dimensions. Traceability and maintainability absorb the\n  # prior seven-dimension model's overlap.\n  dimensions:\n    - id: correctness\n      priority: 1\n      label: Correctness\n      checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n      requiredForSeverityCoverage: true\n    - id: security\n      priority: 2\n      label: Security\n      checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n      requiredForSeverityCoverage: true\n    - id: traceability\n      priority: 3\n      label: Traceability\n      checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n      requiredForSeverityCoverage: false\n    - id: maintainability\n      priority: 4\n      label: Maintainability\n      checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n      requiredForSeverityCoverage: false\n\n  # Severity contract stays stable across review outputs.\n  severities:\n    - id: P0\n      weight: 10.0\n      label: Blocker\n      requiresFileLineEvidence: true\n    - id: P1\n      weight: 5.0\n      label: Required\n      requiresFileLineEvidence: true\n    - id: P2\n      weight: 1.0\n      label: Suggestion\n      requiresFileLineEvidence: true\n\n  # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n  verdicts:\n    - id: FAIL\n      label: Fail\n      condition: \"activeP0 > 0 OR any required quality gate fails\"\n      nextCommand: /speckit:plan\n    - id: CONDITIONAL\n      label: Conditional\n      condition: \"activeP0 == 0 AND activeP1 > 0\"\n      nextCommand: /speckit:plan\n    - id: PASS\n      label: Pass\n      condition: \"activeP0 == 0 AND activeP1 == 0\"\n      hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n      nextCommand: /create:changelog\n\n  # Binary gates applied after convergence math votes STOP.\n  qualityGates:\n    - id: evidence\n      label: Evidence\n      binary: true\n      combines:\n        - evidence-completeness\n        - no-inference-only\n      rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n    - id: scope\n      label: Scope\n      binary: true\n      combines:\n        - scope-alignment\n      rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n    - id: coverage\n      label: Coverage\n      binary: true\n      combines:\n        - severity-coverage\n        - cross-reference\n      rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n\n  # Review-specific convergence settings calibrated from the v2 research.\n  convergence:\n    defaults:\n      maxIterations: 7\n      convergenceThreshold: 0.10\n      stuckThreshold: 2\n    signals:\n      - id: rolling-average\n        weight: 0.30\n        description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n      - id: mad-noise-floor\n        weight: 0.25\n        description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n      - id: dimension-coverage\n        weight: 0.45\n        description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n    severityMath:\n      refinementMultiplier: 0.5\n      p0OverrideMinRatio: 0.50\n      noFindingsRatio: 0.0\n    coverageAge:\n      minStabilizationPasses: 1\n    thresholds:\n      rollingStopThreshold: 0.08\n      noProgressThreshold: 0.05\n      compositeStopScore: 0.60\n\n  lifecycleModes:\n    - id: new\n      description: Create a brand-new review lineage with generation 1 and no parent session.\n    - id: resume\n      description: Continue the current review lineage without changing generation.\n    - id: restart\n      description: Start a new generation for the same target and archive the prior review packet state.\n    - id: fork\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n    - id: completed-continue\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n\n  lineageFields:\n    - sessionId\n    - parentSessionId\n    - lineageMode\n    - generation\n    - continuedFromRun\n\n  reducer:\n    enabled: true\n    inputs:\n      - latestJSONLDelta\n      - newIterationFile\n      - priorReducedState\n    outputs:\n      - findingsRegistry\n      - dashboardMetrics\n      - strategyUpdates\n    failureModes:\n      malformedDelta: skip-and-warn\n      missingIterationFile: no-op-with-error\n      schemaMismatch: reject-with-conflict-event\n    idempotent: true\n\n  releaseReadinessStates:\n    - id: in-progress\n      description: Review is ongoing or coverage is incomplete.\n    - id: converged\n      description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n    - id: release-blocking\n      description: At least one unresolved P0 finding is present.\n\n  # Cross-reference protocols are typed traceability checks. Core protocols are\n  # hard gates; overlay protocols apply only to matching target types.\n  crossReferenceProtocols:\n    - id: spec_code\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n      partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n      failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n    - id: checklist_evidence\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n      partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n      failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n    - id: skill_agent\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill]\n      gateClass: advisory\n      passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n      partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n      failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n    - id: agent_cross_runtime\n      dimension: traceability\n      level: overlay\n      appliesTo: [agent]\n      gateClass: advisory\n      passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n      partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n      failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n    - id: feature_catalog_code\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, spec-folder, track, files]\n      gateClass: advisory\n      passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n      partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n      failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n    - id: playbook_capability\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, agent, spec-folder]\n      gateClass: advisory\n      passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n      partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n      failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n\n  # Output contracts consumed by synthesis and replay tooling.\n  outputs:\n    config:\n      pathPattern: \"{artifact_dir}/deep-review-config.json\"\n      machineOwned: false\n      fields:\n        - sessionId\n        - parentSessionId\n        - lineageMode\n        - generation\n        - continuedFromRun\n        - releaseReadinessState\n    findingsRegistry:\n      pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n      machineOwned: true\n      sections:\n        - openFindings\n        - resolvedFindings\n        - repeatedFindings\n        - dimensionCoverage\n        - findingsBySeverity\n        - convergenceScore\n    reviewReport:\n      pathPattern: \"{artifact_dir}/review-report.md\"\n      sections:\n        - executive-summary\n        - planning-trigger\n        - active-finding-registry\n        - remediation-workstreams\n        - spec-seed\n        - plan-seed\n        - traceability-status\n        - deferred-items\n        - audit-appendix\n    strategy:\n      pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n      requiredSections:\n        - topic\n        - review-dimensions\n        - completed-dimensions\n        - running-findings\n        - what-worked\n        - what-failed\n        - exhausted-approaches\n        - ruled-out-directions\n        - next-focus\n        - known-context\n        - cross-reference-status\n        - files-under-review\n        - review-boundaries\n    dashboard:\n      pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n      machineOwned: true\n      sections:\n        - status\n        - findings-summary\n        - dimension-coverage\n        - progress\n        - next-focus\n    pauseSentinel:\n      pathPattern: \"{artifact_dir}/.deep-review-pause\"\n      machineOwned: false\n      description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n    jsonl:\n      pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n      iterationRecord:\n        required:\n          - type\n          - mode\n          - run\n          - status\n          - focus\n          - dimensions\n          - filesReviewed\n          - findingsCount\n          - findingsSummary\n          - findingsNew\n          - findingDetails\n          - newFindingsRatio\n          - sessionId\n          - generation\n          - lineageMode\n          - timestamp\n          - durationMs\n        optional:\n          - parentSessionId\n          - continuedFromRun\n          - findingsRefined\n          - findingRefs\n          - traceabilityChecks\n          - coverage\n          - noveltyJustification\n          - ruledOut\n          - focusTrack\n          - scoreEstimate\n          - segment\n          - convergenceSignals\n          - graphEvents\n      synthesisEvent:\n        required:\n          - type\n          - event\n          - mode\n          - totalIterations\n          - verdict\n          - activeP0\n          - activeP1\n          - activeP2\n          - dimensionCoverage\n          - stopReason\n          - timestamp\n\n# Render targets define where generated or mixed-authored contract fragments land.\nrender:\n  artifacts:\n    - id: workflow-auto\n      path: .opencode/commands/deep/assets/deep_review_auto.yaml\n      ownership: mixed\n      format: yaml\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-auto -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/workflow-auto -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n    - id: workflow-confirm\n      path: .opencode/commands/deep/assets/deep_review_confirm.yaml\n      ownership: mixed\n      format: yaml\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-confirm -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/workflow-confirm -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n    - id: agent-opencode\n      path: .opencode/agents/deep-review.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-opencode -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/agent-opencode -->\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: agent-claude\n      path: .claude/agents/deep-review.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-claude -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/agent-claude -->\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: quick-reference-review-mode\n      path: .opencode/skills/deep-loop-workflows/deep-review/references/protocol/quick_reference.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - outputs\n    - id: review-contract-snapshot\n      path: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract_snapshot.md\n      ownership: generated\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n      sections:\n        - meta\n        - target-types\n        - dimensions\n        - severities\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n        - outputs\n        - validation\n\n# Validator contract for CI, render verification, and drift detection.\nvalidation:\n  schemaVersion: 1\n  checks:\n    - id: schema\n      description: Validate this manifest against the canonical review-mode contract schema.\n    - id: render-verify\n      description: Re-render downstream artifacts in verify mode and fail on drift.\n    - id: marker-integrity\n      description: Ensure every render target contains intact begin/end markers with no overlapping generated blocks.\n    - id: enum-parity\n      description: Ensure target types, dimensions, severities, verdicts, and quality gates match across rendered artifacts.\n    - id: jsonl-parity\n      description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n    - id: lifecycle-parity\n      description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n    - id: reducer-contract\n      description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n    - id: duplicate-literal-lint\n      description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n    - id: runtime-coverage\n      description: Ensure every supported runtime deep-review agent has a declared render artifact and parity coverage.\n    - id: playbook-assertions\n      description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.","lineStart":1,"lineEnd":486,"totalLines":486,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml","time":{"start":1783433250704,"end":1783433250722}},"metadata":{"openai":{"itemId":"fc_00e23ee13638bdd5016a4d082285948190940765a9ed679cc5"}},"id":"prt_f3ce7c78e001fEzkjiXh70ACue","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","messageID":"msg_f3ce78108001vpvWPy5TsYcdSF"}}
