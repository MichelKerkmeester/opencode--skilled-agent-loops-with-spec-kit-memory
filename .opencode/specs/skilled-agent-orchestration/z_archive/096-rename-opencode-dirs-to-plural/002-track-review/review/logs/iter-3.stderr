    70	    ? path.resolve(process.cwd(), runtimeDbDir)
    71	    : path.dirname(DB_PATH);
    72	
    73	  // Resolve symlinks before the boundary check so repo-local links cannot
    74	  // smuggle the database into an unrelated system path.
    75	  const resolved = realpathAllowMissing(databaseDir);
    76	  const allowedPrefixes = [process.cwd(), os.homedir()].map(realpathAllowMissing);
