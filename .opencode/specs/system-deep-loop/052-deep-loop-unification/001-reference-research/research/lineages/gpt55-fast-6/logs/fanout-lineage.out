.subprocessExitedAtMs = null;\n735:           continue;\n736:         }\n737: \n738:         const exitedAtMs = Number.isFinite(liveness.exitedAtMs)\n739:           ? liveness.exitedAtMs\n740:           : (activeAttempt.subprocessExitedAtMs ?? nowMs);\n741:         activeAttempt.subprocessExitedAtMs = exitedAtMs;\n742:         liveness.exitedAtMs = exitedAtMs;\n743:         const elapsedMs = Math.max(0, nowMs - exitedAtMs);\n744:         if (elapsedMs < postExitGraceMs) {\n745:           nextDelayMs = Math.min(nextDelayMs, postExitGraceMs - elapsedMs);\n746:           continue;\n747:         }\n748: \n749:         const error = buildPostExitOrphanError({ label: activeAttempt.label, graceMs: postExitGraceMs, liveness });\n750:         const result = buildPostExitOrphanResult(activeAttempt, liveness, error);\n751:         activeAttempt.abortController?.abort(error);\n752:         settleActiveAttempt(activeAttempt, result);\n753:         return true;\n754:       }\n755: \n756:       schedulePostExitWatchdogCheck(nextDelayMs);\n757:       return false;\n758:     };\n759: \n760:     const schedulePostExitWatchdogCheck = (delayMs = postExitPollMs) => {\n761:       clearPostExitWatchdogTimer();\n762:       if (!shouldWatchPostExitOrphans || resolved || activeAttempts.size === 0) return;\n763:       postExitWatchdogTimer = setTimeout(() => {\n764:         postExitWatchdogTimer = null;\n765:         if (!resolved) handlePostExitWatchdog();\n766:       }, Math.max(1, Math.floor(delayMs)));\n767:     };\n768: \n769:     const pump = () => {\n770:       if (resolved) {\n771:         return;\n772:       }\n773:       if (queue.length === 0 && active === 0) {\n774:         resolved = true;\n775:         clearLagCeilingTimer();\n776:         clearPostExitWatchdogTimer();\n777:         resolve(buildPoolSummary(results));\n778:         return;\n779:       }\n780:       while (active < concurrency && queue.length > 0) {\n781:         const index = queue.shift();\n782:         const label = labelFor(items[index], index);\n783:         const retryCount = retryCounts.get(label) || 0;\n784:         const attempt = retryCount + 1;\n785:         const startedAtIso = normalizeTimestamp(now());\n786:         const startedAtMs = Date.now();\n787:         const abortController = shouldAbortStalledLineages || shouldWatchPostExitOrphans ? new AbortController() : null;\n788:         const activeAttempt = {\n789:           id: nextAttemptId,\n790:           index,\n791:           label,\n792:           retryCount,\n793:           attempt,\n794:           startedAtIso,\n795:           startedAtMs,\n796:           abortController,\n797:           settled: false,\n798:         };\n799:         nextAttemptId += 1;\n800:         activeAttempts.set(activeAttempt.id, activeAttempt);\n801:         active += 1;\n802:         settleItem({\n803:           item: items[index],\n804:           index,\n805:           worker,\n806:           now,\n807:           onEvent: emitEvent,\n808:           attempt,\n809:           emitSettledEvent: false,\n810:           abortSignal: abortController ? abortController.signal : undefined,\n811:           startedAtIso,\n812:           startedAtMs,\n813:         })\n814:           .then((result) => {\n815:             settleActiveAttempt(activeAttempt, result);\n816:           })\n817:           .catch((error) => {\n818:             // The item settler is meant to capture worker failures; this keeps\n819:             // an unexpected bug in the settler from wedging the whole pool.\n820:             settleActiveAttempt(activeAttempt, buildPoolErrorResult(activeAttempt, error));\n821:           });\n822:       }\n823:       scheduleLagCeilingCheck();\n824:       schedulePostExitWatchdogCheck();\n825:     };\n826: \n827:     pump();\n828:   });\n829: }\n830: \n831: /**\n832:  * Build the ordered-results + summary envelope for a completed pool run.\n833:  *\n834:  * @param {Array<Object>} results - Per-item settlement results (ordered).\n835:  * @returns {Object} { results, summary: { total, succeeded, failed, all_failed } }.\n836:  */\n837: function buildPoolSummary(results) {\n838:   const total = results.length;\n839:   const succeeded = results.filter((result) => result && result.status === 'fulfilled').length;\n840:   const failed = total - succeeded;\n841:   const gauges = buildPoolGauges({ total, settled: total, pending: 0, failed });\n842:   const failureClasses = buildFailureClassRollup(results);\n843:   return {\n844:     results,\n845:     summary: {\n846:       total,\n847:       succeeded,\n848:       failed,\n849:       all_failed: total > 0 && failed === total,\n850:       gauges,\n851:       failure_classes: failureClasses,\n852:     },\n853:   };\n854: }\n855: \n856: // ─────────────────────────────────────────────────────────────────────────────\n857: // 5. STATUS LEDGER\n858: // ─────────────────────────────────────────────────────────────────────────────\n859: \n860: /**\n861:  * Append one JSONL event to the orchestration status ledger.\n862:  *\n863:  * Follows the `orchestration-status.log` ledger pattern: one line per lineage\n864:  * lifecycle event (started / completed / failed / salvaged / converged).\n865:  *\n866:  * @param {string} ledgerPath - Path to the JSONL ledger file.\n867:  * @param {Object} entry - A serializable event object.\n868:  */\n869: function appendStatusLedger(ledgerPath, entry) {\n870:   fs.mkdirSync(path.dirname(ledgerPath), { recursive: true });\n871:   fs.appendFileSync(ledgerPath, `${JSON.stringify(entry)}\\n`);\n872: }\n873: \n874: /**\n875:  * Write the orchestration summary JSON for a completed fan-out run.\n876:  *\n877:  * @param {string} summaryPath - Path to the summary JSON file.\n878:  * @param {Object} summary - Summary payload (e.g. the pool summary plus\n879:  *   salvage counts and per-lineage rollups).\n880:  */\n881: function writeOrchestrationSummary(summaryPath, summary) {\n882:   fs.mkdirSync(path.dirname(summaryPath), { recursive: true });\n883:   fs.writeFileSync(summaryPath, `${JSON.stringify(summary, null, 2)}\\n`);\n884: }\n885: \n886: // ─────────────────────────────────────────────────────────────────────────────\n887: // 6. EXPORTS\n888: // ─────────────────────────────────────────────────────────────────────────────\n889: \n890: module.exports = {\n891:   runCappedPool,\n892:   settleItem,\n893:   buildPoolSummary,\n894:   buildPoolGauges,\n895:   classifyLineageFailure,\n896:   detectOrphanedLineages,\n897:   createWavePlannerInterface,\n898:   markOrphanedLineages,\n899:   readRetryCountsFromLedger,\n900:   appendStatusLedger,\n901:   writeOrchestrationSummary,\n902: };\n\n(End of file - total 902 lines)\n</content>","metadata":{"preview":"          index: activeAttempt.index,\n          attempt: activeAttempt.attempt,\n          at: result.completed_at_iso,\n          action: lagCeilingAction,\n          lag_ceiling_ms: lagCeilingMs,\n          oldest_pending_lag_ms: gauges.oldest_pending_lag_ms,\n          gauges: buildCurrentGauges(),\n        });\n      }\n      settleActiveAttempt(activeAttempt, result);\n      return true;\n    };\n\n    const handleLagCeilingExceeded = () => {\n      if (lagCeilingMs <= 0 || queue.length === 0) return;\n      const gauges = buildCurrentGauges();\n      if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return;\n      emitLagCeilingWarning(gauges);\n      abortStalledAttempt(gauges);\n    };","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","text":"          index: activeAttempt.index,\n          attempt: activeAttempt.attempt,\n          at: result.completed_at_iso,\n          action: lagCeilingAction,\n          lag_ceiling_ms: lagCeilingMs,\n          oldest_pending_lag_ms: gauges.oldest_pending_lag_ms,\n          gauges: buildCurrentGauges(),\n        });\n      }\n      settleActiveAttempt(activeAttempt, result);\n      return true;\n    };\n\n    const handleLagCeilingExceeded = () => {\n      if (lagCeilingMs <= 0 || queue.length === 0) return;\n      const gauges = buildCurrentGauges();\n      if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return;\n      emitLagCeilingWarning(gauges);\n      abortStalledAttempt(gauges);\n    };\n\n    const handlePostExitWatchdog = () => {\n      if (!shouldWatchPostExitOrphans || activeAttempts.size === 0) return false;\n      const nowMs = Date.now();\n      let nextDelayMs = postExitPollMs;\n      for (const activeAttempt of activeAttempts.values()) {\n        if (!activeAttempt || activeAttempt.settled) continue;\n        let liveness;\n        try {\n          liveness = normalizeAttemptLiveness(getAttemptLiveness(activeAttempt));\n        } catch {\n          continue;\n        }\n        if (liveness.alive !== false) {\n          activeAttempt.subprocessExitedAtMs = null;\n          continue;\n        }\n\n        const exitedAtMs = Number.isFinite(liveness.exitedAtMs)\n          ? liveness.exitedAtMs\n          : (activeAttempt.subprocessExitedAtMs ?? nowMs);\n        activeAttempt.subprocessExitedAtMs = exitedAtMs;\n        liveness.exitedAtMs = exitedAtMs;\n        const elapsedMs = Math.max(0, nowMs - exitedAtMs);\n        if (elapsedMs < postExitGraceMs) {\n          nextDelayMs = Math.min(nextDelayMs, postExitGraceMs - elapsedMs);\n          continue;\n        }\n\n        const error = buildPostExitOrphanError({ label: activeAttempt.label, graceMs: postExitGraceMs, liveness });\n        const result = buildPostExitOrphanResult(activeAttempt, liveness, error);\n        activeAttempt.abortController?.abort(error);\n        settleActiveAttempt(activeAttempt, result);\n        return true;\n      }\n\n      schedulePostExitWatchdogCheck(nextDelayMs);\n      return false;\n    };\n\n    const schedulePostExitWatchdogCheck = (delayMs = postExitPollMs) => {\n      clearPostExitWatchdogTimer();\n      if (!shouldWatchPostExitOrphans || resolved || activeAttempts.size === 0) return;\n      postExitWatchdogTimer = setTimeout(() => {\n        postExitWatchdogTimer = null;\n        if (!resolved) handlePostExitWatchdog();\n      }, Math.max(1, Math.floor(delayMs)));\n    };\n\n    const pump = () => {\n      if (resolved) {\n        return;\n      }\n      if (queue.length === 0 && active === 0) {\n        resolved = true;\n        clearLagCeilingTimer();\n        clearPostExitWatchdogTimer();\n        resolve(buildPoolSummary(results));\n        return;\n      }\n      while (active < concurrency && queue.length > 0) {\n        const index = queue.shift();\n        const label = labelFor(items[index], index);\n        const retryCount = retryCounts.get(label) || 0;\n        const attempt = retryCount + 1;\n        const startedAtIso = normalizeTimestamp(now());\n        const startedAtMs = Date.now();\n        const abortController = shouldAbortStalledLineages || shouldWatchPostExitOrphans ? new AbortController() : null;\n        const activeAttempt = {\n          id: nextAttemptId,\n          index,\n          label,\n          retryCount,\n          attempt,\n          startedAtIso,\n          startedAtMs,\n          abortController,\n          settled: false,\n        };\n        nextAttemptId += 1;\n        activeAttempts.set(activeAttempt.id, activeAttempt);\n        active += 1;\n        settleItem({\n          item: items[index],\n          index,\n          worker,\n          now,\n          onEvent: emitEvent,\n          attempt,\n          emitSettledEvent: false,\n          abortSignal: abortController ? abortController.signal : undefined,\n          startedAtIso,\n          startedAtMs,\n        })\n          .then((result) => {\n            settleActiveAttempt(activeAttempt, result);\n          })\n          .catch((error) => {\n            // The item settler is meant to capture worker failures; this keeps\n            // an unexpected bug in the settler from wedging the whole pool.\n            settleActiveAttempt(activeAttempt, buildPoolErrorResult(activeAttempt, error));\n          });\n      }\n      scheduleLagCeilingCheck();\n      schedulePostExitWatchdogCheck();\n    };\n\n    pump();\n  });\n}\n\n/**\n * Build the ordered-results + summary envelope for a completed pool run.\n *\n * @param {Array<Object>} results - Per-item settlement results (ordered).\n * @returns {Object} { results, summary: { total, succeeded, failed, all_failed } }.\n */\nfunction buildPoolSummary(results) {\n  const total = results.length;\n  const succeeded = results.filter((result) => result && result.status === 'fulfilled').length;\n  const failed = total - succeeded;\n  const gauges = buildPoolGauges({ total, settled: total, pending: 0, failed });\n  const failureClasses = buildFailureClassRollup(results);\n  return {\n    results,\n    summary: {\n      total,\n      succeeded,\n      failed,\n      all_failed: total > 0 && failed === total,\n      gauges,\n      failure_classes: failureClasses,\n    },\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. STATUS LEDGER\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Append one JSONL event to the orchestration status ledger.\n *\n * Follows the `orchestration-status.log` ledger pattern: one line per lineage\n * lifecycle event (started / completed / failed / salvaged / converged).\n *\n * @param {string} ledgerPath - Path to the JSONL ledger file.\n * @param {Object} entry - A serializable event object.\n */\nfunction appendStatusLedger(ledgerPath, entry) {\n  fs.mkdirSync(path.dirname(ledgerPath), { recursive: true });\n  fs.appendFileSync(ledgerPath, `${JSON.stringify(entry)}\\n`);\n}\n\n/**\n * Write the orchestration summary JSON for a completed fan-out run.\n *\n * @param {string} summaryPath - Path to the summary JSON file.\n * @param {Object} summary - Summary payload (e.g. the pool summary plus\n *   salvage counts and per-lineage rollups).\n */\nfunction writeOrchestrationSummary(summaryPath, summary) {\n  fs.mkdirSync(path.dirname(summaryPath), { recursive: true });\n  fs.writeFileSync(summaryPath, `${JSON.stringify(summary, null, 2)}\\n`);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  runCappedPool,\n  settleItem,\n  buildPoolSummary,\n  buildPoolGauges,\n  classifyLineageFailure,\n  detectOrphanedLineages,\n  createWavePlannerInterface,\n  markOrphanedLineages,\n  readRetryCountsFromLedger,\n  appendStatusLedger,\n  writeOrchestrationSummary,\n};","lineStart":700,"lineEnd":902,"totalLines":902,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","time":{"start":1783487594444,"end":1783487594460}},"metadata":{"openai":{"itemId":"fc_0f5646a3c0dcb475016a4ddc6a53b48191a6a12072fa7b3194"}},"id":"prt_f4024ffc1001HyTsRKm02fKZIT","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f4024dd6e0018D1KbIKIsdY5dI"}}
{"type":"tool_use","timestamp":1783487594478,"sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","part":{"type":"tool","tool":"read","callID":"call_yJJGzI1FMy7HeUw1HYljTUay","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep-Loop Runtime — Fan-Out Worker Pool                                   ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n5: // ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n6: // ║ council parallel dispatcher (lib/council/multi-seat-dispatch.cjs) by      ║\n7: // ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n8: // ║ flight, plus a status-ledger writer following the proven                  ║\n9: // ║ orchestration-status.log ledger pattern.                                   ║\n10: // ║                                                                           ║\n11: // ║ Design: pure pool primitive (worker is INJECTED) + ledger helpers, fully  ║\n12: // ║ unit-tested. The real spawn worker and the CLI entry that wires it        ║\n13: // ║ (arg parse, JSON-out, exit codes) live in fanout-run.cjs.                ║\n14: // ╚══════════════════════════════════════════════════════════════════════════╝\n15: \n16: 'use strict';\n17: \n18: // ─────────────────────────────────────────────────────────────────────────────\n19: // 1. IMPORTS\n20: // ─────────────────────────────────────────────────────────────────────────────\n21: \n22: const fs = require('node:fs');\n23: const path = require('node:path');\n24: const { classifyLineageFailure } = require('./lib/cli-guards.cjs');\n25: \n26: // ─────────────────────────────────────────────────────────────────────────────\n27: // 2. CONSTANTS\n28: // ─────────────────────────────────────────────────────────────────────────────\n29: \n30: const LAG_CEILING_ACTION_ABORT_REQUEUE = 'abort-requeue';\n31: const WAVE_ASSIGNMENT_MODEL = 'wave';\n32: const WAVE_PLANNER_STATUS_DORMANT = 'dormant';\n33: const WAVE_PLANNER_DORMANT_MESSAGE = 'wave planner is dormant until conflict-safety substrate is available';\n34: const POST_EXIT_ORPHAN_REASON = 'orphaned_after_subprocess_exit';\n35: \n36: // ─────────────────────────────────────────────────────────────────────────────\n37: // 3. HELPERS\n38: // ─────────────────────────────────────────────────────────────────────────────\n39: \n40: function isRecord(value) {\n41:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n42: }\n43: \n44: function normalizeTimestamp(value) {\n45:   if (value instanceof Date) {\n46:     return value.toISOString();\n47:   }\n48:   if (typeof value === 'string' && value.trim() !== '') {\n49:     return value;\n50:   }\n51:   return new Date().toISOString();\n52: }\n53: \n54: function normalizeConcurrency(value) {\n55:   const n = Number(value);\n56:   if (!Number.isFinite(n) || n < 1) {\n57:     return 1;\n58:   }\n59:   return Math.floor(n);\n60: }\n61: \n62: function labelFor(item, index) {\n63:   if (isRecord(item) && typeof item.label === 'string' && item.label.trim() !== '') {\n64:     return item.label;\n65:   }\n66:   return `item-${index}`;\n67: }\n68: \n69: function buildPoolGauges({ total, settled, pending, failed, oldestPendingLagMs }) {\n70:   const gauges = {\n71:     lag: Math.max(0, total - settled),\n72:     pending: Math.max(0, pending),\n73:     failed: Math.max(0, failed),\n74:   };\n75:   if (Number.isFinite(oldestPendingLagMs)) {\n76:     gauges.oldest_pending_lag_ms = Math.max(0, Math.floor(oldestPendingLagMs));\n77:   }\n78:   return gauges;\n79: }\n80: \n81: function normalizeMaxRetries(value) {\n82:   if (value === undefined || value === null) {\n83:     return 0;\n84:   }\n85:   const n = Number(value);\n86:   if (!Number.isFinite(n) || n < 0) {\n87:     return 0;\n88:   }\n89:   return Math.floor(n);\n90: }\n91: \n92: function normalizeNonNegativeDuration(value) {\n93:   if (value === undefined || value === null) {\n94:     return 0;\n95:   }\n96:   const n = Number(value);\n97:   if (!Number.isFinite(n) || n < 0) {\n98:     return 0;\n99:   }\n100:   return Math.floor(n);\n101: }\n102: \n103: function normalizeLagCeilingAction(value) {\n104:   if (value === undefined || value === null || value === '') {\n105:     return null;\n106:   }\n107:   const action = String(value).trim();\n108:   if (action !== LAG_CEILING_ACTION_ABORT_REQUEUE) {\n109:     throw new TypeError('lagCeilingAction must be \"abort-requeue\" when set');\n110:   }\n111:   return action;\n112: }\n113: \n114: function normalizeRetryCountMap(value) {\n115:   const counts = new Map();\n116:   if (!isRecord(value)) {\n117:     return counts;\n118:   }\n119:   for (const [label, count] of Object.entries(value)) {\n120:     const n = Number(count);\n\n(Showing lines 1-120 of 902. Use offset=121 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Worker Pool                                   ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n// ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n// ║ council parallel dispatcher (lib/council/multi-seat-dispatch.cjs) by      ║\n// ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n// ║ flight, plus a status-ledger writer following the proven                  ║\n// ║ orchestration-status.log ledger pattern.                                   ║\n// ║                                                                           ║\n// ║ Design: pure pool primitive (worker is INJECTED) + ledger helpers, fully  ║\n// ║ unit-tested. The real spawn worker and the CLI entry that wires it        ║\n// ║ (arg parse, JSON-out, exit codes) live in fanout-run.cjs.                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Worker Pool                                   ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n// ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n// ║ council parallel dispatcher (lib/council/multi-seat-dispatch.cjs) by      ║\n// ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n// ║ flight, plus a status-ledger writer following the proven                  ║\n// ║ orchestration-status.log ledger pattern.                                   ║\n// ║                                                                           ║\n// ║ Design: pure pool primitive (worker is INJECTED) + ledger helpers, fully  ║\n// ║ unit-tested. The real spawn worker and the CLI entry that wires it        ║\n// ║ (arg parse, JSON-out, exit codes) live in fanout-run.cjs.                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { classifyLineageFailure } = require('./lib/cli-guards.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst LAG_CEILING_ACTION_ABORT_REQUEUE = 'abort-requeue';\nconst WAVE_ASSIGNMENT_MODEL = 'wave';\nconst WAVE_PLANNER_STATUS_DORMANT = 'dormant';\nconst WAVE_PLANNER_DORMANT_MESSAGE = 'wave planner is dormant until conflict-safety substrate is available';\nconst POST_EXIT_ORPHAN_REASON = 'orphaned_after_subprocess_exit';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeTimestamp(value) {\n  if (value instanceof Date) {\n    return value.toISOString();\n  }\n  if (typeof value === 'string' && value.trim() !== '') {\n    return value;\n  }\n  return new Date().toISOString();\n}\n\nfunction normalizeConcurrency(value) {\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 1) {\n    return 1;\n  }\n  return Math.floor(n);\n}\n\nfunction labelFor(item, index) {\n  if (isRecord(item) && typeof item.label === 'string' && item.label.trim() !== '') {\n    return item.label;\n  }\n  return `item-${index}`;\n}\n\nfunction buildPoolGauges({ total, settled, pending, failed, oldestPendingLagMs }) {\n  const gauges = {\n    lag: Math.max(0, total - settled),\n    pending: Math.max(0, pending),\n    failed: Math.max(0, failed),\n  };\n  if (Number.isFinite(oldestPendingLagMs)) {\n    gauges.oldest_pending_lag_ms = Math.max(0, Math.floor(oldestPendingLagMs));\n  }\n  return gauges;\n}\n\nfunction normalizeMaxRetries(value) {\n  if (value === undefined || value === null) {\n    return 0;\n  }\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) {\n    return 0;\n  }\n  return Math.floor(n);\n}\n\nfunction normalizeNonNegativeDuration(value) {\n  if (value === undefined || value === null) {\n    return 0;\n  }\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) {\n    return 0;\n  }\n  return Math.floor(n);\n}\n\nfunction normalizeLagCeilingAction(value) {\n  if (value === undefined || value === null || value === '') {\n    return null;\n  }\n  const action = String(value).trim();\n  if (action !== LAG_CEILING_ACTION_ABORT_REQUEUE) {\n    throw new TypeError('lagCeilingAction must be \"abort-requeue\" when set');\n  }\n  return action;\n}\n\nfunction normalizeRetryCountMap(value) {\n  const counts = new Map();\n  if (!isRecord(value)) {\n    return counts;\n  }\n  for (const [label, count] of Object.entries(value)) {\n    const n = Number(count);","lineStart":1,"lineEnd":120,"totalLines":902,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","time":{"start":1783487594466,"end":1783487594477}},"metadata":{"openai":{"itemId":"fc_0f5646a3c0dcb475016a4ddc6a53bc81918de5650fc93eda4f"}},"id":"prt_f4024ffd70017eNxtox6kGyQWQ","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f4024dd6e0018D1KbIKIsdY5dI"}}
{"type":"tool_use","timestamp":1783487594497,"sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","part":{"type":"tool","tool":"read","callID":"call_IRR8WiawlZ8IyVY7vwAnor6u","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fanout-run.vitest.ts","offset":1040,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fanout-run.vitest.ts</path>\n<type>file</type>\n<content>\n1040: \n1041:     // Replicas materialize as rep-1 and rep-2.\n1042:     const stateRep1 = join(baseDir, 'lineages', 'rep-1', '.executor-state');\n1043:     const stateRep2 = join(baseDir, 'lineages', 'rep-2', '.executor-state');\n1044:     expect(existsSync(stateRep1)).toBe(true);\n1045:     expect(existsSync(stateRep2)).toBe(true);\n1046:     expect(stateRep1).not.toBe(stateRep2);\n1047: \n1048:     // The stub captured the env each replica actually received; the state dir each\n1049:     // saw must be distinct (this is what the older test never verified).\n1050:     const out1 = readFileSync(join(baseDir, 'lineages', 'rep-1', 'logs', 'fanout-lineage.out'), 'utf8');\n1051:     const out2 = readFileSync(join(baseDir, 'lineages', 'rep-2', 'logs', 'fanout-lineage.out'), 'utf8');\n1052:     const dir1 = /STATE_DIR=(\\S+)/.exec(out1)?.[1];\n1053:     const dir2 = /STATE_DIR=(\\S+)/.exec(out2)?.[1];\n1054:     expect(dir1).toBeTruthy();\n1055:     expect(dir2).toBeTruthy();\n1056:     expect(dir1).not.toBe(dir2);\n1057:     expect(out1).toContain('LINEAGE_ID=rep-1');\n1058:     expect(out2).toContain('LINEAGE_ID=rep-2');\n1059:   });\n1060: });\n1061: \n1062: describe('fanout-run.cjs — non-zero CLI exit is a fan-out failure', () => {\n1063:   it('records exit 3 (all failed) when the only lineage exits non-zero', async () => {\n1064:     const binDir = makeTempDir('fanout-run-fail-bin-');\n1065:     writeFailingStubBinary(binDir, 'opencode', 2);\n1066:     const baseDir = makeTempDir('fanout-run-fail-base-');\n1067: \n1068:     const fanoutConfig = JSON.stringify({\n1069:       executors: [{ label: 'lineage-fail', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n1070:       concurrency: 2,\n1071:     });\n1072: \n1073:     const hermetic = useHermeticEnv('fail-all');\n1074:     const result = await spawnCjs(\n1075:       fanoutRunScript,\n1076:       [\n1077:         '--spec-folder',\n1078:         'specs/test-fanout-run-fail',\n1079:         '--loop-type',\n1080:         'research',\n1081:         '--fanout-config-json',\n1082:         fanoutConfig,\n1083:         '--base-artifact-dir',\n1084:         baseDir,\n1085:       ],\n1086:       {\n1087:         cwd: hermetic.tmpDir,\n1088:         env: envWithBin(hermetic, binDir),\n1089:         timeoutMs: 15_000,\n1090:       },\n1091:     );\n1092: \n1093:     // A single lineage that exits non-zero means all-failed -> exit 3.\n1094:     expect(result.exitCode).toBe(3);\n1095:     const summary = JSON.parse(\n1096:       readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n1097:     ) as { failed?: number; succeeded?: number; all_failed?: boolean };\n1098:     expect(summary.failed).toBe(1);\n1099:     expect(summary.succeeded).toBe(0);\n1100:     expect(summary.all_failed).toBe(true);\n1101:   });\n1102: \n1103:   it('retries a salvage-miss lineage once and exits ok when the retry succeeds', async () => {\n1104:     const binDir = makeTempDir('fanout-run-retry-bin-');\n1105:     const baseDir = makeTempDir('fanout-run-retry-base-');\n1106:     writeFlakySalvageMissStubBinary(binDir, 'opencode', join(baseDir, 'opencode.counter'));\n1107: \n1108:     const fanoutConfig = JSON.stringify({\n1109:       executors: [{ label: 'flaky', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n1110:       concurrency: 1,\n1111:       maxRetries: 1,\n1112:     });\n1113: \n1114:     const hermetic = useHermeticEnv('retry-salvage');\n1115:     const result = await spawnCjs(\n1116:       fanoutRunScript,\n1117:       [\n1118:         '--spec-folder',\n1119:         'specs/test-fanout-run-retry',\n1120:         '--loop-type',\n1121:         'research',\n1122:         '--fanout-config-json',\n1123:         fanoutConfig,\n1124:         '--base-artifact-dir',\n1125:         baseDir,\n1126:       ],\n1127:       {\n1128:         cwd: hermetic.tmpDir,\n1129:         env: envWithBin(hermetic, binDir),\n1130:         timeoutMs: 15_000,\n1131:       },\n1132:     );\n1133: \n1134:     expect(result.exitCode).toBe(0);\n1135:     const summary = JSON.parse(\n1136:       readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n1137:     ) as {\n1138:       failed?: number;\n1139:       succeeded?: number;\n1140:       all_failed?: boolean;\n1141:       results?: Array<{ retry_attempts?: number; status?: string }>;\n1142:     };\n1143:     expect(summary.failed).toBe(0);\n1144:     expect(summary.succeeded).toBe(1);\n1145:     expect(summary.all_failed).toBe(false);\n1146:     const payload = JSON.parse(result.stdout.split('\\n').filter(Boolean).at(-1) ?? '{}') as {\n1147:       results?: Array<{ retry_attempts?: number; status?: string }>;\n1148:     };\n1149:     expect(payload.results?.[0]).toMatchObject({ status: 'fulfilled', retry_attempts: 1 });\n1150: \n1151:     const ledgerLines = readFileSync(join(baseDir, 'orchestration-status.log'), 'utf8')\n1152:       .trim()\n1153:       .split('\\n')\n1154:       .map((line) => JSON.parse(line) as Record<string, unknown>);\n1155:     expect(ledgerLines.filter((event) => event.event === 'retry_scheduled')).toEqual([\n1156:       expect.objectContaining({ label: 'flaky', retry_count: 1, failure_class: 'salvage_miss' }),\n1157:     ]);\n1158:   });\n1159: \n1160:   it('treats an exit-0/no-artifact lineage as salvage-miss and fails it after retry (not fulfilled)', async () => {\n1161:     // Regression guard: a lineage that exited 0 but wrote NO artifact must be treated as a\n1162:     // salvage-miss (retried, then failed if still missing), never counted as fulfilled.\n1163:     // The stub always exits 0 and writes nothing, so this fails (exit 3) iff the invariant holds.\n1164:     const binDir = makeTempDir('fanout-run-noartifact-bin-');\n1165:     const baseDir = makeTempDir('fanout-run-noartifact-base-');\n1166:     writeNoArtifactStubBinary(binDir, 'opencode');\n1167: \n1168:     const fanoutConfig = JSON.stringify({\n1169:       executors: [{ label: 'noart', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n1170:       concurrency: 1,\n1171:       maxRetries: 1,\n1172:     });\n1173: \n1174:     const hermetic = useHermeticEnv('no-artifact');\n1175:     const result = await spawnCjs(\n1176:       fanoutRunScript,\n1177:       [\n1178:         '--spec-folder',\n1179:         'specs/test-fanout-run-noartifact',\n1180:         '--loop-type',\n1181:         'research',\n1182:         '--fanout-config-json',\n1183:         fanoutConfig,\n1184:         '--base-artifact-dir',\n1185:         baseDir,\n1186:       ],\n1187:       {\n1188:         cwd: hermetic.tmpDir,\n1189:         env: envWithBin(hermetic, binDir),\n1190:         timeoutMs: 15_000,\n1191:       },\n1192:     );\n1193: \n1194:     // Exit 3 = all lineages failed; the exit-0/no-artifact lineage must NOT be fulfilled.\n1195:     expect(result.exitCode).toBe(3);\n1196:     const summary = JSON.parse(\n1197:       readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n1198:     ) as { failed?: number; succeeded?: number; all_failed?: boolean };\n1199:     expect(summary.failed).toBe(1);\n1200:     expect(summary.succeeded).toBe(0);\n1201:     expect(summary.all_failed).toBe(true);\n1202: \n1203:     // The lineage must have been classified as salvage_miss and retried before failing.\n1204:     const ledgerLines = readFileSync(join(baseDir, 'orchestration-status.log'), 'utf8')\n1205:       .trim()\n1206:       .split('\\n')\n1207:       .map((line) => JSON.parse(line) as Record<string, unknown>);\n1208:     expect(ledgerLines.filter((event) => event.event === 'retry_scheduled')).toEqual([\n1209:       expect.objectContaining({ label: 'noart', retry_count: 1, failure_class: 'salvage_miss' }),\n1210:     ]);\n1211:   });\n1212: \n1213:   it('records exit 2 (some failed) when one of two lineages exits non-zero', async () => {\n1214:     const binDir = makeTempDir('fanout-run-mixed-bin-');\n1215:     // opencode stub fails; claude stub succeeds.\n1216:     writeFailingStubBinary(binDir, 'opencode', 5);\n1217:     writeStubBinary(binDir, 'claude');\n1218:     const baseDir = makeTempDir('fanout-run-mixed-base-');\n1219: \n1220:     const fanoutConfig = JSON.stringify({\n1221:       executors: [\n1222:         { label: 'fails', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 },\n1223:         { label: 'passes', kind: 'cli-claude-code', model: 'claude-opus-4-8', count: 1 },\n1224:       ],\n1225:       concurrency: 2,\n1226:     });\n1227: \n1228:     const hermetic = useHermeticEnv('mixed-failure');\n1229:     const result = await spawnCjs(\n1230:       fanoutRunScript,\n1231:       [\n1232:         '--spec-folder',\n1233:         'specs/test-fanout-run-mixed',\n1234:         '--loop-type',\n1235:         'research',\n1236:         '--fanout-config-json',\n1237:         fanoutConfig,\n1238:         '--base-artifact-dir',\n1239:         baseDir,\n1240:       ],\n1241:       {\n1242:         cwd: hermetic.tmpDir,\n1243:         env: envWithBin(hermetic, binDir),\n1244:         timeoutMs: 15_000,\n1245:       },\n1246:     );\n1247: \n1248:     expect(result.exitCode).toBe(2);\n1249:     const summary = JSON.parse(\n1250:       readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n1251:     ) as { failed?: number; succeeded?: number; all_failed?: boolean };\n1252:     expect(summary.failed).toBe(1);\n1253:     expect(summary.succeeded).toBe(1);\n1254:     expect(summary.all_failed).toBe(false);\n1255:   });\n1256: });\n1257: \n1258: describe('fanout-run.cjs — lineages run concurrently (not serialized by spawnSync)', () => {\n1259:   it('runs two ~1s lineages in roughly 1s wall-clock with concurrency 2', async () => {\n\n(Showing lines 1040-1259 of 2044. Use offset=1260 to continue.)\n</content>","metadata":{"preview":"\n    // Replicas materialize as rep-1 and rep-2.\n    const stateRep1 = join(baseDir, 'lineages', 'rep-1', '.executor-state');\n    const stateRep2 = join(baseDir, 'lineages', 'rep-2', '.executor-state');\n    expect(existsSync(stateRep1)).toBe(true);\n    expect(existsSync(stateRep2)).toBe(true);\n    expect(stateRep1).not.toBe(stateRep2);\n\n    // The stub captured the env each replica actually received; the state dir each\n    // saw must be distinct (this is what the older test never verified).\n    const out1 = readFileSync(join(baseDir, 'lineages', 'rep-1', 'logs', 'fanout-lineage.out'), 'utf8');\n    const out2 = readFileSync(join(baseDir, 'lineages', 'rep-2', 'logs', 'fanout-lineage.out'), 'utf8');\n    const dir1 = /STATE_DIR=(\\S+)/.exec(out1)?.[1];\n    const dir2 = /STATE_DIR=(\\S+)/.exec(out2)?.[1];\n    expect(dir1).toBeTruthy();\n    expect(dir2).toBeTruthy();\n    expect(dir1).not.toBe(dir2);\n    expect(out1).toContain('LINEAGE_ID=rep-1');\n    expect(out2).toContain('LINEAGE_ID=rep-2');\n  });","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fanout-run.vitest.ts","text":"\n    // Replicas materialize as rep-1 and rep-2.\n    const stateRep1 = join(baseDir, 'lineages', 'rep-1', '.executor-state');\n    const stateRep2 = join(baseDir, 'lineages', 'rep-2', '.executor-state');\n    expect(existsSync(stateRep1)).toBe(true);\n    expect(existsSync(stateRep2)).toBe(true);\n    expect(stateRep1).not.toBe(stateRep2);\n\n    // The stub captured the env each replica actually received; the state dir each\n    // saw must be distinct (this is what the older test never verified).\n    const out1 = readFileSync(join(baseDir, 'lineages', 'rep-1', 'logs', 'fanout-lineage.out'), 'utf8');\n    const out2 = readFileSync(join(baseDir, 'lineages', 'rep-2', 'logs', 'fanout-lineage.out'), 'utf8');\n    const dir1 = /STATE_DIR=(\\S+)/.exec(out1)?.[1];\n    const dir2 = /STATE_DIR=(\\S+)/.exec(out2)?.[1];\n    expect(dir1).toBeTruthy();\n    expect(dir2).toBeTruthy();\n    expect(dir1).not.toBe(dir2);\n    expect(out1).toContain('LINEAGE_ID=rep-1');\n    expect(out2).toContain('LINEAGE_ID=rep-2');\n  });\n});\n\ndescribe('fanout-run.cjs — non-zero CLI exit is a fan-out failure', () => {\n  it('records exit 3 (all failed) when the only lineage exits non-zero', async () => {\n    const binDir = makeTempDir('fanout-run-fail-bin-');\n    writeFailingStubBinary(binDir, 'opencode', 2);\n    const baseDir = makeTempDir('fanout-run-fail-base-');\n\n    const fanoutConfig = JSON.stringify({\n      executors: [{ label: 'lineage-fail', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n      concurrency: 2,\n    });\n\n    const hermetic = useHermeticEnv('fail-all');\n    const result = await spawnCjs(\n      fanoutRunScript,\n      [\n        '--spec-folder',\n        'specs/test-fanout-run-fail',\n        '--loop-type',\n        'research',\n        '--fanout-config-json',\n        fanoutConfig,\n        '--base-artifact-dir',\n        baseDir,\n      ],\n      {\n        cwd: hermetic.tmpDir,\n        env: envWithBin(hermetic, binDir),\n        timeoutMs: 15_000,\n      },\n    );\n\n    // A single lineage that exits non-zero means all-failed -> exit 3.\n    expect(result.exitCode).toBe(3);\n    const summary = JSON.parse(\n      readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n    ) as { failed?: number; succeeded?: number; all_failed?: boolean };\n    expect(summary.failed).toBe(1);\n    expect(summary.succeeded).toBe(0);\n    expect(summary.all_failed).toBe(true);\n  });\n\n  it('retries a salvage-miss lineage once and exits ok when the retry succeeds', async () => {\n    const binDir = makeTempDir('fanout-run-retry-bin-');\n    const baseDir = makeTempDir('fanout-run-retry-base-');\n    writeFlakySalvageMissStubBinary(binDir, 'opencode', join(baseDir, 'opencode.counter'));\n\n    const fanoutConfig = JSON.stringify({\n      executors: [{ label: 'flaky', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n      concurrency: 1,\n      maxRetries: 1,\n    });\n\n    const hermetic = useHermeticEnv('retry-salvage');\n    const result = await spawnCjs(\n      fanoutRunScript,\n      [\n        '--spec-folder',\n        'specs/test-fanout-run-retry',\n        '--loop-type',\n        'research',\n        '--fanout-config-json',\n        fanoutConfig,\n        '--base-artifact-dir',\n        baseDir,\n      ],\n      {\n        cwd: hermetic.tmpDir,\n        env: envWithBin(hermetic, binDir),\n        timeoutMs: 15_000,\n      },\n    );\n\n    expect(result.exitCode).toBe(0);\n    const summary = JSON.parse(\n      readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n    ) as {\n      failed?: number;\n      succeeded?: number;\n      all_failed?: boolean;\n      results?: Array<{ retry_attempts?: number; status?: string }>;\n    };\n    expect(summary.failed).toBe(0);\n    expect(summary.succeeded).toBe(1);\n    expect(summary.all_failed).toBe(false);\n    const payload = JSON.parse(result.stdout.split('\\n').filter(Boolean).at(-1) ?? '{}') as {\n      results?: Array<{ retry_attempts?: number; status?: string }>;\n    };\n    expect(payload.results?.[0]).toMatchObject({ status: 'fulfilled', retry_attempts: 1 });\n\n    const ledgerLines = readFileSync(join(baseDir, 'orchestration-status.log'), 'utf8')\n      .trim()\n      .split('\\n')\n      .map((line) => JSON.parse(line) as Record<string, unknown>);\n    expect(ledgerLines.filter((event) => event.event === 'retry_scheduled')).toEqual([\n      expect.objectContaining({ label: 'flaky', retry_count: 1, failure_class: 'salvage_miss' }),\n    ]);\n  });\n\n  it('treats an exit-0/no-artifact lineage as salvage-miss and fails it after retry (not fulfilled)', async () => {\n    // Regression guard: a lineage that exited 0 but wrote NO artifact must be treated as a\n    // salvage-miss (retried, then failed if still missing), never counted as fulfilled.\n    // The stub always exits 0 and writes nothing, so this fails (exit 3) iff the invariant holds.\n    const binDir = makeTempDir('fanout-run-noartifact-bin-');\n    const baseDir = makeTempDir('fanout-run-noartifact-base-');\n    writeNoArtifactStubBinary(binDir, 'opencode');\n\n    const fanoutConfig = JSON.stringify({\n      executors: [{ label: 'noart', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 }],\n      concurrency: 1,\n      maxRetries: 1,\n    });\n\n    const hermetic = useHermeticEnv('no-artifact');\n    const result = await spawnCjs(\n      fanoutRunScript,\n      [\n        '--spec-folder',\n        'specs/test-fanout-run-noartifact',\n        '--loop-type',\n        'research',\n        '--fanout-config-json',\n        fanoutConfig,\n        '--base-artifact-dir',\n        baseDir,\n      ],\n      {\n        cwd: hermetic.tmpDir,\n        env: envWithBin(hermetic, binDir),\n        timeoutMs: 15_000,\n      },\n    );\n\n    // Exit 3 = all lineages failed; the exit-0/no-artifact lineage must NOT be fulfilled.\n    expect(result.exitCode).toBe(3);\n    const summary = JSON.parse(\n      readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n    ) as { failed?: number; succeeded?: number; all_failed?: boolean };\n    expect(summary.failed).toBe(1);\n    expect(summary.succeeded).toBe(0);\n    expect(summary.all_failed).toBe(true);\n\n    // The lineage must have been classified as salvage_miss and retried before failing.\n    const ledgerLines = readFileSync(join(baseDir, 'orchestration-status.log'), 'utf8')\n      .trim()\n      .split('\\n')\n      .map((line) => JSON.parse(line) as Record<string, unknown>);\n    expect(ledgerLines.filter((event) => event.event === 'retry_scheduled')).toEqual([\n      expect.objectContaining({ label: 'noart', retry_count: 1, failure_class: 'salvage_miss' }),\n    ]);\n  });\n\n  it('records exit 2 (some failed) when one of two lineages exits non-zero', async () => {\n    const binDir = makeTempDir('fanout-run-mixed-bin-');\n    // opencode stub fails; claude stub succeeds.\n    writeFailingStubBinary(binDir, 'opencode', 5);\n    writeStubBinary(binDir, 'claude');\n    const baseDir = makeTempDir('fanout-run-mixed-base-');\n\n    const fanoutConfig = JSON.stringify({\n      executors: [\n        { label: 'fails', kind: 'cli-opencode', model: 'opencode-go/glm-5.1', count: 1 },\n        { label: 'passes', kind: 'cli-claude-code', model: 'claude-opus-4-8', count: 1 },\n      ],\n      concurrency: 2,\n    });\n\n    const hermetic = useHermeticEnv('mixed-failure');\n    const result = await spawnCjs(\n      fanoutRunScript,\n      [\n        '--spec-folder',\n        'specs/test-fanout-run-mixed',\n        '--loop-type',\n        'research',\n        '--fanout-config-json',\n        fanoutConfig,\n        '--base-artifact-dir',\n        baseDir,\n      ],\n      {\n        cwd: hermetic.tmpDir,\n        env: envWithBin(hermetic, binDir),\n        timeoutMs: 15_000,\n      },\n    );\n\n    expect(result.exitCode).toBe(2);\n    const summary = JSON.parse(\n      readFileSync(join(baseDir, 'orchestration-summary.json'), 'utf8'),\n    ) as { failed?: number; succeeded?: number; all_failed?: boolean };\n    expect(summary.failed).toBe(1);\n    expect(summary.succeeded).toBe(1);\n    expect(summary.all_failed).toBe(false);\n  });\n});\n\ndescribe('fanout-run.cjs — lineages run concurrently (not serialized by spawnSync)', () => {\n  it('runs two ~1s lineages in roughly 1s wall-clock with concurrency 2', async () => {","lineStart":1040,"lineEnd":1259,"totalLines":2044,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/tests/unit/fanout-run.vitest.ts","time":{"start":1783487594492,"end":1783487594496}},"metadata":{"openai":{"itemId":"fc_0f5646a3c0dcb475016a4ddc6a53c08191b8b13e99dea70b47"}},"id":"prt_f4024ffe9001L6gvfQhsJmIwnP","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f4024dd6e0018D1KbIKIsdY5dI"}}
