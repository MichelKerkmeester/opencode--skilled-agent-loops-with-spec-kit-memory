ine 69: export { ollamaEmbedding } from \"./janitor/providers/ollama.js\";\n\n  Line 70: export { openaiEmbedding } from \"./janitor/providers/openai.js\";\n\n  Line 71: export { openrouterEmbedding } from \"./janitor/providers/openrouter.js\";\n\n  Line 87:   registerJanitorSchedule, startJanitorScheduler,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/__tests__/events/crossProcess.test.ts:\n  Line 9: import { SETTING_KEYS, SETTING_DEFAULTS } from \"../../janitor/providers/types.js\";\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/embeddings.ts:\n  Line 65:  * Used by the janitor backfill job and SessionStart hint.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/types.ts:\n  Line 84:   | \"user-promotion\" | \"janitor-rollup\" | \"legacy\";\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/__tests__/scheduler/index.test.ts:\n  Line 2:  * scheduler/index.test.ts — dormant-path contract for the Honker janitor cron.\n\n  Line 4:  * must degrade to graceful no-ops so the caller keeps startAutoRun()+HTTP poll.\n\n  Line 8:   registerJanitorSchedule,\n\n  Line 9:   startJanitorScheduler,\n\n  Line 24:     expect(JANITOR_SCHEDULE_NAME).toBe(\"ltm-janitor\");\n\n  Line 25:     expect(JANITOR_QUEUE).toBe(\"ltm-janitor-queue\");\n\n  Line 26:     expect(JANITOR_CHANNEL).toBe(\"janitor\");\n\n  Line 30:   it(\"registerJanitorSchedule returns false when honker is unavailable\", () => {\n\n  Line 31:     expect(registerJanitorSchedu