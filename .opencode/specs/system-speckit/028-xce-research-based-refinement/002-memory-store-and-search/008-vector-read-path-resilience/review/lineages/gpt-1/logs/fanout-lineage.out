advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts\",\n          \"sourceLine\": 83,\n          \"expectedTopK\": [\n            \"getPreparedStatements\",\n            \"dependsOn\",\n            \"transitivePath\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-skill-advisor/mcp_server/lib/skill-graph/skill-graph-queries.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-007\",\n          \"category\": \"regression-detection\",\n          \"query\": \"detect_changes hard block stale graph false safe empty\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/handlers/detect-changes.ts\",\n          \"sourceLine\": 69,\n          \"expectedTopK\": [\n            \"handleDetectChanges\",\n            \"readinessRequiresBlock\",\n            \"blockedResponse\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/handlers/detect-changes.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        },\n        {\n          \"queryId\": \"GQ-REG-008\",\n          \"category\": \"regression-detection\",\n          \"query\": \"phase runner scan phases find candidates parse candidates finalize emit metrics\",\n          \"sourceFile\": \".opencode/skills/system-code-graph/mcp_server/lib/phase-runner.ts\",\n          \"sourceLine\": 266,\n          \"expectedTopK\": [\n            \"runPhases\",\n            \"PhaseRunnerError\",\n            \"topologicalSort\"\n          ],\n          \"probe\": {\n            \"operation\": \"outline\",\n            \"subject\": \".opencode/skills/system-code-graph/mcp_server/lib/phase-runner.ts\",\n            \"limit\": 200\n          },\n          \"matchedSymbols\": [],\n          \"missingSymbols\": [],\n          \"status\": \"passed\"\n        }\n      ]\n    },\n    \"verificationPassPolicy\": {\n      \"overall_pass_rate\": 0.9,\n      \"edge_focus_pass_rate\": 0.8\n    },\n    \"apply\": {\n      \"lastRunAt\": null,\n      \"lastResult\": null,\n      \"batteryPassRate\": null\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781151261298,"end":1781151262478}},"metadata":{"openai":{"itemId":"fc_09b5643023294f6d016a2a361d1abc8191a903ffa88274ec6c"}},"id":"prt_eb4e36262001pzXFC5iec7BZ70","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3446a001ZqTbweZE3DWfMG"}}
