ers: net.Server[] = [];\n38: \n39: function tempDir(prefix: string): string {\n40:   const dir = mkdtempSync(join(tempRoot, prefix));\n41:   tempDirs.push(dir);\n42:   return dir;\n43: }\n44: \n45: async function listenTcp(server: net.Server): Promise<string | null> {\n46:   const listened = await new Promise<boolean>((resolvePromise, reject) => {\n47:     server.once('error', (error: NodeJS.ErrnoException) => {\n48:       if (error.code === 'EPERM') {\n49:         resolvePromise(false);\n50:         return;\n51:       }\n52:       reject(error);\n53:     });\n54:     server.listen(0, '127.0.0.1', () => {\n55:       resolvePromise(true);\n56:     });\n57:   });\n58:   if (!listened) return null;\n59:   servers.push(server);\n60:   const address = server.address();\n61:   if (!address || typeof address === 'string') {\n62:     throw new Error('TCP test server did not expose an address');\n63:   }\n64:   return `tcp://${address.address}:${address.port}`;\n65: }\n66: \n67: function connectionTarget(endpoint: string): string | net.NetConnectOpts {\n68:   if (!endpoint.startsWith('tcp://')) {\n69:     return endpoint;\n70:   }\n71:   const url = new URL(endpoint);\n72:   return { host: url.hostname, port: Number.parseInt(url.port, 10) };\n73: }\n74: \n75: function makeServer(): Server {\n76:   const server = new Server(\n77:     { name: 'test-bridge', version: '0.0.0' },\n78:     { capabilities: { tools: {} } },\n79:   );\n80:   server.setRequestHandler(ListToolsRequestSchema, async () => ({\n81:     tools: [\n82:       {\n83:         name: 'ping',\n84:         description: 'test tool',\n85:         inputSchema: { type: 'object', properties: {} },\n86:       },\n87:     ],\n88:   }));\n89:   return server;\n90: }\n\n(Showing lines 1-90 of 337. Use offset=91 to continue.)\n</content>","metadata":{"preview":"import { spawn, type ChildProcessWithoutNullStreams } from 'node:child_process';\nimport { createRequire } from 'node:module';\nimport net from 'node:net';\nimport { PassThrough } from 'node:stream';\nimport {\n  copyFileSync,\n  cpSync,\n  mkdirSync,\n  mkdtempSync,\n  rmSync,\n  writeFileSync,\n} from 'node:fs';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { Server } from '@modelcontextprotocol/sdk/server/index.js';\nimport { ListToolsRequestSchema } from '@modelcontextprotocol/sdk/types.js';\nimport { afterEach, describe, expect, it } from 'vitest';\n\nimport {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts","text":"import { spawn, type ChildProcessWithoutNullStreams } from 'node:child_process';\nimport { createRequire } from 'node:module';\nimport net from 'node:net';\nimport { PassThrough } from 'node:stream';\nimport {\n  copyFileSync,\n  cpSync,\n  mkdirSync,\n  mkdtempSync,\n  rmSync,\n  writeFileSync,\n} from 'node:fs';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { Server } from '@modelcontextprotocol/sdk/server/index.js';\nimport { ListToolsRequestSchema } from '@modelcontextprotocol/sdk/types.js';\nimport { afterEach, describe, expect, it } from 'vitest';\n\nimport {\n  getIpcBridgeStats,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n  type IpcSocketServerHandle,\n} from '../lib/ipc/socket-server.js';\n\nconst require = createRequire(import.meta.url);\nconst repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../..');\nconst tempRoot = '/private/tmp';\nconst bridgeModule = require('../../../../bin/lib/launcher-ipc-bridge.cjs') as {\n  bridgeStdioToSocket: (socketPath: string, options?: Record<string, unknown>) => net.Socket;\n};\n\nconst tempDirs: string[] = [];\nconst children: ChildProcessWithoutNullStreams[] = [];\nconst handles: IpcSocketServerHandle[] = [];\nconst servers: net.Server[] = [];\n\nfunction tempDir(prefix: string): string {\n  const dir = mkdtempSync(join(tempRoot, prefix));\n  tempDirs.push(dir);\n  return dir;\n}\n\nasync function listenTcp(server: net.Server): Promise<string | null> {\n  const listened = await new Promise<boolean>((resolvePromise, reject) => {\n    server.once('error', (error: NodeJS.ErrnoException) => {\n      if (error.code === 'EPERM') {\n        resolvePromise(false);\n        return;\n      }\n      reject(error);\n    });\n    server.listen(0, '127.0.0.1', () => {\n      resolvePromise(true);\n    });\n  });\n  if (!listened) return null;\n  servers.push(server);\n  const address = server.address();\n  if (!address || typeof address === 'string') {\n    throw new Error('TCP test server did not expose an address');\n  }\n  return `tcp://${address.address}:${address.port}`;\n}\n\nfunction connectionTarget(endpoint: string): string | net.NetConnectOpts {\n  if (!endpoint.startsWith('tcp://')) {\n    return endpoint;\n  }\n  const url = new URL(endpoint);\n  return { host: url.hostname, port: Number.parseInt(url.port, 10) };\n}\n\nfunction makeServer(): Server {\n  const server = new Server(\n    { name: 'test-bridge', version: '0.0.0' },\n    { capabilities: { tools: {} } },\n  );\n  server.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: [\n      {\n        name: 'ping',\n        description: 'test tool',\n        inputSchema: { type: 'object', properties: {} },\n      },\n    ],\n  }));\n  return server;\n}","lineStart":1,"lineEnd":90,"totalLines":337,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts","time":{"start":1781761630644,"end":1781761630647}},"metadata":{"openai":{"itemId":"fc_09b72d3b0de8a697016a33865e47708191857948c15e6ecf24"}},"id":"prt_ed944e049001v7OAGJoKIdeSl4","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed9449255001mSIwd3yEwTl5IR"}}
