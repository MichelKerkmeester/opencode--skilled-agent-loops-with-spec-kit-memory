   277	function run(command, args, options = {}) {
   278	  const result = spawnSync(command, args, {
   279	    cwd: options.cwd || root,
   280	    env: createChildEnv(),
   281	    encoding: 'utf8',
   282	    stdio: ['ignore', 'pipe', 'pipe'],
   283	  });
