{"type":"tool_use","timestamp":1780727679414,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_VtlUlo2jXQu5J4hA9Fz7LBnb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py</path>\n<type>file</type>\n<content>\n1: import asyncio\n2: import logging\n3: import re\n4: import time\n5: from datetime import UTC, datetime\n6: from uuid import UUID\n7: \n8: import httpx\n9: from fastapi import (\n10:     APIRouter,\n11:     Body,\n12:     Depends,\n13:     File,\n14:     Form,\n15:     Header,\n16:     HTTPException,\n17:     Query,\n18:     Request,\n19:     Response,\n20:     UploadFile,\n21: )\n22: from fastapi.responses import JSONResponse\n23: from sqlalchemy import func, select, tuple_, update\n24: from sqlalchemy.exc import OperationalError, SQLAlchemyError\n25: from sqlalchemy.exc import TimeoutError as SQLATimeoutError\n26: from sqlalchemy.ext.asyncio import AsyncSession\n27: \n28: from common.enrichment.constants import SERVER_RESERVED_MEMORY_TYPES\n29: from common.models.memory import Memory\n30: from core_api.auth import AuthContext, get_auth_context\n31: from core_api.clients.storage_client import get_storage_client\n32: from core_api.config import settings as app_settings\n33: from core_api.constants import (\n34:     DEFAULT_LIST_LIMIT,\n35:     MAX_LIST_LIMIT,\n36:     MEMORY_VISIBILITY_SCOPE_AGENT,\n37: )\n38: from core_api.db.session import get_db\n39: from core_api.middleware.idempotency import (\n40:     IDEMPOTENCY_HEADER,\n41:     IdempotencyGuard,\n42:     idempotency_for,\n43:     idempotency_key_from_metadata,\n44: )\n45: from core_api.middleware.per_tenant_concurrency import per_tenant_slot\n46: from core_api.middleware.rate_limit import search_limit, write_bulk_limit, write_limit\n47: from core_api.pagination import decode_cursor, encode_cursor, paginated_order_by\n48: from core_api.schemas import (\n49:     BulkMemoryCreate,\n50:     BulkMemoryResponse,\n51:     IngestCommitRequest,\n52:     IngestRequest,\n53:     MemoryCreate,\n54:     MemoryOut,\n55:     MemoryUpdate,\n56:     PaginatedMemoryResponse,\n57:     RedistributeRequest,\n58:     RedistributeResponse,\n59:     SearchRequest,\n60:     SearchResponse,\n61:     STMWriteResponse,\n62:     UsageSummary,\n63: )\n64: from core_api.services.agent_service import (\n65:     authorize_memory_access,\n66:     enforce_delete,\n67:     enforce_fleet_read,\n68:     enforce_fleet_write,\n69:     enforce_memory_read,\n70:     get_or_create_agent,\n71:     lookup_agent,\n72: )\n73: from core_api.services.audit_service import log_action, log_cross_tenant_read\n74: from core_api.services.ingest_service import (\n75:     ALLOWED_INGEST_MIME_TYPES,\n76:     BINARY_INGEST_MIME_TYPES,\n77:     INGEST_DOCUMENTS_COLLECTION,\n78:     INGEST_MAX_INPUT_BYTES,\n79:     TEXT_INGEST_MIME_TYPES,\n80:     _extract_with_kreuzberg,\n81:     decode_text_body,\n82:     ingest_commit,\n83:     ingest_preview,\n84: )\n85: from core_api.services.memory_service import (\n86:     _memory_to_out,\n87:     create_memories_bulk,\n88:     create_memory,\n89:     search_memories,\n90:     soft_delete_memory,\n91:     update_memory,\n92: )\n93: from core_api.services.tenants import list_active_tenant_ids\n94: from core_api.services.usage_service import bulk_check_and_increment, check_and_increment\n95: \n96: logger = logging.getLogger(__name__)\n97: \n98: router = APIRouter(tags=[\"Memory\"])\n99: \n100: \n101: def _reject_reserved_memory_type(memory_type: str | None, *, index: int | None = None) -> None:\n102:     \"\"\"C3/C8 — reject agent-supplied reserved memory types at the API boundary.\n103: \n104:     Reserved types (``outcome``, ``rule``, ``insight``) are emitted by the\n105:     server's internal write paths — evolve_service for outcome/rule,\n106:     insights_service for insight. Agents writing them explicitly creates\n107:     rows that downstream queries treat as system-authored, polluting\n108:     insights / RL signals. Internal callers go through\n109:     ``services.memory_service.create_memory`` directly and bypass this\n110:     check; only the REST + MCP entry points are gated.\n111: \n112:     ``index`` names the offending row in a bulk request so the operator\n113:     can find it; absent on the single-write path.\n114:     \"\"\"\n115:     if memory_type is None or memory_type not in SERVER_RESERVED_MEMORY_TYPES:\n116:         return\n117:     # ``memory_type`` is a ``MemoryType`` str-Enum value; ``!r`` would render\n118:     # ``<MemoryType.INSIGHT: 'insight'>`` which leaks the wrapper into the\n119:     # operator-facing message. ``.value`` (when present) gives the raw slug\n120:     # the API actually accepts; plain ``str(...)`` is the fallback.\n121:     slug = memory_type.value if hasattr(memory_type, \"value\") else str(memory_type)\n122:     detail = (\n123:         f\"memory_type='{slug}' is server-reserved and cannot be \"\n124:         \"supplied on writes. Use memclaw_evolve for outcome/rule or \"\n125:         \"memclaw_insights for insight; for agent-authored reflections, \"\n126:         \"use memory_type='semantic' or 'fact' (or omit memory_type to \"\n127:         \"auto-classify).\"\n128:     )\n129:     if index is not None:\n130:         detail = f\"items[{index}]: {detail}\"\n131:     raise HTTPException(status_code=422, detail=detail)\n132: \n133: \n134: async def _stats_fallback(tenant_id: str, fleet_id: str | None) -> dict:\n135:     \"\"\"Map storage-api's ``memory_compute_health_stats`` shape onto the\n136:     flat ``{total, by_type, by_agent, by_status}`` shape both stats\n137:     endpoints return. ``by_agent`` is empty because storage-api doesn't\n138:     compute it; ``partial: True`` flags the degradation so callers can\n139:     distinguish a real empty tenant from a degraded response.\n140: \n141:     The two stats routes return bare dicts (no ``response_model``), so\n142:     the ``partial`` field survives FastAPI serialisation. If a\n143:     ``response_model`` is added later, include ``partial`` in the schema\n144:     or the degradation signal will be silently stripped.\n145:     \"\"\"\n146:     try:\n147:         fallback = await get_storage_client().get_memory_stats(tenant_id=tenant_id, fleet_id=fleet_id)\n148:     except httpx.HTTPError as exc:\n149:         # Storage-api is also down. Without this catch the httpx\n150:         # exception would propagate through the route's ``except`` block\n151:         # as a 500 with raw internal detail (storage-api URL, etc.).\n152:         logger.warning(\n153:             \"memory_stats fallback: storage-api request failed\",\n154:             extra={\"tenant_id\": tenant_id, \"fleet_id\": fleet_id, \"error\": str(exc)},\n155:             exc_info=True,\n156:         )\n157:         raise HTTPException(\n158:             status_code=503,\n159:             detail=\"memory stats unavailable: primary DB and storage-api fallback both failed\",\n160:         ) from None\n161:     if not fallback:\n162:         # ``storage_client._get`` returns ``{}`` on 404 (treated as\n163:         # absent). The httpx-error case is handled above. So an empty\n164:         # ``fallback`` here means storage-api 404'd, but since we got\n165:         # here only because the primary DB blew up, we can't tell a\n166:         # real empty tenant from a storage-api hiccup. 503 surfaces the\n167:         # cascading failure instead of returning a plausible-looking\n168:         # ``total: 0`` to a live tenant.\n169:         logger.warning(\n170:             \"memory_stats fallback: storage-api returned 404 or empty response \"\n171:             \"(cannot distinguish empty tenant from cascading failure)\",\n172:             extra={\"tenant_id\": tenant_id, \"fleet_id\": fleet_id},\n173:         )\n174:         raise HTTPException(\n175:             status_code=503,\n176:             detail=\"memory stats unavailable: primary DB and storage-api fallback both failed\",\n177:         ) from None\n178:     return {\n179:         \"total\": fallback.get(\"total\", fallback.get(\"total_memories\", 0)),\n180:         \"by_type\": fallback.get(\"type_distribution\", {}),\n181:         \"by_agent\": {},\n182:         \"by_status\": fallback.get(\"status_distribution\", {}),\n183:         \"partial\": True,\n184:     }\n185: \n186: \n187: @router.get(\"/tenants\")\n188: async def list_tenants(\n189:     auth: AuthContext = Depends(get_auth_context),\n190:     db: AsyncSession = Depends(get_db),\n191: ):\n192:     \"\"\"Return distinct tenant IDs that have memories.\"\"\"\n193:     auth.enforce_admin()\n194:     result = await db.execute(select(Memory.tenant_id).where(Memory.deleted_at.is_(None)).distinct())\n195:     return sorted([row[0] for row in result.all()])\n196: \n197: \n198: @router.get(\"/fleets\")\n199: async def list_fleets(\n200:     tenant_id: str | None = Query(default=None),\n201:     auth: AuthContext = Depends(get_auth_context),\n202:     db: AsyncSession = Depends(get_db),\n203: ):\n204:     \"\"\"Return distinct fleet_ids with memory counts.\"\"\"\n205:     if tenant_id:\n206:         # Read endpoint — honors cross-tenant readable set.\n207:         auth.enforce_readable_tenant(tenant_id)\n208:     elif not auth.is_admin:\n209:         # Non-admin must specify a tenant_id\n210:         if not auth.tenant_id:\n211:             raise HTTPException(status_code=400, detail=\"tenant_id is required\")\n212:         tenant_id = auth.tenant_id\n213:     filters = [\n214:         Memory.deleted_at.is_(None),\n215:         Memory.fleet_id.isnot(None),\n216:         # No ``agent_id`` accepted on this route, so there's no caller\n217:         # identity that could legitimately see ``scope_agent`` rows.\n218:         # Exclude them the same way ``memory_repository.list_by_filters``\n219:         # does (line 137) and ``/memories/stats`` does. Without this,\n220:         # ``memory_count``/``agent_count`` overstate what\n221:         # ``GET /api/v1/memories?fleet_id=X`` would actually return.\n222:         # ``Memory.visibility`` is ``nullable=False`` with a server\n223:         # default (common/models/memory.py:62-66), so the SQL three-\n224:         # valued-logic pitfall (NULL != 'scope_agent' = NULL → row\n225:         # silently dropped) doesn't apply here.\n226:         Memory.visibility != MEMORY_VISIBILITY_SCOPE_AGENT,\n227:     ]\n228:     if tenant_id:\n229:         filters.append(Memory.tenant_id == tenant_id)\n230:     rows = (\n231:         await db.execute(\n232:             select(\n233:                 Memory.fleet_id,\n234:                 func.count(),\n235:                 func.count(func.distinct(Memory.agent_id)),\n236:             )\n237:             .where(*filters)\n238:             .group_by(Memory.fleet_id)\n239:             .order_by(func.count().desc())\n240:         )\n241:     ).all()\n242:     return [{\"fleet_id\": r[0], \"memory_count\": r[1], \"agent_count\": r[2]} for r in rows]\n243: \n244: \n245: @router.get(\"/memories\", response_model=PaginatedMemoryResponse)\n246: async def list_memories(\n247:     tenant_id: str | None = Query(default=None),\n248:     fleet_id: str | None = Query(default=None),\n249:     agent_id: str | None = Query(default=None),\n250:     memory_type: str | None = Query(default=None),\n251:     status: str | None = Query(default=None),\n252:     visibility: str | None = Query(default=None),\n253:     run_id: str | None = Query(default=None),\n254:     cursor: str | None = Query(default=None),\n255:     sort: str = Query(\n256:         default=\"created_at\",\n257:         pattern=r\"^(created_at|weight|memory_type|agent_id|status|recall_count|fleet_id|tenant_id|expires_at|deleted_at)$\",\n258:     ),\n259:     order: str = Query(default=\"desc\", pattern=r\"^(asc|desc)$\"),\n260:     offset: int = Query(default=0, ge=0),\n\n(Showing lines 1-260 of 2023. Use offset=261 to continue.)\n</content>","metadata":{"preview":"import asyncio\nimport logging\nimport re\nimport time\nfrom datetime import UTC, datetime\nfrom uuid import UUID\n\nimport httpx\nfrom fastapi import (\n    APIRouter,\n    Body,\n    Depends,\n    File,\n    Form,\n    Header,\n    HTTPException,\n    Query,\n    Request,\n    Response,\n    UploadFile,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","text":"import asyncio\nimport logging\nimport re\nimport time\nfrom datetime import UTC, datetime\nfrom uuid import UUID\n\nimport httpx\nfrom fastapi import (\n    APIRouter,\n    Body,\n    Depends,\n    File,\n    Form,\n    Header,\n    HTTPException,\n    Query,\n    Request,\n    Response,\n    UploadFile,\n)\nfrom fastapi.responses import JSONResponse\nfrom sqlalchemy import func, select, tuple_, update\nfrom sqlalchemy.exc import OperationalError, SQLAlchemyError\nfrom sqlalchemy.exc import TimeoutError as SQLATimeoutError\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom common.enrichment.constants import SERVER_RESERVED_MEMORY_TYPES\nfrom common.models.memory import Memory\nfrom core_api.auth import AuthContext, get_auth_context\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings as app_settings\nfrom core_api.constants import (\n    DEFAULT_LIST_LIMIT,\n    MAX_LIST_LIMIT,\n    MEMORY_VISIBILITY_SCOPE_AGENT,\n)\nfrom core_api.db.session import get_db\nfrom core_api.middleware.idempotency import (\n    IDEMPOTENCY_HEADER,\n    IdempotencyGuard,\n    idempotency_for,\n    idempotency_key_from_metadata,\n)\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_slot\nfrom core_api.middleware.rate_limit import search_limit, write_bulk_limit, write_limit\nfrom core_api.pagination import decode_cursor, encode_cursor, paginated_order_by\nfrom core_api.schemas import (\n    BulkMemoryCreate,\n    BulkMemoryResponse,\n    IngestCommitRequest,\n    IngestRequest,\n    MemoryCreate,\n    MemoryOut,\n    MemoryUpdate,\n    PaginatedMemoryResponse,\n    RedistributeRequest,\n    RedistributeResponse,\n    SearchRequest,\n    SearchResponse,\n    STMWriteResponse,\n    UsageSummary,\n)\nfrom core_api.services.agent_service import (\n    authorize_memory_access,\n    enforce_delete,\n    enforce_fleet_read,\n    enforce_fleet_write,\n    enforce_memory_read,\n    get_or_create_agent,\n    lookup_agent,\n)\nfrom core_api.services.audit_service import log_action, log_cross_tenant_read\nfrom core_api.services.ingest_service import (\n    ALLOWED_INGEST_MIME_TYPES,\n    BINARY_INGEST_MIME_TYPES,\n    INGEST_DOCUMENTS_COLLECTION,\n    INGEST_MAX_INPUT_BYTES,\n    TEXT_INGEST_MIME_TYPES,\n    _extract_with_kreuzberg,\n    decode_text_body,\n    ingest_commit,\n    ingest_preview,\n)\nfrom core_api.services.memory_service import (\n    _memory_to_out,\n    create_memories_bulk,\n    create_memory,\n    search_memories,\n    soft_delete_memory,\n    update_memory,\n)\nfrom core_api.services.tenants import list_active_tenant_ids\nfrom core_api.services.usage_service import bulk_check_and_increment, check_and_increment\n\nlogger = logging.getLogger(__name__)\n\nrouter = APIRouter(tags=[\"Memory\"])\n\n\ndef _reject_reserved_memory_type(memory_type: str | None, *, index: int | None = None) -> None:\n    \"\"\"C3/C8 — reject agent-supplied reserved memory types at the API boundary.\n\n    Reserved types (``outcome``, ``rule``, ``insight``) are emitted by the\n    server's internal write paths — evolve_service for outcome/rule,\n    insights_service for insight. Agents writing them explicitly creates\n    rows that downstream queries treat as system-authored, polluting\n    insights / RL signals. Internal callers go through\n    ``services.memory_service.create_memory`` directly and bypass this\n    check; only the REST + MCP entry points are gated.\n\n    ``index`` names the offending row in a bulk request so the operator\n    can find it; absent on the single-write path.\n    \"\"\"\n    if memory_type is None or memory_type not in SERVER_RESERVED_MEMORY_TYPES:\n        return\n    # ``memory_type`` is a ``MemoryType`` str-Enum value; ``!r`` would render\n    # ``<MemoryType.INSIGHT: 'insight'>`` which leaks the wrapper into the\n    # operator-facing message. ``.value`` (when present) gives the raw slug\n    # the API actually accepts; plain ``str(...)`` is the fallback.\n    slug = memory_type.value if hasattr(memory_type, \"value\") else str(memory_type)\n    detail = (\n        f\"memory_type='{slug}' is server-reserved and cannot be \"\n        \"supplied on writes. Use memclaw_evolve for outcome/rule or \"\n        \"memclaw_insights for insight; for agent-authored reflections, \"\n        \"use memory_type='semantic' or 'fact' (or omit memory_type to \"\n        \"auto-classify).\"\n    )\n    if index is not None:\n        detail = f\"items[{index}]: {detail}\"\n    raise HTTPException(status_code=422, detail=detail)\n\n\nasync def _stats_fallback(tenant_id: str, fleet_id: str | None) -> dict:\n    \"\"\"Map storage-api's ``memory_compute_health_stats`` shape onto the\n    flat ``{total, by_type, by_agent, by_status}`` shape both stats\n    endpoints return. ``by_agent`` is empty because storage-api doesn't\n    compute it; ``partial: True`` flags the degradation so callers can\n    distinguish a real empty tenant from a degraded response.\n\n    The two stats routes return bare dicts (no ``response_model``), so\n    the ``partial`` field survives FastAPI serialisation. If a\n    ``response_model`` is added later, include ``partial`` in the schema\n    or the degradation signal will be silently stripped.\n    \"\"\"\n    try:\n        fallback = await get_storage_client().get_memory_stats(tenant_id=tenant_id, fleet_id=fleet_id)\n    except httpx.HTTPError as exc:\n        # Storage-api is also down. Without this catch the httpx\n        # exception would propagate through the route's ``except`` block\n        # as a 500 with raw internal detail (storage-api URL, etc.).\n        logger.warning(\n            \"memory_stats fallback: storage-api request failed\",\n            extra={\"tenant_id\": tenant_id, \"fleet_id\": fleet_id, \"error\": str(exc)},\n            exc_info=True,\n        )\n        raise HTTPException(\n            status_code=503,\n            detail=\"memory stats unavailable: primary DB and storage-api fallback both failed\",\n        ) from None\n    if not fallback:\n        # ``storage_client._get`` returns ``{}`` on 404 (treated as\n        # absent). The httpx-error case is handled above. So an empty\n        # ``fallback`` here means storage-api 404'd, but since we got\n        # here only because the primary DB blew up, we can't tell a\n        # real empty tenant from a storage-api hiccup. 503 surfaces the\n        # cascading failure instead of returning a plausible-looking\n        # ``total: 0`` to a live tenant.\n        logger.warning(\n            \"memory_stats fallback: storage-api returned 404 or empty response \"\n            \"(cannot distinguish empty tenant from cascading failure)\",\n            extra={\"tenant_id\": tenant_id, \"fleet_id\": fleet_id},\n        )\n        raise HTTPException(\n            status_code=503,\n            detail=\"memory stats unavailable: primary DB and storage-api fallback both failed\",\n        ) from None\n    return {\n        \"total\": fallback.get(\"total\", fallback.get(\"total_memories\", 0)),\n        \"by_type\": fallback.get(\"type_distribution\", {}),\n        \"by_agent\": {},\n        \"by_status\": fallback.get(\"status_distribution\", {}),\n        \"partial\": True,\n    }\n\n\n@router.get(\"/tenants\")\nasync def list_tenants(\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n):\n    \"\"\"Return distinct tenant IDs that have memories.\"\"\"\n    auth.enforce_admin()\n    result = await db.execute(select(Memory.tenant_id).where(Memory.deleted_at.is_(None)).distinct())\n    return sorted([row[0] for row in result.all()])\n\n\n@router.get(\"/fleets\")\nasync def list_fleets(\n    tenant_id: str | None = Query(default=None),\n    auth: AuthContext = Depends(get_auth_context),\n    db: AsyncSession = Depends(get_db),\n):\n    \"\"\"Return distinct fleet_ids with memory counts.\"\"\"\n    if tenant_id:\n        # Read endpoint — honors cross-tenant readable set.\n        auth.enforce_readable_tenant(tenant_id)\n    elif not auth.is_admin:\n        # Non-admin must specify a tenant_id\n        if not auth.tenant_id:\n            raise HTTPException(status_code=400, detail=\"tenant_id is required\")\n        tenant_id = auth.tenant_id\n    filters = [\n        Memory.deleted_at.is_(None),\n        Memory.fleet_id.isnot(None),\n        # No ``agent_id`` accepted on this route, so there's no caller\n        # identity that could legitimately see ``scope_agent`` rows.\n        # Exclude them the same way ``memory_repository.list_by_filters``\n        # does (line 137) and ``/memories/stats`` does. Without this,\n        # ``memory_count``/``agent_count`` overstate what\n        # ``GET /api/v1/memories?fleet_id=X`` would actually return.\n        # ``Memory.visibility`` is ``nullable=False`` with a server\n        # default (common/models/memory.py:62-66), so the SQL three-\n        # valued-logic pitfall (NULL != 'scope_agent' = NULL → row\n        # silently dropped) doesn't apply here.\n        Memory.visibility != MEMORY_VISIBILITY_SCOPE_AGENT,\n    ]\n    if tenant_id:\n        filters.append(Memory.tenant_id == tenant_id)\n    rows = (\n        await db.execute(\n            select(\n                Memory.fleet_id,\n                func.count(),\n                func.count(func.distinct(Memory.agent_id)),\n            )\n            .where(*filters)\n            .group_by(Memory.fleet_id)\n            .order_by(func.count().desc())\n        )\n    ).all()\n    return [{\"fleet_id\": r[0], \"memory_count\": r[1], \"agent_count\": r[2]} for r in rows]\n\n\n@router.get(\"/memories\", response_model=PaginatedMemoryResponse)\nasync def list_memories(\n    tenant_id: str | None = Query(default=None),\n    fleet_id: str | None = Query(default=None),\n    agent_id: str | None = Query(default=None),\n    memory_type: str | None = Query(default=None),\n    status: str | None = Query(default=None),\n    visibility: str | None = Query(default=None),\n    run_id: str | None = Query(default=None),\n    cursor: str | None = Query(default=None),\n    sort: str = Query(\n        default=\"created_at\",\n        pattern=r\"^(created_at|weight|memory_type|agent_id|status|recall_count|fleet_id|tenant_id|expires_at|deleted_at)$\",\n    ),\n    order: str = Query(default=\"desc\", pattern=r\"^(asc|desc)$\"),\n    offset: int = Query(default=0, ge=0),","lineStart":1,"lineEnd":260,"totalLines":2023,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py","time":{"start":1780727679397,"end":1780727679412}},"metadata":{"openai":{"itemId":"fc_020d7f924b1ec321016a23bf7f4fb88191a4586da8066bc834"}},"id":"prt_e9ba40979001qm0q5XXLHcyU9r","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba3d1cf0017X0Ediqx0UTlLy"}}
{"type":"tool_use","timestamp":1780727679448,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_TJCz2QIS35SchtFoTTQvGxH0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/recall_service.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/recall_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Recall service: search + LLM summarization into a concise context paragraph.\"\"\"\n2: \n3: import json as _json\n4: import logging\n5: import time\n6: from datetime import UTC, datetime\n7: \n8: from sqlalchemy.ext.asyncio import AsyncSession\n9: \n10: from core_api.constants import (\n11:     DEFAULT_SEARCH_TOP_K,\n12:     MEMORY_RECALL_SUMMARY_MAX_TOKENS,\n13:     MEMORY_RECALL_SUMMARY_TEMPERATURE,\n14: )\n15: from core_api.providers._retry import call_with_fallback\n16: from core_api.services.memory_service import search_memories\n17: \n18: logger = logging.getLogger(__name__)\n19: \n20: RECALL_PROMPT = \"\"\"\\\n21: I will give you several facts and observations from past interactions and ingested content. \\\n22: Please answer the question based on the relevant facts. Answer the question step by step: \\\n23: first extract all the relevant information, then reason over the information to get the answer.\n24: \n25: When the question requires combining facts from different memories, trace the connection \\\n26: explicitly. Pay attention to dates within the facts — events described in past tense \\\n27: occurred before the date the memory was recorded.\n28: \n29: Grounding rules — follow strictly:\n30: - Quote only text that appears verbatim in the memories below.\n31: - Do not invent identifiers, field names, dates, titles, or numbers. If a detail is not \\\n32: present in the memories, do not include it.\n33: - If the memories do not contain enough information to answer, say so plainly. Do not \\\n34: infer beyond the evidence.\n35: \n36: Memories:\n37: \n38: {memories}\n39: \n40: {reference_date_line}Question: {query}\n41: Answer (step by step):\"\"\"\n42: \n43: \n44: def _format_memories_for_prompt(memories: list) -> str:\n45:     \"\"\"Format memories as a JSON array for structured LLM consumption.\n46: \n47:     Only fields that exist on the API response are exposed. No ordinal IDs, no\n48:     renamed schema fields — the model must not be able to cite identifiers or\n49:     field names that a caller cannot resolve.\n50:     \"\"\"\n51:     items = []\n52:     for m in memories:\n53:         item: dict = {\"type\": m.memory_type}\n54:         if m.title:\n55:             item[\"title\"] = m.title\n56:         if m.status and m.status != \"active\":\n57:             item[\"status\"] = m.status\n58:         content = m.content or \"\"\n59:         ts = getattr(m, \"ts_valid_start\", None)\n60:         if ts:\n61:             date_str = ts[:10] if isinstance(ts, str) else ts.strftime(\"%Y-%m-%d\")\n62:             content = f\"[{date_str}] {content}\" if content else f\"[{date_str}]\"\n63:         item[\"content\"] = content or None\n64:         items.append(item)\n65:     return _json.dumps(items, indent=2, ensure_ascii=False)\n66: \n67: \n68: async def summarize_memories(\n69:     memories: list,\n70:     query: str,\n71:     config,\n72:     *,\n73:     valid_at: datetime | None = None,\n74:     diagnostic: bool = False,\n75:     diagnostic_ctx: dict | None = None,\n76:     top_k: int = DEFAULT_SEARCH_TOP_K,\n77:     t0: float | None = None,\n78: ) -> dict:\n79:     \"\"\"LLM-only summarization step. No DB access.\n80: \n81:     Audit finding P3: ``memclaw_recall`` previously held the\n82:     ``_mcp_session()`` open across the multi-second LLM round-trip,\n83:     pinning a pooled DB connection. This helper takes already-fetched\n84:     memories + the resolved tenant config and produces the same dict\n85:     shape the legacy ``recall()`` wrapper returned, so the MCP tool can\n86:     exit the session block before invoking it.\n87: \n88:     ``t0`` is the caller's ``time.perf_counter()`` checkpoint for the\n89:     surrounding handler — passing it preserves the original \"recall_ms\n90:     measures end-to-end from auth-pass\" semantics. Omitted callers get\n91:     a fresh checkpoint that only times the summary itself.\n92:     \"\"\"\n93:     if t0 is None:\n94:         t0 = time.perf_counter()\n95:     diagnostic_ctx = diagnostic_ctx or {}\n96: \n97:     if not memories:\n98:         resp = {\n99:             \"query\": query,\n100:             \"summary\": \"No relevant context found.\",\n101:             \"memory_count\": 0,\n102:             # C4 — ``items`` aliases ``memories`` so consumers that\n103:             # pattern-match on /search's shape don't silently get zero\n104:             # results when hitting /recall instead. Both keys point at\n105:             # the same list (here trivially empty).\n106:             \"memories\": [],\n107:             \"items\": [],\n108:             \"recall_ms\": int((time.perf_counter() - t0) * 1000),\n109:         }\n110:         if diagnostic:\n111:             resp[\"diagnostic\"] = {\n112:                 \"recall_prompt\": None,\n113:                 \"recall_model\": None,\n114:                 \"recall_provider\": None,\n115:                 \"all_candidates\": diagnostic_ctx.get(\"all_candidates\", []),\n116:                 \"top_k_used\": top_k,\n117:                 \"retrieval_strategy\": diagnostic_ctx.get(\"retrieval_strategy\"),\n118:                 \"search_params\": {\n119:                     k: (float(v) if isinstance(v, (int, float)) else v)\n120:                     for k, v in diagnostic_ctx.get(\"search_params\", {}).items()\n121:                 },\n122:             }\n123:         return resp\n124: \n125:     # Sort chronologically so the LLM sees a natural timeline. Callers\n126:     # may have already sorted; the operation is idempotent.\n127:     _DT_MIN_UTC = datetime.min.replace(tzinfo=UTC)\n128:     memories.sort(key=lambda m: getattr(m, \"ts_valid_start\", None) or _DT_MIN_UTC)\n129: \n130:     memories_text = _format_memories_for_prompt(memories)\n131:     if valid_at:\n132:         reference_date_line = f\"Current Date: {valid_at.strftime('%Y-%m-%d')}\\n\"\n133:     else:\n134:         reference_date_line = \"\"\n135: \n136:     provider = config.recall_provider\n137: \n138:     if not config.recall_enabled:\n139:         # C4 — materialise once; alias under both ``memories`` and\n140:         # ``items`` keys so consumers built against /search's shape see\n141:         # the same list.\n142:         _memories_dumps = [m.model_dump(mode=\"json\") for m in memories]\n143:         resp = {\n144:             \"query\": query,\n145:             \"summary\": \"Recall summarization is disabled.\",\n146:             \"memory_count\": len(memories),\n147:             \"memories\": _memories_dumps,\n148:             \"items\": _memories_dumps,\n149:             \"recall_ms\": int((time.perf_counter() - t0) * 1000),\n150:         }\n151:         if diagnostic:\n152:             resp[\"diagnostic\"] = {\n153:                 \"recall_prompt\": None,\n154:                 \"recall_model\": None,\n155:                 \"recall_provider\": provider,\n156:                 \"all_candidates\": diagnostic_ctx.get(\"all_candidates\", []),\n157:                 \"top_k_used\": top_k,\n158:                 \"retrieval_strategy\": diagnostic_ctx.get(\"retrieval_strategy\"),\n159:                 \"search_params\": {\n160:                     k: (float(v) if isinstance(v, (int, float)) else v)\n161:                     for k, v in diagnostic_ctx.get(\"search_params\", {}).items()\n162:                 },\n163:             }\n164:         return resp\n165: \n166:     prompt = RECALL_PROMPT.format(\n167:         query=query, memories=memories_text, reference_date_line=reference_date_line\n168:     )\n169: \n170:     def _fake_recall() -> str:\n171:         \"\"\"No-LLM fallback: join top memory contents.\"\"\"\n172:         return \" \".join(m.content[:100] for m in memories[:3])\n173: \n174:     async def _do_recall(llm) -> str:\n175:         return await llm.complete_text(\n176:             prompt,\n177:             temperature=MEMORY_RECALL_SUMMARY_TEMPERATURE,\n178:             max_tokens=MEMORY_RECALL_SUMMARY_MAX_TOKENS,\n179:         )\n180: \n181:     recall_model = getattr(config, \"recall_model\", None)\n182:     summary = await call_with_fallback(\n183:         primary_provider_name=provider,\n184:         call_fn=_do_recall,\n185:         fake_fn=_fake_recall,\n186:         tenant_config=config,\n187:         service_label=\"recall\",\n188:         model_override=recall_model,\n189:         timeout=30.0,\n190:     )\n191: \n192:     recall_ms = int((time.perf_counter() - t0) * 1000)\n193: \n194:     # C4 — materialise once; alias under both ``memories`` and ``items``.\n195:     _memories_dumps = [m.model_dump(mode=\"json\") for m in memories]\n196:     result = {\n197:         \"query\": query,\n198:         \"summary\": summary,\n199:         \"memory_count\": len(memories),\n200:         \"memories\": _memories_dumps,\n201:         \"items\": _memories_dumps,\n202:         \"recall_ms\": recall_ms,\n203:     }\n204: \n205:     if diagnostic:\n206:         result[\"diagnostic\"] = {\n207:             \"recall_prompt\": prompt,\n208:             \"recall_model\": recall_model or \"default\",\n209:             \"recall_provider\": provider,\n210:             \"all_candidates\": diagnostic_ctx.get(\"all_candidates\", []),\n211:             \"top_k_used\": top_k,\n212:             \"retrieval_strategy\": diagnostic_ctx.get(\"retrieval_strategy\"),\n213:             \"search_params\": {\n214:                 k: (float(v) if isinstance(v, (int, float)) else v)\n215:                 for k, v in diagnostic_ctx.get(\"search_params\", {}).items()\n216:             },\n217:         }\n218: \n219:     return result\n220: \n221: \n222: async def recall(\n223:     db: AsyncSession,\n224:     tenant_id: str,\n225:     query: str,\n226:     fleet_ids: list[str] | None = None,\n227:     filter_agent_id: str | None = None,\n228:     caller_agent_id: str | None = None,\n229:     memory_type_filter: str | None = None,\n230:     status_filter: str | None = None,\n231:     top_k: int = DEFAULT_SEARCH_TOP_K,\n232:     valid_at: datetime | None = None,\n233:     diagnostic: bool = False,\n234:     readable_tenant_ids: list[str] | None = None,\n235: ) -> dict:\n236:     \"\"\"Search memories and synthesize a context summary.\n237: \n238:     Returns: {\"query\": ..., \"summary\": ..., \"memory_count\": ..., \"memories\": [...], \"items\": [...], \"recall_ms\": ...}\n239: \n240:     ``memories`` and ``items`` both reference the same list — the ``items``\n241:     alias was added by C4 so consumers built against ``/search``'s\n242:     response shape (which keys on ``items``) don't silently get zero\n243:     results when hitting ``/recall``.\n244: \n245:     Thin wrapper over ``search_memories`` + ``summarize_memories``. MCP\n246:     tool callers that already hold the search results and tenant config\n247:     should invoke ``summarize_memories`` directly so they can close\n248:     their DB session before the LLM round-trip (audit P3). This wrapper\n249:     is retained for the REST surface and other callers that prefer the\n250:     one-shot ergonomics.\n251:     \"\"\"\n252:     t0 = time.perf_counter()\n253: \n254:     from core_api.services.organization_settings import resolve_config\n255: \n256:     config = await resolve_config(db, tenant_id)\n257:     diagnostic_ctx: dict = {} if diagnostic else {}\n258:     memories = await search_memories(\n259:         db,\n260:         tenant_id=tenant_id,\n\n(Showing lines 1-260 of 285. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"Recall service: search + LLM summarization into a concise context paragraph.\"\"\"\n\nimport json as _json\nimport logging\nimport time\nfrom datetime import UTC, datetime\n\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom core_api.constants import (\n    DEFAULT_SEARCH_TOP_K,\n    MEMORY_RECALL_SUMMARY_MAX_TOKENS,\n    MEMORY_RECALL_SUMMARY_TEMPERATURE,\n)\nfrom core_api.providers._retry import call_with_fallback\nfrom core_api.services.memory_service import search_memories\n\nlogger = logging.getLogger(__name__)\n\nRECALL_PROMPT = \"\"\"\\","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/recall_service.py","text":"\"\"\"Recall service: search + LLM summarization into a concise context paragraph.\"\"\"\n\nimport json as _json\nimport logging\nimport time\nfrom datetime import UTC, datetime\n\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom core_api.constants import (\n    DEFAULT_SEARCH_TOP_K,\n    MEMORY_RECALL_SUMMARY_MAX_TOKENS,\n    MEMORY_RECALL_SUMMARY_TEMPERATURE,\n)\nfrom core_api.providers._retry import call_with_fallback\nfrom core_api.services.memory_service import search_memories\n\nlogger = logging.getLogger(__name__)\n\nRECALL_PROMPT = \"\"\"\\\nI will give you several facts and observations from past interactions and ingested content. \\\nPlease answer the question based on the relevant facts. Answer the question step by step: \\\nfirst extract all the relevant information, then reason over the information to get the answer.\n\nWhen the question requires combining facts from different memories, trace the connection \\\nexplicitly. Pay attention to dates within the facts — events described in past tense \\\noccurred before the date the memory was recorded.\n\nGrounding rules — follow strictly:\n- Quote only text that appears verbatim in the memories below.\n- Do not invent identifiers, field names, dates, titles, or numbers. If a detail is not \\\npresent in the memories, do not include it.\n- If the memories do not contain enough information to answer, say so plainly. Do not \\\ninfer beyond the evidence.\n\nMemories:\n\n{memories}\n\n{reference_date_line}Question: {query}\nAnswer (step by step):\"\"\"\n\n\ndef _format_memories_for_prompt(memories: list) -> str:\n    \"\"\"Format memories as a JSON array for structured LLM consumption.\n\n    Only fields that exist on the API response are exposed. No ordinal IDs, no\n    renamed schema fields — the model must not be able to cite identifiers or\n    field names that a caller cannot resolve.\n    \"\"\"\n    items = []\n    for m in memories:\n        item: dict = {\"type\": m.memory_type}\n        if m.title:\n            item[\"title\"] = m.title\n        if m.status and m.status != \"active\":\n            item[\"status\"] = m.status\n        content = m.content or \"\"\n        ts = getattr(m, \"ts_valid_start\", None)\n        if ts:\n            date_str = ts[:10] if isinstance(ts, str) else ts.strftime(\"%Y-%m-%d\")\n            content = f\"[{date_str}] {content}\" if content else f\"[{date_str}]\"\n        item[\"content\"] = content or None\n        items.append(item)\n    return _json.dumps(items, indent=2, ensure_ascii=False)\n\n\nasync def summarize_memories(\n    memories: list,\n    query: str,\n    config,\n    *,\n    valid_at: datetime | None = None,\n    diagnostic: bool = False,\n    diagnostic_ctx: dict | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    t0: float | None = None,\n) -> dict:\n    \"\"\"LLM-only summarization step. No DB access.\n\n    Audit finding P3: ``memclaw_recall`` previously held the\n    ``_mcp_session()`` open across the multi-second LLM round-trip,\n    pinning a pooled DB connection. This helper takes already-fetched\n    memories + the resolved tenant config and produces the same dict\n    shape the legacy ``recall()`` wrapper returned, so the MCP tool can\n    exit the session block before invoking it.\n\n    ``t0`` is the caller's ``time.perf_counter()`` checkpoint for the\n    surrounding handler — passing it preserves the original \"recall_ms\n    measures end-to-end from auth-pass\" semantics. Omitted callers get\n    a fresh checkpoint that only times the summary itself.\n    \"\"\"\n    if t0 is None:\n        t0 = time.perf_counter()\n    diagnostic_ctx = diagnostic_ctx or {}\n\n    if not memories:\n        resp = {\n            \"query\": query,\n            \"summary\": \"No relevant context found.\",\n            \"memory_count\": 0,\n            # C4 — ``items`` aliases ``memories`` so consumers that\n            # pattern-match on /search's shape don't silently get zero\n            # results when hitting /recall instead. Both keys point at\n            # the same list (here trivially empty).\n            \"memories\": [],\n            \"items\": [],\n            \"recall_ms\": int((time.perf_counter() - t0) * 1000),\n        }\n        if diagnostic:\n            resp[\"diagnostic\"] = {\n                \"recall_prompt\": None,\n                \"recall_model\": None,\n                \"recall_provider\": None,\n                \"all_candidates\": diagnostic_ctx.get(\"all_candidates\", []),\n                \"top_k_used\": top_k,\n                \"retrieval_strategy\": diagnostic_ctx.get(\"retrieval_strategy\"),\n                \"search_params\": {\n                    k: (float(v) if isinstance(v, (int, float)) else v)\n                    for k, v in diagnostic_ctx.get(\"search_params\", {}).items()\n                },\n            }\n        return resp\n\n    # Sort chronologically so the LLM sees a natural timeline. Callers\n    # may have already sorted; the operation is idempotent.\n    _DT_MIN_UTC = datetime.min.replace(tzinfo=UTC)\n    memories.sort(key=lambda m: getattr(m, \"ts_valid_start\", None) or _DT_MIN_UTC)\n\n    memories_text = _format_memories_for_prompt(memories)\n    if valid_at:\n        reference_date_line = f\"Current Date: {valid_at.strftime('%Y-%m-%d')}\\n\"\n    else:\n        reference_date_line = \"\"\n\n    provider = config.recall_provider\n\n    if not config.recall_enabled:\n        # C4 — materialise once; alias under both ``memories`` and\n        # ``items`` keys so consumers built against /search's shape see\n        # the same list.\n        _memories_dumps = [m.model_dump(mode=\"json\") for m in memories]\n        resp = {\n            \"query\": query,\n            \"summary\": \"Recall summarization is disabled.\",\n            \"memory_count\": len(memories),\n            \"memories\": _memories_dumps,\n            \"items\": _memories_dumps,\n            \"recall_ms\": int((time.perf_counter() - t0) * 1000),\n        }\n        if diagnostic:\n            resp[\"diagnostic\"] = {\n                \"recall_prompt\": None,\n                \"recall_model\": None,\n                \"recall_provider\": provider,\n                \"all_candidates\": diagnostic_ctx.get(\"all_candidates\", []),\n                \"top_k_used\": top_k,\n                \"retrieval_strategy\": diagnostic_ctx.get(\"retrieval_strategy\"),\n                \"search_params\": {\n                    k: (float(v) if isinstance(v, (int, float)) else v)\n                    for k, v in diagnostic_ctx.get(\"search_params\", {}).items()\n                },\n            }\n        return resp\n\n    prompt = RECALL_PROMPT.format(\n        query=query, memories=memories_text, reference_date_line=reference_date_line\n    )\n\n    def _fake_recall() -> str:\n        \"\"\"No-LLM fallback: join top memory contents.\"\"\"\n        return \" \".join(m.content[:100] for m in memories[:3])\n\n    async def _do_recall(llm) -> str:\n        return await llm.complete_text(\n            prompt,\n            temperature=MEMORY_RECALL_SUMMARY_TEMPERATURE,\n            max_tokens=MEMORY_RECALL_SUMMARY_MAX_TOKENS,\n        )\n\n    recall_model = getattr(config, \"recall_model\", None)\n    summary = await call_with_fallback(\n        primary_provider_name=provider,\n        call_fn=_do_recall,\n        fake_fn=_fake_recall,\n        tenant_config=config,\n        service_label=\"recall\",\n        model_override=recall_model,\n        timeout=30.0,\n    )\n\n    recall_ms = int((time.perf_counter() - t0) * 1000)\n\n    # C4 — materialise once; alias under both ``memories`` and ``items``.\n    _memories_dumps = [m.model_dump(mode=\"json\") for m in memories]\n    result = {\n        \"query\": query,\n        \"summary\": summary,\n        \"memory_count\": len(memories),\n        \"memories\": _memories_dumps,\n        \"items\": _memories_dumps,\n        \"recall_ms\": recall_ms,\n    }\n\n    if diagnostic:\n        result[\"diagnostic\"] = {\n            \"recall_prompt\": prompt,\n            \"recall_model\": recall_model or \"default\",\n            \"recall_provider\": provider,\n            \"all_candidates\": diagnostic_ctx.get(\"all_candidates\", []),\n            \"top_k_used\": top_k,\n            \"retrieval_strategy\": diagnostic_ctx.get(\"retrieval_strategy\"),\n            \"search_params\": {\n                k: (float(v) if isinstance(v, (int, float)) else v)\n                for k, v in diagnostic_ctx.get(\"search_params\", {}).items()\n            },\n        }\n\n    return result\n\n\nasync def recall(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    valid_at: datetime | None = None,\n    diagnostic: bool = False,\n    readable_tenant_ids: list[str] | None = None,\n) -> dict:\n    \"\"\"Search memories and synthesize a context summary.\n\n    Returns: {\"query\": ..., \"summary\": ..., \"memory_count\": ..., \"memories\": [...], \"items\": [...], \"recall_ms\": ...}\n\n    ``memories`` and ``items`` both reference the same list — the ``items``\n    alias was added by C4 so consumers built against ``/search``'s\n    response shape (which keys on ``items``) don't silently get zero\n    results when hitting ``/recall``.\n\n    Thin wrapper over ``search_memories`` + ``summarize_memories``. MCP\n    tool callers that already hold the search results and tenant config\n    should invoke ``summarize_memories`` directly so they can close\n    their DB session before the LLM round-trip (audit P3). This wrapper\n    is retained for the REST surface and other callers that prefer the\n    one-shot ergonomics.\n    \"\"\"\n    t0 = time.perf_counter()\n\n    from core_api.services.organization_settings import resolve_config\n\n    config = await resolve_config(db, tenant_id)\n    diagnostic_ctx: dict = {} if diagnostic else {}\n    memories = await search_memories(\n        db,\n        tenant_id=tenant_id,","lineStart":1,"lineEnd":260,"totalLines":285,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/recall_service.py","time":{"start":1780727679433,"end":1780727679447}},"metadata":{"openai":{"itemId":"fc_020d7f924b1ec321016a23bf7f4fd881919ab943ceaf98bffa"}},"id":"prt_e9ba409be0018Tw5xSemJlp9YT","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba3d1cf0017X0Ediqx0UTlLy"}}
{"type":"tool_use","timestamp":1780727679454,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_2gVDOypNIR5F6Y5DWysPhJmE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md</path>\n<type>file</type>\n<content>\n1: <p align=\"center\">\n2:   <img src=\"static/images/memCLAW_logo_dark.png\" alt=\"MemClaw\" width=\"420\" />\n3: </p>\n4: \n5: <h3 align=\"center\">Fleet memory for AI agents &mdash; governed, shared, self-improving.</h3>\n6: \n7: <p align=\"center\">\n8:   <a href=\"LICENSE\"><img src=\"https://img.shields.io/badge/License-Apache_2.0-blue.svg\" alt=\"License\" /></a>\n9:   <a href=\"https://github.com/caura-ai/caura-memclaw/stargazers\"><img src=\"https://img.shields.io/github/stars/caura-ai/caura-memclaw?style=social\" alt=\"GitHub Stars\" /></a>\n10:   <a href=\"https://github.com/caura-ai/caura-memclaw/actions\"><img src=\"https://img.shields.io/github/actions/workflow/status/caura-ai/caura-memclaw/ci.yml?label=CI\" alt=\"CI\" /></a>\n11:   <a href=\"https://github.com/caura-ai/caura-memclaw/releases\"><img src=\"https://img.shields.io/github/v/release/caura-ai/caura-memclaw\" alt=\"Release\" /></a>\n12:   <a href=\"https://discord.com/invite/aNfpgfpj\"><img src=\"https://img.shields.io/badge/Discord-join-5865F2?logo=discord&logoColor=white\" alt=\"Join us on Discord\" /></a>\n13: </p>\n14: \n15: <p align=\"center\">\n16:   <a href=\"#quick-start\">Quick Start</a> &middot;\n17:   <a href=\"#features\">Features</a> &middot;\n18:   <a href=\"#performance\">Performance</a> &middot;\n19:   <a href=\"#mcp-model-context-protocol\">MCP</a> &middot;\n20:   <a href=\"#api-reference\">API Reference</a> &middot;\n21:   <a href=\"static/docs/integration-guide.md\">Plugin Docs</a> &middot;\n22:   <a href=\"CONTRIBUTING.md\">Contributing</a> &middot;\n23:   <a href=\"https://discord.com/invite/aNfpgfpj\">Discord</a>\n24: </p>\n25: \n26: ---\n27: \n28: ## MemClaw — Fleet memory for AI agents\n29: \n30: MemClaw is open-source memory for **multi-tenant, multi-agent** AI fleets. Your agents store what they learn, find what the fleet knows, and get smarter with every interaction — learning from each other instead of repeating mistakes.\n31: \n32: Agents write plain text. MemClaw turns it into searchable, governed, self-improving memory.\n33: \n34: **One loop, three pillars: write, recall, compound** — every interaction makes the next one smarter.\n35: \n36: **Built for fleets, not single agents.** Public agent-memory benchmarks (LoCoMo, LongMemEval) measure one agent, one user, one long conversation — the single-chatbot shape. The deployment shape we see in production is the opposite: dozens or thousands of agents working on behalf of a company, sharing what they learn under governance. MemClaw is architected around that shape from day one — scoped memory, cross-agent outcome propagation, fleet-wide trust tiers — and competes on the axes that compound with agent count: latency, token efficiency, and governance. See [Performance](#performance) for the numbers, or read the [benchmarks write-up](https://memclaw.net/blog/memclaw-benchmarks).\n37: \n38: <p align=\"center\">\n39:   <img src=\"static/images/memclaw-concept.svg\" alt=\"MemClaw — Fleet Memory that Compounds\" width=\"700\" />\n40: </p>\n41: \n42: ---\n43: \n44: ## Quick Start\n45: \n46: Three paths — pick the one that matches your setup:\n47: \n48: | Path | When | Time to first memory |\n49: |---|---|---|\n50: | **Managed platform** | Quickest. We host the DB + scaling. | ~2 min |\n51: | **Self-hosted (Docker)** | Privacy / on-prem / air-gapped. | ~5 min |\n52: | **OpenClaw plugin** | You already run an OpenClaw fleet — install MemClaw as a plugin against any of the above. | ~3 min |\n53: \n54: ### Managed Platform\n55: \n56: Get up and running in minutes — no infrastructure, automatic updates, usage analytics, and enterprise-grade security included.\n57: \n58: 1. **[Sign up free on memclaw.net](https://memclaw.net)**\n59: 2. Grab your API key from the dashboard\n60: 3. Connect via MCP or REST:\n61: \n62: ```json\n63: {\n64:   \"mcpServers\": {\n65:     \"memclaw\": {\n66:       \"url\": \"https://memclaw.net/mcp\",\n67:       \"headers\": { \"X-API-Key\": \"mc_your_api_key_here\" }\n68:     }\n69:   }\n70: }\n71: ```\n72: \n73: > **Production / team use:** the quickstart key above is a **tenant-scoped credential** — fine for personal use, but a fleet of agents should bind each one to its own **agent-scoped credential** for trust gating, fleet membership, and per-agent keystones. Provision agent-scoped credentials atomically via [`POST /api/v1/admin/agent-keys/provision`](docs/integration-without-plugin.md), or through the dashboard at `/settings/organization/api-credentials`. Both kinds use the `mc_` prefix on the wire — scope is bound at mint time on the credential itself. The MCP server accepts the credential on either `X-API-Key: mc_…` or `Authorization: Bearer mc_…`. *(Pre-existing `mca_…` and `mci_…` keys continue to authenticate via back-compat.)*\n74: >\n75: > Using a tenant-scoped credential? Pass an explicit `agent_id` on every MCP tool call — the gateway refuses the reserved default (`mcp-agent`) on the tenant-scoped path.\n76: \n77: ### Self-Hosted (Open Source)\n78: \n79: The fastest path is Docker Compose — one command brings up Postgres + pgvector + Redis + the API.\n80: \n81: > **Prefer not to use Docker?** Skip to [Manual deployment (Python + Postgres)](#manual-deployment) below for the bare-Python path.\n82: >\n83: > **No cloud API key, no external calls?** v2.0+ supports a self-hosted local embedder (`BAAI/bge-m3` via HuggingFace TEI) — see [`docs/local-embedder.md`](docs/local-embedder.md). The setup below walks through the OpenAI default; the local-embedder doc walks through the alternative.\n84: \n85: #### Prerequisites\n86: \n87: - **Docker Engine 24+** (Linux) or **Docker Desktop** (macOS / Windows). Confirm with `docker --version`.\n88: - **Docker Compose v2** (built into modern Docker). Confirm with `docker compose version`.\n89: - **Git** for cloning.\n90: - ~2 GB free disk for images + Postgres data volume.\n91: \n92: #### 1. Clone and configure\n93: \n94: ```bash\n95: git clone https://github.com/caura-ai/caura-memclaw.git\n96: cd caura-memclaw\n97: cp .env.example .env\n98: ```\n99: \n100: Set your AI provider in `.env` — minimal setup with OpenAI:\n101: \n102: ```env\n103: EMBEDDING_PROVIDER=openai\n104: ENTITY_EXTRACTION_PROVIDER=openai\n105: USE_LLM_FOR_MEMORY_CREATION=true\n106: OPENAI_API_KEY=sk-...\n107: ```\n108: \n109: > Without any AI keys the stack still starts — dummy providers return non-semantic embeddings, useful for testing the API surface.\n110: \n111: > 💡 **Want zero cloud API calls?** v2.0+ ships a self-hosted embedder\n112: > profile (`BAAI/bge-m3` on a [HuggingFace TEI](https://github.com/huggingface/text-embeddings-inference)\n113: > sidecar). Bring up the stack with `docker compose --profile embed-local up -d`\n114: > and set the four `OPENAI_EMBEDDING_*` envs from `.env.example` — see\n115: > [`docs/local-embedder.md`](docs/local-embedder.md) for the full setup.\n116: > Combined with `IS_STANDALONE=true` (below) this is a fully self-contained\n117: > deployment with no external API calls.\n118: \n119: <details>\n120: <summary>Other providers (Gemini, Anthropic, OpenRouter, self-hosted)</summary>\n121: \n122: | Provider | `.env` settings | Required key |\n123: |---|---|---|\n124: | **OpenAI** (default) | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=openai` | `OPENAI_API_KEY` |\n125: | **Google Gemini** | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=gemini` | `GEMINI_API_KEY` + `OPENAI_API_KEY` |\n126: | **Anthropic** | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=anthropic` | `ANTHROPIC_API_KEY` + `OPENAI_API_KEY` |\n127: | **OpenRouter** | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=openrouter` | `OPENROUTER_API_KEY` + `OPENAI_API_KEY` |\n128: | **Self-hosted (TEI / bge-m3)** | `--profile embed-local` + `OPENAI_EMBEDDING_BASE_URL=http://tei:80/v1`<br>+ `OPENAI_EMBEDDING_MODEL=BAAI/bge-m3`<br>+ `OPENAI_EMBEDDING_SEND_DIMENSIONS=false` | none — runs locally |\n129: \n130: Anthropic, Gemini, and OpenRouter don't offer embedding APIs here — pair them with OpenAI (or with TEI) for embeddings. You can mix providers freely. Gemini uses the [Google AI Studio](https://aistudio.google.com/) key-auth Developer API (no GCP project/ADC required). The self-hosted TEI row keeps `EMBEDDING_PROVIDER=openai` because TEI speaks the same OpenAI-compatible API; see [`docs/local-embedder.md`](docs/local-embedder.md) for hardware sizing, GPU setup, and model swapping.\n131: \n132: </details>\n133: \n134: #### 2. Start the stack\n135: \n136: ```bash\n137: docker compose up -d\n138: ```\n139: \n140: By default this **pulls the multi-arch images from `ghcr.io`** (`linux/amd64` + `linux/arm64`) on first run — takes ~30 seconds. Subsequent `up` commands re-use the cached image (no registry round-trip, works offline). To pin a specific version, set `MEMCLAW_VERSION=v1.2.3` in your `.env`. To build from local source instead (e.g. when iterating on a fork), run `docker compose up --build --no-pull`.\n141: \n142: To upgrade to a newer image at the same tag (e.g. `:latest` after we cut a new release), run `docker compose pull && docker compose up -d`. Without an explicit `pull`, the local cache wins — there's no silent version drift.\n143: \n144: > **Offline / air-gapped operation**: depending on whether the image is already cached locally:\n145: > - **Image cached, no network**: `docker compose up -d` works as-is — `pull_policy: missing` doesn't try to pull when the image is present. Use `docker compose up --no-pull` if you want to be explicit.\n146: > - **No local image, no network**: `docker compose up --build --no-pull` (build from source, don't try to pull).\n147: > - **Strict no-network guarantee** (e.g. an air-gapped pipeline that should never reach `ghcr.io`): drop a `docker-compose.override.yml` setting `pull_policy: never` for both services — Compose then fails fast if the image is absent rather than attempting a pull.\n148: \n149: | Service | URL |\n150: |---|---|\n151: | Core API (REST + MCP) | http://localhost:8000 |\n152: | Core Storage API | http://localhost:8002 |\n153: | PostgreSQL (pgvector) | localhost:5432 |\n154: | Redis | localhost:6379 |\n155: \n156: #### 3. Verify\n157: \n158: ```bash\n159: curl http://localhost:8000/api/v1/health\n160: # {\"status\":\"ok\",\"database\":\"connected\",...}\n161: ```\n162: \n163: #### 4. Write and search\n164: \n165: ```bash\n166: # Write a memory (standalone mode — no API key needed)\n167: curl -X POST http://localhost:8000/api/v1/memories \\\n168:   -H \"X-API-Key: standalone\" \\\n169:   -H \"Content-Type: application/json\" \\\n170:   -d '{\"tenant_id\": \"default\", \"content\": \"Our auth service uses JWT with 15-minute expiry.\"}'\n171: \n172: # Search for it\n173: curl -X POST http://localhost:8000/api/v1/search \\\n174:   -H \"X-API-Key: standalone\" \\\n175:   -H \"Content-Type: application/json\" \\\n176:   -d '{\"tenant_id\": \"default\", \"query\": \"authentication token lifetime\"}'\n177: ```\n178: \n179: The write response includes LLM-inferred `type`, `title`, `summary`, `tags`, `status`, and `importance_score` — all from a single `content` field.\n180: \n181: <details>\n182: <summary>Auth modes</summary>\n183: \n184: OSS supports three auth paths. Pick one and add it to your `.env`, then `docker compose up -d` to restart.\n185: \n186: **Standalone** — single-tenant (`tenant_id=\"default\"`), simplest for local / self-install:\n187: ```env\n188: IS_STANDALONE=true\n189: ```\n190: No API key required for REST. MCP still expects a non-empty `X-API-Key` header — any value works.\n191: \n192: > Pair Standalone mode with `--profile embed-local` (see [`docs/local-embedder.md`](docs/local-embedder.md)) for a fully self-contained deployment: no admin keys, no external API calls, all embeddings computed locally. Useful for offline / air-gapped environments and personal-laptop installs.\n193: \n194: **Admin key** — multi-tenant with full access:\n195: ```env\n196: ADMIN_API_KEY=your-long-random-admin-key\n197: ```\n198: Pass `X-API-Key: your-long-random-admin-key` and include `tenant_id` in request bodies / query params.\n199: \n200: **Shared gate** — for network-exposed OSS deployments:\n201: ```env\n202: MEMCLAW_API_KEY=your-shared-key\n203: ```\n204: Clients send `X-API-Key: your-shared-key` plus `X-Tenant-ID: <tenant>`.\n205: \n206: > See [AGENT-INSTALL.md](AGENT-INSTALL.md) for the full agent self-install walkthrough.\n207: \n208: </details>\n209: \n210: <details>\n211: <summary>Running tests</summary>\n212: \n213: ```bash\n214: # Unit tests (no DB needed)\n215: pytest tests/ -m \"unit\"\n216: \n217: # All tests (requires PostgreSQL)\n218: docker compose up -d db\n219: pytest tests/ -m \"not benchmark\"\n220: \n221: # Smoke test against live API (~30s, auto-cleanup)\n222: python scripts/smoke_test.py --url http://localhost:8000 --api-key <admin-key>\n223: ```\n224: \n225: </details>\n226: \n227: ### OpenClaw Plugin\n228: \n229: Already running an OpenClaw fleet? Install MemClaw as a plugin against either the managed platform or your self-hosted stack:\n230: \n231: ```bash\n232: # Point at whichever URL hosts your MemClaw API\n233: export MEMCLAW_URL=https://memclaw.net          # managed\n234: # or:  export MEMCLAW_URL=http://localhost:8000  # self-hosted\n235: export MEMCLAW_KEY=your-key                      # `standalone` works in self-hosted standalone mode\n236: export MEMCLAW_FLEET=my-fleet\n237: \n238: curl -sf -H \"X-API-Key: $MEMCLAW_KEY\" \\\n239:   \"$MEMCLAW_URL/api/v1/install-plugin?fleet_id=$MEMCLAW_FLEET&api_url=$MEMCLAW_URL\" | bash\n240: \n241: # Restart the gateway to load the plugin\n242: openclaw gateway restart\n243: ```\n244: \n245: The plugin claims the OpenClaw `memory` slot (replacing `memory-core`) and exposes the same 12 MCP tools. Full setup, agent prompts, and trust levels: [static/docs/integration-guide.md](static/docs/integration-guide.md).\n246: \n247: ---\n248: \n249: ## Features\n250: \n251: ### Governance\n252: \n253: - **Tenant isolation** — row-level database separation per tenant; PII auto-detected and quarantined before it can cross fleet boundaries\n254: - **Visibility scopes** — every memory is stamped at write time: `scope_agent` (private), `scope_team` (fleet-wide, default), or `scope_org` (cross-fleet). Cross-fleet recall is permissioned, not open\n255: - **Agent trust tiers** — four levels control cross-fleet reads, writes, and deletes. Agents are either provisioned atomically via `POST /admin/agent-keys/provision` (recommended — mints key + row + trust + fleet in one call) or auto-registered on first write (legacy fallback)\n256: - **Full audit log** — every write, delete, and transition logged with tenant and scope context\n257: \n258: ### Memory Pipeline\n259: \n260: - **Single-pass LLM enrichment** — every write auto-classifies into one of 14 memory types, generates title/summary/tags, scores importance, flags PII, and extracts entities — from a single `content` field\n\n(Showing lines 1-260 of 965. Use offset=261 to continue.)\n</content>","metadata":{"preview":"<p align=\"center\">\n  <img src=\"static/images/memCLAW_logo_dark.png\" alt=\"MemClaw\" width=\"420\" />\n</p>\n\n<h3 align=\"center\">Fleet memory for AI agents &mdash; governed, shared, self-improving.</h3>\n\n<p align=\"center\">\n  <a href=\"LICENSE\"><img src=\"https://img.shields.io/badge/License-Apache_2.0-blue.svg\" alt=\"License\" /></a>\n  <a href=\"https://github.com/caura-ai/caura-memclaw/stargazers\"><img src=\"https://img.shields.io/github/stars/caura-ai/caura-memclaw?style=social\" alt=\"GitHub Stars\" /></a>\n  <a href=\"https://github.com/caura-ai/caura-memclaw/actions\"><img src=\"https://img.shields.io/github/actions/workflow/status/caura-ai/caura-memclaw/ci.yml?label=CI\" alt=\"CI\" /></a>\n  <a href=\"https://github.com/caura-ai/caura-memclaw/releases\"><img src=\"https://img.shields.io/github/v/release/caura-ai/caura-memclaw\" alt=\"Release\" /></a>\n  <a href=\"https://discord.com/invite/aNfpgfpj\"><img src=\"https://img.shields.io/badge/Discord-join-5865F2?logo=discord&logoColor=white\" alt=\"Join us on Discord\" /></a>\n</p>\n\n<p align=\"center\">\n  <a href=\"#quick-start\">Quick Start</a> &middot;\n  <a href=\"#features\">Features</a> &middot;\n  <a href=\"#performance\">Performance</a> &middot;\n  <a href=\"#mcp-model-context-protocol\">MCP</a> &middot;\n  <a href=\"#api-reference\">API Reference</a> &middot;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","text":"<p align=\"center\">\n  <img src=\"static/images/memCLAW_logo_dark.png\" alt=\"MemClaw\" width=\"420\" />\n</p>\n\n<h3 align=\"center\">Fleet memory for AI agents &mdash; governed, shared, self-improving.</h3>\n\n<p align=\"center\">\n  <a href=\"LICENSE\"><img src=\"https://img.shields.io/badge/License-Apache_2.0-blue.svg\" alt=\"License\" /></a>\n  <a href=\"https://github.com/caura-ai/caura-memclaw/stargazers\"><img src=\"https://img.shields.io/github/stars/caura-ai/caura-memclaw?style=social\" alt=\"GitHub Stars\" /></a>\n  <a href=\"https://github.com/caura-ai/caura-memclaw/actions\"><img src=\"https://img.shields.io/github/actions/workflow/status/caura-ai/caura-memclaw/ci.yml?label=CI\" alt=\"CI\" /></a>\n  <a href=\"https://github.com/caura-ai/caura-memclaw/releases\"><img src=\"https://img.shields.io/github/v/release/caura-ai/caura-memclaw\" alt=\"Release\" /></a>\n  <a href=\"https://discord.com/invite/aNfpgfpj\"><img src=\"https://img.shields.io/badge/Discord-join-5865F2?logo=discord&logoColor=white\" alt=\"Join us on Discord\" /></a>\n</p>\n\n<p align=\"center\">\n  <a href=\"#quick-start\">Quick Start</a> &middot;\n  <a href=\"#features\">Features</a> &middot;\n  <a href=\"#performance\">Performance</a> &middot;\n  <a href=\"#mcp-model-context-protocol\">MCP</a> &middot;\n  <a href=\"#api-reference\">API Reference</a> &middot;\n  <a href=\"static/docs/integration-guide.md\">Plugin Docs</a> &middot;\n  <a href=\"CONTRIBUTING.md\">Contributing</a> &middot;\n  <a href=\"https://discord.com/invite/aNfpgfpj\">Discord</a>\n</p>\n\n---\n\n## MemClaw — Fleet memory for AI agents\n\nMemClaw is open-source memory for **multi-tenant, multi-agent** AI fleets. Your agents store what they learn, find what the fleet knows, and get smarter with every interaction — learning from each other instead of repeating mistakes.\n\nAgents write plain text. MemClaw turns it into searchable, governed, self-improving memory.\n\n**One loop, three pillars: write, recall, compound** — every interaction makes the next one smarter.\n\n**Built for fleets, not single agents.** Public agent-memory benchmarks (LoCoMo, LongMemEval) measure one agent, one user, one long conversation — the single-chatbot shape. The deployment shape we see in production is the opposite: dozens or thousands of agents working on behalf of a company, sharing what they learn under governance. MemClaw is architected around that shape from day one — scoped memory, cross-agent outcome propagation, fleet-wide trust tiers — and competes on the axes that compound with agent count: latency, token efficiency, and governance. See [Performance](#performance) for the numbers, or read the [benchmarks write-up](https://memclaw.net/blog/memclaw-benchmarks).\n\n<p align=\"center\">\n  <img src=\"static/images/memclaw-concept.svg\" alt=\"MemClaw — Fleet Memory that Compounds\" width=\"700\" />\n</p>\n\n---\n\n## Quick Start\n\nThree paths — pick the one that matches your setup:\n\n| Path | When | Time to first memory |\n|---|---|---|\n| **Managed platform** | Quickest. We host the DB + scaling. | ~2 min |\n| **Self-hosted (Docker)** | Privacy / on-prem / air-gapped. | ~5 min |\n| **OpenClaw plugin** | You already run an OpenClaw fleet — install MemClaw as a plugin against any of the above. | ~3 min |\n\n### Managed Platform\n\nGet up and running in minutes — no infrastructure, automatic updates, usage analytics, and enterprise-grade security included.\n\n1. **[Sign up free on memclaw.net](https://memclaw.net)**\n2. Grab your API key from the dashboard\n3. Connect via MCP or REST:\n\n```json\n{\n  \"mcpServers\": {\n    \"memclaw\": {\n      \"url\": \"https://memclaw.net/mcp\",\n      \"headers\": { \"X-API-Key\": \"mc_your_api_key_here\" }\n    }\n  }\n}\n```\n\n> **Production / team use:** the quickstart key above is a **tenant-scoped credential** — fine for personal use, but a fleet of agents should bind each one to its own **agent-scoped credential** for trust gating, fleet membership, and per-agent keystones. Provision agent-scoped credentials atomically via [`POST /api/v1/admin/agent-keys/provision`](docs/integration-without-plugin.md), or through the dashboard at `/settings/organization/api-credentials`. Both kinds use the `mc_` prefix on the wire — scope is bound at mint time on the credential itself. The MCP server accepts the credential on either `X-API-Key: mc_…` or `Authorization: Bearer mc_…`. *(Pre-existing `mca_…` and `mci_…` keys continue to authenticate via back-compat.)*\n>\n> Using a tenant-scoped credential? Pass an explicit `agent_id` on every MCP tool call — the gateway refuses the reserved default (`mcp-agent`) on the tenant-scoped path.\n\n### Self-Hosted (Open Source)\n\nThe fastest path is Docker Compose — one command brings up Postgres + pgvector + Redis + the API.\n\n> **Prefer not to use Docker?** Skip to [Manual deployment (Python + Postgres)](#manual-deployment) below for the bare-Python path.\n>\n> **No cloud API key, no external calls?** v2.0+ supports a self-hosted local embedder (`BAAI/bge-m3` via HuggingFace TEI) — see [`docs/local-embedder.md`](docs/local-embedder.md). The setup below walks through the OpenAI default; the local-embedder doc walks through the alternative.\n\n#### Prerequisites\n\n- **Docker Engine 24+** (Linux) or **Docker Desktop** (macOS / Windows). Confirm with `docker --version`.\n- **Docker Compose v2** (built into modern Docker). Confirm with `docker compose version`.\n- **Git** for cloning.\n- ~2 GB free disk for images + Postgres data volume.\n\n#### 1. Clone and configure\n\n```bash\ngit clone https://github.com/caura-ai/caura-memclaw.git\ncd caura-memclaw\ncp .env.example .env\n```\n\nSet your AI provider in `.env` — minimal setup with OpenAI:\n\n```env\nEMBEDDING_PROVIDER=openai\nENTITY_EXTRACTION_PROVIDER=openai\nUSE_LLM_FOR_MEMORY_CREATION=true\nOPENAI_API_KEY=sk-...\n```\n\n> Without any AI keys the stack still starts — dummy providers return non-semantic embeddings, useful for testing the API surface.\n\n> 💡 **Want zero cloud API calls?** v2.0+ ships a self-hosted embedder\n> profile (`BAAI/bge-m3` on a [HuggingFace TEI](https://github.com/huggingface/text-embeddings-inference)\n> sidecar). Bring up the stack with `docker compose --profile embed-local up -d`\n> and set the four `OPENAI_EMBEDDING_*` envs from `.env.example` — see\n> [`docs/local-embedder.md`](docs/local-embedder.md) for the full setup.\n> Combined with `IS_STANDALONE=true` (below) this is a fully self-contained\n> deployment with no external API calls.\n\n<details>\n<summary>Other providers (Gemini, Anthropic, OpenRouter, self-hosted)</summary>\n\n| Provider | `.env` settings | Required key |\n|---|---|---|\n| **OpenAI** (default) | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=openai` | `OPENAI_API_KEY` |\n| **Google Gemini** | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=gemini` | `GEMINI_API_KEY` + `OPENAI_API_KEY` |\n| **Anthropic** | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=anthropic` | `ANTHROPIC_API_KEY` + `OPENAI_API_KEY` |\n| **OpenRouter** | `EMBEDDING_PROVIDER=openai`<br>`ENTITY_EXTRACTION_PROVIDER=openrouter` | `OPENROUTER_API_KEY` + `OPENAI_API_KEY` |\n| **Self-hosted (TEI / bge-m3)** | `--profile embed-local` + `OPENAI_EMBEDDING_BASE_URL=http://tei:80/v1`<br>+ `OPENAI_EMBEDDING_MODEL=BAAI/bge-m3`<br>+ `OPENAI_EMBEDDING_SEND_DIMENSIONS=false` | none — runs locally |\n\nAnthropic, Gemini, and OpenRouter don't offer embedding APIs here — pair them with OpenAI (or with TEI) for embeddings. You can mix providers freely. Gemini uses the [Google AI Studio](https://aistudio.google.com/) key-auth Developer API (no GCP project/ADC required). The self-hosted TEI row keeps `EMBEDDING_PROVIDER=openai` because TEI speaks the same OpenAI-compatible API; see [`docs/local-embedder.md`](docs/local-embedder.md) for hardware sizing, GPU setup, and model swapping.\n\n</details>\n\n#### 2. Start the stack\n\n```bash\ndocker compose up -d\n```\n\nBy default this **pulls the multi-arch images from `ghcr.io`** (`linux/amd64` + `linux/arm64`) on first run — takes ~30 seconds. Subsequent `up` commands re-use the cached image (no registry round-trip, works offline). To pin a specific version, set `MEMCLAW_VERSION=v1.2.3` in your `.env`. To build from local source instead (e.g. when iterating on a fork), run `docker compose up --build --no-pull`.\n\nTo upgrade to a newer image at the same tag (e.g. `:latest` after we cut a new release), run `docker compose pull && docker compose up -d`. Without an explicit `pull`, the local cache wins — there's no silent version drift.\n\n> **Offline / air-gapped operation**: depending on whether the image is already cached locally:\n> - **Image cached, no network**: `docker compose up -d` works as-is — `pull_policy: missing` doesn't try to pull when the image is present. Use `docker compose up --no-pull` if you want to be explicit.\n> - **No local image, no network**: `docker compose up --build --no-pull` (build from source, don't try to pull).\n> - **Strict no-network guarantee** (e.g. an air-gapped pipeline that should never reach `ghcr.io`): drop a `docker-compose.override.yml` setting `pull_policy: never` for both services — Compose then fails fast if the image is absent rather than attempting a pull.\n\n| Service | URL |\n|---|---|\n| Core API (REST + MCP) | http://localhost:8000 |\n| Core Storage API | http://localhost:8002 |\n| PostgreSQL (pgvector) | localhost:5432 |\n| Redis | localhost:6379 |\n\n#### 3. Verify\n\n```bash\ncurl http://localhost:8000/api/v1/health\n# {\"status\":\"ok\",\"database\":\"connected\",...}\n```\n\n#### 4. Write and search\n\n```bash\n# Write a memory (standalone mode — no API key needed)\ncurl -X POST http://localhost:8000/api/v1/memories \\\n  -H \"X-API-Key: standalone\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"tenant_id\": \"default\", \"content\": \"Our auth service uses JWT with 15-minute expiry.\"}'\n\n# Search for it\ncurl -X POST http://localhost:8000/api/v1/search \\\n  -H \"X-API-Key: standalone\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"tenant_id\": \"default\", \"query\": \"authentication token lifetime\"}'\n```\n\nThe write response includes LLM-inferred `type`, `title`, `summary`, `tags`, `status`, and `importance_score` — all from a single `content` field.\n\n<details>\n<summary>Auth modes</summary>\n\nOSS supports three auth paths. Pick one and add it to your `.env`, then `docker compose up -d` to restart.\n\n**Standalone** — single-tenant (`tenant_id=\"default\"`), simplest for local / self-install:\n```env\nIS_STANDALONE=true\n```\nNo API key required for REST. MCP still expects a non-empty `X-API-Key` header — any value works.\n\n> Pair Standalone mode with `--profile embed-local` (see [`docs/local-embedder.md`](docs/local-embedder.md)) for a fully self-contained deployment: no admin keys, no external API calls, all embeddings computed locally. Useful for offline / air-gapped environments and personal-laptop installs.\n\n**Admin key** — multi-tenant with full access:\n```env\nADMIN_API_KEY=your-long-random-admin-key\n```\nPass `X-API-Key: your-long-random-admin-key` and include `tenant_id` in request bodies / query params.\n\n**Shared gate** — for network-exposed OSS deployments:\n```env\nMEMCLAW_API_KEY=your-shared-key\n```\nClients send `X-API-Key: your-shared-key` plus `X-Tenant-ID: <tenant>`.\n\n> See [AGENT-INSTALL.md](AGENT-INSTALL.md) for the full agent self-install walkthrough.\n\n</details>\n\n<details>\n<summary>Running tests</summary>\n\n```bash\n# Unit tests (no DB needed)\npytest tests/ -m \"unit\"\n\n# All tests (requires PostgreSQL)\ndocker compose up -d db\npytest tests/ -m \"not benchmark\"\n\n# Smoke test against live API (~30s, auto-cleanup)\npython scripts/smoke_test.py --url http://localhost:8000 --api-key <admin-key>\n```\n\n</details>\n\n### OpenClaw Plugin\n\nAlready running an OpenClaw fleet? Install MemClaw as a plugin against either the managed platform or your self-hosted stack:\n\n```bash\n# Point at whichever URL hosts your MemClaw API\nexport MEMCLAW_URL=https://memclaw.net          # managed\n# or:  export MEMCLAW_URL=http://localhost:8000  # self-hosted\nexport MEMCLAW_KEY=your-key                      # `standalone` works in self-hosted standalone mode\nexport MEMCLAW_FLEET=my-fleet\n\ncurl -sf -H \"X-API-Key: $MEMCLAW_KEY\" \\\n  \"$MEMCLAW_URL/api/v1/install-plugin?fleet_id=$MEMCLAW_FLEET&api_url=$MEMCLAW_URL\" | bash\n\n# Restart the gateway to load the plugin\nopenclaw gateway restart\n```\n\nThe plugin claims the OpenClaw `memory` slot (replacing `memory-core`) and exposes the same 12 MCP tools. Full setup, agent prompts, and trust levels: [static/docs/integration-guide.md](static/docs/integration-guide.md).\n\n---\n\n## Features\n\n### Governance\n\n- **Tenant isolation** — row-level database separation per tenant; PII auto-detected and quarantined before it can cross fleet boundaries\n- **Visibility scopes** — every memory is stamped at write time: `scope_agent` (private), `scope_team` (fleet-wide, default), or `scope_org` (cross-fleet). Cross-fleet recall is permissioned, not open\n- **Agent trust tiers** — four levels control cross-fleet reads, writes, and deletes. Agents are either provisioned atomically via `POST /admin/agent-keys/provision` (recommended — mints key + row + trust + fleet in one call) or auto-registered on first write (legacy fallback)\n- **Full audit log** — every write, delete, and transition logged with tenant and scope context\n\n### Memory Pipeline\n\n- **Single-pass LLM enrichment** — every write auto-classifies into one of 14 memory types, generates title/summary/tags, scores importance, flags PII, and extracts entities — from a single `content` field","lineStart":1,"lineEnd":260,"totalLines":965,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/README.md","time":{"start":1780727679443,"end":1780727679453}},"metadata":{"openai":{"itemId":"fc_020d7f924b1ec321016a23bf7f4fe88191baacdf50e0ebb01e"}},"id":"prt_e9ba409d2001sI3duSZv1ymNTV","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba3d1cf0017X0Ediqx0UTlLy"}}
{"type":"tool_use","timestamp":1780727679456,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_V9g2LSWW3u1kpj8BgT54lcO7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n1: import asyncio\n2: import hashlib\n3: import json\n4: import logging\n5: import re\n6: import time\n7: import uuid\n8: from datetime import UTC, datetime, timedelta\n9: from typing import cast\n10: from uuid import UUID, uuid4\n11: \n12: from fastapi import HTTPException\n13: from sqlalchemy.exc import SQLAlchemyError\n14: from sqlalchemy.ext.asyncio import AsyncSession\n15: \n16: from core_api.clients.storage_client import get_storage_client\n17: from core_api.config import settings\n18: from core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\n19: from core_api.tasks import track_task\n20: \n21: try:\n22:     from openai import OpenAIError\n23: except ImportError:\n24: \n25:     class OpenAIError(Exception):\n26:         pass  # type: ignore[misc]\n27: \n28: \n29: try:\n30:     from google.api_core.exceptions import GoogleAPIError\n31: except ImportError:\n32: \n33:     class GoogleAPIError(Exception):\n34:         pass  # type: ignore[misc]\n35: \n36: \n37: from common.constants import VECTOR_DIM\n38: from common.embedding import get_embedding, get_embeddings_batch, get_query_embedding\n39: from common.events import publish_memory_embed_request, publish_memory_enrich_request\n40: from core_api.constants import (\n41:     BULK_EMBEDDING_TIMEOUT_SECONDS,\n42:     BULK_ENRICHMENT_CONCURRENCY,\n43:     BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS,\n44:     CHUNKING_THRESHOLD_CHARS,\n45:     CRYSTALLIZER_SHORT_CONTENT_CHARS,\n46:     DEFAULT_MEMORY_WEIGHT,\n47:     DEFAULT_SEARCH_TOP_K,\n48:     EMBEDDING_CACHE_TTL,\n49:     FRESHNESS_DECAY_DAYS,\n50:     FRESHNESS_FLOOR,\n51:     FTS_BOOST_MAX_TOKENS,\n52:     FTS_BOOST_SPECIFICITY_RATIO,\n53:     FTS_WEIGHT,\n54:     FTS_WEIGHT_BOOSTED,\n55:     GRAPH_HOP_BOOST,\n56:     GRAPH_MAX_BOOSTED_MEMORIES,\n57:     GRAPH_MAX_HOPS,\n58:     MIN_SEARCH_SIMILARITY,\n59:     OPENAI_EMBEDDING_MODEL,\n60:     RECALL_BOOST_CAP,\n61:     RECALL_DECAY_WINDOW_DAYS,\n62:     SEARCH_OVERFETCH_FACTOR,\n63:     SIMILARITY_BLEND,\n64: )\n65: from core_api.schemas import (\n66:     BulkItemResult,\n67:     BulkMemoryCreate,\n68:     BulkMemoryResponse,\n69:     ContradictionInfo,\n70:     EntityLinkOut,\n71:     MemoryCreate,\n72:     MemoryOut,\n73:     MemoryUpdate,\n74: )\n75: from core_api.services.entity_extraction_worker import process_entity_extraction\n76: from core_api.services.entity_tokens import extract_entity_tokens\n77: from core_api.services.hooks import get_hooks\n78: from core_api.services.task_tracker import tracked_task\n79: \n80: logger = logging.getLogger(__name__)\n81: \n82: # Hardcoded pipeline flags. Intentionally not read from env/Settings: the legacy\n83: # write/search paths are deprecated and scheduled for removal. If an emergency\n84: # rollback is needed, flip these to False and ship a hotfix — do NOT re-introduce\n85: # env-level configuration, since that caused prior silent divergence between\n86: # deployments and the default code path.\n87: _USE_PIPELINE_WRITE = True\n88: _USE_PIPELINE_SEARCH = True\n89: \n90: \n91: def _content_hash(tenant_id: str, fleet_id: str | None, content: str) -> str:\n92:     return hashlib.sha256(f\"{tenant_id}:{fleet_id or ''}:{content}\".encode()).hexdigest()\n93: \n94: \n95: def _auto_chunk_request_id() -> str:\n96:     \"\"\"Mint a per-row attempt id for in-process bulk-insert callers\n97:     (auto-chunk, atomic-facts) that have no ``X-Bulk-Attempt-Id`` from\n98:     a client (CAURA-602). The ``auto-chunk:`` prefix keeps these rows\n99:     visually distinguishable in the partial unique index from\n100:     real client-side bulk attempts (``f\"{X-Bulk-Attempt-Id}:{idx}\"``).\n101:     \"\"\"\n102:     return f\"auto-chunk:{uuid4()}\"\n103: \n104: \n105: async def _find_semantic_duplicate(\n106:     db: AsyncSession,\n107:     tenant_id: str,\n108:     fleet_id: str | None,\n109:     embedding: list[float],\n110:     exclude_id: UUID | None = None,\n111:     visibility: str | None = None,\n112:     min_similarity: float | None = None,\n113: ) -> dict | None:\n114:     \"\"\"Find a near-duplicate memory via cosine similarity.\n115: \n116:     Returns the closest match above the threshold (or ``None``). The\n117:     returned dict carries a ``similarity`` field — added in A1 #16 so\n118:     two-tier callers can dispatch by score.\n119: \n120:     ``min_similarity`` defaults to ``SEMANTIC_DEDUP_THRESHOLD`` (0.95)\n121:     via the storage layer for back-compat. A1 #16's\n122:     ``CheckSemanticDuplicate`` pipeline step passes\n123:     ``SEMANTIC_DEDUP_JUDGE_THRESHOLD`` to surface the judge band.\n124:     \"\"\"\n125:     sc = get_storage_client()\n126:     payload: dict = {\n127:         \"tenant_id\": tenant_id,\n128:         \"fleet_id\": fleet_id,\n129:         \"embedding\": embedding,\n130:         \"exclude_id\": str(exclude_id) if exclude_id else None,\n131:         \"visibility\": visibility,\n132:     }\n133:     if min_similarity is not None:\n134:         payload[\"min_similarity\"] = min_similarity\n135:     return await sc.find_semantic_duplicate(payload)\n136: \n137: \n138: def _dict_to_memory_out(\n139:     mem: dict,\n140:     entity_links: list[EntityLinkOut] | None = None,\n141:     similarity: float | None = None,\n142:     contradictions: list[ContradictionInfo] | None = None,\n143: ) -> MemoryOut:\n144:     \"\"\"Convert a storage-client dict to MemoryOut.\"\"\"\n145:     # Explicit None-check: ``{}`` is falsy, so ``or`` would fall\n146:     # through to the legacy ``\"metadata\"`` key whenever the column\n147:     # is an intentional empty dict, masking the stored value as\n148:     # ``None`` in the API response.\n149:     raw_meta = mem.get(\"metadata_\")\n150:     metadata = raw_meta if raw_meta is not None else mem.get(\"metadata\")\n151:     return MemoryOut(\n152:         id=mem.get(\"id\"),\n153:         tenant_id=mem.get(\"tenant_id\"),\n154:         fleet_id=mem.get(\"fleet_id\"),\n155:         agent_id=mem.get(\"agent_id\"),\n156:         memory_type=mem.get(\"memory_type\"),\n157:         title=mem.get(\"title\"),\n158:         content=mem.get(\"content\"),\n159:         weight=mem.get(\"weight\"),\n160:         source_uri=mem.get(\"source_uri\"),\n161:         run_id=mem.get(\"run_id\"),\n162:         metadata=metadata,\n163:         created_at=mem.get(\"created_at\"),\n164:         expires_at=mem.get(\"expires_at\"),\n165:         entity_links=entity_links or [],\n166:         similarity=similarity,\n167:         subject_entity_id=mem.get(\"subject_entity_id\"),\n168:         predicate=mem.get(\"predicate\"),\n169:         object_value=mem.get(\"object_value\"),\n170:         ts_valid_start=mem.get(\"ts_valid_start\"),\n171:         ts_valid_end=mem.get(\"ts_valid_end\"),\n172:         status=mem.get(\"status\"),\n173:         visibility=mem.get(\"visibility\"),\n174:         recall_count=mem.get(\"recall_count\"),\n175:         last_recalled_at=mem.get(\"last_recalled_at\"),\n176:         supersedes_id=mem.get(\"supersedes_id\"),\n177:         superseded_by=contradictions if contradictions else None,\n178:     )\n179: \n180: \n181: def _mem_attr(memory, key: str, default=None):\n182:     \"\"\"Get a field from either an ORM Memory object or a dict.\"\"\"\n183:     if isinstance(memory, dict):\n184:         return memory.get(key, default)\n185:     return getattr(memory, key, default)\n186: \n187: \n188: def _memory_to_out(\n189:     memory,\n190:     entity_links: list[EntityLinkOut] | None = None,\n191:     similarity: float | None = None,\n192:     contradictions: list[ContradictionInfo] | None = None,\n193: ) -> MemoryOut:\n194:     # See ``_dict_to_memory_out`` for the falsy-``{}`` trap.\n195:     if isinstance(memory, dict):\n196:         raw_meta = memory.get(\"metadata_\")\n197:         metadata = raw_meta if raw_meta is not None else memory.get(\"metadata\")\n198:     else:\n199:         metadata = _mem_attr(memory, \"metadata_\")\n200:     return MemoryOut(\n201:         id=_mem_attr(memory, \"id\"),\n202:         tenant_id=_mem_attr(memory, \"tenant_id\"),\n203:         fleet_id=_mem_attr(memory, \"fleet_id\"),\n204:         agent_id=_mem_attr(memory, \"agent_id\"),\n205:         memory_type=_mem_attr(memory, \"memory_type\"),\n206:         title=_mem_attr(memory, \"title\"),\n207:         content=_mem_attr(memory, \"content\"),\n208:         weight=_mem_attr(memory, \"weight\"),\n209:         source_uri=_mem_attr(memory, \"source_uri\"),\n210:         run_id=_mem_attr(memory, \"run_id\"),\n211:         metadata=metadata,\n212:         created_at=_mem_attr(memory, \"created_at\"),\n213:         expires_at=_mem_attr(memory, \"expires_at\"),\n214:         entity_links=entity_links or [],\n215:         similarity=similarity,\n216:         subject_entity_id=_mem_attr(memory, \"subject_entity_id\"),\n217:         predicate=_mem_attr(memory, \"predicate\"),\n218:         object_value=_mem_attr(memory, \"object_value\"),\n219:         ts_valid_start=_mem_attr(memory, \"ts_valid_start\"),\n220:         ts_valid_end=_mem_attr(memory, \"ts_valid_end\"),\n221:         status=_mem_attr(memory, \"status\"),\n222:         visibility=_mem_attr(memory, \"visibility\"),\n223:         recall_count=_mem_attr(memory, \"recall_count\"),\n224:         last_recalled_at=_mem_attr(memory, \"last_recalled_at\"),\n225:         supersedes_id=_mem_attr(memory, \"supersedes_id\"),\n226:         superseded_by=contradictions if contradictions else None,\n227:     )\n228: \n229: \n230: async def create_memory(db: AsyncSession, data: MemoryCreate) -> MemoryOut:\n231:     if _USE_PIPELINE_WRITE:\n232:         return await _create_memory_pipeline(db, data)\n233:     logger.warning(\"legacy write path invoked; this path is deprecated and scheduled for removal\")\n234:     return await _create_memory_legacy(db, data)\n235: \n236: \n237: async def _create_memory_pipeline(db: AsyncSession, data: MemoryCreate) -> MemoryOut:\n238:     \"\"\"Pipeline-based create_memory — same logic, decomposed into timed steps.\"\"\"\n239:     from core_api.pipeline.compositions.write import (\n240:         build_enrichment_pipeline,\n241:         build_fast_write_pipeline,\n242:         build_stm_write_pipeline,\n243:         build_strong_write_pipeline,\n244:     )\n245:     from core_api.pipeline.context import PipelineContext\n246:     from core_api.services.organization_settings import resolve_config\n247: \n248:     # STM branch: bypass tenant config resolution and LTM pipelines entirely\n249:     if data.write_mode == \"stm\":\n250:         from core_api.config import settings as _stm_settings\n251: \n252:         if not _stm_settings.use_stm:\n253:             from fastapi import HTTPException\n254: \n255:             raise HTTPException(\n256:                 status_code=422,\n257:                 detail=\"STM is not enabled. Set USE_STM=true to enable short-term memory.\",\n258:             )\n259:         ctx = PipelineContext(\n260:             db=db,\n261:             data={\"input\": data, \"t0\": time.perf_counter()},\n262:         )\n263:         pipeline = build_stm_write_pipeline()\n264:         await pipeline.run(ctx)\n265:         return ctx.data[\"stm_response\"]\n266: \n267:     # Resolve tenant config BEFORE building the pipeline\n268:     tenant_config = await resolve_config(db, data.tenant_id)\n269: \n270:     # Extract-only and auto-chunk branches: always use the original enrichment+persist flow\n271:     if not data.persist or (\n272:         len(data.content) > CHUNKING_THRESHOLD_CHARS and tenant_config.auto_chunk_enabled\n273:     ):\n274:         ctx = PipelineContext(db=db, data={\"input\": data, \"t0\": time.perf_counter()})\n275: \n276:         # Phase 1: Enrichment (always runs)\n277:         enrichment_pipeline = build_enrichment_pipeline()\n278:         await enrichment_pipeline.run(ctx)\n279: \n280:         fields = ctx.data[\"memory_fields\"]\n281: \n282:         # Branch: extract-only\n283:         if not data.persist:\n284:             return MemoryOut(\n285:                 id=uuid.uuid4(),\n286:                 tenant_id=data.tenant_id,\n287:                 fleet_id=data.fleet_id,\n288:                 agent_id=data.agent_id,\n289:                 memory_type=fields[\"memory_type\"],\n290:                 title=fields[\"title\"],\n291:                 content=data.content,\n292:                 weight=fields[\"weight\"],\n293:                 source_uri=data.source_uri,\n294:                 run_id=data.run_id,\n295:                 # ``fields[\"metadata\"]`` is always a dict — initialised\n296:                 # as ``data.metadata or {}`` in MergeEnrichmentFields. The\n297:                 # previous ``or None`` coerced an intentional ``{}`` to\n298:                 # ``None``, the same falsy-``{}`` trap fixed in the four\n299:                 # read-path serializers above. Pass the dict through.\n300:                 metadata=fields[\"metadata\"],\n301:                 created_at=datetime.now(UTC),\n302:                 expires_at=data.expires_at,\n303:                 entity_links=[],\n304:                 subject_entity_id=data.subject_entity_id,\n305:                 predicate=data.predicate,\n306:                 object_value=data.object_value,\n307:                 ts_valid_start=fields[\"ts_valid_start\"],\n308:                 ts_valid_end=fields[\"ts_valid_end\"],\n309:                 status=fields[\"status\"],\n310:             )\n311: \n312:         # Branch: auto-chunk\n313:         return await _handle_auto_chunk_from_ctx(db, data, ctx)\n314: \n315:     # Standard persist path: resolve write mode and pick pipeline\n316:     resolved_mode = _resolve_write_mode(data, tenant_config)\n317: \n318:     ctx = PipelineContext(\n319:         db=db,\n320:         data={\n321:             \"input\": data,\n322:             \"t0\": time.perf_counter(),\n323:             \"resolved_write_mode\": resolved_mode,\n324:         },\n325:         tenant_config=tenant_config,\n326:     )\n327: \n328:     if resolved_mode == \"fast\":\n329:         pipeline = build_fast_write_pipeline()\n330:     else:\n331:         pipeline = build_strong_write_pipeline()\n332: \n333:     # CAURA-682 Phase 1: per-phase write-latency emission. One line per\n334:     # write request, structured so GCP log queries can slice by tenant /\n335:     # phase to identify the dominant phase under noisy-neighbor load\n336:     # (loadtest finding ``noisy-neighbor-write``, 3.58x degradation).\n337:     # ``phase_timings`` keys are present only for phases that actually\n338:     # ran; missing key = deferred to core-worker via background topic.\n339:     #\n340:     # The emit lives in ``finally`` so timeouts — the actual\n341:     # noisy-neighbor failure mode (``HTTPException(504)`` from\n342:     # ``parallel_embed_enrich`` on ``asyncio.wait_for`` timeout) — also\n343:     # produce a log line with the partial timings that DID land. Without\n344:     # this, the worst case for diagnosis (timed-out writes) is exactly\n345:     # the case that produces no diagnostic signal. ``success`` lets GCP\n346:     # queries filter failed from successful writes.\n347:     _exc: BaseException | None = None\n348:     try:\n349:         try:\n350:             await pipeline.run(ctx)\n351:         except BaseException as e:\n352:             _exc = e\n353:             raise\n354: \n355:         memory = ctx.data[\"memory\"]\n356:         return _memory_to_out(\n357:             memory,\n358:             entity_links=[\n359:                 EntityLinkOut(entity_id=link.entity_id, role=link.role) for link in data.entity_links\n360:             ],\n\n(Showing lines 1-360 of 3230. Use offset=361 to continue.)\n</content>","metadata":{"preview":"import asyncio\nimport hashlib\nimport json\nimport logging\nimport re\nimport time\nimport uuid\nfrom datetime import UTC, datetime, timedelta\nfrom typing import cast\nfrom uuid import UUID, uuid4\n\nfrom fastapi import HTTPException\nfrom sqlalchemy.exc import SQLAlchemyError\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\nfrom core_api.tasks import track_task\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"import asyncio\nimport hashlib\nimport json\nimport logging\nimport re\nimport time\nimport uuid\nfrom datetime import UTC, datetime, timedelta\nfrom typing import cast\nfrom uuid import UUID, uuid4\n\nfrom fastapi import HTTPException\nfrom sqlalchemy.exc import SQLAlchemyError\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\nfrom core_api.tasks import track_task\n\ntry:\n    from openai import OpenAIError\nexcept ImportError:\n\n    class OpenAIError(Exception):\n        pass  # type: ignore[misc]\n\n\ntry:\n    from google.api_core.exceptions import GoogleAPIError\nexcept ImportError:\n\n    class GoogleAPIError(Exception):\n        pass  # type: ignore[misc]\n\n\nfrom common.constants import VECTOR_DIM\nfrom common.embedding import get_embedding, get_embeddings_batch, get_query_embedding\nfrom common.events import publish_memory_embed_request, publish_memory_enrich_request\nfrom core_api.constants import (\n    BULK_EMBEDDING_TIMEOUT_SECONDS,\n    BULK_ENRICHMENT_CONCURRENCY,\n    BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS,\n    CHUNKING_THRESHOLD_CHARS,\n    CRYSTALLIZER_SHORT_CONTENT_CHARS,\n    DEFAULT_MEMORY_WEIGHT,\n    DEFAULT_SEARCH_TOP_K,\n    EMBEDDING_CACHE_TTL,\n    FRESHNESS_DECAY_DAYS,\n    FRESHNESS_FLOOR,\n    FTS_BOOST_MAX_TOKENS,\n    FTS_BOOST_SPECIFICITY_RATIO,\n    FTS_WEIGHT,\n    FTS_WEIGHT_BOOSTED,\n    GRAPH_HOP_BOOST,\n    GRAPH_MAX_BOOSTED_MEMORIES,\n    GRAPH_MAX_HOPS,\n    MIN_SEARCH_SIMILARITY,\n    OPENAI_EMBEDDING_MODEL,\n    RECALL_BOOST_CAP,\n    RECALL_DECAY_WINDOW_DAYS,\n    SEARCH_OVERFETCH_FACTOR,\n    SIMILARITY_BLEND,\n)\nfrom core_api.schemas import (\n    BulkItemResult,\n    BulkMemoryCreate,\n    BulkMemoryResponse,\n    ContradictionInfo,\n    EntityLinkOut,\n    MemoryCreate,\n    MemoryOut,\n    MemoryUpdate,\n)\nfrom core_api.services.entity_extraction_worker import process_entity_extraction\nfrom core_api.services.entity_tokens import extract_entity_tokens\nfrom core_api.services.hooks import get_hooks\nfrom core_api.services.task_tracker import tracked_task\n\nlogger = logging.getLogger(__name__)\n\n# Hardcoded pipeline flags. Intentionally not read from env/Settings: the legacy\n# write/search paths are deprecated and scheduled for removal. If an emergency\n# rollback is needed, flip these to False and ship a hotfix — do NOT re-introduce\n# env-level configuration, since that caused prior silent divergence between\n# deployments and the default code path.\n_USE_PIPELINE_WRITE = True\n_USE_PIPELINE_SEARCH = True\n\n\ndef _content_hash(tenant_id: str, fleet_id: str | None, content: str) -> str:\n    return hashlib.sha256(f\"{tenant_id}:{fleet_id or ''}:{content}\".encode()).hexdigest()\n\n\ndef _auto_chunk_request_id() -> str:\n    \"\"\"Mint a per-row attempt id for in-process bulk-insert callers\n    (auto-chunk, atomic-facts) that have no ``X-Bulk-Attempt-Id`` from\n    a client (CAURA-602). The ``auto-chunk:`` prefix keeps these rows\n    visually distinguishable in the partial unique index from\n    real client-side bulk attempts (``f\"{X-Bulk-Attempt-Id}:{idx}\"``).\n    \"\"\"\n    return f\"auto-chunk:{uuid4()}\"\n\n\nasync def _find_semantic_duplicate(\n    db: AsyncSession,\n    tenant_id: str,\n    fleet_id: str | None,\n    embedding: list[float],\n    exclude_id: UUID | None = None,\n    visibility: str | None = None,\n    min_similarity: float | None = None,\n) -> dict | None:\n    \"\"\"Find a near-duplicate memory via cosine similarity.\n\n    Returns the closest match above the threshold (or ``None``). The\n    returned dict carries a ``similarity`` field — added in A1 #16 so\n    two-tier callers can dispatch by score.\n\n    ``min_similarity`` defaults to ``SEMANTIC_DEDUP_THRESHOLD`` (0.95)\n    via the storage layer for back-compat. A1 #16's\n    ``CheckSemanticDuplicate`` pipeline step passes\n    ``SEMANTIC_DEDUP_JUDGE_THRESHOLD`` to surface the judge band.\n    \"\"\"\n    sc = get_storage_client()\n    payload: dict = {\n        \"tenant_id\": tenant_id,\n        \"fleet_id\": fleet_id,\n        \"embedding\": embedding,\n        \"exclude_id\": str(exclude_id) if exclude_id else None,\n        \"visibility\": visibility,\n    }\n    if min_similarity is not None:\n        payload[\"min_similarity\"] = min_similarity\n    return await sc.find_semantic_duplicate(payload)\n\n\ndef _dict_to_memory_out(\n    mem: dict,\n    entity_links: list[EntityLinkOut] | None = None,\n    similarity: float | None = None,\n    contradictions: list[ContradictionInfo] | None = None,\n) -> MemoryOut:\n    \"\"\"Convert a storage-client dict to MemoryOut.\"\"\"\n    # Explicit None-check: ``{}`` is falsy, so ``or`` would fall\n    # through to the legacy ``\"metadata\"`` key whenever the column\n    # is an intentional empty dict, masking the stored value as\n    # ``None`` in the API response.\n    raw_meta = mem.get(\"metadata_\")\n    metadata = raw_meta if raw_meta is not None else mem.get(\"metadata\")\n    return MemoryOut(\n        id=mem.get(\"id\"),\n        tenant_id=mem.get(\"tenant_id\"),\n        fleet_id=mem.get(\"fleet_id\"),\n        agent_id=mem.get(\"agent_id\"),\n        memory_type=mem.get(\"memory_type\"),\n        title=mem.get(\"title\"),\n        content=mem.get(\"content\"),\n        weight=mem.get(\"weight\"),\n        source_uri=mem.get(\"source_uri\"),\n        run_id=mem.get(\"run_id\"),\n        metadata=metadata,\n        created_at=mem.get(\"created_at\"),\n        expires_at=mem.get(\"expires_at\"),\n        entity_links=entity_links or [],\n        similarity=similarity,\n        subject_entity_id=mem.get(\"subject_entity_id\"),\n        predicate=mem.get(\"predicate\"),\n        object_value=mem.get(\"object_value\"),\n        ts_valid_start=mem.get(\"ts_valid_start\"),\n        ts_valid_end=mem.get(\"ts_valid_end\"),\n        status=mem.get(\"status\"),\n        visibility=mem.get(\"visibility\"),\n        recall_count=mem.get(\"recall_count\"),\n        last_recalled_at=mem.get(\"last_recalled_at\"),\n        supersedes_id=mem.get(\"supersedes_id\"),\n        superseded_by=contradictions if contradictions else None,\n    )\n\n\ndef _mem_attr(memory, key: str, default=None):\n    \"\"\"Get a field from either an ORM Memory object or a dict.\"\"\"\n    if isinstance(memory, dict):\n        return memory.get(key, default)\n    return getattr(memory, key, default)\n\n\ndef _memory_to_out(\n    memory,\n    entity_links: list[EntityLinkOut] | None = None,\n    similarity: float | None = None,\n    contradictions: list[ContradictionInfo] | None = None,\n) -> MemoryOut:\n    # See ``_dict_to_memory_out`` for the falsy-``{}`` trap.\n    if isinstance(memory, dict):\n        raw_meta = memory.get(\"metadata_\")\n        metadata = raw_meta if raw_meta is not None else memory.get(\"metadata\")\n    else:\n        metadata = _mem_attr(memory, \"metadata_\")\n    return MemoryOut(\n        id=_mem_attr(memory, \"id\"),\n        tenant_id=_mem_attr(memory, \"tenant_id\"),\n        fleet_id=_mem_attr(memory, \"fleet_id\"),\n        agent_id=_mem_attr(memory, \"agent_id\"),\n        memory_type=_mem_attr(memory, \"memory_type\"),\n        title=_mem_attr(memory, \"title\"),\n        content=_mem_attr(memory, \"content\"),\n        weight=_mem_attr(memory, \"weight\"),\n        source_uri=_mem_attr(memory, \"source_uri\"),\n        run_id=_mem_attr(memory, \"run_id\"),\n        metadata=metadata,\n        created_at=_mem_attr(memory, \"created_at\"),\n        expires_at=_mem_attr(memory, \"expires_at\"),\n        entity_links=entity_links or [],\n        similarity=similarity,\n        subject_entity_id=_mem_attr(memory, \"subject_entity_id\"),\n        predicate=_mem_attr(memory, \"predicate\"),\n        object_value=_mem_attr(memory, \"object_value\"),\n        ts_valid_start=_mem_attr(memory, \"ts_valid_start\"),\n        ts_valid_end=_mem_attr(memory, \"ts_valid_end\"),\n        status=_mem_attr(memory, \"status\"),\n        visibility=_mem_attr(memory, \"visibility\"),\n        recall_count=_mem_attr(memory, \"recall_count\"),\n        last_recalled_at=_mem_attr(memory, \"last_recalled_at\"),\n        supersedes_id=_mem_attr(memory, \"supersedes_id\"),\n        superseded_by=contradictions if contradictions else None,\n    )\n\n\nasync def create_memory(db: AsyncSession, data: MemoryCreate) -> MemoryOut:\n    if _USE_PIPELINE_WRITE:\n        return await _create_memory_pipeline(db, data)\n    logger.warning(\"legacy write path invoked; this path is deprecated and scheduled for removal\")\n    return await _create_memory_legacy(db, data)\n\n\nasync def _create_memory_pipeline(db: AsyncSession, data: MemoryCreate) -> MemoryOut:\n    \"\"\"Pipeline-based create_memory — same logic, decomposed into timed steps.\"\"\"\n    from core_api.pipeline.compositions.write import (\n        build_enrichment_pipeline,\n        build_fast_write_pipeline,\n        build_stm_write_pipeline,\n        build_strong_write_pipeline,\n    )\n    from core_api.pipeline.context import PipelineContext\n    from core_api.services.organization_settings import resolve_config\n\n    # STM branch: bypass tenant config resolution and LTM pipelines entirely\n    if data.write_mode == \"stm\":\n        from core_api.config import settings as _stm_settings\n\n        if not _stm_settings.use_stm:\n            from fastapi import HTTPException\n\n            raise HTTPException(\n                status_code=422,\n                detail=\"STM is not enabled. Set USE_STM=true to enable short-term memory.\",\n            )\n        ctx = PipelineContext(\n            db=db,\n            data={\"input\": data, \"t0\": time.perf_counter()},\n        )\n        pipeline = build_stm_write_pipeline()\n        await pipeline.run(ctx)\n        return ctx.data[\"stm_response\"]\n\n    # Resolve tenant config BEFORE building the pipeline\n    tenant_config = await resolve_config(db, data.tenant_id)\n\n    # Extract-only and auto-chunk branches: always use the original enrichment+persist flow\n    if not data.persist or (\n        len(data.content) > CHUNKING_THRESHOLD_CHARS and tenant_config.auto_chunk_enabled\n    ):\n        ctx = PipelineContext(db=db, data={\"input\": data, \"t0\": time.perf_counter()})\n\n        # Phase 1: Enrichment (always runs)\n        enrichment_pipeline = build_enrichment_pipeline()\n        await enrichment_pipeline.run(ctx)\n\n        fields = ctx.data[\"memory_fields\"]\n\n        # Branch: extract-only\n        if not data.persist:\n            return MemoryOut(\n                id=uuid.uuid4(),\n                tenant_id=data.tenant_id,\n                fleet_id=data.fleet_id,\n                agent_id=data.agent_id,\n                memory_type=fields[\"memory_type\"],\n                title=fields[\"title\"],\n                content=data.content,\n                weight=fields[\"weight\"],\n                source_uri=data.source_uri,\n                run_id=data.run_id,\n                # ``fields[\"metadata\"]`` is always a dict — initialised\n                # as ``data.metadata or {}`` in MergeEnrichmentFields. The\n                # previous ``or None`` coerced an intentional ``{}`` to\n                # ``None``, the same falsy-``{}`` trap fixed in the four\n                # read-path serializers above. Pass the dict through.\n                metadata=fields[\"metadata\"],\n                created_at=datetime.now(UTC),\n                expires_at=data.expires_at,\n                entity_links=[],\n                subject_entity_id=data.subject_entity_id,\n                predicate=data.predicate,\n                object_value=data.object_value,\n                ts_valid_start=fields[\"ts_valid_start\"],\n                ts_valid_end=fields[\"ts_valid_end\"],\n                status=fields[\"status\"],\n            )\n\n        # Branch: auto-chunk\n        return await _handle_auto_chunk_from_ctx(db, data, ctx)\n\n    # Standard persist path: resolve write mode and pick pipeline\n    resolved_mode = _resolve_write_mode(data, tenant_config)\n\n    ctx = PipelineContext(\n        db=db,\n        data={\n            \"input\": data,\n            \"t0\": time.perf_counter(),\n            \"resolved_write_mode\": resolved_mode,\n        },\n        tenant_config=tenant_config,\n    )\n\n    if resolved_mode == \"fast\":\n        pipeline = build_fast_write_pipeline()\n    else:\n        pipeline = build_strong_write_pipeline()\n\n    # CAURA-682 Phase 1: per-phase write-latency emission. One line per\n    # write request, structured so GCP log queries can slice by tenant /\n    # phase to identify the dominant phase under noisy-neighbor load\n    # (loadtest finding ``noisy-neighbor-write``, 3.58x degradation).\n    # ``phase_timings`` keys are present only for phases that actually\n    # ran; missing key = deferred to core-worker via background topic.\n    #\n    # The emit lives in ``finally`` so timeouts — the actual\n    # noisy-neighbor failure mode (``HTTPException(504)`` from\n    # ``parallel_embed_enrich`` on ``asyncio.wait_for`` timeout) — also\n    # produce a log line with the partial timings that DID land. Without\n    # this, the worst case for diagnosis (timed-out writes) is exactly\n    # the case that produces no diagnostic signal. ``success`` lets GCP\n    # queries filter failed from successful writes.\n    _exc: BaseException | None = None\n    try:\n        try:\n            await pipeline.run(ctx)\n        except BaseException as e:\n            _exc = e\n            raise\n\n        memory = ctx.data[\"memory\"]\n        return _memory_to_out(\n            memory,\n            entity_links=[\n                EntityLinkOut(entity_id=link.entity_id, role=link.role) for link in data.entity_links\n            ],","lineStart":1,"lineEnd":360,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780727679420,"end":1780727679455}},"metadata":{"openai":{"itemId":"fc_020d7f924b1ec321016a23bf7f4fcc8191a111c2db13776323"}},"id":"prt_e9ba409a7001KxSARcdTyGzRK4","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba3d1cf0017X0Ediqx0UTlLy"}}
{"type":"tool_use","timestamp":1780727679463,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_Y9Sh80e8rDwrmCl6kEPaBzlH","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","offset":1,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"PostgreSQL service -- all database queries for core tables.\n2: \n3: Single point of DB access for the OSS core-storage-api.  Every query that\n4: was previously spread across eight repository classes now lives here, grouped\n5: by domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n6: \n7: Session management uses a module-level ``async_sessionmaker`` backed by the\n8: shared engine from ``core_storage_api.database.init.get_engine``.\n9: \"\"\"\n10: \n11: from __future__ import annotations\n12: \n13: import json\n14: import logging\n15: from collections import OrderedDict\n16: from collections.abc import AsyncIterator, Sequence\n17: from contextlib import asynccontextmanager\n18: from datetime import UTC, datetime, timedelta\n19: from types import SimpleNamespace\n20: from typing import Any\n21: from uuid import UUID\n22: \n23: from sqlalchemy import and_, case, delete, false, func, literal_column, or_, select, text, tuple_\n24: from sqlalchemy import update as sql_update\n25: from sqlalchemy.dialects.postgresql import insert as pg_insert\n26: from sqlalchemy.exc import IntegrityError\n27: from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker\n28: from sqlalchemy.orm import load_only\n29: \n30: from common.constants import (\n31:     CONTRADICTION_CANDIDATE_MAX,\n32:     CONTRADICTION_SIMILARITY_THRESHOLD,\n33:     DEFAULT_RELATION_TYPE_WEIGHT,\n34:     ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n35:     GRAPH_MAX_HOPS,\n36:     RECALL_BOOST_SCALE,\n37:     RELATION_TYPE_WEIGHTS,\n38:     SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n39:     SEMANTIC_DEDUP_THRESHOLD,\n40:     TYPE_DECAY_DAYS,\n41: )\n42: from common.events.lifecycle_purge_request import MEMORY_RETENTION_MAX_DAYS\n43: from common.models import (\n44:     Agent,\n45:     AuditLog,\n46:     BackgroundTaskLog,\n47:     CrystallizationReport,\n48:     DedupReview,\n49:     Document,\n50:     Entity,\n51:     FleetCommand,\n52:     FleetNode,\n53:     IdempotencyResponse,\n54:     LifecycleAudit,\n55:     Memory,\n56:     MemoryEntityLink,\n57:     Relation,\n58: )\n59: from core_storage_api.observability import db_measure\n60: \n61: logger = logging.getLogger(__name__)\n62: \n63: # ---------------------------------------------------------------------------\n64: # Session factories (singletons)\n65: # ---------------------------------------------------------------------------\n66: #\n67: # Two factories bound to two engines: writer (primary) and reader\n68: # (replica when ``read_database_url`` is set, else the primary). The\n69: # factories are lazy so tests can swap the underlying engines before\n70: # the first request without touching service-module state.\n71: \n72: _session_factory: async_sessionmaker[AsyncSession] | None = None\n73: _read_session_factory: async_sessionmaker[AsyncSession] | None = None\n74: \n75: \n76: def _get_session_factory() -> async_sessionmaker[AsyncSession]:\n77:     global _session_factory\n78:     if _session_factory is None:\n79:         from core_storage_api.database.init import get_engine\n80: \n81:         _session_factory = async_sessionmaker(\n82:             get_engine(),\n83:             expire_on_commit=False,\n84:         )\n85:     return _session_factory\n86: \n87: \n88: def _get_read_session_factory() -> async_sessionmaker[AsyncSession]:\n89:     global _read_session_factory\n90:     if _read_session_factory is None:\n91:         from core_storage_api.database.init import get_read_engine\n92: \n93:         _read_session_factory = async_sessionmaker(\n94:             get_read_engine(),\n95:             expire_on_commit=False,\n96:         )\n97:     return _read_session_factory\n98: \n99: \n100: @asynccontextmanager\n101: async def get_session() -> AsyncIterator[AsyncSession]:\n102:     \"\"\"Transactional writer session; commits on success, rolls back on error.\"\"\"\n103:     factory = _get_session_factory()\n104:     async with factory() as session:\n105:         async with session.begin():\n106:             yield session\n107: \n108: \n109: @asynccontextmanager\n110: async def get_read_session() -> AsyncIterator[AsyncSession]:\n111:     \"\"\"Reader session — no explicit transaction wrapper since these are\n112:     query-only paths. Routes to the replica engine when\n113:     ``settings.read_database_url`` is set; otherwise shares the primary\n114:     pool (OSS standalone — unchanged behavior).\n115: \n116:     Do NOT use for read-your-writes flows inside a single request; use\n117:     :func:`get_session` for those so the read sees the same transaction\n118:     scope as the write.\n119:     \"\"\"\n120:     factory = _get_read_session_factory()\n121:     async with factory() as session:\n122:         yield session\n123: \n124: \n125: # ---------------------------------------------------------------------------\n126: # Helpers\n127: # ---------------------------------------------------------------------------\n128: \n129: \n130: def _scope_sql(\n131:     tenant_id: str,\n132:     fleet_id: str | None,\n133:     table: str = \"m\",\n134: ) -> tuple[str, dict]:\n135:     \"\"\"Build a WHERE clause fragment for tenant + optional fleet scoping.\"\"\"\n136:     clause = f\"{table}.tenant_id = :tenant_id\"\n137:     params: dict = {\"tenant_id\": tenant_id}\n138:     if fleet_id is not None:\n139:         clause += f\" AND {table}.fleet_id = :fleet_id\"\n140:         params[\"fleet_id\"] = fleet_id\n141:     return clause, params\n142: \n143: \n144: def _relation_weight(relation_type: str, row_weight: float) -> float:\n145:     \"\"\"Compute effective weight for a relation edge.\"\"\"\n146:     type_w = RELATION_TYPE_WEIGHTS.get(\n147:         relation_type.lower(),\n148:         DEFAULT_RELATION_TYPE_WEIGHT,\n149:     )\n150:     return type_w * row_weight\n151: \n152: \n153: # Cached at import time so the per-row column-name filter on the bulk\n154: # write hot path (100 items x ~25 columns) doesn't pay the cost of\n155: # walking ``Memory.__table__.columns`` and ``__mapper__.column_attrs``\n156: # on every call. Both sets are static for the lifetime of the process.\n157: _MEMORY_VALID_FIELDS = frozenset(\n158:     {c.key for c in Memory.__table__.columns} | {a.key for a in Memory.__mapper__.column_attrs}\n159: )\n160: \n161: \n162: # ── Org hard-delete purge (CAURA-689) ──\n163: #\n164: # Tables wiped when an organization is permanently deleted. Ordered\n165: # children-before-parents so the per-table DELETEs never trip a foreign\n166: # key. Tables WITHOUT their own ``tenant_id`` column (``memory_entity_links``)\n167: # are not listed — they're removed by the ON DELETE CASCADE from\n168: # ``memories`` / ``entities``. ``relations`` and ``fleet_commands`` are\n169: # listed explicitly (ahead of their parents) so their per-table counts are\n170: # reported rather than hidden inside a cascade.\n171: _PURGE_TENANT_TABLES: tuple[str, ...] = (\n172:     \"relations\",\n173:     \"fleet_commands\",\n174:     \"memories\",\n175:     \"entities\",\n176:     \"agents\",\n177:     \"fleet_nodes\",\n178:     \"audit_log\",\n179:     \"documents\",\n180:     \"analysis_reports\",\n181:     \"dedup_reviews\",\n182:     \"background_task_log\",\n183:     \"idempotency_responses\",\n184: )\n185: # OSS keys these by ``org_id``, which equals the tenant id in the\n186: # single-key-per-tenant OSS model (CAURA-654). ``lifecycle_audit`` is\n187: # deliberately NOT purged: it's the operational audit trail (including\n188: # the hard-delete-org row itself), so wiping it would erase the record\n189: # of the very deletion being performed.\n190: _PURGE_ORG_KEYED_TABLES: tuple[str, ...] = (\n191:     \"organization_settings\",\n192:     \"organization_settings_audit\",\n193: )\n194: \n195: # ── Fleet-scoped hard-purge (test-tenant hygiene) ──\n196: #\n197: # The subset of ``_PURGE_TENANT_TABLES`` that carries its own ``fleet_id``\n198: # column, so a single fleet's footprint can be permanently removed from a\n199: # SHARED tenant without touching the rest of the tenant. Used by the\n200: # OpenClaw fleet-tester to clean up its run-scoped ``nightly-<run_id>-fleet-NN``\n201: # fleets at teardown (the dev tenant otherwise accumulates run data that\n202: # confounds isolation/trust tests). Ordered children-before-parents so the\n203: # per-table DELETEs never trip a foreign key.\n204: #\n205: # ``fleet_commands`` is intentionally NOT in this tuple — it has no\n206: # ``fleet_id`` of its own (it's keyed by ``node_id``); ``purge_fleet_data``\n207: # deletes it explicitly by the fleet's node ids before the nodes go, so its\n208: # count is reported rather than hidden inside the ``fleet_nodes`` ON DELETE\n209: # CASCADE. ``memory_entity_links`` (no ``fleet_id``) rides the CASCADE from\n210: # ``memories`` / ``entities``. Tenant-wide tables (``audit_log``,\n211: # ``background_task_log``, ``idempotency_responses``, ``organization_settings*``)\n212: # are excluded — they're tenant config or the retained audit trail, not\n213: # fleet-scoped run data.\n214: _PURGE_FLEET_TABLES: tuple[str, ...] = (\n215:     \"relations\",\n216:     \"memories\",\n217:     \"entities\",\n218:     \"agents\",\n219:     \"fleet_nodes\",\n220:     \"documents\",\n221:     \"analysis_reports\",\n222:     \"dedup_reviews\",\n223: )\n224: \n225: \n226: # ═══════════════════════════════════════════════════════════════════════════\n227: # PostgresService\n228: # ═══════════════════════════════════════════════════════════════════════════\n229: \n230: \n231: class PostgresService:\n232:     \"\"\"Single point of DB access for all core tables.\n233: \n234:     Every public method acquires its own session via ``get_session()``.\n235:     Callers never need to manage sessions or transactions.\n236:     \"\"\"\n237: \n238:     # ══════════════════════════════════════════════════════════════════════\n239:     #  MEMORIES\n240:     # ══════════════════════════════════════════════════════════════════════\n241: \n242:     # ------------------------------------------------------------------\n243:     # A) Core CRUD\n244:     # ------------------------------------------------------------------\n245: \n246:     async def memory_get_by_id(self, memory_id: UUID) -> Memory | None:\n247:         # Wrap the full session block so db_ms includes connection-pool\n248:         # wait time — a saturated pool shows up as slow \"DB\" here, which\n249:         # is exactly how we want to see it in Cloud Logging.\n250:         with db_measure():\n251:             async with get_read_session() as session:\n252:                 return await session.get(Memory, memory_id)\n253: \n254:     async def memory_get_by_id_for_tenant(\n255:         self,\n256:         memory_id: UUID,\n257:         tenant_id: str,\n258:     ) -> Memory | None:\n259:         with db_measure():\n260:             async with get_read_session() as session:\n261:                 memory = await session.get(Memory, memory_id)\n262:                 if memory is None or memory.tenant_id != tenant_id or memory.deleted_at is not None:\n263:                     return None\n264:                 return memory\n265: \n266:     @staticmethod\n267:     def _filter_fields(model_cls, data: dict) -> dict:\n268:         valid = {c.key for c in model_cls.__table__.columns}\n269:         return {k: v for k, v in data.items() if k in valid}\n270: \n271:     @staticmethod\n272:     def _filter_memory_fields(data: dict) -> dict:\n273:         return {k: v for k, v in data.items() if k in _MEMORY_VALID_FIELDS}\n274: \n275:     async def memory_add(self, data: dict) -> Memory:\n276:         async with get_session() as session:\n277:             memory = Memory(**self._filter_memory_fields(data))\n278:             session.add(memory)\n279:             await session.flush()\n280:             return memory\n281: \n282:     async def memory_add_all(self, items: list[dict]) -> list[dict]:\n283:         \"\"\"Insert with per-attempt idempotency (CAURA-602).\n284: \n285:         Every item must carry a non-empty ``client_request_id``. Callers\n286:         on the bulk-write path derive it from the\n287:         ``X-Bulk-Attempt-Id`` header (``f\"{attempt_id}:{index}\"``);\n288:         server-internal callers (auto-chunk, atomic-facts) generate a\n289:         UUID per item. Partial unique\n290:         ``ix_memories_attempt_unique`` makes a retry of the same logical\n291:         attempt deterministic: rows already committed by a prior call\n292:         are detected via ``ON CONFLICT DO NOTHING`` and returned with\n293:         ``was_inserted=False`` and the canonical row id, instead of\n294:         being silently re-inserted or vanishing because the response\n295:         was lost mid-flight.\n296: \n297:         Returns one entry per input item, **in input order**:\n298: \n299:             ``{client_request_id, id, was_inserted}``\n300: \n301:         ``id`` is ``None`` only in the pathological case where the\n302:         item was neither inserted nor found on a follow-up read — e.g.\n303:         a concurrent soft-delete between INSERT and SELECT, or the\n304:         unresolved row drifted out of scope. The caller surfaces those\n305:         as per-item errors.\n306:         \"\"\"\n307:         if not items:\n308:             return []\n309: \n310:         for d in items:\n311:             if not d.get(\"client_request_id\"):\n312:                 # Required at this layer so the partial-unique guarantee\n313:                 # holds for every row. Routing the rejection here, rather\n314:                 # than at the FastAPI route, also catches in-process\n315:                 # callers (auto-chunk via ``sc.create_memories``) that\n316:                 # forgot to mint an id.\n317:                 raise ValueError(\"memory_add_all: every item must carry client_request_id\")\n318: \n319:         # All callers send a single-tenant, single-fleet batch (the\n320:         # bulk endpoint is tenant-and-fleet-scoped on the way in). Pin\n321:         # the post-conflict re-query to BOTH dimensions so an attacker\n322:         # who learned a foreign ``client_request_id`` can't read\n323:         # across tenants OR fleets by sneaking it into an items list,\n324:         # and so the re-query window matches the unique index's scope\n325:         # ``(tenant_id, COALESCE(fleet_id, ''), client_request_id)``\n326:         # exactly. Validating up-front keeps the invariant explicit\n327:         # instead of relying on the upstream schema.\n328:         tenant_id = items[0][\"tenant_id\"]\n329:         fleet_id = items[0].get(\"fleet_id\")\n330:         if any(d.get(\"tenant_id\") != tenant_id for d in items):\n331:             raise ValueError(\"memory_add_all: all items must share the same tenant_id\")\n332:         if any(d.get(\"fleet_id\") != fleet_id for d in items):\n333:             raise ValueError(\"memory_add_all: all items must share the same fleet_id\")\n334: \n335:         async with get_session() as session:\n336:             rows = [self._filter_memory_fields(d) for d in items]\n337:             # The conflict target must mirror ``ix_memories_attempt_unique``\n338:             # *expression-for-expression* — the planner only treats the\n339:             # ON CONFLICT and the partial-unique index as matched if every\n340:             # element is byte-equivalent, including the ``COALESCE`` over\n341:             # nullable ``fleet_id``. Stripping the COALESCE here would\n342:             # silently fall back to \"no inferred constraint\" and double-\n343:             # insert on retry for fleetless attempts.\n344:             stmt = (\n345:                 pg_insert(Memory)\n346:                 .values(rows)\n347:                 .on_conflict_do_nothing(\n348:                     # ``text(\"COALESCE(fleet_id, '')\")`` matches migration\n349:                     # 007's CREATE INDEX SQL character-for-character.\n350:                     # ``func.coalesce(Memory.fleet_id, \"\")`` works today\n351:                     # via Postgres conflict-inference normalisation\n352:                     # (which strips table qualifiers), but pinning the\n353:                     # raw text removes the dependency on that\n354:                     # normalisation behaviour across SQLAlchemy + asyncpg\n355:                     # versions. A future renderer change that emits\n356:                     # ``coalesce(memories.fleet_id, '')`` *would* still\n357:                     # match today, but if the planner ever returns \"no\n358:                     # unique constraint matches the ON CONFLICT\n359:                     # specification\" the silent-create class re-emerges\n360:                     # as a 500-on-every-retry. The model-level Index in\n361:                     # ``common/models/memory.py`` uses the same text()\n362:                     # form for the same reason.\n363:                     index_elements=[\n364:                         Memory.tenant_id,\n365:                         text(\"COALESCE(fleet_id, '')\"),\n366:                         Memory.client_request_id,\n367:                     ],\n368:                     index_where=text(\"deleted_at IS NULL AND client_request_id IS NOT NULL\"),\n369:                 )\n370:                 .returning(Memory.id, Memory.client_request_id)\n371:             )\n372:             inserted: dict[str, UUID] = {\n373:                 row.client_request_id: row.id for row in (await session.execute(stmt)).all()\n374:             }\n375: \n376:             # Items the conflict swallowed already exist — committed by a\n377:             # prior attempt with the same ``X-Bulk-Attempt-Id``. Re-read\n378:             # their canonical ids in the same session so the caller can\n379:             # surface ``duplicate_attempt`` instead of dropping them.\n380:             unresolved = [d[\"client_request_id\"] for d in items if d[\"client_request_id\"] not in inserted]\n381:             existing: dict[str, UUID] = {}\n382:             if unresolved:\n383:                 # Chunk the IN-list to keep the parameter count well below\n384:                 # asyncpg's 32k bind-arg ceiling. 500 mirrors the bulk\n385:                 # batch ceiling so a single-batch retry is one query;\n386:                 # larger calls (auto-chunk) split cleanly.\n387:                 fleet_predicate = (\n388:                     Memory.fleet_id == fleet_id if fleet_id is not None else Memory.fleet_id.is_(None)\n389:                 )\n390:                 for chunk_start in range(0, len(unresolved), 500):\n391:                     chunk = unresolved[chunk_start : chunk_start + 500]\n392:                     result = await session.execute(\n393:                         select(Memory.id, Memory.client_request_id).where(\n394:                             Memory.tenant_id == tenant_id,\n395:                             fleet_predicate,\n396:                             Memory.client_request_id.in_(chunk),\n397:                             Memory.deleted_at.is_(None),\n398:                         )\n399:                     )\n400:                     for row in result.all():\n401:                         existing[row.client_request_id] = row.id\n402: \n403:         out: list[dict] = []\n404:         for d in items:\n405:             crid = d[\"client_request_id\"]\n406:             if crid in inserted:\n407:                 out.append({\"client_request_id\": crid, \"id\": str(inserted[crid]), \"was_inserted\": True})\n408:             elif crid in existing:\n409:                 out.append({\"client_request_id\": crid, \"id\": str(existing[crid]), \"was_inserted\": False})\n410:             else:\n411:                 # Soft-delete or schema-skew edge case: the row was neither\n412:                 # newly inserted nor visible on the follow-up read. ``id``\n413:                 # is None so the core-api layer surfaces this as a\n414:                 # per-item error rather than fabricating an id.\n415:                 out.append({\"client_request_id\": crid, \"id\": None, \"was_inserted\": False})\n416:         return out\n417: \n418:     async def memory_soft_delete(self, memory_id: UUID) -> None:\n419:         async with get_session() as session:\n420:             memory = await session.get(Memory, memory_id)\n421:             if memory is not None:\n422:                 memory.deleted_at = datetime.now(UTC)\n423:                 memory.status = \"deleted\"\n424: \n425:     async def memory_update(self, memory_id: UUID, patch: dict) -> bool:\n426:         \"\"\"Apply arbitrary field updates to a memory.\n427: \n428:         Two patch shapes are supported in the same request:\n429: \n430:         * Plain ORM column keys (``memory_type``, ``weight``, ``status``,\n431:           ``ts_valid_*``, …) — applied as a single ``UPDATE ... SET``.\n432:         * The synthetic key ``metadata_patch`` — a dict that is merged\n433:           into the existing ``metadata`` JSONB column atomically with\n434:           ``COALESCE(metadata, '{}'::jsonb) || :patch``. Used by the\n435:           async-enrich worker (CAURA-595) to add ``summary`` / ``tags`` /\n436:           ``contains_pii`` / ``pii_types`` / ``retrieval_hint`` /\n437:           ``llm_ms`` without clobbering keys an earlier write set.\n438: \n439:         Other top-level keys whose names don't match a ``Memory`` column\n440:         are silently dropped — callers validate upstream.\n441: \n442:         Returns ``True`` when the row exists and is live (the patch was\n443:         applied or was a no-op due to all-unknown keys); ``False`` when\n444:         the row is absent or soft-deleted, which the route turns into\n445:         404. Both UPDATE branches run inside a single\n446:         ``SELECT ... FOR UPDATE`` snapshot so a concurrent\n447:         ``memory_soft_delete`` can't commit between them and leave the\n448:         row in a torn state (status updated, metadata not, or vice\n449:         versa) — the bare per-statement ``deleted_at IS NULL`` guard\n450:         wasn't enough on its own under READ COMMITTED.\n451:         \"\"\"\n452:         metadata_patch = patch.get(\"metadata_patch\") if isinstance(patch, dict) else None\n453:         # Map JSON keys to model columns. ``metadata_patch`` is handled\n454:         # via a separate JSONB-merge statement below; skip it here so it\n455:         # doesn't accidentally land as a column write.\n456:         values: dict = {\n457:             key: val for key, val in patch.items() if key != \"metadata_patch\" and hasattr(Memory, key)\n458:         }\n459:         async with get_session() as session:\n460:             # Existence check FIRST — runs even on empty / all-unknown-\n461:             # keys patches so a PATCH on an absent or soft-deleted row\n462:             # consistently returns 404 regardless of body shape. Pre-\n463:             # this-change the no-op paths (empty body, all-unknown\n464:             # keys) short-circuited with ``return True`` and the route\n465:             # answered 200, so a deleted row could absorb a \"successful\"\n466:             # no-op PATCH that depended only on whether the body\n467:             # carried recognised columns.\n468:             #\n469:             # ``SELECT ... FOR UPDATE`` locks the row so the two UPDATE\n470:             # branches below run inside one snapshot: a concurrent soft\n471:             # DELETE blocks until this transaction commits or rolls\n472:             # back, eliminating the column-set-but-not-metadata torn\n473:             # state under READ COMMITTED.\n474:             #\n475:             # ``id, deleted_at`` come back as a tuple so \"row absent\"\n476:             # (None tuple) and \"row exists, deleted_at IS NULL\" (live)\n477:             # are distinguishable — ``scalar_one_or_none`` on\n478:             # ``deleted_at`` alone would collapse both into None.\n479:             row = (\n480:                 await session.execute(\n481:                     select(Memory.id, Memory.deleted_at).where(Memory.id == memory_id).with_for_update()\n482:                 )\n483:             ).first()\n484:             if row is None:\n485:                 return False  # row truly absent — caller → 404\n486:             if row.deleted_at is not None:\n487:                 return False  # soft-deleted — caller → 404, no UPDATE runs\n488: \n489:             # No-op patches on a live row are valid: existence check\n490:             # already passed, so report success without burning UPDATEs.\n491:             # Worth the SELECT roundtrip cost (rate-limited PATCH route\n492:             # bounds it) for the consistent 404-on-absent contract.\n493:             if not patch or (not values and not metadata_patch):\n494:                 return True\n495: \n496:             # ``deleted_at IS NULL`` predicate stays on each UPDATE\n497:             # even though the FOR UPDATE lock above already gates this\n498:             # path; it's belt-and-suspenders against a future change\n499:             # that splits the lock and the UPDATEs into separate\n500:             # sessions.\n501:             if values:\n502:                 await session.execute(\n503:                     sql_update(Memory)\n504:                     .where(Memory.id == memory_id, Memory.deleted_at.is_(None))\n505:                     .values(**values)\n506:                 )\n507:             if metadata_patch:\n508:                 # Single-statement JSONB merge — concurrent merges are\n509:                 # last-writer-wins per key but never corrupt the doc.\n510:                 # ``::jsonb`` cast on the bind keeps the parameter typed\n511:                 # so empty dicts merge cleanly instead of failing the\n512:                 # ``||`` operator.\n513:                 #\n514:                 # ``metadata::jsonb`` cast on the column handles the\n515:                 # CAURA-595 production drift case: the ORM declares the\n516:                 # column as ``JSONB`` (common/models/memory.py) but\n517:                 # legacy Postgres tables created before the JSONB\n518:                 # migration store it as ``json`` (lowercase). Without\n519:                 # the explicit cast, ``COALESCE(metadata, '{}'::jsonb)``\n520:                 # raises ``CannotCoerceError: COALESCE could not\n\n(Showing lines 1-520 of 4754. Use offset=521 to continue.)\n</content>","metadata":{"preview":"\"\"\"PostgreSQL service -- all database queries for core tables.\n\nSingle point of DB access for the OSS core-storage-api.  Every query that\nwas previously spread across eight repository classes now lives here, grouped\nby domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n\nSession management uses a module-level ``async_sessionmaker`` backed by the\nshared engine from ``core_storage_api.database.init.get_engine``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nfrom collections import OrderedDict\nfrom collections.abc import AsyncIterator, Sequence\nfrom contextlib import asynccontextmanager\nfrom datetime import UTC, datetime, timedelta\nfrom types import SimpleNamespace\nfrom typing import Any","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"\"\"\"PostgreSQL service -- all database queries for core tables.\n\nSingle point of DB access for the OSS core-storage-api.  Every query that\nwas previously spread across eight repository classes now lives here, grouped\nby domain: memories, entities, agents, documents, fleet, audit, reports, tasks.\n\nSession management uses a module-level ``async_sessionmaker`` backed by the\nshared engine from ``core_storage_api.database.init.get_engine``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nfrom collections import OrderedDict\nfrom collections.abc import AsyncIterator, Sequence\nfrom contextlib import asynccontextmanager\nfrom datetime import UTC, datetime, timedelta\nfrom types import SimpleNamespace\nfrom typing import Any\nfrom uuid import UUID\n\nfrom sqlalchemy import and_, case, delete, false, func, literal_column, or_, select, text, tuple_\nfrom sqlalchemy import update as sql_update\nfrom sqlalchemy.dialects.postgresql import insert as pg_insert\nfrom sqlalchemy.exc import IntegrityError\nfrom sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker\nfrom sqlalchemy.orm import load_only\n\nfrom common.constants import (\n    CONTRADICTION_CANDIDATE_MAX,\n    CONTRADICTION_SIMILARITY_THRESHOLD,\n    DEFAULT_RELATION_TYPE_WEIGHT,\n    ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n    GRAPH_MAX_HOPS,\n    RECALL_BOOST_SCALE,\n    RELATION_TYPE_WEIGHTS,\n    SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n    SEMANTIC_DEDUP_THRESHOLD,\n    TYPE_DECAY_DAYS,\n)\nfrom common.events.lifecycle_purge_request import MEMORY_RETENTION_MAX_DAYS\nfrom common.models import (\n    Agent,\n    AuditLog,\n    BackgroundTaskLog,\n    CrystallizationReport,\n    DedupReview,\n    Document,\n    Entity,\n    FleetCommand,\n    FleetNode,\n    IdempotencyResponse,\n    LifecycleAudit,\n    Memory,\n    MemoryEntityLink,\n    Relation,\n)\nfrom core_storage_api.observability import db_measure\n\nlogger = logging.getLogger(__name__)\n\n# ---------------------------------------------------------------------------\n# Session factories (singletons)\n# ---------------------------------------------------------------------------\n#\n# Two factories bound to two engines: writer (primary) and reader\n# (replica when ``read_database_url`` is set, else the primary). The\n# factories are lazy so tests can swap the underlying engines before\n# the first request without touching service-module state.\n\n_session_factory: async_sessionmaker[AsyncSession] | None = None\n_read_session_factory: async_sessionmaker[AsyncSession] | None = None\n\n\ndef _get_session_factory() -> async_sessionmaker[AsyncSession]:\n    global _session_factory\n    if _session_factory is None:\n        from core_storage_api.database.init import get_engine\n\n        _session_factory = async_sessionmaker(\n            get_engine(),\n            expire_on_commit=False,\n        )\n    return _session_factory\n\n\ndef _get_read_session_factory() -> async_sessionmaker[AsyncSession]:\n    global _read_session_factory\n    if _read_session_factory is None:\n        from core_storage_api.database.init import get_read_engine\n\n        _read_session_factory = async_sessionmaker(\n            get_read_engine(),\n            expire_on_commit=False,\n        )\n    return _read_session_factory\n\n\n@asynccontextmanager\nasync def get_session() -> AsyncIterator[AsyncSession]:\n    \"\"\"Transactional writer session; commits on success, rolls back on error.\"\"\"\n    factory = _get_session_factory()\n    async with factory() as session:\n        async with session.begin():\n            yield session\n\n\n@asynccontextmanager\nasync def get_read_session() -> AsyncIterator[AsyncSession]:\n    \"\"\"Reader session — no explicit transaction wrapper since these are\n    query-only paths. Routes to the replica engine when\n    ``settings.read_database_url`` is set; otherwise shares the primary\n    pool (OSS standalone — unchanged behavior).\n\n    Do NOT use for read-your-writes flows inside a single request; use\n    :func:`get_session` for those so the read sees the same transaction\n    scope as the write.\n    \"\"\"\n    factory = _get_read_session_factory()\n    async with factory() as session:\n        yield session\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _scope_sql(\n    tenant_id: str,\n    fleet_id: str | None,\n    table: str = \"m\",\n) -> tuple[str, dict]:\n    \"\"\"Build a WHERE clause fragment for tenant + optional fleet scoping.\"\"\"\n    clause = f\"{table}.tenant_id = :tenant_id\"\n    params: dict = {\"tenant_id\": tenant_id}\n    if fleet_id is not None:\n        clause += f\" AND {table}.fleet_id = :fleet_id\"\n        params[\"fleet_id\"] = fleet_id\n    return clause, params\n\n\ndef _relation_weight(relation_type: str, row_weight: float) -> float:\n    \"\"\"Compute effective weight for a relation edge.\"\"\"\n    type_w = RELATION_TYPE_WEIGHTS.get(\n        relation_type.lower(),\n        DEFAULT_RELATION_TYPE_WEIGHT,\n    )\n    return type_w * row_weight\n\n\n# Cached at import time so the per-row column-name filter on the bulk\n# write hot path (100 items x ~25 columns) doesn't pay the cost of\n# walking ``Memory.__table__.columns`` and ``__mapper__.column_attrs``\n# on every call. Both sets are static for the lifetime of the process.\n_MEMORY_VALID_FIELDS = frozenset(\n    {c.key for c in Memory.__table__.columns} | {a.key for a in Memory.__mapper__.column_attrs}\n)\n\n\n# ── Org hard-delete purge (CAURA-689) ──\n#\n# Tables wiped when an organization is permanently deleted. Ordered\n# children-before-parents so the per-table DELETEs never trip a foreign\n# key. Tables WITHOUT their own ``tenant_id`` column (``memory_entity_links``)\n# are not listed — they're removed by the ON DELETE CASCADE from\n# ``memories`` / ``entities``. ``relations`` and ``fleet_commands`` are\n# listed explicitly (ahead of their parents) so their per-table counts are\n# reported rather than hidden inside a cascade.\n_PURGE_TENANT_TABLES: tuple[str, ...] = (\n    \"relations\",\n    \"fleet_commands\",\n    \"memories\",\n    \"entities\",\n    \"agents\",\n    \"fleet_nodes\",\n    \"audit_log\",\n    \"documents\",\n    \"analysis_reports\",\n    \"dedup_reviews\",\n    \"background_task_log\",\n    \"idempotency_responses\",\n)\n# OSS keys these by ``org_id``, which equals the tenant id in the\n# single-key-per-tenant OSS model (CAURA-654). ``lifecycle_audit`` is\n# deliberately NOT purged: it's the operational audit trail (including\n# the hard-delete-org row itself), so wiping it would erase the record\n# of the very deletion being performed.\n_PURGE_ORG_KEYED_TABLES: tuple[str, ...] = (\n    \"organization_settings\",\n    \"organization_settings_audit\",\n)\n\n# ── Fleet-scoped hard-purge (test-tenant hygiene) ──\n#\n# The subset of ``_PURGE_TENANT_TABLES`` that carries its own ``fleet_id``\n# column, so a single fleet's footprint can be permanently removed from a\n# SHARED tenant without touching the rest of the tenant. Used by the\n# OpenClaw fleet-tester to clean up its run-scoped ``nightly-<run_id>-fleet-NN``\n# fleets at teardown (the dev tenant otherwise accumulates run data that\n# confounds isolation/trust tests). Ordered children-before-parents so the\n# per-table DELETEs never trip a foreign key.\n#\n# ``fleet_commands`` is intentionally NOT in this tuple — it has no\n# ``fleet_id`` of its own (it's keyed by ``node_id``); ``purge_fleet_data``\n# deletes it explicitly by the fleet's node ids before the nodes go, so its\n# count is reported rather than hidden inside the ``fleet_nodes`` ON DELETE\n# CASCADE. ``memory_entity_links`` (no ``fleet_id``) rides the CASCADE from\n# ``memories`` / ``entities``. Tenant-wide tables (``audit_log``,\n# ``background_task_log``, ``idempotency_responses``, ``organization_settings*``)\n# are excluded — they're tenant config or the retained audit trail, not\n# fleet-scoped run data.\n_PURGE_FLEET_TABLES: tuple[str, ...] = (\n    \"relations\",\n    \"memories\",\n    \"entities\",\n    \"agents\",\n    \"fleet_nodes\",\n    \"documents\",\n    \"analysis_reports\",\n    \"dedup_reviews\",\n)\n\n\n# ═══════════════════════════════════════════════════════════════════════════\n# PostgresService\n# ═══════════════════════════════════════════════════════════════════════════\n\n\nclass PostgresService:\n    \"\"\"Single point of DB access for all core tables.\n\n    Every public method acquires its own session via ``get_session()``.\n    Callers never need to manage sessions or transactions.\n    \"\"\"\n\n    # ══════════════════════════════════════════════════════════════════════\n    #  MEMORIES\n    # ══════════════════════════════════════════════════════════════════════\n\n    # ------------------------------------------------------------------\n    # A) Core CRUD\n    # ------------------------------------------------------------------\n\n    async def memory_get_by_id(self, memory_id: UUID) -> Memory | None:\n        # Wrap the full session block so db_ms includes connection-pool\n        # wait time — a saturated pool shows up as slow \"DB\" here, which\n        # is exactly how we want to see it in Cloud Logging.\n        with db_measure():\n            async with get_read_session() as session:\n                return await session.get(Memory, memory_id)\n\n    async def memory_get_by_id_for_tenant(\n        self,\n        memory_id: UUID,\n        tenant_id: str,\n    ) -> Memory | None:\n        with db_measure():\n            async with get_read_session() as session:\n                memory = await session.get(Memory, memory_id)\n                if memory is None or memory.tenant_id != tenant_id or memory.deleted_at is not None:\n                    return None\n                return memory\n\n    @staticmethod\n    def _filter_fields(model_cls, data: dict) -> dict:\n        valid = {c.key for c in model_cls.__table__.columns}\n        return {k: v for k, v in data.items() if k in valid}\n\n    @staticmethod\n    def _filter_memory_fields(data: dict) -> dict:\n        return {k: v for k, v in data.items() if k in _MEMORY_VALID_FIELDS}\n\n    async def memory_add(self, data: dict) -> Memory:\n        async with get_session() as session:\n            memory = Memory(**self._filter_memory_fields(data))\n            session.add(memory)\n            await session.flush()\n            return memory\n\n    async def memory_add_all(self, items: list[dict]) -> list[dict]:\n        \"\"\"Insert with per-attempt idempotency (CAURA-602).\n\n        Every item must carry a non-empty ``client_request_id``. Callers\n        on the bulk-write path derive it from the\n        ``X-Bulk-Attempt-Id`` header (``f\"{attempt_id}:{index}\"``);\n        server-internal callers (auto-chunk, atomic-facts) generate a\n        UUID per item. Partial unique\n        ``ix_memories_attempt_unique`` makes a retry of the same logical\n        attempt deterministic: rows already committed by a prior call\n        are detected via ``ON CONFLICT DO NOTHING`` and returned with\n        ``was_inserted=False`` and the canonical row id, instead of\n        being silently re-inserted or vanishing because the response\n        was lost mid-flight.\n\n        Returns one entry per input item, **in input order**:\n\n            ``{client_request_id, id, was_inserted}``\n\n        ``id`` is ``None`` only in the pathological case where the\n        item was neither inserted nor found on a follow-up read — e.g.\n        a concurrent soft-delete between INSERT and SELECT, or the\n        unresolved row drifted out of scope. The caller surfaces those\n        as per-item errors.\n        \"\"\"\n        if not items:\n            return []\n\n        for d in items:\n            if not d.get(\"client_request_id\"):\n                # Required at this layer so the partial-unique guarantee\n                # holds for every row. Routing the rejection here, rather\n                # than at the FastAPI route, also catches in-process\n                # callers (auto-chunk via ``sc.create_memories``) that\n                # forgot to mint an id.\n                raise ValueError(\"memory_add_all: every item must carry client_request_id\")\n\n        # All callers send a single-tenant, single-fleet batch (the\n        # bulk endpoint is tenant-and-fleet-scoped on the way in). Pin\n        # the post-conflict re-query to BOTH dimensions so an attacker\n        # who learned a foreign ``client_request_id`` can't read\n        # across tenants OR fleets by sneaking it into an items list,\n        # and so the re-query window matches the unique index's scope\n        # ``(tenant_id, COALESCE(fleet_id, ''), client_request_id)``\n        # exactly. Validating up-front keeps the invariant explicit\n        # instead of relying on the upstream schema.\n        tenant_id = items[0][\"tenant_id\"]\n        fleet_id = items[0].get(\"fleet_id\")\n        if any(d.get(\"tenant_id\") != tenant_id for d in items):\n            raise ValueError(\"memory_add_all: all items must share the same tenant_id\")\n        if any(d.get(\"fleet_id\") != fleet_id for d in items):\n            raise ValueError(\"memory_add_all: all items must share the same fleet_id\")\n\n        async with get_session() as session:\n            rows = [self._filter_memory_fields(d) for d in items]\n            # The conflict target must mirror ``ix_memories_attempt_unique``\n            # *expression-for-expression* — the planner only treats the\n            # ON CONFLICT and the partial-unique index as matched if every\n            # element is byte-equivalent, including the ``COALESCE`` over\n            # nullable ``fleet_id``. Stripping the COALESCE here would\n            # silently fall back to \"no inferred constraint\" and double-\n            # insert on retry for fleetless attempts.\n            stmt = (\n                pg_insert(Memory)\n                .values(rows)\n                .on_conflict_do_nothing(\n                    # ``text(\"COALESCE(fleet_id, '')\")`` matches migration\n                    # 007's CREATE INDEX SQL character-for-character.\n                    # ``func.coalesce(Memory.fleet_id, \"\")`` works today\n                    # via Postgres conflict-inference normalisation\n                    # (which strips table qualifiers), but pinning the\n                    # raw text removes the dependency on that\n                    # normalisation behaviour across SQLAlchemy + asyncpg\n                    # versions. A future renderer change that emits\n                    # ``coalesce(memories.fleet_id, '')`` *would* still\n                    # match today, but if the planner ever returns \"no\n                    # unique constraint matches the ON CONFLICT\n                    # specification\" the silent-create class re-emerges\n                    # as a 500-on-every-retry. The model-level Index in\n                    # ``common/models/memory.py`` uses the same text()\n                    # form for the same reason.\n                    index_elements=[\n                        Memory.tenant_id,\n                        text(\"COALESCE(fleet_id, '')\"),\n                        Memory.client_request_id,\n                    ],\n                    index_where=text(\"deleted_at IS NULL AND client_request_id IS NOT NULL\"),\n                )\n                .returning(Memory.id, Memory.client_request_id)\n            )\n            inserted: dict[str, UUID] = {\n                row.client_request_id: row.id for row in (await session.execute(stmt)).all()\n            }\n\n            # Items the conflict swallowed already exist — committed by a\n            # prior attempt with the same ``X-Bulk-Attempt-Id``. Re-read\n            # their canonical ids in the same session so the caller can\n            # surface ``duplicate_attempt`` instead of dropping them.\n            unresolved = [d[\"client_request_id\"] for d in items if d[\"client_request_id\"] not in inserted]\n            existing: dict[str, UUID] = {}\n            if unresolved:\n                # Chunk the IN-list to keep the parameter count well below\n                # asyncpg's 32k bind-arg ceiling. 500 mirrors the bulk\n                # batch ceiling so a single-batch retry is one query;\n                # larger calls (auto-chunk) split cleanly.\n                fleet_predicate = (\n                    Memory.fleet_id == fleet_id if fleet_id is not None else Memory.fleet_id.is_(None)\n                )\n                for chunk_start in range(0, len(unresolved), 500):\n                    chunk = unresolved[chunk_start : chunk_start + 500]\n                    result = await session.execute(\n                        select(Memory.id, Memory.client_request_id).where(\n                            Memory.tenant_id == tenant_id,\n                            fleet_predicate,\n                            Memory.client_request_id.in_(chunk),\n                            Memory.deleted_at.is_(None),\n                        )\n                    )\n                    for row in result.all():\n                        existing[row.client_request_id] = row.id\n\n        out: list[dict] = []\n        for d in items:\n            crid = d[\"client_request_id\"]\n            if crid in inserted:\n                out.append({\"client_request_id\": crid, \"id\": str(inserted[crid]), \"was_inserted\": True})\n            elif crid in existing:\n                out.append({\"client_request_id\": crid, \"id\": str(existing[crid]), \"was_inserted\": False})\n            else:\n                # Soft-delete or schema-skew edge case: the row was neither\n                # newly inserted nor visible on the follow-up read. ``id``\n                # is None so the core-api layer surfaces this as a\n                # per-item error rather than fabricating an id.\n                out.append({\"client_request_id\": crid, \"id\": None, \"was_inserted\": False})\n        return out\n\n    async def memory_soft_delete(self, memory_id: UUID) -> None:\n        async with get_session() as session:\n            memory = await session.get(Memory, memory_id)\n            if memory is not None:\n                memory.deleted_at = datetime.now(UTC)\n                memory.status = \"deleted\"\n\n    async def memory_update(self, memory_id: UUID, patch: dict) -> bool:\n        \"\"\"Apply arbitrary field updates to a memory.\n\n        Two patch shapes are supported in the same request:\n\n        * Plain ORM column keys (``memory_type``, ``weight``, ``status``,\n          ``ts_valid_*``, …) — applied as a single ``UPDATE ... SET``.\n        * The synthetic key ``metadata_patch`` — a dict that is merged\n          into the existing ``metadata`` JSONB column atomically with\n          ``COALESCE(metadata, '{}'::jsonb) || :patch``. Used by the\n          async-enrich worker (CAURA-595) to add ``summary`` / ``tags`` /\n          ``contains_pii`` / ``pii_types`` / ``retrieval_hint`` /\n          ``llm_ms`` without clobbering keys an earlier write set.\n\n        Other top-level keys whose names don't match a ``Memory`` column\n        are silently dropped — callers validate upstream.\n\n        Returns ``True`` when the row exists and is live (the patch was\n        applied or was a no-op due to all-unknown keys); ``False`` when\n        the row is absent or soft-deleted, which the route turns into\n        404. Both UPDATE branches run inside a single\n        ``SELECT ... FOR UPDATE`` snapshot so a concurrent\n        ``memory_soft_delete`` can't commit between them and leave the\n        row in a torn state (status updated, metadata not, or vice\n        versa) — the bare per-statement ``deleted_at IS NULL`` guard\n        wasn't enough on its own under READ COMMITTED.\n        \"\"\"\n        metadata_patch = patch.get(\"metadata_patch\") if isinstance(patch, dict) else None\n        # Map JSON keys to model columns. ``metadata_patch`` is handled\n        # via a separate JSONB-merge statement below; skip it here so it\n        # doesn't accidentally land as a column write.\n        values: dict = {\n            key: val for key, val in patch.items() if key != \"metadata_patch\" and hasattr(Memory, key)\n        }\n        async with get_session() as session:\n            # Existence check FIRST — runs even on empty / all-unknown-\n            # keys patches so a PATCH on an absent or soft-deleted row\n            # consistently returns 404 regardless of body shape. Pre-\n            # this-change the no-op paths (empty body, all-unknown\n            # keys) short-circuited with ``return True`` and the route\n            # answered 200, so a deleted row could absorb a \"successful\"\n            # no-op PATCH that depended only on whether the body\n            # carried recognised columns.\n            #\n            # ``SELECT ... FOR UPDATE`` locks the row so the two UPDATE\n            # branches below run inside one snapshot: a concurrent soft\n            # DELETE blocks until this transaction commits or rolls\n            # back, eliminating the column-set-but-not-metadata torn\n            # state under READ COMMITTED.\n            #\n            # ``id, deleted_at`` come back as a tuple so \"row absent\"\n            # (None tuple) and \"row exists, deleted_at IS NULL\" (live)\n            # are distinguishable — ``scalar_one_or_none`` on\n            # ``deleted_at`` alone would collapse both into None.\n            row = (\n                await session.execute(\n                    select(Memory.id, Memory.deleted_at).where(Memory.id == memory_id).with_for_update()\n                )\n            ).first()\n            if row is None:\n                return False  # row truly absent — caller → 404\n            if row.deleted_at is not None:\n                return False  # soft-deleted — caller → 404, no UPDATE runs\n\n            # No-op patches on a live row are valid: existence check\n            # already passed, so report success without burning UPDATEs.\n            # Worth the SELECT roundtrip cost (rate-limited PATCH route\n            # bounds it) for the consistent 404-on-absent contract.\n            if not patch or (not values and not metadata_patch):\n                return True\n\n            # ``deleted_at IS NULL`` predicate stays on each UPDATE\n            # even though the FOR UPDATE lock above already gates this\n            # path; it's belt-and-suspenders against a future change\n            # that splits the lock and the UPDATEs into separate\n            # sessions.\n            if values:\n                await session.execute(\n                    sql_update(Memory)\n                    .where(Memory.id == memory_id, Memory.deleted_at.is_(None))\n                    .values(**values)\n                )\n            if metadata_patch:\n                # Single-statement JSONB merge — concurrent merges are\n                # last-writer-wins per key but never corrupt the doc.\n                # ``::jsonb`` cast on the bind keeps the parameter typed\n                # so empty dicts merge cleanly instead of failing the\n                # ``||`` operator.\n                #\n                # ``metadata::jsonb`` cast on the column handles the\n                # CAURA-595 production drift case: the ORM declares the\n                # column as ``JSONB`` (common/models/memory.py) but\n                # legacy Postgres tables created before the JSONB\n                # migration store it as ``json`` (lowercase). Without\n                # the explicit cast, ``COALESCE(metadata, '{}'::jsonb)``\n                # raises ``CannotCoerceError: COALESCE could not","lineStart":1,"lineEnd":520,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780727679441,"end":1780727679462}},"metadata":{"openai":{"itemId":"fc_020d7f924b1ec321016a23bf7f4fe08191ae69690949622730"}},"id":"prt_e9ba409cb001A55rbN9FmnEZ7W","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba3d1cf0017X0Ediqx0UTlLy"}}
{"type":"tool_use","timestamp":1780727679464,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_y8hUSMmGwrx4pJyPZ55Fdnyt","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/api-surfaces.md","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/api-surfaces.md</path>\n<type>file</type>\n<content>\n1: # API Surface Ownership Charter\n2: \n3: MemClaw exposes three callable surfaces — REST, MCP, and the OpenClaw plugin.\n4: They are intentionally **not symmetric**. Each serves a different audience and\n5: operates under different assumptions. This document records who owns what and\n6: when to add or move an operation.\n7: \n8: > Looking for **latency and throughput numbers** per surface? See\n9: > [`performance.md`](performance.md). This document is about *which surface\n10: > owns which operation*, not about how fast each one runs.\n11: \n12: ## Audiences\n13: \n14: | Surface | Primary audience | Trust model |\n15: |---------|------------------|-------------|\n16: | REST    | Web UI, ops dashboards, programmatic admins, scripted clients | Explicit `tenant_id` in body/query; API key + role gating; full operational vocabulary. |\n17: | MCP     | AI agents (Claude Code, third-party agents) | Tenant inferred from auth header; agent-natural operations; description-driven discoverability. |\n18: | OpenClaw plugin | Local plugin runtime that hosts agents | Operational concerns of the local install — heartbeat, agent registration, fleet readiness. Delegates business operations to MCP. |\n19: \n20: ## Surface ownership\n21: \n22: | Concern | Owner | Reason |\n23: |---------|-------|--------|\n24: | Memory CRUD (write/recall/list/get/update/delete/transition) | REST + MCP | Universal; needed by every audience. |\n25: | Bulk write | REST + MCP | Same. |\n26: | Per-agent search profile (tune) | REST + MCP | Both administrators (REST) and agents tuning themselves (MCP) need it. |\n27: | Doc CRUD | REST + MCP | Universal. |\n28: | Doc semantic search | MCP **and** REST | Was MCP-only; REST endpoint added so non-MCP clients can use vector search on documents. |\n29: | Doc list-collections | MCP **and** REST | Was MCP-only; REST endpoint added for parity with list use cases. |\n30: | Bulk delete | REST + MCP (`memclaw_manage op=bulk_delete`) | Admin sometimes; agents cleaning up after themselves sometimes. |\n31: | Memory lineage walk | REST + MCP (`memclaw_manage op=lineage`) | Agents reviewing their own writes need to trace supersession chains. |\n32: | Knowledge graph / `/graph` | REST only | Aggregation surface for UIs and analytics tools. Agents that need entity context use `memclaw_entity_get` (single entity) and `memclaw_recall` (with entity_links in results). |\n33: | Memory stats | REST + MCP (`memclaw_stats`) | Aggregate counts (total + breakdown by type, agent, status; opt-in `include_deleted=true` adds `deleted` and `total_including_deleted`) — useful for admin/dashboard usage on REST and for agent self-introspection on MCP. Read-only aggregations don't need a use-case gate. |\n34: | Skill sharing | REST (`/documents` + `/documents/search` on `collection=\"skills\"`) + MCP (`memclaw_doc op=write\\|read\\|query\\|delete\\|search collection=skills`) | Skill sharing rides the generic document surface. Slugs (`doc_id`) are constrained to `^[a-z0-9][a-z0-9._-]{0,99}$` (filesystem-safe), and skills writes require `data[\"summary\"]` (with back-compat fallback to `data[\"description\"]`) so the catalog is semantic-searchable without ceremony. The dedicated `memclaw_share_skill`/`memclaw_unshare_skill` tools and `/skills/*` REST routes were dropped 2026-05; fleet auto-install (push to every node) is restored by Phase A's plugin-side reconciler. Trust ≥ 1 (inherited from `memclaw_doc`). |\n35: | Keystones (mandatory rules) | REST (`/memclaw/keystones`) + MCP (`memclaw_keystones` read, `memclaw_keystones_set` set\\|delete) | Governance policies that agents MUST obey — fetched deterministically (no semantic search) and injected into every session by the OpenClaw plugin. Storage lives in the system-managed `_keystones` collection on `documents`; the dedicated surface exists so the read tool stays discoverable in MCP `instructions` and the write surface can be trust-gated separately. Reads are open. Writes are tiered: a freshly-registered (trust ≥ 1) agent can author its own `scope=agent` rule — self-authored autonomy — but `scope=fleet`, `scope=tenant`, and cross-agent `scope=agent` stay at trust ≥ 2 so a default-trust agent (or a prompt-injected one) can't plant a tenant-wide rule. |\n36: | Tenant settings | REST only | Settings are a tenant-administrator concern; not safe for arbitrary agents to flip global config. |\n37: | Redistribute (mass reassign) | REST only | Destructive bulk op requires `trust_level >= 3`. Admin operation, not agent-driven. |\n38: | Ingest preview/commit | REST only (revisit per use case) | Pipeline workflow; expose to MCP only if \"agent crawls a URL and writes memories\" becomes a real use case. |\n39: | Contradictions / lineage at `/memories/{id}/contradictions` | REST + MCP (`memclaw_manage op=lineage`) | UI gets the rich endpoint; agents get the focused tool. |\n40: | Heartbeat / fleet readiness | REST receives, plugin produces | Plugin is the natural producer (it knows the local node state). REST is the receiver. MCP doesn't need this — agents don't report their own runtime state. |\n41: | Agent registration | OpenClaw plugin | Local-runtime concern. |\n42: \n43: ## When to add an operation\n44: \n45: Before adding a new MCP tool that mirrors a REST endpoint, justify it with a\n46: concrete agent workflow OR demonstrate that the operation is a read-only\n47: aggregation/introspection:\n48: \n49: 1. **Read-only aggregations** (counts, summaries, listings of caller-visible\n50:    state) don't need a blocking use case — they're cheap, safe, and useful for\n51:    any agent that wants to introspect the store. Add freely; trust gate at\n52:    the same level as `memclaw_list` (≥ 1 for own scope, ≥ 2 for cross-agent).\n53: 2. For everything else: is there an agent that **today** is blocked from\n54:    doing useful work because this operation only exists on REST?\n55: 3. If yes, does it fit naturally into an existing tool (`memclaw_manage`,\n56:    `memclaw_doc`, etc.) as another `op=...`? Prefer extending an existing\n57:    tool over adding a new top-level surface.\n58: 4. If a new tool is genuinely warranted, it must include: a clear description,\n59:    trust-level enforcement consistent with the REST counterpart, and a wet\n60:    test that exercises the same workflow against the local docker stack.\n61: \n62: Before adding a new REST endpoint that mirrors an MCP tool, justify it with a\n63: concrete non-agent workflow (a UI screen, a script, an integration). Don't\n64: mirror \"for symmetry.\"\n65: \n66: ## What this charter is NOT\n67: \n68: - It's not a list of bugs. Asymmetry is the design, not a defect.\n69: - It's not exhaustive — new operations should be classified above when added.\n70: - It's not a justification for current cross-surface drift in error contracts\n71:   or response shapes — those are separate hygiene concerns and should be\n72:   fixed regardless of where each operation lives.\n73: \n74: ## Cross-surface hygiene (separate from ownership)\n75: \n76: The following inconsistencies span surfaces and should be addressed\n77: independently of ownership decisions:\n78: \n79: - **Error contracts**: REST raises `HTTPException` with status codes; MCP\n80:   returns string error prefixes (`\"Error (422): ...\"`). Cross-surface clients\n81:   must special-case. Pick one canonical shape and align both surfaces.\n82: - **Response shape drift on `recall`**: REST `/recall` returns\n83:   `{query, summary, memory_count, memories, recall_ms}`; MCP\n84:   `memclaw_recall(include_brief=true)` returns\n85:   `{results, brief: <REST-recall-response>}`. Same conceptual operation,\n86:   different payloads. Pick one and align.\n87: - **Tenant resolution**: REST takes `body.tenant_id`; MCP infers from auth\n88:   header. Both are reasonable; document the convention.\n\n(End of file - total 88 lines)\n</content>","metadata":{"preview":"# API Surface Ownership Charter\n\nMemClaw exposes three callable surfaces — REST, MCP, and the OpenClaw plugin.\nThey are intentionally **not symmetric**. Each serves a different audience and\noperates under different assumptions. This document records who owns what and\nwhen to add or move an operation.\n\n> Looking for **latency and throughput numbers** per surface? See\n> [`performance.md`](performance.md). This document is about *which surface\n> owns which operation*, not about how fast each one runs.\n\n## Audiences\n\n| Surface | Primary audience | Trust model |\n|---------|------------------|-------------|\n| REST    | Web UI, ops dashboards, programmatic admins, scripted clients | Explicit `tenant_id` in body/query; API key + role gating; full operational vocabulary. |\n| MCP     | AI agents (Claude Code, third-party agents) | Tenant inferred from auth header; agent-natural operations; description-driven discoverability. |\n| OpenClaw plugin | Local plugin runtime that hosts agents | Operational concerns of the local install — heartbeat, agent registration, fleet readiness. Delegates business operations to MCP. |\n\n## Surface ownership","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/api-surfaces.md","text":"# API Surface Ownership Charter\n\nMemClaw exposes three callable surfaces — REST, MCP, and the OpenClaw plugin.\nThey are intentionally **not symmetric**. Each serves a different audience and\noperates under different assumptions. This document records who owns what and\nwhen to add or move an operation.\n\n> Looking for **latency and throughput numbers** per surface? See\n> [`performance.md`](performance.md). This document is about *which surface\n> owns which operation*, not about how fast each one runs.\n\n## Audiences\n\n| Surface | Primary audience | Trust model |\n|---------|------------------|-------------|\n| REST    | Web UI, ops dashboards, programmatic admins, scripted clients | Explicit `tenant_id` in body/query; API key + role gating; full operational vocabulary. |\n| MCP     | AI agents (Claude Code, third-party agents) | Tenant inferred from auth header; agent-natural operations; description-driven discoverability. |\n| OpenClaw plugin | Local plugin runtime that hosts agents | Operational concerns of the local install — heartbeat, agent registration, fleet readiness. Delegates business operations to MCP. |\n\n## Surface ownership\n\n| Concern | Owner | Reason |\n|---------|-------|--------|\n| Memory CRUD (write/recall/list/get/update/delete/transition) | REST + MCP | Universal; needed by every audience. |\n| Bulk write | REST + MCP | Same. |\n| Per-agent search profile (tune) | REST + MCP | Both administrators (REST) and agents tuning themselves (MCP) need it. |\n| Doc CRUD | REST + MCP | Universal. |\n| Doc semantic search | MCP **and** REST | Was MCP-only; REST endpoint added so non-MCP clients can use vector search on documents. |\n| Doc list-collections | MCP **and** REST | Was MCP-only; REST endpoint added for parity with list use cases. |\n| Bulk delete | REST + MCP (`memclaw_manage op=bulk_delete`) | Admin sometimes; agents cleaning up after themselves sometimes. |\n| Memory lineage walk | REST + MCP (`memclaw_manage op=lineage`) | Agents reviewing their own writes need to trace supersession chains. |\n| Knowledge graph / `/graph` | REST only | Aggregation surface for UIs and analytics tools. Agents that need entity context use `memclaw_entity_get` (single entity) and `memclaw_recall` (with entity_links in results). |\n| Memory stats | REST + MCP (`memclaw_stats`) | Aggregate counts (total + breakdown by type, agent, status; opt-in `include_deleted=true` adds `deleted` and `total_including_deleted`) — useful for admin/dashboard usage on REST and for agent self-introspection on MCP. Read-only aggregations don't need a use-case gate. |\n| Skill sharing | REST (`/documents` + `/documents/search` on `collection=\"skills\"`) + MCP (`memclaw_doc op=write\\|read\\|query\\|delete\\|search collection=skills`) | Skill sharing rides the generic document surface. Slugs (`doc_id`) are constrained to `^[a-z0-9][a-z0-9._-]{0,99}$` (filesystem-safe), and skills writes require `data[\"summary\"]` (with back-compat fallback to `data[\"description\"]`) so the catalog is semantic-searchable without ceremony. The dedicated `memclaw_share_skill`/`memclaw_unshare_skill` tools and `/skills/*` REST routes were dropped 2026-05; fleet auto-install (push to every node) is restored by Phase A's plugin-side reconciler. Trust ≥ 1 (inherited from `memclaw_doc`). |\n| Keystones (mandatory rules) | REST (`/memclaw/keystones`) + MCP (`memclaw_keystones` read, `memclaw_keystones_set` set\\|delete) | Governance policies that agents MUST obey — fetched deterministically (no semantic search) and injected into every session by the OpenClaw plugin. Storage lives in the system-managed `_keystones` collection on `documents`; the dedicated surface exists so the read tool stays discoverable in MCP `instructions` and the write surface can be trust-gated separately. Reads are open. Writes are tiered: a freshly-registered (trust ≥ 1) agent can author its own `scope=agent` rule — self-authored autonomy — but `scope=fleet`, `scope=tenant`, and cross-agent `scope=agent` stay at trust ≥ 2 so a default-trust agent (or a prompt-injected one) can't plant a tenant-wide rule. |\n| Tenant settings | REST only | Settings are a tenant-administrator concern; not safe for arbitrary agents to flip global config. |\n| Redistribute (mass reassign) | REST only | Destructive bulk op requires `trust_level >= 3`. Admin operation, not agent-driven. |\n| Ingest preview/commit | REST only (revisit per use case) | Pipeline workflow; expose to MCP only if \"agent crawls a URL and writes memories\" becomes a real use case. |\n| Contradictions / lineage at `/memories/{id}/contradictions` | REST + MCP (`memclaw_manage op=lineage`) | UI gets the rich endpoint; agents get the focused tool. |\n| Heartbeat / fleet readiness | REST receives, plugin produces | Plugin is the natural producer (it knows the local node state). REST is the receiver. MCP doesn't need this — agents don't report their own runtime state. |\n| Agent registration | OpenClaw plugin | Local-runtime concern. |\n\n## When to add an operation\n\nBefore adding a new MCP tool that mirrors a REST endpoint, justify it with a\nconcrete agent workflow OR demonstrate that the operation is a read-only\naggregation/introspection:\n\n1. **Read-only aggregations** (counts, summaries, listings of caller-visible\n   state) don't need a blocking use case — they're cheap, safe, and useful for\n   any agent that wants to introspect the store. Add freely; trust gate at\n   the same level as `memclaw_list` (≥ 1 for own scope, ≥ 2 for cross-agent).\n2. For everything else: is there an agent that **today** is blocked from\n   doing useful work because this operation only exists on REST?\n3. If yes, does it fit naturally into an existing tool (`memclaw_manage`,\n   `memclaw_doc`, etc.) as another `op=...`? Prefer extending an existing\n   tool over adding a new top-level surface.\n4. If a new tool is genuinely warranted, it must include: a clear description,\n   trust-level enforcement consistent with the REST counterpart, and a wet\n   test that exercises the same workflow against the local docker stack.\n\nBefore adding a new REST endpoint that mirrors an MCP tool, justify it with a\nconcrete non-agent workflow (a UI screen, a script, an integration). Don't\nmirror \"for symmetry.\"\n\n## What this charter is NOT\n\n- It's not a list of bugs. Asymmetry is the design, not a defect.\n- It's not exhaustive — new operations should be classified above when added.\n- It's not a justification for current cross-surface drift in error contracts\n  or response shapes — those are separate hygiene concerns and should be\n  fixed regardless of where each operation lives.\n\n## Cross-surface hygiene (separate from ownership)\n\nThe following inconsistencies span surfaces and should be addressed\nindependently of ownership decisions:\n\n- **Error contracts**: REST raises `HTTPException` with status codes; MCP\n  returns string error prefixes (`\"Error (422): ...\"`). Cross-surface clients\n  must special-case. Pick one canonical shape and align both surfaces.\n- **Response shape drift on `recall`**: REST `/recall` returns\n  `{query, summary, memory_count, memories, recall_ms}`; MCP\n  `memclaw_recall(include_brief=true)` returns\n  `{results, brief: <REST-recall-response>}`. Same conceptual operation,\n  different payloads. Pick one and align.\n- **Tenant resolution**: REST takes `body.tenant_id`; MCP infers from auth\n  header. Both are reasonable; document the convention.","lineStart":1,"lineEnd":88,"totalLines":88,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/api-surfaces.md","time":{"start":1780727679451,"end":1780727679464}},"metadata":{"openai":{"itemId":"fc_020d7f924b1ec321016a23bf7f4fec81919179ca4bac21a3cd"}},"id":"prt_e9ba409d4001YoRkGUzUDJ1Hea","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba3d1cf0017X0Ediqx0UTlLy"}}
