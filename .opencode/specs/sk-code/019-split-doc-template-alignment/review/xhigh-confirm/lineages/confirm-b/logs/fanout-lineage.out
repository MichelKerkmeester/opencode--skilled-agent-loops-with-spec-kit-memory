{"type":"tool_use","timestamp":1783921310406,"sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","part":{"type":"tool","tool":"read","callID":"call_eGfomvela4W9a0Fqi6PAvJbp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/shared/scripts/validate_document.py","offset":300,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/shared/scripts/validate_document.py</path>\n<type>file</type>\n<content>\n300: \n301:                 errors.append({\n302:                     'type': 'toc_not_uppercase',\n303:                     'severity': 'blocking',\n304:                     'message': f'TOC entry not ALL CAPS: \"{entry_text}\"',\n305:                     'line': line,\n306:                     'auto_fixable': True,\n307:                     'fix': fixed_line,\n308:                     'fix_hint': f'Change \"{section_text}\" to \"{section_text.upper()}\"'\n309:                 })\n310: \n311:     return errors\n312: \n313: \n314: # ───────────────────────────────────────────────────────────────\n315: # 4. HEADER VALIDATION\n316: # ───────────────────────────────────────────────────────────────\n317: \n318: def validate_h2_headers(content: str, doc_type_rules: Dict[str, Any], rules: Dict[str, Any]) -> List[Dict[str, Any]]:\n319:     \"\"\"Validate H2 header format and emojis.\"\"\"\n320:     errors = []\n321: \n322:     h2_pattern = re.compile(r'^## (\\d+)\\.\\s+(.+)$', re.MULTILINE)\n323:     matches = list(h2_pattern.finditer(content))\n324: \n325:     if not matches:\n326:         # No numbered H2 headers found - check if this is expected\n327:         # Some documents might use different header styles\n328:         return errors\n329: \n330:     expected_num = 1\n331:     emoji_required = doc_type_rules.get('h2EmojiRequired', True)\n332:     section_emojis = doc_type_rules.get('sectionEmojis', {})\n333:     section_aliases = doc_type_rules.get('sectionAliases', {})\n334: \n335:     for match in matches:\n336:         num = int(match.group(1))\n337:         title = match.group(2).strip()\n338:         line = match.group(0)\n339: \n340:         if num != expected_num:\n341:             errors.append({\n342:                 'type': 'non_sequential_numbering',\n343:                 'severity': 'warning',\n344:                 'message': f'Non-sequential section number: expected {expected_num}, found {num}',\n345:                 'line': line\n346:             })\n347:         expected_num = num + 1\n348: \n349:         if emoji_required:\n350:             title_has_emoji = has_emoji(title)\n351: \n352:             if not title_has_emoji:\n353:                 section_name = normalize_section_name(title)\n354: \n355:                 if section_name in section_aliases:\n356:                     section_name = section_aliases[section_name]\n357: \n358:                 expected_emoji = section_emojis.get(section_name)\n359: \n360:                 # Fallback: match ignoring underscores for flexibility\n361:                 if not expected_emoji:\n362:                     section_name_no_underscore = section_name.replace('_', '')\n363:                     for key, emoji in section_emojis.items():\n364:                         if key.replace('_', '') == section_name_no_underscore:\n365:                             expected_emoji = emoji\n366:                             break\n367: \n368:                 errors.append({\n369:                     'type': 'missing_h2_emoji',\n370:                     'severity': 'blocking',\n371:                     'message': f'H2 header missing emoji: \"{line}\"',\n372:                     'line': line,\n373:                     'section_name': section_name,\n374:                     'expected_emoji': expected_emoji,\n375:                     'auto_fixable': expected_emoji is not None,\n376:                     'fix': f'## {num}. {expected_emoji} {title}' if expected_emoji else None,\n377:                     'fix_hint': f'Add {expected_emoji} after \"{num}.\"' if expected_emoji else 'Add appropriate emoji after section number'\n378:                 })\n379: \n\n(Showing lines 300-379 of 928. Use offset=380 to continue.)\n</content>","metadata":{"preview":"\n                errors.append({\n                    'type': 'toc_not_uppercase',\n                    'severity': 'blocking',\n                    'message': f'TOC entry not ALL CAPS: \"{entry_text}\"',\n                    'line': line,\n                    'auto_fixable': True,\n                    'fix': fixed_line,\n                    'fix_hint': f'Change \"{section_text}\" to \"{section_text.upper()}\"'\n                })\n\n    return errors\n\n\n# ───────────────────────────────────────────────────────────────\n# 4. HEADER VALIDATION\n# ───────────────────────────────────────────────────────────────\n\ndef validate_h2_headers(content: str, doc_type_rules: Dict[str, Any], rules: Dict[str, Any]) -> List[Dict[str, Any]]:\n    \"\"\"Validate H2 header format and emojis.\"\"\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/shared/scripts/validate_document.py","text":"\n                errors.append({\n                    'type': 'toc_not_uppercase',\n                    'severity': 'blocking',\n                    'message': f'TOC entry not ALL CAPS: \"{entry_text}\"',\n                    'line': line,\n                    'auto_fixable': True,\n                    'fix': fixed_line,\n                    'fix_hint': f'Change \"{section_text}\" to \"{section_text.upper()}\"'\n                })\n\n    return errors\n\n\n# ───────────────────────────────────────────────────────────────\n# 4. HEADER VALIDATION\n# ───────────────────────────────────────────────────────────────\n\ndef validate_h2_headers(content: str, doc_type_rules: Dict[str, Any], rules: Dict[str, Any]) -> List[Dict[str, Any]]:\n    \"\"\"Validate H2 header format and emojis.\"\"\"\n    errors = []\n\n    h2_pattern = re.compile(r'^## (\\d+)\\.\\s+(.+)$', re.MULTILINE)\n    matches = list(h2_pattern.finditer(content))\n\n    if not matches:\n        # No numbered H2 headers found - check if this is expected\n        # Some documents might use different header styles\n        return errors\n\n    expected_num = 1\n    emoji_required = doc_type_rules.get('h2EmojiRequired', True)\n    section_emojis = doc_type_rules.get('sectionEmojis', {})\n    section_aliases = doc_type_rules.get('sectionAliases', {})\n\n    for match in matches:\n        num = int(match.group(1))\n        title = match.group(2).strip()\n        line = match.group(0)\n\n        if num != expected_num:\n            errors.append({\n                'type': 'non_sequential_numbering',\n                'severity': 'warning',\n                'message': f'Non-sequential section number: expected {expected_num}, found {num}',\n                'line': line\n            })\n        expected_num = num + 1\n\n        if emoji_required:\n            title_has_emoji = has_emoji(title)\n\n            if not title_has_emoji:\n                section_name = normalize_section_name(title)\n\n                if section_name in section_aliases:\n                    section_name = section_aliases[section_name]\n\n                expected_emoji = section_emojis.get(section_name)\n\n                # Fallback: match ignoring underscores for flexibility\n                if not expected_emoji:\n                    section_name_no_underscore = section_name.replace('_', '')\n                    for key, emoji in section_emojis.items():\n                        if key.replace('_', '') == section_name_no_underscore:\n                            expected_emoji = emoji\n                            break\n\n                errors.append({\n                    'type': 'missing_h2_emoji',\n                    'severity': 'blocking',\n                    'message': f'H2 header missing emoji: \"{line}\"',\n                    'line': line,\n                    'section_name': section_name,\n                    'expected_emoji': expected_emoji,\n                    'auto_fixable': expected_emoji is not None,\n                    'fix': f'## {num}. {expected_emoji} {title}' if expected_emoji else None,\n                    'fix_hint': f'Add {expected_emoji} after \"{num}.\"' if expected_emoji else 'Add appropriate emoji after section number'\n                })\n","lineStart":300,"lineEnd":379,"totalLines":928,"truncated":true}},"title":".opencode/skills/sk-doc/shared/scripts/validate_document.py","time":{"start":1783921310375,"end":1783921310391}},"metadata":{"openai":{"itemId":"fc_03b49908c9a32738016a547a9e0ea48191b742c2f153771b2c"}},"id":"prt_f59fefaa6001nyjvjR3xLn6O7V","sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","messageID":"msg_f59fec928001cz11FYpcd93kU5"}}
{"type":"tool_use","timestamp":1783921310406,"sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","part":{"type":"tool","tool":"read","callID":"call_2WTYwpIyLkLO4CsrWkID5sR1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-skill/assets/skill/skill_asset_template.md","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-skill/assets/skill/skill_asset_template.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Skill Asset File Templates\n3: description: Templates and guidelines for creating asset files in AI agent skills.\n4: trigger_phrases:\n5:   - \"skill asset templates\"\n6:   - \"asset file guidelines\"\n7:   - \"asset document structure\"\n8:   - \"standard asset structure\"\n9: importance_tier: normal\n10: contextType: general\n11: version: 1.8.0.19\n12: ---\n13: \n14: # Skill Asset File Templates - Creation Guidelines\n15: \n16: Templates and guidelines for creating asset files in AI agent skills.\n17: \n18: ## 1. OVERVIEW\n19: \n20: ### Location & Naming\n21: \n22: **Location:** `.opencode/skills/[skill-name]/assets/`\n23: \n24: **Naming Convention:** snake_case with appropriate extension\n25: \n26: | ✅ Valid Names | ❌ Invalid Names |\n27: |---------------|-----------------|\n28: | `frontmatter_templates.md` | `FrontmatterTemplates.md` (PascalCase) |\n29: | `config_examples.yaml` | `config-examples.yaml` (kebab-case) |\n30: | `validation_checklist.md` | `ValidationChecklist.MD` (wrong case) |\n31: | `emoji_reference.md` | `emojiReference.md` (camelCase) |\n32: \n33: ### When to Create Assets\n34: \n35: **Create an asset file when:**\n36: - Templates users apply repeatedly\n37: - Reference data >50 lines and self-contained\n38: - Multiple examples of same pattern exist\n39: - Lookup tables or decision matrices needed\n40: - Template variations for different scenarios\n41: \n42: **Keep in SKILL.md when:**\n43: - Content <30 lines\n44: - Tightly coupled to workflow logic\n45: - Needs to be visible immediately (not progressive disclosure)\n46: - Part of core instructions (RULES, WORKFLOW sections)\n47: \n48: ---\n49: \n50: ## 2. ASSET FILE TYPES\n51: \n52: ### Template Files\n53: **Purpose**: Provide copy-paste starting points for common tasks\n54: \n55: **Naming**: `[content-type]_templates.md`\n56: - Example: `frontmatter_templates.md`, `structure_templates.md`\n57: \n58: **Structure**:\n59: - One template per section\n60: - Include field descriptions\n61: - Show complete examples\n62: - Explain when to use each template\n63: \n64: **Use cases**:\n65: - Document templates (SKILL.md, commands, knowledge files)\n66: - Configuration templates (YAML, JSON)\n67: - Code templates (functions, classes, modules)\n68: \n69: ### Reference Files\n70: **Purpose**: Provide lookup tables, decision trees, or reference data\n71: \n72: **Naming**: `[topic]_reference.md`\n73: - Example: `emoji_reference.md`, `validation_reference.md`\n74: \n75: **Structure**:\n76: - Tables or lists for quick lookup\n77: - Decision matrices\n78: - Classification systems\n79: - Standards and conventions\n80: \n81: **Use cases**:\n82: - Emoji selection guides\n83: - File type classifications\n84: - Validation rule sets\n85: - Naming conventions\n86: \n87: ### Example Files\n88: **Purpose**: Show working examples of skill outputs\n89: \n90: **Naming**: `[topic]_examples.md`\n91: - Example: `optimization_examples.md`, `skill_examples.md`\n92: \n93: **Structure**:\n94: - Before/after comparisons\n95: - Annotated examples\n96: - Multiple variations\n97: - Anti-patterns to avoid\n98: \n99: **Use cases**:\n100: - Complete skill applications\n101: - Common patterns\n102: - Edge cases\n103: - Quality standards\n104: \n105: ### Guide Files\n106: **Purpose**: Detailed how-to guides for complex processes\n107: \n108: **Naming**: `[process]_guide.md`\n109: - Example: `packaging_guide.md`, `distribution_guide.md`\n110: \n111: **Structure**:\n112: - Step-by-step instructions\n113: - Troubleshooting sections\n114: - Best practices\n115: - Common pitfalls\n116: \n117: **Use cases**:\n118: - Multi-step processes\n119: - Advanced techniques\n120: - Workflow deep-dives\n121: - Integration guides\n122: \n123: ---\n124: \n125: ## 3. DOCUMENT STRUCTURE\n126: \n127: ### Title and Intro\n128: \n129: **CRITICAL: The intro after the H1 title must be 1-2 SHORT sentences only.**\n130: \n131: ```markdown\n132: ---\n133: title: [Title]\n134: description: [One-line description - same as intro]\n135: trigger_phrases:\n136:   - \"[distinctive phrase one]\"\n137:   - \"[distinctive phrase two]\"\n138:   - \"[distinctive phrase three]\"\n139: importance_tier: normal\n140: contextType: general\n141: version: 1.0.0.0\n142: ---\n143: \n144: # [Title]\n145: \n146: [1-2 SHORT sentences only. Brief hook/summary. NO subsections, NO headers here.]\n147: \n148: \\## 1. OVERVIEW\n149: \n150: ### Purpose\n151: \n152: [Why this asset exists]\n153: \n154: ### Usage\n155: \n156: [How to use this asset - copy instructions, customization notes]\n157: \n158: ---\n159: \n160: \\## 2. [Content Section]\n161: \n162: [The actual template/checklist/snippet content]\n163: \n164: ---\n165: \n166: ## N. Related Resources (optional, if present must be last)\n167: \n168: [Links to related files]\n169: \n170: ```\n171: \n172: Every asset file carries this full 5-field frontmatter block: the Skill Advisor harvests it as routing signal (3-8 lowercase multi-word `trigger_phrases` drawn from the doc's content; `importance_tier` defaults to `normal`; `contextType` one of `planning|research|implementation|general`). See [frontmatter_templates.md](../../../shared/assets/frontmatter_templates.md) for field rules.\n173: \n174: > **WARNING: DO NOT duplicate content between intro and OVERVIEW section.**\n175: > The intro is a hook; OVERVIEW provides the details.\n176: \n177: #### GOOD Intro Structure\n178: \n179: ```markdown\n180: # Git Commit Templates\n181: \n182: Copy-paste templates for creating well-structured commit messages.\n183: \n184: \\## 1. OVERVIEW\n185: \n186: ### Purpose\n187: \n188: Provides consistent commit message formats for atomic commits...\n189: \n190: ### Usage\n191: \n192: Copy the appropriate template based on commit type...\n193: \n194: ---\n195: \n196: \\## 2. COMMIT TEMPLATES\n197: ...\n198: ```\n199: \n200: #### BAD Intro Structure (too long, has subsections)\n201: \n202: ```markdown\n203: # Git Commit Templates\n204: \n205: Copy-paste templates for creating well-structured commit messages.\n206: \n207: ### Core Principle    ← WRONG: No headers in intro!\n208: Atomic commits with clear intent = maintainable history.\n209: \n210: ### When to Use       ← WRONG: This belongs in OVERVIEW section!\n211: - Creating new features\n212: - Fixing bugs\n213: \n214: ---\n215: ```\n216: \n217: ### Intro vs OVERVIEW Content Placement\n218: \n219: | Content Type          | Intro (after H1) | OVERVIEW Section       |\n220: | --------------------- | ---------------- | ---------------------- |\n\n(Showing lines 1-220 of 946. Use offset=221 to continue.)\n</content>","metadata":{"preview":"---\ntitle: Skill Asset File Templates\ndescription: Templates and guidelines for creating asset files in AI agent skills.\ntrigger_phrases:\n  - \"skill asset templates\"\n  - \"asset file guidelines\"\n  - \"asset document structure\"\n  - \"standard asset structure\"\nimportance_tier: normal\ncontextType: general\nversion: 1.8.0.19\n---\n\n# Skill Asset File Templates - Creation Guidelines\n\nTemplates and guidelines for creating asset files in AI agent skills.\n\n## 1. OVERVIEW\n\n### Location & Naming","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/create-skill/assets/skill/skill_asset_template.md","text":"---\ntitle: Skill Asset File Templates\ndescription: Templates and guidelines for creating asset files in AI agent skills.\ntrigger_phrases:\n  - \"skill asset templates\"\n  - \"asset file guidelines\"\n  - \"asset document structure\"\n  - \"standard asset structure\"\nimportance_tier: normal\ncontextType: general\nversion: 1.8.0.19\n---\n\n# Skill Asset File Templates - Creation Guidelines\n\nTemplates and guidelines for creating asset files in AI agent skills.\n\n## 1. OVERVIEW\n\n### Location & Naming\n\n**Location:** `.opencode/skills/[skill-name]/assets/`\n\n**Naming Convention:** snake_case with appropriate extension\n\n| ✅ Valid Names | ❌ Invalid Names |\n|---------------|-----------------|\n| `frontmatter_templates.md` | `FrontmatterTemplates.md` (PascalCase) |\n| `config_examples.yaml` | `config-examples.yaml` (kebab-case) |\n| `validation_checklist.md` | `ValidationChecklist.MD` (wrong case) |\n| `emoji_reference.md` | `emojiReference.md` (camelCase) |\n\n### When to Create Assets\n\n**Create an asset file when:**\n- Templates users apply repeatedly\n- Reference data >50 lines and self-contained\n- Multiple examples of same pattern exist\n- Lookup tables or decision matrices needed\n- Template variations for different scenarios\n\n**Keep in SKILL.md when:**\n- Content <30 lines\n- Tightly coupled to workflow logic\n- Needs to be visible immediately (not progressive disclosure)\n- Part of core instructions (RULES, WORKFLOW sections)\n\n---\n\n## 2. ASSET FILE TYPES\n\n### Template Files\n**Purpose**: Provide copy-paste starting points for common tasks\n\n**Naming**: `[content-type]_templates.md`\n- Example: `frontmatter_templates.md`, `structure_templates.md`\n\n**Structure**:\n- One template per section\n- Include field descriptions\n- Show complete examples\n- Explain when to use each template\n\n**Use cases**:\n- Document templates (SKILL.md, commands, knowledge files)\n- Configuration templates (YAML, JSON)\n- Code templates (functions, classes, modules)\n\n### Reference Files\n**Purpose**: Provide lookup tables, decision trees, or reference data\n\n**Naming**: `[topic]_reference.md`\n- Example: `emoji_reference.md`, `validation_reference.md`\n\n**Structure**:\n- Tables or lists for quick lookup\n- Decision matrices\n- Classification systems\n- Standards and conventions\n\n**Use cases**:\n- Emoji selection guides\n- File type classifications\n- Validation rule sets\n- Naming conventions\n\n### Example Files\n**Purpose**: Show working examples of skill outputs\n\n**Naming**: `[topic]_examples.md`\n- Example: `optimization_examples.md`, `skill_examples.md`\n\n**Structure**:\n- Before/after comparisons\n- Annotated examples\n- Multiple variations\n- Anti-patterns to avoid\n\n**Use cases**:\n- Complete skill applications\n- Common patterns\n- Edge cases\n- Quality standards\n\n### Guide Files\n**Purpose**: Detailed how-to guides for complex processes\n\n**Naming**: `[process]_guide.md`\n- Example: `packaging_guide.md`, `distribution_guide.md`\n\n**Structure**:\n- Step-by-step instructions\n- Troubleshooting sections\n- Best practices\n- Common pitfalls\n\n**Use cases**:\n- Multi-step processes\n- Advanced techniques\n- Workflow deep-dives\n- Integration guides\n\n---\n\n## 3. DOCUMENT STRUCTURE\n\n### Title and Intro\n\n**CRITICAL: The intro after the H1 title must be 1-2 SHORT sentences only.**\n\n```markdown\n---\ntitle: [Title]\ndescription: [One-line description - same as intro]\ntrigger_phrases:\n  - \"[distinctive phrase one]\"\n  - \"[distinctive phrase two]\"\n  - \"[distinctive phrase three]\"\nimportance_tier: normal\ncontextType: general\nversion: 1.0.0.0\n---\n\n# [Title]\n\n[1-2 SHORT sentences only. Brief hook/summary. NO subsections, NO headers here.]\n\n\\## 1. OVERVIEW\n\n### Purpose\n\n[Why this asset exists]\n\n### Usage\n\n[How to use this asset - copy instructions, customization notes]\n\n---\n\n\\## 2. [Content Section]\n\n[The actual template/checklist/snippet content]\n\n---\n\n## N. Related Resources (optional, if present must be last)\n\n[Links to related files]\n\n```\n\nEvery asset file carries this full 5-field frontmatter block: the Skill Advisor harvests it as routing signal (3-8 lowercase multi-word `trigger_phrases` drawn from the doc's content; `importance_tier` defaults to `normal`; `contextType` one of `planning|research|implementation|general`). See [frontmatter_templates.md](../../../shared/assets/frontmatter_templates.md) for field rules.\n\n> **WARNING: DO NOT duplicate content between intro and OVERVIEW section.**\n> The intro is a hook; OVERVIEW provides the details.\n\n#### GOOD Intro Structure\n\n```markdown\n# Git Commit Templates\n\nCopy-paste templates for creating well-structured commit messages.\n\n\\## 1. OVERVIEW\n\n### Purpose\n\nProvides consistent commit message formats for atomic commits...\n\n### Usage\n\nCopy the appropriate template based on commit type...\n\n---\n\n\\## 2. COMMIT TEMPLATES\n...\n```\n\n#### BAD Intro Structure (too long, has subsections)\n\n```markdown\n# Git Commit Templates\n\nCopy-paste templates for creating well-structured commit messages.\n\n### Core Principle    ← WRONG: No headers in intro!\nAtomic commits with clear intent = maintainable history.\n\n### When to Use       ← WRONG: This belongs in OVERVIEW section!\n- Creating new features\n- Fixing bugs\n\n---\n```\n\n### Intro vs OVERVIEW Content Placement\n\n| Content Type          | Intro (after H1) | OVERVIEW Section       |\n| --------------------- | ---------------- | ---------------------- |","lineStart":1,"lineEnd":220,"totalLines":946,"truncated":true}},"title":".opencode/skills/sk-doc/create-skill/assets/skill/skill_asset_template.md","time":{"start":1783921310356,"end":1783921310403}},"metadata":{"openai":{"itemId":"fc_03b49908c9a32738016a547a9e0e888191922d323294a04d76"}},"id":"prt_f59fefa3f001STizJB99QuepmI","sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","messageID":"msg_f59fec928001cz11FYpcd93kU5"}}
{"type":"tool_use","timestamp":1783921310406,"sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","part":{"type":"tool","tool":"read","callID":"call_mIloQfaxDUPyQows8X8oss2E","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/code-opencode/references/rust/style_guide/interop_errors_and_parity.md","offset":1,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/code-opencode/references/rust/style_guide/interop_errors_and_parity.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Rust/TypeScript Interop — Errors, Parity & Related Resources\n3: description: Formatting standards, naming conventions, and TypeScript interoperability rules for Rust files in the OpenCode development environment. — Rust/TypeScript Interop — Errors, Parity & Related Resources.\n4: trigger_phrases:\n5:   - \"rust typescript interop errors parity related resources\"\n6:   - \"rust interop errors and parity\"\n7:   - \"rust style guidance\"\n8: importance_tier: normal\n9: contextType: implementation\n10: version: 1.0.0.0\n11: ---\n12: \n13: # Rust/TypeScript Interop — Errors, Parity & Related Resources\n14: \n15: Formatting standards, naming conventions, and TypeScript interoperability rules for Rust files in the OpenCode development environment.\n16: \n17: ---\n18: \n19: ## 1. OVERVIEW\n20: \n21: ### Purpose\n22: \n23: Provides focused Rust guidance for rust/typescript interop — errors, parity & related resources in the OpenCode development environment.\n24: \n25: ### When to Use\n26: \n27: - Implementing or reviewing Rust code covered by this topic\n28: - Preserving TypeScript interoperability and deterministic behavior\n29: - Applying the corresponding Rust standards at an implementation boundary\n30: \n31: ## 2. ERROR STYLE\n32: \n33: Core public operations return domain-specific `Result` values backed by `thiserror`.\n34: \n35: ```rust\n36: use thiserror::Error;\n37: \n38: #[derive(Debug, Error)]\n39: pub enum RankingError {\n40:     #[error(\"candidate identifier must not be empty\")]\n41:     EmptyIdentifier,\n42: \n43:     #[error(\"candidate score must be finite\")]\n44:     NonFiniteScore,\n45: \n46:     #[error(\"candidate limit {limit} exceeds maximum {maximum}\")]\n47:     LimitExceeded {\n48:         limit: u32,\n49:         maximum: u32,\n50:     },\n51: }\n52: ```\n53: \n54: Rules:\n55: \n56: - Core errors contain adapter-relevant structured context.\n57: - Core errors contain no napi-rs, WASM, or Node runtime types.\n58: - `anyhow` is prohibited in pure-core public APIs and exported functions.\n59: - `anyhow` MAY be used in sidecar `main`, build tooling, and the outermost non-ABI shell.\n60: - Every adapter owns one exhaustive mapping from core errors to stable JavaScript errors.\n61: - Error messages and codes covered by TypeScript contracts are golden-tested.\n62: - Panic only for an impossible internal invariant, never for recoverable boundary input.\n63: \n64: ## 3. EXHAUSTIVE ADAPTER ERROR MAPPING\n65: \n66: ```rust\n67: #[derive(Debug)]\n68: struct JsErrorShape {\n69:     code: &'static str,\n70:     message: String,\n71: }\n72: \n73: fn map_ranking_error(error: RankingError) -> JsErrorShape {\n74:     match error {\n75:         RankingError::EmptyIdentifier => JsErrorShape {\n76:             code: \"INVALID_IDENTIFIER\",\n77:             message: error.to_string(),\n78:         },\n79:         RankingError::NonFiniteScore => JsErrorShape {\n80:             code: \"NON_FINITE_SCORE\",\n81:             message: error.to_string(),\n82:         },\n83:         RankingError::LimitExceeded { .. } => JsErrorShape {\n84:             code: \"LIMIT_EXCEEDED\",\n85:             message: error.to_string(),\n86:         },\n87:     }\n88: }\n89: ```\n90: \n91: The adapter must also preserve whether the existing TypeScript operation throws synchronously or rejects a Promise.\n92: \n93: ## 4. PANIC-FREE BOUNDARY VALIDATION\n94: \n95: Do not use:\n96: \n97: ```rust\n98: let score = input.parse::<f64>().unwrap();\n99: let first = candidates[0].clone();\n100: let ordering = left.score.partial_cmp(&right.score).unwrap();\n101: ```\n102: \n103: Use typed failures:\n104: \n105: ```rust\n106: use std::num::ParseFloatError;\n107: \n108: fn parse_score(input: &str) -> Result<f64, ParseFloatError> {\n109:     input.parse::<f64>()\n110: }\n111: \n112: fn first_candidate(candidates: &[String]) -> Option<&str> {\n113:     candidates.first().map(String::as_str)\n114: }\n115: ```\n116: \n117: JavaScript-controlled data must not reach:\n118: \n119: - `unwrap`\n120: - `expect`\n121: - Unchecked indexing\n122: - `panic!`\n123: - `unreachable!`\n124: - Assertions used as validation\n125: - `partial_cmp(...).unwrap()`\n126: \n127: ## 5. DETERMINISTIC IDENTIFIERS\n128: \n129: Identifier generation preserves the exact TypeScript preimage contract:\n130: \n131: - Input fields\n132: - Field order\n133: - Separators\n134: - UTF-8 encoding\n135: - Hash algorithm\n136: - Lowercase hexadecimal encoding\n137: - Truncation length\n138: \n139: ```rust\n140: use sha2::{Digest, Sha256};\n141: \n142: fn deterministic_id(namespace: &str, name: &str) -> String {\n143:     let preimage = format!(\"{namespace}\\0{name}\");\n144:     let digest = Sha256::digest(preimage.as_bytes());\n145:     let hexadecimal = format!(\"{digest:x}\");\n146:     hexadecimal[..24].to_owned()\n147: }\n148: ```\n149: \n150: This example is correct only if the TypeScript oracle uses the same fields, NUL delimiter, UTF-8 bytes, SHA-256, lowercase hexadecimal output, and 24-character truncation. Never infer those details from a semantically similar implementation.\n151: \n152: ## 6. STABLE SERIALIZATION\n153: \n154: Do not assume `serde_json` reproduces JavaScript byte output automatically.\n155: \n156: Potential differences include:\n157: \n158: - Number spelling\n159: - Negative zero\n160: - Exponent notation\n161: - Omitted versus `null` fields\n162: - Escaping\n163: - Key order\n164: - Non-finite values\n165: - Map iteration order\n166: \n167: Use passive DTOs and canonical maps:\n168: \n169: ```rust\n170: use std::collections::BTreeMap;\n171: \n172: use serde::Serialize;\n173: \n174: #[derive(Debug, Serialize)]\n175: #[serde(rename_all = \"camelCase\")]\n176: struct SearchResponse {\n177:     results: Vec<SearchResult>,\n178:     metadata: BTreeMap<String, String>,\n179: }\n180: \n181: #[derive(Debug, Serialize)]\n182: struct SearchResult {\n183:     id: String,\n184:     score: f64,\n185: }\n186: ```\n187: \n188: Byte-for-byte fixtures remain required even when the Rust structure appears equivalent to the TypeScript object.\n189: \n190: ## 7. ASYNC AND THREADING\n191: \n192: Keep parsing, scoring, ranking, hashing, canonicalization, and serialization preparation synchronous in the core.\n193: \n194: Use napi-rs `AsyncTask` only for measured CPU or blocking work that would materially block Node.\n195: \n196: Before worker execution:\n197: \n198: - Convert JavaScript values into owned DTOs.\n199: - Copy JavaScript-owned buffers.\n200: - Validate cheap structural constraints.\n201: - Do not retain `Env`, `JsValue`, or thread-affine handles.\n202: \n203: After worker execution:\n204: \n205: - Reorder results by deterministic sequence keys.\n206: - Canonicalize output synchronously.\n207: - Map typed errors on the JavaScript thread.\n208: \n209: Use Tokio only for genuine Rust-owned asynchronous I/O. Use Rayon only after benchmark evidence demonstrates a useful batch-size threshold.\n210: \n211: Parity-visible floating-point reductions MUST NOT run in nondeterministic parallel order. If parallel reduction is unavoidable, fix the reduction tree and golden-test it across every supported target.\n212: \n213: Baseline WASM is single-threaded. Promise bridging does not create CPU parallelism.\n214: \n215: ## 8. NAPI-RS EXPORT EXAMPLE\n216: \n217: ```rust\n218: use napi::bindgen_prelude::{Error, Status};\n219: use napi_derive::napi;\n220: \n221: #[napi(object)]\n222: pub struct CandidateDto {\n223:     pub id: String,\n224:     pub score: f64,\n225: }\n226: \n227: #[napi(js_name = \"rankCandidates\")]\n228: pub fn rank_candidates(candidates: Vec<CandidateDto>) -> napi::Result<Vec<CandidateDto>> {\n229:     let mut candidates = candidates;\n230: \n231:     if candidates.iter().any(|candidate| !candidate.score.is_finite()) {\n232:         return Err(Error::new(\n233:             Status::InvalidArg,\n234:             \"NON_FINITE_SCORE: candidate score must be finite\",\n235:         ));\n236:     }\n237: \n238:     candidates.sort_by(|left, right| {\n239:         right\n240:             .score\n241:             .total_cmp(&left.score)\n242:             .then_with(|| left.id.cmp(&right.id))\n243:     });\n244: \n245:     Ok(candidates)\n246: }\n247: ```\n248: \n249: In production, ranking belongs in the pure core and the adapter converts DTOs and errors only. The example shows the JavaScript-visible naming and owned boundary shape.\n250: \n251: ## 9. WASM-BINDGEN EXPORT EXAMPLE\n252: \n253: ```rust\n254: use wasm_bindgen::prelude::*;\n255: \n256: #[wasm_bindgen(js_name = normalizeScore)]\n257: pub fn normalize_score(value: f64) -> Result<f64, JsValue> {\n258:     if !value.is_finite() {\n259:         return Err(JsValue::from_str(\n260:             \"NON_FINITE_SCORE: score must be finite\",\n261:         ));\n262:     }\n263: \n264:     let normalized = (value * 1_000_000.0).round() / 1_000_000.0;\n265:     Ok(if normalized == 0.0 { 0.0 } else { normalized })\n266: }\n267: ```\n268: \n269: The exact rounding implementation and error shape require differential fixtures against the TypeScript oracle before release.\n270: \n271: ## 10. COEXISTENCE AND FALLBACKS\n272: \n273: TypeScript retains fallback selection. Rust adapters expose capability; they do not silently choose themselves.\n274: \n275: ```typescript\n276: const result = flags.nativeRanking && nativeAddon !== null\n277:   ? await nativeAddon.rankCandidates(input)\n278:   : await rankCandidatesTypeScript(input);\n279: ```\n280: \n281: Both paths must emit identical bytes for the supported input domain. A semantic deep-equality test is useful for diagnosis but does not replace the byte comparison.\n282: \n283: ## 11. DIFFERENTIAL TEST CONTRACT\n284: \n285: The release-level assertion is:\n286: \n287: ```rust\n288: fn assert_byte_parity(\n289:     typescript_bytes: &[u8],\n290:     rust_bytes: &[u8],\n291: ) {\n292:     assert_eq!(typescript_bytes, rust_bytes);\n293: }\n294: ```\n295: \n296: Golden fixtures MUST originate from the pinned TypeScript oracle. Rust must not author or automatically accept its own expected output.\n297: \n298: Parity fixtures cover:\n299: \n300: - Six-decimal edge cases\n301: - Positive and negative halfway values\n302: - Negative zero\n303: - Very small and very large finite numbers\n304: - Complete sorting ties\n305: - Identifier alphabet boundaries\n306: - Unicode and UTF-8 preimages\n307: - Optional and omitted fields\n308: - Empty collections\n309: - Map and object ordering\n310: - Error codes and exact messages\n311: - Synchronous throws and Promise rejections\n312: - Native and WASM artifacts\n313: \n314: ## 12. RELATED RESOURCES\n315: \n316: - [quality_standards.md](../quality_standards/overview_and_data_ownership.md) - Ownership, safety, ABI contracts, error translation, concurrency, Cargo, and parity gates\n317: - [quick_reference.md](../quick_reference/overview_and_boundary_template.md) - Copy-paste Rust boundary templates, deterministic recipes, and build commands\n\n(End of file - total 317 lines)\n</content>","metadata":{"preview":"---\ntitle: Rust/TypeScript Interop — Errors, Parity & Related Resources\ndescription: Formatting standards, naming conventions, and TypeScript interoperability rules for Rust files in the OpenCode development environment. — Rust/TypeScript Interop — Errors, Parity & Related Resources.\ntrigger_phrases:\n  - \"rust typescript interop errors parity related resources\"\n  - \"rust interop errors and parity\"\n  - \"rust style guidance\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.0.0.0\n---\n\n# Rust/TypeScript Interop — Errors, Parity & Related Resources\n\nFormatting standards, naming conventions, and TypeScript interoperability rules for Rust files in the OpenCode development environment.\n\n---\n\n## 1. OVERVIEW\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/code-opencode/references/rust/style_guide/interop_errors_and_parity.md","text":"---\ntitle: Rust/TypeScript Interop — Errors, Parity & Related Resources\ndescription: Formatting standards, naming conventions, and TypeScript interoperability rules for Rust files in the OpenCode development environment. — Rust/TypeScript Interop — Errors, Parity & Related Resources.\ntrigger_phrases:\n  - \"rust typescript interop errors parity related resources\"\n  - \"rust interop errors and parity\"\n  - \"rust style guidance\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.0.0.0\n---\n\n# Rust/TypeScript Interop — Errors, Parity & Related Resources\n\nFormatting standards, naming conventions, and TypeScript interoperability rules for Rust files in the OpenCode development environment.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nProvides focused Rust guidance for rust/typescript interop — errors, parity & related resources in the OpenCode development environment.\n\n### When to Use\n\n- Implementing or reviewing Rust code covered by this topic\n- Preserving TypeScript interoperability and deterministic behavior\n- Applying the corresponding Rust standards at an implementation boundary\n\n## 2. ERROR STYLE\n\nCore public operations return domain-specific `Result` values backed by `thiserror`.\n\n```rust\nuse thiserror::Error;\n\n#[derive(Debug, Error)]\npub enum RankingError {\n    #[error(\"candidate identifier must not be empty\")]\n    EmptyIdentifier,\n\n    #[error(\"candidate score must be finite\")]\n    NonFiniteScore,\n\n    #[error(\"candidate limit {limit} exceeds maximum {maximum}\")]\n    LimitExceeded {\n        limit: u32,\n        maximum: u32,\n    },\n}\n```\n\nRules:\n\n- Core errors contain adapter-relevant structured context.\n- Core errors contain no napi-rs, WASM, or Node runtime types.\n- `anyhow` is prohibited in pure-core public APIs and exported functions.\n- `anyhow` MAY be used in sidecar `main`, build tooling, and the outermost non-ABI shell.\n- Every adapter owns one exhaustive mapping from core errors to stable JavaScript errors.\n- Error messages and codes covered by TypeScript contracts are golden-tested.\n- Panic only for an impossible internal invariant, never for recoverable boundary input.\n\n## 3. EXHAUSTIVE ADAPTER ERROR MAPPING\n\n```rust\n#[derive(Debug)]\nstruct JsErrorShape {\n    code: &'static str,\n    message: String,\n}\n\nfn map_ranking_error(error: RankingError) -> JsErrorShape {\n    match error {\n        RankingError::EmptyIdentifier => JsErrorShape {\n            code: \"INVALID_IDENTIFIER\",\n            message: error.to_string(),\n        },\n        RankingError::NonFiniteScore => JsErrorShape {\n            code: \"NON_FINITE_SCORE\",\n            message: error.to_string(),\n        },\n        RankingError::LimitExceeded { .. } => JsErrorShape {\n            code: \"LIMIT_EXCEEDED\",\n            message: error.to_string(),\n        },\n    }\n}\n```\n\nThe adapter must also preserve whether the existing TypeScript operation throws synchronously or rejects a Promise.\n\n## 4. PANIC-FREE BOUNDARY VALIDATION\n\nDo not use:\n\n```rust\nlet score = input.parse::<f64>().unwrap();\nlet first = candidates[0].clone();\nlet ordering = left.score.partial_cmp(&right.score).unwrap();\n```\n\nUse typed failures:\n\n```rust\nuse std::num::ParseFloatError;\n\nfn parse_score(input: &str) -> Result<f64, ParseFloatError> {\n    input.parse::<f64>()\n}\n\nfn first_candidate(candidates: &[String]) -> Option<&str> {\n    candidates.first().map(String::as_str)\n}\n```\n\nJavaScript-controlled data must not reach:\n\n- `unwrap`\n- `expect`\n- Unchecked indexing\n- `panic!`\n- `unreachable!`\n- Assertions used as validation\n- `partial_cmp(...).unwrap()`\n\n## 5. DETERMINISTIC IDENTIFIERS\n\nIdentifier generation preserves the exact TypeScript preimage contract:\n\n- Input fields\n- Field order\n- Separators\n- UTF-8 encoding\n- Hash algorithm\n- Lowercase hexadecimal encoding\n- Truncation length\n\n```rust\nuse sha2::{Digest, Sha256};\n\nfn deterministic_id(namespace: &str, name: &str) -> String {\n    let preimage = format!(\"{namespace}\\0{name}\");\n    let digest = Sha256::digest(preimage.as_bytes());\n    let hexadecimal = format!(\"{digest:x}\");\n    hexadecimal[..24].to_owned()\n}\n```\n\nThis example is correct only if the TypeScript oracle uses the same fields, NUL delimiter, UTF-8 bytes, SHA-256, lowercase hexadecimal output, and 24-character truncation. Never infer those details from a semantically similar implementation.\n\n## 6. STABLE SERIALIZATION\n\nDo not assume `serde_json` reproduces JavaScript byte output automatically.\n\nPotential differences include:\n\n- Number spelling\n- Negative zero\n- Exponent notation\n- Omitted versus `null` fields\n- Escaping\n- Key order\n- Non-finite values\n- Map iteration order\n\nUse passive DTOs and canonical maps:\n\n```rust\nuse std::collections::BTreeMap;\n\nuse serde::Serialize;\n\n#[derive(Debug, Serialize)]\n#[serde(rename_all = \"camelCase\")]\nstruct SearchResponse {\n    results: Vec<SearchResult>,\n    metadata: BTreeMap<String, String>,\n}\n\n#[derive(Debug, Serialize)]\nstruct SearchResult {\n    id: String,\n    score: f64,\n}\n```\n\nByte-for-byte fixtures remain required even when the Rust structure appears equivalent to the TypeScript object.\n\n## 7. ASYNC AND THREADING\n\nKeep parsing, scoring, ranking, hashing, canonicalization, and serialization preparation synchronous in the core.\n\nUse napi-rs `AsyncTask` only for measured CPU or blocking work that would materially block Node.\n\nBefore worker execution:\n\n- Convert JavaScript values into owned DTOs.\n- Copy JavaScript-owned buffers.\n- Validate cheap structural constraints.\n- Do not retain `Env`, `JsValue`, or thread-affine handles.\n\nAfter worker execution:\n\n- Reorder results by deterministic sequence keys.\n- Canonicalize output synchronously.\n- Map typed errors on the JavaScript thread.\n\nUse Tokio only for genuine Rust-owned asynchronous I/O. Use Rayon only after benchmark evidence demonstrates a useful batch-size threshold.\n\nParity-visible floating-point reductions MUST NOT run in nondeterministic parallel order. If parallel reduction is unavoidable, fix the reduction tree and golden-test it across every supported target.\n\nBaseline WASM is single-threaded. Promise bridging does not create CPU parallelism.\n\n## 8. NAPI-RS EXPORT EXAMPLE\n\n```rust\nuse napi::bindgen_prelude::{Error, Status};\nuse napi_derive::napi;\n\n#[napi(object)]\npub struct CandidateDto {\n    pub id: String,\n    pub score: f64,\n}\n\n#[napi(js_name = \"rankCandidates\")]\npub fn rank_candidates(candidates: Vec<CandidateDto>) -> napi::Result<Vec<CandidateDto>> {\n    let mut candidates = candidates;\n\n    if candidates.iter().any(|candidate| !candidate.score.is_finite()) {\n        return Err(Error::new(\n            Status::InvalidArg,\n            \"NON_FINITE_SCORE: candidate score must be finite\",\n        ));\n    }\n\n    candidates.sort_by(|left, right| {\n        right\n            .score\n            .total_cmp(&left.score)\n            .then_with(|| left.id.cmp(&right.id))\n    });\n\n    Ok(candidates)\n}\n```\n\nIn production, ranking belongs in the pure core and the adapter converts DTOs and errors only. The example shows the JavaScript-visible naming and owned boundary shape.\n\n## 9. WASM-BINDGEN EXPORT EXAMPLE\n\n```rust\nuse wasm_bindgen::prelude::*;\n\n#[wasm_bindgen(js_name = normalizeScore)]\npub fn normalize_score(value: f64) -> Result<f64, JsValue> {\n    if !value.is_finite() {\n        return Err(JsValue::from_str(\n            \"NON_FINITE_SCORE: score must be finite\",\n        ));\n    }\n\n    let normalized = (value * 1_000_000.0).round() / 1_000_000.0;\n    Ok(if normalized == 0.0 { 0.0 } else { normalized })\n}\n```\n\nThe exact rounding implementation and error shape require differential fixtures against the TypeScript oracle before release.\n\n## 10. COEXISTENCE AND FALLBACKS\n\nTypeScript retains fallback selection. Rust adapters expose capability; they do not silently choose themselves.\n\n```typescript\nconst result = flags.nativeRanking && nativeAddon !== null\n  ? await nativeAddon.rankCandidates(input)\n  : await rankCandidatesTypeScript(input);\n```\n\nBoth paths must emit identical bytes for the supported input domain. A semantic deep-equality test is useful for diagnosis but does not replace the byte comparison.\n\n## 11. DIFFERENTIAL TEST CONTRACT\n\nThe release-level assertion is:\n\n```rust\nfn assert_byte_parity(\n    typescript_bytes: &[u8],\n    rust_bytes: &[u8],\n) {\n    assert_eq!(typescript_bytes, rust_bytes);\n}\n```\n\nGolden fixtures MUST originate from the pinned TypeScript oracle. Rust must not author or automatically accept its own expected output.\n\nParity fixtures cover:\n\n- Six-decimal edge cases\n- Positive and negative halfway values\n- Negative zero\n- Very small and very large finite numbers\n- Complete sorting ties\n- Identifier alphabet boundaries\n- Unicode and UTF-8 preimages\n- Optional and omitted fields\n- Empty collections\n- Map and object ordering\n- Error codes and exact messages\n- Synchronous throws and Promise rejections\n- Native and WASM artifacts\n\n## 12. RELATED RESOURCES\n\n- [quality_standards.md](../quality_standards/overview_and_data_ownership.md) - Ownership, safety, ABI contracts, error translation, concurrency, Cargo, and parity gates\n- [quick_reference.md](../quick_reference/overview_and_boundary_template.md) - Copy-paste Rust boundary templates, deterministic recipes, and build commands","lineStart":1,"lineEnd":317,"totalLines":317,"truncated":false}},"title":".opencode/skills/sk-code/code-opencode/references/rust/style_guide/interop_errors_and_parity.md","time":{"start":1783921310364,"end":1783921310405}},"metadata":{"openai":{"itemId":"fc_03b49908c9a32738016a547a9e0e908191b8b4ac22a56fa0c4"}},"id":"prt_f59fefa97001bQkY3op75mSi3C","sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","messageID":"msg_f59fec928001cz11FYpcd93kU5"}}
{"type":"tool_use","timestamp":1783921310409,"sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","part":{"type":"tool","tool":"read","callID":"call_oWPQ5VgT0wKgtb3SuLIvgrry","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/code-webflow/references/implementation/third_party_integrations/overview_hls_and_lenis.md","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/code-webflow/references/implementation/third_party_integrations/overview_hls_and_lenis.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Third-Party Library Integrations\n3: description: Reference guide for integrating external JavaScript libraries in Webflow projects, with production-tested patterns.\n4: trigger_phrases:\n5:   - \"webflow third party libraries\"\n6:   - \"hls js video streaming\"\n7:   - \"external library integration\"\n8:   - \"library loading pattern webflow\"\n9: importance_tier: normal\n10: contextType: implementation\n11: version: 3.5.0.4\n12: ---\n13: \n14: # Third-Party Library Integrations\n15: \n16: Reference guide for integrating external JavaScript libraries in Webflow projects, with production-tested patterns following code quality standards.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: Entry point for integrating external JavaScript libraries into Webflow: the shared integration principles and script-loading pattern, plus concrete setups for HLS.js (video streaming) and Lenis (smooth scroll).\n25: \n26: ### When to Use\n27: - Integrating new third-party libraries\n28: - Managing dependencies (CDN, versions)\n29: - Handling external script loading\n30: \n31: ### Integration Principles\n32: \n33: 1. **CDN-first loading** - Use jsDelivr or unpkg for reliable delivery\n34: 2. **Version pinning** - Always pin to specific versions for stability\n35: 3. **Feature detection** - Check library availability before use\n36: 4. **Graceful fallbacks** - Handle missing/failed libraries gracefully\n37: 5. **Memory management** - Proper cleanup to prevent leaks\n38: \n39: ### Loading Pattern\n40: \n41: ```javascript\n42: const LIBRARY_CDN_URL = 'https://cdn.jsdelivr.net/npm/library@{version}';\n43: \n44: async function load_library() {\n45:   if (typeof window.Library !== 'undefined') {\n46:     return true;\n47:   }\n48: \n49:   return new Promise((resolve) => {\n50:     const script = document.createElement('script');\n51:     script.src = LIBRARY_CDN_URL;\n52:     script.async = true;\n53:     script.onload = () => resolve(true);\n54:     script.onerror = () => resolve(false);\n55:     document.head.appendChild(script);\n56:   });\n57: }\n58: ```\n59: \n60: ---\n61: \n62: ## 2. HLS.JS (VIDEO STREAMING)\n63: \n64: HTTP Live Streaming library for adaptive video playback in non-Safari browsers.\n65: \n66: ### CDN URL\n67: \n68: ```html\n69: <!-- Preload for critical video pages -->\n70: <link rel=\"preload\" href=\"https://cdn.jsdelivr.net/npm/hls.js@{version}\" as=\"script\">\n71: \n72: <!-- Load with defer -->\n73: <script src=\"https://cdn.jsdelivr.net/npm/hls.js@{version}\" defer></script>\n74: ```\n75: \n76: ### Feature Detection\n77: \n78: ```javascript\n79: const test_video = document.createElement('video');\n80: const safari_native = !!test_video.canPlayType('application/vnd.apple.mpegurl');\n\n(Showing lines 1-80 of 215. Use offset=81 to continue.)\n</content>","metadata":{"preview":"---\ntitle: Third-Party Library Integrations\ndescription: Reference guide for integrating external JavaScript libraries in Webflow projects, with production-tested patterns.\ntrigger_phrases:\n  - \"webflow third party libraries\"\n  - \"hls js video streaming\"\n  - \"external library integration\"\n  - \"library loading pattern webflow\"\nimportance_tier: normal\ncontextType: implementation\nversion: 3.5.0.4\n---\n\n# Third-Party Library Integrations\n\nReference guide for integrating external JavaScript libraries in Webflow projects, with production-tested patterns following code quality standards.\n\n---\n\n## 1. OVERVIEW","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/code-webflow/references/implementation/third_party_integrations/overview_hls_and_lenis.md","text":"---\ntitle: Third-Party Library Integrations\ndescription: Reference guide for integrating external JavaScript libraries in Webflow projects, with production-tested patterns.\ntrigger_phrases:\n  - \"webflow third party libraries\"\n  - \"hls js video streaming\"\n  - \"external library integration\"\n  - \"library loading pattern webflow\"\nimportance_tier: normal\ncontextType: implementation\nversion: 3.5.0.4\n---\n\n# Third-Party Library Integrations\n\nReference guide for integrating external JavaScript libraries in Webflow projects, with production-tested patterns following code quality standards.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nEntry point for integrating external JavaScript libraries into Webflow: the shared integration principles and script-loading pattern, plus concrete setups for HLS.js (video streaming) and Lenis (smooth scroll).\n\n### When to Use\n- Integrating new third-party libraries\n- Managing dependencies (CDN, versions)\n- Handling external script loading\n\n### Integration Principles\n\n1. **CDN-first loading** - Use jsDelivr or unpkg for reliable delivery\n2. **Version pinning** - Always pin to specific versions for stability\n3. **Feature detection** - Check library availability before use\n4. **Graceful fallbacks** - Handle missing/failed libraries gracefully\n5. **Memory management** - Proper cleanup to prevent leaks\n\n### Loading Pattern\n\n```javascript\nconst LIBRARY_CDN_URL = 'https://cdn.jsdelivr.net/npm/library@{version}';\n\nasync function load_library() {\n  if (typeof window.Library !== 'undefined') {\n    return true;\n  }\n\n  return new Promise((resolve) => {\n    const script = document.createElement('script');\n    script.src = LIBRARY_CDN_URL;\n    script.async = true;\n    script.onload = () => resolve(true);\n    script.onerror = () => resolve(false);\n    document.head.appendChild(script);\n  });\n}\n```\n\n---\n\n## 2. HLS.JS (VIDEO STREAMING)\n\nHTTP Live Streaming library for adaptive video playback in non-Safari browsers.\n\n### CDN URL\n\n```html\n<!-- Preload for critical video pages -->\n<link rel=\"preload\" href=\"https://cdn.jsdelivr.net/npm/hls.js@{version}\" as=\"script\">\n\n<!-- Load with defer -->\n<script src=\"https://cdn.jsdelivr.net/npm/hls.js@{version}\" defer></script>\n```\n\n### Feature Detection\n\n```javascript\nconst test_video = document.createElement('video');\nconst safari_native = !!test_video.canPlayType('application/vnd.apple.mpegurl');","lineStart":1,"lineEnd":80,"totalLines":215,"truncated":true}},"title":".opencode/skills/sk-code/code-webflow/references/implementation/third_party_integrations/overview_hls_and_lenis.md","time":{"start":1783921310370,"end":1783921310407}},"metadata":{"openai":{"itemId":"fc_03b49908c9a32738016a547a9e0e9881919b40d94073d14c2e"}},"id":"prt_f59fefaa00011NCvPZIOj5CfZe","sessionID":"ses_0a6050609ffeLmwfdMHnBWCS8d","messageID":"msg_f59fec928001cz11FYpcd93kU5"}}
