{
  "color": {
    "void": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Void — Page canvas, nav background, card surfaces, icon fills — the infinite black that swallows all non-essential content"
    },
    "graphite": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Graphite — Elevated card surfaces one step above the void — large feature cards and modal containers"
    },
    "obsidian": {
      "$value": "#171717",
      "$type": "color",
      "$description": "Obsidian — Mid-tier surface for buttons, secondary cards, UI fills — separates interactive elements from the canvas"
    },
    "slate": {
      "$value": "#242424",
      "$type": "color",
      "$description": "Slate — Hover states, input fields, and elevated panels — the brightest neutral before reaching text territory"
    },
    "ash": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Ash — Deep fill for inactive backgrounds and structural elements"
    },
    "smoke": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Smoke — Disabled text, low-emphasis body copy, tertiary strokes"
    },
    "fog": {
      "$value": "#888888",
      "$type": "color",
      "$description": "Fog — Borders, dividers, icon strokes — the structural outline color"
    },
    "mist": {
      "$value": "#999999",
      "$type": "color",
      "$description": "Mist — Secondary body text, captions, metadata — readable but never competing with headlines"
    },
    "pearl": {
      "$value": "#cccccc",
      "$type": "color",
      "$description": "Pearl — Light body text for contrast pairs on dark surfaces"
    },
    "bone": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Bone — Primary headings, body text on dark canvas, button backgrounds — the sole light source"
    },
    "electric-blue": {
      "$value": "#0099ff",
      "$type": "color",
      "$description": "Electric Blue — Accent borders, glows, link underlines, badge outlines, active states — the only chromatic punctuation in the entire system"
    },
    "deep-current": {
      "$value": "#00406b",
      "$type": "color",
      "$description": "Deep Current — Dark accent fills and box-shadows paired with Electric Blue — the saturated shadow underneath blue glows"
    },
    "midnight-tide": {
      "$value": "#002238",
      "$type": "color",
      "$description": "Midnight Tide — Subtle blue-tinted surface washes and shadow tints — keeps the blue accent feeling atmospheric even in flat fills"
    },
    "signal-green": {
      "$value": "#4cd963",
      "$type": "color",
      "$description": "Signal Green — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    },
    "vivid-violet": {
      "$value": "#0066ff",
      "$type": "color",
      "$description": "Vivid Violet — Primary action button fill — the only place a solid chromatic button background appears in the interface"
    },
    "alert-red": {
      "$value": "#ff0022",
      "$type": "color",
      "$description": "Alert Red — Red wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    },
    "amber": {
      "$value": "#ffbb00",
      "$type": "color",
      "$description": "Amber — Yellow wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    },
    "lime": {
      "$value": "#cbff00",
      "$type": "color",
      "$description": "Lime — CSS token hint — secondary accent available in the design system but not actively surfaced in core pages"
    }
  },
  "font": {
    "sans-serif": {
      "$value": "sans-serif",
      "$type": "fontFamily",
      "$description": "sans-serif — detected in extracted data but not described by AI"
    },
    "gt-walsheim": {
      "$value": "GT Walsheim",
      "$type": "fontFamily",
      "$description": "Display and heading type — the signature typeface. Aggressively compressed with line-height 0.8–1.1 and tracking -0.04em to -0.05em at 44–68px. This isn't decoration; GT Walsheim's geometric warmth at tight metrics creates the system's voice — confident, compact, slightly futuristic. Substitute: Inter Tight or Space Grotesk Bold for similar geometric presence."
    },
    "inter-variable": {
      "$value": "Inter Variable",
      "$type": "fontFamily",
      "$description": "Body, nav, and secondary headings — the workhorse. Inter Variable's variable axis allows smooth weight interpolation. Tracking tightens as size grows: -0.001em at 18px to -0.027em at 22px. The variable version enables the site's fluid micro-animations. Substitute: Inter (Google) is a near-identical fallback."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Static Inter for UI controls, buttons (500/600), and uppercase labels (700 at 9px). Used where variable weight isn't needed. The 20px/600/lh=1.2 heading style with -0.04em tracking provides a compact sub-heading tier below GT Walsheim displays."
    },
    "input-mono": {
      "$value": "Input Mono",
      "$type": "fontFamily",
      "$description": "Code snippets, monospace tags, and technical metadata — appears in product UI screenshots and code-context moments. The mono voice contrasts the geometric sans-serif to signal 'this is structural, not prose'."
    },
    "jetbrains-mono": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily",
      "$description": "Secondary monospace for code blocks — shares the developer-tool vocabulary with Input Mono but used in longer-form code contexts."
    },
    "inter-medium": {
      "$value": "Inter Medium",
      "$type": "fontFamily",
      "$description": "Inter Medium — detected in extracted data but not described by AI"
    }
  },
