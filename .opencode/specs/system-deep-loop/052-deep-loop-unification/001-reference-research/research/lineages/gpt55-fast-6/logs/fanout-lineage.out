{"type":"tool_use","timestamp":1783487640080,"sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","part":{"type":"tool","tool":"read","callID":"call_qTFarlQtUIvoJ6rOqkOw0xPl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep-Loop Script CLI Guards                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: 'use strict';\n5: \n6: // ─────────────────────────────────────────────────────────────────────────────\n7: // 1. IMPORTS\n8: // ─────────────────────────────────────────────────────────────────────────────\n9: \n10: const fs = require('node:fs');\n11: const path = require('node:path');\n12: const { randomUUID } = require('node:crypto');\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 2. CONSTANTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: let signalHandlersInstalled = false;\n19: const DEFAULT_WRITER_LOCK_MAX_WAIT_MS = 1_000;\n20: const DEFAULT_WRITER_LOCK_RETRY_INTERVAL_MS = 25;\n21: // A live holder that has held the lock longer than this is treated as stale\n22: // (orphaned by an OOM/SIGKILL that left the file but whose pid was recycled, or\n23: // a wedged process). Generous so a legitimately slow write is never reclaimed.\n24: const DEFAULT_WRITER_LOCK_MAX_HOLD_MS = 60_000;\n25: const LINEAGE_FAILURE_CLASSES = Object.freeze({\n26:   TIMEOUT: 'timeout',\n27:   EXIT: 'exit',\n28:   SALVAGE_MISS: 'salvage_miss',\n29:   ARTIFACT_MISS: 'artifact_miss',\n30: });\n31: const LINEAGE_RETRY_VERDICTS = Object.freeze({\n32:   TRANSIENT: 'transient',\n33:   FATAL: 'fatal',\n34: });\n35: \n36: // ─────────────────────────────────────────────────────────────────────────────\n37: // 3. HELPERS\n38: // ─────────────────────────────────────────────────────────────────────────────\n39: \n40: function findRepoRoot(startDir) {\n41:   let current = path.resolve(startDir);\n42:   let opencodeMatch = null;\n43:   while (current !== path.dirname(current)) {\n44:     // `.git` is the unambiguous repo-root marker; prefer it so nested `.opencode`\n45:     // sandbox/residue dirs under skills/** cannot short-circuit detection.\n46:     if (fs.existsSync(path.join(current, '.git'))) {\n47:       return current;\n48:     }\n49:     if (opencodeMatch === null && fs.existsSync(path.join(current, '.opencode'))) {\n50:       opencodeMatch = current;\n51:     }\n52:     current = path.dirname(current);\n53:   }\n54:   return opencodeMatch || path.resolve(startDir, '..', '..', '..', '..', '..');\n55: }\n56: \n57: const REPO_ROOT = findRepoRoot(__dirname);\n58: \n59: function hasTraversalSegment(value) {\n60:   return value.split(/[\\\\/]+/).some((segment) => segment === '..');\n61: }\n62: \n63: function isInsideRepo(resolvedPath) {\n64:   const relative = path.relative(REPO_ROOT, resolvedPath);\n65:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n66: }\n67: \n68: // ─────────────────────────────────────────────────────────────────────────────\n69: // 4. CORE LOGIC\n70: // ─────────────────────────────────────────────────────────────────────────────\n71: \n72: /**\n73:  * Validate a namespace-scoped value (specFolder, sessionId) for safety.\n74:  * Rejects null bytes, `..` path traversal segments, and absolute paths\n75:  * that escape the repository root.\n76:  *\n77:  * @param {string} value - The value to validate.\n78:  * @param {string} key - Label for error messages (e.g. 'specFolder').\n79:  * @param {Function} makeInputError - Factory that creates an InputValidation\n80:  *   error from a message string.\n81:  * @returns {string} The validated value, unchanged when valid.\n82:  * @throws {Error} With code INPUT_VALIDATION on failure.\n83:  */\n84: function validateNamespaceValue(value, key, makeInputError) {\n85:   if (value.includes('\\0')) {\n86:     throw makeInputError(`${key} must not contain null bytes`);\n87:   }\n88:   if (hasTraversalSegment(value)) {\n89:     throw makeInputError(`${key} must not contain '..' path segments`);\n90:   }\n91:   if (path.isAbsolute(value) && !isInsideRepo(path.resolve(value))) {\n92:     throw makeInputError(`${key} absolute path must stay inside the repository root`);\n93:   }\n94:   return value;\n95: }\n96: \n97: /**\n98:  * Install one-shot signal handlers (SIGINT, SIGTERM) that run a cleanup\n99:  * callback before exiting. Idempotent — subsequent calls are no-ops.\n100:  *\n101:  * @param {Function} cleanup - Cleanup callback invoked before process exit.\n102:  */\n103: function installSignalHandlers(cleanup) {\n104:   if (signalHandlersInstalled) return;\n105:   signalHandlersInstalled = true;\n106: \n107:   for (const signal of ['SIGINT', 'SIGTERM']) {\n108:     process.once(signal, () => {\n109:       try {\n110:         cleanup();\n111:       } finally {\n112:         process.exit(signal === 'SIGINT' ? 130 : 143);\n113:       }\n114:     });\n115:   }\n116: }\n117: \n118: /**\n119:  * Map an error to a structured exit code for CLI scripts.\n120:  *\n121:  * @param {Error|Object} err - An error object, optionally carrying a `code`\n122:  *   property.\n123:  * @returns {number} Exit code: 1=script error, 2=DB/permissions error,\n124:  *   3=input validation error.\n125:  */\n126: function classifyExitCode(err) {\n127:   const code = err && typeof err === 'object' && 'code' in err ? err.code : undefined;\n128:   if (code === 'INPUT_VALIDATION') return 3;\n129:   if (\n130:     code === 'DB_ERROR'\n131:     || code === 'SQLITE_ERROR'\n132:     || code === 'SQLITE_BUSY'\n133:     || code === 'SQLITE_CANTOPEN'\n134:     || code === 'EACCES'\n135:     || code === 'EPERM'\n136:     || code === 'ENOTDIR'\n137:   ) {\n138:     return 2;\n139:   }\n140:   return 1;\n141: }\n142: \n143: function readFiniteInteger(value) {\n144:   const number = Number(value);\n145:   return Number.isFinite(number) ? Math.trunc(number) : null;\n146: }\n147: \n148: function readNonNegativeInteger(value) {\n149:   const number = readFiniteInteger(value);\n150:   return number !== null && number >= 0 ? number : null;\n151: }\n152: \n153: function normalizeSalvageSummary(value) {\n154:   if (!value || typeof value !== 'object' || Array.isArray(value)) {\n155:     return null;\n156:   }\n157:   return {\n158:     salvaged: readNonNegativeInteger(value.salvaged) ?? 0,\n159:     failed: readNonNegativeInteger(value.failed) ?? 0,\n160:   };\n161: }\n162: \n163: /**\n164:  * Classify a lineage failure using only bounded process and salvage signals.\n165:  *\n166:  * @param {Error|Object} error - Error object from a failed lineage worker.\n167:  * @returns {{failure_class:string,retry_verdict:string,retryable:boolean,exit_code:number|null,timed_out:boolean,salvage:{salvaged:number,failed:number}|null}}\n168:  */\n169: function classifyLineageFailure(error) {\n170:   const timedOut = Boolean(error && typeof error === 'object' && error.timedOut === true);\n171:   const exitCode = error && typeof error === 'object' ? readFiniteInteger(error.exitCode) : null;\n172:   const salvage = error && typeof error === 'object' ? normalizeSalvageSummary(error.salvage) : null;\n173: \n174:   let failureClass = LINEAGE_FAILURE_CLASSES.EXIT;\n175:   if (timedOut) {\n176:     failureClass = LINEAGE_FAILURE_CLASSES.TIMEOUT;\n177:   } else if (salvage && salvage.failed > 0 && salvage.salvaged === 0) {\n178:     failureClass = LINEAGE_FAILURE_CLASSES.SALVAGE_MISS;\n179:   } else if (salvage && salvage.failed > 0) {\n180:     // Mixed salvage: at least one iteration was recovered but some artifact/iteration\n181:     // markdown was unrecoverable or a top-level artifact went missing. This is a\n182:     // transient artifact-recovery gap, not a fatal exit, so it should be retried rather\n183:     // than consumed as terminal. Without this branch a { salvaged: >0, failed: >0 }\n184:     // lineage fell through to EXIT (fatal) and was never retried.\n185:     failureClass = LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n186:   }\n187: \n188:   const retryable =\n189:     failureClass === LINEAGE_FAILURE_CLASSES.TIMEOUT\n190:     || failureClass === LINEAGE_FAILURE_CLASSES.SALVAGE_MISS\n191:     || failureClass === LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n192:   return {\n193:     failure_class: failureClass,\n194:     retry_verdict: retryable ? LINEAGE_RETRY_VERDICTS.TRANSIENT : LINEAGE_RETRY_VERDICTS.FATAL,\n195:     retryable,\n196:     exit_code: exitCode,\n197:     timed_out: timedOut,\n198:     salvage,\n199:   };\n200: }\n201: \n202: /**\n203:  * Throw a synthetic fault when the DEEP_LOOP_TEST_FAULT environment\n204:  * variable is set. Used by contract tests to verify that scripts\n205:  * handle injected DB and script-level errors correctly.\n206:  *\n207:  * @throws {Error} With code DB_ERROR or generic script error.\n208:  */\n209: function maybeThrowTestFault() {\n210:   if (process.env.DEEP_LOOP_TEST_FAULT === 'db') {\n211:     const err = new Error('Injected DB fault for deep-loop script contract tests');\n212:     err.code = 'DB_ERROR';\n213:     throw err;\n214:   }\n215:   if (process.env.DEEP_LOOP_TEST_FAULT === 'script') {\n216:     throw new Error('Injected script fault for deep-loop script contract tests');\n217:   }\n218: }\n219: \n220: /**\n\n(Showing lines 1-220 of 517. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Script CLI Guards                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { randomUUID } = require('node:crypto');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nlet signalHandlersInstalled = false;\nconst DEFAULT_WRITER_LOCK_MAX_WAIT_MS = 1_000;\nconst DEFAULT_WRITER_LOCK_RETRY_INTERVAL_MS = 25;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Script CLI Guards                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { randomUUID } = require('node:crypto');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nlet signalHandlersInstalled = false;\nconst DEFAULT_WRITER_LOCK_MAX_WAIT_MS = 1_000;\nconst DEFAULT_WRITER_LOCK_RETRY_INTERVAL_MS = 25;\n// A live holder that has held the lock longer than this is treated as stale\n// (orphaned by an OOM/SIGKILL that left the file but whose pid was recycled, or\n// a wedged process). Generous so a legitimately slow write is never reclaimed.\nconst DEFAULT_WRITER_LOCK_MAX_HOLD_MS = 60_000;\nconst LINEAGE_FAILURE_CLASSES = Object.freeze({\n  TIMEOUT: 'timeout',\n  EXIT: 'exit',\n  SALVAGE_MISS: 'salvage_miss',\n  ARTIFACT_MISS: 'artifact_miss',\n});\nconst LINEAGE_RETRY_VERDICTS = Object.freeze({\n  TRANSIENT: 'transient',\n  FATAL: 'fatal',\n});\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction findRepoRoot(startDir) {\n  let current = path.resolve(startDir);\n  let opencodeMatch = null;\n  while (current !== path.dirname(current)) {\n    // `.git` is the unambiguous repo-root marker; prefer it so nested `.opencode`\n    // sandbox/residue dirs under skills/** cannot short-circuit detection.\n    if (fs.existsSync(path.join(current, '.git'))) {\n      return current;\n    }\n    if (opencodeMatch === null && fs.existsSync(path.join(current, '.opencode'))) {\n      opencodeMatch = current;\n    }\n    current = path.dirname(current);\n  }\n  return opencodeMatch || path.resolve(startDir, '..', '..', '..', '..', '..');\n}\n\nconst REPO_ROOT = findRepoRoot(__dirname);\n\nfunction hasTraversalSegment(value) {\n  return value.split(/[\\\\/]+/).some((segment) => segment === '..');\n}\n\nfunction isInsideRepo(resolvedPath) {\n  const relative = path.relative(REPO_ROOT, resolvedPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Validate a namespace-scoped value (specFolder, sessionId) for safety.\n * Rejects null bytes, `..` path traversal segments, and absolute paths\n * that escape the repository root.\n *\n * @param {string} value - The value to validate.\n * @param {string} key - Label for error messages (e.g. 'specFolder').\n * @param {Function} makeInputError - Factory that creates an InputValidation\n *   error from a message string.\n * @returns {string} The validated value, unchanged when valid.\n * @throws {Error} With code INPUT_VALIDATION on failure.\n */\nfunction validateNamespaceValue(value, key, makeInputError) {\n  if (value.includes('\\0')) {\n    throw makeInputError(`${key} must not contain null bytes`);\n  }\n  if (hasTraversalSegment(value)) {\n    throw makeInputError(`${key} must not contain '..' path segments`);\n  }\n  if (path.isAbsolute(value) && !isInsideRepo(path.resolve(value))) {\n    throw makeInputError(`${key} absolute path must stay inside the repository root`);\n  }\n  return value;\n}\n\n/**\n * Install one-shot signal handlers (SIGINT, SIGTERM) that run a cleanup\n * callback before exiting. Idempotent — subsequent calls are no-ops.\n *\n * @param {Function} cleanup - Cleanup callback invoked before process exit.\n */\nfunction installSignalHandlers(cleanup) {\n  if (signalHandlersInstalled) return;\n  signalHandlersInstalled = true;\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      try {\n        cleanup();\n      } finally {\n        process.exit(signal === 'SIGINT' ? 130 : 143);\n      }\n    });\n  }\n}\n\n/**\n * Map an error to a structured exit code for CLI scripts.\n *\n * @param {Error|Object} err - An error object, optionally carrying a `code`\n *   property.\n * @returns {number} Exit code: 1=script error, 2=DB/permissions error,\n *   3=input validation error.\n */\nfunction classifyExitCode(err) {\n  const code = err && typeof err === 'object' && 'code' in err ? err.code : undefined;\n  if (code === 'INPUT_VALIDATION') return 3;\n  if (\n    code === 'DB_ERROR'\n    || code === 'SQLITE_ERROR'\n    || code === 'SQLITE_BUSY'\n    || code === 'SQLITE_CANTOPEN'\n    || code === 'EACCES'\n    || code === 'EPERM'\n    || code === 'ENOTDIR'\n  ) {\n    return 2;\n  }\n  return 1;\n}\n\nfunction readFiniteInteger(value) {\n  const number = Number(value);\n  return Number.isFinite(number) ? Math.trunc(number) : null;\n}\n\nfunction readNonNegativeInteger(value) {\n  const number = readFiniteInteger(value);\n  return number !== null && number >= 0 ? number : null;\n}\n\nfunction normalizeSalvageSummary(value) {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) {\n    return null;\n  }\n  return {\n    salvaged: readNonNegativeInteger(value.salvaged) ?? 0,\n    failed: readNonNegativeInteger(value.failed) ?? 0,\n  };\n}\n\n/**\n * Classify a lineage failure using only bounded process and salvage signals.\n *\n * @param {Error|Object} error - Error object from a failed lineage worker.\n * @returns {{failure_class:string,retry_verdict:string,retryable:boolean,exit_code:number|null,timed_out:boolean,salvage:{salvaged:number,failed:number}|null}}\n */\nfunction classifyLineageFailure(error) {\n  const timedOut = Boolean(error && typeof error === 'object' && error.timedOut === true);\n  const exitCode = error && typeof error === 'object' ? readFiniteInteger(error.exitCode) : null;\n  const salvage = error && typeof error === 'object' ? normalizeSalvageSummary(error.salvage) : null;\n\n  let failureClass = LINEAGE_FAILURE_CLASSES.EXIT;\n  if (timedOut) {\n    failureClass = LINEAGE_FAILURE_CLASSES.TIMEOUT;\n  } else if (salvage && salvage.failed > 0 && salvage.salvaged === 0) {\n    failureClass = LINEAGE_FAILURE_CLASSES.SALVAGE_MISS;\n  } else if (salvage && salvage.failed > 0) {\n    // Mixed salvage: at least one iteration was recovered but some artifact/iteration\n    // markdown was unrecoverable or a top-level artifact went missing. This is a\n    // transient artifact-recovery gap, not a fatal exit, so it should be retried rather\n    // than consumed as terminal. Without this branch a { salvaged: >0, failed: >0 }\n    // lineage fell through to EXIT (fatal) and was never retried.\n    failureClass = LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n  }\n\n  const retryable =\n    failureClass === LINEAGE_FAILURE_CLASSES.TIMEOUT\n    || failureClass === LINEAGE_FAILURE_CLASSES.SALVAGE_MISS\n    || failureClass === LINEAGE_FAILURE_CLASSES.ARTIFACT_MISS;\n  return {\n    failure_class: failureClass,\n    retry_verdict: retryable ? LINEAGE_RETRY_VERDICTS.TRANSIENT : LINEAGE_RETRY_VERDICTS.FATAL,\n    retryable,\n    exit_code: exitCode,\n    timed_out: timedOut,\n    salvage,\n  };\n}\n\n/**\n * Throw a synthetic fault when the DEEP_LOOP_TEST_FAULT environment\n * variable is set. Used by contract tests to verify that scripts\n * handle injected DB and script-level errors correctly.\n *\n * @throws {Error} With code DB_ERROR or generic script error.\n */\nfunction maybeThrowTestFault() {\n  if (process.env.DEEP_LOOP_TEST_FAULT === 'db') {\n    const err = new Error('Injected DB fault for deep-loop script contract tests');\n    err.code = 'DB_ERROR';\n    throw err;\n  }\n  if (process.env.DEEP_LOOP_TEST_FAULT === 'script') {\n    throw new Error('Injected script fault for deep-loop script contract tests');\n  }\n}\n\n/**","lineStart":1,"lineEnd":220,"totalLines":517,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/lib/cli-guards.cjs","time":{"start":1783487640074,"end":1783487640079}},"metadata":{"openai":{"itemId":"fc_0a6e9db9b8252491016a4ddc970f148191b1b32ba3d7ee0fb6"}},"id":"prt_f4025ae20001Nn4CkAGetY0SVd","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f4025a457001ujqQZ0Ma7lSOeu"}}
