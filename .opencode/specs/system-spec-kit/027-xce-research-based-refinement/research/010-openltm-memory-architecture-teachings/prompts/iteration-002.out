{"type":"tool_use","timestamp":1780925309082,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_Q6dhBYhOG3S4dXnxtwGgZ1Pc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","offset":180,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts</path>\n<type>file</type>\n<content>\n180:   const results: MemoryWithRelations[\"relations\"] = [];\n181: \n182:   for (const r of outgoing) {\n183:     const mem = db.query<Memory, [number]>(`SELECT * FROM memories WHERE id=?`).get(r.target_memory_id);\n184:     if (mem) results.push({ memory: mem, relationship_type: r.relationship_type as RelationshipType, direction: \"outgoing\" });\n185:   }\n186:   for (const r of incoming) {\n187:     const mem = db.query<Memory, [number]>(`SELECT * FROM memories WHERE id=?`).get(r.source_memory_id);\n188:     if (mem) results.push({ memory: mem, relationship_type: r.relationship_type as RelationshipType, direction: \"incoming\" });\n189:   }\n190: \n191:   return results;\n192: }\n193: \n194: function enrichMemory(db: Database, mem: Memory): MemoryWithRelations {\n195:   return { ...mem, tags: getTagsForMemory(db, mem.id), relations: getRelationsForMemory(db, mem.id) };\n196: }\n197: \n198: // --- Decay / relevance scoring ---\n199: \n200: /** Half-life in days by importance level. Infinity = never decays. */\n201: const HALF_LIVES: Record<number, number> = {\n202:   5: Infinity,\n203:   4: 180,\n204:   3: 90,\n205:   2: 30,\n206:   1: 14,\n207: };\n208: \n209: /** Memories below this score are soft-deprecated (not deleted). */\n210: const DEPRECATION_THRESHOLD = 0.25;\n211: \n212: /**\n213:  * Compute effective relevance score.\n214:  * score = importance × confidence × decay\n215:  * decay = 0.5 ^ (days_since / half_life)  (1.0 for importance=5)\n216:  */\n217: export function computeDecayScore(memory: Memory): number {\n218:   const halfLife = HALF_LIVES[memory.importance] ?? 90;\n219:   if (halfLife === Infinity) {\n220:     return memory.importance * memory.confidence;\n221:   }\n222:   const latestTs = [memory.last_used_at, memory.last_confirmed_at, memory.created_at]\n223:     .map(t => new Date(t).getTime())\n224:     .reduce((a, b) => Math.max(a, b), 0);\n225:   const daysSince = (Date.now() - latestTs) / 86_400_000;\n226:   const decay = Math.pow(0.5, daysSince / halfLife);\n227:   return memory.importance * memory.confidence * decay;\n228: }\n229: \n230: /** Update last_used_at for a batch of memory IDs. */\n231: export function updateLastUsed(ids: number[]): void {\n232:   if (ids.length === 0) return;\n233:   const db = getDb();\n234:   const placeholders = ids.map(() => \"?\").join(\",\");\n235:   db.run(\n236:     `UPDATE memories SET last_used_at = datetime('now') WHERE id IN (${placeholders})`,\n237:     ids\n238:   );\n239: }\n240: \n241: export interface DecayResult {\n242:   deprecated: number;\n243:   scored: number;\n244: }\n245: \n246: /**\n247:  * Compute decay scores for all active memories. Deprecate those below threshold.\n248:  * Protection: importance=5 OR confirm_count>=5 are never deprecated.\n249:  */\n250: export function decayMemories(): DecayResult {\n251:   const db = getDb();\n252: \n253:   const rows = db.query<Memory, []>(\n254:     `SELECT * FROM memories WHERE status = 'active'`\n255:   ).all();\n256: \n257:   const toDeprecate = rows\n258:     .filter(mem => mem.importance !== 5 && mem.confirm_count < 5)\n259:     .filter(mem => computeDecayScore(mem) < DEPRECATION_THRESHOLD)\n260:     .map(mem => mem.id);\n261: \n262:   if (toDeprecate.length > 0) {\n263:     const placeholders = toDeprecate.map(() => \"?\").join(\",\");\n264:     db.run(\n265:       `UPDATE memories SET status = 'deprecated' WHERE id IN (${placeholders})`,\n266:       toDeprecate\n267:     );\n268:   }\n269: \n270:   return { deprecated: toDeprecate.length, scored: rows.length };\n271: }\n272: \n273: // Auto-relation detection — called fire-and-forget from learn()\n274: async function autoDetectRelations(\n275:   newId: number,\n276:   content: string,\n277:   getSimilarMemories: (text: string, topN: number, threshold: number) => Promise<Array<{ id: number; content: string; similarity: number }>>,\n278:   classifyRelation: (a: string, b: string) => Promise<RelationshipType | null>,\n279: ): Promise<void> {\n280:   try {\n281:     const { readConfigSync } = await import(\"./config.js\");\n282:     if (readConfigSync().ltm?.autoRelate === false) return;\n283: \n284:     const candidates = await getSimilarMemories(content, 5, 0.6);\n285:     const others = candidates.filter(c => c.id !== newId);\n286:     if (!others.length) return;\n287: \n288:     await Promise.allSettled(\n289:       others.map(async (candidate) => {\n290:         const relType = await classifyRelation(content, candidate.content);\n291:         if (!relType) return;\n292:         try {\n293:           relate({ source_id: newId, target_id: candidate.id, relationship_type: relType });\n294:         } catch {\n295:           // Memory may have been deleted between detection and insertion — ignore\n296:         }\n297:       })\n298:     );\n299:   } catch (err) {\n\n(Showing lines 180-299 of 780. Use offset=300 to continue.)\n</content>","metadata":{"preview":"  const results: MemoryWithRelations[\"relations\"] = [];\n\n  for (const r of outgoing) {\n    const mem = db.query<Memory, [number]>(`SELECT * FROM memories WHERE id=?`).get(r.target_memory_id);\n    if (mem) results.push({ memory: mem, relationship_type: r.relationship_type as RelationshipType, direction: \"outgoing\" });\n  }\n  for (const r of incoming) {\n    const mem = db.query<Memory, [number]>(`SELECT * FROM memories WHERE id=?`).get(r.source_memory_id);\n    if (mem) results.push({ memory: mem, relationship_type: r.relationship_type as RelationshipType, direction: \"incoming\" });\n  }\n\n  return results;\n}\n\nfunction enrichMemory(db: Database, mem: Memory): MemoryWithRelations {\n  return { ...mem, tags: getTagsForMemory(db, mem.id), relations: getRelationsForMemory(db, mem.id) };\n}\n\n// --- Decay / relevance scoring ---\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","text":"  const results: MemoryWithRelations[\"relations\"] = [];\n\n  for (const r of outgoing) {\n    const mem = db.query<Memory, [number]>(`SELECT * FROM memories WHERE id=?`).get(r.target_memory_id);\n    if (mem) results.push({ memory: mem, relationship_type: r.relationship_type as RelationshipType, direction: \"outgoing\" });\n  }\n  for (const r of incoming) {\n    const mem = db.query<Memory, [number]>(`SELECT * FROM memories WHERE id=?`).get(r.source_memory_id);\n    if (mem) results.push({ memory: mem, relationship_type: r.relationship_type as RelationshipType, direction: \"incoming\" });\n  }\n\n  return results;\n}\n\nfunction enrichMemory(db: Database, mem: Memory): MemoryWithRelations {\n  return { ...mem, tags: getTagsForMemory(db, mem.id), relations: getRelationsForMemory(db, mem.id) };\n}\n\n// --- Decay / relevance scoring ---\n\n/** Half-life in days by importance level. Infinity = never decays. */\nconst HALF_LIVES: Record<number, number> = {\n  5: Infinity,\n  4: 180,\n  3: 90,\n  2: 30,\n  1: 14,\n};\n\n/** Memories below this score are soft-deprecated (not deleted). */\nconst DEPRECATION_THRESHOLD = 0.25;\n\n/**\n * Compute effective relevance score.\n * score = importance × confidence × decay\n * decay = 0.5 ^ (days_since / half_life)  (1.0 for importance=5)\n */\nexport function computeDecayScore(memory: Memory): number {\n  const halfLife = HALF_LIVES[memory.importance] ?? 90;\n  if (halfLife === Infinity) {\n    return memory.importance * memory.confidence;\n  }\n  const latestTs = [memory.last_used_at, memory.last_confirmed_at, memory.created_at]\n    .map(t => new Date(t).getTime())\n    .reduce((a, b) => Math.max(a, b), 0);\n  const daysSince = (Date.now() - latestTs) / 86_400_000;\n  const decay = Math.pow(0.5, daysSince / halfLife);\n  return memory.importance * memory.confidence * decay;\n}\n\n/** Update last_used_at for a batch of memory IDs. */\nexport function updateLastUsed(ids: number[]): void {\n  if (ids.length === 0) return;\n  const db = getDb();\n  const placeholders = ids.map(() => \"?\").join(\",\");\n  db.run(\n    `UPDATE memories SET last_used_at = datetime('now') WHERE id IN (${placeholders})`,\n    ids\n  );\n}\n\nexport interface DecayResult {\n  deprecated: number;\n  scored: number;\n}\n\n/**\n * Compute decay scores for all active memories. Deprecate those below threshold.\n * Protection: importance=5 OR confirm_count>=5 are never deprecated.\n */\nexport function decayMemories(): DecayResult {\n  const db = getDb();\n\n  const rows = db.query<Memory, []>(\n    `SELECT * FROM memories WHERE status = 'active'`\n  ).all();\n\n  const toDeprecate = rows\n    .filter(mem => mem.importance !== 5 && mem.confirm_count < 5)\n    .filter(mem => computeDecayScore(mem) < DEPRECATION_THRESHOLD)\n    .map(mem => mem.id);\n\n  if (toDeprecate.length > 0) {\n    const placeholders = toDeprecate.map(() => \"?\").join(\",\");\n    db.run(\n      `UPDATE memories SET status = 'deprecated' WHERE id IN (${placeholders})`,\n      toDeprecate\n    );\n  }\n\n  return { deprecated: toDeprecate.length, scored: rows.length };\n}\n\n// Auto-relation detection — called fire-and-forget from learn()\nasync function autoDetectRelations(\n  newId: number,\n  content: string,\n  getSimilarMemories: (text: string, topN: number, threshold: number) => Promise<Array<{ id: number; content: string; similarity: number }>>,\n  classifyRelation: (a: string, b: string) => Promise<RelationshipType | null>,\n): Promise<void> {\n  try {\n    const { readConfigSync } = await import(\"./config.js\");\n    if (readConfigSync().ltm?.autoRelate === false) return;\n\n    const candidates = await getSimilarMemories(content, 5, 0.6);\n    const others = candidates.filter(c => c.id !== newId);\n    if (!others.length) return;\n\n    await Promise.allSettled(\n      others.map(async (candidate) => {\n        const relType = await classifyRelation(content, candidate.content);\n        if (!relType) return;\n        try {\n          relate({ source_id: newId, target_id: candidate.id, relationship_type: relType });\n        } catch {\n          // Memory may have been deleted between detection and insertion — ignore\n        }\n      })\n    );\n  } catch (err) {","lineStart":180,"lineEnd":299,"totalLines":780,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","time":{"start":1780925309073,"end":1780925309080}},"metadata":{"openai":{"itemId":"fc_00b496da07f8d519016a26c37cebd0819793611b1f1d1d2a8f"}},"id":"prt_ea76ba05e001C4bIQTpub3nflS","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76b7bfe001TX705YTw1ImP35"}}
{"type":"tool_use","timestamp":1780925309136,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_o1kJKDPbO2ezcUHjIdeu5iky","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from \"fs\";\n3: import { join } from \"path\";\n4: import { resolveProject, registerPath, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n5: import { readStdin, parseHookInput, trimToLines, readFileSafe, safeRun } from \"../lib/hookUtils.js\";\n6: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n7: import { EVENTS } from \"../lib/eventNames.js\";\n8: import { spawnSync } from \"child_process\";\n9: import { getContextMerge, getSimilarMemories, getContextMergeWithGraph, computeDecayScore,\n10:          embedText, getDb, listMemoryIdsMissingEmbedding, exportContextMarkdown,\n11:          runPendingMigrations, getRecentConflicts, emitEvent } from \"@rohirik/openltm-core\";\n12: import { readConfigSync } from \"../../src/config.js\";\n13: \n14: const TMP_DIR      = join(CLAUDE_DIR, \"tmp\");\n15: const COUNTER_FILE = join(TMP_DIR, \"session-tool-count.txt\");\n16: const DB_PATH      = getDbPath();\n17: const MAX_INJECT_LINES = 60;\n18: const MAX_LTM_LINES    = 30;\n19: const MAX_CONFLICT_LINES = 5;\n20: const MAX_AGE_MS       = 30 * 24 * 60 * 60 * 1000;\n21: const LTM_REMINDER     = \"⚡ LTM MCP live — use mcp__plugin_openltm_memory__recall before tasks, mcp__plugin_openltm_memory__learn after discoveries.\\n\";\n22: const LTM_REPO_SLUG    = \"RohiRIK/OpenLtm\";\n23: const LTM_DIRECTIVE   = \"⚡ LTM Active — Before starting work: call `recall` with task keywords. Check `context` for project state. After decisions: call `learn` to store them.\\n\\n\";\n24: \n25: function defaultName(cwd: string): string {\n26:   const last = cwd.replace(/\\/$/, \"\").split(\"/\").pop() ?? \"\";\n27:   return last.toLowerCase().replace(/[^a-z0-9]+/g, \"-\").replace(/^-|-$/g, \"\");\n28: }\n29: \n30: async function buildLtmSection(project: string, sessionContext?: string): Promise<string> {\n31:   if (!existsSync(DB_PATH)) return \"\";\n32:   try {\n33:     let globals: Array<{ id: number; content: string }>;\n34:     let scoped: Array<{ id: number; content: string; importance: number }>;\n35:     let graphInsights: string | undefined;\n36: \n37:     const queryVec = sessionContext ? await embedText(sessionContext) : null;\n38:     if (queryVec) {\n39:       const db = getDb();\n40:       globals = getSimilarMemories(db, queryVec, { minImportance: 4, limit: 16 });\n41:       scoped  = getSimilarMemories(db, queryVec, { projectScope: project, minImportance: 2, limit: 15 });\n42:       process.stderr.write(`[SessionStart] Semantic LTM: ${globals.length} globals, ${scoped.length} scoped\\n`);\n43:     } else {\n44:       const merged = getContextMerge(project) as { globals: Array<{ id: number; content: string }>; scoped: Array<{ id: number; content: string; importance: number }> };\n45:       globals = merged.globals;\n46:       scoped  = merged.scoped;\n47:     }\n48: \n49:     const cfg = readConfigSync();\n50:     if (cfg?.ltm?.graphReasoning) {\n51:       const withGraph = await getContextMergeWithGraph(project);\n52:       graphInsights = withGraph.graphInsights;\n53:     }\n54: \n55:     if (globals.length === 0 && scoped.length === 0) return \"\";\n56: \n57:     const lines: string[] = [\"LTM:\", \"\"];\n58:     if (globals.length > 0) { lines.push(\"globals:\"); for (const m of globals) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n59:     if (scoped.length > 0) { lines.push(\"project:\"); for (const m of scoped) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n60:     if (graphInsights) { lines.push(graphInsights); lines.push(\"\"); }\n61: \n62:     const allLines = lines.join(\"\\n\").split(\"\\n\");\n63:     if (allLines.length > MAX_LTM_LINES) return allLines.slice(0, MAX_LTM_LINES).join(\"\\n\") + \"\\n… (truncated)\\n\";\n64:     return lines.join(\"\\n\");\n65:   } catch (err) {\n66:     process.stderr.write(`[SessionStart:buildLtmSection] ${err}\\n`);\n67:     return \"\";\n68:   }\n69: }\n70: \n71: function buildConflictSection(project: string): string {\n72:   if (!existsSync(DB_PATH)) return \"\";\n73:   try {\n74:     const db = getDb();\n75:     const conflicts = getRecentConflicts(db, project, MAX_CONFLICT_LINES);\n76: \n77:     if (conflicts.length === 0) return \"\";\n78: \n79:     const lines: string[] = [\"⚠️ Memory Conflicts Detected\", \"\"];\n80:     for (const c of conflicts) {\n81:       lines.push(`- [${c.olderId}] superseded by [${c.newerId}]`);\n82:     }\n83:     if (conflicts.length >= MAX_CONFLICT_LINES) {\n84:       lines.push(`… and ${conflicts.length - MAX_CONFLICT_LINES + 1} more conflicts`);\n85:     }\n86:     return lines.join(\"\\n\");\n87:   } catch (err) {\n88:     process.stderr.write(`[SessionStart:buildConflictSection] ${err}\\n`);\n89:     return \"\";\n90:   }\n91: }\n92: \n93: const BACKFILL_HINT_FILE = join(TMP_DIR, \"ltm-backfill-hint.flag\");\n94: \n95: function buildBackfillHint(): string {\n96:   if (!existsSync(DB_PATH)) return \"\";\n97:   try {\n98:     const cfg = readConfigSync();\n99:     if (!cfg.embeddings || cfg.embeddings.provider === \"disabled\") return \"\";\n100: \n101:     const today = new Date().toISOString().slice(0, 10);\n102:     try {\n103:       if (readFileSync(BACKFILL_HINT_FILE, \"utf-8\").trim() === today) return \"\";\n104:     } catch { /* file absent — first run today */ }\n105: \n106:     const db = getDb();\n107:     const missing = listMemoryIdsMissingEmbedding(db, 1);\n108:     if (missing.length === 0) return \"\";\n109: \n110:     writeFileSync(BACKFILL_HINT_FILE, today);\n111:     return `\\n💡 Embedding backfill: ${cfg.embeddings.provider} provider is configured but some memories lack embeddings. Run \\`/openltm:admin backfill\\` to enable semantic recall.\\n`;\n112:   } catch {\n113:     return \"\";\n114:   }\n115: }\n116: \n117: function refreshMarketplaceClone(): void {\n118:   const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n119:   if (!pluginRoot) return;\n120:   spawnSync(\"git\", [\"fetch\", \"--quiet\"], { cwd: pluginRoot, stdio: \"ignore\", timeout: 5000 });\n121: }\n122: \n123: function patchMarketplaceSource(): void {\n124:   const knownPath = join(CLAUDE_DIR, \"plugins\", \"known_marketplaces.json\");\n125:   try {\n126:     const data = JSON.parse(readFileSync(knownPath, \"utf-8\")) as Record<string, unknown>;\n127:     const ltm = data[\"ltm\"] as Record<string, unknown> | undefined;\n128:     const src = ltm?.[\"source\"] as Record<string, unknown> | undefined;\n129:     if (src?.[\"source\"] === \"git\" && String(src?.[\"url\"] ?? \"\").includes(LTM_REPO_SLUG)) {\n130:       data[\"ltm\"] = { ...ltm, source: { source: \"github\", repo: LTM_REPO_SLUG } };\n131:       writeFileSync(knownPath, JSON.stringify(data, null, 2));\n132:     }\n133:   } catch {}\n134: }\n135: \n136: async function main(): Promise<void> {\n137:   refreshMarketplaceClone();\n138:   patchMarketplaceSource();\n139: \n140:   try { const results = await runPendingMigrations(); if (results.length > 0) process.stderr.write(`[SessionStart] Applied ${results.length} migration(s)\\n`); }\n141:   catch (e) { process.stderr.write(`[SessionStart] Migration warning: ${e}\\n`); }\n142: \n143:   const raw = await readStdin();\n144:   const parsed = parseHookInput(raw);\n145:   if (!existsSync(TMP_DIR)) mkdirSync(TMP_DIR, { recursive: true });\n146:   writeFileSync(COUNTER_FILE, \"0\");\n147: \n148:   if (!parsed) {\n149:     process.stderr.write(\"[SessionStart] No cwd in input, skipping context injection\\n\");\n150:     process.stdout.write(\"**Context not restored:** registry_miss\\n\");\n151:     return;\n152:   }\n153:   const { cwd } = parsed;\n154:   const { name, projectDir, isNew, registeredPath } = resolveProject(cwd);\n155: \n156:   // P5-0.5: auto-onboard on first SessionStart (global flag, fire-once)\n157:   const pluginData = process.env.CLAUDE_PLUGIN_DATA ?? join(CLAUDE_DIR, \"plugins\", \"data\", \"OpenLtm-openltm\");\n158:   const onboardedFlagPath = join(pluginData, \"onboarded.flag\");\n159:   if (!existsSync(onboardedFlagPath)) {\n160:     const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n161:     if (pluginRoot) {\n162:       spawnSync(\"bun\", [\"run\", join(pluginRoot, \"src\", \"onboard.ts\"), \"--non-interactive\"],\n163:         { stdio: \"pipe\", timeout: 30_000 });\n164:     }\n165:     const displayName = isNew ? defaultName(cwd) : name;\n166:     process.stdout.write(`LTM: auto-onboarded \"${displayName}\" — run /openltm:onboard to customize\\n`);\n167:   }\n168: \n169:   if (isNew) {\n170:     const suggested = defaultName(cwd);\n171:     registerPath(cwd, suggested);\n172:     mkdirSync(join(PROJECTS_DIR, suggested), { recursive: true });\n173:     process.stdout.write(\n174:       `**Context not restored:** fresh_project\\n\\n` +\n175:       `# New Project Detected\\n\\nNo context files found for: \\`${cwd}\\`\\n\\n` +\n176:       `I've registered this project as **\"${suggested}\"**.\\n` +\n177:       `Should I create the 4 context files now? (yes/no)\\n`,\n178:     );\n179:     return;\n180:   }\n\n(Showing lines 1-180 of 247. Use offset=181 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { resolveProject, registerPath, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdin, parseHookInput, trimToLines, readFileSafe, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { spawnSync } from \"child_process\";\nimport { getContextMerge, getSimilarMemories, getContextMergeWithGraph, computeDecayScore,\n         embedText, getDb, listMemoryIdsMissingEmbedding, exportContextMarkdown,\n         runPendingMigrations, getRecentConflicts, emitEvent } from \"@rohirik/openltm-core\";\nimport { readConfigSync } from \"../../src/config.js\";\n\nconst TMP_DIR      = join(CLAUDE_DIR, \"tmp\");\nconst COUNTER_FILE = join(TMP_DIR, \"session-tool-count.txt\");\nconst DB_PATH      = getDbPath();\nconst MAX_INJECT_LINES = 60;\nconst MAX_LTM_LINES    = 30;\nconst MAX_CONFLICT_LINES = 5;\nconst MAX_AGE_MS       = 30 * 24 * 60 * 60 * 1000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport { resolveProject, registerPath, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdin, parseHookInput, trimToLines, readFileSafe, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { spawnSync } from \"child_process\";\nimport { getContextMerge, getSimilarMemories, getContextMergeWithGraph, computeDecayScore,\n         embedText, getDb, listMemoryIdsMissingEmbedding, exportContextMarkdown,\n         runPendingMigrations, getRecentConflicts, emitEvent } from \"@rohirik/openltm-core\";\nimport { readConfigSync } from \"../../src/config.js\";\n\nconst TMP_DIR      = join(CLAUDE_DIR, \"tmp\");\nconst COUNTER_FILE = join(TMP_DIR, \"session-tool-count.txt\");\nconst DB_PATH      = getDbPath();\nconst MAX_INJECT_LINES = 60;\nconst MAX_LTM_LINES    = 30;\nconst MAX_CONFLICT_LINES = 5;\nconst MAX_AGE_MS       = 30 * 24 * 60 * 60 * 1000;\nconst LTM_REMINDER     = \"⚡ LTM MCP live — use mcp__plugin_openltm_memory__recall before tasks, mcp__plugin_openltm_memory__learn after discoveries.\\n\";\nconst LTM_REPO_SLUG    = \"RohiRIK/OpenLtm\";\nconst LTM_DIRECTIVE   = \"⚡ LTM Active — Before starting work: call `recall` with task keywords. Check `context` for project state. After decisions: call `learn` to store them.\\n\\n\";\n\nfunction defaultName(cwd: string): string {\n  const last = cwd.replace(/\\/$/, \"\").split(\"/\").pop() ?? \"\";\n  return last.toLowerCase().replace(/[^a-z0-9]+/g, \"-\").replace(/^-|-$/g, \"\");\n}\n\nasync function buildLtmSection(project: string, sessionContext?: string): Promise<string> {\n  if (!existsSync(DB_PATH)) return \"\";\n  try {\n    let globals: Array<{ id: number; content: string }>;\n    let scoped: Array<{ id: number; content: string; importance: number }>;\n    let graphInsights: string | undefined;\n\n    const queryVec = sessionContext ? await embedText(sessionContext) : null;\n    if (queryVec) {\n      const db = getDb();\n      globals = getSimilarMemories(db, queryVec, { minImportance: 4, limit: 16 });\n      scoped  = getSimilarMemories(db, queryVec, { projectScope: project, minImportance: 2, limit: 15 });\n      process.stderr.write(`[SessionStart] Semantic LTM: ${globals.length} globals, ${scoped.length} scoped\\n`);\n    } else {\n      const merged = getContextMerge(project) as { globals: Array<{ id: number; content: string }>; scoped: Array<{ id: number; content: string; importance: number }> };\n      globals = merged.globals;\n      scoped  = merged.scoped;\n    }\n\n    const cfg = readConfigSync();\n    if (cfg?.ltm?.graphReasoning) {\n      const withGraph = await getContextMergeWithGraph(project);\n      graphInsights = withGraph.graphInsights;\n    }\n\n    if (globals.length === 0 && scoped.length === 0) return \"\";\n\n    const lines: string[] = [\"LTM:\", \"\"];\n    if (globals.length > 0) { lines.push(\"globals:\"); for (const m of globals) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n    if (scoped.length > 0) { lines.push(\"project:\"); for (const m of scoped) lines.push(`- [${m.id}] ${m.content}`); lines.push(\"\"); }\n    if (graphInsights) { lines.push(graphInsights); lines.push(\"\"); }\n\n    const allLines = lines.join(\"\\n\").split(\"\\n\");\n    if (allLines.length > MAX_LTM_LINES) return allLines.slice(0, MAX_LTM_LINES).join(\"\\n\") + \"\\n… (truncated)\\n\";\n    return lines.join(\"\\n\");\n  } catch (err) {\n    process.stderr.write(`[SessionStart:buildLtmSection] ${err}\\n`);\n    return \"\";\n  }\n}\n\nfunction buildConflictSection(project: string): string {\n  if (!existsSync(DB_PATH)) return \"\";\n  try {\n    const db = getDb();\n    const conflicts = getRecentConflicts(db, project, MAX_CONFLICT_LINES);\n\n    if (conflicts.length === 0) return \"\";\n\n    const lines: string[] = [\"⚠️ Memory Conflicts Detected\", \"\"];\n    for (const c of conflicts) {\n      lines.push(`- [${c.olderId}] superseded by [${c.newerId}]`);\n    }\n    if (conflicts.length >= MAX_CONFLICT_LINES) {\n      lines.push(`… and ${conflicts.length - MAX_CONFLICT_LINES + 1} more conflicts`);\n    }\n    return lines.join(\"\\n\");\n  } catch (err) {\n    process.stderr.write(`[SessionStart:buildConflictSection] ${err}\\n`);\n    return \"\";\n  }\n}\n\nconst BACKFILL_HINT_FILE = join(TMP_DIR, \"ltm-backfill-hint.flag\");\n\nfunction buildBackfillHint(): string {\n  if (!existsSync(DB_PATH)) return \"\";\n  try {\n    const cfg = readConfigSync();\n    if (!cfg.embeddings || cfg.embeddings.provider === \"disabled\") return \"\";\n\n    const today = new Date().toISOString().slice(0, 10);\n    try {\n      if (readFileSync(BACKFILL_HINT_FILE, \"utf-8\").trim() === today) return \"\";\n    } catch { /* file absent — first run today */ }\n\n    const db = getDb();\n    const missing = listMemoryIdsMissingEmbedding(db, 1);\n    if (missing.length === 0) return \"\";\n\n    writeFileSync(BACKFILL_HINT_FILE, today);\n    return `\\n💡 Embedding backfill: ${cfg.embeddings.provider} provider is configured but some memories lack embeddings. Run \\`/openltm:admin backfill\\` to enable semantic recall.\\n`;\n  } catch {\n    return \"\";\n  }\n}\n\nfunction refreshMarketplaceClone(): void {\n  const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n  if (!pluginRoot) return;\n  spawnSync(\"git\", [\"fetch\", \"--quiet\"], { cwd: pluginRoot, stdio: \"ignore\", timeout: 5000 });\n}\n\nfunction patchMarketplaceSource(): void {\n  const knownPath = join(CLAUDE_DIR, \"plugins\", \"known_marketplaces.json\");\n  try {\n    const data = JSON.parse(readFileSync(knownPath, \"utf-8\")) as Record<string, unknown>;\n    const ltm = data[\"ltm\"] as Record<string, unknown> | undefined;\n    const src = ltm?.[\"source\"] as Record<string, unknown> | undefined;\n    if (src?.[\"source\"] === \"git\" && String(src?.[\"url\"] ?? \"\").includes(LTM_REPO_SLUG)) {\n      data[\"ltm\"] = { ...ltm, source: { source: \"github\", repo: LTM_REPO_SLUG } };\n      writeFileSync(knownPath, JSON.stringify(data, null, 2));\n    }\n  } catch {}\n}\n\nasync function main(): Promise<void> {\n  refreshMarketplaceClone();\n  patchMarketplaceSource();\n\n  try { const results = await runPendingMigrations(); if (results.length > 0) process.stderr.write(`[SessionStart] Applied ${results.length} migration(s)\\n`); }\n  catch (e) { process.stderr.write(`[SessionStart] Migration warning: ${e}\\n`); }\n\n  const raw = await readStdin();\n  const parsed = parseHookInput(raw);\n  if (!existsSync(TMP_DIR)) mkdirSync(TMP_DIR, { recursive: true });\n  writeFileSync(COUNTER_FILE, \"0\");\n\n  if (!parsed) {\n    process.stderr.write(\"[SessionStart] No cwd in input, skipping context injection\\n\");\n    process.stdout.write(\"**Context not restored:** registry_miss\\n\");\n    return;\n  }\n  const { cwd } = parsed;\n  const { name, projectDir, isNew, registeredPath } = resolveProject(cwd);\n\n  // P5-0.5: auto-onboard on first SessionStart (global flag, fire-once)\n  const pluginData = process.env.CLAUDE_PLUGIN_DATA ?? join(CLAUDE_DIR, \"plugins\", \"data\", \"OpenLtm-openltm\");\n  const onboardedFlagPath = join(pluginData, \"onboarded.flag\");\n  if (!existsSync(onboardedFlagPath)) {\n    const pluginRoot = process.env.CLAUDE_PLUGIN_ROOT;\n    if (pluginRoot) {\n      spawnSync(\"bun\", [\"run\", join(pluginRoot, \"src\", \"onboard.ts\"), \"--non-interactive\"],\n        { stdio: \"pipe\", timeout: 30_000 });\n    }\n    const displayName = isNew ? defaultName(cwd) : name;\n    process.stdout.write(`LTM: auto-onboarded \"${displayName}\" — run /openltm:onboard to customize\\n`);\n  }\n\n  if (isNew) {\n    const suggested = defaultName(cwd);\n    registerPath(cwd, suggested);\n    mkdirSync(join(PROJECTS_DIR, suggested), { recursive: true });\n    process.stdout.write(\n      `**Context not restored:** fresh_project\\n\\n` +\n      `# New Project Detected\\n\\nNo context files found for: \\`${cwd}\\`\\n\\n` +\n      `I've registered this project as **\"${suggested}\"**.\\n` +\n      `Should I create the 4 context files now? (yes/no)\\n`,\n    );\n    return;\n  }","lineStart":1,"lineEnd":180,"totalLines":247,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/SessionStart.ts","time":{"start":1780925309123,"end":1780925309134}},"metadata":{"openai":{"itemId":"fc_00b496da07f8d519016a26c37cebf88197bb76eb2441aef7e7"}},"id":"prt_ea76ba0bf001Ehm1jElsHxiqFe","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76b7bfe001TX705YTw1ImP35"}}
{"type":"tool_use","timestamp":1780925309139,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_c0LJOKFxW8iSpw7lzLs95qPA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","offset":520,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts</path>\n<type>file</type>\n<content>\n520: \n521:   const where = `WHERE ${conditions.join(\" AND \")}`;\n522:   // Explicit columns — excludes embedding blob (~260 KB/row) from hot recall path.\n523:   // Use getById(id, { withEmbedding: true }) when the blob is needed.\n524:   // default sort (no query): ORDER BY decay_score DESC pushed to SQL → O(log N)\n525:   const defaultSqlSort = (!input.sort_by || input.sort_by === \"relevance\") && ids === null;\n526:   const orderBy = defaultSqlSort ? \"ORDER BY decay_score DESC\" : \"\";\n527:   const rows = db.query<Memory, typeof params>(\n528:     `SELECT id, content, category, importance, confidence, source, project_scope, dedup_key,\n529:             created_at, last_confirmed_at, last_used_at, confirm_count, status,\n530:             first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n531:             workspace_id, agent_id, decay_score\n532:      FROM memories ${where} ${orderBy} LIMIT ${limit}`\n533:   ).all(...params);\n534: \n535:   let sorted: typeof rows;\n536:   if (defaultSqlSort) {\n537:     sorted = rows; // already ordered by decay_score DESC in SQL\n538:   } else if (input.sort_by === \"created\") {\n539:     sorted = rows.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());\n540:   } else if (input.sort_by === \"last_recalled\") {\n541:     sorted = rows.sort((a, b) => new Date(b.last_recalled_at ?? \"1970\").getTime() - new Date(a.last_recalled_at ?? \"1970\").getTime());\n542:   } else if (input.sort_by === \"recall_count\") {\n543:     sorted = rows.sort((a, b) => (b.recall_count ?? 0) - (a.recall_count ?? 0));\n544:   } else {\n545:     // FTS/semantic path: small result set (≤50), JS sort is O(k log k) — negligible.\n546:     // Use materialised decay_score if available, fall back to computing it.\n547:     sorted = rows\n548:       .map(m => ({ m, score: m.decay_score ?? computeDecayScore(m) }))\n549:       .sort((a, b) => b.score - a.score)\n550:       .map(({ m }) => m);\n551:   }\n552:   if (sorted.length > 0) {\n553:     const placeholders = sorted.map(() => \"?\").join(\",\");\n554:     db.run(\n555:       `UPDATE memories SET last_used_at = datetime('now'), last_recalled_at = datetime('now'),\n556:               recall_count = recall_count + 1,\n557:               first_recalled_at = COALESCE(first_recalled_at, datetime('now'))\n558:        WHERE id IN (${placeholders})`,\n559:       sorted.map(m => m.id),\n560:     );\n561:   }\n562:   const enriched = sorted.map(m => enrichMemory(db, m));\n563:   if (input.includeProvenance) {\n564:     const provMap = listProvenanceBatch(db, enriched.map(m => m.id));\n565:     for (const m of enriched) {\n566:       m.provenance = provMap.get(m.id) ?? [];\n567:     }\n568:   }\n569: \n570:   // Attach explainer (pure function — no extra DB calls).\n571:   if (enriched.length > 0) {\n572:     const { buildExplainer } = await import(\"./recall/explainer.js\");\n573:     for (const m of enriched) {\n574:       m.explainer = buildExplainer({\n575:         importance: m.importance,\n576:         recall_count: m.recall_count ?? 0,\n577:         last_recalled_at: m.last_recalled_at,\n578:         ftsRank: ftsRanks.get(m.id) ?? null,\n579:         semanticScore: semanticScores.get(m.id) ?? null,\n580:       });\n581:     }\n582:   }\n583: \n584:   return enriched;\n585: }\n586: \n587: export function relate(input: {\n588:   source_id: number;\n589:   target_id: number;\n590:   relationship_type: RelationshipType;\n591: }): void {\n592:   const db = getDb();\n593:   if (!db.query<{ id: number }, [number]>(`SELECT id FROM memories WHERE id=?`).get(input.source_id)) {\n594:     throw new Error(`Source memory ${input.source_id} not found`);\n595:   }\n596:   if (!db.query<{ id: number }, [number]>(`SELECT id FROM memories WHERE id=?`).get(input.target_id)) {\n597:     throw new Error(`Target memory ${input.target_id} not found`);\n598:   }\n599:   db.run(\n600:     `INSERT OR IGNORE INTO memory_relations (source_memory_id, target_memory_id, relationship_type)\n601:      VALUES (?, ?, ?)`,\n602:     [input.source_id, input.target_id, input.relationship_type]\n603:   );\n604: }\n605: \n606: export function forget(input: { id: number; reason?: string; skipExport?: boolean; actor?: string; sessionId?: string }): void {\n607:   const db = getDb();\n608:   const snap = snapshotMemory(db, input.id);\n609:   if (!snap) throw new Error(`Memory ${input.id} not found`);\n\n(Showing lines 520-609 of 780. Use offset=610 to continue.)\n</content>","metadata":{"preview":"\n  const where = `WHERE ${conditions.join(\" AND \")}`;\n  // Explicit columns — excludes embedding blob (~260 KB/row) from hot recall path.\n  // Use getById(id, { withEmbedding: true }) when the blob is needed.\n  // default sort (no query): ORDER BY decay_score DESC pushed to SQL → O(log N)\n  const defaultSqlSort = (!input.sort_by || input.sort_by === \"relevance\") && ids === null;\n  const orderBy = defaultSqlSort ? \"ORDER BY decay_score DESC\" : \"\";\n  const rows = db.query<Memory, typeof params>(\n    `SELECT id, content, category, importance, confidence, source, project_scope, dedup_key,\n            created_at, last_confirmed_at, last_used_at, confirm_count, status,\n            first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n            workspace_id, agent_id, decay_score\n     FROM memories ${where} ${orderBy} LIMIT ${limit}`\n  ).all(...params);\n\n  let sorted: typeof rows;\n  if (defaultSqlSort) {\n    sorted = rows; // already ordered by decay_score DESC in SQL\n  } else if (input.sort_by === \"created\") {\n    sorted = rows.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","text":"\n  const where = `WHERE ${conditions.join(\" AND \")}`;\n  // Explicit columns — excludes embedding blob (~260 KB/row) from hot recall path.\n  // Use getById(id, { withEmbedding: true }) when the blob is needed.\n  // default sort (no query): ORDER BY decay_score DESC pushed to SQL → O(log N)\n  const defaultSqlSort = (!input.sort_by || input.sort_by === \"relevance\") && ids === null;\n  const orderBy = defaultSqlSort ? \"ORDER BY decay_score DESC\" : \"\";\n  const rows = db.query<Memory, typeof params>(\n    `SELECT id, content, category, importance, confidence, source, project_scope, dedup_key,\n            created_at, last_confirmed_at, last_used_at, confirm_count, status,\n            first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n            workspace_id, agent_id, decay_score\n     FROM memories ${where} ${orderBy} LIMIT ${limit}`\n  ).all(...params);\n\n  let sorted: typeof rows;\n  if (defaultSqlSort) {\n    sorted = rows; // already ordered by decay_score DESC in SQL\n  } else if (input.sort_by === \"created\") {\n    sorted = rows.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());\n  } else if (input.sort_by === \"last_recalled\") {\n    sorted = rows.sort((a, b) => new Date(b.last_recalled_at ?? \"1970\").getTime() - new Date(a.last_recalled_at ?? \"1970\").getTime());\n  } else if (input.sort_by === \"recall_count\") {\n    sorted = rows.sort((a, b) => (b.recall_count ?? 0) - (a.recall_count ?? 0));\n  } else {\n    // FTS/semantic path: small result set (≤50), JS sort is O(k log k) — negligible.\n    // Use materialised decay_score if available, fall back to computing it.\n    sorted = rows\n      .map(m => ({ m, score: m.decay_score ?? computeDecayScore(m) }))\n      .sort((a, b) => b.score - a.score)\n      .map(({ m }) => m);\n  }\n  if (sorted.length > 0) {\n    const placeholders = sorted.map(() => \"?\").join(\",\");\n    db.run(\n      `UPDATE memories SET last_used_at = datetime('now'), last_recalled_at = datetime('now'),\n              recall_count = recall_count + 1,\n              first_recalled_at = COALESCE(first_recalled_at, datetime('now'))\n       WHERE id IN (${placeholders})`,\n      sorted.map(m => m.id),\n    );\n  }\n  const enriched = sorted.map(m => enrichMemory(db, m));\n  if (input.includeProvenance) {\n    const provMap = listProvenanceBatch(db, enriched.map(m => m.id));\n    for (const m of enriched) {\n      m.provenance = provMap.get(m.id) ?? [];\n    }\n  }\n\n  // Attach explainer (pure function — no extra DB calls).\n  if (enriched.length > 0) {\n    const { buildExplainer } = await import(\"./recall/explainer.js\");\n    for (const m of enriched) {\n      m.explainer = buildExplainer({\n        importance: m.importance,\n        recall_count: m.recall_count ?? 0,\n        last_recalled_at: m.last_recalled_at,\n        ftsRank: ftsRanks.get(m.id) ?? null,\n        semanticScore: semanticScores.get(m.id) ?? null,\n      });\n    }\n  }\n\n  return enriched;\n}\n\nexport function relate(input: {\n  source_id: number;\n  target_id: number;\n  relationship_type: RelationshipType;\n}): void {\n  const db = getDb();\n  if (!db.query<{ id: number }, [number]>(`SELECT id FROM memories WHERE id=?`).get(input.source_id)) {\n    throw new Error(`Source memory ${input.source_id} not found`);\n  }\n  if (!db.query<{ id: number }, [number]>(`SELECT id FROM memories WHERE id=?`).get(input.target_id)) {\n    throw new Error(`Target memory ${input.target_id} not found`);\n  }\n  db.run(\n    `INSERT OR IGNORE INTO memory_relations (source_memory_id, target_memory_id, relationship_type)\n     VALUES (?, ?, ?)`,\n    [input.source_id, input.target_id, input.relationship_type]\n  );\n}\n\nexport function forget(input: { id: number; reason?: string; skipExport?: boolean; actor?: string; sessionId?: string }): void {\n  const db = getDb();\n  const snap = snapshotMemory(db, input.id);\n  if (!snap) throw new Error(`Memory ${input.id} not found`);","lineStart":520,"lineEnd":609,"totalLines":780,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","time":{"start":1780925309091,"end":1780925309137}},"metadata":{"openai":{"itemId":"fc_00b496da07f8d519016a26c37cebe48197bfe5f8b0fd075bca"}},"id":"prt_ea76ba092001pIwW8nZOlc3eTd","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76b7bfe001TX705YTw1ImP35"}}
{"type":"tool_use","timestamp":1780925309139,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_SxWPBTOAR0mnwlOuCkINoYAx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","offset":630,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts</path>\n<type>file</type>\n<content>\n630:   let query: string;\n631:   let params: (string | number)[];\n632: \n633:   if (projectScope) {\n634:     query = `SELECT * FROM memories WHERE project_scope=? AND importance>=? AND embedding IS NOT NULL AND status='active' LIMIT ${limit * 3}`;\n635:     params = [projectScope, minImportance];\n636:   } else {\n637:     query = `SELECT * FROM memories WHERE project_scope IS NULL AND importance>=? AND embedding IS NOT NULL AND status='active' LIMIT ${limit * 3}`;\n638:     params = [minImportance];\n639:   }\n640: \n641:   const rows = db.query<Memory & { embedding: Buffer }, typeof params>(query).all(...params);\n642: \n643:   const scored = rows.map(row => {\n644:     const { embedding, ...mem } = row as Memory & { embedding: Buffer };\n645:     const sim = cosineSimilarity(queryVec, blobToVec(embedding));\n646:     return { mem, sim };\n647:   });\n648: \n649:   scored.sort((a, b) => b.sim - a.sim);\n650:   return scored.slice(0, limit).map(s => s.mem);\n651: }\n652: \n653: export function getContextMerge(project: string): { globals: Memory[]; scoped: Memory[] } {\n654:   const db = getDb();\n655:   const sortByDecay = (arr: Memory[]) =>\n656:     arr.map(m => ({ m, score: computeDecayScore(m) }))\n657:        .sort((a, b) => b.score - a.score)\n658:        .map(({ m }) => m);\n659: \n660:   const SLIM = `id, content, category, importance, confidence, source, project_scope, dedup_key,\n661:                created_at, last_confirmed_at, last_used_at, confirm_count, status,\n662:                first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n663:                workspace_id, agent_id`;\n664:   const globals = sortByDecay(db.query<Memory, []>(\n665:     `SELECT ${SLIM} FROM memories WHERE importance >= 4 AND project_scope IS NULL AND status = 'active'`\n666:   ).all());\n667: \n668:   const scoped = sortByDecay(db.query<Memory, [string]>(\n669:     `SELECT ${SLIM} FROM memories WHERE project_scope=? AND importance >= 3 AND status = 'active' LIMIT 15`\n670:   ).all(project));\n671: \n672:   const allIds = [...globals, ...scoped].map(m => m.id);\n673:   updateLastUsed(allIds);\n674: \n675:   return { globals, scoped };\n676: }\n677: \n678: /**\n679:  * Async variant: returns getContextMerge result plus graph insights block.\n680:  * Used by SessionStart hook when graphReasoning is enabled.\n681:  */\n682: export async function getContextMergeWithGraph(project: string): Promise<{ globals: Memory[]; scoped: Memory[]; graphInsights?: string }> {\n683:   const base = getContextMerge(project);\n684: \n685:   const { readConfigSync } = await import(\"./config.js\");\n686:   if (!readConfigSync().ltm?.graphReasoning) return base;\n687: \n688:   const seeds = [...base.globals.slice(0, 2), ...base.scoped.slice(0, 1)].map(m => m.id);\n689:   if (seeds.length === 0) return base;\n690: \n691:   try {\n692:     const { traverseGraph, buildReasoningContext } = await import(\"./graph.js\");\n693:     const results = await Promise.allSettled(seeds.map(id => traverseGraph(id, 2, false)));\n694:     const lines: string[] = [];\n695:     for (const r of results) {\n696:       if (r.status === \"fulfilled\") {\n697:         const block = buildReasoningContext(r.value);\n698:         if (block) lines.push(block);\n699:       }\n700:     }\n701:     const graphInsights = lines.slice(0, 5).join(\"\\n\") || undefined;\n702:     return { ...base, graphInsights };\n703:   } catch (err) {\n704:     process.stderr.write(`[getContextMergeWithGraph] error: ${err}\\n`);\n705:     return base;\n706:   }\n707: }\n708: \n709: /** Write docs/memory-long-term-dump.md — auto-generated snapshot (never overwrites the architecture doc). */\n710: export function exportMarkdown(): void {\n711:   const db = getDb();\n712:   if (!existsSync(DOCS_DIR)) mkdirSync(DOCS_DIR, { recursive: true });\n713: \n714:   const rows = db.query<Memory, []>(\n715:     `SELECT * FROM memories ORDER BY importance DESC, category ASC, created_at DESC LIMIT 500`\n716:   ).all();\n717: \n718:   // Batch-fetch all tags in one query to avoid N+1\n719:   const tagsByMemory = getTagsBatch(db, rows.map(r => r.id));\n\n(Showing lines 630-719 of 780. Use offset=720 to continue.)\n</content>","metadata":{"preview":"  let query: string;\n  let params: (string | number)[];\n\n  if (projectScope) {\n    query = `SELECT * FROM memories WHERE project_scope=? AND importance>=? AND embedding IS NOT NULL AND status='active' LIMIT ${limit * 3}`;\n    params = [projectScope, minImportance];\n  } else {\n    query = `SELECT * FROM memories WHERE project_scope IS NULL AND importance>=? AND embedding IS NOT NULL AND status='active' LIMIT ${limit * 3}`;\n    params = [minImportance];\n  }\n\n  const rows = db.query<Memory & { embedding: Buffer }, typeof params>(query).all(...params);\n\n  const scored = rows.map(row => {\n    const { embedding, ...mem } = row as Memory & { embedding: Buffer };\n    const sim = cosineSimilarity(queryVec, blobToVec(embedding));\n    return { mem, sim };\n  });\n\n  scored.sort((a, b) => b.sim - a.sim);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","text":"  let query: string;\n  let params: (string | number)[];\n\n  if (projectScope) {\n    query = `SELECT * FROM memories WHERE project_scope=? AND importance>=? AND embedding IS NOT NULL AND status='active' LIMIT ${limit * 3}`;\n    params = [projectScope, minImportance];\n  } else {\n    query = `SELECT * FROM memories WHERE project_scope IS NULL AND importance>=? AND embedding IS NOT NULL AND status='active' LIMIT ${limit * 3}`;\n    params = [minImportance];\n  }\n\n  const rows = db.query<Memory & { embedding: Buffer }, typeof params>(query).all(...params);\n\n  const scored = rows.map(row => {\n    const { embedding, ...mem } = row as Memory & { embedding: Buffer };\n    const sim = cosineSimilarity(queryVec, blobToVec(embedding));\n    return { mem, sim };\n  });\n\n  scored.sort((a, b) => b.sim - a.sim);\n  return scored.slice(0, limit).map(s => s.mem);\n}\n\nexport function getContextMerge(project: string): { globals: Memory[]; scoped: Memory[] } {\n  const db = getDb();\n  const sortByDecay = (arr: Memory[]) =>\n    arr.map(m => ({ m, score: computeDecayScore(m) }))\n       .sort((a, b) => b.score - a.score)\n       .map(({ m }) => m);\n\n  const SLIM = `id, content, category, importance, confidence, source, project_scope, dedup_key,\n               created_at, last_confirmed_at, last_used_at, confirm_count, status,\n               first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n               workspace_id, agent_id`;\n  const globals = sortByDecay(db.query<Memory, []>(\n    `SELECT ${SLIM} FROM memories WHERE importance >= 4 AND project_scope IS NULL AND status = 'active'`\n  ).all());\n\n  const scoped = sortByDecay(db.query<Memory, [string]>(\n    `SELECT ${SLIM} FROM memories WHERE project_scope=? AND importance >= 3 AND status = 'active' LIMIT 15`\n  ).all(project));\n\n  const allIds = [...globals, ...scoped].map(m => m.id);\n  updateLastUsed(allIds);\n\n  return { globals, scoped };\n}\n\n/**\n * Async variant: returns getContextMerge result plus graph insights block.\n * Used by SessionStart hook when graphReasoning is enabled.\n */\nexport async function getContextMergeWithGraph(project: string): Promise<{ globals: Memory[]; scoped: Memory[]; graphInsights?: string }> {\n  const base = getContextMerge(project);\n\n  const { readConfigSync } = await import(\"./config.js\");\n  if (!readConfigSync().ltm?.graphReasoning) return base;\n\n  const seeds = [...base.globals.slice(0, 2), ...base.scoped.slice(0, 1)].map(m => m.id);\n  if (seeds.length === 0) return base;\n\n  try {\n    const { traverseGraph, buildReasoningContext } = await import(\"./graph.js\");\n    const results = await Promise.allSettled(seeds.map(id => traverseGraph(id, 2, false)));\n    const lines: string[] = [];\n    for (const r of results) {\n      if (r.status === \"fulfilled\") {\n        const block = buildReasoningContext(r.value);\n        if (block) lines.push(block);\n      }\n    }\n    const graphInsights = lines.slice(0, 5).join(\"\\n\") || undefined;\n    return { ...base, graphInsights };\n  } catch (err) {\n    process.stderr.write(`[getContextMergeWithGraph] error: ${err}\\n`);\n    return base;\n  }\n}\n\n/** Write docs/memory-long-term-dump.md — auto-generated snapshot (never overwrites the architecture doc). */\nexport function exportMarkdown(): void {\n  const db = getDb();\n  if (!existsSync(DOCS_DIR)) mkdirSync(DOCS_DIR, { recursive: true });\n\n  const rows = db.query<Memory, []>(\n    `SELECT * FROM memories ORDER BY importance DESC, category ASC, created_at DESC LIMIT 500`\n  ).all();\n\n  // Batch-fetch all tags in one query to avoid N+1\n  const tagsByMemory = getTagsBatch(db, rows.map(r => r.id));","lineStart":630,"lineEnd":719,"totalLines":780,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","time":{"start":1780925309099,"end":1780925309138}},"metadata":{"openai":{"itemId":"fc_00b496da07f8d519016a26c37cebf08197bf3900ae