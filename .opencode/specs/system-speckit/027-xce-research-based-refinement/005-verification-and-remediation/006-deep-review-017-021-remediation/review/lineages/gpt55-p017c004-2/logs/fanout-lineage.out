86:     {\n187:       \"query\": \"feature specification sales hubspot automation merge\",\n188:       \"memoryId\": \".opencode/specs/ai-systems/005-sales-hubspot-automation-merge\",\n189:       \"relevant\": 1\n190:     },\n191:     {\n192:       \"query\": \"feature specification sales hubspot automation merge\",\n193:       \"memoryId\": \".opencode/specs/skilled-agent-orchestration/144-operate-like-fable-5\",\n194:       \"relevant\": 0\n195:     },\n196:     {\n197:       \"query\": \"feature specification barter blog posts generalization\",\n198:       \"memoryId\": \".opencode/specs/ai-systems/006-blog-posts-generalization\",\n199:       \"relevant\": 1\n200:     },\n201:     {\n202:       \"query\": \"feature specification barter blog posts generalization\",\n203:       \"memoryId\": \".opencode/specs/skilled-agent-orchestration/144-operate-like-fable-5/002-fable-mode-efficiency-research\",\n204:       \"relevant\": 0\n205:     },\n206:     {\n207:       \"query\": \"feature specification reference overview fast-or-deep prompt\",\n208:       \"memoryId\": \".opencode/specs/ai-systems/007-reference-overview-and-fast-prompt\",\n209:       \"relevant\": 1\n210:     },\n211:     {\n212:       \"query\": \"feature specification reference overview fast-or-deep prompt\",\n213:       \"memoryId\": \".opencode/specs/skilled-agent-orchestration/144-operate-like-fable-5/003-measurement-baseline\",\n214:       \"relevant\": 0\n215:     },\n216:     {\n217:       \"query\": \"product-owner verbosity scope scaling concise ticket\",\n218:       \"memoryId\": \".opencode/specs/ai-systems/008-product-owner-scope-aware-verbosity\",\n219:       \"relevant\": 1\n220:     },\n221:     {\n222:       \"query\": \"product-owner verbosity scope scaling concise ticket\",\n223:       \"memoryId\": \".opencode/specs/skilled-agent-orchestration/144-operate-like-fable-5/004-doctrine-quick-wins\",\n224:       \"relevant\": 0\n225:     },\n226:     {\n227:       \"query\": \"feature speci