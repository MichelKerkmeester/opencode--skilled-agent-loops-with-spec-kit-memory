{"type":"text","timestamp":1781764017704,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"id":"prt_ed9693045001l5Rg1pWhRGVI64","messageID":"msg_ed969147b001guuoGjbpQJWHum","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","type":"text","text":"One possible schema/handler drift exists in ingest path validation, but it is likely low severity. I’m looking for stronger correctness or lifecycle bugs before recording findings.","time":{"start":1781764010053,"end":1781764017702},"metadata":{"openai":{"itemId":"msg_0f62038bf7812bee016a338fa9f7ec819189d87db39e6cd44e","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781764018129,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_YRRX7cIxF5m7CRWx5I4FGD1U","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Bulk Delete\n3: // ────────────────────────────────────────────────────────────────\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* ───────────────────────────────────────────────────────────────\n29:    1. TYPES\n30: ──────────────────────────────────────────────────────────────── */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* ───────────────────────────────────────────────────────────────\n74:     2. HANDLER\n75: ──────────────────────────────────────────────────────────────── */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n261:         deletedCount++;\n262:         deletedIds.push(memory.id);\n263: \n264:         // Clean up causal edges\n265:         // Propagate edge-cleanup errors to fail the transaction.\n266:         // Previously errors were caught and logged, leaving orphan causal edges\n267:         // When memory rows were successfully deleted but edge cleanup failed.\n268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n269:           reason: 'memory row mutation cleanup',\n270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n272:         });\n273:       }\n274:     }\n275:   });\n276: \n277:   bulkDeleteTx();\n278: \n279:   // Record in mutation ledger (single entry for bulk operation)\n280:   const ledgerRecorded = appendMutationLedgerSafe(database, {\n\n(Showing lines 1-280 of 372. Use offset=281 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n    2. HANDLER\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }\n        deletedCount++;\n        deletedIds.push(memory.id);\n\n        // Clean up causal edges\n        // Propagate edge-cleanup errors to fail the transaction.\n        // Previously errors were caught and logged, leaving orphan causal edges\n        // When memory rows were successfully deleted but edge cleanup failed.\n        causalEdges.deleteEdgesForMemory(String(memory.id), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-bulk-delete.handleMemoryBulkDelete',\n          restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n        });\n      }\n    }\n  });\n\n  bulkDeleteTx();\n\n  // Record in mutation ledger (single entry for bulk operation)\n  const ledgerRecorded = appendMutationLedgerSafe(database, {","lineStart":1,"lineEnd":280,"totalLines":372,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781764018121,"end":1781764018128}},"metadata":{"openai":{"itemId":"fc_0f62038bf7812bee016a338fb190ac81918da41c31c854a0bb"}},"id":"prt_ed9694e3e0016Bds6SCN1OdB2C","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed969147b001guuoGjbpQJWHum"}}
{"type":"tool_use","timestamp":1781764018443,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_VxngakrFIEnwlaQCnAfLrY6p","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","offset":1,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Checkpoints\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    1. LIB MODULE IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import * as checkpoints from '../lib/storage/checkpoints.js';\n10: import * as vectorIndex from '../lib/search/vector-index.js';\n11: import * as bm25Index from '../lib/search/bm25-index.js';\n12: import * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\n13: import * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\n14: import { executeAutoPromotion } from '../lib/search/auto-promotion.js';\n15: import { recordSelection } from '../lib/search/learned-feedback.js';\n16: import { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\n17: import { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\n18: import { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\n19: import { checkDatabaseUpdated } from '../core/index.js';\n20: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n21: import { requireDb, toErrorMessage } from '../utils/index.js';\n22: import * as sessionManager from '../lib/session/session-manager.js';\n23: \n24: // Standardized response structure\n25: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n26: \n27: // Shared handler types\n28: import type { MCPResponse } from './types.js';\n29: \n30: // Feature catalog: Checkpoint creation (checkpoint_create)\n31: // Feature catalog: Checkpoint listing (checkpoint_list)\n32: // Feature catalog: Checkpoint restore (checkpoint_restore)\n33: // Feature catalog: Checkpoint deletion (checkpoint_delete)\n34: // Feature catalog: Checkpoint delete confirmName safety\n35: \n36: \n37: /* ───────────────────────────────────────────────────────────────\n38:    2. TYPES\n39: ──────────────────────────────────────────────────────────────── */\n40: \n41: interface CheckpointCreateArgs {\n42:   name: string;\n43:   specFolder?: string;\n44:   tenantId?: string;\n45:   userId?: string;\n46:   agentId?: string;\n47:   includeEmbeddings?: boolean;\n48:   metadata?: Record<string, unknown>;\n49: }\n50: \n51: interface CheckpointListArgs {\n52:   specFolder?: string;\n53:   tenantId?: string;\n54:   userId?: string;\n55:   agentId?: string;\n56:   limit?: number;\n57: }\n58: \n59: interface CheckpointRestoreArgs {\n60:   name: string;\n61:   tenantId?: string;\n62:   userId?: string;\n63:   agentId?: string;\n64:   clearExisting?: boolean;\n65: }\n66: \n67: interface CheckpointDeleteArgs {\n68:   name: string;\n69:   tenantId?: string;\n70:   userId?: string;\n71:   agentId?: string;\n72:   confirmName: string;\n73: }\n74: \n75: interface CheckpointScopeArgs {\n76:   tenantId?: string;\n77:   userId?: string;\n78:   agentId?: string;\n79: }\n80: \n81: interface MemoryValidateArgs {\n82:   id: number | string;\n83:   wasUseful: boolean;\n84:   queryId?: string;\n85:   queryTerms?: string[];\n86:   resultRank?: number;\n87:   totalResultsShown?: number;\n88:   searchMode?: string;\n89:   intent?: string;\n90:   sessionId?: string;\n91:   notes?: string;\n92: }\n93: \n94: interface ValidationResult {\n95:   confidence: number;\n96:   validationCount: number;\n97:   positiveValidationCount: number;\n98:   promotionEligible: boolean;\n99: }\n100: \n101: function resolveValidationQueryText(\n102:   database: ReturnType<typeof requireDb>,\n103:   queryId?: string,\n104: ): string | null {\n105:   if (typeof queryId !== 'string') {\n106:     return null;\n107:   }\n108: \n109:   const normalizedQueryId = queryId.trim();\n110:   if (normalizedQueryId.length === 0) {\n111:     return null;\n112:   }\n113: \n114:   if (/\\s/.test(normalizedQueryId)) {\n115:     return normalizedQueryId;\n116:   }\n117: \n118:   const consumptionMatch = normalizedQueryId.match(/^(?:consumption:)?(\\d+)$/);\n119:   if (!consumptionMatch) {\n120:     return null;\n121:   }\n122: \n123:   const consumptionLogTable = database.prepare(`\n124:     SELECT 1\n125:     FROM sqlite_master\n126:     WHERE type = 'table'\n127:       AND name = 'consumption_log'\n128:     LIMIT 1\n129:   `).get();\n130:   if (!consumptionLogTable) {\n131:     return null;\n132:   }\n133: \n134:   // The clean consumption_log schema stores only a query fingerprint; raw\n135:   // query text exists solely on unmigrated legacy tables. Without the column\n136:   // there is nothing to resolve, and selecting it would throw.\n137:   const columns = database.prepare(`PRAGMA table_info(consumption_log)`).all() as Array<{ name: string }>;\n138:   if (!columns.some((column) => column.name === 'query_text')) {\n139:     return null;\n140:   }\n141: \n142:   const row = database.prepare(`\n143:     SELECT query_text\n144:     FROM consumption_log\n145:     WHERE id = ?\n146:       AND query_text IS NOT NULL\n147:       AND TRIM(query_text) != ''\n148:     LIMIT 1\n149:   `).get(Number.parseInt(consumptionMatch[1], 10)) as { query_text?: string } | undefined;\n150: \n151:   return typeof row?.query_text === 'string' && row.query_text.trim().length > 0\n152:     ? row.query_text\n153:     : null;\n154: }\n155: \n156: function parseMemoryId(rawId: number | string): number {\n157:   const numericId = typeof rawId === 'string'\n158:     ? Number.parseInt(rawId.trim(), 10)\n159:     : rawId;\n160: \n161:   if (\n162:     typeof numericId !== 'number' ||\n163:     !Number.isSafeInteger(numericId) ||\n164:     numericId <= 0 ||\n165:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n166:   ) {\n167:     throw new Error('id must be a positive integer');\n168:   }\n169: \n170:   return numericId;\n171: }\n172: \n173: function parseCheckpointMetadata(rawMetadata: unknown): Record<string, unknown> {\n174:   if (!rawMetadata) {\n175:     return {};\n176:   }\n177: \n178:   if (typeof rawMetadata === 'string') {\n179:     try {\n180:       const parsed = JSON.parse(rawMetadata);\n181:       return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n182:         ? parsed as Record<string, unknown>\n183:         : {};\n184:     } catch (_error: unknown) {\n185:       return {};\n186:     }\n187:   }\n188: \n189:   return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n190:     ? rawMetadata as Record<string, unknown>\n191:     : {};\n192: }\n193: \n194: function validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n195:   const validateValue = (\n196:     value: string | undefined,\n197:     field: keyof CheckpointScopeArgs,\n198:     options: { trim?: boolean } = {},\n199:   ): string | undefined => {\n200:     if (value === undefined) {\n201:       return undefined;\n202:     }\n203:     if (typeof value !== 'string') {\n204:       throw new Error(`${field} must be a string`);\n205:     }\n206:     return options.trim ? value.trim() : value;\n207:   };\n208: \n209:   const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n210:   const userId = validateValue(args.userId, 'userId');\n211:   const agentId = validateValue(args.agentId, 'agentId');\n212:   const hasActorScope = userId !== undefined || agentId !== undefined;\n213: \n214:   if (\n215:     hasActorScope\n216:     && tenantId !== undefined\n217:     && tenantId.trim().length === 0\n218:   ) {\n219:     throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n220:   }\n221: \n222:   return {\n223:     tenantId: tenantId && tenantId.length > 0 ? tenantId : undefined,\n224:     userId,\n225:     agentId,\n226:   };\n227: }\n228: \n229: function hasCheckpointScope(scope: CheckpointScopeArgs): boolean {\n230:   return (\n231:     scope.tenantId !== undefined\n232:     || scope.userId !== undefined\n233:     || scope.agentId !== undefined\n234:   );\n235: }\n236: \n237: function requiresCheckpointTenant(scope: CheckpointScopeArgs): boolean {\n238:   return scope.tenantId === undefined && (\n239:     scope.userId !== undefined\n240:     || scope.agentId !== undefined\n241:   );\n242: }\n243: \n244: function mergeCheckpointScopeMetadata(\n245:   metadata: Record<string, unknown> | undefined,\n246:   scope: CheckpointScopeArgs,\n247: ): Record<string, unknown> {\n248:   return {\n249:     ...(metadata ?? {}),\n250:     ...(scope.tenantId !== undefined ? { tenantId: scope.tenantId } : {}),\n251:     ...(scope.userId !== undefined ? { userId: scope.userId } : {}),\n252:     ...(scope.agentId !== undefined ? { agentId: scope.agentId } : {}),\n253:   };\n254: }\n255: \n256: function checkpointMatchesScope(rawMetadata: unknown, scope: CheckpointScopeArgs): boolean {\n257:   const metadata = parseCheckpointMetadata(rawMetadata);\n258:   const matchesScopeField = (field: keyof CheckpointScopeArgs): boolean => {\n259:     const expected = scope[field];\n260:     if (expected === undefined) {\n261:       return true;\n262:     }\n263:     const actual = metadata[field];\n264:     return actual === undefined || actual === expected;\n265:   };\n266: \n267:   return (\n268:     matchesScopeField('tenantId') &&\n269:     matchesScopeField('userId') &&\n270:     matchesScopeField('agentId')\n271:   );\n272: }\n273: \n274: function checkpointScopeDetails(scope: CheckpointScopeArgs): Record<string, string> {\n275:   const details: Record<string, string> = {};\n276:   if (scope.tenantId !== undefined) {\n277:     details.tenantId = scope.tenantId;\n278:   }\n279:   if (scope.userId !== undefined) {\n280:     details.userId = scope.userId;\n281:   }\n282:   if (scope.agentId !== undefined) {\n283:     details.agentId = scope.agentId;\n284:   }\n285:   return details;\n286: }\n287: \n288: function createCheckpointScopeValidationError(\n289:   tool: 'checkpoint_create' | 'checkpoint_list' | 'checkpoint_restore' | 'checkpoint_delete',\n290: ): MCPResponse {\n291:   return createMCPErrorResponse({\n292:     tool,\n293:     error: 'tenantId is required when userId or agentId is provided.',\n294:     code: 'CHECKPOINT_SCOPE_TENANT_REQUIRED',\n295:     details: {\n296:       reason: 'checkpoint_scope_tenant_required',\n297:     },\n298:     recovery: {\n299:       hint: 'Retry with tenantId included for governed checkpoint access.',\n300:     },\n301:   });\n302: }\n303: \n304: function createCheckpointCreateFailureResponse(\n305:   error: unknown,\n306:   context: { name: string; specFolder: string | null },\n307:   startTime: number,\n308: ): MCPResponse {\n309:   const typedError = error instanceof checkpoints.CheckpointCreateError ? error : null;\n310:   const code = typedError?.code ?? 'CHECKPOINT_CREATE_FAILED';\n311:   const message = typedError?.message ?? `Checkpoint creation failed: ${toErrorMessage(error)}`;\n312: \n313:   const recoveryByCode: Record<string, { hint: string; actions: string[]; severity: string }> = {\n314:     CHECKPOINT_CREATE_SQLITE_BUSY: {\n315:       hint: 'SQLite was busy while creating the checkpoint. Retry after active writes finish.',\n316:       actions: [\n317:         'Retry checkpoint_create after concurrent memory writes complete',\n318:         'For sweep harnesses, prefer specFolder-scoped checkpoints or includeEmbeddings=false when rollback semantics allow',\n319:         'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n320:       ],\n321:       severity: 'medium',\n322:     },\n323:     CHECKPOINT_CREATE_SQLITE_LOCKED: {\n324:       hint: 'SQLite was locked by another operation while creating the checkpoint.',\n325:       actions: [\n326:         'Wait for the active lifecycle operation to finish, then retry',\n327:         'Serialize global checkpoint_create calls in parallel sweep harnesses',\n328:         'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n329:       ],\n330:       severity: 'medium',\n331:     },\n332:     CHECKPOINT_CREATE_DUPLICATE_NAME: {\n333:       hint: 'A checkpoint with this name already exists.',\n334:       actions: [\n335:         'Use a unique checkpoint name',\n336:         'Run checkpoint_list() to inspect existing names',\n337:         'Delete the existing checkpoint only if rollback policy allows it',\n338:       ],\n339:       severity: 'low',\n340:     },\n\n(Showing lines 1-340 of 918. Use offset=341 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\nimport { executeAutoPromotion } from '../lib/search/auto-promotion.js';\nimport { recordSelection } from '../lib/search/learned-feedback.js';\nimport { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\nimport { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\nimport { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\nimport { executeAutoPromotion } from '../lib/search/auto-promotion.js';\nimport { recordSelection } from '../lib/search/learned-feedback.js';\nimport { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\nimport { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\nimport { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { requireDb, toErrorMessage } from '../utils/index.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\n\n// Standardized response structure\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n\n// Shared handler types\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint listing (checkpoint_list)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Feature catalog: Checkpoint deletion (checkpoint_delete)\n// Feature catalog: Checkpoint delete confirmName safety\n\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface CheckpointCreateArgs {\n  name: string;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n}\n\ninterface CheckpointListArgs {\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n}\n\ninterface CheckpointRestoreArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  clearExisting?: boolean;\n}\n\ninterface CheckpointDeleteArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  confirmName: string;\n}\n\ninterface CheckpointScopeArgs {\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface MemoryValidateArgs {\n  id: number | string;\n  wasUseful: boolean;\n  queryId?: string;\n  queryTerms?: string[];\n  resultRank?: number;\n  totalResultsShown?: number;\n  searchMode?: string;\n  intent?: string;\n  sessionId?: string;\n  notes?: string;\n}\n\ninterface ValidationResult {\n  confidence: number;\n  validationCount: number;\n  positiveValidationCount: number;\n  promotionEligible: boolean;\n}\n\nfunction resolveValidationQueryText(\n  database: ReturnType<typeof requireDb>,\n  queryId?: string,\n): string | null {\n  if (typeof queryId !== 'string') {\n    return null;\n  }\n\n  const normalizedQueryId = queryId.trim();\n  if (normalizedQueryId.length === 0) {\n    return null;\n  }\n\n  if (/\\s/.test(normalizedQueryId)) {\n    return normalizedQueryId;\n  }\n\n  const consumptionMatch = normalizedQueryId.match(/^(?:consumption:)?(\\d+)$/);\n  if (!consumptionMatch) {\n    return null;\n  }\n\n  const consumptionLogTable = database.prepare(`\n    SELECT 1\n    FROM sqlite_master\n    WHERE type = 'table'\n      AND name = 'consumption_log'\n    LIMIT 1\n  `).get();\n  if (!consumptionLogTable) {\n    return null;\n  }\n\n  // The clean consumption_log schema stores only a query fingerprint; raw\n  // query text exists solely on unmigrated legacy tables. Without the column\n  // there is nothing to resolve, and selecting it would throw.\n  const columns = database.prepare(`PRAGMA table_info(consumption_log)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'query_text')) {\n    return null;\n  }\n\n  const row = database.prepare(`\n    SELECT query_text\n    FROM consumption_log\n    WHERE id = ?\n      AND query_text IS NOT NULL\n      AND TRIM(query_text) != ''\n    LIMIT 1\n  `).get(Number.parseInt(consumptionMatch[1], 10)) as { query_text?: string } | undefined;\n\n  return typeof row?.query_text === 'string' && row.query_text.trim().length > 0\n    ? row.query_text\n    : null;\n}\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('id must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction parseCheckpointMetadata(rawMetadata: unknown): Record<string, unknown> {\n  if (!rawMetadata) {\n    return {};\n  }\n\n  if (typeof rawMetadata === 'string') {\n    try {\n      const parsed = JSON.parse(rawMetadata);\n      return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n        ? parsed as Record<string, unknown>\n        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n\n  return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n    ? rawMetadata as Record<string, unknown>\n    : {};\n}\n\nfunction validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n  const validateValue = (\n    value: string | undefined,\n    field: keyof CheckpointScopeArgs,\n    options: { trim?: boolean } = {},\n  ): string | undefined => {\n    if (value === undefined) {\n      return undefined;\n    }\n    if (typeof value !== 'string') {\n      throw new Error(`${field} must be a string`);\n    }\n    return options.trim ? value.trim() : value;\n  };\n\n  const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n  const userId = validateValue(args.userId, 'userId');\n  const agentId = validateValue(args.agentId, 'agentId');\n  const hasActorScope = userId !== undefined || agentId !== undefined;\n\n  if (\n    hasActorScope\n    && tenantId !== undefined\n    && tenantId.trim().length === 0\n  ) {\n    throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n  }\n\n  return {\n    tenantId: tenantId && tenantId.length > 0 ? tenantId : undefined,\n    userId,\n    agentId,\n  };\n}\n\nfunction hasCheckpointScope(scope: CheckpointScopeArgs): boolean {\n  return (\n    scope.tenantId !== undefined\n    || scope.userId !== undefined\n    || scope.agentId !== undefined\n  );\n}\n\nfunction requiresCheckpointTenant(scope: CheckpointScopeArgs): boolean {\n  return scope.tenantId === undefined && (\n    scope.userId !== undefined\n    || scope.agentId !== undefined\n  );\n}\n\nfunction mergeCheckpointScopeMetadata(\n  metadata: Record<string, unknown> | undefined,\n  scope: CheckpointScopeArgs,\n): Record<string, unknown> {\n  return {\n    ...(metadata ?? {}),\n    ...(scope.tenantId !== undefined ? { tenantId: scope.tenantId } : {}),\n    ...(scope.userId !== undefined ? { userId: scope.userId } : {}),\n    ...(scope.agentId !== undefined ? { agentId: scope.agentId } : {}),\n  };\n}\n\nfunction checkpointMatchesScope(rawMetadata: unknown, scope: CheckpointScopeArgs): boolean {\n  const metadata = parseCheckpointMetadata(rawMetadata);\n  const matchesScopeField = (field: keyof CheckpointScopeArgs): boolean => {\n    const expected = scope[field];\n    if (expected === undefined) {\n      return true;\n    }\n    const actual = metadata[field];\n    return actual === undefined || actual === expected;\n  };\n\n  return (\n    matchesScopeField('tenantId') &&\n    matchesScopeField('userId') &&\n    matchesScopeField('agentId')\n  );\n}\n\nfunction checkpointScopeDetails(scope: CheckpointScopeArgs): Record<string, string> {\n  const details: Record<string, string> = {};\n  if (scope.tenantId !== undefined) {\n    details.tenantId = scope.tenantId;\n  }\n  if (scope.userId !== undefined) {\n    details.userId = scope.userId;\n  }\n  if (scope.agentId !== undefined) {\n    details.agentId = scope.agentId;\n  }\n  return details;\n}\n\nfunction createCheckpointScopeValidationError(\n  tool: 'checkpoint_create' | 'checkpoint_list' | 'checkpoint_restore' | 'checkpoint_delete',\n): MCPResponse {\n  return createMCPErrorResponse({\n    tool,\n    error: 'tenantId is required when userId or agentId is provided.',\n    code: 'CHECKPOINT_SCOPE_TENANT_REQUIRED',\n    details: {\n      reason: 'checkpoint_scope_tenant_required',\n    },\n    recovery: {\n      hint: 'Retry with tenantId included for governed checkpoint access.',\n    },\n  });\n}\n\nfunction createCheckpointCreateFailureResponse(\n  error: unknown,\n  context: { name: string; specFolder: string | null },\n  startTime: number,\n): MCPResponse {\n  const typedError = error instanceof checkpoints.CheckpointCreateError ? error : null;\n  const code = typedError?.code ?? 'CHECKPOINT_CREATE_FAILED';\n  const message = typedError?.message ?? `Checkpoint creation failed: ${toErrorMessage(error)}`;\n\n  const recoveryByCode: Record<string, { hint: string; actions: string[]; severity: string }> = {\n    CHECKPOINT_CREATE_SQLITE_BUSY: {\n      hint: 'SQLite was busy while creating the checkpoint. Retry after active writes finish.',\n      actions: [\n        'Retry checkpoint_create after concurrent memory writes complete',\n        'For sweep harnesses, prefer specFolder-scoped checkpoints or includeEmbeddings=false when rollback semantics allow',\n        'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n      ],\n      severity: 'medium',\n    },\n    CHECKPOINT_CREATE_SQLITE_LOCKED: {\n      hint: 'SQLite was locked by another operation while creating the checkpoint.',\n      actions: [\n        'Wait for the active lifecycle operation to finish, then retry',\n        'Serialize global checkpoint_create calls in parallel sweep harnesses',\n        'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n      ],\n      severity: 'medium',\n    },\n    CHECKPOINT_CREATE_DUPLICATE_NAME: {\n      hint: 'A checkpoint with this name already exists.',\n      actions: [\n        'Use a unique checkpoint name',\n        'Run checkpoint_list() to inspect existing names',\n        'Delete the existing checkpoint only if rollback policy allows it',\n      ],\n      severity: 'low',\n    },","lineStart":1,"lineEnd":340,"totalLines":918,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","time":{"start":1781764018438,"end":1781764018442}},"metadata":{"openai":{"itemId":"fc_0f62038bf7812bee016a338fb190bc8191857e522489a821fe"}},"id":"prt_ed9695056001SPmBe4pMCd6o6f","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed969147b001guuoGjbpQJWHum"}}
{"type":"tool_use","timestamp":1781764019541,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_BPGWwI7PLHbDs84eT0JYlvEq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n11: \n12: import type { MCPResponse } from './types.js';\n13: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n14: \n15: /** Handle the memory_retention_sweep MCP tool request. */\n16: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n17:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n18:   await checkDatabaseUpdated();\n19: \n20:   const database = vectorIndex.getDb();\n21:   if (!database) {\n22:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n23:     return createMCPErrorResponse({\n24:       tool: 'memory_retention_sweep',\n25:       error: 'Retention sweep aborted: database unavailable',\n26:       code: 'E_DB_UNAVAILABLE',\n27:       details: {\n28:         dryRun: args?.dryRun === true,\n29:       },\n30:       recovery: {\n31:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n32:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n33:         severity: 'error',\n34:       },\n35:     });\n36:   }\n37: \n38:   try {\n39:     const result = runMemoryRetentionSweep(database, {\n40:       dryRun: args?.dryRun === true,\n41:       feedbackRetention: args?.feedbackRetention,\n42:     });\n43:     const protectedSuffix = result.protectedCount > 0\n44:       ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n45:       : '';\n46:     const summary = result.dryRun\n47:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n48:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n49: \n50:     const hints: string[] = [];\n51:     if (result.ledgerRecorded === false) {\n52:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n53:     }\n54:     if (result.dryRun && result.candidates.length > 0) {\n55:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n56:     }\n57:     recordMaintenanceRun('memory_retention_sweep', {\n58:       status: 'success',\n59:       counts: {\n60:         swept: result.swept,\n61:         retained: result.retained,\n62:         candidates: result.candidates.length,\n63:         protectedCount: result.protectedCount,\n64:       },\n65:       staleCandidates: result.candidates.length,\n66:     });\n67: \n68:     return createMCPSuccessResponse({\n69:       tool: 'memory_retention_sweep',\n70:       summary,\n71:       data: {\n72:         swept: result.swept,\n73:         retained: result.retained,\n74:         dryRun: result.dryRun,\n75:         durationMs: result.durationMs,\n76:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n77:           id: candidate.id,\n78:           deleteAfter: candidate.deleteAfter,\n79:           specFolder: candidate.specFolder,\n80:           filePath: candidate.filePath,\n81:         })),\n82:         deletedIds: result.deletedIds,\n83:         protectedCount: result.protectedCount,\n84:         protectedIds: result.protectedIds,\n85:         ledgerRecorded: result.ledgerRecorded,\n86:         ...(result.feedbackRetention ? {\n87:           feedbackRetention: {\n88:             mode: result.feedbackRetention.mode,\n89:             activeGatePassed: result.feedbackRetention.activeGatePassed,\n90:             activeBlocked: result.feedbackRetention.activeBlocked,\n91:             auditCount: result.feedbackRetention.auditCount,\n92:             protectedCount: result.feedbackRetention.protectedIds.length,\n93:             extendedCount: result.feedbackRetention.extendedIds.length,\n94:             deletedCount: result.feedbackRetention.deletedIds.length,\n95:           },\n96:           extendedIds: result.feedbackRetention.extendedIds,\n97:         } : {}),\n98:       },\n99:       hints,\n100:     });\n101:   } catch (error: unknown) {\n102:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n103:     return createMCPErrorResponse({\n104:       tool: 'memory_retention_sweep',\n105:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n106:       code: 'E_RETENTION_SWEEP_FAILED',\n107:       details: {\n108:         dryRun: args?.dryRun === true,\n109:       },\n110:       recovery: {\n111:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n112:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n113:         severity: 'error',\n114:       },\n115:     });\n116:   }\n117: }\n118: \n119: export { handleMemoryRetentionSweep };\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, {\n      dryRun: args?.dryRun === true,\n      feedbackRetention: args?.feedbackRetention,\n    });\n    const protectedSuffix = result.protectedCount > 0\n      ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n      : '';\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n    recordMaintenanceRun('memory_retention_sweep', {\n      status: 'success',\n      counts: {\n        swept: result.swept,\n        retained: result.retained,\n        candidates: result.candidates.length,\n        protectedCount: result.protectedCount,\n      },\n      staleCandidates: result.candidates.length,\n    });\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        protectedCount: result.protectedCount,\n        protectedIds: result.protectedIds,\n        ledgerRecorded: result.ledgerRecorded,\n        ...(result.feedbackRetention ? {\n          feedbackRetention: {\n            mode: result.feedbackRetention.mode,\n            activeGatePassed: result.feedbackRetention.activeGatePassed,\n            activeBlocked: result.feedbackRetention.activeBlocked,\n            auditCount: result.feedbackRetention.auditCount,\n            protectedCount: result.feedbackRetention.protectedIds.length,\n            extendedCount: result.feedbackRetention.extendedIds.length,\n            deletedCount: result.feedbackRetention.deletedIds.length,\n          },\n          extendedIds: result.feedbackRetention.extendedIds,\n        } : {}),\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":119,"totalLines":119,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1781764019536,"end":1781764019540}},"metadata":{"openai":{"itemId":"fc_0f62038bf7812bee016a338fb190c4819187360ecb4d9fe194"}},"id":"prt_ed96954d0001G1VHYaxsnM0XSx","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed969147b001guuoGjbpQJWHum"}}
{"type":"tool_use","timestamp":1781764019833,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_rRYyzZ6LXZO2NyWMsaD5yyIE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Embedding Reconcile Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n11: \n12: import type { MCPResponse } from './types.js';\n13: import type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n14: \n15: /** Handle the memory_embedding_reconcile MCP tool request. */\n16: async function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n17:   await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n18:   await checkDatabaseUpdated();\n19: \n20:   const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n21: \n22:   const database = vectorIndex.getDb();\n23:   if (!database) {\n24:     recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n25:     return createMCPErrorResponse({\n26:       tool: 'memory_embedding_reconcile',\n27:       error: 'Embedding reconcile aborted: database unavailable',\n28:       code: 'E_DB_UNAVAILABLE',\n29:       details: { mode },\n30:       recovery: {\n31:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n32:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n33:         severity: 'error',\n34:       },\n35:     });\n36:   }\n37: \n38:   // Best-effort: guarantee the active shard is attached as active_vec. The\n39:   // reconcile verifies it and fails closed if it is still unavailable.\n40:   // Attach (or re-point) the canonical active shard as active_vec. This is the\n41:   // path authority: it detaches any wrong/stale shard and attaches the shard\n42:   // resolved from the active embedder profile. For apply, a failed attach is\n43:   // FATAL — proceeding could mutate rows against a stale same-profile shard\n44:   // (the metadata-only guard can't tell two same-profile shard files apart).\n45:   try {\n46:     vectorIndex.attachActiveVectorShardForActiveProfile(database);\n47:   } catch (attachErr: unknown) {\n48:     if (mode === 'apply') {\n49:       recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n50:       return createMCPErrorResponse({\n51:         tool: 'memory_embedding_reconcile',\n52:         error: `Embedding reconcile aborted: could not attach the active vector shard (${toErrorMessage(attachErr)})`,\n53:         code: 'E_ACTIVE_SHARD_UNVERIFIED',\n54:         details: { mode },\n55:         recovery: {\n56:           hint: 'Ensure the active embedder shard exists and the daemon is healthy, then retry; restart the MCP server if it persists.',\n57:           actions: ['Run embedder_status()', 'Run memory_health()'],\n58:           severity: 'error',\n59:         },\n60:       });\n61:     }\n62:     // dry-run: non-fatal; verifyActiveShard reports activeShardVerified=false.\n63:   }\n64: \n65:   try {\n66:     const result = runMemoryEmbeddingReconcile(database, args ?? {});\n67:     const stale = result.buckets.vector_present_status_stale.count;\n68:     const missing = result.buckets.missing_active_vector_retry_eligible.count;\n69: \n70:     const coverageReset = result.applied?.successCoverageReset ?? 0;\n71:     const summary = result.mode === 'apply'\n72:       ? `Reconciled ${result.applied?.reconciledToSuccess ?? 0} vector-present row(s) to success; reset ${result.applied?.resetToRetry ?? 0} missing-vector row(s) to retry${coverageReset ? `; repaired ${coverageReset} success-coverage row(s) to retry` : ''}`\n73:       : `Dry-run: ${stale} vector-present stale row(s), ${missing} missing-vector retry-eligible; no rows mutated`;\n74: \n75:     const hints: string[] = [];\n76:     if (!result.safety.activeShardVerified) {\n77:       hints.push(`Active shard not verified (${result.safety.reason ?? 'unknown'}); no rows were counted or mutated.`);\n78:     } else if (result.mode === 'dry-run' && stale > 0) {\n79:       hints.push('Run memory_embedding_reconcile({ mode: \"apply\" }) to converge embedding_status to success.');\n80:     }\n81:     recordMaintenanceRun('memory_embedding_reconcile', {\n82:       status: 'success',\n83:       counts: {\n84:         vectorPresentStatusStale: stale,\n85:         missingActiveVectorRetryEligible: missing,\n86:         reconciledToSuccess: result.applied?.reconciledToSuccess ?? 0,\n87:         resetToRetry: result.applied?.resetToRetry ?? 0,\n88:         successCoverageReset: coverageReset,\n89:       },\n90:       staleCandidates: stale + missing,\n91:     });\n92: \n93:     return createMCPSuccessResponse({\n94:       tool: 'memory_embedding_reconcile',\n95:       summary,\n96:       data: result,\n97:       hints,\n98:     });\n99:   } catch (error: unknown) {\n100:     // Health reads last-run state; a failed run must be visible there, not\n101:     // only in the error response of the call that happened to observe it.\n102:     recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n103:     if (error instanceof ActiveShardGuardError) {\n104:       return createMCPErrorResponse({\n105:         tool: 'memory_embedding_reconcile',\n106:         error: error.message,\n107:         code: error.code,\n108:         details: { mode },\n109:         recovery: {\n110:           hint: 'Ensure the active embedder shard is attached and matches the active pointer; restart the MCP server if needed.',\n111:           actions: ['Run embedder_status()', 'Run memory_health()'],\n112:           severity: 'error',\n113:         },\n114:       });\n115:     }\n116:     return createMCPErrorResponse({\n117:       tool: 'memory_embedding_reconcile',\n118:       error: `Embedding reconcile failed: ${toErrorMessage(error)}`,\n119:       code: 'E_EMBEDDING_RECONCILE_FAILED',\n120:       details: { mode },\n121:       recovery: {\n122:         hint: 'Inspect memory_index and the active vector shard state, then retry in dry-run.',\n123:         actions: ['Run memory_health()', 'Retry memory_embedding_reconcile({ mode: \"dry-run\" })'],\n124:         severity: 'error',\n125:       },\n126:     });\n127:   }\n128: }\n129: \n130: export { handleMemoryEmbeddingReconcile };\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n\n/** Handle the memory_embedding_reconcile MCP tool request. */\nasync function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n  await checkDatabaseUpdated();\n\n  const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n\n/** Handle the memory_embedding_reconcile MCP tool request. */\nasync function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n  await checkDatabaseUpdated();\n\n  const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_embedding_reconcile',\n      error: 'Embedding reconcile aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: { mode },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Best-effort: guarantee the active shard is attached as active_vec. The\n  // reconcile verifies it and fails closed if it is still unavailable.\n  // Attach (or re-point) the canonical active shard as active_vec. This is the\n  // path authority: it detaches any wrong/stale shard and attaches the shard\n  // resolved from the active embedder profile. For apply, a failed attach is\n  // FATAL — proceeding could mutate rows against a stale same-profile shard\n  // (the metadata-only guard can't tell two same-profile shard files apart).\n  try {\n    vectorIndex.attachActiveVectorShardForActiveProfile(database);\n  } catch (attachErr: unknown) {\n    if (mode === 'apply') {\n      recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n      return createMCPErrorResponse({\n        tool: 'memory_embedding_reconcile',\n        error: `Embedding reconcile aborted: could not attach the active vector shard (${toErrorMessage(attachErr)})`,\n        code: 'E_ACTIVE_SHARD_UNVERIFIED',\n        details: { mode },\n        recovery: {\n          hint: 'Ensure the active embedder shard exists and the daemon is healthy, then retry; restart the MCP server if it persists.',\n          actions: ['Run embedder_status()', 'Run memory_health()'],\n          severity: 'error',\n        },\n      });\n    }\n    // dry-run: non-fatal; verifyActiveShard reports activeShardVerified=false.\n  }\n\n  try {\n    const result = runMemoryEmbeddingReconcile(database, args ?? {});\n    const stale = result.buckets.vector_present_status_stale.count;\n    const missing = result.buckets.missing_active_vector_retry_eligible.count;\n\n    const coverageReset = result.applied?.successCoverageReset ?? 0;\n    const summary = result.mode === 'apply'\n      ? `Reconciled ${result.applied?.reconciledToSuccess ?? 0} vector-present row(s) to success; reset ${result.applied?.resetToRetry ?? 0} missing-vector row(s) to retry${coverageReset ? `; repaired ${coverageReset} success-coverage row(s) to retry` : ''}`\n      : `Dry-run: ${stale} vector-present stale row(s), ${missing} missing-vector retry-eligible; no rows mutated`;\n\n    const hints: string[] = [];\n    if (!result.safety.activeShardVerified) {\n      hints.push(`Active shard not verified (${result.safety.reason ?? 'unknown'}); no rows were counted or mutated.`);\n    } else if (result.mode === 'dry-run' && stale > 0) {\n      hints.push('Run memory_embedding_reconcile({ mode: \"apply\" }) to converge embedding_status to success.');\n    }\n    recordMaintenanceRun('memory_embedding_reconcile', {\n      status: 'success',\n      counts: {\n        vectorPresentStatusStale: stale,\n        missingActiveVectorRetryEligible: missing,\n        reconciledToSuccess: result.applied?.reconciledToSuccess ?? 0,\n        resetToRetry: result.applied?.resetToRetry ?? 0,\n        successCoverageReset: coverageReset,\n      },\n      staleCandidates: stale + missing,\n    });\n\n    return createMCPSuccessResponse({\n      tool: 'memory_embedding_reconcile',\n      summary,\n      data: result,\n      hints,\n    });\n  } catch (error: unknown) {\n    // Health reads last-run state; a failed run must be visible there, not\n    // only in the error response of the call that happened to observe it.\n    recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n    if (error instanceof ActiveShardGuardError) {\n      return createMCPErrorResponse({\n        tool: 'memory_embedding_reconcile',\n        error: error.message,\n        code: error.code,\n        details: { mode },\n        recovery: {\n          hint: 'Ensure the active embedder shard is attached and matches the active pointer; restart the MCP server if needed.',\n          actions: ['Run embedder_status()', 'Run memory_health()'],\n          severity: 'error',\n        },\n      });\n    }\n    return createMCPErrorResponse({\n      tool: 'memory_embedding_reconcile',\n      error: `Embedding reconcile failed: ${toErrorMessage(error)}`,\n      code: 'E_EMBEDDING_RECONCILE_FAILED',\n      details: { mode },\n      recovery: {\n        hint: 'Inspect memory_index and the active vector shard state, then retry in dry-run.',\n        actions: ['Run memory_health()', 'Retry memory_embedding_reconcile({ mode: \"dry-run\" })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryEmbeddingReconcile };","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","time":{"start":1781764019823,"end":1781764019831}},"metadata":{"openai":{"itemId":"fc_0f62038bf7812bee016a338fb190cc8191ab4185afea7cdce2"}},"id":"prt_ed96955ac0017O0WDKpfFPnYYG","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed969147b001guuoGjbpQJWHum"}}
