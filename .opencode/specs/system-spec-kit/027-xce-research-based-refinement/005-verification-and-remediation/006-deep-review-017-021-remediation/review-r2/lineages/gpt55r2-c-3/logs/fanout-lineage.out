{"type":"tool_use","timestamp":1781762012624,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_araTGehApZP9TpALibozSJ58","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // --------------------------------------------------------------------------\n3: // COMPONENT: Spec Memory CLI Shim\n4: // PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n5: // --------------------------------------------------------------------------\n6: 'use strict';\n7: \n8: const fs = require('fs');\n9: const path = require('path');\n10: const crypto = require('crypto');\n11: const { spawnSync } = require('child_process');\n12: \n13: const opencodeDir = path.resolve(__dirname, '..');\n14: const mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\n15: const cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\n16: const sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\n17: const defaultSocketDir = '/tmp/mk-spec-memory';\n18: const socketFileName = 'daemon-ipc.sock';\n19: const allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n20: \n21: function fail(message) {\n22:   process.stderr.write(`${message}\\n`);\n23:   process.exit(69);\n24: }\n25: \n26: // Recursively collects the CLI's compiled-source surface (entry, local schema\n27: // imports, tsconfig) so new files under candidate directories are watched\n28: // without editing this list. Must stay in lock-step with\n29: // scripts/finalize-dist.mjs, which writes the matching hash at build time.\n30: function sourceCandidates() {\n31:   const candidates = [\n32:     path.join(mcpServerDir, 'spec-memory-cli.ts'),\n33:     path.join(mcpServerDir, 'tool-schemas.ts'),\n34:     path.join(mcpServerDir, 'tsconfig.json'),\n35:     path.join(mcpServerDir, 'schemas'),\n36:   ];\n37:   const files = [];\n38: \n39:   const visit = (candidate) => {\n40:     if (!fs.existsSync(candidate)) return;\n41:     const stat = fs.statSync(candidate);\n42:     if (stat.isDirectory()) {\n43:       for (const entry of fs.readdirSync(candidate)) {\n44:         visit(path.join(candidate, entry));\n45:       }\n46:       return;\n47:     }\n48:     if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n49:       files.push(candidate);\n50:     }\n51:   };\n52: \n53:   for (const candidate of candidates) visit(candidate);\n54:   return files;\n55: }\n56: \n57: function hashSourceFiles(existingSources) {\n58:   const hash = crypto.createHash('sha256');\n59:   for (const filePath of [...existingSources].sort()) {\n60:     hash.update(path.relative(mcpServerDir, filePath));\n61:     hash.update('\\0');\n62:     hash.update(fs.readFileSync(filePath));\n63:     hash.update('\\0');\n64:   }\n65:   return hash.digest('hex');\n66: }\n67: \n68: function readStoredSourceHash() {\n69:   try {\n70:     const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n71:     return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n72:   } catch {\n73:     return null;\n74:   }\n75: }\n76: \n77: function writeStoredSourceHash(sourceHash) {\n78:   try {\n79:     fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n80:     fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n81:   } catch {\n82:     // Freshness metadata is an optimization; stale detection remains conservative.\n83:   }\n84: }\n85: \n86: function ensureFreshDist() {\n87:   if (!fs.existsSync(cliDist)) {\n88:     fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n89:   }\n90:   if (allowStale) return;\n91:   const existingSources = sourceCandidates();\n92:   if (existingSources.length === 0) return;\n93:   const currentSourceHash = hashSourceFiles(existingSources);\n94:   if (readStoredSourceHash() === currentSourceHash) return;\n95:   const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n96:   const distMtime = fs.statSync(cliDist).mtimeMs;\n97:   if (newestSourceMtime > distMtime) {\n98:     fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n99:   }\n100:   writeStoredSourceHash(currentSourceHash);\n101: }\n102: \n103: function ensureSocketDir() {\n104:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n105:     process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n106:   }\n107:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n108:   if (socketDir.startsWith('tcp://')) return;\n109:   fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n110:   const socketPath = path.join(path.resolve(socketDir), socketFileName);\n111:   if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n112:     fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n113:   }\n114: }\n115: \n116: ensureSocketDir();\n117: ensureFreshDist();\n118: \n119: const result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n120:   cwd: path.dirname(opencodeDir),\n121:   env: process.env,\n122:   stdio: 'inherit',\n123: });\n124: \n125: if (result.error) {\n126:   process.stderr.write(`${result.error.message}\\n`);\n127:   process.exit(75);\n128: }\n129: \n130: process.exit(result.status ?? 1);\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","text":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n\nfunction fail(message) {\n  process.stderr.write(`${message}\\n`);\n  process.exit(69);\n}\n\n// Recursively collects the CLI's compiled-source surface (entry, local schema\n// imports, tsconfig) so new files under candidate directories are watched\n// without editing this list. Must stay in lock-step with\n// scripts/finalize-dist.mjs, which writes the matching hash at build time.\nfunction sourceCandidates() {\n  const candidates = [\n    path.join(mcpServerDir, 'spec-memory-cli.ts'),\n    path.join(mcpServerDir, 'tool-schemas.ts'),\n    path.join(mcpServerDir, 'tsconfig.json'),\n    path.join(mcpServerDir, 'schemas'),\n  ];\n  const files = [];\n\n  const visit = (candidate) => {\n    if (!fs.existsSync(candidate)) return;\n    const stat = fs.statSync(candidate);\n    if (stat.isDirectory()) {\n      for (const entry of fs.readdirSync(candidate)) {\n        visit(path.join(candidate, entry));\n      }\n      return;\n    }\n    if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n      files.push(candidate);\n    }\n  };\n\n  for (const candidate of candidates) visit(candidate);\n  return files;\n}\n\nfunction hashSourceFiles(existingSources) {\n  const hash = crypto.createHash('sha256');\n  for (const filePath of [...existingSources].sort()) {\n    hash.update(path.relative(mcpServerDir, filePath));\n    hash.update('\\0');\n    hash.update(fs.readFileSync(filePath));\n    hash.update('\\0');\n  }\n  return hash.digest('hex');\n}\n\nfunction readStoredSourceHash() {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n    return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction writeStoredSourceHash(sourceHash) {\n  try {\n    fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n    fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n  } catch {\n    // Freshness metadata is an optimization; stale detection remains conservative.\n  }\n}\n\nfunction ensureFreshDist() {\n  if (!fs.existsSync(cliDist)) {\n    fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n  }\n  if (allowStale) return;\n  const existingSources = sourceCandidates();\n  if (existingSources.length === 0) return;\n  const currentSourceHash = hashSourceFiles(existingSources);\n  if (readStoredSourceHash() === currentSourceHash) return;\n  const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n  const distMtime = fs.statSync(cliDist).mtimeMs;\n  if (newestSourceMtime > distMtime) {\n    fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n  }\n  writeStoredSourceHash(currentSourceHash);\n}\n\nfunction ensureSocketDir() {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (socketDir.startsWith('tcp://')) return;\n  fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  const socketPath = path.join(path.resolve(socketDir), socketFileName);\n  if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n    fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n  }\n}\n\nensureSocketDir();\nensureFreshDist();\n\nconst result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n  cwd: path.dirname(opencodeDir),\n  env: process.env,\n  stdio: 'inherit',\n});\n\nif (result.error) {\n  process.stderr.write(`${result.error.message}\\n`);\n  process.exit(75);\n}\n\nprocess.exit(result.status ?? 1);","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/bin/spec-memory.cjs","time":{"start":1781762012616,"end":1781762012623}},"metadata":{"openai":{"itemId":"fc_0ea88119742d1da2016a3387dc8828819185545fe6f4fc13ee"}},"id":"prt_ed94ab5a2001gUAOOzEm1Pzt2W","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94a8622001CH88ScXqbsbwyu"}}
{"type":"tool_use","timestamp":1781762012645,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_ki8kwzIDLGLHvfTEWvDIsXx1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   readMaintenanceMarker,\n37:   shouldAdoptDespiteProbe,\n38:   releaseRespawnLockFile,\n39:   sampleProcessTreeRssMb,\n40:   shouldAbortRelaunchOnFire,\n41:   shouldSkipLaunch,\n42:   signalProcess,\n43:   superviseChildExit,\n44:   waitForPidExit,\n45: } = mss;\n46: \n47: const root = path.resolve(__dirname, '..', '..');\n48: const opencodeDir = path.join(root, '.opencode');\n49: \n50: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n51: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n52: // Minimal parser — no external dependency.\n53: function loadEnvFile(filePath) {\n54:   if (!fs.existsSync(filePath)) return 0;\n55:   let count = 0;\n56:   const raw = fs.readFileSync(filePath, 'utf8');\n57:   for (const line of raw.split('\\n')) {\n58:     const trimmed = line.trim();\n59:     if (!trimmed || trimmed.startsWith('#')) continue;\n60:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n61:     if (!m) continue;\n62:     const key = m[1];\n63:     let val = m[2];\n64:     // Strip matching outer quotes (single or double)\n65:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n66:       val = val.slice(1, -1);\n67:     }\n68:     if (!(key in process.env)) {\n69:       process.env[key] = val;\n70:       count++;\n71:     }\n72:   }\n73:   return count;\n74: }\n75: \n76: function isStrictModeDisabled(value) {\n77:   if (value === undefined || value === null) return false;\n78:   const v = String(value).trim().toLowerCase();\n79:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n80: }\n81: \n82: let skillsDir = path.join(opencodeDir, 'skills');\n83: let legacySkillDir = path.join(opencodeDir, 'skill');\n84: let kitDir = path.join(skillsDir, 'system-spec-kit');\n85: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n86: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n87: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n88: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n89: let stateFile = path.join(dbDir, PID_FILE_NAME);\n90: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n91: \n92: const rel = (p) => path.relative(root, p) || '.';\n93: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n94: const now = () => new Date().toISOString();\n95: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n96: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n97: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n98: let childProcess = null;\n99: let ownerLeasePid = null;\n100: let leaseStartedAt = null;\n101: let launcherShutdownInProgress = false;\n102: let rssBreachSelfExitInProgress = false;\n103: let rssWatchdogTimer = null;\n104: let crashLoopGuard = null;\n105: let supervisorRelaunchTimer = null;\n106: // The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n107: // launcher's parent. When the host disposes its session the launcher is orphaned and its\n108: // ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n109: // path can tell \"owning runtime went away\" apart from a genuine daemon crash.\n110: const LAUNCHER_INITIAL_PPID = process.ppid;\n111: let ownerLeaseHeartbeatTimer = null;\n112: let ownerLeaseRequired = true;\n113: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n114: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n115: // orphaned sidecar after the child has already exited.\n116: let lastKnownDescendantPids = [];\n117: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n118: const durableWriteWarnings = new Set();\n119: // Daemon exit code meaning \"another live process holds the database\n120: // single-writer lock\". Never counts toward the crash loop: the right move is\n121: // bridging to the live owner (or a bounded retry while a maintenance script\n122: // finishes), not relaunching a doomed second writer. Mirrored in\n123: // mcp_server context-server (EXIT_DB_LOCK_HELD).\n124: const EXIT_DB_LOCK_HELD = 86;\n125: const DB_LOCK_HELD_MAX_RETRIES = 3;\n126: let dbLockHeldRetries = 0;\n127: \n128: function log(message) {\n129:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n130:   persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n131: }\n132: \n133: function isDurableWriteUnavailable(error) {\n134:   const code = error && typeof error === 'object' ? error.code : undefined;\n135:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n136: }\n137: \n138: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n139:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n140:   const key = `${operation}:${targetPath}:${code}`;\n141:   if (durableWriteWarnings.has(key)) return;\n142:   durableWriteWarnings.add(key);\n143:   const detail = error instanceof Error ? error.message : String(error ?? code);\n144:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n145: }\n146: \n147: // Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n148: // ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n149: // durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n150: // launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n151: // grow without bound.\n152: function launcherLogIsEnabled(env = process.env) {\n153:   return env.SPECKIT_LAUNCHER_LOG !== '0';\n154: }\n155: function launcherLogMaxBytes(env = process.env) {\n156:   return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n157: }\n158: function resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n159:   const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n160:   return typeof override === 'string' && override.trim()\n161:     ? override.trim()\n162:     : path.join(baseDir, '.mk-spec-memory-launcher.log');\n163: }\n164: function shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n165:   return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n166: }\n167: function persistLauncherLogLine(line) {\n168:   if (!launcherLogIsEnabled()) return;\n169:   let target;\n170:   try {\n171:     target = resolveLauncherLogPath();\n172:     try {\n173:       const { size } = fs.statSync(target);\n174:       if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n175:         try {\n176:           // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n177:           // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n178:           // suffix still rotates instead of renaming the file onto itself and growing without bound.\n179:           const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n180:           fs.renameSync(target, rotated);\n181:         } catch {\n182:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n183:         }\n184:       }\n185:     } catch (statErr) {\n186:       if (statErr.code !== 'ENOENT') throw statErr;\n187:     }\n188:     fs.appendFileSync(target, line, { mode: 0o600 });\n189:   } catch (error) {\n190:     if (target && isDurableWriteUnavailable(error)) {\n191:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n192:       return;\n193:     }\n194:     // Logging must never break the launcher.\n195:   }\n196: }\n197: \n198: // Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n199: // When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n200: // (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n201: // not tear the shared backend out from under other sessions. A fresh session that finds the released\n202: // daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n203: // it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n204: // writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n205: // killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n206: // sweeper bounds any leak.\n207: function daemonReelectionEnabled(env = process.env) {\n208:   return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n209: }\n210: function contextServerSpawnIo(reelectionEnabled) {\n211:   return reelectionEnabled\n212:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n213:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n214: }\n215: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n216:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n217: }\n218: \n219: function cleanupTmpFile(tmpPath) {\n220:   try {\n221:     fs.unlinkSync(tmpPath);\n222:   } catch (error) {\n223:     if (error.code !== 'ENOENT') {\n224:       // Best-effort cleanup only; the original durable-write failure is more useful.\n225:     }\n226:   }\n227: }\n228: \n229: function writeAtomicJsonFile(targetPath, payload, operation) {\n230:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n231:   const tmp = `${currentPath}.tmp.${process.pid}`;\n232:   try {\n233:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n234:     fs.renameSync(tmp, currentPath);\n235:     return true;\n236:   } catch (error) {\n237:     cleanupTmpFile(tmp);\n238:     if (isDurableWriteUnavailable(error)) {\n239:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n240:       return false;\n241:     }\n242:     throw error;\n243:   }\n244: }\n245: \n246: function loadProjectEnvFiles() {\n247:   for (const fname of ['.env.local', '.env']) {\n248:     const p = path.join(root, fname);\n249:     if (fs.existsSync(p)) {\n250:       const n = loadEnvFile(p);\n251:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n252:     }\n253:   }\n254: }\n255: \n256: function parsePositiveInteger(value, fallback) {\n257:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n258:   const parsed = Number.parseInt(String(value).trim(), 10);\n259:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n260: }\n\n(Showing lines 1-260 of 1882. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;\nlet crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\n// The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n// launcher's parent. When the host disposes its session the launcher is orphaned and its\n// ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n// path can tell \"owning runtime went away\" apart from a genuine daemon crash.\nconst LAUNCHER_INITIAL_PPID = process.ppid;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n// Daemon exit code meaning \"another live process holds the database\n// single-writer lock\". Never counts toward the crash loop: the right move is\n// bridging to the live owner (or a bounded retry while a maintenance script\n// finishes), not relaunching a doomed second writer. Mirrored in\n// mcp_server context-server (EXIT_DB_LOCK_HELD).\nconst EXIT_DB_LOCK_HELD = 86;\nconst DB_LOCK_HELD_MAX_RETRIES = 3;\nlet dbLockHeldRetries = 0;\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n  persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\n// Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n// ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n// durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n// launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n// grow without bound.\nfunction launcherLogIsEnabled(env = process.env) {\n  return env.SPECKIT_LAUNCHER_LOG !== '0';\n}\nfunction launcherLogMaxBytes(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n}\nfunction resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n  const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n  return typeof override === 'string' && override.trim()\n    ? override.trim()\n    : path.join(baseDir, '.mk-spec-memory-launcher.log');\n}\nfunction shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n  return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n}\nfunction persistLauncherLogLine(line) {\n  if (!launcherLogIsEnabled()) return;\n  let target;\n  try {\n    target = resolveLauncherLogPath();\n    try {\n      const { size } = fs.statSync(target);\n      if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n        try {\n          // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n          // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n          // suffix still rotates instead of renaming the file onto itself and growing without bound.\n          const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n// (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n// not tear the shared backend out from under other sessions. A fresh session that finds the released\n// daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n// it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n// writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n// killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n// sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","lineStart":1,"lineEnd":260,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781762012641,"end":1781762012644}},"metadata":{"openai":{"itemId":"fc_0ea88119742d1da2016a3387dc88448191a4ac5bdc20aae998"}},"id":"prt_ed94ab5ca00102I3PUU675cYc3","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94a8622001CH88ScXqbsbwyu"}}
{"type":"tool_use","timestamp":1781762012651,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_NacJXhdRe3ulz3NEUYOyXANA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC Socket Server (multi-client launcher bridge)\n3: // ───────────────────────────────────────────────────────────────\n4: // Thin re-export of the canonical bridge logic. The bind/reclaim/serve\n5: // behaviour (including the race-safe stale-socket fence and the dir\n6: // ownership/mode hardening) is shared across every daemon launcher so\n7: // the security contract cannot drift between services. Per-service\n8: // socket/db PATHS remain owned by each package's own resolution code.\n9: \n10: export {\n11:   canUnlinkExistingSocket,\n12:   getIpcBridgeStats,\n13:   parseMaxClients,\n14:   resolveIpcSocketPath,\n15:   startIpcSocketServer,\n16: } from '@spec-kit/shared/ipc/socket-server.js';\n17: \n18: export type {\n19:   IpcBridgeStats,\n20:   IpcSocketServerHandle,\n21:   IpcSocketServerOptions,\n22: } from '@spec-kit/shared/ipc/socket-server.js';\n\n(End of file - total 22 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Thin re-export of the canonical bridge logic. The bind/reclaim/serve\n// behaviour (including the race-safe stale-socket fence and the dir\n// ownership/mode hardening) is shared across every daemon launcher so\n// the security contract cannot drift between services. Per-service\n// socket/db PATHS remain owned by each package's own resolution code.\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n} from '@spec-kit/shared/ipc/socket-server.js';\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Thin re-export of the canonical bridge logic. The bind/reclaim/serve\n// behaviour (including the race-safe stale-socket fence and the dir\n// ownership/mode hardening) is shared across every daemon launcher so\n// the security contract cannot drift between services. Per-service\n// socket/db PATHS remain owned by each package's own resolution code.\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n} from '@spec-kit/shared/ipc/socket-server.js';\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,\n  IpcSocketServerOptions,\n} from '@spec-kit/shared/ipc/socket-server.js';","lineStart":1,"lineEnd":22,"totalLines":22,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ipc/socket-server.ts","time":{"start":1781762012649,"end":1781762012651}},"metadata":{"openai":{"itemId":"fc_0ea88119742d1da2016a3387dc884c819192b4d8e16bb8e0f3"}},"id":"prt_ed94ab5e600103M387XadTev1P","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94a8622001CH88ScXqbsbwyu"}}
{"type":"tool_use","timestamp":1781762012666,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_DVkUXA7YETE410Ti7SqR6ikI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/launcher-idle-timeout.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/launcher-idle-timeout.ts</path>\n<type>file</type>\n<content>\n1: // MODULE: Launcher Idle Timeout Monitor\n2: \n3: const DEFAULT_IDLE_TIMEOUT_MIN = 30;\n4: const MS_PER_MINUTE = 60_000;\n5: const MIN_IDLE_CHECK_INTERVAL_MS = 1_000;\n6: const MAX_IDLE_CHECK_INTERVAL_MS = 60_000;\n7: \n8: type IntervalHandle = ReturnType<typeof setInterval>;\n9: type DataListener = (chunk: unknown) => void;\n10: type StdinLike = {\n11:   on(eventName: 'data', listener: DataListener): unknown;\n12:   off?: (eventName: 'data', listener: DataListener) => unknown;\n13:   removeListener?: (eventName: 'data', listener: DataListener) => unknown;\n14: };\n15: \n16: interface LauncherIdleMonitorOptions {\n17:   readonly serviceName: string;\n18:   readonly timeoutMinutesRaw?: string;\n19:   readonly stdin?: StdinLike | null;\n20:   readonly getActiveClientCount?: () => number;\n21:   readonly onIdle: () => void | Promise<void>;\n22:   readonly log?: (message: string) => void;\n23:   readonly now?: () => number;\n24:   readonly setIntervalFn?: (callback: () => void, ms: number) => IntervalHandle;\n25:   readonly clearIntervalFn?: (timer: IntervalHandle) => void;\n26: }\n27: \n28: interface LauncherIdleMonitor {\n29:   readonly timeoutMs: number | null;\n30:   readonly markActivity: () => void;\n31:   readonly stop: () => void;\n32: }\n33: \n34: function parseLauncherIdleTimeoutMs(rawValue = process.env.SPECKIT_LAUNCHER_IDLE_TIMEOUT_MIN): number | null {\n35:   const raw = rawValue === undefined || rawValue === null || String(rawValue).trim() === ''\n36:     ? String(DEFAULT_IDLE_TIMEOUT_MIN)\n37:     : String(rawValue).trim();\n38:   const parsedMinutes = Number(raw);\n39:   if (!Number.isFinite(parsedMinutes) || parsedMinutes < 0) {\n40:     return DEFAULT_IDLE_TIMEOUT_MIN * MS_PER_MINUTE;\n41:   }\n42:   if (parsedMinutes === 0) {\n43:     return null;\n44:   }\n45:   return Math.max(1, Math.round(parsedMinutes * MS_PER_MINUTE));\n46: }\n47: \n48: function removeDataListener(stdin: StdinLike | null | undefined, listener: DataListener): void {\n49:   if (!stdin) return;\n50:   if (typeof stdin.off === 'function') {\n51:     stdin.off('data', listener);\n52:     return;\n53:   }\n54:   if (typeof stdin.removeListener === 'function') {\n55:     stdin.removeListener('data', listener);\n56:   }\n57: }\n58: \n59: function createLauncherIdleMonitor(options: LauncherIdleMonitorOptions): LauncherIdleMonitor {\n60:   const log = options.log ?? ((message: string) => console.error(message));\n61:   const timeoutMs = parseLauncherIdleTimeoutMs(options.timeoutMinutesRaw);\n62:   const noop = () => undefined;\n63:   if (timeoutMs === null) {\n64:     log(`[${options.serviceName}] launcher idle timeout disabled`);\n65:     return { timeoutMs, markActivity: noop, stop: noop };\n66:   }\n67: \n68:   const now = options.now ?? (() => Date.now());\n69:   const setIntervalFn = options.setIntervalFn ?? ((callback: () => void, ms: number) => setInterval(callback, ms));\n70:   const clearIntervalFn = options.clearIntervalFn ?? ((interval: IntervalHandle) => clearInterval(interval));\n71:   const stdin = options.stdin === undefined ? process.stdin : options.stdin;\n72:   const checkIntervalMs = Math.min(\n73:     MAX_IDLE_CHECK_INTERVAL_MS,\n74:     Math.max(MIN_IDLE_CHECK_INTERVAL_MS, Math.floor(timeoutMs / 2)),\n75:   );\n76: \n77:   let stopped = false;\n78:   let lastActivityAt = now();\n79:   let timer: IntervalHandle | null = null;\n80:   let sawActiveClient = false;\n81:   let zeroActiveClientChecks = 0;\n82: \n83:   const markActivity = () => {\n84:     if (!stopped) {\n85:       lastActivityAt = now();\n86:     }\n87:   };\n88: \n89:   const stop = () => {\n90:     if (stopped) return;\n91:     stopped = true;\n92:     removeDataListener(stdin, markActivity);\n93:     if (timer !== null) {\n94:       clearIntervalFn(timer);\n95:     }\n96:   };\n97: \n98:   const checkIdle = async () => {\n99:     if (stopped) return;\n100:     const activeClients = options.getActiveClientCount?.() ?? 0;\n101:     if (activeClients > 0) {\n102:       sawActiveClient = true;\n103:       zeroActiveClientChecks = 0;\n104:       lastActivityAt = now();\n105:       return;\n106:     }\n107:     zeroActiveClientChecks += 1;\n108:     if (sawActiveClient && zeroActiveClientChecks < 2) {\n109:       // A reconnect can briefly drop the socket count to zero while the launcher is still preserving stdio.\n110:       lastActivityAt = now();\n111:       return;\n112:     }\n113:     const idleForMs = now() - lastActivityAt;\n114:     if (idleForMs < timeoutMs) return;\n115: \n116:     stopped = true;\n117:     removeDataListener(stdin, markActivity);\n118:     if (timer !== null) {\n119:       clearIntervalFn(timer);\n120:     }\n121:     log(`[${options.serviceName}] launcher idle timeout reached after ${Math.round(idleForMs)}ms`);\n122:     try {\n123:       await options.onIdle();\n124:     } catch (error: unknown) {\n125:       const message = error instanceof Error ? error.message : String(error);\n126:       log(`[${options.serviceName}] launcher idle shutdown failed: ${message}`);\n127:     }\n128:   };\n129: \n130:   stdin?.on('data', markActivity);\n131:   timer = setIntervalFn(() => {\n132:     void checkIdle();\n133:   }, checkIntervalMs);\n134:   if (typeof (timer as { unref?: () => void }).unref === 'function') {\n135:     (timer as { unref: () => void }).unref();\n136:   }\n137: \n138:   return { timeoutMs, markActivity, stop };\n139: }\n140: \n141: export {\n142:   createLauncherIdleMonitor,\n143:   parseLauncherIdleTimeoutMs,\n144: };\n145: \n146: export type {\n147:   LauncherIdleMonitor,\n148:   LauncherIdleMonitorOptions,\n149: };\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"// MODULE: Launcher Idle Timeout Monitor\n\nconst DEFAULT_IDLE_TIMEOUT_MIN = 30;\nconst MS_PER_MINUTE = 60_000;\nconst MIN_IDLE_CHECK_INTERVAL_MS = 1_000;\nconst MAX_IDLE_CHECK_INTERVAL_MS = 60_000;\n\ntype IntervalHandle = ReturnType<typeof setInterval>;\ntype DataListener = (chunk: unknown) => void;\ntype StdinLike = {\n  on(eventName: 'data', listener: DataListener): unknown;\n  off?: (eventName: 'data', listener: DataListener) => unknown;\n  removeListener?: (eventName: 'data', listener: DataListener) => unknown;\n};\n\ninterface LauncherIdleMonitorOptions {\n  readonly serviceName: string;\n  readonly timeoutMinutesRaw?: string;\n  readonly stdin?: StdinLike | null;\n  readonly getActiveClientCount?: () => number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ipc/launcher-idle-timeout.ts","text":"// MODULE: Launcher Idle Timeout Monitor\n\nconst DEFAULT_IDLE_TIMEOUT_MIN = 30;\nconst MS_PER_MINUTE = 60_000;\nconst MIN_IDLE_CHECK_INTERVAL_MS = 1_000;\nconst MAX_IDLE_CHECK_INTERVAL_MS = 60_000;\n\ntype IntervalHandle = ReturnType<typeof setInterval>;\ntype DataListener = (chunk: unknown) => void;\ntype StdinLike = {\n  on(eventName: 'data', listener: DataListener): unknown;\n  off?: (eventName: 'data', listener: DataListener) => unknown;\n  removeListener?: (eventName: 'data', listener: DataListener) => unknown;\n};\n\ninterface LauncherIdleMonitorOptions {\n  readonly serviceName: string;\n  readonly timeoutMinutesRaw?: string;\n  readonly stdin?: StdinLike | null;\n  readonly getActiveClientCount?: () => number;\n  readonly onIdle: () => void | Promise<void>;\n  readonly log?: (message: string) => void;\n  readonly now?: () => number;\n  readonly setIntervalFn?: (callback: () => void, ms: number) => IntervalHandle;\n  readonly clearIntervalFn?: (timer: IntervalHandle) => void;\n}\n\ninterface LauncherIdleMonitor {\n  readonly timeoutMs: number | null;\n  readonly markActivity: () => void;\n  readonly stop: () => void;\n}\n\nfunction parseLauncherIdleTimeoutMs(rawValue = process.env.SPECKIT_LAUNCHER_IDLE_TIMEOUT_MIN): number | null {\n  const raw = rawValue === undefined || rawValue === null || String(rawValue).trim() === ''\n    ? String(DEFAULT_IDLE_TIMEOUT_MIN)\n    : String(rawValue).trim();\n  const parsedMinutes = Number(raw);\n  if (!Number.isFinite(parsedMinutes) || parsedMinutes < 0) {\n    return DEFAULT_IDLE_TIMEOUT_MIN * MS_PER_MINUTE;\n  }\n  if (parsedMinutes === 0) {\n    return null;\n  }\n  return Math.max(1, Math.round(parsedMinutes * MS_PER_MINUTE));\n}\n\nfunction removeDataListener(stdin: StdinLike | null | undefined, listener: DataListener): void {\n  if (!stdin) return;\n  if (typeof stdin.off === 'function') {\n    stdin.off('data', listener);\n    return;\n  }\n  if (typeof stdin.removeListener === 'function') {\n    stdin.removeListener('data', listener);\n  }\n}\n\nfunction createLauncherIdleMonitor(options: LauncherIdleMonitorOptions): LauncherIdleMonitor {\n  const log = options.log ?? ((message: string) => console.error(message));\n  const timeoutMs = parseLauncherIdleTimeoutMs(options.timeoutMinutesRaw);\n  const noop = () => undefined;\n  if (timeoutMs === null) {\n    log(`[${options.serviceName}] launcher idle timeout disabled`);\n    return { timeoutMs, markActivity: noop, stop: noop };\n  }\n\n  const now = options.now ?? (() => Date.now());\n  const setIntervalFn = options.setIntervalFn ?? ((callback: () => void, ms: number) => setInterval(callback, ms));\n  const clearIntervalFn = options.clearIntervalFn ?? ((interval: IntervalHandle) => clearInterval(interval));\n  const stdin = options.stdin === undefined ? process.stdin : options.stdin;\n  const checkIntervalMs = Math.min(\n    MAX_IDLE_CHECK_INTERVAL_MS,\n    Math.max(MIN_IDLE_CHECK_INTERVAL_MS, Math.floor(timeoutMs / 2)),\n  );\n\n  let stopped = false;\n  let lastActivityAt = now();\n  let timer: IntervalHandle | null = null;\n  let sawActiveClient = false;\n  let zeroActiveClientChecks = 0;\n\n  const markActivity = () => {\n    if (!stopped) {\n      lastActivityAt = now();\n    }\n  };\n\n  const stop = () => {\n    if (stopped) return;\n    stopped = true;\n    removeDataListener(stdin, markActivity);\n    if (timer !== null) {\n      clearIntervalFn(timer);\n    }\n  };\n\n  const checkIdle = async () => {\n    if (stopped) return;\n    const activeClients = options.getActiveClientCount?.() ?? 0;\n    if (activeClients > 0) {\n      sawActiveClient = true;\n      zeroActiveClientChecks = 0;\n      lastActivityAt = now();\n      return;\n    }\n    zeroActiveClientChecks += 1;\n    if (sawActiveClient && zeroActiveClientChecks < 2) {\n      // A reconnect can briefly drop the socket count to zero while the launcher is still preserving stdio.\n      lastActivityAt = now();\n      return;\n    }\n    const idleForMs = now() - lastActivityAt;\n    if (idleForMs < timeoutMs) return;\n\n    stopped = true;\n    removeDataListener(stdin, markActivity);\n    if (timer !== null) {\n      clearIntervalFn(timer);\n    }\n    log(`[${options.serviceName}] launcher idle timeout reached after ${Math.round(idleForMs)}ms`);\n    try {\n      await options.onIdle();\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      log(`[${options.serviceName}] launcher idle shutdown failed: ${message}`);\n    }\n  };\n\n  stdin?.on('data', markActivity);\n  timer = setIntervalFn(() => {\n    void checkIdle();\n  }, checkIntervalMs);\n  if (typeof (timer as { unref?: () => void }).unref === 'function') {\n    (timer as { unref: () => void }).unref();\n  }\n\n  return { timeoutMs, markActivity, stop };\n}\n\nexport {\n  createLauncherIdleMonitor,\n  parseLauncherIdleTimeoutMs,\n};\n\nexport type {\n  LauncherIdleMonitor,\n  LauncherIdleMonitorOptions,\n};","lineStart":1,"lineEnd":149,"totalLines":149,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ipc/launcher-idle-timeout.ts","time":{"start":1781762012663,"end":1781762012665}},"metadata":{"openai":{"itemId":"fc_0ea88119742d1da2016a3387dc88588191b3306c1433403515"}},"id":"prt_ed94ab5f2001oLLfNXZ4rHKQJ2","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94a8622001CH88ScXqbsbwyu"}}
{"type":"tool_use","timestamp":1781762012687,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_5ULpu9xQzAeBm69khQz4Mlff","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1580,"limit":210},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1580: ──────────────────────────────────────────────────────────────── */\n1581: \n1582: let shuttingDown = false;\n1583: // Hoist transport to module scope so shutdown handlers can close it\n1584: let transport: StdioServerTransport | null = null;\n1585: let transportConnectedAt: string | null = null;\n1586: let fileWatcher: FSWatcher | null = null;\n1587: let ipcBridge: IpcSocketServerHandle | null = null;\n1588: let launcherIdleMonitor: LauncherIdleMonitor | null = null;\n1589: \n1590: /** Maximum time (ms) to wait for async cleanup before force-exiting. */\n1591: const SHUTDOWN_DEADLINE_MS = 5000;\n1592: \n1593: /**\n1594:  * Exit code telling the launcher \"another live process holds the database\n1595:  * single-writer lock\": bridge to that owner instead of counting this exit\n1596:  * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n1597:  * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n1598:  * mk-spec-memory-launcher.cjs.\n1599:  */\n1600: const EXIT_DB_LOCK_HELD = 86;\n1601: \n1602: export const __testables = {\n1603:   runCleanupStep,\n1604:   runAsyncCleanupStep,\n1605:   main: () => main(),\n1606:   getBootFtsIntegrityHealth,\n1607:   runCheckpointNeedsRebuildRepair,\n1608:   normalizeGraphFilePath,\n1609:   extractFilePathsFromToolArgs,\n1610: };\n1611: \n1612: async function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n1613:   if (shuttingDown) return;\n1614:   shuttingDown = true;\n1615:   console.error(`[context-server] ${reason}`);\n1616: \n1617:   runCleanupStep('sessionManager', () => sessionManager.shutdown());\n1618:   runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n1619:   // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n1620:   // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n1621:   // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n1622:   runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n1623:   runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n1624:   runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n1625:   runCleanupStep('accessTracker', () => accessTracker.reset());\n1626:   runCleanupStep('toolCache', () => toolCache.shutdown());\n1627:   runCleanupStep('launcherIdleMonitor', () => {\n1628:     if (launcherIdleMonitor) {\n1629:       launcherIdleMonitor.stop();\n1630:       launcherIdleMonitor = null;\n1631:     }\n1632:   });\n1633: \n1634:   let deadlineTimer: NodeJS.Timeout | undefined;\n1635:   const cleanup = (async () => {\n1636:     // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n1637:     // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n1638:     // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n1639:     await runAsyncCleanupStep('startupScan', async () => {\n1640:       if (startupScanPromise) await startupScanPromise;\n1641:     });\n1642:     // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n1643:     // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n1644:     // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n1645:     // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n1646:     // at rest and defeating the durability guarantee. closeDb() is\n1647:     // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n1648:     // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n1649:     // small even if a pathologically slow drain starves this step.\n1650:     await runAsyncCleanupStep('fileWatcher', async () => {\n1651:       if (fileWatcher) {\n1652:         await fileWatcher.close();\n1653:         fileWatcher = null;\n1654:       }\n1655:     });\n1656:     // Fence the ingest worker before closeDb for the same reason as the file\n1657:     // watcher above: the worker writes through the DB and would otherwise reopen\n1658:     // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n1659:     await runAsyncCleanupStep('ingestWorker', async () => {\n1660:       await stopIngestWorker();\n1661:     });\n1662:     runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n1663:     // Close MCP transport on shutdown\n1664:     runCleanupStep('transport', () => {\n1665:       if (transport) {\n1666:         transport.close();\n1667:         transport = null;\n1668:         transportConnectedAt = null;\n1669:       }\n1670:     });\n1671:     await runAsyncCleanupStep('ipcBridge', async () => {\n1672:       if (ipcBridge) {\n1673:         await ipcBridge.close();\n1674:         ipcBridge = null;\n1675:       }\n1676:     });\n1677:     await runAsyncCleanupStep('shutdownHooks', async () => {\n1678:       await runShutdownHooks();\n1679:     });\n1680:     runCleanupStep('registeredTimers', () => clearAllTimers());\n1681:   })();\n1682: \n1683:   const timedOut = await Promise.race([\n1684:     cleanup.then(() => false),\n1685:     new Promise<boolean>((resolve) => {\n1686:       deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n1687:     }),\n1688:   ]);\n1689: \n1690:   if (deadlineTimer) {\n1691:     clearRegisteredTimer(deadlineTimer);\n1692:   }\n1693: \n1694:   if (timedOut) {\n1695:     console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n1696:   }\n1697: \n1698:   process.exit(exitCode);\n1699: }\n1700: \n1701: /** Remove indexed rows for watcher delete and rename events. */\n1702: async function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n1703:   const database = vectorIndex.getDb();\n1704:   if (!database) {\n1705:     return;\n1706:   }\n1707: \n1708:   const canonicalPath = getCanonicalPathKey(filePath);\n1709:   let rows: Array<{ id: number; spec_folder: string | null }> = [];\n1710: \n1711:   try {\n1712:     rows = database.prepare(`\n1713:       SELECT id, spec_folder\n1714:       FROM memory_index\n1715:       WHERE canonical_file_path = ? OR file_path = ?\n1716:       ORDER BY id ASC\n1717:     `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n1718:   } catch (_error: unknown) {\n1719:     rows = database.prepare(`\n1720:       SELECT id, spec_folder\n1721:       FROM memory_index\n1722:       WHERE file_path = ?\n1723:       ORDER BY id ASC\n1724:     `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n1725:   }\n1726: \n1727:   let deletedCount = 0;\n1728:   for (const row of rows) {\n1729:     if (typeof row.id === 'number') {\n1730:       if (vectorIndex.deleteMemory(row.id)) {\n1731:         deletedCount += 1;\n1732:         // Record DELETE history only after confirmed deletion.\n1733:         try {\n1734:           recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n1735:         } catch (_histErr: unknown) {\n1736:           // History recording is best-effort in file-watcher path\n1737:         }\n1738:       }\n1739:     }\n1740:   }\n1741: \n1742:   if (deletedCount > 0) {\n1743:     try {\n1744:       runPostMutationHooks('delete', { filePath, deletedCount });\n1745:     } catch (_error: unknown) {\n1746:       // Non-throwing by design: file-watcher path must not crash the server.\n1747:     }\n1748:   }\n1749: }\n1750: \n1751: process.on('SIGTERM', () => {\n1752:   void fatalShutdown('Received SIGTERM, shutting down...', 0);\n1753: });\n1754: process.on('SIGINT', () => {\n1755:   void fatalShutdown('Received SIGINT, shutting down...', 0);\n1756: });\n1757: process.on('SIGHUP', () => {\n1758:   void fatalShutdown('Received SIGHUP, shutting down...', 0);\n1759: });\n1760: process.on('SIGQUIT', () => {\n1761:   void fatalShutdown('Received SIGQUIT, shutting down...', 0);\n1762: });\n1763: \n1764: process.on('uncaughtException', (err: Error) => {\n1765:   void fatalShutdown(`Uncaught exception: ${err.stack ?? err.message}`, 1);\n1766: });\n1767: \n1768: process.on('unhandledRejection', (reason: unknown, promise: Promise<unknown>) => {\n1769:   void fatalShutdown(\n1770:     `Unhandled rejection at: ${String(promise)} reason: ${reason instanceof Error ? reason.stack ?? reason.message : String(reason)}`,\n1771:     1,\n1772:   );\n1773: });\n1774: \n1775: /* ───────────────────────────────────────────────────────────────\n1776:    8. MAIN\n1777: ──────────────────────────────────────────────────────────────── */\n1778: \n1779: async function main(): Promise<void> {\n1780:   // Node version mismatch detection (non-blocking)\n1781:   detectNodeVersionMismatch();\n1782:   detectedRuntime = detectRuntime();\n1783:   console.error(\n1784:     `[context-server] Detected runtime: ${detectedRuntime.runtime} (hookPolicy=${detectedRuntime.hookPolicy})`,\n1785:   );\n1786: \n1787:   validateConfiguredEmbeddingsProvider();\n1788: \n1789:   // Refuse to boot as a second writer BEFORE anything else initializes. The\n\n(Showing lines 1580-1789 of 2341. Use offset=1790 to continue.)\n</content>","metadata":{"preview":"──────────────────────────────────────────────────────────────── */\n\nlet shuttingDown = false;\n// Hoist transport to module scope so shutdown handlers can close it\nlet transport: StdioServerTransport | null = null;\nlet transportConnectedAt: string | null = null;\nlet fileWatcher: FSWatcher | null = null;\nlet ipcBridge: IpcSocketServerHandle | null = null;\nlet launcherIdleMonitor: LauncherIdleMonitor | null = null;\n\n/** Maximum time (ms) to wait for async cleanup before force-exiting. */\nconst SHUTDOWN_DEADLINE_MS = 5000;\n\n/**\n * Exit code telling the launcher \"another live process holds the database\n * single-writer lock\": bridge to that owner instead of counting this exit\n * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n * mk-spec-memory-launcher.cjs.\n */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"──────────────────────────────────────────────────────────────── */\n\nlet shuttingDown = false;\n// Hoist transport to module scope so shutdown handlers can close it\nlet transport: StdioServerTransport | null = null;\nlet transportConnectedAt: string | null = null;\nlet fileWatcher: FSWatcher | null = null;\nlet ipcBridge: IpcSocketServerHandle | null = null;\nlet launcherIdleMonitor: LauncherIdleMonitor | null = null;\n\n/** Maximum time (ms) to wait for async cleanup before force-exiting. */\nconst SHUTDOWN_DEADLINE_MS = 5000;\n\n/**\n * Exit code telling the launcher \"another live process holds the database\n * single-writer lock\": bridge to that owner instead of counting this exit\n * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n * mk-spec-memory-launcher.cjs.\n */\nconst EXIT_DB_LOCK_HELD = 86;\n\nexport const __testables = {\n  runCleanupStep,\n  runAsyncCleanupStep,\n  main: () => main(),\n  getBootFtsIntegrityHealth,\n  runCheckpointNeedsRebuildRepair,\n  normalizeGraphFilePath,\n  extractFilePathsFromToolArgs,\n};\n\nasync function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  console.error(`[context-server] ${reason}`);\n\n  runCleanupStep('sessionManager', () => sessionManager.shutdown());\n  runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n  // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n  // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n  // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n  runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n  runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n  runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n  runCleanupStep('accessTracker', () => accessTracker.reset());\n  runCleanupStep('toolCache', () => toolCache.shutdown());\n  runCleanupStep('launcherIdleMonitor', () => {\n    if (launcherIdleMonitor) {\n      launcherIdleMonitor.stop();\n      launcherIdleMonitor = null;\n    }\n  });\n\n  let deadlineTimer: NodeJS.Timeout | undefined;\n  const cleanup = (async () => {\n    // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n    // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n    // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n    await runAsyncCleanupStep('startupScan', async () => {\n      if (startupScanPromise) await startupScanPromise;\n    });\n    // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n    // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n    // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n    // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n    // at rest and defeating the durability guarantee. closeDb() is\n    // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n    // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n    // small even if a pathologically slow drain starves this step.\n    await runAsyncCleanupStep('fileWatcher', async () => {\n      if (fileWatcher) {\n        await fileWatcher.close();\n        fileWatcher = null;\n      }\n    });\n    // Fence the ingest worker before closeDb for the same reason as the file\n    // watcher above: the worker writes through the DB and would otherwise reopen\n    // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n    await runAsyncCleanupStep('ingestWorker', async () => {\n      await stopIngestWorker();\n    });\n    runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n    // Close MCP transport on shutdown\n    runCleanupStep('transport', () => {\n      if (transport) {\n        transport.close();\n        transport = null;\n        transportConnectedAt = null;\n      }\n    });\n    await runAsyncCleanupStep('ipcBridge', async () => {\n      if (ipcBridge) {\n        await ipcBridge.close();\n        ipcBridge = null;\n      }\n    });\n    await runAsyncCleanupStep('shutdownHooks', async () => {\n      await runShutdownHooks();\n    });\n    runCleanupStep('registeredTimers', () => clearAllTimers());\n  })();\n\n  const timedOut = await Promise.race([\n    cleanup.then(() => false),\n    new Promise<boolean>((resolve) => {\n      deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n    }),\n  ]);\n\n  if (deadlineTimer) {\n    clearRegisteredTimer(deadlineTimer);\n  }\n\n  if (timedOut) {\n    console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n  }\n\n  process.exit(exitCode);\n}\n\n/** Remove indexed rows for watcher delete and rename events. */\nasync function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return;\n  }\n\n  const canonicalPath = getCanonicalPathKey(filePath);\n  let rows: Array<{ id: number; spec_folder: string | null }> = [];\n\n  try {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE canonical_file_path = ? OR file_path = ?\n      ORDER BY id ASC\n    `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n  } catch (_error: unknown) {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE file_path = ?\n      ORDER BY id ASC\n    `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n  }\n\n  let deletedCount = 0;\n  for (const row of rows) {\n    if (typeof row.id === 'number') {\n      if (vectorIndex.deleteMemory(row.id)) {\n        deletedCount += 1;\n        // Record DELETE history only after confirmed deletion.\n        try {\n          recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n        } catch (_histErr: unknown) {\n          // History recording is best-effort in file-watcher path\n        }\n      }\n    }\n  }\n\n  if (deletedCount > 0) {\n    try {\n      runPostMutationHooks('delete', { filePath, deletedCount });\n    } catch (_error: unknown) {\n      // Non-throwing by design: file-watcher path must not crash the server.\n    }\n  }\n}\n\nprocess.on('SIGTERM', () => {\n  void fatalShutdown('Received SIGTERM, shutting down...', 0);\n});\nprocess.on('SIGINT', () => {\n  void fatalShutdown('Received SIGINT, shutting down...', 0);\n});\nprocess.on('SIGHUP', () => {\n  void fatalShutdown('Received SIGHUP, shutting down...', 0);\n});\nprocess.on('SIGQUIT', () => {\n  void fatalShutdown('Received SIGQUIT, shutting down...', 0);\n});\n\nprocess.on('uncaughtException', (err: Error) => {\n  void fatalShutdown(`Uncaught exception: ${err.stack ?? err.message}`, 1);\n});\n\nprocess.on('unhandledRejection', (reason: unknown, promise: Promise<unknown>) => {\n  void fatalShutdown(\n    `Unhandled rejection at: ${String(promise)} reason: ${reason instanceof Error ? reason.stack ?? reason.message : String(reason)}`,\n    1,\n  );\n});\n\n/* ───────────────────────────────────────────────────────────────\n   8. MAIN\n──────────────────────────────────────────────────────────────── */\n\nasync function main(): Promise<void> {\n  // Node version mismatch detection (non-blocking)\n  detectNodeVersionMismatch();\n  detectedRuntime = detectRuntime();\n  console.error(\n    `[context-server] Detected runtime: ${detectedRuntime.runtime} (hookPolicy=${detectedRuntime.hookPolicy})`,\n  );\n\n  validateConfiguredEmbeddingsProvider();\n\n  // Refuse to boot as a second writer BEFORE anything else initializes. The","lineStart":1580,"lineEnd":1789,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781762012682,"end":1781762012686}},"metadata":{"openai":{"itemId":"fc_0ea88119742d1da2016a3387dc88608191a6674b49365aae5d"}},"id":"prt_ed94ab5fa001S6vP7LgqWY7fNK","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94a8622001CH88ScXqbsbwyu"}}
{"type":"tool_use","timestamp":1781762012699,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_5yJf4vppTFxsY1aUevADeEJZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":2280,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n2280:     setImmediate(() => {\n2281:       try {\n2282:         runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n2283:       } catch (repairErr: unknown) {\n2284:         const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n2285:         console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n2286:       }\n2287:       startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n2288:     });\n2289:   });\n2290: \n2291:   // Assign to module-level transport (not const) so shutdown handlers can close it\n2292:   if (isDynamicInitEnabled()) {\n2293:     try {\n2294:       const dynamicInstructions = await buildServerInstructions();\n2295:       if (dynamicInstructions.length > 0) {\n2296:         serverWithInstructions.setInstructions?.(dynamicInstructions);\n2297:       }\n2298:     } catch (instructionErr: unknown) {\n2299:       const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);\n2300:       console.warn('[context-server] Dynamic instructions init failed (non-fatal):', message);\n2301:     }\n2302:   }\n2303: \n2304:   const backendOnly = process.env.SPECKIT_BACKEND_ONLY === '1';\n2305:   if (!backendOnly) {\n2306:     transportConnectedAt = new Date().toISOString();\n2307:     transport = new StdioServerTransport();\n2308:     await server.connect(transport);\n2309:   }\n2310:   scheduleBootFtsIntegrityCheck();\n2311:   registerInterval(() => vectorIndex.checkpointAllWal(), 300_000, { unref: true });\n2312:   launcherIdleMonitor = createLauncherIdleMonitor({\n2313:     serviceName: 'context-server',\n2314:     getActiveClientCount: () => getIpcBridgeStats().secondary_clients_count,\n2315:     onIdle: () => fatalShutdown('Launcher idle timeout reached, shutting down...', 0),\n2316:     log: (message) => console.error(message),\n2317:     stdin: backendOnly ? null : undefined,\n2318:   });\n2319:   ipcBridge = await startIpcSocketServer({\n2320:     socketPath: resolveIpcSocketPath(DATABASE_DIR),\n2321:     createServer: () => {\n2322:       const secondaryServer = createContextMcpServer();\n2323:       registerContextServerHandlers(secondaryServer);\n2324:       return secondaryServer;\n2325:     },\n2326:     log: (message) => console.error(message),\n2327:     onActivity: () => launcherIdleMonitor?.markActivity(),\n2328:   });\n2329:   const rssMb = Math.round(process.memoryUsage().rss / 1024 / 1024);\n2330:   console.error(`[health] startup pid=${process.pid} rss=${rssMb}MB uptime=0s`);\n2331:   console.error(backendOnly\n2332:     ? '[context-server] Context MCP server running on IPC socket only'\n2333:     : '[context-server] Context MCP server running on stdio and IPC socket');\n2334: \n2335: }\n2336: \n2337: const isMain = process.argv[1] && decodeURIComponent(import.meta.url).endsWith(process.argv[1].replace(/\\\\/g, '/'));\n2338: \n2339: if (isMain) {\n2340:   main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n2341: }\n\n(End of file - total 2341 lines)\n</content>","metadata":{"preview":"    setImmediate(() => {\n      try {\n        runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n      } catch (repairErr: unknown) {\n        const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n        console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n      }\n      startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n    });\n  });\n\n  // Assign to module-level transport (not const) so shutdown handlers can close it\n  if (isDynamicInitEnabled()) {\n    try {\n      const dynamicInstructions = await buildServerInstructions();\n      if (dynamicInstructions.length > 0) {\n        serverWithInstructions.setInstructions?.(dynamicInstructions);\n      }\n    } catch (instructionErr: unknown) {\n      const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"    setImmediate(() => {\n      try {\n        runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n      } catch (repairErr: unknown) {\n        const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n        console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n      }\n      startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n    });\n  });\n\n  // Assign to module-level transport (not const) so shutdown handlers can close it\n  if (isDynamicInitEnabled()) {\n    try {\n      const dynamicInstructions = await buildServerInstructions();\n      if (dynamicInstructions.length > 0) {\n        serverWithInstructions.setInstructions?.(dynamicInstructions);\n      }\n    } catch (instructionErr: unknown) {\n      const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);\n      console.warn('[context-server] Dynamic instructions init failed (non-fatal):', message);\n    }\n  }\n\n  const backendOnly = process.env.SPECKIT_BACKEND_ONLY === '1';\n  if (!backendOnly) {\n    transportConnectedAt = new Date().toISOString();\n    transport = new StdioServerTransport();\n    await server.connect(transport);\n  }\n  scheduleBootFtsIntegrityCheck();\n  registerInterval(() => vectorIndex.checkpointAllWal(), 300_000, { unref: true });\n  launcherIdleMonitor = createLauncherIdleMonitor({\n    serviceName: 'context-server',\n    getActiveClientCount: () => getIpcBridgeStats().secondary_clients_count,\n    onIdle: () => fatalShutdown('Launcher idle timeout reached, shutting down...', 0),\n    log: (message) => console.error(message),\n    stdin: backendOnly ? null : undefined,\n  });\n  ipcBridge = await startIpcSocketServer({\n    socketPath: resolveIpcSocketPath(DATABASE_DIR),\n    createServer: () => {\n      const secondaryServer = createContextMcpServer();\n      registerContextServerHandlers(secondaryServer);\n      return secondaryServer;\n    },\n    log: (message) => console.error(message),\n    onActivity: () => launcherIdleMonitor?.markActivity(),\n  });\n  const rssMb = Math.round(process.memoryUsage().rss / 1024 / 1024);\n  console.error(`[health] startup pid=${process.pid} rss=${rssMb}MB uptime=0s`);\n  console.error(backendOnly\n    ? '[context-server] Context MCP server running on IPC socket only'\n    : '[context-server] Context MCP server running on stdio and IPC socket');\n\n}\n\nconst isMain = process.argv[1] && decodeURIComponent(import.meta.url).endsWith(process.argv[1].replace(/\\\\/g, '/'));\n\nif (isMain) {\n  main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n}","lineStart":2280,"lineEnd":2341,"totalLines":2341,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781762012696,"end":1781762012699}},"metadata":{"openai":{"itemId":"fc_0ea88119742d1da2016a3387dc886c81919bc4e1bbf17a4e8c"}},"id":"prt_ed94ab60c001VHLEAbcm8ySiLX","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94a8622001CH88ScXqbsbwyu"}}
