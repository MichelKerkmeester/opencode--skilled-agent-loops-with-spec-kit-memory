{"type":"tool_use","timestamp":1783487175549,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_2Hz78vOzWJ6sXuUEAU5Vguue","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/review-research-paths.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/review-research-paths.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Review Research Paths                                                    ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: \n14: const MODE_CONFIG_FILE = {\n15:   research: 'deep-research-config.json',\n16:   review: 'deep-review-config.json',\n17: };\n18: \n19: const MODE_STATE_FILE = {\n20:   research: 'deep-research-state.jsonl',\n21:   review: 'deep-review-state.jsonl',\n22: };\n23: \n24: // ─────────────────────────────────────────────────────────────────────────────\n25: // 2. CORE LOGIC\n26: // ─────────────────────────────────────────────────────────────────────────────\n27: \n28: /**\n29:  * Allocate the next artifact subfolder name under an artifact root directory\n30:  * using the {phaseSlug}-pt-{NN} naming convention.\n31:  *\n32:  * The phase slug is the FULL first-segment folder name under the spec tree\n33:  * root (e.g. \"019-system-hardening\").  NN is a two-digit zero-padded counter:\n34:  * 1 + the number of existing pt-folders whose slug prefix matches the requested\n35:  * phase, so repeated calls produce sequential names without any stored counter.\n36:  *\n37:  * @param {string} rootDir   - Absolute path to the artifact root (research/ or review/)\n38:  * @param {string} phaseSlug - Full phase folder name (e.g. \"019-system-hardening\")\n39:  * @returns {string} Subfolder name, e.g. \"019-system-hardening-pt-03\"\n40:  */\n41: function allocateShortSubfolder(rootDir, phaseSlug) {\n42:   let existingCount = 0;\n43: \n44:   if (fs.existsSync(rootDir)) {\n45:     const prefix = `${phaseSlug}-pt-`;\n46:     existingCount = fs.readdirSync(rootDir).filter(\n47:       (entry) => entry.startsWith(prefix),\n48:     ).length;\n49:   }\n50: \n51:   const nn = String(existingCount + 1).padStart(2, '0');\n52:   return `${phaseSlug}-pt-${nn}`;\n53: }\n54: \n55: function normalizeSpecFolderReference(specFolder) {\n56:   if (!specFolder) {\n57:     return null;\n58:   }\n59: \n60:   const normalized = String(specFolder)\n61:     .trim()\n62:     .replace(/\\\\/g, '/')\n63:     .replace(/\\/+$/g, '');\n64: \n65:   if (!normalized) {\n66:     return null;\n67:   }\n68: \n69:   const opencodeSpecsMarker = '/.opencode/specs/';\n70:   const specsMarker = '/specs/';\n71:   const opencodeIndex = normalized.lastIndexOf(opencodeSpecsMarker);\n72:   if (opencodeIndex !== -1) {\n73:     return normalized.slice(opencodeIndex + opencodeSpecsMarker.length);\n74:   }\n75: \n76:   const specsIndex = normalized.lastIndexOf(specsMarker);\n77:   if (specsIndex !== -1) {\n78:     return normalized.slice(specsIndex + specsMarker.length);\n79:   }\n80: \n81:   return normalized\n82:     .replace(/^\\.\\/+/, '')\n83:     .replace(/^\\.opencode\\/specs\\//, '')\n84:     .replace(/^specs\\//, '');\n85: }\n86: \n87: function findAncestorSpecFolder(specFolder) {\n88:   let current = path.resolve(specFolder);\n89: \n90:   while (true) {\n91:     const parent = path.dirname(current);\n92: \n93:     if (parent === current || path.basename(parent) === 'specs') {\n94:       return null;\n95:     }\n96: \n97:     if (fs.existsSync(path.join(parent, 'spec.md'))) {\n98:       return parent;\n99:     }\n100: \n101:     current = parent;\n102:   }\n103: }\n104: \n105: function readPacketSpecFolder(packetDir, mode) {\n106:   const configPath = path.join(packetDir, MODE_CONFIG_FILE[mode]);\n107:   if (fs.existsSync(configPath)) {\n108:     try {\n109:       const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));\n110:       return normalizeSpecFolderReference(config.specFolder);\n111:     } catch (_error) {\n112:       // Fall through to state log probing.\n113:     }\n114:   }\n115: \n116:   const stateLogPath = path.join(packetDir, MODE_STATE_FILE[mode]);\n117:   if (!fs.existsSync(stateLogPath)) {\n118:     return null;\n119:   }\n120: \n121:   try {\n122:     const lines = fs.readFileSync(stateLogPath, 'utf8').split(/\\r?\\n/);\n123:     for (const line of lines) {\n124:       if (!line.trim()) {\n125:         continue;\n126:       }\n127:       const parsed = JSON.parse(line);\n128:       return normalizeSpecFolderReference(parsed.specFolder);\n129:     }\n130:   } catch (_error) {\n131:     return null;\n132:   }\n133: \n134:   return null;\n135: }\n136: \n137: function listPacketDirectories(rootDir) {\n138:   if (!fs.existsSync(rootDir)) {\n139:     return [];\n140:   }\n141: \n142:   return fs.readdirSync(rootDir, { withFileTypes: true })\n143:     .filter((entry) => entry.isDirectory() && /-pt-\\d+$/.test(entry.name))\n144:     .map((entry) => entry.name)\n145:     .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }));\n146: }\n147: \n148: function findExistingPacket(rootDir, specFolder, mode) {\n149:   const targetSpecFolder = normalizeSpecFolderReference(specFolder);\n150: \n151:   if (!targetSpecFolder) {\n152:     return null;\n153:   }\n154: \n155:   const matches = [];\n156:   for (const packetName of listPacketDirectories(rootDir)) {\n157:     const packetDir = path.join(rootDir, packetName);\n158:     if (readPacketSpecFolder(packetDir, mode) === targetSpecFolder) {\n159:       matches.push(packetName);\n160:     }\n161:   }\n162: \n163:   return matches.at(-1) || null;\n164: }\n165: \n166: /**\n167:  * Resolve the canonical artifact directory for review or research output.\n168:  *\n169:  * Conventions (post-028 contract fix):\n170:  *   - Root specs ALWAYS use flat: {spec_folder}/{mode}/\n171:  *   - Child phases use FLAT-FIRST:\n172:  *       (a) First run with empty {mode}/ directory → flat (subfolder=null)\n173:  *       (b) Continuation when flat artifact's config matches current target → reuse flat\n174:  *       (c) Existing pt-NN packet matches current target → reuse pt-NN\n175:  *       (d) Prior content exists for non-matching target → allocate pt-NN\n176:  *\n177:  * Subfolder naming convention (when pt-NN allocation kicks in): {phaseSlug}-pt-{NN}\n178:  *   - phaseSlug: the FULL immediate child phase segment under the spec tree\n179:  *     root (e.g. \"019-system-hardening\")\n180:  *   - NN: sequential two-digit counter scoped to that phase within the\n181:  *     artifact root directory; allocated by counting existing same-prefix\n182:  *     entries at call time\n183:  *\n184:  * Example:\n185:  *   - root spec run → {spec_folder}/research/\n186:  *   - child phase first run → {spec_folder}/research/   (flat, no pt-NN wrapper)\n187:  *   - child phase second run with prior content for different target → {spec_folder}/research/{phaseSlug}-pt-NN/\n188:  *   - child phase same-target continuation → reuses prior flat or pt-NN\n189:  *\n190:  * @param {string} specFolder - Absolute or relative path to the target spec folder\n191:  * @param {'review'|'research'|'context'} [mode='review'] - Which artifact type to resolve\n192:  *\n193:  * @returns {{\n194:  *   rootDir: string,\n195:  *   subfolder: string|null,\n196:  *   artifactDir: string,\n197:  *   artifactArchiveRoot: string\n198:  * }} Resolved packet root plus canonical packet/archive directories\n199:  */\n200: function resolveArtifactRoot(specFolder, mode = 'review') {\n201:   // Workflow write-authority: reject specFolder values that contain\n202:   // shell metacharacters or quote characters. The YAML workflow interpolates\n203:   // {spec_folder} into a `node -e` shell command; without this guard, a\n204:   // malicious specFolder containing single-quotes / semicolons / backticks /\n205:   // $ / | / & / < / > could break out of the shell-quoted argument and\n206:   // execute arbitrary code in the Node process or shell.\n207:   if (typeof specFolder !== 'string' || specFolder.length === 0) {\n208:     throw new Error(`resolveArtifactRoot: specFolder must be a non-empty string`);\n209:   }\n210:   if (/['\"`$;|&<>\\\\]/.test(specFolder)) {\n211:     throw new Error(\n212:       `resolveArtifactRoot: specFolder contains forbidden shell metacharacter(s); refusing to proceed`,\n213:     );\n214:   }\n215: \n216:   const resolved = path.resolve(specFolder);\n217:   const rootDir = path.join(resolved, mode);\n218:   const artifactArchiveRoot = path.join(resolved, `${mode}_archive`);\n219:   const ancestorSpecFolder = findAncestorSpecFolder(resolved);\n220: \n221:   // ROOT spec: always flat\n222:   if (!ancestorSpecFolder) {\n223:     return {\n224:       rootDir,\n225:       subfolder: null,\n226:       artifactDir: rootDir,\n227:       artifactArchiveRoot,\n228:     };\n229:   }\n230: \n231:   // CHILD phase: prefer existing pt-NN packet for current target if any\n232:   const existingPacket = findExistingPacket(rootDir, resolved, mode);\n233:   if (existingPacket) {\n234:     return {\n235:       rootDir,\n236:       subfolder: existingPacket,\n237:       artifactDir: path.join(rootDir, existingPacket),\n238:       artifactArchiveRoot: path.join(artifactArchiveRoot, existingPacket),\n239:     };\n240:   }\n241: \n242:   // CHILD phase: check for flat artifact at rootDir\n243:   const targetSpecFolder = normalizeSpecFolderReference(resolved);\n244:   const flatConfigPath = path.join(rootDir, MODE_CONFIG_FILE[mode]);\n245:   const flatStateLogPath = path.join(rootDir, MODE_STATE_FILE[mode]);\n246:   const hasFlatArtifact = fs.existsSync(flatConfigPath) || fs.existsSync(flatStateLogPath);\n247: \n248:   if (hasFlatArtifact) {\n249:     const flatSpecFolder = readPacketSpecFolder(rootDir, mode);\n250:     if (flatSpecFolder === null || flatSpecFolder === targetSpecFolder) {\n251:       // Flat artifact matches current target (or its config is unreadable but rootDir is owned by this target's path) → reuse flat\n252:       return {\n253:         rootDir,\n254:         subfolder: null,\n255:         artifactDir: rootDir,\n256:         artifactArchiveRoot,\n257:       };\n258:     }\n259:     // Flat artifact is for a different target — fall through to allocate pt-NN\n260:   }\n\n(Showing lines 1-260 of 290. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Review Research Paths                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst MODE_CONFIG_FILE = {\n  research: 'deep-research-config.json',\n  review: 'deep-review-config.json',\n};\n\nconst MODE_STATE_FILE = {\n  research: 'deep-research-state.jsonl',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/review-research-paths.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Review Research Paths                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst MODE_CONFIG_FILE = {\n  research: 'deep-research-config.json',\n  review: 'deep-review-config.json',\n};\n\nconst MODE_STATE_FILE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n};\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Allocate the next artifact subfolder name under an artifact root directory\n * using the {phaseSlug}-pt-{NN} naming convention.\n *\n * The phase slug is the FULL first-segment folder name under the spec tree\n * root (e.g. \"019-system-hardening\").  NN is a two-digit zero-padded counter:\n * 1 + the number of existing pt-folders whose slug prefix matches the requested\n * phase, so repeated calls produce sequential names without any stored counter.\n *\n * @param {string} rootDir   - Absolute path to the artifact root (research/ or review/)\n * @param {string} phaseSlug - Full phase folder name (e.g. \"019-system-hardening\")\n * @returns {string} Subfolder name, e.g. \"019-system-hardening-pt-03\"\n */\nfunction allocateShortSubfolder(rootDir, phaseSlug) {\n  let existingCount = 0;\n\n  if (fs.existsSync(rootDir)) {\n    const prefix = `${phaseSlug}-pt-`;\n    existingCount = fs.readdirSync(rootDir).filter(\n      (entry) => entry.startsWith(prefix),\n    ).length;\n  }\n\n  const nn = String(existingCount + 1).padStart(2, '0');\n  return `${phaseSlug}-pt-${nn}`;\n}\n\nfunction normalizeSpecFolderReference(specFolder) {\n  if (!specFolder) {\n    return null;\n  }\n\n  const normalized = String(specFolder)\n    .trim()\n    .replace(/\\\\/g, '/')\n    .replace(/\\/+$/g, '');\n\n  if (!normalized) {\n    return null;\n  }\n\n  const opencodeSpecsMarker = '/.opencode/specs/';\n  const specsMarker = '/specs/';\n  const opencodeIndex = normalized.lastIndexOf(opencodeSpecsMarker);\n  if (opencodeIndex !== -1) {\n    return normalized.slice(opencodeIndex + opencodeSpecsMarker.length);\n  }\n\n  const specsIndex = normalized.lastIndexOf(specsMarker);\n  if (specsIndex !== -1) {\n    return normalized.slice(specsIndex + specsMarker.length);\n  }\n\n  return normalized\n    .replace(/^\\.\\/+/, '')\n    .replace(/^\\.opencode\\/specs\\//, '')\n    .replace(/^specs\\//, '');\n}\n\nfunction findAncestorSpecFolder(specFolder) {\n  let current = path.resolve(specFolder);\n\n  while (true) {\n    const parent = path.dirname(current);\n\n    if (parent === current || path.basename(parent) === 'specs') {\n      return null;\n    }\n\n    if (fs.existsSync(path.join(parent, 'spec.md'))) {\n      return parent;\n    }\n\n    current = parent;\n  }\n}\n\nfunction readPacketSpecFolder(packetDir, mode) {\n  const configPath = path.join(packetDir, MODE_CONFIG_FILE[mode]);\n  if (fs.existsSync(configPath)) {\n    try {\n      const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));\n      return normalizeSpecFolderReference(config.specFolder);\n    } catch (_error) {\n      // Fall through to state log probing.\n    }\n  }\n\n  const stateLogPath = path.join(packetDir, MODE_STATE_FILE[mode]);\n  if (!fs.existsSync(stateLogPath)) {\n    return null;\n  }\n\n  try {\n    const lines = fs.readFileSync(stateLogPath, 'utf8').split(/\\r?\\n/);\n    for (const line of lines) {\n      if (!line.trim()) {\n        continue;\n      }\n      const parsed = JSON.parse(line);\n      return normalizeSpecFolderReference(parsed.specFolder);\n    }\n  } catch (_error) {\n    return null;\n  }\n\n  return null;\n}\n\nfunction listPacketDirectories(rootDir) {\n  if (!fs.existsSync(rootDir)) {\n    return [];\n  }\n\n  return fs.readdirSync(rootDir, { withFileTypes: true })\n    .filter((entry) => entry.isDirectory() && /-pt-\\d+$/.test(entry.name))\n    .map((entry) => entry.name)\n    .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }));\n}\n\nfunction findExistingPacket(rootDir, specFolder, mode) {\n  const targetSpecFolder = normalizeSpecFolderReference(specFolder);\n\n  if (!targetSpecFolder) {\n    return null;\n  }\n\n  const matches = [];\n  for (const packetName of listPacketDirectories(rootDir)) {\n    const packetDir = path.join(rootDir, packetName);\n    if (readPacketSpecFolder(packetDir, mode) === targetSpecFolder) {\n      matches.push(packetName);\n    }\n  }\n\n  return matches.at(-1) || null;\n}\n\n/**\n * Resolve the canonical artifact directory for review or research output.\n *\n * Conventions (post-028 contract fix):\n *   - Root specs ALWAYS use flat: {spec_folder}/{mode}/\n *   - Child phases use FLAT-FIRST:\n *       (a) First run with empty {mode}/ directory → flat (subfolder=null)\n *       (b) Continuation when flat artifact's config matches current target → reuse flat\n *       (c) Existing pt-NN packet matches current target → reuse pt-NN\n *       (d) Prior content exists for non-matching target → allocate pt-NN\n *\n * Subfolder naming convention (when pt-NN allocation kicks in): {phaseSlug}-pt-{NN}\n *   - phaseSlug: the FULL immediate child phase segment under the spec tree\n *     root (e.g. \"019-system-hardening\")\n *   - NN: sequential two-digit counter scoped to that phase within the\n *     artifact root directory; allocated by counting existing same-prefix\n *     entries at call time\n *\n * Example:\n *   - root spec run → {spec_folder}/research/\n *   - child phase first run → {spec_folder}/research/   (flat, no pt-NN wrapper)\n *   - child phase second run with prior content for different target → {spec_folder}/research/{phaseSlug}-pt-NN/\n *   - child phase same-target continuation → reuses prior flat or pt-NN\n *\n * @param {string} specFolder - Absolute or relative path to the target spec folder\n * @param {'review'|'research'|'context'} [mode='review'] - Which artifact type to resolve\n *\n * @returns {{\n *   rootDir: string,\n *   subfolder: string|null,\n *   artifactDir: string,\n *   artifactArchiveRoot: string\n * }} Resolved packet root plus canonical packet/archive directories\n */\nfunction resolveArtifactRoot(specFolder, mode = 'review') {\n  // Workflow write-authority: reject specFolder values that contain\n  // shell metacharacters or quote characters. The YAML workflow interpolates\n  // {spec_folder} into a `node -e` shell command; without this guard, a\n  // malicious specFolder containing single-quotes / semicolons / backticks /\n  // $ / | / & / < / > could break out of the shell-quoted argument and\n  // execute arbitrary code in the Node process or shell.\n  if (typeof specFolder !== 'string' || specFolder.length === 0) {\n    throw new Error(`resolveArtifactRoot: specFolder must be a non-empty string`);\n  }\n  if (/['\"`$;|&<>\\\\]/.test(specFolder)) {\n    throw new Error(\n      `resolveArtifactRoot: specFolder contains forbidden shell metacharacter(s); refusing to proceed`,\n    );\n  }\n\n  const resolved = path.resolve(specFolder);\n  const rootDir = path.join(resolved, mode);\n  const artifactArchiveRoot = path.join(resolved, `${mode}_archive`);\n  const ancestorSpecFolder = findAncestorSpecFolder(resolved);\n\n  // ROOT spec: always flat\n  if (!ancestorSpecFolder) {\n    return {\n      rootDir,\n      subfolder: null,\n      artifactDir: rootDir,\n      artifactArchiveRoot,\n    };\n  }\n\n  // CHILD phase: prefer existing pt-NN packet for current target if any\n  const existingPacket = findExistingPacket(rootDir, resolved, mode);\n  if (existingPacket) {\n    return {\n      rootDir,\n      subfolder: existingPacket,\n      artifactDir: path.join(rootDir, existingPacket),\n      artifactArchiveRoot: path.join(artifactArchiveRoot, existingPacket),\n    };\n  }\n\n  // CHILD phase: check for flat artifact at rootDir\n  const targetSpecFolder = normalizeSpecFolderReference(resolved);\n  const flatConfigPath = path.join(rootDir, MODE_CONFIG_FILE[mode]);\n  const flatStateLogPath = path.join(rootDir, MODE_STATE_FILE[mode]);\n  const hasFlatArtifact = fs.existsSync(flatConfigPath) || fs.existsSync(flatStateLogPath);\n\n  if (hasFlatArtifact) {\n    const flatSpecFolder = readPacketSpecFolder(rootDir, mode);\n    if (flatSpecFolder === null || flatSpecFolder === targetSpecFolder) {\n      // Flat artifact matches current target (or its config is unreadable but rootDir is owned by this target's path) → reuse flat\n      return {\n        rootDir,\n        subfolder: null,\n        artifactDir: rootDir,\n        artifactArchiveRoot,\n      };\n    }\n    // Flat artifact is for a different target — fall through to allocate pt-NN\n  }","lineStart":1,"lineEnd":260,"totalLines":290,"truncated":true}},"title":".opencode/skills/system-spec-kit/shared/review-research-paths.cjs","time":{"start":1783487175524,"end":1783487175534}},"metadata":{"openai":{"itemId":"fc_07eb68de2a932469016a4ddac7721c81918cf8d3369ec1ba7b"}},"id":"prt_f401e9b640012XeU8YqVKGS4jQ","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messageID":"msg_f401e66c1001MfS9cRaTJqPsgc"}}
{"type":"tool_use","timestamp":1783487175549,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_HtK72OyNG50irPnAMSeW9FWE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vitest Config\n3: // ───────────────────────────────────────────────────────────────\n4: // ───────────────────────────────────────────────────────────────\n5: // 1. VITEST\n6: \n7: // ───────────────────────────────────────────────────────────────\n8: import { defineConfig } from 'vitest/config';\n9: import path from 'path';\n10: \n11: const TEST_TIMEOUT_MS = 30_000; // 30s default, increase for CI if needed\n12: const TEARDOWN_TIMEOUT_MS = 1_000;\n13: const _INCLUDE_BENCHES = process.env.SPECKIT_RUN_BENCHES === 'true';\n14: \n15: export default defineConfig({\n16:   root: path.resolve(import.meta.dirname, '..'),\n17:   test: {\n18:     include: [\n19:       'mcp_server/tests/**/*.{vitest,test}.ts',\n20:       '../deep-loop-runtime/tests/**/*.{vitest,test}.ts',\n21:       'scripts/tests/**/*.{vitest,test}.ts',\n22:     ],\n23:     exclude: [\n24:       'mcp_server/tests/memory-save.vitest.ts',\n25:       'mcp_server/tests/archive/**',\n26:     ],\n27:     setupFiles: [\n28:       path.resolve(import.meta.dirname, 'tests', '_support', 'vitest-setup.ts'),\n29:     ],\n30:     // Several script suites mutate shared process-level state and temp project roots.\n31:     // Run files serially so the combined config remains deterministic.\n32:     fileParallelism: false,\n33:     globals: true,\n34:     environment: 'node',\n35:     testTimeout: TEST