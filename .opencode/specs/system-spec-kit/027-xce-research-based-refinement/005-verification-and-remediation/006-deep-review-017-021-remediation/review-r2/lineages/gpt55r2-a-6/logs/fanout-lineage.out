ource scores are unavailable', () => {\n128:     const whyRanked = buildWhyRankedTrace({\n129:       id: 51,\n130:       file_path: '/tmp/vector-only.md',\n131:       anchor_id: 'state',\n132:       similarity: 80,\n133:     }, 1);\n134: \n135:     expect(whyRanked.effectiveScore).toBe(0.8);\n136:     expect(whyRanked.scoreSource).toBe('semantic');\n137:     expect(whyRanked.channels.vector).toBe(0.8);\n138:   });\n139: \n140:   it('surfaces one inline warning for a returned contradicts or supersedes pair', async () => {\n\n(Showing lines 96-140 of 241. Use offset=141 to continue.)\n</content>","metadata":{"preview":"        spec_folder: 'specs/test',\n        rrfScore: 0.9,\n        similarity: 0.7,\n      },\n      {\n        id: 42,\n        file_path: '/tmp/target/doc-b.md',\n        anchor_id: 'state',\n        title: 'Doc B',\n        spec_folder: 'specs/test',\n        rrfScore: 0.2,\n        similarity: 0.6,\n      },\n    ];\n\n    const boosted = memorySearchTestables.applyFolderBoostRanking(rows, {\n      folder: '/tmp/target',\n      factor: 1.3,\n    });\n    memorySearchTestables.stampFinalRankScores(rows);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts","text":"        spec_folder: 'specs/test',\n        rrfScore: 0.9,\n        similarity: 0.7,\n      },\n      {\n        id: 42,\n        file_path: '/tmp/target/doc-b.md',\n        anchor_id: 'state',\n        title: 'Doc B',\n        spec_folder: 'specs/test',\n        rrfScore: 0.2,\n        similarity: 0.6,\n      },\n    ];\n\n    const boosted = memorySearchTestables.applyFolderBoostRanking(rows, {\n      folder: '/tmp/target',\n      factor: 1.3,\n    });\n    memorySearchTestables.stampFinalRankScores(rows);\n    const response = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, true);\n    const results = dataFrom(response).results as Array<Record<string, unknown>>;\n    const firstWhy = results[0].why_ranked as Record<string, unknown>;\n    const secondWhy = results[1].why_ranked as Record<string, unknown>;\n\n    expect(boosted).toBe(true);\n    expect(results.map((row) => row.filePath)).toEqual(['/tmp/target/doc-b.md', '/tmp/other/doc-a.md']);\n    expect(firstWhy).toMatchObject({ rank: 1, effectiveScore: 1, scoreSource: 'finalRank' });\n    expect(secondWhy).toMatchObject({ rank: 2, effectiveScore: 0.5, scoreSource: 'finalRank' });\n  });\n\n  it('normalizes raw vector similarity when source scores are unavailable', () => {\n    const whyRanked = buildWhyRankedTrace({\n      id: 51,\n      file_path: '/tmp/vector-only.md',\n      anchor_id: 'state',\n      similarity: 80,\n    }, 1);\n\n    expect(whyRanked.effectiveScore).toBe(0.8);\n    expect(whyRanked.scoreSource).toBe('semantic');\n    expect(whyRanked.channels.vector).toBe(0.8);\n  });\n\n  it('surfaces one inline warning for a returned contradicts or supersedes pair', async () => {","lineStart":96,"lineEnd":140,"totalLines":241,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts","time":{"start":1781762698765,"end":1781762698768}},"metadata":{"openai":{"itemId":"fc_0ca6a69e419d0321016a338a89c7188191a713a58815211312"}},"id":"prt_ed9552dda0015svhVKVChwYl0D","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed955035b001aDkee2keYWcIds"}}
