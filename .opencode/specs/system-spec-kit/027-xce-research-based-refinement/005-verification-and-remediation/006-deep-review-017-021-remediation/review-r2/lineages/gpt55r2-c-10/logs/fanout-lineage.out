{"type":"tool_use","timestamp":1781764204336,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_ZJcyPi4cHhMDPQiz2Tinox6D","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","offset":1,"limit":400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Input Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // Centralized strict Zod validation schemas for MCP tool inputs.\n5: // Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { z, ZodError } from 'zod';\n12: \n13: import type { ZodType } from 'zod';\n14: \n15: // Feature catalog: Strict Zod schema validation\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: type ToolInput = Record<string, unknown>;\n22: type ToolInputSchema = ZodType<ToolInput>;\n23: \n24: /* ───────────────────────────────────────────────────────────────\n25:    3. HELPERS\n26: ──────────────────────────────────────────────────────────────── */\n27: \n28: export const getSchema = <T extends z.ZodRawShape>(shape: T): z.ZodObject<T> => {\n29:   const strict = process.env.SPECKIT_STRICT_SCHEMAS !== 'false';\n30:   const base = z.object(shape);\n31:   return strict ? base.strict() : base.passthrough();\n32: };\n33: \n34: /* ───────────────────────────────────────────────────────────────\n35:    4. CONSTANTS\n36: ──────────────────────────────────────────────────────────────── */\n37: \n38: // Guard against safeNumericPreprocess.pipe(z.number()) coercing \"\", null, and false to 0.\n39: // Use a safe preprocessor that only accepts actual numbers or numeric strings.\n40: const safeNumericPreprocess = z.preprocess((val) => {\n41:   if (typeof val === 'number') return val;\n42:   if (typeof val === 'string' && val.trim().length > 0) {\n43:     const parsed = Number(val);\n44:     return Number.isFinite(parsed) ? parsed : val;\n45:   }\n46:   return val;\n47: }, z.number());\n48: \n49: const intRange = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().int().min(min).max(max));\n50: const positiveInt = safeNumericPreprocess.pipe(z.number().int().positive());\n51: const positiveIntMax = (max: number) => intRange(1, max);\n52: const boundedNumber = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().min(min).max(max));\n53: const optionalStringArray = z.array(z.string()).optional();\n54: \n55: const PATH_TRAVERSAL_MESSAGE = 'Path must not contain traversal sequences';\n56: const isSafePath = (value: string): boolean => !value.includes('..') && !value.includes('\\0');\n57: const pathString = (minLength = 0) => {\n58:   let schema = z.string();\n59:   if (minLength > 0) {\n60:     schema = schema.min(minLength);\n61:   }\n62:   return schema.refine(isSafePath, { message: PATH_TRAVERSAL_MESSAGE });\n63: };\n64: const optionalPathString = (minLength = 0) => pathString(minLength).optional();\n65: \n66: /** Shared max paths constant — used by both schema and handler. */\n67: export const MAX_INGEST_PATHS = 50;\n68: export const MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS = 1;\n69: export const RESERVED_FEEDBACK_TYPE_ERROR_CODE = 'E_RESERVED_FEEDBACK_TYPE';\n70: \n71: const publicMemoryWriteTools = new Set(['memory_save', 'memory_update']);\n72: const reservedFeedbackEventTypes = new Set([\n73:   'search_shown',\n74:   'result_cited',\n75:   'query_reformulated',\n76:   'same_topic_requery',\n77:   'follow_on_tool_use',\n78: ]);\n79: const reservedFeedbackArtifactTypes = new Set([\n80:   'feedback',\n81:   'feedback_event',\n82:   'feedback_events',\n83:   'feedback-ledger',\n84:   'feedback_ledger',\n85:   'batch_learning_log',\n86:   'learned_feedback',\n87: ]);\n88: \n89: const reservedFeedbackFields = new Set([\n90:   'artifact_type',\n91:   'artifactType',\n92:   'feedback_event_type',\n93:   'feedbackEventType',\n94:   'feedbackType',\n95:   'source_kind',\n96:   'sourceKind',\n97:   'type',\n98: ]);\n99: \n100: const intentEnum = z.enum([\n101:   'add_feature',\n102:   'fix_bug',\n103:   'refactor',\n104:   'security_audit',\n105:   'understand',\n106:   'find_spec',\n107:   'find_decision',\n108: ]);\n109: \n110: const importanceTierEnum = z.enum([\n111:   'constitutional',\n112:   'critical',\n113:   'important',\n114:   'normal',\n115:   'temporary',\n116:   'deprecated',\n117: ]);\n118: \n119: const relationEnum = z.enum([\n120:   'caused',\n121:   'enabled',\n122:   'supersedes',\n123:   'contradicts',\n124:   'derived_from',\n125:   'supports',\n126: ]);\n127: \n128: const routeCategoryEnum = z.enum([\n129:   'narrative_progress',\n130:   'narrative_delivery',\n131:   'decision',\n132:   'handover_state',\n133:   'research_finding',\n134:   'task_update',\n135:   'metadata_only',\n136:   'drop',\n137: ]);\n138: \n139: const mergeModeHintEnum = z.enum([\n140:   'append-as-paragraph',\n141:   'insert-new-adr',\n142:   'append-table-row',\n143:   'update-in-place',\n144:   'append-section',\n145: ]);\n146: \n147: const plannerModeEnum = z.enum(['plan-only', 'hybrid', 'full-auto']);\n148: \n149: const skillGraphQueryTypeEnum = z.enum([\n150:   'depends_on',\n151:   'dependents',\n152:   'enhances',\n153:   'enhanced_by',\n154:   'family_members',\n155:   'conflicts',\n156:   'transitive_path',\n157:   'hub_skills',\n158:   'orphans',\n159:   'subgraph',\n160: ]);\n161: \n162: const skillFamilyEnum = z.enum(['cli', 'mcp', 'sk-code', 'deep-loop', 'sk-util', 'system']);\n163: \n164: /* ───────────────────────────────────────────────────────────────\n165:    5. SCHEMA DEFINITIONS\n166: ──────────────────────────────────────────────────────────────── */\n167: \n168: const memoryContextSchema = getSchema({\n169:   input: z.string().min(1),\n170:   mode: z.enum(['auto', 'quick', 'deep', 'focused', 'resume']).optional(),\n171:   intent: intentEnum.optional(),\n172:   specFolder: optionalPathString(),\n173:   tenantId: z.string().optional(),\n174:   userId: z.string().optional(),\n175:   agentId: z.string().optional(),\n176:   limit: positiveIntMax(100).optional(),\n177:   sessionId: z.string().optional(),\n178:   enableDedup: z.boolean().optional(),\n179:   includeContent: z.boolean().optional(),\n180:   includeTrace: z.boolean().optional(), // Forward to internal memory_search\n181:   tokenUsage: boundedNumber(0, 1).optional(),\n182:   anchors: optionalStringArray,\n183:   profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n184: });\n185: \n186: const memorySearchSchema = getSchema({\n187:   cursor: z.string().min(1).optional(),\n188:   query: z.string().min(2).max(1000).optional(),\n189:   concepts: z.array(z.string().min(1)).min(2).max(5).optional(),\n190:   specFolder: optionalPathString(),\n191:   tenantId: z.string().optional(),\n192:   userId: z.string().optional(),\n193:   agentId: z.string().optional(),\n194:   limit: positiveIntMax(100).optional(),\n195:   sessionId: z.string().optional(),\n196:   enableDedup: z.boolean().optional(),\n197:   tier: importanceTierEnum.optional(),\n198:   contextType: z.string().optional(),\n199:   useDecay: z.boolean().optional(),\n200:   includeContiguity: z.boolean().optional(),\n201:   includeConstitutional: z.boolean().optional(),\n202:   enableSessionBoost: z.boolean().optional(),\n203:   enableCausalBoost: z.boolean().optional(),\n204:   includeContent: z.boolean().optional(),\n205:   anchors: optionalStringArray,\n206:   min_quality_score: boundedNumber(0, 1).optional(),\n207:   minQualityScore: boundedNumber(0, 1).optional(),\n208:   bypassCache: z.boolean().optional(),\n209:   rerank: z.boolean().optional(),\n210:   applyLengthPenalty: z.boolean().optional(),\n211:   applyStateLimits: z.boolean().optional(),\n212:   minState: z.enum(['HOT', 'WARM', 'COLD', 'DORMANT', 'ARCHIVED']).optional(),\n213:   intent: intentEnum.optional(),\n214:   autoDetectIntent: z.boolean().optional(),\n215:   trackAccess: z.boolean().optional(),\n216:   includeArchived: z.boolean().optional(),\n217:   mode: z.enum(['auto', 'deep']).optional(),\n218:   includeTrace: z.boolean().optional(),\n219:   profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n220: });\n221: \n222: // E3: Simplified search schema — 3 params only\n223: const memoryQuickSearchSchema = getSchema({\n224:   query: z.string().min(2).max(1000),\n225:   limit: positiveIntMax(100).optional(),\n226:   specFolder: optionalPathString(),\n227:   tenantId: z.string().optional(),\n228:   userId: z.string().optional(),\n229:   agentId: z.string().optional(),\n230: });\n231: \n232: const memoryMatchTriggersSchema = getSchema({\n233:   prompt: z.string().min(1),\n234:   specFolder: optionalPathString(),\n235:   tenantId: z.string().optional(),\n236:   userId: z.string().optional(),\n237:   agentId: z.string().optional(),\n238:   limit: positiveIntMax(100).optional(),\n239:   session_id: z.string().optional(),\n240:   turnNumber: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n241:   include_cognitive: z.boolean().optional(),\n242: });\n243: \n244: const memorySaveSchema = getSchema({\n245:   filePath: pathString(1),\n246:   force: z.boolean().optional(),\n247:   dryRun: z.boolean().optional(),\n248:   skipPreflight: z.boolean().optional(),\n249:   asyncEmbedding: z.boolean().optional(),\n250:   routeAs: routeCategoryEnum.optional(),\n251:   mergeModeHint: mergeModeHintEnum.optional(),\n252:   plannerMode: plannerModeEnum.optional(),\n253:   targetAnchorId: z.string().optional(),\n254:   // Governance args — accepted by tool-schemas.ts tool definition and\n255:   // validated at runtime by scope-governance.ts.\n256:   tenantId: z.string().optional(),\n257:   userId: z.string().optional(),\n258:   agentId: z.string().optional(),\n259:   sessionId: z.string().optional(),\n260:   provenanceSource: z.string().optional(),\n261:   provenanceActor: z.string().optional(),\n262:   governedAt: z.string().optional(),\n263:   retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n264:   deleteAfter: z.string().optional(),\n265: });\n266: \n267: const governanceSchemaFields = {\n268:   tenantId: z.string().optional(),\n269:   userId: z.string().optional(),\n270:   agentId: z.string().optional(),\n271:   sessionId: z.string().optional(),\n272:   provenanceSource: z.string().optional(),\n273:   provenanceActor: z.string().optional(),\n274:   governedAt: z.string().optional(),\n275:   retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n276:   deleteAfter: z.string().optional(),\n277: };\n278: \n279: // Destructive delete: every mutation path requires `confirm: true`.\n280: // Branch 1 requires `id` + `confirm` (single-record delete).\n281: // Branch 2 requires `specFolder` + `confirm` (bulk folder delete).\n282: const memoryDeleteSchema = getSchema({\n283:   id: positiveInt.optional().describe('Memory ID to delete (required unless specFolder + confirm provided for bulk)'),\n284:   specFolder: optionalPathString().describe('Spec folder scope for bulk delete (requires confirm: true)'),\n285:   confirm: z.literal(true).optional().describe('Must be true for every delete mutation'),\n286: }).superRefine((value, ctx) => {\n287:   if (value.confirm !== true) {\n288:     ctx.addIssue({\n289:       code: z.ZodIssueCode.custom,\n290:       path: ['confirm'],\n291:       message: 'confirm:true is required for every memory_delete mutation',\n292:     });\n293:   }\n294: \n295:   if (value.id === undefined && value.specFolder === undefined) {\n296:     ctx.addIssue({\n297:       code: z.ZodIssueCode.custom,\n298:       path: ['id'],\n299:       message: 'Either id or specFolder is required',\n300:     });\n301:   }\n302: });\n303: \n304: const memoryUpdateSchema = getSchema({\n305:   id: positiveInt,\n306:   title: z.string().optional(),\n307:   triggerPhrases: optionalStringArray,\n308:   importanceWeight: boundedNumber(0, 1).optional(),\n309:   importanceTier: importanceTierEnum.optional(),\n310:   allowPartialUpdate: z.boolean().optional(),\n311: });\n312: \n313: const memoryValidateSchema = getSchema({\n314:   id: positiveInt,\n315:   wasUseful: z.boolean(),\n316:   queryId: z.string().optional(),\n317:   queryTerms: optionalStringArray,\n318:   resultRank: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n319:   totalResultsShown: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n320:   searchMode: z.string().optional(),\n321:   intent: z.string().optional(),\n322:   sessionId: z.string().optional(),\n323:   notes: z.string().optional(),\n324: });\n325: \n326: export const memoryBulkDeleteSchema = getSchema({\n327:   tier: importanceTierEnum,\n328:   specFolder: optionalPathString(),\n329:   confirm: z.literal(true),\n330:   olderThanDays: safeNumericPreprocess\n331:     .pipe(z.number().int().min(MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS))\n332:     .optional(),\n333:   skipCheckpoint: z.boolean().optional(),\n334: });\n335: \n336: export const memoryRetentionSweepSchema = getSchema({\n337:   dryRun: z.boolean().optional(),\n338: });\n339: \n340: export const memoryEmbeddingReconcileSchema = getSchema({\n341:   mode: z.enum(['dry-run', 'apply']).optional(),\n342:   activeOnly: z.boolean().optional(),\n343:   resetMissing: z.boolean().optional(),\n344:   missingFailureScope: z.enum(['retry-retention']).optional(),\n345:   maskedFailedPolicy: z.enum(['reconcile']).optional(),\n346:   providerFailurePolicy: z.enum(['report-only']).optional(),\n347:   requireActiveShard: z.boolean().optional(),\n348:   repairSuccessCoverage: z.boolean().optional(),\n349: });\n350: \n351: const memoryListSchema = getSchema({\n352:   limit: positiveIntMax(100).optional(),\n353:   offset: safeNumericPreprocess.pipe(z.number().int().min(0)).optional(),\n354:   specFolder: optionalPathString(),\n355:   sortBy: z.enum(['created_at', 'updated_at', 'importance_weight']).optional(),\n356:   includeChunks: z.boolean().optional(),\n357: });\n358: \n359: const memoryStatsSchema = getSchema({\n360:   folderRanking: z.enum(['count', 'recency', 'importance', 'composite']).optional(),\n361:   excludePatterns: optionalStringArray,\n362:   includeScores: z.boolean().optional(),\n363:   includeArchived: z.boolean().optional(),\n364:   limit: positiveIntMax(100).optional(),\n365: });\n366: \n367: const memoryHealthSchema = getSchema({\n368:   reportMode: z.enum(['full', 'divergent_aliases']).optional(),\n369:   includeFullReport: z.boolean().optional(),\n370:   limit: positiveIntMax(200).optional(),\n371:   specFolder: optionalPathString(),\n372:   autoRepair: z.boolean().optional(),\n373:   confirmed: z.boolean().optional(),\n374:   cleanFiles: z.boolean().optional(),\n375: });\n376: \n377: const checkpointCreateSchema = getSchema({\n378:   name: z.string().min(1),\n379:   includeEmbeddings: z.boolean().optional(),\n380:   specFolder: optionalPathString(),\n381:   tenantId: z.string().min(1).optional(),\n382:   userId: z.string().min(1).optional(),\n383:   agentId: z.string().min(1).optional(),\n384:   metadata: z.record(z.string(), z.unknown()).optional(),\n385: });\n386: \n387: const checkpointListSchema = getSchema({\n388:   specFolder: optionalPathString(),\n389:   tenantId: z.string().min(1).optional(),\n390:   userId: z.string().min(1).optional(),\n391:   agentId: z.string().min(1).optional(),\n392:   limit: positiveIntMax(100).optional(),\n393: });\n394: \n395: const checkpointRestoreSchema = getSchema({\n396:   name: z.string().min(1),\n397:   tenantId: z.string().min(1).optional(),\n398:   userId: z.string().min(1).optional(),\n399:   agentId: z.string().min(1).optional(),\n400:   clearExisting: z.boolean().optional(),\n\n(Showing lines 1-400 of 818. Use offset=401 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Input Schemas\n// ───────────────────────────────────────────────────────────────\n// Centralized strict Zod validation schemas for MCP tool inputs.\n// Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { z, ZodError } from 'zod';\n\nimport type { ZodType } from 'zod';\n\n// Feature catalog: Strict Zod schema validation\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Input Schemas\n// ───────────────────────────────────────────────────────────────\n// Centralized strict Zod validation schemas for MCP tool inputs.\n// Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { z, ZodError } from 'zod';\n\nimport type { ZodType } from 'zod';\n\n// Feature catalog: Strict Zod schema validation\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ntype ToolInput = Record<string, unknown>;\ntype ToolInputSchema = ZodType<ToolInput>;\n\n/* ───────────────────────────────────────────────────────────────\n   3. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nexport const getSchema = <T extends z.ZodRawShape>(shape: T): z.ZodObject<T> => {\n  const strict = process.env.SPECKIT_STRICT_SCHEMAS !== 'false';\n  const base = z.object(shape);\n  return strict ? base.strict() : base.passthrough();\n};\n\n/* ───────────────────────────────────────────────────────────────\n   4. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\n// Guard against safeNumericPreprocess.pipe(z.number()) coercing \"\", null, and false to 0.\n// Use a safe preprocessor that only accepts actual numbers or numeric strings.\nconst safeNumericPreprocess = z.preprocess((val) => {\n  if (typeof val === 'number') return val;\n  if (typeof val === 'string' && val.trim().length > 0) {\n    const parsed = Number(val);\n    return Number.isFinite(parsed) ? parsed : val;\n  }\n  return val;\n}, z.number());\n\nconst intRange = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().int().min(min).max(max));\nconst positiveInt = safeNumericPreprocess.pipe(z.number().int().positive());\nconst positiveIntMax = (max: number) => intRange(1, max);\nconst boundedNumber = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().min(min).max(max));\nconst optionalStringArray = z.array(z.string()).optional();\n\nconst PATH_TRAVERSAL_MESSAGE = 'Path must not contain traversal sequences';\nconst isSafePath = (value: string): boolean => !value.includes('..') && !value.includes('\\0');\nconst pathString = (minLength = 0) => {\n  let schema = z.string();\n  if (minLength > 0) {\n    schema = schema.min(minLength);\n  }\n  return schema.refine(isSafePath, { message: PATH_TRAVERSAL_MESSAGE });\n};\nconst optionalPathString = (minLength = 0) => pathString(minLength).optional();\n\n/** Shared max paths constant — used by both schema and handler. */\nexport const MAX_INGEST_PATHS = 50;\nexport const MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS = 1;\nexport const RESERVED_FEEDBACK_TYPE_ERROR_CODE = 'E_RESERVED_FEEDBACK_TYPE';\n\nconst publicMemoryWriteTools = new Set(['memory_save', 'memory_update']);\nconst reservedFeedbackEventTypes = new Set([\n  'search_shown',\n  'result_cited',\n  'query_reformulated',\n  'same_topic_requery',\n  'follow_on_tool_use',\n]);\nconst reservedFeedbackArtifactTypes = new Set([\n  'feedback',\n  'feedback_event',\n  'feedback_events',\n  'feedback-ledger',\n  'feedback_ledger',\n  'batch_learning_log',\n  'learned_feedback',\n]);\n\nconst reservedFeedbackFields = new Set([\n  'artifact_type',\n  'artifactType',\n  'feedback_event_type',\n  'feedbackEventType',\n  'feedbackType',\n  'source_kind',\n  'sourceKind',\n  'type',\n]);\n\nconst intentEnum = z.enum([\n  'add_feature',\n  'fix_bug',\n  'refactor',\n  'security_audit',\n  'understand',\n  'find_spec',\n  'find_decision',\n]);\n\nconst importanceTierEnum = z.enum([\n  'constitutional',\n  'critical',\n  'important',\n  'normal',\n  'temporary',\n  'deprecated',\n]);\n\nconst relationEnum = z.enum([\n  'caused',\n  'enabled',\n  'supersedes',\n  'contradicts',\n  'derived_from',\n  'supports',\n]);\n\nconst routeCategoryEnum = z.enum([\n  'narrative_progress',\n  'narrative_delivery',\n  'decision',\n  'handover_state',\n  'research_finding',\n  'task_update',\n  'metadata_only',\n  'drop',\n]);\n\nconst mergeModeHintEnum = z.enum([\n  'append-as-paragraph',\n  'insert-new-adr',\n  'append-table-row',\n  'update-in-place',\n  'append-section',\n]);\n\nconst plannerModeEnum = z.enum(['plan-only', 'hybrid', 'full-auto']);\n\nconst skillGraphQueryTypeEnum = z.enum([\n  'depends_on',\n  'dependents',\n  'enhances',\n  'enhanced_by',\n  'family_members',\n  'conflicts',\n  'transitive_path',\n  'hub_skills',\n  'orphans',\n  'subgraph',\n]);\n\nconst skillFamilyEnum = z.enum(['cli', 'mcp', 'sk-code', 'deep-loop', 'sk-util', 'system']);\n\n/* ───────────────────────────────────────────────────────────────\n   5. SCHEMA DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nconst memoryContextSchema = getSchema({\n  input: z.string().min(1),\n  mode: z.enum(['auto', 'quick', 'deep', 'focused', 'resume']).optional(),\n  intent: intentEnum.optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  limit: positiveIntMax(100).optional(),\n  sessionId: z.string().optional(),\n  enableDedup: z.boolean().optional(),\n  includeContent: z.boolean().optional(),\n  includeTrace: z.boolean().optional(), // Forward to internal memory_search\n  tokenUsage: boundedNumber(0, 1).optional(),\n  anchors: optionalStringArray,\n  profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n});\n\nconst memorySearchSchema = getSchema({\n  cursor: z.string().min(1).optional(),\n  query: z.string().min(2).max(1000).optional(),\n  concepts: z.array(z.string().min(1)).min(2).max(5).optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  limit: positiveIntMax(100).optional(),\n  sessionId: z.string().optional(),\n  enableDedup: z.boolean().optional(),\n  tier: importanceTierEnum.optional(),\n  contextType: z.string().optional(),\n  useDecay: z.boolean().optional(),\n  includeContiguity: z.boolean().optional(),\n  includeConstitutional: z.boolean().optional(),\n  enableSessionBoost: z.boolean().optional(),\n  enableCausalBoost: z.boolean().optional(),\n  includeContent: z.boolean().optional(),\n  anchors: optionalStringArray,\n  min_quality_score: boundedNumber(0, 1).optional(),\n  minQualityScore: boundedNumber(0, 1).optional(),\n  bypassCache: z.boolean().optional(),\n  rerank: z.boolean().optional(),\n  applyLengthPenalty: z.boolean().optional(),\n  applyStateLimits: z.boolean().optional(),\n  minState: z.enum(['HOT', 'WARM', 'COLD', 'DORMANT', 'ARCHIVED']).optional(),\n  intent: intentEnum.optional(),\n  autoDetectIntent: z.boolean().optional(),\n  trackAccess: z.boolean().optional(),\n  includeArchived: z.boolean().optional(),\n  mode: z.enum(['auto', 'deep']).optional(),\n  includeTrace: z.boolean().optional(),\n  profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n});\n\n// E3: Simplified search schema — 3 params only\nconst memoryQuickSearchSchema = getSchema({\n  query: z.string().min(2).max(1000),\n  limit: positiveIntMax(100).optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n});\n\nconst memoryMatchTriggersSchema = getSchema({\n  prompt: z.string().min(1),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  limit: positiveIntMax(100).optional(),\n  session_id: z.string().optional(),\n  turnNumber: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n  include_cognitive: z.boolean().optional(),\n});\n\nconst memorySaveSchema = getSchema({\n  filePath: pathString(1),\n  force: z.boolean().optional(),\n  dryRun: z.boolean().optional(),\n  skipPreflight: z.boolean().optional(),\n  asyncEmbedding: z.boolean().optional(),\n  routeAs: routeCategoryEnum.optional(),\n  mergeModeHint: mergeModeHintEnum.optional(),\n  plannerMode: plannerModeEnum.optional(),\n  targetAnchorId: z.string().optional(),\n  // Governance args — accepted by tool-schemas.ts tool definition and\n  // validated at runtime by scope-governance.ts.\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  sessionId: z.string().optional(),\n  provenanceSource: z.string().optional(),\n  provenanceActor: z.string().optional(),\n  governedAt: z.string().optional(),\n  retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n  deleteAfter: z.string().optional(),\n});\n\nconst governanceSchemaFields = {\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  sessionId: z.string().optional(),\n  provenanceSource: z.string().optional(),\n  provenanceActor: z.string().optional(),\n  governedAt: z.string().optional(),\n  retentionPolicy: z.enum(['keep', 'ephemeral']).optional(),\n  deleteAfter: z.string().optional(),\n};\n\n// Destructive delete: every mutation path requires `confirm: true`.\n// Branch 1 requires `id` + `confirm` (single-record delete).\n// Branch 2 requires `specFolder` + `confirm` (bulk folder delete).\nconst memoryDeleteSchema = getSchema({\n  id: positiveInt.optional().describe('Memory ID to delete (required unless specFolder + confirm provided for bulk)'),\n  specFolder: optionalPathString().describe('Spec folder scope for bulk delete (requires confirm: true)'),\n  confirm: z.literal(true).optional().describe('Must be true for every delete mutation'),\n}).superRefine((value, ctx) => {\n  if (value.confirm !== true) {\n    ctx.addIssue({\n      code: z.ZodIssueCode.custom,\n      path: ['confirm'],\n      message: 'confirm:true is required for every memory_delete mutation',\n    });\n  }\n\n  if (value.id === undefined && value.specFolder === undefined) {\n    ctx.addIssue({\n      code: z.ZodIssueCode.custom,\n      path: ['id'],\n      message: 'Either id or specFolder is required',\n    });\n  }\n});\n\nconst memoryUpdateSchema = getSchema({\n  id: positiveInt,\n  title: z.string().optional(),\n  triggerPhrases: optionalStringArray,\n  importanceWeight: boundedNumber(0, 1).optional(),\n  importanceTier: importanceTierEnum.optional(),\n  allowPartialUpdate: z.boolean().optional(),\n});\n\nconst memoryValidateSchema = getSchema({\n  id: positiveInt,\n  wasUseful: z.boolean(),\n  queryId: z.string().optional(),\n  queryTerms: optionalStringArray,\n  resultRank: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n  totalResultsShown: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n  searchMode: z.string().optional(),\n  intent: z.string().optional(),\n  sessionId: z.string().optional(),\n  notes: z.string().optional(),\n});\n\nexport const memoryBulkDeleteSchema = getSchema({\n  tier: importanceTierEnum,\n  specFolder: optionalPathString(),\n  confirm: z.literal(true),\n  olderThanDays: safeNumericPreprocess\n    .pipe(z.number().int().min(MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS))\n    .optional(),\n  skipCheckpoint: z.boolean().optional(),\n});\n\nexport const memoryRetentionSweepSchema = getSchema({\n  dryRun: z.boolean().optional(),\n});\n\nexport const memoryEmbeddingReconcileSchema = getSchema({\n  mode: z.enum(['dry-run', 'apply']).optional(),\n  activeOnly: z.boolean().optional(),\n  resetMissing: z.boolean().optional(),\n  missingFailureScope: z.enum(['retry-retention']).optional(),\n  maskedFailedPolicy: z.enum(['reconcile']).optional(),\n  providerFailurePolicy: z.enum(['report-only']).optional(),\n  requireActiveShard: z.boolean().optional(),\n  repairSuccessCoverage: z.boolean().optional(),\n});\n\nconst memoryListSchema = getSchema({\n  limit: positiveIntMax(100).optional(),\n  offset: safeNumericPreprocess.pipe(z.number().int().min(0)).optional(),\n  specFolder: optionalPathString(),\n  sortBy: z.enum(['created_at', 'updated_at', 'importance_weight']).optional(),\n  includeChunks: z.boolean().optional(),\n});\n\nconst memoryStatsSchema = getSchema({\n  folderRanking: z.enum(['count', 'recency', 'importance', 'composite']).optional(),\n  excludePatterns: optionalStringArray,\n  includeScores: z.boolean().optional(),\n  includeArchived: z.boolean().optional(),\n  limit: positiveIntMax(100).optional(),\n});\n\nconst memoryHealthSchema = getSchema({\n  reportMode: z.enum(['full', 'divergent_aliases']).optional(),\n  includeFullReport: z.boolean().optional(),\n  limit: positiveIntMax(200).optional(),\n  specFolder: optionalPathString(),\n  autoRepair: z.boolean().optional(),\n  confirmed: z.boolean().optional(),\n  cleanFiles: z.boolean().optional(),\n});\n\nconst checkpointCreateSchema = getSchema({\n  name: z.string().min(1),\n  includeEmbeddings: z.boolean().optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().min(1).optional(),\n  userId: z.string().min(1).optional(),\n  agentId: z.string().min(1).optional(),\n  metadata: z.record(z.string(), z.unknown()).optional(),\n});\n\nconst checkpointListSchema = getSchema({\n  specFolder: optionalPathString(),\n  tenantId: z.string().min(1).optional(),\n  userId: z.string().min(1).optional(),\n  agentId: z.string().min(1).optional(),\n  limit: positiveIntMax(100).optional(),\n});\n\nconst checkpointRestoreSchema = getSchema({\n  name: z.string().min(1),\n  tenantId: z.string().min(1).optional(),\n  userId: z.string().min(1).optional(),\n  agentId: z.string().min(1).optional(),\n  clearExisting: z.boolean().optional(),","lineStart":1,"lineEnd":400,"totalLines":818,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","time":{"start":1781764204326,"end":1781764204333}},"metadata":{"openai":{"itemId":"fc_05adcc0f00918ed9016a33906ba5c48191b45e658d13909c7a"}},"id":"prt_ed96c249f001pHZ53csIfctdXT","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed96c066d001sBNX6XmIwyfqLY"}}
