{"type":"text","timestamp":1781761915151,"sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","part":{"id":"prt_ed94938df001k4JnfANPjwj2z4","messageID":"msg_ed949243d001P2JpZJ88NY48KJ","sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","type":"text","text":"I found tombstone-retention and deletion code worth checking against tests/filters; I’m reading that implementation before deciding whether it is a real finding.","time":{"start":1781761915103,"end":1781761915148},"metadata":{"openai":{"itemId":"msg_0e4a3f3dea6a4441016a33877b15948191b1a3c98498b1212e","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781761915469,"sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","part":{"type":"tool","tool":"read","callID":"call_VvbvdtHeBQfugri3dmoUeYFL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see — aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n341: \n342: function appendRetentionLedger(\n343:   database: Database.Database,\n344:   deletedIds: number[],\n345:   candidates: RetentionExpiredRow[],\n346: ): boolean {\n347:   try {\n348:     mutationLedger.initLedger(database);\n349:     mutationLedger.appendEntry(database, {\n350:       mutation_type: 'delete',\n351:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n352:       prior_hash: null,\n353:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n354:       linked_memory_ids: deletedIds.slice(0, 50),\n355:       decision_meta: {\n356:         tool: 'memory_retention_sweep',\n357:         reason: 'retention_expired',\n358:         totalDeleted: deletedIds.length,\n359:         originalDeleteAfter: candidates\n360:           .filter((candidate) => deletedIds.includes(candidate.id))\n361:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n362:       },\n363:       actor: 'mcp:memory_retention_sweep',\n364:     });\n365:     return true;\n366:   } catch (error: unknown) {\n367:     const message = error instanceof Error ? error.message : String(error);\n368:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n369:     return false;\n370:   }\n371: }\n372: \n373: function runPostDeleteMaintenance(database: Database.Database): void {\n374:   try {\n375:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n376:   } catch (error: unknown) {\n377:     const message = error instanceof Error ? error.message : String(error);\n378:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n379:   }\n380: \n381:   const maintenance = new BetterSqliteMaintenance(database, {\n382:     onMaintenanceError: reportRetentionMaintenanceError,\n383:   });\n384:   maintenance.vacuum();\n385:   maintenance.checkpoint({ mode: 'truncate' });\n386: }\n387: \n388: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n389:   const message = error instanceof Error ? error.message : String(error);\n390:   if (operation === 'auto_vacuum') {\n391:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n392:   } else if (operation === 'incremental_vacuum') {\n393:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n394:   } else if (operation === 'wal_checkpoint') {\n395:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n396:   }\n397: }\n398: \n399: /**\n400:  * Sweep expired governed memory rows.\n401:  *\n402:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n403:  * to enforce the ISO timestamps persisted by governed ingest.\n404:  */\n405: export function runMemoryRetentionSweep(\n406:   database: Database.Database,\n407:   args: MemoryRetentionSweepArgs = {},\n408: ): MemoryRetentionSweepResult {\n409:   const startTime = Date.now();\n410:   const dryRun = args.dryRun === true;\n411:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n412: \n413:   if (!hasTable(database, 'memory_index')) {\n414:     return {\n415:       swept: 0,\n416:       retained: 0,\n417:       protectedCount: 0,\n418:       dryRun,\n419:       durationMs: Date.now() - startTime,\n420:       candidates: [],\n421:       deletedIds: [],\n422:       protectedIds: [],\n423:       ledgerRecorded: null,\n424:       tombstoneState: {\n425:         usesPurgeablePartition: false,\n426:         usingPurgeableIndex: false,\n427:         candidateCount: 0,\n428:         deletedCount: 0,\n429:       },\n430:       edgeState: {\n431:         causalEdgesTablePresent: false,\n432:         candidateEdgeCount: 0,\n433:       },\n434:     };\n435:   }\n436: \n437:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n438:   const initialEdgeState = buildEdgeState(database, candidates);\n439:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n440:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n441:     : null;\n442: \n443:   if (dryRun || candidates.length === 0) {\n444:     const totalRows = countRows(database);\n445:     const dryRunProtectedIds = candidates\n446:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n447:       .map((candidate) => candidate.id);\n448:     return {\n449:       swept: 0,\n450:       retained: totalRows,\n451:       protectedCount: dryRunProtectedIds.length,\n452:       dryRun,\n453:       durationMs: Date.now() - startTime,\n454:       candidates,\n455:       deletedIds: [],\n456:       protectedIds: dryRunProtectedIds,\n457:       ledgerRecorded: null,\n458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n459:       edgeState: initialEdgeState,\n460:       ...(feedbackRetention ? { feedbackRetention } : {}),\n461:     };\n462:   }\n463: \n464:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n465:     const auditTx = database.transaction(() => {\n466:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n467:         database,\n468:         candidates,\n469:         feedbackRetention,\n470:         false,\n471:       );\n472:     });\n473:     auditTx();\n474: \n475:     return {\n476:       swept: 0,\n477:       retained: countRows(database),\n478:       protectedCount: feedbackRetention.protectedIds.length,\n479:       dryRun,\n480:       durationMs: Date.now() - startTime,\n481:       candidates,\n482:       deletedIds: [],\n483:       protectedIds: feedbackRetention.protectedIds,\n484:       extendedIds: [],\n485:       ledgerRecorded: null,\n486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n487:       edgeState: initialEdgeState,\n488:       feedbackRetention,\n489:     };\n490:   }\n491: \n492:   initHistory(database);\n493: \n494:   const deletedIds: number[] = [];\n495:   const protectedIds: number[] = [];\n496:   const extendedIds: number[] = [];\n497:   let ledgerRecorded: boolean | null = null;\n498: \n499:   const sweepTx = database.transaction(() => {\n500:     for (const candidate of candidates) {\n501:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n502:       const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n503:       if (!currentCandidate) {\n504:         continue;\n505:       }\n506:       let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n507:       if (feedbackRetention) {\n508:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n509:         if (!decision) {\n510:           continue;\n511:         }\n512: \n513:         if (decision.decision === 'protect') {\n514:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n515:           protectedIds.push(candidate.id);\n516:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n517:             mode: feedbackRetention.mode,\n518:             applied: true,\n519:             activeGatePassed: feedbackRetention.activeGatePassed,\n520:           });\n521:           feedbackRetention.auditCount += 1;\n522:           continue;\n523:         }\n524: \n525:         if (decision.decision === 'extend') {\n526:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n527:             decision.nextDeleteAfter,\n528:             candidate.id,\n529:           );\n530:           extendedIds.push(candidate.id);\n531:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n532:             mode: feedbackRetention.mode,\n533:             applied: true,\n534:             activeGatePassed: feedbackRetention.activeGatePassed,\n535:           });\n536:           feedbackRetention.auditCount += 1;\n537:           continue;\n538:         }\n539:         feedbackDeleteDecision = decision;\n540:       }\n541:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n542:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n543:       if (isProtectedFromRetentionDelete(currentCandidate)) {\n544:         if (feedbackRetention && feedbackDeleteDecision) {\n545:           recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n546:             mode: feedbackRetention.mode,\n547:             applied: false,\n548:             activeGatePassed: feedbackRetention.activeGatePassed,\n549:           });\n550:           feedbackRetention.auditCount += 1;\n551:         }\n552:         protectedIds.push(currentCandidate.id);\n553:         recordGovernanceAudit(database, {\n554:           action: 'retention_sweep',\n555:           decision: 'deny',\n556:           memoryId: currentCandidate.id,\n557:           logicalKey: currentCandidate.filePath,\n558:           tenantId: currentCandidate.tenantId ?? undefined,\n559:           userId: currentCandidate.userId ?? undefined,\n560:           agentId: currentCandidate.agentId ?? undefined,\n561:           sessionId: currentCandidate.sessionId ?? undefined,\n562:           reason: 'retention_tier_protected',\n563:           metadata: {\n564:             originalDeleteAfter: currentCandidate.deleteAfter,\n565:             importanceTier: currentCandidate.importanceTier,\n566:             isPinned: currentCandidate.isPinned,\n567:             specFolder: currentCandidate.specFolder,\n568:             filePath: currentCandidate.filePath,\n569:           },\n570:         });\n571:         continue;\n572:       }\n573:       if (feedbackRetention && feedbackDeleteDecision) {\n574:         recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n575:           mode: feedbackRetention.mode,\n576:           applied: true,\n577:           activeGatePassed: feedbackRetention.activeGatePassed,\n578:         });\n579:         feedbackRetention.auditCount += 1;\n580:       }\n581:       const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n582:       if (!deleted) {\n583:         continue;\n584:       }\n585: \n586:       deletedIds.push(currentCandidate.id);\n587: \n588:       recordHistory(\n589:         currentCandidate.id,\n590:         'DELETE',\n591:         {\n592:           reason: 'retention_expired',\n593:           deleteAfter: currentCandidate.deleteAfter,\n594:           filePath: currentCandidate.filePath,\n595:         },\n596:         null,\n597:         'mcp:memory_retention_sweep',\n598:         currentCandidate.specFolder,\n599:       );\n600: \n601:       recordGovernanceAudit(database, {\n602:         action: 'retention_sweep',\n603:         decision: 'delete',\n604:         memoryId: currentCandidate.id,\n605:         logicalKey: currentCandidate.filePath,\n606:         tenantId: currentCandidate.tenantId ?? undefined,\n607:         userId: currentCandidate.userId ?? undefined,\n608:         agentId: currentCandidate.agentId ?? undefined,\n609:         sessionId: currentCandidate.sessionId ?? undefined,\n610:         reason: 'retention_expired',\n611:         metadata: {\n612:           originalDeleteAfter: currentCandidate.deleteAfter,\n613:           delete_after: currentCandidate.deleteAfter,\n614:           specFolder: currentCandidate.specFolder,\n615:           filePath: currentCandidate.filePath,\n616:         },\n617:       });\n618:     }\n619: \n620:     if (deletedIds.length > 0) {\n621:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n622:     }\n623:   });\n624: \n625:   sweepTx();\n626:   if (deletedIds.length > 0) {\n627:     runPostDeleteMaintenance(database);\n628:   }\n629:   if (feedbackRetention) {\n630:     feedbackRetention.extendedIds = extendedIds;\n631:     feedbackRetention.protectedIds = protectedIds;\n632:     feedbackRetention.deletedIds = deletedIds;\n633:   }\n634: \n635:   return {\n636:     swept: deletedIds.length,\n637:     retained: countRows(database),\n638:     protectedCount: protectedIds.length,\n639:     dryRun,\n640:     durationMs: Date.now() - startTime,\n641:     candidates,\n642:     deletedIds,\n643:     protectedIds,\n644:     ledgerRecorded,\n645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n646:     edgeState: initialEdgeState,\n647:     ...(feedbackRetention ? { extendedIds } : {}),\n648:     ...(feedbackRetention ? { feedbackRetention } : {}),\n649:   };\n650: }\n\n(End of file - total 650 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see — aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n      if (!currentCandidate) {\n        continue;\n      }\n      let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n        feedbackDeleteDecision = decision;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(currentCandidate)) {\n        if (feedbackRetention && feedbackDeleteDecision) {\n          recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n            mode: feedbackRetention.mode,\n            applied: false,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n        }\n        protectedIds.push(currentCandidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: currentCandidate.id,\n          logicalKey: currentCandidate.filePath,\n          tenantId: currentCandidate.tenantId ?? undefined,\n          userId: currentCandidate.userId ?? undefined,\n          agentId: currentCandidate.agentId ?? undefined,\n          sessionId: currentCandidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: currentCandidate.deleteAfter,\n            importanceTier: currentCandidate.importanceTier,\n            isPinned: currentCandidate.isPinned,\n            specFolder: currentCandidate.specFolder,\n            filePath: currentCandidate.filePath,\n          },\n        });\n        continue;\n      }\n      if (feedbackRetention && feedbackDeleteDecision) {\n        recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(currentCandidate.id);\n\n      recordHistory(\n        currentCandidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: currentCandidate.deleteAfter,\n          filePath: currentCandidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        currentCandidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: currentCandidate.id,\n        logicalKey: currentCandidate.filePath,\n        tenantId: currentCandidate.tenantId ?? undefined,\n        userId: currentCandidate.userId ?? undefined,\n        agentId: currentCandidate.agentId ?? undefined,\n        sessionId: currentCandidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: currentCandidate.deleteAfter,\n          delete_after: currentCandidate.deleteAfter,\n          specFolder: currentCandidate.specFolder,\n          filePath: currentCandidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),\n    ...(feedbackRetention ? { feedbackRetention } : {}),\n  };\n}","lineStart":1,"lineEnd":650,"totalLines":650,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781761915461,"end":1781761915467}},"metadata":{"openai":{"itemId":"fc_0e4a3f3dea6a4441016a33877b22548191bb55a9a622593a4a"}},"id":"prt_ed949390e0019dn3hQlBRpPChb","sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","messageID":"msg_ed949243d001P2JpZJ88NY48KJ"}}
