eturn JSON.stringify(value);\n522:   return JSON.stringify(value, null, 2);\n523: }\n524: \n525: function compactTool(tool: ToolDefinition): Record<string, unknown> {\n526:   return {\n527:     name: tool.name,\n528:     command: tool.name,\n529:     kebabCommand: toKebabCommand(tool.name),\n530:     camelCommand: toCamelCommand(tool.name),\n531:     aliases: commandAliases(tool.name),\n532:     description: tool.description,\n533:   };\n534: }\n535: \n536: function renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n537:   const payload = {\n538:     status: 'ok',\n539:     data: {\n540:       count: TOOL_DEFINITIONS.length,\n541:       mode,\n542:       tools: TOOL_DEFINITIONS.map((tool) => ({\n543:         name: tool.name,\n544:         command: tool.name,\n545:         kebabCommand: toKebabCommand(tool.name),\n546:         camelCommand: toCamelCommand(tool.name),\n547:         aliases: commandAliases(tool.name),\n548:         description: tool.description,\n549:         inputSchema: tool.inputSchema,\n550:       })),\n551:     },\n552:   };\n553:   const compactPayload = {\n554:     status: 'ok',\n555:     data: {\n556:       count: TOOL_DEFINITIONS.length,\n557:       mode,\n558:       tools: TOOL_DEFINITIONS.map(compactTool),\n559:     },\n560:   };\n561:   const namesOnlyPayload = {\n562:     status: 'ok',\n563:     data: {\n564:       count: TOOL_DEFINITIONS.length,\n565:       mode,\n566:       names: TOOL_DEFINITIONS.map((tool) => tool.name),\n567:     },\n568:   };\n569: \n570:   if (format === 'text') {\n571:     return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n572:   }\n573:   if (mode === 'compact') return renderJson(compactPayload, format);\n574:   if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n575:   return renderJson(payload, format);\n576: }\n577: \n578: function completionWords(): string[] {\n579:   return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n580: }\n581: \n582: function shellWords(words: readonly string[]): string {\n583:   return words.join(' ');\n584: }\n585: \n586: function renderBashCompletion(): string {\n587:   const commands = shellWords(completionWords());\n588:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n589:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n590:   return `_spec_memory_completion() {\n591:   local cur\n592:   COMPREPLY=()\n593:   cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n594:   if [[ \\${COMP_CWORD} -eq 1 ]]; then\n595:     COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n596:     return 0\n597:   fi\n598:   case \"\\${COMP_WORDS[1]}\" in\n599:     completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n600:     list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n601:     *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n602:   esac\n603: }\n604: complete -F _spec_memory_completion spec-memory`;\n605: }\n606: \n607: function renderZshCompletion(): string {\n608:   const commands = shellWords(completionWords());\n609:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n610:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n611:   return `#compdef spec-memory\n612: _spec_memory() {\n613:   local -a commands common_flags list_flags shells\n614:   commands=(${commands})\n615:   common_flags=(${commonFlags})\n616:   list_flags=(${listFlags})\n617:   shells=(bash zsh)\n618:   if (( CURRENT == 2 )); then\n619:     _describe 'commands' commands\n620:     return\n621:   fi\n622:   case \\${words[2]} in\n623:     completion) _describe 'shells' shells ;;\n624:     list-tools) _describe 'flags' list_flags ;;\n625:     *) _describe 'flags' common_flags ;;\n626:   esac\n627: }\n628: _spec_memory \"$@\"`;\n629: }\n630: \n631: function renderCompletion(shell: CompletionShell): string {\n632:   return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n633: }\n634: \n635: function isErrorPayload(payload: unknown): boolean {\n636:   return Boolean(payload)\n637:     && typeof payload === 'object'\n638:     && !Array.isArray(payload)\n639:     && (payload as { readonly status?: unknown }).status === 'error';\n640: }\n641: \n642: function extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n643:   const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n644:   const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n645:   if (firstText) {\n646:     try {\n647:       return {\n648:         payload: JSON.parse(firstText) as unknown,\n649:         isError: toolResult?.isError === true,\n650:       };\n651:     } catch {\n652:       return {\n653:         payload: {\n654:           status: toolResult?.isError ? 'error' : 'ok',\n655:           tool: toolName,\n656:           text: firstText,\n657:         },\n658:         isError: toolResult?.isError === true,\n659:       };\n660:     }\n661:   }\n662:   return {\n663:     payload: {\n664:       status: toolResult?.isError ? 'error' : 'ok',\n665:       tool: toolName,\n666:       result,\n667:     },\n668:     isError: toolResult?.isError === true,\n669:   };\n670: }\n671: \n672: function renderPayload(payload: unknown, format: OutputFormat): string {\n673:   if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n674:   if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n675:     const record = payload as Record<string, unknown>;\n676:     if (typeof record.summary === 'string') return record.summary;\n677:     if (typeof record.error === 'string') return record.error;\n678:     if (typeof record.message === 'string') return record.message;\n679:   }\n680:   return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n681: }\n682: \n683: function isProtocolMismatch(error: unknown): boolean {\n684:   if (error instanceof JsonRpcError && error.code === -32002) return true;\n685:   const message = error instanceof Error ? error.message : String(error);\n686:   return /protocol.*(mismatch|changed|version)/i.test(message);\n687: }\n688: \n689: function isRetryableError(error: unknown): boolean {\n690:   if (error instanceof CliRetryableError) return true;\n691:   if (error instanceof JsonRpcError && error.code === -32001) return true;\n692:   const message = error instanceof Error ? error.message : String(error);\n693:   return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n694: }\n695: \n696: function exitCodeForError(error: unknown): number {\n697:   if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n698:   if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n699:   if (isRetryableError(error)) return EXIT_RETRYABLE;\n700:   if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n701:   return EXIT_RUNTIME;\n702: }\n703: \n704: function levenshteinDistance(left: string, right: string): number {\n705:   const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n706:   const current = new Array<number>(right.length + 1);\n707: \n708:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n709:     current[0] = leftIndex;\n710:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n711:       const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n712:       current[rightIndex] = Math.min(\n713:         current[rightIndex - 1] + 1,\n714:         previous[rightIndex] + 1,\n715:         previous[rightIndex - 1] + cost,\n716:       );\n717:     }\n718:     previous.splice(0, previous.length, ...current);\n719:   }\n720: \n721:   return previous[right.length];\n722: }\n723: \n724: function closestCommand(command: string): string | undefined {\n725:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n726:   targets.set('completion', 'completion');\n727:   for (const tool of TOOL_DEFINITIONS) {\n728:     for (const alias of commandAliases(tool.name)) {\n729:       targets.set(alias, tool.name);\n730:     }\n731:   }\n732: \n733:   let best: { readonly command: string; readonly distance: number } | null = null;\n734:   for (const [alias, canonical] of targets) {\n735:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n736:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n737:       best = { command: canonical, distance };\n738:     }\n739:   }\n740: \n741:   if (!best) return undefined;\n742:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n743:   return best.distance <= threshold ? best.command : undefined;\n744: }\n745: \n746: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n747:   const match = message.match(/^Unknown command: (.+)$/);\n748:   if (!match) return null;\n749:   return {\n750:     hint: 'Try `list-tools` to see available commands.',\n751:     suggestion: closestCommand(match[1]),\n752:   };\n753: }\n754: \n755: function socketPathTooLong(socketPath: string): boolean {\n756:   if (socketPath.startsWith('tcp://')) return false;\n757:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n758: }\n759: \n760: // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n761: // (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n762: // mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n763: // a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n764: // symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\n765: function assertSocketPerimeter(socketDir: string): void {\n766:   const dirLink = lstatSync(socketDir);\n767:   if (dirLink.isSymbolicLink()) {\n768:     throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n769:   }\n770:   const dirStat = statSync(socketDir);\n771:   const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n772:   if (uid !== null && dirStat.uid !== uid) {\n773:     throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n774:   }\n775:   if ((dirStat.mode & 0o022) !== 0) {\n776:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n777:   }\n778:   const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n779:   let nodeLink;\n780:   try {\n\n(Showing lines 421-780 of 1084. Use offset=781 to continue.)\n</content>","metadata":{"preview":"      timeoutMs = parsePositiveInteger(read.value, option);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'session-id') {\n      const read = readOptionValue(tokens, index, option);\n      sessionId = read.value;\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'warm-only') {\n      const inline = token.match(/^--[^=]+=(.*)$/);\n      warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'no-warm-only') {\n      warmOnly = false;\n      index += 1;\n      continue;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"      timeoutMs = parsePositiveInteger(read.value, option);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'session-id') {\n      const read = readOptionValue(tokens, index, option);\n      sessionId = read.value;\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'warm-only') {\n      const inline = token.match(/^--[^=]+=(.*)$/);\n      warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'no-warm-only') {\n      warmOnly = false;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'compact') {\n      toolListMode = 'compact';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'names-only') {\n      toolListMode = 'names-only';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'json') {\n      const read = readOptionValue(tokens, index, option);\n      jsonPayload = parseJsonObject(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n\n    if (!tool) {\n      throw new CliUsageError(`Unknown command: ${command}`);\n    }\n\n    const propertyName = resolvePropertyName(rawFlag, tool);\n    const inline = token.match(/^--[^=]+=(.*)$/);\n    if (inline) {\n      parsedArgs[propertyName] = parseValue(inline[1]);\n      index += 1;\n      continue;\n    }\n\n    const next = tokens[index + 1];\n    if (next === undefined || next.startsWith('--')) {\n      parsedArgs[propertyName] = true;\n      index += 1;\n      continue;\n    }\n    parsedArgs[propertyName] = parseValue(next);\n    index += 2;\n  }\n\n  if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n    throw new CliUsageError('--json cannot be combined with per-parameter flags');\n  }\n\n  return {\n    command,\n    format,\n    timeoutMs,\n    sessionId,\n    warmOnly,\n    toolListMode,\n    completionShell,\n    args: jsonPayload ?? parsedArgs,\n    help: false,\n    version: false,\n  };\n}\n\nfunction validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n  if (RESERVED_COMMANDS.has(parsed.command)) return null;\n  const tool = getToolDefinition(parsed.command);\n  if (!tool) {\n    throw new CliUsageError(`Unknown command: ${parsed.command}`);\n  }\n\n  const args = { ...parsed.args };\n  const properties = new Set(inputPropertyNames(tool));\n  if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n    args.sessionId = parsed.sessionId;\n  } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n    args.session_id = parsed.sessionId;\n  }\n\n  return {\n    tool,\n    args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n  };\n}\n\nfunction renderJson(value: unknown, format: OutputFormat): string {\n  if (format === 'jsonl') return JSON.stringify(value);\n  return JSON.stringify(value, null, 2);\n}\n\nfunction compactTool(tool: ToolDefinition): Record<string, unknown> {\n  return {\n    name: tool.name,\n    command: tool.name,\n    kebabCommand: toKebabCommand(tool.name),\n    camelCommand: toCamelCommand(tool.name),\n    aliases: commandAliases(tool.name),\n    description: tool.description,\n  };\n}\n\nfunction renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n  const payload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      tools: TOOL_DEFINITIONS.map((tool) => ({\n        name: tool.name,\n        command: tool.name,\n        kebabCommand: toKebabCommand(tool.name),\n        camelCommand: toCamelCommand(tool.name),\n        aliases: commandAliases(tool.name),\n        description: tool.description,\n        inputSchema: tool.inputSchema,\n      })),\n    },\n  };\n  const compactPayload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      tools: TOOL_DEFINITIONS.map(compactTool),\n    },\n  };\n  const namesOnlyPayload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      names: TOOL_DEFINITIONS.map((tool) => tool.name),\n    },\n  };\n\n  if (format === 'text') {\n    return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n  }\n  if (mode === 'compact') return renderJson(compactPayload, format);\n  if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n  return renderJson(payload, format);\n}\n\nfunction completionWords(): string[] {\n  return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n}\n\nfunction shellWords(words: readonly string[]): string {\n  return words.join(' ');\n}\n\nfunction renderBashCompletion(): string {\n  const commands = shellWords(completionWords());\n  const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n  const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n  return `_spec_memory_completion() {\n  local cur\n  COMPREPLY=()\n  cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n  if [[ \\${COMP_CWORD} -eq 1 ]]; then\n    COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n    return 0\n  fi\n  case \"\\${COMP_WORDS[1]}\" in\n    completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n    list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n    *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n  esac\n}\ncomplete -F _spec_memory_completion spec-memory`;\n}\n\nfunction renderZshCompletion(): string {\n  const commands = shellWords(completionWords());\n  const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n  const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n  return `#compdef spec-memory\n_spec_memory() {\n  local -a commands common_flags list_flags shells\n  commands=(${commands})\n  common_flags=(${commonFlags})\n  list_flags=(${listFlags})\n  shells=(bash zsh)\n  if (( CURRENT == 2 )); then\n    _describe 'commands' commands\n    return\n  fi\n  case \\${words[2]} in\n    completion) _describe 'shells' shells ;;\n    list-tools) _describe 'flags' list_flags ;;\n    *) _describe 'flags' common_flags ;;\n  esac\n}\n_spec_memory \"$@\"`;\n}\n\nfunction renderCompletion(shell: CompletionShell): string {\n  return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n}\n\nfunction isErrorPayload(payload: unknown): boolean {\n  return Boolean(payload)\n    && typeof payload === 'object'\n    && !Array.isArray(payload)\n    && (payload as { readonly status?: unknown }).status === 'error';\n}\n\nfunction extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n  const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n  const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n  if (firstText) {\n    try {\n      return {\n        payload: JSON.parse(firstText) as unknown,\n        isError: toolResult?.isError === true,\n      };\n    } catch {\n      return {\n        payload: {\n          status: toolResult?.isError ? 'error' : 'ok',\n          tool: toolName,\n          text: firstText,\n        },\n        isError: toolResult?.isError === true,\n      };\n    }\n  }\n  return {\n    payload: {\n      status: toolResult?.isError ? 'error' : 'ok',\n      tool: toolName,\n      result,\n    },\n    isError: toolResult?.isError === true,\n  };\n}\n\nfunction renderPayload(payload: unknown, format: OutputFormat): string {\n  if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n  if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n    const record = payload as Record<string, unknown>;\n    if (typeof record.summary === 'string') return record.summary;\n    if (typeof record.error === 'string') return record.error;\n    if (typeof record.message === 'string') return record.message;\n  }\n  return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n}\n\nfunction isProtocolMismatch(error: unknown): boolean {\n  if (error instanceof JsonRpcError && error.code === -32002) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /protocol.*(mismatch|changed|version)/i.test(message);\n}\n\nfunction isRetryableError(error: unknown): boolean {\n  if (error instanceof CliRetryableError) return true;\n  if (error instanceof JsonRpcError && error.code === -32001) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n}\n\nfunction exitCodeForError(error: unknown): number {\n  if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n  if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n  if (isRetryableError(error)) return EXIT_RETRYABLE;\n  if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n  return EXIT_RUNTIME;\n}\n\nfunction levenshteinDistance(left: string, right: string): number {\n  const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n  const current = new Array<number>(right.length + 1);\n\n  for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n    current[0] = leftIndex;\n    for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n      const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n      current[rightIndex] = Math.min(\n        current[rightIndex - 1] + 1,\n        previous[rightIndex] + 1,\n        previous[rightIndex - 1] + cost,\n      );\n    }\n    previous.splice(0, previous.length, ...current);\n  }\n\n  return previous[right.length];\n}\n\nfunction closestCommand(command: string): string | undefined {\n  const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n  targets.set('completion', 'completion');\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      targets.set(alias, tool.name);\n    }\n  }\n\n  let best: { readonly command: string; readonly distance: number } | null = null;\n  for (const [alias, canonical] of targets) {\n    const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n    if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n      best = { command: canonical, distance };\n    }\n  }\n\n  if (!best) return undefined;\n  const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n  return best.distance <= threshold ? best.command : undefined;\n}\n\nfunction unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n  const match = message.match(/^Unknown command: (.+)$/);\n  if (!match) return null;\n  return {\n    hint: 'Try `list-tools` to see available commands.',\n    suggestion: closestCommand(match[1]),\n  };\n}\n\nfunction socketPathTooLong(socketPath: string): boolean {\n  if (socketPath.startsWith('tcp://')) return false;\n  return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n}\n\n// `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n// (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n// mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n// a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n// symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\nfunction assertSocketPerimeter(socketDir: string): void {\n  const dirLink = lstatSync(socketDir);\n  if (dirLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n  }\n  const dirStat = statSync(socketDir);\n  const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n  if (uid !== null && dirStat.uid !== uid) {\n    throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n  }\n  if ((dirStat.mode & 0o022) !== 0) {\n    throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n  }\n  const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n  let nodeLink;\n  try {","lineStart":421,"lineEnd":780,"totalLines":1084,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781762036423,"end":1781762036427}},"metadata":{"openai":{"itemId":"fc_0b50bd46bc0ce1ad016a3387f45ad48191a2bec0f4294ed155"}},"id":"prt_ed94b12b1001qzu8WLM0M1XJCP","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94aed360019KK8P6LBX130rw"}}
{"type":"tool_use","timestamp":1781762036487,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_RuqX2lXvX7if2b6HgHely0pg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","offset":781,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts</path>\n<type>file</type>\n<content>\n781:     nodeLink = lstatSync(socketPath);\n782:   } catch (error: unknown) {\n783:     const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n784:     if (code === 'ENOENT') return;\n785:     throw error;\n786:   }\n787:   if (nodeLink.isSymbolicLink()) {\n788:     throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n789:   }\n790:   if (uid !== null && nodeLink.uid !== uid) {\n791:     throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n792:   }\n793: }\n794: \n795: function ensureSocketEnvironment(): void {\n796:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n797:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n798:   }\n799:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n800:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n801:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n802:   assertSocketPerimeter(socketDir);\n803: }\n804: \n805: function sleep(ms: number): Promise<void> {\n806:   return new Promise((resolve) => setTimeout(resolve, ms));\n807: }\n808: \n809: function spawnLauncher(paths: RepoPaths): void {\n810:   const child = spawn(process.execPath, [paths.launcherPath], {\n811:     cwd: paths.repoRoot,\n812:     env: process.env,\n813:     detached: true,\n814:     stdio: 'ignore',\n815:   });\n816:   child.unref();\n817: }\n818: \n819: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n820:   const deadline = Date.now() + timeoutMs;\n821:   let lastReason = 'not probed';\n822: \n823:   while (Date.now() <= deadline) {\n824:     const remaining = Math.max(1, deadline - Date.now());\n825:     const probe = await bridge.probeDaemon(socketPath, {\n826:       timeoutMs: Math.min(remaining, 5000),\n827:       deepProbe: true,\n828:     });\n829:     if (probe.status === 'alive') return;\n830:     lastReason = probe.reason ?? probe.status;\n831:     await sleep(100);\n832:   }\n833: \n834:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n835: }\n836: \n837: class JsonRpcSocketClient {\n838:   private nextId = 1;\n839:   private readonly decoder = new StringDecoder('utf8');\n840: \n841:   private constructor(\n842:     private readonly socket: net.Socket,\n843:   ) {}\n844: \n845:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n846:     return new Promise((resolve, reject) => {\n847:       let socket: net.Socket;\n848:       let settled = false;\n849:       const finish = (error?: Error): void => {\n850:         if (settled) return;\n851:         settled = true;\n852:         clearTimeout(timer);\n853:         socket.off?.('connect', onConnect);\n854:         socket.off?.('error', onError);\n855:         if (error) {\n856:           socket.destroy?.();\n857:           reject(error);\n858:           return;\n859:         }\n860:         resolve(new JsonRpcSocketClient(socket));\n861:       };\n862:       const onConnect = (): void => finish();\n863:       const onError = (error: Error): void => finish(error);\n864:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n865:       timer.unref?.();\n866: \n867:       try {\n868:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n869:         socket = typeof connectionOptions === 'string'\n870:           ? net.createConnection(connectionOptions)\n871:           : net.createConnection(connectionOptions);\n872:       } catch (error: unknown) {\n873:         clearTimeout(timer);\n874:         reject(error instanceof Error ? error : new Error(String(error)));\n875:         return;\n876:       }\n877:       socket.once('connect', onConnect);\n878:       socket.once('error', onError);\n879:     });\n880:   }\n881: \n882:   notify(method: string, params?: unknown): void {\n883:     const frame = params === undefined\n884:       ? { jsonrpc: '2.0', method }\n885:       : { jsonrpc: '2.0', method, params };\n886:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n887:   }\n888: \n889:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n890:     const id = this.nextId++;\n891:     const request = { jsonrpc: '2.0', id, method, params };\n892:     return new Promise((resolve, reject) => {\n893:       let buffer = '';\n894:       let settled = false;\n895: \n896:       const cleanup = (): void => {\n897:         clearTimeout(timer);\n898:         this.socket.off('data', onData);\n899:         this.socket.off('error', onError);\n900:         this.socket.off('close', onClose);\n901:       };\n902:       const finish = (error: unknown, value?: unknown): void => {\n903:         if (settled) return;\n904:         settled = true;\n905:         cleanup();\n906:         if (error) {\n907:           reject(error);\n908:           return;\n909:         }\n910:         resolve(value);\n911:       };\n912:       const onData = (chunk: Buffer | string): void => {\n913:         buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n914:         let newlineIndex = buffer.indexOf('\\n');\n915:         while (newlineIndex !== -1) {\n916:           const line = buffer.slice(0, newlineIndex).trim();\n917:           buffer = buffer.slice(newlineIndex + 1);\n918:           newlineIndex = buffer.indexOf('\\n');\n919:           if (!line) continue;\n920:           let parsed: JsonRpcResponse;\n921:           try {\n922:             parsed = JSON.parse(line) as JsonRpcResponse;\n923:           } catch {\n924:             continue;\n925:           }\n926:           if (parsed.id !== id) continue;\n927:           if (parsed.error) {\n928:             finish(new JsonRpcError(parsed.error));\n929:             return;\n930:           }\n931:           finish(null, parsed.result);\n932:           return;\n933:         }\n934:       };\n935:       const onError = (error: Error): void => finish(error);\n936:       const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n937:       const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n938:       timer.unref?.();\n939: \n940:       this.socket.on('data', onData);\n941:       this.socket.once('error', onError);\n942:       this.socket.once('close', onClose);\n943:       this.socket.write(`${JSON.stringify(request)}\\n`);\n944:     });\n945:   }\n946: \n947:   close(): void {\n948:     this.socket.end();\n949:     this.socket.destroy();\n950:   }\n951: }\n952: \n953: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n954:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n955:   if (initialProbe.status === 'alive') return;\n956:   if (warmOnly) {\n957:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n958:   }\n959:   spawnLauncher(paths);\n960:   await waitForDaemon(socketPath, bridge, timeoutMs);\n961: }\n962: \n963: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n964:   ensureSocketEnvironment();\n965:   const paths = findRepoPaths();\n966:   const bridge = loadBridge(paths);\n967:   const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n968:   if (socketPathTooLong(socketPath)) {\n969:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n970:   }\n971: \n972:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n973: \n974:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n975:   try {\n976:     const initialize = await client.request('initialize', {\n977:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n978:       capabilities: {},\n979:       clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n980:     }, timeoutMs) as InitializeResult;\n981:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n982:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n983:     }\n984:     client.notify('notifications/initialized');\n985:     return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n986:   } finally {\n987:     client.close();\n988:   }\n989: }\n990: \n991: export async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n992:   try {\n993:     const parsed = parseCliArgs(argv);\n994:     if (parsed.help) {\n995:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n996:       return EXIT_SUCCESS;\n997:     }\n998:     if (parsed.version) {\n999:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n1000:       return EXIT_SUCCESS;\n1001:     }\n1002:     if (parsed.command === 'list-tools') {\n1003:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n1004:       return EXIT_SUCCESS;\n1005:     }\n1006:     if (parsed.command === 'completion') {\n1007:       if (!parsed.completionShell) {\n1008:         throw new CliUsageError('completion requires a shell: bash or zsh');\n1009:       }\n1010:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n1011:       return EXIT_SUCCESS;\n1012:     }\n1013: \n1014:     const validated = validateCommand(parsed);\n1015:     if (!validated) {\n1016:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n1017:     }\n1018:     const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n1019:     const { payload, isError } = extractToolPayload(validated.tool.name, result);\n1020:     await writeLine(io.stdout, renderPayload(payload, parsed.format));\n1021:     return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n1022:   } catch (error: unknown) {\n1023:     const exitCode = exitCodeForError(error);\n1024:     const message = error instanceof Error ? error.message : String(error);\n1025:     const unknownCommand = unknownCommandContext(message);\n1026:     const payload = {\n1027:       status: 'error',\n1028:       error: message,\n1029:       exitCode,\n1030:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n1031:       ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n1032:     };\n1033:     const format = (() => {\n1034:       try {\n1035:         return parseCliArgs(argv).format;\n1036:       } catch {\n1037:         return 'text' as OutputFormat;\n1038:       }\n1039:     })();\n1040:     if (format === 'json' || format === 'jsonl') {\n1041:       await writeLine(io.stderr, renderJson(payload, format));\n1042:     } else {\n1043:       await writeLine(io.stderr, [\n1044:         `ERROR: ${message}`,\n1045:         unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n1046:         unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n1047:       ].filter((line): line is string => Boolean(line)).join('\\n'));\n1048:     }\n1049:     return exitCode;\n1050:   }\n1051: }\n1052: \n1053: function isCliEntrypoint(): boolean {\n1054:   const invoked = process.argv[1];\n1055:   if (!invoked) return false;\n1056:   return path.resolve(invoked) === path.resolve(currentModulePath());\n1057: }\n1058: \n1059: export const __testing = {\n1060:   DEFAULT_SOCKET_DIR,\n1061:   EXIT_PROTOCOL,\n1062:   EXIT_RETRYABLE,\n1063:   EXIT_RUNTIME,\n1064:   EXIT_USAGE,\n1065:   commandMap,\n1066:   commandAliases,\n1067:   assertSocketPerimeter,\n1068:   ensureSocketEnvironment,\n1069:   exitCodeForError,\n1070:   findRepoPaths,\n1071:   isErrorPayload,\n1072:   closestCommand,\n1073:   renderCompletion,\n1074:   renderToolList,\n1075:   resolvePropertyName,\n1076: };\n1077: \n1078: if (isCliEntrypoint()) {\n1079:   // Natural exit via process.exitCode: a hard process.exit() drops any\n1080:   // stdout bytes still queued behind the kernel pipe buffer, truncating\n1081:   // large payloads. Pending pipe writes keep the event loop alive until\n1082:   // they flush; all sockets and timers are closed or unref'd by here.\n1083:   process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n1084: }\n\n(End of file - total 1084 lines)\n</content>","metadata":{"preview":"    nodeLink = lstatSync(socketPath);\n  } catch (error: unknown) {\n    const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n    if (code === 'ENOENT') return;\n    throw error;\n  }\n  if (nodeLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n  }\n  if (uid !== null && nodeLink.uid !== uid) {\n    throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n  }\n}\n\nfunction ensureSocketEnvironment(): void {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (!socketDir || socketDir.startsWith('tcp://')) return;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"    nodeLink = lstatSync(socketPath);\n  } catch (error: unknown) {\n    const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n    if (code === 'ENOENT') return;\n    throw error;\n  }\n  if (nodeLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n  }\n  if (uid !== null && nodeLink.uid !== uid) {\n    throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n  }\n}\n\nfunction ensureSocketEnvironment(): void {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (!socketDir || socketDir.startsWith('tcp://')) return;\n  mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  assertSocketPerimeter(socketDir);\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction spawnLauncher(paths: RepoPaths): void {\n  const child = spawn(process.execPath, [paths.launcherPath], {\n    cwd: paths.repoRoot,\n    env: process.env,\n    detached: true,\n    stdio: 'ignore',\n  });\n  child.unref();\n}\n\nasync function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  let lastReason = 'not probed';\n\n  while (Date.now() <= deadline) {\n    const remaining = Math.max(1, deadline - Date.now());\n    const probe = await bridge.probeDaemon(socketPath, {\n      timeoutMs: Math.min(remaining, 5000),\n      deepProbe: true,\n    });\n    if (probe.status === 'alive') return;\n    lastReason = probe.reason ?? probe.status;\n    await sleep(100);\n  }\n\n  throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n}\n\nclass JsonRpcSocketClient {\n  private nextId = 1;\n  private readonly decoder = new StringDecoder('utf8');\n\n  private constructor(\n    private readonly socket: net.Socket,\n  ) {}\n\n  static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n    return new Promise((resolve, reject) => {\n      let socket: net.Socket;\n      let settled = false;\n      const finish = (error?: Error): void => {\n        if (settled) return;\n        settled = true;\n        clearTimeout(timer);\n        socket.off?.('connect', onConnect);\n        socket.off?.('error', onError);\n        if (error) {\n          socket.destroy?.();\n          reject(error);\n          return;\n        }\n        resolve(new JsonRpcSocketClient(socket));\n      };\n      const onConnect = (): void => finish();\n      const onError = (error: Error): void => finish(error);\n      const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n      timer.unref?.();\n\n      try {\n        const connectionOptions = bridge.toConnectionOptions(socketPath);\n        socket = typeof connectionOptions === 'string'\n          ? net.createConnection(connectionOptions)\n          : net.createConnection(connectionOptions);\n      } catch (error: unknown) {\n        clearTimeout(timer);\n        reject(error instanceof Error ? error : new Error(String(error)));\n        return;\n      }\n      socket.once('connect', onConnect);\n      socket.once('error', onError);\n    });\n  }\n\n  notify(method: string, params?: unknown): void {\n    const frame = params === undefined\n      ? { jsonrpc: '2.0', method }\n      : { jsonrpc: '2.0', method, params };\n    this.socket.write(`${JSON.stringify(frame)}\\n`);\n  }\n\n  request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n    const id = this.nextId++;\n    const request = { jsonrpc: '2.0', id, method, params };\n    return new Promise((resolve, reject) => {\n      let buffer = '';\n      let settled = false;\n\n      const cleanup = (): void => {\n        clearTimeout(timer);\n        this.socket.off('data', onData);\n        this.socket.off('error', onError);\n        this.socket.off('close', onClose);\n      };\n      const finish = (error: unknown, value?: unknown): void => {\n        if (settled) return;\n        settled = true;\n        cleanup();\n        if (error) {\n          reject(error);\n          return;\n        }\n        resolve(value);\n      };\n      const onData = (chunk: Buffer | string): void => {\n        buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n        let newlineIndex = buffer.indexOf('\\n');\n        while (newlineIndex !== -1) {\n          const line = buffer.slice(0, newlineIndex).trim();\n          buffer = buffer.slice(newlineIndex + 1);\n          newlineIndex = buffer.indexOf('\\n');\n          if (!line) continue;\n          let parsed: JsonRpcResponse;\n          try {\n            parsed = JSON.parse(line) as JsonRpcResponse;\n          } catch {\n            continue;\n          }\n          if (parsed.id !== id) continue;\n          if (parsed.error) {\n            finish(new JsonRpcError(parsed.error));\n            return;\n          }\n          finish(null, parsed.result);\n          return;\n        }\n      };\n      const onError = (error: Error): void => finish(error);\n      const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n      const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n      timer.unref?.();\n\n      this.socket.on('data', onData);\n      this.socket.once('error', onError);\n      this.socket.once('close', onClose);\n      this.socket.write(`${JSON.stringify(request)}\\n`);\n    });\n  }\n\n  close(): void {\n    this.socket.end();\n    this.socket.destroy();\n  }\n}\n\nasync function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n  const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n  if (initialProbe.status === 'alive') return;\n  if (warmOnly) {\n    throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n  }\n  spawnLauncher(paths);\n  await waitForDaemon(socketPath, bridge, timeoutMs);\n}\n\nasync function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n  ensureSocketEnvironment();\n  const paths = findRepoPaths();\n  const bridge = loadBridge(paths);\n  const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n  if (socketPathTooLong(socketPath)) {\n    throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n  }\n\n  await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n\n  const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n  try {\n    const initialize = await client.request('initialize', {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n    }, timeoutMs) as InitializeResult;\n    if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n      throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n    }\n    client.notify('notifications/initialized');\n    return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n  } finally {\n    client.close();\n  }\n}\n\nexport async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n  try {\n    const parsed = parseCliArgs(argv);\n    if (parsed.help) {\n      await writeLine(io.stdout, usageText(parsed.command || undefined));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.version) {\n      await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'list-tools') {\n      await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'completion') {\n      if (!parsed.completionShell) {\n        throw new CliUsageError('completion requires a shell: bash or zsh');\n      }\n      await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n      return EXIT_SUCCESS;\n    }\n\n    const validated = validateCommand(parsed);\n    if (!validated) {\n      throw new CliUsageError(`Unknown command: ${parsed.command}`);\n    }\n    const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n    const { payload, isError } = extractToolPayload(validated.tool.name, result);\n    await writeLine(io.stdout, renderPayload(payload, parsed.format));\n    return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n  } catch (error: unknown) {\n    const exitCode = exitCodeForError(error);\n    const message = error instanceof Error ? error.message : String(error);\n    const unknownCommand = unknownCommandContext(message);\n    const payload = {\n      status: 'error',\n      error: message,\n      exitCode,\n      ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n      ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n    };\n    const format = (() => {\n      try {\n        return parseCliArgs(argv).format;\n      } catch {\n        return 'text' as OutputFormat;\n      }\n    })();\n    if (format === 'json' || format === 'jsonl') {\n      await writeLine(io.stderr, renderJson(payload, format));\n    } else {\n      await writeLine(io.stderr, [\n        `ERROR: ${message}`,\n        unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n        unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n      ].filter((line): line is string => Boolean(line)).join('\\n'));\n    }\n    return exitCode;\n  }\n}\n\nfunction isCliEntrypoint(): boolean {\n  const invoked = process.argv[1];\n  if (!invoked) return false;\n  return path.resolve(invoked) === path.resolve(currentModulePath());\n}\n\nexport const __testing = {\n  DEFAULT_SOCKET_DIR,\n  EXIT_PROTOCOL,\n  EXIT_RETRYABLE,\n  EXIT_RUNTIME,\n  EXIT_USAGE,\n  commandMap,\n  commandAliases,\n  assertSocketPerimeter,\n  ensureSocketEnvironment,\n  exitCodeForError,\n  findRepoPaths,\n  isErrorPayload,\n  closestCommand,\n  renderCompletion,\n  renderToolList,\n  resolvePropertyName,\n};\n\nif (isCliEntrypoint()) {\n  // Natural exit via process.exitCode: a hard process.exit() drops any\n  // stdout bytes still queued behind the kernel pipe buffer, truncating\n  // large payloads. Pending pipe writes keep the event loop alive until\n  // they flush; all sockets and timers are closed or unref'd by here.\n  process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n}","lineStart":781,"lineEnd":1084,"totalLines":1084,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781762036481,"end":1781762036486}},"metadata":{"openai":{"itemId":"fc_0b50bd46bc0ce1ad016a3387f45ae88191961507a4b18752b3"}},"id":"prt_ed94b12ef00123MYe0bgja0lLK","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94aed360019KK8P6LBX130rw"}}
{"type":"tool_use","timestamp":1781762036543,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_UgYuC7NkqGvA39icjMEbiaQW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const fs = require('fs');\n4: const net = require('net');\n5: const path = require('path');\n6: const { StringDecoder } = require('string_decoder');\n7: \n8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n9: const DEFAULT_PROBE_TIMEOUT_MS = 5000;\n10: const MAX_PROBE_TIMEOUT_MS = 6999;\n11: const DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\n12: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n13: const MODEL_SERVER_HEALTH_PATH = '/api/health';\n14: let nextProbeId = 1;\n15: \n16: function parsePositiveInteger(value, fallback) {\n17:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n18:   const parsed = Number.parseInt(String(value).trim(), 10);\n19:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n20: }\n21: \n22: function clampProbeTimeoutMs(value) {\n23:   return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n24: }\n25: \n26: function resolveProbeTimeoutMs(options = {}) {\n27:   if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n28:     return clampProbeTimeoutMs(options.timeoutMs);\n29:   }\n30:   return clampProbeTimeoutMs(parsePositiveInteger(\n31:     (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n32:     DEFAULT_PROBE_TIMEOUT_MS,\n33:   ));\n34: }\n35: \n36: function parseNonNegativeInteger(value, fallback) {\n37:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n38:   const parsed = Number.parseInt(String(value).trim(), 10);\n39:   return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n40: }\n41: \n42: // A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n43: // daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n44: // consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n45: // its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n46: // the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\n47: function resolveLeaseProbeAttempts(env = process.env) {\n48:   return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n49: }\n50: function resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n51:   return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n52: }\n53: function resolveLeaseProbeRetryBackoffMs(env = process.env) {\n54:   return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n55: }\n56: \n57: function repoRoot() {\n58:   return path.resolve(__dirname, '..', '..', '..');\n59: }\n60: \n61: function defaultDbDirForService(serviceName) {\n62:   const root = repoRoot();\n63:   if (serviceName === 'mk-spec-memory') {\n64:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n65:   }\n66:   if (serviceName === 'mk-code-index') {\n67:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n68:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n69:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n70:   }\n71:   if (serviceName === 'mk-skill-advisor') {\n72:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n73:     return advisorOverride\n74:       ? path.resolve(advisorOverride)\n75:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n76:   }\n77:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n78: }\n79: \n80: function getIpcSocketPath(serviceName, options = {}) {\n81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n83:   }\n84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n86:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n87:   return path.join(socketDir, SOCKET_FILE_NAME);\n88: }\n89: \n90: function toConnectionOptions(socketPath) {\n91:   if (!socketPath.startsWith('tcp://')) {\n92:     return socketPath;\n93:   }\n94:   const url = new URL(socketPath);\n95:   return {\n96:     host: url.hostname,\n97:     port: Number.parseInt(url.port, 10),\n98:   };\n99: }\n100: \n101: function bridgeStdioToSocket(socketPath, options = {}) {\n102:   const input = options.stdin ?? process.stdin;\n103:   const output = options.stdout ?? process.stdout;\n104:   const exit = options.exit ?? ((code) => process.exit(code));\n105:   const socket = net.createConnection(toConnectionOptions(socketPath));\n106:   let closed = false;\n107: \n108:   const closeOnce = (code = 0) => {\n109:     if (closed) return;\n110:     closed = true;\n111:     input.unpipe(socket);\n112:     socket.unpipe(output);\n113:     socket.destroy();\n114:     exit(code);\n115:   };\n116: \n117:   socket.once('connect', () => {\n118:     options.onConnect?.(socket);\n119:     input.pipe(socket);\n120:     socket.pipe(output);\n121:   });\n122: \n123:   socket.once('error', (error) => {\n124:     options.onError?.(error);\n125:     closeOnce(0);\n126:   });\n127: \n128:   socket.once('close', () => {\n129:     closeOnce(0);\n130:   });\n131: \n132:   input.once('end', () => {\n133:     socket.end();\n134:   });\n135:   input.once('close', () => {\n136:     closeOnce(0);\n137:   });\n138:   output.once('error', () => {\n139:     closeOnce(0);\n140:   });\n141: \n142:   return socket;\n143: }\n144: \n145: function probeDaemon(socketPath, options = {}) {\n146:   const timeoutMs = resolveProbeTimeoutMs(options);\n147:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n148:   // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n149:   // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n150:   // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n151:   // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n152:   const deepProbe = options.deepProbe === true;\n153:   const id = nextProbeId++;\n154:   const request = `${JSON.stringify({\n155:     jsonrpc: '2.0',\n156:     id,\n157:     method: 'initialize',\n158:     params: {\n159:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n160:       capabilities: {},\n161:       clientInfo: { name: 'liveness-probe', version: '0' },\n162:     },\n163:   })}\\n`;\n164: \n165:   return new Promise((resolve) => {\n166:     let socket;\n167:     let settled = false;\n168:     let buffer = '';\n169:     let timer;\n170:     // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n171:     // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n172:     const decoder = new StringDecoder('utf8');\n173: \n174:     const finish = (status, reason) => {\n175:       if (settled) return;\n176:       settled = true;\n177:       if (timer) clearTimeout(timer);\n178:       if (socket) socket.destroy();\n179:       resolve({ status, reason });\n180:     };\n181: \n182:     try {\n183:       socket = connect(toConnectionOptions(socketPath));\n184:     } catch (error) {\n185:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n186:       return;\n187:     }\n188: \n189:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n190:     timer.unref?.();\n191: \n192:     socket.once('connect', () => {\n193:       if (!deepProbe) {\n194:         finish('alive', 'connect-ok');\n195:         return;\n196:       }\n197:       socket.write(request);\n198:     });\n199:     socket.on('data', (chunk) => {\n200:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n201:       let newlineIndex = buffer.indexOf('\\n');\n202:       while (newlineIndex !== -1) {\n203:         const line = buffer.slice(0, newlineIndex).trim();\n204:         buffer = buffer.slice(newlineIndex + 1);\n205:         newlineIndex = buffer.indexOf('\\n');\n206:         if (!line) continue;\n207:         try {\n208:           const parsed = JSON.parse(line);\n209:           if (\n210:             parsed &&\n211:             parsed.jsonrpc === '2.0' &&\n212:             parsed.id === id &&\n213:             (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n214:               Object.prototype.hasOwnProperty.call(parsed, 'error'))\n215:           ) {\n216:             finish('alive', 'json-rpc-reply');\n217:             return;\n218:           }\n219:         } catch {\n220:           // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n221:         }\n222:       }\n223:     });\n224:     socket.once('error', (error) => {\n225:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n226:     });\n227:     socket.once('close', () => {\n228:       finish('dead', 'closed-before-reply');\n229:     });\n230:   });\n231: }\n232: \n233: function parseHttpJsonResponse(buffer) {\n234:   const raw = buffer.toString('utf8');\n235:   const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n236:   if (headerEnd === -1) return null;\n237:   const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n238:   const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n239:   if (!statusMatch) return null;\n240:   const statusCode = Number.parseInt(statusMatch[1], 10);\n241:   const bodyRaw = raw.slice(headerEnd + 4).trim();\n242:   let body = null;\n243:   try {\n244:     body = bodyRaw ? JSON.parse(bodyRaw) : null;\n245:   } catch {\n246:     return { statusCode, body: null };\n247:   }\n248:   return { statusCode, body };\n249: }\n250: \n251: function probeModelServer(socketPath, options = {}) {\n252:   const timeoutMs = resolveProbeTimeoutMs(options);\n253:   const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n254:     ? options.loadingMaxMs\n255:     : parsePositiveInteger(\n256:       (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n257:       DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n258:     );\n259:   const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n260:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n261:   // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n262:   // without spawning a model server. Genuine embed consumers do not send this header, so their\n263:   // wake-on-demand path is unchanged.\n264:   const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n265: \n266:   return new Promise((resolve) => {\n267:     let socket;\n268:     let settled = false;\n269:     let chunks = [];\n270:     let timer;\n271: \n272:     // Carry the parsed health body so callers (the idle-eviction tick) can read\n273:     // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n274:     const finish = (status, reason, health) => {\n275:       if (settled) return;\n276:       settled = true;\n277:       if (timer) clearTimeout(timer);\n278:       if (socket) socket.destroy();\n279:       resolve({ status, reason, health });\n280:     };\n281: \n282:     try {\n283:       socket = connect(toConnectionOptions(socketPath));\n284:     } catch (error) {\n285:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n286:       return;\n287:     }\n288: \n289:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n290:     timer.unref?.();\n291: \n292:     socket.once('connect', () => {\n293:       socket.write(request);\n294:     });\n295:     socket.on('data', (chunk) => {\n296:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n297:     });\n298:     socket.once('end', () => {\n299:       const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n300:       const state = parsed && parsed.body && typeof parsed.body === 'object'\n301:         ? parsed.body.state\n302:         : null;\n303:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n304:         finish('alive', `health-${state}`, parsed.body);\n305:         return;\n306:       }\n307:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n308:         const loadStartedAt = parsed.body.loadStartedAt;\n309:         const loadProgressAt = parsed.body.loadProgressAt;\n310:         // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n311:         const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n312:           ? loadProgressAt\n313:           : loadStartedAt;\n314:         if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n315:           finish('dead', 'loading-wedged');\n316:           return;\n317:         }\n318:         finish('alive', 'health-loading', parsed.body);\n319:         return;\n320:       }\n321:       finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n322:     });\n323:     socket.once('error', (error) => {\n324:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n325:     });\n326:     socket.once('close', () => {\n327:       if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n328:     });\n329:   });\n330: }\n331: \n332: // Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n333: // only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n334: // sleep are injectable so the retry decision is unit-testable without real sockets or timers.\n335: async function probeLeaseHolderWithRetries(socketPath, options = {}) {\n336:   const {\n337:     probe = probeDaemon,\n338:     firstTimeoutMs,\n339:     retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n340:     retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n341:     attempts = resolveLeaseProbeAttempts(),\n342:     connect,\n343:     sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n344:     onRetry,\n345:   } = options;\n346:   const totalAttempts = Math.max(1, attempts);\n347:   let result = { status: 'dead', reason: 'no-probe-attempted' };\n348:   for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n349:     const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n350:     result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n351:     if (result.status === 'alive') return result;\n352:     if (attempt < totalAttempts) {\n353:       if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n354:       await sleepFn(retryBackoffMs);\n355:     }\n356:   }\n357:   return result;\n358: }\n359: \n360: async function maybeBridgeLeaseHolder(options) {\n361:   const {\n362:     serviceName,\n363:     leaseResult,\n364:     loggerPrefix,\n365:     dbDir,\n366:     legacyReport,\n367:     probeTimeoutMs,\n368:     connect,\n369:     bridge,\n370:   } = options;\n371:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n372:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n373:   const ownerPid = leaseResult.ownerPid;\n374:   const writeLeaseHeld = (suffix = '') => {\n375:     process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n376:   };\n377: \n378:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n379:     if (legacyReport) {\n380:       legacyReport(leaseResult);\n381:       return { action: 'report', reason: 'bridge-disabled' };\n382:     }\n383:     writeLeaseHeld();\n384:     return { action: 'report', reason: 'bridge-disabled' };\n385:   }\n386: \n387:   // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n388:   // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n389:   // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n390:   // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n391:   // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n392:   // leases never carry it.\n393:   const storedSocketPath = leaseResult.socketPath;\n394:   const usableStoredSocketPath = typeof storedSocketPath === 'string'\n395:     && storedSocketPath.length > 0\n396:     && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n397:     ? storedSocketPath\n398:     : null;\n399:   const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n400:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n401:     writeLeaseHeld(' (no-bridge-socket)');\n402:     return { action: 'report', reason: 'no-bridge-socket', socketPath };\n403:   }\n404: \n405:   // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n406:   // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n407:   // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n408:   // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n409:   // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n410:   // does not regress that.\n411:   // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n412:   const probeAttempts = resolveLeaseProbeAttempts();\n413:   const probe = await probeLeaseHolderWithRetries(socketPath, {\n414:     firstTimeoutMs: probeTimeoutMs,\n415:     attempts: probeAttempts,\n416:     connect,\n417:     onRetry: (attempt, total, result) => process.stderr.write(\n418:       `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n419:     ),\n420:   });\n\n(Showing lines 1-420 of 451. Use offset=421 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction parseNonNegativeInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n}\n\n// A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n// daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n// consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n// its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n// the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\nfunction resolveLeaseProbeAttempts(env = process.env) {\n  return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n}\nfunction resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n  return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n}\nfunction resolveLeaseProbeRetryBackoffMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });\n\n  socket.once('error', (error) => {\n    options.onError?.(error);\n    closeOnce(0);\n  });\n\n  socket.once('close', () => {\n    closeOnce(0);\n  });\n\n  input.once('end', () => {\n    socket.end();\n  });\n  input.once('close', () => {\n    closeOnce(0);\n  });\n  output.once('error', () => {\n    closeOnce(0);\n  });\n\n  return socket;\n}\n\nfunction probeDaemon(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n  // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n  // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n  // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n  const deepProbe = options.deepProbe === true;\n  const id = nextProbeId++;\n  const request = `${JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    method: 'initialize',\n    params: {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'liveness-probe', version: '0' },\n    },\n  })}\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let buffer = '';\n    let timer;\n    // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n    // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n    const decoder = new StringDecoder('utf8');\n\n    const finish = (status, reason) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      if (!deepProbe) {\n        finish('alive', 'connect-ok');\n        return;\n      }\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const line = buffer.slice(0, newlineIndex).trim();\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (!line) continue;\n        try {\n          const parsed = JSON.parse(line);\n          if (\n            parsed &&\n            parsed.jsonrpc === '2.0' &&\n            parsed.id === id &&\n            (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n              Object.prototype.hasOwnProperty.call(parsed, 'error'))\n          ) {\n            finish('alive', 'json-rpc-reply');\n            return;\n          }\n        } catch {\n          // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n        }\n      }\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\nfunction parseHttpJsonResponse(buffer) {\n  const raw = buffer.toString('utf8');\n  const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n  if (headerEnd === -1) return null;\n  const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n  const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n  if (!statusMatch) return null;\n  const statusCode = Number.parseInt(statusMatch[1], 10);\n  const bodyRaw = raw.slice(headerEnd + 4).trim();\n  let body = null;\n  try {\n    body = bodyRaw ? JSON.parse(bodyRaw) : null;\n  } catch {\n    return { statusCode, body: null };\n  }\n  return { statusCode, body };\n}\n\nfunction probeModelServer(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n    ? options.loadingMaxMs\n    : parsePositiveInteger(\n      (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n      DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n    );\n  const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n  // without spawning a model server. Genuine embed consumers do not send this header, so their\n  // wake-on-demand path is unchanged.\n  const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let chunks = [];\n    let timer;\n\n    // Carry the parsed health body so callers (the idle-eviction tick) can read\n    // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n    const finish = (status, reason, health) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason, health });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n    });\n    socket.once('end', () => {\n      const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n      const state = parsed && parsed.body && typeof parsed.body === 'object'\n        ? parsed.body.state\n        : null;\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n        finish('alive', `health-${state}`, parsed.body);\n        return;\n      }\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n        const loadStartedAt = parsed.body.loadStartedAt;\n        const loadProgressAt = parsed.body.loadProgressAt;\n        // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n        const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n          ? loadProgressAt\n          : loadStartedAt;\n        if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n          finish('dead', 'loading-wedged');\n          return;\n        }\n        finish('alive', 'health-loading', parsed.body);\n        return;\n      }\n      finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\n// Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n// only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n// sleep are injectable so the retry decision is unit-testable without real sockets or timers.\nasync function probeLeaseHolderWithRetries(socketPath, options = {}) {\n  const {\n    probe = probeDaemon,\n    firstTimeoutMs,\n    retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n    retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n    attempts = resolveLeaseProbeAttempts(),\n    connect,\n    sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n    onRetry,\n  } = options;\n  const totalAttempts = Math.max(1, attempts);\n  let result = { status: 'dead', reason: 'no-probe-attempted' };\n  for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n    const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n    result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt < totalAttempts) {\n      if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n      await sleepFn(retryBackoffMs);\n    }\n  }\n  return result;\n}\n\nasync function maybeBridgeLeaseHolder(options) {\n  const {\n    serviceName,\n    leaseResult,\n    loggerPrefix,\n    dbDir,\n    legacyReport,\n    probeTimeoutMs,\n    connect,\n    bridge,\n  } = options;\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  const ownerPid = leaseResult.ownerPid;\n  const writeLeaseHeld = (suffix = '') => {\n    process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n  };\n\n  if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n    if (legacyReport) {\n      legacyReport(leaseResult);\n      return { action: 'report', reason: 'bridge-disabled' };\n    }\n    writeLeaseHeld();\n    return { action: 'report', reason: 'bridge-disabled' };\n  }\n\n  // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n  // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n  // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n  // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n  // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n  // leases never carry it.\n  const storedSocketPath = leaseResult.socketPath;\n  const usableStoredSocketPath = typeof storedSocketPath === 'string'\n    && storedSocketPath.length > 0\n    && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n    ? storedSocketPath\n    : null;\n  const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n  if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n    writeLeaseHeld(' (no-bridge-socket)');\n    return { action: 'report', reason: 'no-bridge-socket', socketPath };\n  }\n\n  // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n  // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n  // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n  // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n  // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n  // does not regress that.\n  // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n  const probeAttempts = resolveLeaseProbeAttempts();\n  const probe = await probeLeaseHolderWithRetries(socketPath, {\n    firstTimeoutMs: probeTimeoutMs,\n    attempts: probeAttempts,\n    connect,\n    onRetry: (attempt, total, result) => process.stderr.write(\n      `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n    ),\n  });","lineStart":1,"lineEnd":420,"totalLines":451,"truncated":true}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1781762036532,"end":1781762036541}},"metadata":{"openai":{"itemId":"fc_0b50bd46bc0ce1ad016a3387f45af081919266d89b1cd43f2b"}},"id":"prt_ed94b1302001Cpv34GWxw3gAVi","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94aed360019KK8P6LBX130rw"}}
{"type":"tool_use","timestamp":1781762036606,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_8aSR60WpO7153pJZ5UXOSGPl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: Model Server Supervision                                      ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n5: // ╚══════════════════════════════════════════════════════════════════════════╝\n6: \n7: 'use strict';\n8: \n9: const fs = require('fs');\n10: const http = require('http');\n11: const path = require('path');\n12: const { spawn, spawnSync } = require('child_process');\n13: \n14: const defaultRoot = path.resolve(__dirname, '..', '..', '..');\n15: const defaultOpencodeDir = path.join(defaultRoot, '.opencode');\n16: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n17: \n18: const SHUTDOWN_DEADLINE_MS = 5000;\n19: const RESPAWN_REAP_GRACE_MS = 7000;\n20: const RESPAWN_LOCK_STALE_MS = 60000;\n21: const DEFAULT_WATCHDOG_GRACE_MS = 7000;\n22: const DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\n23: const DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\n24: const DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\n25: const DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\n26: const DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\n27: const DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\n28: const DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\n29: const HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\n30: const HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\n31: const HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\n32: const HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\n33: const MODEL_SERVER_DEMAND_STATUS = 503;\n34: const DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\n35: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n36: const durableWriteWarnings = new Set();\n37: \n38: function defaultLog(message) {\n39:   process.stderr.write(`[model-server-supervision] ${message}\\n`);\n40: }\n41: \n42: function parsePositiveInteger(value, fallback) {\n43:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n44:   const parsed = Number.parseInt(String(value).trim(), 10);\n45:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n46: }\n47: \n48: function isPermissionError(error) {\n49:   const code = error && typeof error === 'object' ? error.code : undefined;\n50:   if (code === 'EPERM' || code === 'EACCES') return true;\n51:   const message = error instanceof Error ? error.message : String(error ?? '');\n52:   return /operation not permitted|permission denied/i.test(message);\n53: }\n54: \n55: function isDurableWriteUnavailable(error) {\n56:   const code = error && typeof error === 'object' ? error.code : undefined;\n57:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n58: }\n59: \n60: function logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n61:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n62:   const key = `${operation}:${targetPath}:${code}`;\n63:   if (durableWriteWarnings.has(key)) return;\n64:   durableWriteWarnings.add(key);\n65:   const detail = error instanceof Error ? error.message : String(error ?? code);\n66:   logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n67: }\n68: \n69: function cleanupTmpFile(tmpPath, fsApi = fs) {\n70:   try {\n71:     fsApi.unlinkSync(tmpPath);\n72:   } catch (error) {\n73:     if (error.code !== 'ENOENT') {\n74:       // Best-effort cleanup only; the original durable-write failure is more useful.\n75:     }\n76:   }\n77: }\n78: \n79: function parseProcessRows(input) {\n80:   if (Array.isArray(input)) {\n81:     return input\n82:       .map((row) => ({\n83:         pid: Number(row.pid),\n84:         ppid: Number(row.ppid),\n85:         rss: Number(row.rss),\n86:       }))\n87:       .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n88:   }\n89: \n90:   return String(input ?? '')\n91:     .split(/\\r?\\n/)\n92:     .map((line) => line.trim())\n93:     .filter(Boolean)\n94:     .map((line) => {\n95:       const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n96:       return { pid, ppid, rss };\n97:     })\n98:     .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n99: }\n100: \n101: function defaultProcessRowsRunner() {\n102:   const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n103:     encoding: 'utf8',\n104:     stdio: ['ignore', 'pipe', 'pipe'],\n105:   });\n106:   if (result.error) throw result.error;\n107:   if (result.status !== 0) {\n108:     const error = new Error(result.stderr || `ps exited ${result.status}`);\n109:     error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n110:     throw error;\n111:   }\n112:   return result.stdout;\n113: }\n114: \n115: function resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n116:   if (!Number.isInteger(childPid) || childPid <= 0) return null;\n117: \n118:   let rows;\n119:   try {\n120:     rows = parseProcessRows(runner());\n121:   } catch (error) {\n122:     if (isPermissionError(error)) return null;\n123:     throw error;\n124:   }\n125: \n126:   const byPid = new Map();\n127:   const childrenByPpid = new Map();\n128:   for (const row of rows) {\n129:     byPid.set(row.pid, row);\n130:     const children = childrenByPpid.get(row.ppid) || [];\n131:     children.push(row);\n132:     childrenByPpid.set(row.ppid, children);\n133:   }\n134:   if (!byPid.has(childPid)) return null;\n135: \n136:   const subtree = [];\n137:   const stack = [childPid];\n138:   const seen = new Set();\n139:   while (stack.length > 0) {\n140:     const pid = stack.pop();\n141:     if (seen.has(pid)) continue;\n142:     seen.add(pid);\n143:     const row = byPid.get(pid);\n144:     if (row) subtree.push(row);\n145:     for (const child of childrenByPpid.get(pid) || []) {\n146:       stack.push(child.pid);\n147:     }\n148:   }\n149: \n150:   return subtree;\n151: }\n152: \n153: function sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n154:   const rows = resolveProcessTreeRows(childPid, runner);\n155:   if (!rows) return null;\n156:   const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n157:   return rssKb / 1024;\n158: }\n159: \n160: function normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n161:   const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n162:   if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n163:   warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n164:   return DEFAULT_WATCHDOG_GRACE_MS;\n165: }\n166: \n167: function getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n168:   const envNames = {\n169:     maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n170:     selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n171:     intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n172:     consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n173:     graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n174:   };\n175:   const rawMaxRssMb = env[envNames.maxRssMb];\n176:   const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n177:     ? null\n178:     : Number.parseFloat(String(rawMaxRssMb).trim());\n179:   const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n180:   return {\n181:     enabled,\n182:     maxRssMb,\n183:     intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n184:     consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n185:     graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n186:     maxRssMbEnv: envNames.maxRssMb,\n187:     selfExitEnv: envNames.selfExit,\n188:   };\n189: }\n190: \n191: function getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n192:   return getWatchdogConfig(env, warn, {\n193:     maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n194:     selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n195:   });\n196: }\n197: \n198: function getModelServerIdleConfig(env = process.env) {\n199:   const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n200:   const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n201:     ? 0\n202:     : Number.parseFloat(String(rawIdleMin).trim());\n203:   const enabled = Number.isFinite(idleMin) && idleMin > 0;\n204:   return {\n205:     enabled,\n206:     timeoutMs: enabled ? idleMin * 60000 : 0,\n207:   };\n208: }\n209: \n210: function computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n211:   const exponent = Math.max(0, deathsInWindow - 1);\n212:   return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n213: }\n214: \n215: function createCrashLoopGuard(options = {}) {\n216:   const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_C