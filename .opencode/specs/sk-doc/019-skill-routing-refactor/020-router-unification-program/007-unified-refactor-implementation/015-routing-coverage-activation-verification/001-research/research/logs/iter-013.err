.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:51:  node generate-context.js --json '{"specFolder":"specs/001-feature/"}'
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:52:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:53:Output:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:54:  Creates the saved context artifact for the active spec folder and indexes it
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:55:  into the Spec Kit Memory system. Canonical saves also refresh the packet's
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:56:  root-level graph-metadata.json file as part of the same workflow.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:57:  Planner-first canonical saves are requested by default; use --full-auto for
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:58:  the legacy mutation-first fallback.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:59:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:60:Preferred save path (JSON-PRIMARY):
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:61:  - ALWAYS use --stdin, --json, or a JSON temp file.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:62:  - If file mode is required, use a session-scoped temp path such as ${SESSION_SCOPED_SAVE_CONTEXT_EXAMPLE}.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:63:  - The legacy shared path /tmp/save-context-data.json is rejected.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:64:  - The AI has strictly better information about its own session than any DB query can reconstruct.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:65:  - Explicit CLI targets still outrank payload specFolder values in every structured-input mode.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:66:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:67:Direct CLI target rule:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:68:  - When a spec folder is passed on the CLI, that explicit target is authoritative.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:69:  - Session learning, JSON SPEC_FOLDER fields, and auto-detect may inform logging,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:70:    but they must not reroute the save to another folder.
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:71:
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:72:JSON Data Format (with preflight/postflight, session/git, and tool/exchange enrichment):
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:73:  {
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:74:    "user_prompts": [...],
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:75:    "observations": [...],
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:76:    "recent_context": [...],
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:77:    "toolCalls": [
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:78:      { "tool": "Read", "inputSummary": "Read data-loader.ts", "outputSummary": "585 lines", "status": "success", "durationEstimate": "fast" },
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:79:      { "tool": "Edit", "inputSummary": "Added deprecation warning", "outputSummary": "Inserted 10 lines", "status": "success" }
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:80:    ],
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:81:    "exchanges": [
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:82:      { "userInput": "Implement the JSON-primary plan", "assistantResponse": "Updated 8 files...", "timestamp": "ISO-8601" }
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:83:    ],
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:84:    "preflight": {
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:85:      "knowledgeScore": 40,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:86:      "uncertaintyScore": 60,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:87:      "contextScore": 50,
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:88:      "timestamp": "ISO-8601",
