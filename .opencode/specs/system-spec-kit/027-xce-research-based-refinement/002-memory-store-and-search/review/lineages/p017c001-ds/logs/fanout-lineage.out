{"type":"tool_use","timestamp":1781722677577,"sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","part":{"type":"tool","tool":"read","callID":"call_00_WgFLGVCfwcQmJRHzqQ6u3294","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1446},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1446:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1447:       }\n1448:     }\n1449: \n1450:     // Degree channel re-ranks based on causal-edge connectivity.\n1451:     // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n1452:     // Degree channel — also gated by query-complexity routing\n1453:     if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n1454:       try {\n1455:         graphMetrics.degreeQueries++;\n1456:         // Collect all numeric IDs from existing channels\n1457:         const allResultIds = new Set<number>();\n1458:         for (const list of lists) {\n1459:           for (const r of list.results) {\n1460:             const id = r.id;\n1461:             if (typeof id === 'number') allResultIds.add(id);\n1462:           }\n1463:         }\n1464: \n1465:         if (allResultIds.size > 0) {\n1466:           const degreeScores = computeDegreeScores(db, Array.from(allResultIds));\n1467: \n1468:           // Build a ranked list sorted by degree score (highest first)\n1469:           const degreeItems: Array<{ id: number; degreeScore: number }> = [];\n1470:           for (const [idStr, score] of degreeScores) {\n1471:             const numId = Number(idStr);\n1472:             if (score > 0 && !isNaN(numId)) {\n1473:               degreeItems.push({ id: numId, degreeScore: score });\n1474:             }\n1475:           }\n1476:           degreeItems.sort((a, b) => b.degreeScore - a.degreeScore);\n1477: \n1478:           if (degreeItems.length > 0) {\n1479:             graphMetrics.degreeHits++;\n1480:             graphMetrics.degreeResultCount += degreeItems.length;\n1481:             lists.push({\n1482:               source: 'degree',\n1483:               results: degreeItems.map(item => ({\n1484:                 id: item.id,\n1485:                 degreeScore: item.degreeScore,\n1486:               })),\n1487:               weight: DEGREE_CHANNEL_WEIGHT,\n1488:             });\n1489:           }\n1490:         }\n1491:       } catch (_err: unknown) {\n1492:         // Non-critical — degree channel failure does not block pipeline\n1493:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1494:       }\n1495:     }\n1496: \n1497:     // Merge keyword results after all channels complete\n1498:     const keywordResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [\n1499:       ...ftsChannelResults,\n1500:       ...bm25ChannelResults,\n1501:     ];\n1502: \n1503:     if (options.skipFusion) {\n1504:       return {\n1505:         evaluationMode,\n1506:         intent: options.intent || classifyIntent(query).intent,\n1507:         lists,\n1508:         routeResult,\n1509:         budgetResult,\n1510:         s3meta,\n1511:         vectorEmbeddingCache,\n1512:         fusedResults: collectCandidatesFromLists(\n1513:           lists.filter((list) => list.source !== 'degree'),\n1514:           options.limit ?? DEFAULT_LIMIT\n1515:         ),\n1516:       };\n1517:     }\n1518: \n1519:     if (lists.length === 0) {\n1520:       return null;\n1521:     }\n1522: \n1523:     // Track multi-source and graph-only results\n1524:     const sourceMap = new Map<string, Set<string>>();\n1525:     for (const list of lists) {\n1526:       for (const r of list.results) {\n1527:         const key = canonicalResultId(r.id);\n1528:         if (!sourceMap.has(key)) sourceMap.set(key, new Set());\n1529:         sourceMap.get(key)!.add(list.source); // non-null safe: has() guard above guarantees entry exists\n1530:       }\n1531:     }\n1532:     for (const [, sources] of sourceMap) {\n1533:       if (sources.size > 1) graphMetrics.multiSourceResults++;\n1534:       if (sources.size > 1 && sources.has('graph')) graphMetrics.graphMultiSourceResults++;\n1535:       if (sources.size === 1 && sources.has('graph')) graphMetrics.graphOnlyResults++;\n1536:     }\n1537: \n1538:     // Build weighted fusion lists once from lightweight adaptive\n1539:     // weights, avoiding the heavier hybridAdaptiveFuse() standard-first path.\n1540:     const detectedIntent = classifyIntent(query).intent;\n1541:     const intent = resolveFusionIntentContract({\n1542:       detectedIntent,\n1543:       adaptiveFusionIntent: options.intent ?? null,\n1544:       query,\n1545:     })\n1546:       ?? detectedIntent;\n1547:     const adaptiveEnabled = isAdaptiveFusionEnabled();\n1548:     const documentType = resolveAdaptiveDocumentType(lists.map((list) => ({\n1549:       results: list.results as Array<Record<string, unknown>>,\n1550:     })));\n1551:     const fusionWeights = adaptiveEnabled\n1552:       ? getAdaptiveWeights(intent, documentType)\n1553:       : { semanticWeight: 1.0, keywordWeight: 1.0, recencyWeight: 0 };\n1554:     const { semanticWeight, keywordWeight, graphWeight: adaptiveGraphWeight } = fusionWeights;\n1555:     const keywordFusionResults = keywordResults.map((result) => {\n1556:       const originalSource = typeof result.source === 'string' ? result.source : null;\n1557:       const existingSources = Array.isArray((result as Record<string, unknown>).sources)\n1558:         ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n1559:         : [];\n1560:       return {\n1561:         ...result,\n1562:         source: 'keyword',\n1563:         sources: Array.from(new Set([...existingSources, ...(originalSource ? [originalSource] : []), 'keyword'])),\n1564:       };\n1565:     });\n1566:     const fusionLists = lists\n1567:       .filter((list) => list.source !== 'fts' && list.source !== 'bm25')\n1568:       .map((list) => {\n1569:         if (list.source === 'vector') {\n1570:           return { ...list, weight: semanticWeight };\n1571:         }\n1572:         if (list.source === 'graph' && typeof adaptiveGraphWeight === 'number') {\n1573:           return { ...list, weight: adaptiveGraphWeight };\n1574:         }\n1575:         return { ...list };\n1576:       });\n1577: \n1578:     if (keywordFusionResults.length > 0 && keywordWeight > 0) {\n1579:       fusionLists.push({\n1580:         source: 'keyword',\n1581:         results: keywordFusionResults,\n1582:         weight: keywordWeight,\n1583:       });\n1584:     }\n1585: \n1586:     const graphList = fusionLists.find((list) => list.source === 'graph');\n1587:     const vectorList = fusionLists.find((list) => list.source === 'vector');\n1588:     const passthroughLists = fusionLists.filter((list) => list.source !== 'graph' && list.source !== 'vector' && list.source !== 'keyword');\n1589:     const fused = adaptiveEnabled\n1590:       ? (adaptiveFuse as unknown as (\n1591:         semanticResults: Array<Record<string, unknown>>,\n1592:         keywordResults: Array<Record<string, unknown>>,\n1593:         weights: typeof fusionWeights,\n1594:         options: {\n1595:           graphResults?: Array<Record<string, unknown>>;\n1596:           additionalLists?: typeof passthroughLists;\n1597:         },\n1598:       ) => FusionResult[])(\n1599:         (vectorList?.results ?? []) as Array<Record<string, unknown>>,\n1600:         keywordFusionResults,\n1601:         fusionWeights,\n1602:         {\n1603:           graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n1604:           additionalLists: passthroughLists,\n1605:         },\n1606:       )\n1607:       : fuseResultsMulti(fusionLists);\n1608: \n1609:     const keywordSourceMap = new Map<string, string[]>();\n1610:     for (const result of keywordFusionResults) {\n1611:       const sources = Array.isArray((result as Record<string, unknown>).sources)\n1612:         ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n1613:         : [];\n1614:       if (sources.length > 0) {\n1615:         keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n1616:       }\n1617:     }\n1618:     const triggerScoreMap = new Map<string, number>();\n1619:     for (const result of triggerChannelResults) {\n1620:       if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n1621:         triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n1622:       }\n1623:     }\n1624: \n1625:     const fusedResults = fused.map(toHybridResult).map((row) => {\n1626:       const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n1627:       if (keywordSources && keywordSources.length > 0) {\n1628:         const rowSources = Array.isArray(row.sources)\n1629:           ? row.sources.filter((source): source is string => typeof source === 'string')\n1630:           : [];\n1631:         const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n1632:         row = {\n1633:           ...row,\n1634:           sources,\n1635:           channelAttribution: sources,\n1636:           source: row.source === 'keyword'\n1637:             ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n1638:             : row.source,\n1639:         };\n1640:       }\n1641:       const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n1642:       if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n1643:         row = {\n1644:           ...row,\n1645:           triggerScore,\n1646:           exactTriggerMatch: triggerScore >= 0.94,\n1647:         };\n1648:       }\n1649:       const rowRecord = row as Record<string, unknown>;\n1650:       if (rowRecord.parentMemoryId !== undefined) return row;\n1651:       const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n1652:       if (normalizedParentMemoryId === undefined) return row;\n1653:       return {\n1654:         ...row,\n1655:         parentMemoryId: normalizedParentMemoryId,\n1656:       };\n1657:     });\n1658: \n1659:     return {\n1660:       evaluationMode,\n1661:       intent,\n1662:       lists,\n1663:       routeResult,\n1664:       budgetResult,\n1665:       s3meta,\n1666:       vectorEmbeddingCache,\n1667:       fusedResults,\n1668:     };\n1669:   } catch (error: unknown) {\n1670:     const msg = error instanceof Error ? error.message : String(error);\n1671:     console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n1672:     return null;\n1673:   }\n1674: }\n1675: \n1676: async function enrichFusedResults(\n1677:   query: string,\n1678:   execution: HybridFusionExecution,\n1679:   options: HybridSearchOptions = {},\n1680:   initialResults: HybridSearchResult[] = execution.fusedResults\n1681: ): Promise<HybridSearchResult[]> {\n1682:   enrichFusedResultsObserver?.();\n1683: \n1684:   const {\n1685:     evaluationMode,\n1686:     intent,\n1687:     lists,\n1688:     routeResult,\n1689:     budgetResult,\n1690:     s3meta,\n1691:     vectorEmbeddingCache,\n1692:   } = execution;\n1693:   let fusedHybridResults = initialResults;\n1694:   const limit = options.limit || DEFAULT_LIMIT;\n1695: \n1696:   // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n1697:   // When enabled, collapses chunk-level results back to their parent memory\n1698:   // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n1699:   // Multiple chunks from the same document dominating the result list.\n1700:   // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n1701:   if (isDocscoreAggregationEnabled()) {\n1702:     try {\n1703:       const chunkResults = fusedHybridResults.filter(\n1704:         r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n1705:       );\n1706:       if (chunkResults.length > 0) {\n1707:         const nonChunkResults = fusedHybridResults.filter(\n1708:           r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n1709:         );\n1710:         const collapsed = collapseAndReassembleChunkResults(\n1711:           chunkResults.map(r => ({\n1712:             id: r.id,\n1713:             parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n1714:             chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n1715:             score: r.score,\n1716:           }))\n1717:         );\n1718:         // Merge collapsed chunk results with non-chunk results\n1719:         fusedHybridResults = [\n1720:           ...collapsed.map(c => ({\n1721:             id: c.parentMemoryId,\n1722:             score: c.mpabScore,\n1723:             source: 'mpab' as string,\n1724:             _chunkHits: c._chunkHits,\n1725:           } as HybridSearchResult)),\n1726:           ...nonChunkResults,\n1727:         ];\n1728:       }\n1729:     } catch (_mpabErr: unknown) {\n1730:       // Non-critical — MPAB failure does not block pipeline\n1731:       const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n1732:       console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n1733:     }\n1734:   }\n1735: \n1736:   // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n1737:   // Ensures every channel that returned results has at least one representative\n1738:   // In the top-k window. Prevents single-channel dominance in fusion output.\n1739:   // When disabled, passes results through unchanged.\n1740:   try {\n1741:     const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n1742:     for (const list of lists) {\n1743:       channelResultSets.set(list.source, list.results.map(r => ({\n1744:         ...r,\n1745:         id: r.id,\n1746:         score: typeof (r as Record<string, unknown>).score === 'number'\n1747:           ? (r as Record<string, unknown>).score as number\n1748:           : typeof (r as Record<string, unknown>).similarity === 'number'\n1749:             ? ((r as Record<string, unknown>).similarity as number) / 100\n1750:             : 0,\n1751:       })));\n1752:     }\n1753: \n1754:     const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n1755:       fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n1756:       channelResultSets,\n1757:       limit,\n1758:     );\n1759: \n1760:     if (enforcementResult.enforcement.applied) {\n1761:       fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n1762:       s3meta.enforcement = {\n1763:         applied: true,\n1764:         promotedCount: enforcementResult.enforcement.promotedCount,\n1765:         underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n1766:       };\n1767:     }\n1768:   } catch (err: unknown) {\n1769:     // Non-critical — enforcement failure does not block pipeline\n1770:     console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n1771:   }\n1772: \n1773:   // Preserve non-enumerable eval metadata across later array reallocations.\n1774:   const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n1775:   const s4shadowMeta = shadowMeta._s4shadow;\n1776:   const s4attributionMeta = shadowMeta._s4attribution;\n1777:   const degradationMeta = shadowMeta._degradation;\n1778: \n1779:   // MMR reranking with request-scoped embedding cache.\n1780:   // Reuse embeddings already returned by the vector channel when present and\n1781:   // only query vec_memories for missing IDs.\n1782:   let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n1783: \n1784:   if (db && isMMREnabled()) {\n1785:     const numericIds = reranked\n1786:       .map(r => r.id)\n1787:       .filter((id): id is number => typeof id === 'number');\n1788: \n1789:     if (numericIds.length >= MMR_MIN_CANDIDATES) {\n1790:       try {\n1791:         const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n1792:         const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n1793: \n1794:         if (missingIds.length > 0) {\n1795:           const placeholders = missingIds.map(() => '?').join(', ');\n1796:           const embRows = (db.prepare(\n1797:             `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n1798:           ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n1799: \n1800:           for (const row of embRows) {\n1801:             if (Buffer.isBuffer(row.embedding)) {\n1802:               embeddingMap.set(\n1803:                 row.rowid,\n1804:                 new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n1805:               );\n1806:             }\n1807:           }\n1808:         }\n1809: \n1810:         const mmrCandidates: MMRCandidate[] = [];\n1811:         for (const r of reranked) {\n1812:           const emb = embeddingMap.get(r.id as number);\n1813:           if (emb) {\n1814:             mmrCandidates.push({\n1815:               id: r.id as number,\n1816:               score: (r.score as number) ?? 0,\n1817:               embedding: emb,\n1818:             });\n1819:           }\n1820:         }\n1821: \n1822:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n1823:           const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n1824:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n1825: \n1826:           // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n1827:           // rows that have embeddings. Non-embedded rows (lexical-only hits,\n1828:           // graph injections) must be preserved and merged back in their\n1829:           // original relative order instead of being silently dropped.\n1830:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n1831:           const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n1832:           const rerankedById = new Map<string, HybridSearchResult>(\n1833:             reranked.map((result) => [canonicalResultId(result.id), result])\n1834:           );\n1835: \n1836:           const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n1837:             const existing = rerankedById.get(canonicalResultId(candidate.id));\n1838:             if (existing) {\n1839:               return existing;\n1840:             }\n1841: \n1842:             return {\n1843:               id: candidate.id,\n1844:               score: candidate.score,\n1845:               source: 'vector',\n1846:             };\n1847:           });\n1848: \n1849:           // Merge: diversified embedded rows first (MMR-ordered), then\n1850:           // non-embedded rows in their original relative order.\n1851:           reranked = [...diversifiedRows, ...nonEmbeddedRows];\n1852:         }\n1853:       } catch (embErr: unknown) {\n1854:         const msg = embErr instanceof Error ? embErr.message : String(embErr);\n1855:         console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n1856:       }\n1857:     }\n1858:   }\n1859: \n1860:   // Co-activation spreading — enrich with temporal neighbors\n1861:   const topIds = reranked\n1862:     .slice(0, SPREAD_ACTIVATION_TOP_N)\n1863:     .map(r => r.id)\n1864:     .filter((id): id is number => typeof id === 'number');\n1865:   if (topIds.length > 0) {\n1866:     try {\n1867:       const spreadResults: SpreadResult[] = spreadActivation(topIds);\n1868:       // Boost scores of results that appear in co-activation graph\n1869:       if (spreadResults.length > 0) {\n1870:         const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n1871:         for (const result of reranked) {\n1872:           const boost = spreadMap.get(result.id as number);\n1873:           if (boost !== undefined) {\n1874:             // Update all score aliases so downstream consumers see the boost.\n1875:             const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n1876:             (result as Record<string, unknown>).score = boostedScore;\n1877:             if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n1878:             if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n1879:           }\n1880:         }\n1881:       }\n1882:       // Re-sort after co-activation boost to ensure boosted results\n1883:       // Are promoted to their correct position in the ranking\n1884:       reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n1885:     } catch (err: unknown) {\n1886:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1887:       console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n1888:     }\n1889:   }\n1890: \n1891:   // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n1892:   if (db && isFolderScoringEnabled() && reranked.length > 0) {\n1893:     try {\n1894:       const numericIds = reranked\n1895:         .map(r => r.id)\n1896:         .filter((id): id is number => typeof id === 'number');\n1897: \n1898:       if (numericIds.length > 0) {\n1899:         const folderMap = lookupFolders(db, numericIds);\n1900:         if (folderMap.size > 0) {\n1901:           const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n1902:           const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n1903:           const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n1904:           const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n1905: \n1906:           const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n1907:           const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n1908:           reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n1909:         }\n1910:       }\n1911:     } catch (_folderErr: unknown) {\n1912:       // Folder scoring is optional and must not break retrieval\n1913:     }\n1914:   }\n1915: \n1916:   // -- Stage D: Confidence Truncation (SPECKIT_CONFIDENCE_TRUNCATION) --\n1917:   // Run after the ranking pipeline so later boosts/promotions can rescue\n1918:   // candidates before low-confidence tails are trimmed.\n1919:   if (!evaluationMode) {\n1920:     try {\n1921:       const truncationResult: TruncationResult = truncateByConfidence(\n1922:         reranked.map(r => ({ ...r, id: r.id, score: r.score })),\n1923:       );\n1924: \n1925:       if (truncationResult.truncated) {\n1926:         reranked = truncationResult.results.map(r => r as HybridSearchResult);\n1927:         s3meta.truncation = {\n1928:           truncated: true,\n1929:           originalCount: truncationResult.originalCount,\n1930:           truncatedCount: truncationResult.truncatedCount,\n1931:           medianGap: truncationResult.medianGap,\n1932:           cutoffGap: truncationResult.cutoffGap,\n1933:           cutoffIndex: truncationResult.cutoffIndex,\n1934:           thresholdMultiplier: GAP_THRESHOLD_MULTIPLIER,\n1935:           minResultsGuaranteed: DEFAULT_MIN_RESULTS,\n1936:           featureFlagEnabled: isConfidenceTruncationEnabled(),\n1937:         };\n1938:       }\n1939:     } catch (err: unknown) {\n1940:       // Non-critical — truncation failure does not block pipeline\n1941:       console.warn('[hybrid-search] confidence truncation failed:', err instanceof Error ? err.message : String(err));\n1942:     }\n1943:   }\n1944: \n1945:   // Preserve routing and Stage 4 trace metadata as explicit result fields so downstream\n1946:   // Formatters can opt-in to provenance-rich envelopes without relying on\n1947:   // Non-enumerable array shadow properties.\n1948:   if (reranked.length > 0) {\n1949:     reranked = reranked.map((row): HybridSearchResult => {\n1950:       const existingTraceMetadata =\n1951:         typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n1952:           ? row.traceMetadata\n1953:           : {};\n1954: \n1955:       return {\n1956:         ...row,\n1957:         traceMetadata: {\n1958:           ...existingTraceMetadata,\n1959:           ...(s4shadowMeta !== undefined ? { stage4: s4shadowMeta } : {}),\n1960:           ...(s4attributionMeta !== undefined ? { attribution: s4attributionMeta } : {}),\n1961:           ...(degradationMeta !== undefined ? { degradation: degradationMeta } : {}),\n1962:           evaluationMode,\n1963:           // Wire queryComplexity from router classification into trace\n1964:           queryComplexity: routeResult.tier,\n1965:           // Wire confidence truncation metadata into per-result trace (036)\n1966:           ...(s3meta.truncation ? {\n1967:             confidenceTruncation: {\n1968:               truncated: s3meta.truncation.truncated,\n1969:               originalCount: s3meta.truncation.originalCount,\n1970:               truncatedCount: s3meta.truncation.truncatedCount,\n1971:               medianGap: s3meta.truncation.medianGap,\n1972:               cutoffGap: s3meta.truncation.cutoffGap,\n1973:               cutoffIndex: s3meta.truncation.cutoffIndex,\n1974:               thresholdMultiplier: s3meta.truncation.thresholdMultiplier,\n1975:               minResultsGuaranteed: s3meta.truncation.minResultsGuaranteed,\n1976:             },\n1977:           } : {}),\n1978:         },\n1979:       };\n1980:     });\n1981:   }\n1982: \n1983:   if (isContextHeadersEnabled() && reranked.length > 0) {\n1984:     const descriptionCache = buildDescriptionTailMap();\n1985:     if (descriptionCache.size > 0) {\n1986:       reranked = reranked.map((row) => injectContextualTree(row, descriptionCache));\n1987:     }\n1988:   }\n1989: \n1990:   let budgetTruncated = false;\n1991:   let budgetLimit: number | undefined;\n1992:   if (evaluationMode) {\n1993:     reranked = applyResultLimit(reranked, options.limit);\n1994:   } else {\n1995:     // Apply token budget truncation after trace/header enrichment so token\n1996:     // estimates reflect the actual returned payload shape.\n1997:     const headerOverhead = isContextHeadersEnabled()\n1998:       ? reranked.length * CONTEXT_HEADER_TOKEN_OVERHEAD\n1999:       : 0;\n2000:     const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n2001: \n2002:     if (s3meta.tokenBudget) {\n2003:       s3meta.tokenBudget.headerOverhead = headerOverhead;\n2004:       s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n2005:     }\n2006: \n2007:     const budgeted = truncateToBudget(reranked, adjustedBudget, {\n2008:       includeContent: options.includeContent ?? false,\n2009:       queryId: `hybrid-${Date.now()}`,\n2010:       limit: options.limit,\n2011:       query,\n2012:     });\n2013:     reranked = budgeted.results;\n2014:     budgetTruncated = budgeted.truncated;\n2015:     budgetLimit = budgetResult.budget;\n2016: \n2017:     // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n2018:     // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n2019:     // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n2020:     // the budgeted survivors it is the last word on order without disturbing the\n2021:     // budget membership decision. Skipped in evaluationMode so the labeled-set\n2022:     // top-K window stays exactly as fused.\n2023:     if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n2024:       reranked = reorderTopNByCosine(reranked);\n2025:     }\n2026:   }\n2027: \n2028:   if (reranked.length > 0) {\n2029:     reranked = reranked.map((row): HybridSearchResult => {\n2030:       const existingTraceMetadata =\n2031:         typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n2032:           ? row.traceMetadata\n2033:           : {};\n2034: \n2035:       return {\n2036:         ...row,\n2037:         traceMetadata: {\n2038:           ...existingTraceMetadata,\n2039:           budgetTruncated,\n2040:           ...(budgetLimit !== undefined ? { budgetLimit } : {}),\n2041:         },\n2042:       };\n2043:     });\n2044:   }\n2045: \n2046:   if (s4shadowMeta !== undefined && reranked.length > 0) {\n2047:     Object.defineProperty(reranked, '_s4shadow', {\n2048:       value: s4shadowMeta,\n2049:       enumerable: false,\n2050:       configurable: true,\n2051:     });\n2052:   }\n2053: \n2054:   if (s4attributionMeta !== undefined && reranked.length > 0) {\n2055:     Object.defineProperty(reranked, '_s4attribution', {\n2056:       value: s4attributionMeta,\n2057:       enumerable: false,\n2058:       configurable: true,\n2059:     });\n2060:   }\n2061: \n2062:   // Attach pipeline metadata to results for eval/debugging\n2063:   // Metadata is attached as non-enumerable _s3meta property to avoid\n2064:   // Polluting result serialization while remaining accessible for debugging.\n2065:   if (Object.keys(s3meta).length > 0 && reranked.length > 0) {\n2066:     Object.defineProperty(reranked, '_s3meta', { value: s3meta, enumerable: false, configurable: true });\n2067:   }\n2068: \n2069:   return reranked;\n2070: }\n2071: \n2072: /**\n2073:  * Collect pipeline candidates through the adaptive fallback chain, returning\n2074:  * immediately after intra-query fusion and before downstream aggregation,\n2075:  * reranking, or post-processing.\n2076:  *\n2077:  * @param query - The search query string.\n2078:  * @param embedding - Optional embedding vector for semantic search.\n2079:  * @param options - Hybrid search configuration options.\n2080:  * @returns Unfused candidate results from the first non-empty collection stage.\n2081:  */\n2082: async function collectRawCandidates(\n2083:   query: string,\n2084:   embedding: Float32Array | number[] | null,\n2085:   options: HybridSearchOptions = {}\n2086: ): Promise<HybridSearchResult[]> {\n2087:   const { allowedChannels, stages } = await executeFallbackPlan(\n2088:     query,\n2089:     embedding,\n2090:     options,\n2091:     isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n2092:     { stopAfterFusion: true }\n2093:   );\n2094: \n2095:   const primaryResults = stages[0]?.results ?? [];\n2096:   const retryResults = stages[1]?.results ?? [];\n2097: \n2098:   if (isSearchFallbackEnabled()) {\n2099:     const mergedResults = retryResults.length > 0\n2100:       ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n2101:       : primaryResults;\n2102:     if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n2103:   } else {\n2104:     const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n2105:     if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n2106:   }\n2107: \n2108:   if (allowedChannels.has('fts')) {\n2109:     const ftsFallback = collectCandidatesFromLists(\n2110:       [{ source: 'fts', results: ftsSearch(query, options) }],\n2111:       options.limit\n2112:     );\n2113:     if (ftsFallback.length > 0) return ftsFallback;\n2114:   }\n2115: \n2116:   if (allowedChannels.has('bm25')) {\n2117:     const bm25Fallback = collectCandidatesFromLists(\n2118:       [{ source: 'bm25', results: bm25Search(query, options) }],\n2119:       options.limit\n2120:     );\n2121:     if (bm25Fallback.length > 0) return bm25Fallback;\n2122:   }\n2123: \n2124:   console.warn('[hybrid-search] Raw candidate collection returned empty results');\n2125:   return [];\n2126: }\n2127: \n2128: /**\n2129:  * Search with automatic fallback chain.\n2130:  * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n2131:    * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n2132:  * fallback — primary at minSimilarity=30, retry at 17.\n2133:  *\n2134:  * @param query - The search query string.\n2135:  * @param embedding - Optional embedding vector for semantic search.\n2136:  * @param options - Hybrid search configuration options.\n2137:  * @returns Results from the first non-empty stage.\n2138:  */\n2139: async function searchWithFallback(\n2140:   query: string,\n2141:   embedding: Float32Array | number[] | null,\n2142:   options: HybridSearchOptions = {}\n2143: ): Promise<HybridSearchResult[]> {\n2144:   // PI-A2: Delegate to tiered fallback when flag is enabled\n2145:   if (isSearchFallbackEnabled()) {\n2146:     return searchWithFallbackTiered(query, embedding, options);\n2147:   }\n2148: \n2149:   // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n2150:   // Where no result exceeds the primary threshold — chosen empirically via eval.\n2151:   // Use hybridSearchEnhanced (with RRF fusion) instead of\n2152:   // The naive hybridSearch that merges raw scores\n2153:   const { allowedChannels, stages } = await executeFallbackPlan(\n2154:     query,\n2155:     embedding,\n2156:     options,\n2157:     'adaptive'\n2158:   );\n2159:   const primaryStage = stages[0];\n2160:   const retryStage = stages[1];\n2161:   const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n2162:   if (finalStage?.results.length) {\n2163:     return finalStage.execution\n2164:       ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n2165:       : finalStage.results;\n2166:   }\n2167: \n2168:   // Fallback to FTS only\n2169:   if (allowedChannels.has('fts')) {\n2170:     const ftsResults = ftsSearch(query, options);\n2171:     if (ftsResults.length > 0) return ftsResults;\n2172:   }\n2173: \n2174:   // Fallback to BM25 only\n2175:   if (allowedChannels.has('bm25')) {\n2176:     const bm25Results = bm25Search(query, options);\n2177:     if (bm25Results.length > 0) return bm25Results;\n2178:   }\n2179: \n2180:   console.warn('[hybrid-search] All search methods returned empty results');\n2181:   return [];\n2182: }\n2183: \n2184: // 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n2185: \n2186: /**\n2187:  * PI-A2: Last-resort structural search against the memory_index table.\n2188:  * Retrieves memories ordered by importance tier and weight, without\n2189:  * requiring embeddings or text similarity. Pure SQL fallback.\n2190:  *\n2191:  * @param options - Search options (specFolder for filtering, limit for cap).\n2192:  * @returns Array of HybridSearchResult with source='structural'.\n2193:  */\n2194: function structuralSearch(\n2195:   options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n2196: ): HybridSearchResult[] {\n2197:   if (!db) {\n2198:     console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n2199:     return [];\n2200:   }\n2201: \n2202:   const limit = options.limit ?? DEFAULT_LIMIT;\n2203: \n2204:   try {\n2205:     // Build SQL with optional specFolder filter\n2206:     // Exclude archived rows unless explicitly requested\n2207:     const conditions = [\n2208:       `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n2209:     ];\n2210:     const params: unknown[] = [];\n2211: \n2212:     if (options.specFolder) {\n2213:       conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n2214:       params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n2215:     }\n2216: \n2217:     const whereClause = conditions.join(' AND ');\n2218: \n2219:     const sql = `\n2220:       SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n2221:       FROM memory_index\n2222:       WHERE ${whereClause}\n2223:       ORDER BY\n2224:         CASE importance_tier\n2225:           WHEN 'constitutional' THEN 1\n2226:           WHEN 'critical' THEN 2\n2227:           WHEN 'important' THEN 3\n2228:           WHEN 'normal' THEN 4\n2229:           WHEN 'temporary' THEN 5\n2230:           ELSE 6\n2231:         END ASC,\n2232:         importance_weight DESC,\n2233:         created_at DESC\n2234:       LIMIT ?\n2235:     `;\n2236:     params.push(limit);\n2237: \n2238:     const stmt = db.prepare(sql);\n2239:     const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n2240: \n2241:     return rows.map((row, index) => ({\n2242:       id: row.id as number,\n2243:       score: Math.max(0, 1.0 - index * 0.05),\n2244:       source: 'structural',\n2245:       title: (row.title as string) ?? undefined,\n2246:       file_path: row.file_path as string,\n2247:       importance_tier: row.importance_tier as string,\n2248:       spec_folder: row.spec_folder as string,\n2249:     }));\n2250:   } catch (error: unknown) {\n2251:     const msg = error instanceof Error ? error.message : String(error);\n2252:     console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n2253:     return [];\n2254:   }\n2255: }\n2256: \n2257: /**\n2258:  * Normalize result IDs to a canonical key used for deduplication and source tracking.\n2259:  * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n2260:  */\n2261: function canonicalResultId(id: number | string): string {\n2262:   if (typeof id === 'number') {\n2263:     return String(id);\n2264:   }\n2265: \n2266:   const raw = String(id).trim();\n2267:   const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n2268:   if (memPrefixed) {\n2269:     return String(Number(memPrefixed[1]));\n2270:   }\n2271: \n2272:   if (/^\\d+$/.test(raw)) {\n2273:     return String(Number(raw));\n2274:   }\n2275: \n2276:   return raw;\n2277: }\n2278: \n2279: function truncateChars(input: string, maxChars: number): string {\n2280:   if (input.length <= maxChars) return input;\n2281:   if (maxChars <= 1) return input.slice(0, maxChars);\n2282:   return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n2283: }\n2284: \n2285: function extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n2286:   const normalized = filePath.replace(/\\\\/g, '/');\n2287:   const splitToken = '/specs/';\n2288:   const splitIdx = normalized.lastIndexOf(splitToken);\n2289:   if (splitIdx < 0) return null;\n2290: \n2291:   const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n2292:   const parts = relative.split('/').filter(Boolean);\n2293:   if (parts.length < 2) return null;\n2294: \n2295:   // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n2296:   // For canonical memory paths like:\n2297:   // .../specs/<parent>/<child>/memory/<file>.md\n2298:   const memoryIdx = parts.indexOf('memory');\n2299:   const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n2300:   const tailParts = scopeParts.slice(-2);\n2301:   if (tailParts.length < 2) return null;\n2302: \n2303:   return {\n2304:     left: tailParts[0],\n2305:     right: tailParts[1],\n2306:     tailKey: tailParts.join('/'),\n2307:   };\n2308: }\n2309: \n2310: // Memoize description map to avoid rebuilding on every search query.\n2311: // Cache invalidates after 60 seconds so folder renames are eventually picked up.\n2312: // Return stale cache immediately and refresh asynchronously to avoid\n2313: // blocking the search hot path with synchronous filesystem crawls.\n2314: let descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\n2315: let descMapRefreshing = false;\n2316: const DESC_MAP_TTL_MS = 60_000;\n2317: \n2318: function rebuildDescriptionTailMap(): Map<string, string> {\n2319:   const descByTail = new Map<string, string>();\n2320:   const cache = ensureDescriptionCache(getSpecsBasePaths());\n2321:   if (!cache || !Array.isArray(cache.folders)) {\n2322:     return descByTail;\n2323:   }\n2324: \n2325:   for (const entry of cache.folders) {\n2326:     const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n2327:     const description = typeof entry.description === 'string' ? entry.description : '';\n2328:     if (!specFolder || !description) continue;\n2329:     const folderParts = specFolder.split('/').filter(Boolean);\n2330:     if (folderParts.length < 2) continue;\n2331:     const tailKey = folderParts.slice(-2).join('/');\n2332:     if (!descByTail.has(tailKey)) {\n2333:       descByTail.set(tailKey, description);\n2334:     }\n2335:   }\n2336: \n2337:   return descByTail;\n2338: }\n2339: \n2340: function buildDescriptionTailMap(): Map<string, string> {\n2341:   // Fresh cache — return immediately\n2342:   if (descMapCache && (Date.now() - descMapCache.timestamp) < DESC_MAP_TTL_MS) {\n2343:     return descMapCache.map;\n2344:   }\n2345: \n2346:   // Stale cache — return it and schedule async refresh (fail open)\n2347:   if (descMapCache) {\n2348:     if (!descMapRefreshing) {\n2349:       descMapRefreshing = true;\n2350:       setTimeout(() => {\n2351:         try {\n2352:           const freshMap = rebuildDescriptionTailMap();\n2353:           descMapCache = { map: freshMap, timestamp: Date.now() };\n2354:         } catch (_error: unknown) {\n2355:           // Non-fatal: stale cache remains usable\n2356:         } finally {\n2357:           descMapRefreshing = false;\n2358:         }\n2359:       }, 0);\n2360:     }\n2361:     return descMapCache.map;\n2362:   }\n2363: \n2364:   // Cold start — synchronous build required (no stale data to return)\n2365:   const freshMap = rebuildDescriptionTailMap();\n2366:   descMapCache = { map: freshMap, timestamp: Date.now() };\n2367:   return freshMap;\n2368: }\n2369: \n2370: function injectContextualTree(row: HybridSearchResult, descCache: Map<string, string>): HybridSearchResult {\n2371:   const rowData = row as Record<string, unknown>;\n2372:   const content = rowData.content;\n2373:   const filePath = typeof rowData.file_path === 'string' ? rowData.file_path : null;\n2374: \n2375:   if (typeof content !== 'string' || content.length === 0 || !filePath) {\n2376:     return row;\n2377:   }\n2378: \n2379:   const segments = extractSpecSegments(filePath);\n2380:   if (!segments) {\n2381:     return row;\n2382:   }\n2383: \n2384:   const descriptionRaw = descCache.get(segments.tailKey) ?? '';\n2385:   const description = truncateChars(descriptionRaw, 60);\n2386:   const base = `[${segments.left} > ${segments.right}`;\n2387:   const withDesc = description.length > 0 ? `${base} — ${description}]` : `${base}]`;\n2388:   const header = truncateChars(withDesc, CONTEXT_HEADER_MAX_CHARS);\n2389: \n2390:   return {\n2391:     ...row,\n2392:     content: `${header}\\n${content}`,\n2393:   };\n2394: }\n2395: \n2396: function dedupeResultsByCanonicalId(results: HybridSearchResult[]): HybridSearchResult[] {\n2397:   const deduped = new Map<string, HybridSearchResult>();\n2398:   for (const result of results) {\n2399:     const key = canonicalResultId(result.id);\n2400:     if (!deduped.has(key)) {\n2401:       deduped.set(key, result);\n2402:     }\n2403:   }\n2404:   return Array.from(deduped.values());\n2405: }\n2406: \n2407: /** Apply caller limit after merges that can expand result count. */\n2408: function applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n2409:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n2410:     return results;\n2411:   }\n2412:   return results.slice(0, limit);\n2413: }\n2414: \n2415: /** Depth of the result head rebalanced by the cosine-primary reorder. */\n2416: const COSINE_TOPN_REORDER_DEPTH = 10;\n2417: \n2418: /**\n2419:  * Cosine-primary reorder of the result head.\n2420:  *\n2421:  * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n2422:  * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n2423:  * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n2424:  * decisive for downstream consumers — is rebalanced toward the strongest absolute\n2425:  * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n2426:  * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n2427:  * and membership are invariant — this only permutes the head.\n2428:  */\n2429: function reorderTopNByCosine(\n2430:   results: HybridSearchResult[],\n2431:   depth: number = COSINE_TOPN_REORDER_DEPTH\n2432: ): HybridSearchResult[] {\n2433:   const headCount = Math.min(depth, results.length);\n2434:   if (headCount <= 1) return results;\n2435: \n2436:   const head = results.slice(0, headCount);\n2437:   // Decorate with the original index so equal-relevance ties resolve to fused\n2438:   // order regardless of the engine's sort stability.\n2439:   const reordered = head\n2440:     .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n2441:     .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n2442:     .map((entry) => entry.row);\n2443: \n2444:   return [...reordered, ...results.slice(headCount)];\n2445: }\n2446: \n2447: /** Tier-3 structural results are capped at this fraction of the top existing score. */\n2448: const TIER3_CAP_RATIO = 0.5;\n2449: /** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\n2450: const TIER3_DECAY_PER_RANK = 0.08;\n2451: \n2452: /**\n2453:  * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n2454:  * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n2455:  */\n2456: function calibrateTier3Scores(\n2457:   existing: HybridSearchResult[],\n2458:   tier3: HybridSearchResult[]\n2459: ): HybridSearchResult[] {\n2460:   const topExisting = existing.reduce((max, row) => {\n2461:     if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n2462:       return max;\n2463:     }\n2464:     return Math.max(max, row.score);\n2465:   }, 0);\n2466: \n2467:   if (topExisting <= 0) {\n2468:     return tier3;\n2469:   }\n2470: \n2471:   const topCap = topExisting * TIER3_CAP_RATIO;\n2472:   const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n2473: \n2474:   return tier3.map((row, index) => {\n2475:     const calibrated = Math.max(0, topCap - (index * decayPerRank));\n2476:     return {\n2477:       ...row,\n2478:       score: Math.min(row.score, calibrated),\n2479:     };\n2480:   });\n2481: }\n2482: \n2483: // 13. TIERED FALLBACK (PI-A2)\n2484: \n2485: /**\n2486:  * Evaluate whether results meet quality thresholds.\n2487:  * Returns null if thresholds are met, or a DegradationTrigger if not.\n2488:  */\n2489: function checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n2490:   const scores = results\n2491:     .map(r => r.score)\n2492:     .filter((score): score is number => typeof score === 'number' && Number.isFinite(score))\n2493:     .sort((a, b) => b - a);\n2494: \n2495:   const topScore = scores[0] ?? 0;\n2496:   const secondScore = scores[1] ?? 0;\n2497:   const relativeGap = topScore > 0 ? (topScore - secondScore) / topScore : 0;\n2498:   const count = results.length;\n2499: \n2500:   const lowQuality =\n2501:     topScore < DEGRADATION_QUALITY_THRESHOLD\n2502:     && relativeGap < DEGRADATION_MIN_RELATIVE_GAP;\n2503:   const insufficientResults = count < DEGRADATION_MIN_RESULTS;\n2504: \n2505:   if (!lowQuality && !insufficientResults) return null;\n2506: \n2507:   return {\n2508:     reason: lowQuality && insufficientResults ? 'both'\n2509:       : lowQuality ? 'low_quality'\n2510:       : 'insufficient_results',\n2511:     topScore,\n2512:     resultCount: count,\n2513:     relativeGap,\n2514:   };\n2515: }\n2516: \n2517: /**\n2518:  * Merge two result arrays, deduplicating by id and keeping the higher score.\n2519:  */\n2520: function mergeResults(\n2521:   existing: HybridSearchResult[],\n2522:   incoming: HybridSearchResult[]\n2523: ): HybridSearchResult[] {\n2524:   const byId = new Map<string, HybridSearchResult>();\n2525: \n2526:   for (const r of existing) {\n2527:     byId.set(canonicalResultId(r.id), r);\n2528:   }\n2529:   for (const r of incoming) {\n2530:     const key = canonicalResultId(r.id);\n2531:     const prev = byId.get(key);\n2532:     if (!prev || r.score > prev.score) {\n2533:       byId.set(key, r);\n2534:     }\n2535:   }\n2536: \n2537:   return Array.from(byId.values()).sort((a, b) => b.score - a.score);\n2538: }\n2539: \n2540: /**\n2541:  * PI-A2: Quality-aware 3-tier search fallback chain.\n2542:  *\n2543:  * TIER 1: hybridSearchEnhanced at minSimilarity=30\n2544:  *   → Pass if quality signal is healthy AND count >= 3\n2545:  *\n2546:  * TIER 2: hybridSearchEnhanced at minSimilarity=10, all allowed channels forced\n2547:  *   → Merge with Tier 1, dedup by id\n2548:  *   → Pass if quality signal is healthy AND count >= 3\n2549:  *\n2550:  * TIER 3: structuralSearch (pure SQL last-resort)\n2551:  *   → Merge with Tier 1+2 results after score calibration\n2552:  *   → Return capped set\n2553:  *\n2554:  * @param query - The search query string.\n2555:  * @param embedding - Optional embedding vector for semantic search.\n2556:  * @param options - Hybrid search configuration options.\n2557:  * @returns Results with _degradation metadata attached as non-enumerable property.\n2558:  */\n2559: async function searchWithFallbackTiered(\n2560:   query: string,\n2561:   embedding: Float32Array | number[] | null,\n2562:   options: HybridSearchOptions = {}\n2563: ): Promise<HybridSearchResult[]> {\n2564:   const degradationEvents: DegradationEvent[] = [];\n2565:   const { stages } = await executeFallbackPlan(query, embedding, options, 'tiered');\n2566:   const tier1Stage = stages[0];\n2567:   const tier2Stage = stages[1];\n2568:   let results = tier1Stage?.results ?? [];\n2569:   let enrichmentExecution = tier1Stage?.execution ?? null;\n2570:   let enrichmentOptions = tier1Stage?.options ?? options;\n2571: \n2572:   const tier1Trigger = checkDegradation(results);\n2573:   if (tier1Trigger) {\n2574:     // TIER 2: Widen search — lower similarity, force all channels\n2575:     const tier1CountBefore = results.length;\n2576: \n2577:     console.error(`[hybrid-search] Tier 1→2 degradation: ${tier1Trigger.reason} (topScore=${tier1Trigger.topScore.toFixed(3)}, count=${tier1Trigger.resultCount})`);\n2578: \n2579:     const tier2Results = tier2Stage?.results ?? [];\n2580:     results = mergeResults(results, tier2Results);\n2581:     if (tier2Stage?.execution) {\n2582:       enrichmentExecution = tier2Stage.execution;\n2583:       enrichmentOptions = tier2Stage.options;\n2584:     }\n2585:     degradationEvents.push({\n2586:       tier: 1,\n2587:       trigger: tier1Trigger,\n2588:       resultCountBefore: tier1CountBefore,\n2589:       resultCountAfter: results.length,\n2590:     });\n2591: \n2592:     const tier2Trigger = checkDegradation(results);\n2593:     if (tier2Trigger) {\n2594:       // TIER 3: Structural search (pure SQL last-resort)\n2595:       const tier2CountBefore = results.length;\n2596: \n2597:       console.error(`[hybrid-search] Tier 2→3 degradation: ${tier2Trigger.reason} (topScore=${tier2Trigger.topScore.toFixed(3)}, count=${tier2Trigger.resultCount})`);\n2598: \n2599:       const tier3Results = structuralSearch({ specFolder: options.specFolder, limit: options.limit });\n2600:       const calibratedTier3 = calibrateTier3Scores(results, tier3Results);\n2601:       results = mergeResults(results, calibratedTier3);\n2602:       degradationEvents.push({\n2603:         tier: 2,\n2604:         trigger: tier2Trigger,\n2605:         resultCountBefore: tier2CountBefore,\n2606:         resultCountAfter: results.length,\n2607:       });\n2608:     }\n2609:   }\n2610: \n2611:   const finalResults = enrichmentExecution\n2612:     ? await enrichFusedResults(query, enrichmentExecution, enrichmentOptions, results)\n2613:     : applyResultLimit(results, options.limit);\n2614: \n2615:   Object.defineProperty(finalResults, '_degradation', {\n2616:     value: degradationEvents,\n2617:     enumerable: false,\n2618:     configurable: true,\n2619:   });\n2620: \n2621:   return finalResults;\n2622: }\n2623: \n2624: // 14. PRE-FLIGHT TOKEN BUDGET VALIDATION\n2625: \n2626: /** Default token budget — configurable via SPECKIT_TOKEN_BUDGET env var. */\n2627: const DEFAULT_TOKEN_BUDGET = 2000;\n2628: \n2629: /** Maximum characters for a summary fallback when a single result overflows the budget. */\n2630: const SUMMARY_MAX_CHARS = 400;\n2631: \n2632: /** Overflow log entry recording budget truncation events for eval infrastructure. */\n2633: interface OverflowLogEntry {\n2634:   queryId: string;\n2635:   candidateCount: number;\n2636:   totalTokens: number;\n2637:   budgetLimit: number;\n2638:   truncatedToCount: number;\n2639:   timestamp: string;\n2640: }\n2641: \n2642: /** Result of budget-aware truncation. */\n2643: interface TruncateToBudgetResult {\n2644:   results: HybridSearchResult[];\n2645:   truncated: boolean;\n2646:   overflow?: OverflowLogEntry;\n2647:   /** Progressive-disclosure envelope (summary + first page + cursor) for the\n2648:    * overflow remainder that did not fit the immediate payload. Present only\n2649:    * when results overflowed the budget and some remainder was deferred. */\n2650:   progressive?: ProgressiveResponse;\n2651: }\n2652: \n2653: /**\n2654:  * Estimate token count for a text string using a chars/4 heuristic.\n2655:  * @param text - The text to estimate tokens for.\n2656:  * @returns Approximate token count (ceiling of length / 4).\n2657:  */\n2658: function estimateTokenCount(text: string): number {\n2659:   if (!text) return 0;\n2660:   return Math.ceil(text.length / 4);\n2661: }\n2662: \n2663: function estimateStructuredValueChars(value: unknown, seen: WeakSet<object>): number {\n2664:   if (value == null) return 4;\n2665: \n2666:   if (typeof value === 'string') return value.length + 2;\n2667:   if (typeof value === 'number' || typeof value === 'bigint') return String(value).length;\n2668:   if (typeof value === 'boolean') return value ? 4 : 5;\n2669: \n2670:   if (Array.isArray(value)) {\n2671:     let chars = 2;\n2672:     for (const item of value) {\n2673:       chars += estimateStructuredValueChars(item, seen) + 1;\n2674:     }\n2675:     return chars;\n2676:   }\n2677: \n2678:   if (typeof value !== 'object') return 0;\n2679:   if (seen.has(value)) return 8;\n2680:   seen.add(value);\n2681: \n2682:   let chars = 2;\n2683:   for (const [key, nestedValue] of Object.entries(value as Record<string, unknown>)) {\n2684:     chars += key.length + 3;\n2685:     chars += estimateStructuredValueChars(nestedValue, seen) + 1;\n2686:   }\n2687:   return chars;\n2688: }\n2689: \n2690: /**\n2691:  * Estimate the token footprint of a single HybridSearchResult.\n2692:  * @param result - The search result to measure.\n2693:  * @returns Approximate token count based on serialized key-value lengths.\n2694:  */\n2695: function estimateResultTokens(result: HybridSearchResult): number {\n2696:   const record = result as Record<string, unknown>;\n2697:   const seen = new WeakSet<object>();\n2698:   const handledKeys = new Set([\n2699:     'id',\n2700:     'score',\n2701:     'source',\n2702:     'title',\n2703:     'content',\n2704:     'sources',\n2705:     'spec_folder',\n2706:     'file_path',\n2707:     'traceMetadata',\n2708:     'parentMemoryId',\n2709:     'chunkIndex',\n2710:     'similarity',\n2711:     'combined_lexical_score',\n2712:   ]);\n2713: \n2714:   let chars = 0;\n2715:   for (const key of handledKeys) {\n2716:     if (!(key in record)) continue;\n2717:     chars += key.length + 3;\n2718:     chars += estimateStructuredValueChars(record[key], seen) + 1;\n2719:   }\n2720: \n2721:   for (const key of Object.keys(record)) {\n2722:     if (handledKeys.has(key)) continue;\n2723:     const value = record[key];\n2724:     chars += key.length + 3;\n2725:     chars += estimateStructuredValueChars(value, seen) + 1;\n2726:   }\n2727: \n2728:   return Math.ceil(chars / 4);\n2729: }\n2730: \n2731: /**\n2732:  * Read the configured token budget from SPECKIT_TOKEN_BUDGET env var,\n2733:  * falling back to DEFAULT_TOKEN_BUDGET (2000).\n2734:  * @returns The effective token budget for result truncation.\n2735:  */\n2736: function getTokenBudget(): number {\n2737:   const envVal = process.env['SPECKIT_TOKEN_BUDGET'];\n2738:   if (envVal) {\n2739:     const parsed = parseInt(envVal, 10);\n2740:     if (!isNaN(parsed) && parsed > 0) return parsed;\n2741:   }\n2742:   return DEFAULT_TOKEN_BUDGET;\n2743: }\n2744: \n2745: /**\n2746:  * Create a summary fallback for a single result whose content exceeds the token budget.\n2747:  */\n2748: function createSummaryFallback(result: HybridSearchResult, budget: number): HybridSearchResult {\n2749:   const content = typeof result['content'] === 'string' ? result['content'] as string : '';\n2750:   const title = typeof result['title'] === 'string' ? result['title'] : 'Untitled';\n2751: \n2752:   const maxSummaryChars = Math.min(SUMMARY_MAX_CHARS, budget * 4);\n2753:   const truncatedContent = content.length > maxSummaryChars\n2754:     ? content.slice(0, maxSummaryChars) + '...'\n2755:     : content;\n2756: \n2757:   return {\n2758:     ...result,\n2759:     content: `[Summary] ${title}: ${truncatedContent}`,\n2760:     _summarized: true,\n2761:   };\n2762: }\n2763: \n2764: /**\n2765:  * Truncate a result set to fit within a token budget.\n2766:  *\n2767:  * Results are sorted highest-score-first. On overflow the accumulator\n2768:  * skips a too-large result and keeps scanning, so a single large top memory\n2769:  * never starves smaller lower-ranked results that still fit. The detailed\n2770:  * count is floored at min(limit, DEFAULT_MIN_RESULTS): when fewer full results\n2771:  * fit, the highest-scoring overflow remainder is promoted as token-cheap\n2772:  * summaries so a populated search never collapses to a near-empty payload.\n2773:  * Whatever remains after the floor is routed through progressive disclosure\n2774:  * (summary + first page + cursor) rather than discarded.\n2775:  *\n2776:  * @param results - The full result set to truncate.\n2777:  * @param budget - Optional token budget override (defaults to SPECKIT_TOKEN_BUDGET env / 2000).\n2778:  * @param options - Optional includeContent flag, queryId for overflow logging,\n2779:  *   result limit (for the detailed-count floor), and query text (for cursors).\n2780:  * @returns Object with truncated results, truncation flag, optional overflow log\n2781:  *   entry, and an optional progressive-disclosure envelope for the remainder.\n2782:  */\n2783: function truncateToBudget(\n2784:   results: HybridSearchResult[],\n2785:   budget?: number,\n2786:   options?: { includeContent?: boolean; queryId?: string; limit?: number; query?: string }\n2787: ): TruncateToBudgetResult {\n2788:   const effectiveBudget = (budget && budget > 0) ? budget : getTokenBudget();\n2789:   const includeContent = options?.includeContent ?? false;\n2790:   const queryId = options?.queryId ?? `q-${Date.now()}`;\n2791:   const query = options?.query ?? '';\n2792: \n2793:   if (results.length === 0) {\n2794:     return { results: [], truncated: false };\n2795:   }\n2796: \n2797:   const sorted = [...results].sort((a, b) => b.score - a.score);\n2798:   const tokenEstimateCache = new Map<string, number>();\n2799:   const getTokenEstimate = (result: HybridSearchResult): number => {\n2800:     const cacheKey = canonicalResultId(result.id);\n2801:     const cached = tokenEstimateCache.get(cacheKey);\n2802:     if (cached !== undefined) {\n2803:       return cached;\n2804:     }\n2805: \n2806:     const estimate = estimateResultTokens(result);\n2807:     tokenEstimateCache.set(cacheKey, estimate);\n2808:     return estimate;\n2809:   };\n2810: \n2811:   const totalTokens = sorted.reduce((sum, result) => sum + getTokenEstimate(result), 0);\n2812: \n2813:   if (totalTokens <= effectiveBudget) {\n2814:     return { results: sorted, truncated: false };\n2815:   }\n2816: \n2817:   // Single-result overflow: summarize when content is included, otherwise keep\n2818:   // the lone result and mark the overflow for callers.\n2819:   if (sorted.length === 1) {\n2820:     const outputResult = includeContent\n2821:       ? createSummaryFallback(sorted[0]!, effectiveBudget)\n2822:       : sorted[0]!;\n2823:     const overflow: OverflowLogEntry = {\n2824:       queryId,\n2825:       candidateCount: 1,\n2826:       totalTokens,\n\n(Output capped at 50 KB. Showing lines 1446-2826. Use offset=2827 to continue.)\n</content>","metadata":{"preview":"        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Degree channel re-ranks based on causal-edge connectivity.\n    // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n    // Degree channel — also gated by query-complexity routing\n    if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n      try {\n        graphMetrics.degreeQueries++;\n        // Collect all numeric IDs from existing channels\n        const allResultIds = new Set<number>();\n        for (const list of lists) {\n          for (const r of list.results) {\n            const id = r.id;\n            if (typeof id === 'number') allResultIds.add(id);\n          }\n        }\n\n        if (allResultIds.size > 0) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Degree channel re-ranks based on causal-edge connectivity.\n    // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n    // Degree channel — also gated by query-complexity routing\n    if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n      try {\n        graphMetrics.degreeQueries++;\n        // Collect all numeric IDs from existing channels\n        const allResultIds = new Set<number>();\n        for (const list of lists) {\n          for (const r of list.results) {\n            const id = r.id;\n            if (typeof id === 'number') allResultIds.add(id);\n          }\n        }\n\n        if (allResultIds.size > 0) {\n          const degreeScores = computeDegreeScores(db, Array.from(allResultIds));\n\n          // Build a ranked list sorted by degree score (highest first)\n          const degreeItems: Array<{ id: number; degreeScore: number }> = [];\n          for (const [idStr, score] of degreeScores) {\n            const numId = Number(idStr);\n            if (score > 0 && !isNaN(numId)) {\n              degreeItems.push({ id: numId, degreeScore: score });\n            }\n          }\n          degreeItems.sort((a, b) => b.degreeScore - a.degreeScore);\n\n          if (degreeItems.length > 0) {\n            graphMetrics.degreeHits++;\n            graphMetrics.degreeResultCount += degreeItems.length;\n            lists.push({\n              source: 'degree',\n              results: degreeItems.map(item => ({\n                id: item.id,\n                degreeScore: item.degreeScore,\n              })),\n              weight: DEGREE_CHANNEL_WEIGHT,\n            });\n          }\n        }\n      } catch (_err: unknown) {\n        // Non-critical — degree channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Merge keyword results after all channels complete\n    const keywordResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [\n      ...ftsChannelResults,\n      ...bm25ChannelResults,\n    ];\n\n    if (options.skipFusion) {\n      return {\n        evaluationMode,\n        intent: options.intent || classifyIntent(query).intent,\n        lists,\n        routeResult,\n        budgetResult,\n        s3meta,\n        vectorEmbeddingCache,\n        fusedResults: collectCandidatesFromLists(\n          lists.filter((list) => list.source !== 'degree'),\n          options.limit ?? DEFAULT_LIMIT\n        ),\n      };\n    }\n\n    if (lists.length === 0) {\n      return null;\n    }\n\n    // Track multi-source and graph-only results\n    const sourceMap = new Map<string, Set<string>>();\n    for (const list of lists) {\n      for (const r of list.results) {\n        const key = canonicalResultId(r.id);\n        if (!sourceMap.has(key)) sourceMap.set(key, new Set());\n        sourceMap.get(key)!.add(list.source); // non-null safe: has() guard above guarantees entry exists\n      }\n    }\n    for (const [, sources] of sourceMap) {\n      if (sources.size > 1) graphMetrics.multiSourceResults++;\n      if (sources.size > 1 && sources.has('graph')) graphMetrics.graphMultiSourceResults++;\n      if (sources.size === 1 && sources.has('graph')) graphMetrics.graphOnlyResults++;\n    }\n\n    // Build weighted fusion lists once from lightweight adaptive\n    // weights, avoiding the heavier hybridAdaptiveFuse() standard-first path.\n    const detectedIntent = classifyIntent(query).intent;\n    const intent = resolveFusionIntentContract({\n      detectedIntent,\n      adaptiveFusionIntent: options.intent ?? null,\n      query,\n    })\n      ?? detectedIntent;\n    const adaptiveEnabled = isAdaptiveFusionEnabled();\n    const documentType = resolveAdaptiveDocumentType(lists.map((list) => ({\n      results: list.results as Array<Record<string, unknown>>,\n    })));\n    const fusionWeights = adaptiveEnabled\n      ? getAdaptiveWeights(intent, documentType)\n      : { semanticWeight: 1.0, keywordWeight: 1.0, recencyWeight: 0 };\n    const { semanticWeight, keywordWeight, graphWeight: adaptiveGraphWeight } = fusionWeights;\n    const keywordFusionResults = keywordResults.map((result) => {\n      const originalSource = typeof result.source === 'string' ? result.source : null;\n      const existingSources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      return {\n        ...result,\n        source: 'keyword',\n        sources: Array.from(new Set([...existingSources, ...(originalSource ? [originalSource] : []), 'keyword'])),\n      };\n    });\n    const fusionLists = lists\n      .filter((list) => list.source !== 'fts' && list.source !== 'bm25')\n      .map((list) => {\n        if (list.source === 'vector') {\n          return { ...list, weight: semanticWeight };\n        }\n        if (list.source === 'graph' && typeof adaptiveGraphWeight === 'number') {\n          return { ...list, weight: adaptiveGraphWeight };\n        }\n        return { ...list };\n      });\n\n    if (keywordFusionResults.length > 0 && keywordWeight > 0) {\n      fusionLists.push({\n        source: 'keyword',\n        results: keywordFusionResults,\n        weight: keywordWeight,\n      });\n    }\n\n    const graphList = fusionLists.find((list) => list.source === 'graph');\n    const vectorList = fusionLists.find((list) => list.source === 'vector');\n    const passthroughLists = fusionLists.filter((list) => list.source !== 'graph' && list.source !== 'vector' && list.source !== 'keyword');\n    const fused = adaptiveEnabled\n      ? (adaptiveFuse as unknown as (\n        semanticResults: Array<Record<string, unknown>>,\n        keywordResults: Array<Record<string, unknown>>,\n        weights: typeof fusionWeights,\n        options: {\n          graphResults?: Array<Record<string, unknown>>;\n          additionalLists?: typeof passthroughLists;\n        },\n      ) => FusionResult[])(\n        (vectorList?.results ?? []) as Array<Record<string, unknown>>,\n        keywordFusionResults,\n        fusionWeights,\n        {\n          graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n          additionalLists: passthroughLists,\n        },\n      )\n      : fuseResultsMulti(fusionLists);\n\n    const keywordSourceMap = new Map<string, string[]>();\n    for (const result of keywordFusionResults) {\n      const sources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      if (sources.length > 0) {\n        keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n      }\n    }\n    const triggerScoreMap = new Map<string, number>();\n    for (const result of triggerChannelResults) {\n      if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n        triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n      }\n    }\n\n    const fusedResults = fused.map(toHybridResult).map((row) => {\n      const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n      if (keywordSources && keywordSources.length > 0) {\n        const rowSources = Array.isArray(row.sources)\n          ? row.sources.filter((source): source is string => typeof source === 'string')\n          : [];\n        const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n        row = {\n          ...row,\n          sources,\n          channelAttribution: sources,\n          source: row.source === 'keyword'\n            ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n            : row.source,\n        };\n      }\n      const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n      if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n        row = {\n          ...row,\n          triggerScore,\n          exactTriggerMatch: triggerScore >= 0.94,\n        };\n      }\n      const rowRecord = row as Record<string, unknown>;\n      if (rowRecord.parentMemoryId !== undefined) return row;\n      const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n      if (normalizedParentMemoryId === undefined) return row;\n      return {\n        ...row,\n        parentMemoryId: normalizedParentMemoryId,\n      };\n    });\n\n    return {\n      evaluationMode,\n      intent,\n      lists,\n      routeResult,\n      budgetResult,\n      s3meta,\n      vectorEmbeddingCache,\n      fusedResults,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n    return null;\n  }\n}\n\nasync function enrichFusedResults(\n  query: string,\n  execution: HybridFusionExecution,\n  options: HybridSearchOptions = {},\n  initialResults: HybridSearchResult[] = execution.fusedResults\n): Promise<HybridSearchResult[]> {\n  enrichFusedResultsObserver?.();\n\n  const {\n    evaluationMode,\n    intent,\n    lists,\n    routeResult,\n    budgetResult,\n    s3meta,\n    vectorEmbeddingCache,\n  } = execution;\n  let fusedHybridResults = initialResults;\n  const limit = options.limit || DEFAULT_LIMIT;\n\n  // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n  // When enabled, collapses chunk-level results back to their parent memory\n  // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n  // Multiple chunks from the same document dominating the result list.\n  // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n  if (isDocscoreAggregationEnabled()) {\n    try {\n      const chunkResults = fusedHybridResults.filter(\n        r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n      );\n      if (chunkResults.length > 0) {\n        const nonChunkResults = fusedHybridResults.filter(\n          r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n        );\n        const collapsed = collapseAndReassembleChunkResults(\n          chunkResults.map(r => ({\n            id: r.id,\n            parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n            chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n            score: r.score,\n          }))\n        );\n        // Merge collapsed chunk results with non-chunk results\n        fusedHybridResults = [\n          ...collapsed.map(c => ({\n            id: c.parentMemoryId,\n            score: c.mpabScore,\n            source: 'mpab' as string,\n            _chunkHits: c._chunkHits,\n          } as HybridSearchResult)),\n          ...nonChunkResults,\n        ];\n      }\n    } catch (_mpabErr: unknown) {\n      // Non-critical — MPAB failure does not block pipeline\n      const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n      console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n    }\n  }\n\n  // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n  // Ensures every channel that returned results has at least one representative\n  // In the top-k window. Prevents single-channel dominance in fusion output.\n  // When disabled, passes results through unchanged.\n  try {\n    const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n    for (const list of lists) {\n      channelResultSets.set(list.source, list.results.map(r => ({\n        ...r,\n        id: r.id,\n        score: typeof (r as Record<string, unknown>).score === 'number'\n          ? (r as Record<string, unknown>).score as number\n          : typeof (r as Record<string, unknown>).similarity === 'number'\n            ? ((r as Record<string, unknown>).similarity as number) / 100\n            : 0,\n      })));\n    }\n\n    const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n      fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n      channelResultSets,\n      limit,\n    );\n\n    if (enforcementResult.enforcement.applied) {\n      fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n      s3meta.enforcement = {\n        applied: true,\n        promotedCount: enforcementResult.enforcement.promotedCount,\n        underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n      };\n    }\n  } catch (err: unknown) {\n    // Non-critical — enforcement failure does not block pipeline\n    console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n  }\n\n  // Preserve non-enumerable eval metadata across later array reallocations.\n  const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n  const s4shadowMeta = shadowMeta._s4shadow;\n  const s4attributionMeta = shadowMeta._s4attribution;\n  const degradationMeta = shadowMeta._degradation;\n\n  // MMR reranking with request-scoped embedding cache.\n  // Reuse embeddings already returned by the vector channel when present and\n  // only query vec_memories for missing IDs.\n  let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n\n  if (db && isMMREnabled()) {\n    const numericIds = reranked\n      .map(r => r.id)\n      .filter((id): id is number => typeof id === 'number');\n\n    if (numericIds.length >= MMR_MIN_CANDIDATES) {\n      try {\n        const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n        const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n\n        if (missingIds.length > 0) {\n          const placeholders = missingIds.map(() => '?').join(', ');\n          const embRows = (db.prepare(\n            `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n          ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n          for (const row of embRows) {\n            if (Buffer.isBuffer(row.embedding)) {\n              embeddingMap.set(\n                row.rowid,\n                new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n              );\n            }\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of reranked) {\n          const emb = embeddingMap.get(r.id as number);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id as number,\n              score: (r.score as number) ?? 0,\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n\n          // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n          // rows that have embeddings. Non-embedded rows (lexical-only hits,\n          // graph injections) must be preserved and merged back in their\n          // original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n          const rerankedById = new Map<string, HybridSearchResult>(\n            reranked.map((result) => [canonicalResultId(result.id), result])\n          );\n\n          const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n            const existing = rerankedById.get(canonicalResultId(candidate.id));\n            if (existing) {\n              return existing;\n            }\n\n            return {\n              id: candidate.id,\n              score: candidate.score,\n              source: 'vector',\n            };\n          });\n\n          // Merge: diversified embedded rows first (MMR-ordered), then\n          // non-embedded rows in their original relative order.\n          reranked = [...diversifiedRows, ...nonEmbeddedRows];\n        }\n      } catch (embErr: unknown) {\n        const msg = embErr instanceof Error ? embErr.message : String(embErr);\n        console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n      }\n    }\n  }\n\n  // Co-activation spreading — enrich with temporal neighbors\n  const topIds = reranked\n    .slice(0, SPREAD_ACTIVATION_TOP_N)\n    .map(r => r.id)\n    .filter((id): id is number => typeof id === 'number');\n  if (topIds.length > 0) {\n    try {\n      const spreadResults: SpreadResult[] = spreadActivation(topIds);\n      // Boost scores of results that appear in co-activation graph\n      if (spreadResults.length > 0) {\n        const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n        for (const result of reranked) {\n          const boost = spreadMap.get(result.id as number);\n          if (boost !== undefined) {\n            // Update all score aliases so downstream consumers see the boost.\n            const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n            (result as Record<string, unknown>).score = boostedScore;\n            if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n            if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n          }\n        }\n      }\n      // Re-sort after co-activation boost to ensure boosted results\n      // Are promoted to their correct position in the ranking\n      reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n  if (db && isFolderScoringEnabled() && reranked.length > 0) {\n    try {\n      const numericIds = reranked\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length > 0) {\n        const folderMap = lookupFolders(db, numericIds);\n        if (folderMap.size > 0) {\n          const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n          const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n          const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n          const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n\n          const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n          const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n          reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n        }\n      }\n    } catch (_folderErr: unknown) {\n      // Folder scoring is optional and must not break retrieval\n    }\n  }\n\n  // -- Stage D: Confidence Truncation (SPECKIT_CONFIDENCE_TRUNCATION) --\n  // Run after the ranking pipeline so later boosts/promotions can rescue\n  // candidates before low-confidence tails are trimmed.\n  if (!evaluationMode) {\n    try {\n      const truncationResult: TruncationResult = truncateByConfidence(\n        reranked.map(r => ({ ...r, id: r.id, score: r.score })),\n      );\n\n      if (truncationResult.truncated) {\n        reranked = truncationResult.results.map(r => r as HybridSearchResult);\n        s3meta.truncation = {\n          truncated: true,\n          originalCount: truncationResult.originalCount,\n          truncatedCount: truncationResult.truncatedCount,\n          medianGap: truncationResult.medianGap,\n          cutoffGap: truncationResult.cutoffGap,\n          cutoffIndex: truncationResult.cutoffIndex,\n          thresholdMultiplier: GAP_THRESHOLD_MULTIPLIER,\n          minResultsGuaranteed: DEFAULT_MIN_RESULTS,\n          featureFlagEnabled: isConfidenceTruncationEnabled(),\n        };\n      }\n    } catch (err: unknown) {\n      // Non-critical — truncation failure does not block pipeline\n      console.warn('[hybrid-search] confidence truncation failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Preserve routing and Stage 4 trace metadata as explicit result fields so downstream\n  // Formatters can opt-in to provenance-rich envelopes without relying on\n  // Non-enumerable array shadow properties.\n  if (reranked.length > 0) {\n    reranked = reranked.map((row): HybridSearchResult => {\n      const existingTraceMetadata =\n        typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n          ? row.traceMetadata\n          : {};\n\n      return {\n        ...row,\n        traceMetadata: {\n          ...existingTraceMetadata,\n          ...(s4shadowMeta !== undefined ? { stage4: s4shadowMeta } : {}),\n          ...(s4attributionMeta !== undefined ? { attribution: s4attributionMeta } : {}),\n          ...(degradationMeta !== undefined ? { degradation: degradationMeta } : {}),\n          evaluationMode,\n          // Wire queryComplexity from router classification into trace\n          queryComplexity: routeResult.tier,\n          // Wire confidence truncation metadata into per-result trace (036)\n          ...(s3meta.truncation ? {\n            confidenceTruncation: {\n              truncated: s3meta.truncation.truncated,\n              originalCount: s3meta.truncation.originalCount,\n              truncatedCount: s3meta.truncation.truncatedCount,\n              medianGap: s3meta.truncation.medianGap,\n              cutoffGap: s3meta.truncation.cutoffGap,\n              cutoffIndex: s3meta.truncation.cutoffIndex,\n              thresholdMultiplier: s3meta.truncation.thresholdMultiplier,\n              minResultsGuaranteed: s3meta.truncation.minResultsGuaranteed,\n            },\n          } : {}),\n        },\n      };\n    });\n  }\n\n  if (isContextHeadersEnabled() && reranked.length > 0) {\n    const descriptionCache = buildDescriptionTailMap();\n    if (descriptionCache.size > 0) {\n      reranked = reranked.map((row) => injectContextualTree(row, descriptionCache));\n    }\n  }\n\n  let budgetTruncated = false;\n  let budgetLimit: number | undefined;\n  if (evaluationMode) {\n    reranked = applyResultLimit(reranked, options.limit);\n  } else {\n    // Apply token budget truncation after trace/header enrichment so token\n    // estimates reflect the actual returned payload shape.\n    const headerOverhead = isContextHeadersEnabled()\n      ? reranked.length * CONTEXT_HEADER_TOKEN_OVERHEAD\n      : 0;\n    const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n\n    if (s3meta.tokenBudget) {\n      s3meta.tokenBudget.headerOverhead = headerOverhead;\n      s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n    }\n\n    const budgeted = truncateToBudget(reranked, adjustedBudget, {\n      includeContent: options.includeContent ?? false,\n      queryId: `hybrid-${Date.now()}`,\n      limit: options.limit,\n      query,\n    });\n    reranked = budgeted.results;\n    budgetTruncated = budgeted.truncated;\n    budgetLimit = budgetResult.budget;\n\n    // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n    // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n    // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n    // the budgeted survivors it is the last word on order without disturbing the\n    // budget membership decision. Skipped in evaluationMode so the labeled-set\n    // top-K window stays exactly as fused.\n    if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n      reranked = reorderTopNByCosine(reranked);\n    }\n  }\n\n  if (reranked.length > 0) {\n    reranked = reranked.map((row): HybridSearchResult => {\n      const existingTraceMetadata =\n        typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n          ? row.traceMetadata\n          : {};\n\n      return {\n        ...row,\n        traceMetadata: {\n          ...existingTraceMetadata,\n          budgetTruncated,\n          ...(budgetLimit !== undefined ? { budgetLimit } : {}),\n        },\n      };\n    });\n  }\n\n  if (s4shadowMeta !== undefined && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s4shadow', {\n      value: s4shadowMeta,\n      enumerable: false,\n      configurable: true,\n    });\n  }\n\n  if (s4attributionMeta !== undefined && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s4attribution', {\n      value: s4attributionMeta,\n      enumerable: false,\n      configurable: true,\n    });\n  }\n\n  // Attach pipeline metadata to results for eval/debugging\n  // Metadata is attached as non-enumerable _s3meta property to avoid\n  // Polluting result serialization while remaining accessible for debugging.\n  if (Object.keys(s3meta).length > 0 && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s3meta', { value: s3meta, enumerable: false, configurable: true });\n  }\n\n  return reranked;\n}\n\n/**\n * Collect pipeline candidates through the adaptive fallback chain, returning\n * immediately after intra-query fusion and before downstream aggregation,\n * reranking, or post-processing.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Unfused candidate results from the first non-empty collection stage.\n */\nasync function collectRawCandidates(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n    { stopAfterFusion: true }\n  );\n\n  const primaryResults = stages[0]?.results ?? [];\n  const retryResults = stages[1]?.results ?? [];\n\n  if (isSearchFallbackEnabled()) {\n    const mergedResults = retryResults.length > 0\n      ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n      : primaryResults;\n    if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n  } else {\n    const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n    if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n  }\n\n  if (allowedChannels.has('fts')) {\n    const ftsFallback = collectCandidatesFromLists(\n      [{ source: 'fts', results: ftsSearch(query, options) }],\n      options.limit\n    );\n    if (ftsFallback.length > 0) return ftsFallback;\n  }\n\n  if (allowedChannels.has('bm25')) {\n    const bm25Fallback = collectCandidatesFromLists(\n      [{ source: 'bm25', results: bm25Search(query, options) }],\n      options.limit\n    );\n    if (bm25Fallback.length > 0) return bm25Fallback;\n  }\n\n  console.warn('[hybrid-search] Raw candidate collection returned empty results');\n  return [];\n}\n\n/**\n * Search with automatic fallback chain.\n * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n   * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n * fallback — primary at minSimilarity=30, retry at 17.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Results from the first non-empty stage.\n */\nasync function searchWithFallback(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  // PI-A2: Delegate to tiered fallback when flag is enabled\n  if (isSearchFallbackEnabled()) {\n    return searchWithFallbackTiered(query, embedding, options);\n  }\n\n  // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n  // Where no result exceeds the primary threshold — chosen empirically via eval.\n  // Use hybridSearchEnhanced (with RRF fusion) instead of\n  // The naive hybridSearch that merges raw scores\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    'adaptive'\n  );\n  const primaryStage = stages[0];\n  const retryStage = stages[1];\n  const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n  if (finalStage?.results.length) {\n    return finalStage.execution\n      ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n      : finalStage.results;\n  }\n\n  // Fallback to FTS only\n  if (allowedChannels.has('fts')) {\n    const ftsResults = ftsSearch(query, options);\n    if (ftsResults.length > 0) return ftsResults;\n  }\n\n  // Fallback to BM25 only\n  if (allowedChannels.has('bm25')) {\n    const bm25Results = bm25Search(query, options);\n    if (bm25Results.length > 0) return bm25Results;\n  }\n\n  console.warn('[hybrid-search] All search methods returned empty results');\n  return [];\n}\n\n// 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n\n/**\n * PI-A2: Last-resort structural search against the memory_index table.\n * Retrieves memories ordered by importance tier and weight, without\n * requiring embeddings or text similarity. Pure SQL fallback.\n *\n * @param options - Search options (specFolder for filtering, limit for cap).\n * @returns Array of HybridSearchResult with source='structural'.\n */\nfunction structuralSearch(\n  options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n): HybridSearchResult[] {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n    return [];\n  }\n\n  const limit = options.limit ?? DEFAULT_LIMIT;\n\n  try {\n    // Build SQL with optional specFolder filter\n    // Exclude archived rows unless explicitly requested\n    const conditions = [\n      `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n    ];\n    const params: unknown[] = [];\n\n    if (options.specFolder) {\n      conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n      params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n    }\n\n    const whereClause = conditions.join(' AND ');\n\n    const sql = `\n      SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n      FROM memory_index\n      WHERE ${whereClause}\n      ORDER BY\n        CASE importance_tier\n          WHEN 'constitutional' THEN 1\n          WHEN 'critical' THEN 2\n          WHEN 'important' THEN 3\n          WHEN 'normal' THEN 4\n          WHEN 'temporary' THEN 5\n          ELSE 6\n        END ASC,\n        importance_weight DESC,\n        created_at DESC\n      LIMIT ?\n    `;\n    params.push(limit);\n\n    const stmt = db.prepare(sql);\n    const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n\n    return rows.map((row, index) => ({\n      id: row.id as number,\n      score: Math.max(0, 1.0 - index * 0.05),\n      source: 'structural',\n      title: (row.title as string) ?? undefined,\n      file_path: row.file_path as string,\n      importance_tier: row.importance_tier as string,\n      spec_folder: row.spec_folder as string,\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Normalize result IDs to a canonical key used for deduplication and source tracking.\n * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n */\nfunction canonicalResultId(id: number | string): string {\n  if (typeof id === 'number') {\n    return String(id);\n  }\n\n  const raw = String(id).trim();\n  const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n  if (memPrefixed) {\n    return String(Number(memPrefixed[1]));\n  }\n\n  if (/^\\d+$/.test(raw)) {\n    return String(Number(raw));\n  }\n\n  return raw;\n}\n\nfunction truncateChars(input: string, maxChars: number): string {\n  if (input.length <= maxChars) return input;\n  if (maxChars <= 1) return input.slice(0, maxChars);\n  return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n}\n\nfunction extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n  const normalized = filePath.replace(/\\\\/g, '/');\n  const splitToken = '/specs/';\n  const splitIdx = normalized.lastIndexOf(splitToken);\n  if (splitIdx < 0) return null;\n\n  const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n  const parts = relative.split('/').filter(Boolean);\n  if (parts.length < 2) return null;\n\n  // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n  // For canonical memory paths like:\n  // .../specs/<parent>/<child>/memory/<file>.md\n  const memoryIdx = parts.indexOf('memory');\n  const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n  const tailParts = scopeParts.slice(-2);\n  if (tailParts.length < 2) return null;\n\n  return {\n    left: tailParts[0],\n    right: tailParts[1],\n    tailKey: tailParts.join('/'),\n  };\n}\n\n// Memoize description map to avoid rebuilding on every search query.\n// Cache invalidates after 60 seconds so folder renames are eventually picked up.\n// Return stale cache immediately and refresh asynchronously to avoid\n// blocking the search hot path with synchronous filesystem crawls.\nlet descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\nlet descMapRefreshing = false;\nconst DESC_MAP_TTL_MS = 60_000;\n\nfunction rebuildDescriptionTailMap(): Map<string, string> {\n  const descByTail = new Map<string, string>();\n  const cache = ensureDescriptionCache(getSpecsBasePaths());\n  if (!cache || !Array.isArray(cache.folders)) {\n    return descByTail;\n  }\n\n  for (const entry of cache.folders) {\n    const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n    const description = typeof entry.description === 'string' ? entry.description : '';\n    if (!specFolder || !description) continue;\n    const folderParts = specFolder.split('/').filter(Boolean);\n    if (folderParts.length < 2) continue;\n    const tailKey = folderParts.slice(-2).join('/');\n    if (!descByTail.has(tailKey)) {\n      descByTail.set(tailKey, description);\n    }\n  }\n\n  return descByTail;\n}\n\nfunction buildDescriptionTailMap(): Map<string, string> {\n  // Fresh cache — return immediately\n  if (descMapCache && (Date.now() - descMapCache.timestamp) < DESC_MAP_TTL_MS) {\n    return descMapCache.map;\n  }\n\n  // Stale cache — return it and schedule async refresh (fail open)\n  if (descMapCache) {\n    if (!descMapRefreshing) {\n      descMapRefreshing = true;\n      setTimeout(() => {\n        try {\n          const freshMap = rebuildDescriptionTailMap();\n          descMapCache = { map: freshMap, timestamp: Date.now() };\n        } catch (_error: unknown) {\n          // Non-fatal: stale cache remains usable\n        } finally {\n          descMapRefreshing = false;\n        }\n      }, 0);\n    }\n    return descMapCache.map;\n  }\n\n  // Cold start — synchronous build required (no stale data to return)\n  const freshMap = rebuildDescriptionTailMap();\n  descMapCache = { map: freshMap, timestamp: Date.now() };\n  return freshMap;\n}\n\nfunction injectContextualTree(row: HybridSearchResult, descCache: Map<string, string>): HybridSearchResult {\n  const rowData = row as Record<string, unknown>;\n  const content = rowData.content;\n  const filePath = typeof rowData.file_path === 'string' ? rowData.file_path : null;\n\n  if (typeof content !== 'string' || content.length === 0 || !filePath) {\n    return row;\n  }\n\n  const segments = extractSpecSegments(filePath);\n  if (!segments) {\n    return row;\n  }\n\n  const descriptionRaw = descCache.get(segments.tailKey) ?? '';\n  const description = truncateChars(descriptionRaw, 60);\n  const base = `[${segments.left} > ${segments.right}`;\n  const withDesc = description.length > 0 ? `${base} — ${description}]` : `${base}]`;\n  const header = truncateChars(withDesc, CONTEXT_HEADER_MAX_CHARS);\n\n  return {\n    ...row,\n    content: `${header}\\n${content}`,\n  };\n}\n\nfunction dedupeResultsByCanonicalId(results: HybridSearchResult[]): HybridSearchResult[] {\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const result of results) {\n    const key = canonicalResultId(result.id);\n    if (!deduped.has(key)) {\n      deduped.set(key, result);\n    }\n  }\n  return Array.from(deduped.values());\n}\n\n/** Apply caller limit after merges that can expand result count. */\nfunction applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return results;\n  }\n  return results.slice(0, limit);\n}\n\n/** Depth of the result head rebalanced by the cosine-primary reorder. */\nconst COSINE_TOPN_REORDER_DEPTH = 10;\n\n/**\n * Cosine-primary reorder of the result head.\n *\n * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n * decisive for downstream consumers — is rebalanced toward the strongest absolute\n * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n * and membership are invariant — this only permutes the head.\n */\nfunction reorderTopNByCosine(\n  results: HybridSearchResult[],\n  depth: number = COSINE_TOPN_REORDER_DEPTH\n): HybridSearchResult[] {\n  const headCount = Math.min(depth, results.length);\n  if (headCount <= 1) return results;\n\n  const head = results.slice(0, headCount);\n  // Decorate with the original index so equal-relevance ties resolve to fused\n  // order regardless of the engine's sort stability.\n  const reordered = head\n    .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n    .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n    .map((entry) => entry.row);\n\n  return [...reordered, ...results.slice(headCount)];\n}\n\n/** Tier-3 structural results are capped at this fraction of the top existing score. */\nconst TIER3_CAP_RATIO = 0.5;\n/** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\nconst TIER3_DECAY_PER_RANK = 0.08;\n\n/**\n * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n */\nfunction calibrateTier3Scores(\n  existing: HybridSearchResult[],\n  tier3: HybridSearchResult[]\n): HybridSearchResult[] {\n  const topExisting = existing.reduce((max, row) => {\n    if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n      return max;\n    }\n    return Math.max(max, row.score);\n  }, 0);\n\n  if (topExisting <= 0) {\n    return tier3;\n  }\n\n  const topCap = topExisting * TIER3_CAP_RATIO;\n  const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n\n  return tier3.map((row, index) => {\n    const calibrated = Math.max(0, topCap - (index * decayPerRank));\n    return {\n      ...row,\n      score: Math.min(row.score, calibrated),\n    };\n  });\n}\n\n// 13. TIERED FALLBACK (PI-A2)\n\n/**\n * Evaluate whether results meet quality thresholds.\n * Returns null if thresholds are met, or a DegradationTrigger if not.\n */\nfunction checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n  const scores = results\n    .map(r => r.score)\n    .filter((score): score is number => typeof score === 'number' && Number.isFinite(score))\n    .sort((a, b) => b - a);\n\n  const topScore = scores[0] ?? 0;\n  const secondScore = scores[1] ?? 0;\n  const relativeGap = topScore > 0 ? (topScore - secondScore) / topScore : 0;\n  const count = results.length;\n\n  const lowQuality =\n    topScore < DEGRADATION_QUALITY_THRESHOLD\n    && relativeGap < DEGRADATION_MIN_RELATIVE_GAP;\n  const insufficientResults = count < DEGRADATION_MIN_RESULTS;\n\n  if (!lowQuality && !insufficientResults) return null;\n\n  return {\n    reason: lowQuality && insufficientResults ? 'both'\n      : lowQuality ? 'low_quality'\n      : 'insufficient_results',\n    topScore,\n    resultCount: count,\n    relativeGap,\n  };\n}\n\n/**\n * Merge two result arrays, deduplicating by id and keeping the higher score.\n */\nfunction mergeResults(\n  existing: HybridSearchResult[],\n  incoming: HybridSearchResult[]\n): HybridSearchResult[] {\n  const byId = new Map<string, HybridSearchResult>();\n\n  for (const r of existing) {\n    byId.set(canonicalResultId(r.id), r);\n  }\n  for (const r of incoming) {\n    const key = canonicalResultId(r.id);\n    const prev = byId.get(key);\n    if (!prev || r.score > prev.score) {\n      byId.set(key, r);\n    }\n  }\n\n  return Array.from(byId.values()).sort((a, b) => b.score - a.score);\n}\n\n/**\n * PI-A2: Quality-aware 3-tier search fallback chain.\n *\n * TIER 1: hybridSearchEnhanced at minSimilarity=30\n *   → Pass if quality signal is healthy AND count >= 3\n *\n * TIER 2: hybridSearchEnhanced at minSimilarity=10, all allowed channels forced\n *   → Merge with Tier 1, dedup by id\n *   → Pass if quality signal is healthy AND count >= 3\n *\n * TIER 3: structuralSearch (pure SQL last-resort)\n *   → Merge with Tier 1+2 results after score calibration\n *   → Return capped set\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Results with _degradation metadata attached as non-enumerable property.\n */\nasync function searchWithFallbackTiered(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const degradationEvents: DegradationEvent[] = [];\n  const { stages } = await executeFallbackPlan(query, embedding, options, 'tiered');\n  const tier1Stage = stages[0];\n  const tier2Stage = stages[1];\n  let results = tier1Stage?.results ?? [];\n  let enrichmentExecution = tier1Stage?.execution ?? null;\n  let enrichmentOptions = tier1Stage?.options ?? options;\n\n  const tier1Trigger = checkDegradation(results);\n  if (tier1Trigger) {\n    // TIER 2: Widen search — lower similarity, force all channels\n    const tier1CountBefore = results.length;\n\n    console.error(`[hybrid-search] Tier 1→2 degradation: ${tier1Trigger.reason} (topScore=${tier1Trigger.topScore.toFixed(3)}, count=${tier1Trigger.resultCount})`);\n\n    const tier2Results = tier2Stage?.results ?? [];\n    results = mergeResults(results, tier2Results);\n    if (tier2Stage?.execution) {\n      enrichmentExecution = tier2Stage.execution;\n      enrichmentOptions = tier2Stage.options;\n    }\n    degradationEvents.push({\n      tier: 1,\n      trigger: tier1Trigger,\n      resultCountBefore: tier1CountBefore,\n      resultCountAfter: results.length,\n    });\n\n    const tier2Trigger = checkDegradation(results);\n    if (tier2Trigger) {\n      // TIER 3: Structural search (pure SQL last-resort)\n      const tier2CountBefore = results.length;\n\n      console.error(`[hybrid-search] Tier 2→3 degradation: ${tier2Trigger.reason} (topScore=${tier2Trigger.topScore.toFixed(3)}, count=${tier2Trigger.resultCount})`);\n\n      const tier3Results = structuralSearch({ specFolder: options.specFolder, limit: options.limit });\n      const calibratedTier3 = calibrateTier3Scores(results, tier3Results);\n      results = mergeResults(results, calibratedTier3);\n      degradationEvents.push({\n        tier: 2,\n        trigger: tier2Trigger,\n        resultCountBefore: tier2CountBefore,\n        resultCountAfter: results.length,\n      });\n    }\n  }\n\n  const finalResults = enrichmentExecution\n    ? await enrichFusedResults(query, enrichmentExecution, enrichmentOptions, results)\n    : applyResultLimit(results, options.limit);\n\n  Object.defineProperty(finalResults, '_degradation', {\n    value: degradationEvents,\n    enumerable: false,\n    configurable: true,\n  });\n\n  return finalResults;\n}\n\n// 14. PRE-FLIGHT TOKEN BUDGET VALIDATION\n\n/** Default token budget — configurable via SPECKIT_TOKEN_BUDGET env var. */\nconst DEFAULT_TOKEN_BUDGET = 2000;\n\n/** Maximum characters for a summary fallback when a single result overflows the budget. */\nconst SUMMARY_MAX_CHARS = 400;\n\n/** Overflow log entry recording budget truncation events for eval infrastructure. */\ninterface OverflowLogEntry {\n  queryId: string;\n  candidateCount: number;\n  totalTokens: number;\n  budgetLimit: number;\n  truncatedToCount: number;\n  timestamp: string;\n}\n\n/** Result of budget-aware truncation. */\ninterface TruncateToBudgetResult {\n  results: HybridSearchResult[];\n  truncated: boolean;\n  overflow?: OverflowLogEntry;\n  /** Progressive-disclosure envelope (summary + first page + cursor) for the\n   * overflow remainder that did not fit the immediate payload. Present only\n   * when results overflowed the budget and some remainder was deferred. */\n  progressive?: ProgressiveResponse;\n}\n\n/**\n * Estimate token count for a text string using a chars/4 heuristic.\n * @param text - The text to estimate tokens for.\n * @returns Approximate token count (ceiling of length / 4).\n */\nfunction estimateTokenCount(text: string): number {\n  if (!text) return 0;\n  return Math.ceil(text.length / 4);\n}\n\nfunction estimateStructuredValueChars(value: unknown, seen: WeakSet<object>): number {\n  if (value == null) return 4;\n\n  if (typeof value === 'string') return value.length + 2;\n  if (typeof value === 'number' || typeof value === 'bigint') return String(value).length;\n  if (typeof value === 'boolean') return value ? 4 : 5;\n\n  if (Array.isArray(value)) {\n    let chars = 2;\n    for (const item of value) {\n      chars += estimateStructuredValueChars(item, seen) + 1;\n    }\n    return chars;\n  }\n\n  if (typeof value !== 'object') return 0;\n  if (seen.has(value)) return 8;\n  seen.add(value);\n\n  let chars = 2;\n  for (const [key, nestedValue] of Object.entries(value as Record<string, unknown>)) {\n    chars += key.length + 3;\n    chars += estimateStructuredValueChars(nestedValue, seen) + 1;\n  }\n  return chars;\n}\n\n/**\n * Estimate the token footprint of a single HybridSearchResult.\n * @param result - The search result to measure.\n * @returns Approximate token count based on serialized key-value lengths.\n */\nfunction estimateResultTokens(result: HybridSearchResult): number {\n  const record = result as Record<string, unknown>;\n  const seen = new WeakSet<object>();\n  const handledKeys = new Set([\n    'id',\n    'score',\n    'source',\n    'title',\n    'content',\n    'sources',\n    'spec_folder',\n    'file_path',\n    'traceMetadata',\n    'parentMemoryId',\n    'chunkIndex',\n    'similarity',\n    'combined_lexical_score',\n  ]);\n\n  let chars = 0;\n  for (const key of handledKeys) {\n    if (!(key in record)) continue;\n    chars += key.length + 3;\n    chars += estimateStructuredValueChars(record[key], seen) + 1;\n  }\n\n  for (const key of Object.keys(record)) {\n    if (handledKeys.has(key)) continue;\n    const value = record[key];\n    chars += key.length + 3;\n    chars += estimateStructuredValueChars(value, seen) + 1;\n  }\n\n  return Math.ceil(chars / 4);\n}\n\n/**\n * Read the configured token budget from SPECKIT_TOKEN_BUDGET env var,\n * falling back to DEFAULT_TOKEN_BUDGET (2000).\n * @returns The effective token budget for result truncation.\n */\nfunction getTokenBudget(): number {\n  const envVal = process.env['SPECKIT_TOKEN_BUDGET'];\n  if (envVal) {\n    const parsed = parseInt(envVal, 10);\n    if (!isNaN(parsed) && parsed > 0) return parsed;\n  }\n  return DEFAULT_TOKEN_BUDGET;\n}\n\n/**\n * Create a summary fallback for a single result whose content exceeds the token budget.\n */\nfunction createSummaryFallback(result: HybridSearchResult, budget: number): HybridSearchResult {\n  const content = typeof result['content'] === 'string' ? result['content'] as string : '';\n  const title = typeof result['title'] === 'string' ? result['title'] : 'Untitled';\n\n  const maxSummaryChars = Math.min(SUMMARY_MAX_CHARS, budget * 4);\n  const truncatedContent = content.length > maxSummaryChars\n    ? content.slice(0, maxSummaryChars) + '...'\n    : content;\n\n  return {\n    ...result,\n    content: `[Summary] ${title}: ${truncatedContent}`,\n    _summarized: true,\n  };\n}\n\n/**\n * Truncate a result set to fit within a token budget.\n *\n * Results are sorted highest-score-first. On overflow the accumulator\n * skips a too-large result and keeps scanning, so a single large top memory\n * never starves smaller lower-ranked results that still fit. The detailed\n * count is floored at min(limit, DEFAULT_MIN_RESULTS): when fewer full results\n * fit, the highest-scoring overflow remainder is promoted as token-cheap\n * summaries so a populated search never collapses to a near-empty payload.\n * Whatever remains after the floor is routed through progressive disclosure\n * (summary + first page + cursor) rather than discarded.\n *\n * @param results - The full result set to truncate.\n * @param budget - Optional token budget override (defaults to SPECKIT_TOKEN_BUDGET env / 2000).\n * @param options - Optional includeContent flag, queryId for overflow logging,\n *   result limit (for the detailed-count floor), and query text (for cursors).\n * @returns Object with truncated results, truncation flag, optional overflow log\n *   entry, and an optional progressive-disclosure envelope for the remainder.\n */\nfunction truncateToBudget(\n  results: HybridSearchResult[],\n  budget?: number,\n  options?: { includeContent?: boolean; queryId?: string; limit?: number; query?: string }\n): TruncateToBudgetResult {\n  const effectiveBudget = (budget && budget > 0) ? budget : getTokenBudget();\n  const includeContent = options?.includeContent ?? false;\n  const queryId = options?.queryId ?? `q-${Date.now()}`;\n  const query = options?.query ?? '';\n\n  if (results.length === 0) {\n    return { results: [], truncated: false };\n  }\n\n  const sorted = [...results].sort((a, b) => b.score - a.score);\n  const tokenEstimateCache = new Map<string, number>();\n  const getTokenEstimate = (result: HybridSearchResult): number => {\n    const cacheKey = canonicalResultId(result.id);\n    const cached = tokenEstimateCache.get(cacheKey);\n    if (cached !== undefined) {\n      return cached;\n    }\n\n    const estimate = estimateResultTokens(result);\n    tokenEstimateCache.set(cacheKey, estimate);\n    return estimate;\n  };\n\n  const totalTokens = sorted.reduce((sum, result) => sum + getTokenEstimate(result), 0);\n\n  if (totalTokens <= effectiveBudget) {\n    return { results: sorted, truncated: false };\n  }\n\n  // Single-result overflow: summarize when content is included, otherwise keep\n  // the lone result and mark the overflow for callers.\n  if (sorted.length === 1) {\n    const outputResult = includeContent\n      ? createSummaryFallback(sorted[0]!, effectiveBudget)\n      : sorted[0]!;\n    const overflow: OverflowLogEntry = {\n      queryId,\n      candidateCount: 1,\n      totalTokens,","lineStart":1446,"lineEnd":2826,"totalLines":2827,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781722677566,"end":1781722677575}},"id":"prt_ed6f27f64001MW67WIdFQ2Lji9","sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","messageID":"msg_ed6f274680011R1yHLvfLJShf6"}}
