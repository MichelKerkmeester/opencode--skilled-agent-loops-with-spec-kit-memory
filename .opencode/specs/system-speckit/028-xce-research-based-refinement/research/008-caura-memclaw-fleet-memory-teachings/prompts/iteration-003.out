{"type":"tool_use","timestamp":1780727782340,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_9CHyfLj4FdNv0Hslxt1sCote","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py","offset":250,"limit":125},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py</path>\n<type>file</type>\n<content>\n250:         \"\"\"\n251:         if self.capabilities is None:\n252:             return\n253:         if \"write\" not in self.capabilities:\n254:             raise HTTPException(\n255:                 status_code=403,\n256:                 detail=\"This API key is read-only and cannot perform write operations.\",\n257:             )\n258: \n259: \n260: def _parse_csv_header(value: str | None) -> list[str]:\n261:     \"\"\"Parse a comma-separated header value into a stripped, non-empty list.\"\"\"\n262:     if not value:\n263:         return []\n264:     return [item.strip() for item in value.split(\",\") if item.strip()]\n265: \n266: \n267: async def _block_if_suppressed(tenant_id: str | None) -> None:\n268:     \"\"\"Raise 403 if the tenant's enterprise org has been soft-deleted.\n269: \n270:     CAURA-694 boundary guard. The check is cached (30 s TTL, see\n271:     :mod:`core_api.suppression`) so the hot-path cost is one dict lookup\n272:     per request. Admin and tenant-less paths are skipped by the\n273:     ``tenant_id`` guard.\n274: \n275:     The 403 message is intentionally generic — surfacing\n276:     \"soft-deleted\" to the caller risks leaking org lifecycle state to\n277:     a partner whose key was provisioned under that org. \"Suspended\"\n278:     is the user-visible posture the dashboard already shows.\n279:     \"\"\"\n280:     if not tenant_id:\n281:         return\n282:     if await is_tenant_suppressed(tenant_id):\n283:         raise HTTPException(\n284:             status_code=403,\n285:             detail=\"Organization is suspended; access denied.\",\n286:         )\n287: \n288: \n289: async def _block_if_any_readable_suppressed(tenant_id: str | None, readable_tenants: list[str]) -> None:\n290:     \"\"\"Apply :func:`_block_if_suppressed` to every cross-tenant read in\n291:     ``readable_tenants``, skipping the home ``tenant_id`` (which the\n292:     caller already checked).\n293: \n294:     Bot review round 2 on PR #244 (🟢 Low): a multi-tenant credential\n295:     whose readable set spans a suppressed org would otherwise pass the\n296:     home-only guard. The enterprise ingress should already exclude\n297:     suppressed tenants from this list, but defence-in-depth at the OSS\n298:     boundary means we don't rely on that. The cache makes each extra\n299:     check one dict lookup per tenant per 30 s.\n300:     \"\"\"\n301:     for rt in readable_tenants:\n302:         if rt and rt != tenant_id:\n303:             await _block_if_suppressed(rt)\n304: \n305: \n306: async def get_auth_context(\n307:     request: Request,\n308:     key: str | None = Security(api_key_header),\n309: ) -> AuthContext:\n310:     admin_key = get_admin_key()\n311:     # Enterprise gateway injects X-Agent-ID when the caller's credential\n312:     # is agent-scoped (kind=agent_key).\n313:     agent_id = request.headers.get(\"x-agent-id\") or None\n314:     # Enterprise gateway injects X-Org-Read-Only: true when the org has\n315:     # exceeded plan limits after a subscription cancellation. In standalone\n316:     # and OSS-direct paths the header is absent, so enforcement is a no-op.\n317:     is_read_only = request.headers.get(\"x-org-read-only\", \"\").lower() == \"true\"\n318:     # Multi-tenant read support: the gateway plumbs the set of tenants this\n319:     # caller may read from. Absent header → single-tenant key (defaults to\n320:     # [tenant_id] inside AuthContext). Present → AuthContext.readable_tenant_ids\n321:     # widens to the union, while writes still target tenant_id.\n322:     readable_tenants = _parse_csv_header(request.headers.get(\"x-readable-tenant-ids\"))\n323:     # Capabilities plumbed alongside readable tenants. Empty/absent →\n324:     # None (full scope, legacy behavior). X-Capabilities is the\n325:     # canonical header from the unified auth-api; X-Key-Scopes is\n326:     # accepted as a back-compat alias during the gateway rollout\n327:     # window so an old gateway running against a new core-api (or\n328:     # vice versa) doesn't break auth.\n329:     capability_list = _parse_csv_header(\n330:         request.headers.get(\"x-capabilities\") or request.headers.get(\"x-key-scopes\")\n331:     )\n332:     capabilities: set[str] | None = set(capability_list) if capability_list else None\n333: \n334:     # ── Path 1: Admin API key ──\n335:     if key and admin_key and hmac.compare_digest(key, admin_key):\n336:         set_current_tenant(None)  # Admin — RLS bypass\n337:         return AuthContext(tenant_id=None, is_admin=True)\n338: \n339:     # ── Path 2: MEMCLAW_API_KEY gate (optional, for network-exposed OSS) ──\n340:     mclaw_key = settings.memclaw_api_key\n341:     if mclaw_key:\n342:         if key and hmac.compare_digest(key, mclaw_key):\n343:             # Valid memclaw key — resolve tenant from standalone or header\n344:             if settings.is_standalone:\n345:                 from core_api.standalone import get_standalone_tenant_id\n346: \n347:                 tenant_id = get_standalone_tenant_id()\n348:                 await _block_if_suppressed(tenant_id)\n349:                 set_current_tenant(tenant_id)\n350:                 return AuthContext(tenant_id=tenant_id, org_role=\"admin\", agent_id=agent_id)\n351:             tenant_id = request.headers.get(\"x-tenant-id\")\n352:             if tenant_id:\n353:                 await _block_if_suppressed(tenant_id)\n354:                 # ``readable_tenants`` is typically not set on this\n355:                 # branch today, but apply the cross-tenant guard for\n356:                 # symmetry with Path 4 so a future widening of this\n357:                 # path picks up the protection automatically. Bot\n358:                 # review round 2 on PR #244.\n359:                 await _block_if_any_readable_suppressed(tenant_id, readable_tenants)\n360:                 set_current_tenant(tenant_id)\n361:                 return AuthContext(\n362:                     tenant_id=tenant_id,\n363:                     agent_id=agent_id,\n364:                     is_read_only=is_read_only,\n365:                 )\n366:             set_current_tenant(None)\n367:             return AuthContext(tenant_id=None, agent_id=agent_id)\n368:         # Key configured but not provided or wrong — reject\n369:         if not key:\n370:             raise HTTPException(\n371:                 status_code=401,\n372:                 detail=\"Missing API key. Include X-API-Key header.\",\n373:             )\n374:         raise HTTPException(status_code=401, detail=\"Invalid API key.\")\n\n(Showing lines 250-374 of 443. Use offset=375 to continue.)\n</content>","metadata":{"preview":"        \"\"\"\n        if self.capabilities is None:\n            return\n        if \"write\" not in self.capabilities:\n            raise HTTPException(\n                status_code=403,\n                detail=\"This API key is read-only and cannot perform write operations.\",\n            )\n\n\ndef _parse_csv_header(value: str | None) -> list[str]:\n    \"\"\"Parse a comma-separated header value into a stripped, non-empty list.\"\"\"\n    if not value:\n        return []\n    return [item.strip() for item in value.split(\",\") if item.strip()]\n\n\nasync def _block_if_suppressed(tenant_id: str | None) -> None:\n    \"\"\"Raise 403 if the tenant's enterprise org has been soft-deleted.\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py","text":"        \"\"\"\n        if self.capabilities is None:\n            return\n        if \"write\" not in self.capabilities:\n            raise HTTPException(\n                status_code=403,\n                detail=\"This API key is read-only and cannot perform write operations.\",\n            )\n\n\ndef _parse_csv_header(value: str | None) -> list[str]:\n    \"\"\"Parse a comma-separated header value into a stripped, non-empty list.\"\"\"\n    if not value:\n        return []\n    return [item.strip() for item in value.split(\",\") if item.strip()]\n\n\nasync def _block_if_suppressed(tenant_id: str | None) -> None:\n    \"\"\"Raise 403 if the tenant's enterprise org has been soft-deleted.\n\n    CAURA-694 boundary guard. The check is cached (30 s TTL, see\n    :mod:`core_api.suppression`) so the hot-path cost is one dict lookup\n    per request. Admin and tenant-less paths are skipped by the\n    ``tenant_id`` guard.\n\n    The 403 message is intentionally generic — surfacing\n    \"soft-deleted\" to the caller risks leaking org lifecycle state to\n    a partner whose key was provisioned under that org. \"Suspended\"\n    is the user-visible posture the dashboard already shows.\n    \"\"\"\n    if not tenant_id:\n        return\n    if await is_tenant_suppressed(tenant_id):\n        raise HTTPException(\n            status_code=403,\n            detail=\"Organization is suspended; access denied.\",\n        )\n\n\nasync def _block_if_any_readable_suppressed(tenant_id: str | None, readable_tenants: list[str]) -> None:\n    \"\"\"Apply :func:`_block_if_suppressed` to every cross-tenant read in\n    ``readable_tenants``, skipping the home ``tenant_id`` (which the\n    caller already checked).\n\n    Bot review round 2 on PR #244 (🟢 Low): a multi-tenant credential\n    whose readable set spans a suppressed org would otherwise pass the\n    home-only guard. The enterprise ingress should already exclude\n    suppressed tenants from this list, but defence-in-depth at the OSS\n    boundary means we don't rely on that. The cache makes each extra\n    check one dict lookup per tenant per 30 s.\n    \"\"\"\n    for rt in readable_tenants:\n        if rt and rt != tenant_id:\n            await _block_if_suppressed(rt)\n\n\nasync def get_auth_context(\n    request: Request,\n    key: str | None = Security(api_key_header),\n) -> AuthContext:\n    admin_key = get_admin_key()\n    # Enterprise gateway injects X-Agent-ID when the caller's credential\n    # is agent-scoped (kind=agent_key).\n    agent_id = request.headers.get(\"x-agent-id\") or None\n    # Enterprise gateway injects X-Org-Read-Only: true when the org has\n    # exceeded plan limits after a subscription cancellation. In standalone\n    # and OSS-direct paths the header is absent, so enforcement is a no-op.\n    is_read_only = request.headers.get(\"x-org-read-only\", \"\").lower() == \"true\"\n    # Multi-tenant read support: the gateway plumbs the set of tenants this\n    # caller may read from. Absent header → single-tenant key (defaults to\n    # [tenant_id] inside AuthContext). Present → AuthContext.readable_tenant_ids\n    # widens to the union, while writes still target tenant_id.\n    readable_tenants = _parse_csv_header(request.headers.get(\"x-readable-tenant-ids\"))\n    # Capabilities plumbed alongside readable tenants. Empty/absent →\n    # None (full scope, legacy behavior). X-Capabilities is the\n    # canonical header from the unified auth-api; X-Key-Scopes is\n    # accepted as a back-compat alias during the gateway rollout\n    # window so an old gateway running against a new core-api (or\n    # vice versa) doesn't break auth.\n    capability_list = _parse_csv_header(\n        request.headers.get(\"x-capabilities\") or request.headers.get(\"x-key-scopes\")\n    )\n    capabilities: set[str] | None = set(capability_list) if capability_list else None\n\n    # ── Path 1: Admin API key ──\n    if key and admin_key and hmac.compare_digest(key, admin_key):\n        set_current_tenant(None)  # Admin — RLS bypass\n        return AuthContext(tenant_id=None, is_admin=True)\n\n    # ── Path 2: MEMCLAW_API_KEY gate (optional, for network-exposed OSS) ──\n    mclaw_key = settings.memclaw_api_key\n    if mclaw_key:\n        if key and hmac.compare_digest(key, mclaw_key):\n            # Valid memclaw key — resolve tenant from standalone or header\n            if settings.is_standalone:\n                from core_api.standalone import get_standalone_tenant_id\n\n                tenant_id = get_standalone_tenant_id()\n                await _block_if_suppressed(tenant_id)\n                set_current_tenant(tenant_id)\n                return AuthContext(tenant_id=tenant_id, org_role=\"admin\", agent_id=agent_id)\n            tenant_id = request.headers.get(\"x-tenant-id\")\n            if tenant_id:\n                await _block_if_suppressed(tenant_id)\n                # ``readable_tenants`` is typically not set on this\n                # branch today, but apply the cross-tenant guard for\n                # symmetry with Path 4 so a future widening of this\n                # path picks up the protection automatically. Bot\n                # review round 2 on PR #244.\n                await _block_if_any_readable_suppressed(tenant_id, readable_tenants)\n                set_current_tenant(tenant_id)\n                return AuthContext(\n                    tenant_id=tenant_id,\n                    agent_id=agent_id,\n                    is_read_only=is_read_only,\n                )\n            set_current_tenant(None)\n            return AuthContext(tenant_id=None, agent_id=agent_id)\n        # Key configured but not provided or wrong — reject\n        if not key:\n            raise HTTPException(\n                status_code=401,\n                detail=\"Missing API key. Include X-API-Key header.\",\n            )\n        raise HTTPException(status_code=401, detail=\"Invalid API key.\")","lineStart":250,"lineEnd":374,"totalLines":443,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py","time":{"start":1780727782323,"end":1780727782337}},"metadata":{"openai":{"itemId":"fc_0b9353a5ef6f4ac0016a23bfe4979081919df60af3f58cae7f"}},"id":"prt_e9ba5953a001Xils4OdL31LXIT","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba5888900130GfV4fg8gayTb"}}
{"type":"step_finish","timestamp":1780727782651,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"id":"prt_e9ba59cf9001vaNW2CUBaWcjxv","reason":"tool-calls","snapshot":"d9387bd5663e94b79c66c2c3d76ec17fc0e0e2cb","messageID":"msg_e9ba5888900130GfV4fg8gayTb","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","type":"step-finish","tokens":{"total":117799,"input":1499,"output":76,"reasoning":0,"cache":{"write":0,"read":116224}},"cost":0}}
