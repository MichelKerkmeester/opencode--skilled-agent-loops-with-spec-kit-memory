{"type":"tool_use","timestamp":1780205049034,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_1by3k66nl8t2_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/_args.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/_args.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: /**\n4:  * Shared space-form arg parser for Lane C scripts. Lane C is invoked by\n5:  * loop-host with space-separated flags (--skill <v> --outputs-dir <v> ...),\n6:  * matching the Lane B run surface. Bare flags with no following value (or a\n7:  * following --flag) become boolean true.\n8:  */\n9: function parse(argv) {\n10:   const args = {};\n11:   for (let i = 0; i < argv.length; i += 1) {\n12:     const entry = argv[i];\n13:     const eq = /^--([a-z][a-z0-9-]*)=(.*)$/.exec(entry);\n14:     if (eq) { args[eq[1]] = eq[2]; continue; }\n15:     const bare = /^--([a-z][a-z0-9-]*)$/.exec(entry);\n16:     if (!bare) continue;\n17:     const next = argv[i + 1];\n18:     if (next !== undefined && !next.startsWith('--')) { args[bare[1]] = next; i += 1; }\n19:     else args[bare[1]] = true;\n20:   }\n21:   return args;\n22: }\n23: \n24: module.exports = { parse };\n\n(End of file - total 24 lines)\n</content>","metadata":{"preview":"'use strict';\n\n/**\n * Shared space-form arg parser for Lane C scripts. Lane C is invoked by\n * loop-host with space-separated flags (--skill <v> --outputs-dir <v> ...),\n * matching the Lane B run surface. Bare flags with no following value (or a\n * following --flag) become boolean true.\n */\nfunction parse(argv) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const entry = argv[i];\n    const eq = /^--([a-z][a-z0-9-]*)=(.*)$/.exec(entry);\n    if (eq) { args[eq[1]] = eq[2]; continue; }\n    const bare = /^--([a-z][a-z0-9-]*)$/.exec(entry);\n    if (!bare) continue;\n    const next = argv[i + 1];\n    if (next !== undefined && !next.startsWith('--')) { args[bare[1]] = next; i += 1; }\n    else args[bare[1]] = true;\n  }","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/_args.cjs","time":{"start":1780205049015,"end":1780205049033}},"id":"prt_e7c7d523c001O7pcp46US3xIs5","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7d409c001J6sIJub63sP2O5"}}
{"type":"tool_use","timestamp":1780205049095,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_1by3k66nl8t2_2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/build-report.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/build-report.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * build-report.cjs — render report.md FROM report.json (anti-drift).\n6:  *\n7:  * The converged design requires a dual artifact: a machine report.json and a\n8:  * human report.md, with the markdown rendered from the JSON so they cannot drift.\n9:  * There is no pre-existing Lane B renderer to reuse (Lane B emits JSON only), so\n10:  * this renderer is Lane-C-specific. It is the ONLY writer of report.md — it\n11:  * accepts no score arguments, only the report object.\n12:  */\n13: \n14: const fs = require('fs');\n15: \n16: function dimLine(name, d) {\n17:   if (!d) return `| ${name} | — | — |`;\n18:   const score = d.score == null ? `_${d.status || 'unscored'}_` : `${d.score}/100`;\n19:   const gate = d.hardGate ? ' (hard gate)' : '';\n20:   return `| ${name}${gate} | ${d.points}pts | ${score} |`;\n21: }\n22: \n23: function renderReport(report) {\n24:   const r = report;\n25:   const lines = [];\n26:   lines.push(`# Skill Benchmark Report — ${r.targetSkill ? r.targetSkill.id : 'unknown'}`);\n27:   lines.push('');\n28:   lines.push(`> Rendered from report.json (do not hand-edit). Scoring: \\`${r.scoringMethod}\\` · trace mode: \\`${r.traceMode}\\`.`);\n29:   lines.push('');\n30:   lines.push(`**Verdict: ${r.verdict}**${r.aggregateScore != null ? ` · aggregate ${r.aggregateScore}/100` : ''}`);\n31:   if (r.gate && r.gate.gateFailed) lines.push(`\\n⚠ **${r.gate.reason}** — verdict capped regardless of weighted score.`);\n32:   lines.push('');\n33: \n34:   lines.push('## Dimension scores');\n35:   lines.push('');\n36:   lines.push('| Dimension | Weight | Score |');\n37:   lines.push('| --------- | ------ | ----- |');\n38:   const d = r.dimensionScores || {};\n39:   lines.push(dimLine('D1 inter (advisor)', d.D1inter));\n40:   lines.push(dimLine('D1 intra (router)', d.D1intra));\n41:   lines.push(dimLine('D2 discovery', d.D2));\n42:   lines.push(dimLine('D3 efficiency', d.D3));\n43:   lines.push(dimLine('D4 usefulness', d.D4));\n44:   lines.push(dimLine('D5 connectivity', d.D5));\n45:   if (r.unscoredDimensions && r.unscoredDimensions.length) {\n46:     lines.push('');\n47:     lines.push(`_Unscored in this run (need live mode): ${r.unscoredDimensions.join(', ')}._`);\n48:   }\n49:   lines.push('');\n50: \n51:   lines.push('## Funnel');\n52:   lines.push('');\n53:   for (const [stage, count] of Object.entries(r.funnel || {})) {\n54:     lines.push(`- ${stage}: ${count}`);\n55:   }\n56:   if (r.headlineBottleneck) lines.push(`\\n**Headline bottleneck: ${r.headlineBottleneck}**`);\n57:   lines.push('');\n58: \n59:   lines.push('## Ranked bottlenecks');\n60:   lines.push('');\n61:   const bn = r.bottlenecks || [];\n62:   if (!bn.length) lines.push('_None._');\n63:   else {\n64:     lines.push('| Severity | Class | Locus | Finding |');\n65:     lines.push('| -------- | ----- | ----- | ------- |');\n66:     for (const b of bn) {\n67:       lines.push(`| ${b.severity || '—'} | ${b.class || '—'} | ${b.locus || b.stage || '—'} | ${(b.detail || '').replace(/\\|/g, '\\\\|')} |`);\n68:     }\n69:   }\n70:   lines.push('');\n71: \n72:   lines.push('## Scenarios');\n73:   lines.push('');\n74:   const rows = r.scenarioRows || [];\n75:   if (!rows.length) lines.push('_No scenarios._');\n76:   else {\n77:     lines.push('| Scenario | Tier | Mode A score | First failing stage |');\n78:     lines.push('| -------- | ---- | ------------ | ------------------- |');\n79:     for (const s of rows) {\n80:       lines.push(`| ${s.scenarioId} | ${s.tier || '—'} | ${s.modeAScore}/100 | ${s.firstFailingStage || 'passed'} |`);\n81:     }\n82:   }\n83:   lines.push('');\n84:   lines.push('## Methodology / caveats');\n85:   lines.push('');\n86:   lines.push(`- ${r.runQuality ? r.runQuality.note : 'Mode A deterministic router-replay.'}`);\n87:   lines.push(`- Scenario count: ${r.runQuality ? r.runQuality.scenarioCount : (rows.length)}.`);\n88:   lines.push('');\n89:   return lines.join('\\n');\n90: }\n91: \n92: module.exports = { renderReport };\n93: \n94: if (require.main === module) {\n95:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n96:   if (!args.report) {\n97:     process.stderr.write('usage: build-report.cjs --report <report.json> [--output <report.md>]\\n');\n98:     process.exit(2);\n99:   }\n100:   const report = JSON.parse(fs.readFileSync(args.report, 'utf8'));\n101:   const md = renderReport(report);\n102:   if (args.output) { fs.writeFileSync(args.output, md); process.stdout.write(`wrote ${args.output}\\n`); }\n103:   else process.stdout.write(md + '\\n');\n104:   process.exit(0);\n105: }\n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * build-report.cjs — render report.md FROM report.json (anti-drift).\n *\n * The converged design requires a dual artifact: a machine report.json and a\n * human report.md, with the markdown rendered from the JSON so they cannot drift.\n * There is no pre-existing Lane B renderer to reuse (Lane B emits JSON only), so\n * this renderer is Lane-C-specific. It is the ONLY writer of report.md — it\n * accepts no score arguments, only the report object.\n */\n\nconst fs = require('fs');\n\nfunction dimLine(name, d) {\n  if (!d) return `| ${name} | — | — |`;\n  const score = d.score == null ? `_${d.status || 'unscored'}_` : `${d.score}/100`;\n  const gate = d.hardGate ? ' (hard gate)' : '';\n  return `| ${name}${gate} | ${d.points}pts | ${score} |`;","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/build-report.cjs","time":{"start":1780205049079,"end":1780205049093}},"id":"prt_e7c7d54bd001S2oEjIDWSYMDqT","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7d409c001J6sIJub63sP2O5"}}
{"type":"step_finish","timestamp":1780205049337,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"id":"prt_e7c7d55f7001eGGkmVe4vR41DI","reason":"tool-calls","snapshot":"cd438c859c6e14a537bb7f1437f2c3f14fbf6dab","messageID":"msg_e7c7d409c001J6sIJub63sP2O5","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","type":"step-finish","tokens":{"total":43875,"input":6183,"output":146,"reasoning":0,"cache":{"write":4379,"read":33167}},"cost":0.007692345}}
{"type":"step_start","timestamp":1780205051938,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"id":"prt_e7c7d6021001sJh3ahE5UtPDB4","messageID":"msg_e7c7d56df001ymVMwvqeQDRJE6","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","snapshot":"d8ba904c1be91a9532f7232ada8357907db94d23","type":"step-start"}}
{"type":"tool_use","timestamp":1780205053545,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_dlk37tp15eh3_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/SKILL.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/SKILL.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: deep-improvement\n3: description: \"Evaluator-first bounded agent improvement: 5-dim scoring, dynamic profiling, packet-local candidates, guarded promotion.\"\n4: allowed-tools: [Read, Write, Edit, Bash, Glob, Grep]\n5: version: 1.9.0.0\n6: triggers:\n7:   - deep-improvement\n8:   - agent improvement loop\n9:   - bounded agent improvement\n10:   - 5-dimension scoring\n11:   - integration scanner\n12:   - dynamic profiling\n13:   - model-benchmark mode\n14:   - benchmark a model or prompt framework\n15: ---\n16: \n17: <!-- Keywords: deep-improvement, deep-improvement, agent-improvement, benchmark-harness, score-candidate, promote-candidate, rollback-candidate -->\n18: \n19: # Recursive Agent: Evaluator-First Improvement Orchestrator\n20: \n21: Evaluator-first workflow for testing whether a bounded agent surface can be improved without immediately mutating the source of truth. It combines packet-local candidates, deterministic scoring, repeatable benchmarks, and explicit promotion or rollback gates.\n22: \n23: ---\n24: \n25: ## 1. WHEN TO USE\n26: \n27: ### Three Co-Equal Lanes\n28: \n29: This skill supports three co-equal use-case lanes that share the same candidate, dispatcher, and scorer seams:\n30: \n31: | Lane | Pick when | Command |\n32: | --- | --- | --- |\n33: | **Lane A: Agent-Improvement** | You want to improve a bounded agent `.md` file | `/deep:start-agent-improvement-loop` |\n34: | **Lane B: Model-Benchmark** | You want to benchmark a model or prompt framework | `/deep:start-model-benchmark-loop` |\n35: | **Lane C: Skill-Benchmark** | You want to diagnose a skill's real-world routing, discovery, efficiency, and usefulness | `/deep:start-skill-benchmark-loop` |\n36: \n37: Lane A is detailed in §3 (Runtime Initialization, Proposal and Evaluation, Promotion and Recovery). Lane B is detailed in §4. Lane C (skill-benchmark) is documented in `references/skill-benchmark/` (operator guide, scoring contract, scenario authoring) and run via `loop-host.cjs --mode=skill-benchmark`. All three lanes run the same loop shape and keep the agent-improvement path byte-identical when no mode flag is set.\n38: \n39: ### Activation Triggers\n40: \n41: Use this skill when:\n42: - You want to test whether an agent prompt or instruction surface can be improved (Lane A)\n43: - You want to benchmark a model or prompt framework against repeatable fixtures (Lane B)\n44: - You want to diagnose whether a skill is well-routed, discoverable, efficient, and useful in practice (Lane C)\n45: - The mutation boundary is explicit and narrow\n46: - You need packet-local evidence instead of ad hoc prompt tweaking\n47: - You need target-specific benchmark or scoring rules before any canonical mutation\n48: - Promotion must stay gated behind independent evidence plus operator approval\n49: \n50: ### Primary Use Cases\n51: \n52: #### Bounded Agent Improvement\n53: \n54: Use this skill to set up a proposal-first loop for any bounded agent file, write packet-local candidates, and record append-only evidence.\n55: \n56: #### Benchmark-Backed Evaluation\n57: \n58: Use this skill when candidate quality must be judged by produced artifacts and repeatability reports, not just by how a prompt file reads in isolation.\n59: \n60: #### Promotion and Rollback Verification\n61: \n62: Use this skill when you need to prove that guarded promotion, validation, rollback, and post-rollback comparison all work end to end without leaving hidden drift behind.\n63: \n64: #### Model and Prompt Benchmarking\n65: \n66: Use Lane B (model-benchmark) when the thing under test is a model or prompt framework rather than an agent definition. It runs the same loop shape against a benchmark profile and scores produced outputs, sharing the candidate, dispatcher, and scorer seams with the agent-improvement path. See §4 below.\n67: \n68: #### Skill Benchmarking\n69: \n70: Use Lane C (skill-benchmark) when the thing under test is a *skill* — to measure whether AIs actually get routed to it, discover its references/assets unprompted, use it efficiently, and benefit from it. It emits a ranked, remediable Skill Benchmark Report and is diagnostic by default (it does not mutate the target skill). See `references/skill-benchmark/operator_guide.md`.\n71: \n72: ### When NOT to Use\n73: \n74: Do not use this skill for:\n75: - Open-ended prompt rewrites across multiple agent families at once\n76: - Direct canonical edits without a packet-local candidate and evaluator evidence\n77: - Broad runtime-mirror synchronization work presented as benchmark truth\n78: - General packet planning that belongs in `/speckit:plan` or implementation that does not need an improvement loop\n79: \n80: ---\n81: \n82: ## 2. SMART ROUTING\n83: \n84: \n85: ### Resource Domains\n86: \n87: The router discovers markdown resources recursively from `references/` and `assets/`, then applies intent scoring so only the guidance that matches the current task is loaded.\n88: \n89: - `references/` for operator workflows, evaluator policy, promotion or rollback rules, target onboarding, and quick-reference guidance\n90: - `assets/` for reusable runtime templates such as the charter and strategy markdown files\n91: - `scripts/` for deterministic benchmark, scoring, reduction, promotion, rollback, and drift-check helpers\n92: \n93: **Lane awareness**: resources are organized by lane. `references/agent-improvement/` + `assets/agent-improvement/` carry Lane A guidance, `references/model-benchmark/` + `assets/model-benchmark/` carry Lane B guidance, and `references/skill-benchmark/` + `assets/skill-benchmark/` carry Lane C guidance. `RESOURCE_MAP` routes the `MODEL_BENCHMARK` and `SKILL_BENCHMARK` intents to their lane references, and `RUNTIME_ASSETS` loads each lane's profile only when its intent is selected. The `ALWAYS` and shared `references/shared/` resources apply to all three lanes.\n94: \n95: ### Resource Loading Levels\n96: \n97: | Level | When to Load | Resources |\n98: | --- | --- | --- |\n99: | ALWAYS | Every skill invocation | `references/shared/quick_reference.md` |\n100: | CONDITIONAL | If intent signals match | Workflow, policy, or onboarding references |\n101: | ON_DEMAND | Only on explicit request or full setup | Markdown runtime templates in `assets/` |\n102: \n103: ### Smart Router Pseudocode\n104: \n105: The authoritative routing logic for scoped markdown loading and explicit runtime-asset loading.\n106: \n107: - Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans `references/` and `assets/`.\n108: - Pattern 2: Existence-Check Before Load - `load_if_available()` uses `_guard_in_skill()`, `inventory`, and `seen`.\n109: - Pattern 3: Extensible Routing Key - quick-reference, loop, evaluation, promotion, target onboarding, integration, and setup intents route resources.\n110: - Pattern 4: Multi-Tier Graceful Fallback - `UNKNOWN_FALLBACK_CHECKLIST` asks for target/action/gate disambiguation and missing intent routes return a \"no knowledge base\" notice.\n111: \n112: ```python\n113: from pathlib import Path\n114: \n115: SKILL_ROOT = Path(__file__).resolve().parent\n116: RESOURCE_BASES = (SKILL_ROOT / \"references\", SKILL_ROOT / \"assets\")\n117: DEFAULT_RESOURCE = \"references/shared/quick_reference.md\"\n118: \n119: INTENT_SIGNALS = {\n120:     \"QUICK_REFERENCE\": {\"weight\": 3, \"keywords\": [\"quick reference\", \"short reminder\", \"command example\"]},\n121:     \"LOOP_EXECUTION\": {\"weight\": 4, \"keywords\": [\"run loop\", \"proposal\", \"candidate\", \"score candidate\", \"benchmark\"]},\n122:     \"EVALUATION_POLICY\": {\"weight\": 4, \"keywords\": [\"evaluator\", \"rubric\", \"contract\", \"repeatability\", \"no-go\"]},\n123:     \"PROMOTION_OPERATIONS\": {\"weight\": 4, \"keywords\": [\"promote\", \"rollback\", \"mirror drift\", \"approval gate\"]},\n124:     \"TARGET_ONBOARDING\": {\"weight\": 4, \"keywords\": [\"new target\", \"target profile\", \"onboarding\", \"second target\"]},\n125:     \"INTEGRATION_SCAN\": {\"weight\": 4, \"keywords\": [\"integration\", \"scan surfaces\", \"mirror sync\", \"dynamic profile\", \"5-dimension\"]},\n126:     \"MODEL_BENCHMARK\": {\"weight\": 5, \"keywords\": [\"benchmark a model\", \"benchmark a prompt framework\", \"optimize a model\", \"model-benchmark\", \"model benchmark\"]},\n127:     \"SKILL_BENCHMARK\": {\"weight\": 5, \"keywords\": [\"benchmark a skill\", \"skill benchmark\", \"skill routing\", \"unprompted discovery\", \"routing accuracy\", \"skill-benchmark\"]},\n128:     \"FULL_SETUP\": {\"weight\": 3, \"keywords\": [\"full setup\", \"initialize runtime\", \"charter\", \"strategy\"]},\n129: }\n130: \n131: RESOURCE_MAP = {\n132:     \"QUICK_REFERENCE\": [\"references/shared/quick_reference.md\"],\n133:     \"LOOP_EXECUTION\": [\"references/shared/loop_protocol.md\", \"references/model-benchmark/benchmark_operator_guide.md\"],\n134:     \"EVALUATION_POLICY\": [\"references/model-benchmark/evaluator_contract.md\", \"references/shared/promotion_rules.md\"],\n135:     \"PROMOTION_OPERATIONS\": [\"references/shared/rollback_runbook.md\", \"references/agent-improvement/mirror_drift_policy.md\", \"references/shared/promotion_rules.md\"],\n136:     \"TARGET_ONBOARDING\": [\"references/agent-improvement/target_onboarding.md\"],\n137:     \"INTEGRATION_SCAN\": [\"references/agent-improvement/integration_scanning.md\", \"references/model-benchmark/evaluator_contract.md\"],\n138:     \"MODEL_BENCHMARK\": [\"references/model-benchmark/benchmark_operator_guide.md\", \"references/model-benchmark/evaluator_contract.md\"],\n139:     \"SKILL_BENCHMARK\": [\"references/skill-benchmark/operator_guide.md\", \"references/skill-benchmark/scoring_contract.md\", \"references/skill-benchmark/scenario_authoring.md\"],\n140:     \"FULL_SETUP\": [\"assets/agent-improvement/improvement_charter.md\", \"assets/agent-improvement/improvement_strategy.md\"],\n141: }\n142: \n143: RUNTIME_ASSETS = {\n144:     \"ALWAYS\": [\"assets/agent-improvement/improvement_config.json\", \"assets/agent-improvement/target_manifest.jsonc\"],\n145:     \"MODEL_BENCHMARK\": [\"assets/model-benchmark/benchmark-profiles/default.json\"],\n146:     \"SKILL_BENCHMARK\": [\"assets/skill-benchmark/default_profile.json\"],\n147: }\n148: \n149: ON_DEMAND_KEYWORDS = [\"target profile\", \"score candidate\", \"proposal loop\", \"benchmark\", \"promotion gate\", \"mirror drift\"]\n150: \n151: def _task_text(task) -> str:\n152:     return \" \".join([\n153:         str(getattr(task, \"text\", \"\")),\n154:         str(getattr(task, \"query\", \"\")),\n155:         \" \".join(getattr(task, \"keywords\", []) or []),\n156:     ]).lower()\n157: \n158: UNKNOWN_FALLBACK_CHECKLIST = [\"Confirm target path\", \"Confirm proposal vs scoring vs promotion\", \"Confirm packet-local evidence path\"]\n159: \n160: def _guard_in_skill(relative_path: str) -> str:\n161:     resolved = (SKILL_ROOT / relative_path).resolve()\n162:     resolved.relative_to(SKILL_ROOT)\n163:     if resolved.suffix.lower() != \".md\":\n164:         raise ValueError(f\"Only markdown resources are routed here: {relative_path}\")\n165:     return resolved.relative_to(SKILL_ROOT).as_posix()\n166: \n167: def discover_markdown_resources() -> set[str]:\n168:     docs = []\n169:     for base in RESOURCE_BASES:\n170:         if base.exists():\n171:             docs.extend(p for p in base.rglob(\"*.md\") if p.is_file())\n172:     return {doc.relative_to(SKILL_ROOT).as_posix() for doc in docs}\n173: \n174: def score_intents(task) -> dict[str, float]:\n175:     text = _task_text(task)\n176:     scores = {intent: 0.0 for intent in INTENT_SIGNALS}\n177:     for intent, cfg in INTENT_SIGNALS.items():\n178:         for keyword in cfg[\"keywords\"]:\n179:             if keyword in text:\n180:                 scores[intent] += cfg[\"weight\"]\n181:     return scores\n182: \n183: def select_intents(scores: dict[str, float], ambiguity_delta: float = 1.0, max_intents: int = 2) -> list[str]:\n184:     ranked = sorted(scores.items(), key=lambda item: item[1], reverse=True)\n185:     if not ranked or ranked[0][1] <= 0:\n186:         return [\"QUICK_REFERENCE\"]\n187:     selected = [ranked[0][0]]\n188:     if len(ranked) > 1 and ranked[1][1] > 0 and (ranked[0][1] - ranked[1][1]) <= ambiguity_delta:\n189:         selected.append(ranked[1][0])\n190:     return selected[:max_intents]\n191: \n192: def route_recursive_agent_resources(task):\n193:     inventory = discover_markdown_resources()\n194:     intents = select_intents(score_intents(task))\n195:     loaded = []\n196:     seen = set()\n197: \n198:     def load_if_available(relative_path: str) -> None:\n199:         guarded = _guard_in_skill(relative_path)\n200:         if guarded in inventory and guarded not in seen:\n201:             load(guarded)\n202:             loaded.append(guarded)\n203:             seen.add(guarded)\n204: \n205:     load_if_available(DEFAULT_RESOURCE)\n206:     for intent in intents:\n207:         for relative_path in RESOURCE_MAP.get(intent, []):\n208:             load_if_available(relative_path)\n209: \n210:     text = _task_text(task)\n211:     if any(keyword in text for keyword in ON_DEMAND_KEYWORDS):\n212:         for paths in RESOURCE_MAP.values():\n213:             for relative_path in paths:\n214:                 load_if_available(relative_path)\n215: \n216:     runtime_assets = list(RUNTIME_ASSETS[\"ALWAYS\"])\n217:     if \"MODEL_BENCHMARK\" in intents:\n218:         runtime_assets.extend(RUNTIME_ASSETS.get(\"MODEL_BENCHMARK\", []))\n219: \n220:     if not loaded:\n221:         load_if_available(DEFAULT_RESOURCE)\n222:     return {\"intents\": intents, \"resources\": loaded, \"runtime_assets\": runtime_assets}\n223: ```\n224: \n225: ---\n226: \n227: ## 3. LANE A: AGENT-IMPROVEMENT\n228: \n229: Lane A improves a bounded agent `.md` file. Command: `/deep:start-agent-improvement-loop`. It runs the proposal-first loop in three modes (initialization, proposal and evaluation, promotion and recovery) and scores candidates with dynamic-mode 5-dimension scoring.\n230: \n231: ### Mode 1: Runtime Initialization\n232: \n233: 1. Confirm the spec folder, target path, execution mode, and active target profile.\n234: 2. Create `{spec_folder}/improvement/` plus the packet-local `candidates/`, `benchmark-runs/`, and `archive/` directories when needed.\n235: 3. Copy in the runtime config, charter, strategy, and boundary templates.\n236: 4. Record baseline state in the append-only ledger before the first candidate run.\n237: \n238: ### Mode 2: Proposal and Evaluation\n239: \n240: 1. Read the charter, boundary file, target profile, and canonical target surface.\n241: 2. Run `scripts/agent-improvement/scan-integration.cjs` to discover all surfaces the target agent touches.\n242: 3. Write exactly one bounded candidate under the packet-local `candidates/` directory.\n243: 4. Run `scripts/agent-improvement/score-candidate.cjs` to evaluate the candidate via dynamic-mode 5-dimension scoring (the sole supported path).\n244: 5. Run `scripts/model-benchmark/run-benchmark.cjs` to measure produced outputs against the active fixture set.\n245: 6. Append score and benchmark results to the packet-local ledger.\n246: 7. Run `scripts/shared/reduce-state.cjs` to refresh the dashboard and experiment registry.\n247: \n248: ### Mode 2A: Stress-Test Failure Paths Before Promotion Claims\n249: \n250: For changes that alter agent discipline, run at least one same-task A/B stress scenario before recommending promotion:\n251: \n252: 1. Call A: a generic improvement attempt against an isolated sandbox copy of the target.\n253: 2. Reset the sandbox to its baseline copy.\n254: 3. Call B: the disciplined `/deep:start-agent-improvement-loop` path against the identical prompt and files.\n255: 4. Judge only grep/file/diff/exit-code signals: helper invocation, packet-local candidate boundary, no canonical or mirror mutation before promotion, benchmark journal boundary, legal-stop gate keys, and stop-reason correctness.\n256: \n257: Do not treat `Read(SKILL.md)` or `skill(deep-improvement)` as evidence that this protocol executed.\n258: \n259: ### 5-Dimension Evaluation Framework\n260: \n261: Dynamic mode is the only scoring path. Scoring evaluates five dimensions:\n262: \n263: | Dimension | Weight | What It Measures |\n264: | --- | --- | --- |\n265: | Structural Integrity | 0.20 | Agent template compliance (required sections present) |\n266: | Rule Coherence | 0.25 | ALWAYS/NEVER rules align with workflow steps |\n267: | Integration Consistency | 0.25 | Mirrors in sync, commands reference agent, skills reference agent |\n268: | Output Quality | 0.15 | Output verification items present, no placeholder content |\n269: | System Fitness | 0.15 | Permission alignment, resource references valid, frontmatter complete |\n270: \n271: Profiles are generated on the fly from any agent file via `scripts/agent-improvement/generate-profile.cjs`. No static profiles are shipped. Every target is evaluated against its own derived structure and rules.\n272: \n273: ### Mode 3: Promotion and Recovery\n274: \n275: 1. Promote only when prompt scoring, benchmark status, repeatability, boundary, and approval gates all pass.\n276: 2. Use `scripts/shared/promote-candidate.cjs` for guarded canonical mutation.\n277: 3. Use `scripts/agent-improvement/rollback-candidate.cjs` plus direct comparison evidence when the canonical target must be restored.\n278: 4. Treat mirror drift as downstream packaging work and review it separately with `scripts/agent-improvement/check-mirror-drift.cjs`.\n279: \n280: ---\n281: \n282: ## 4. LANE B: MODEL-BENCHMARK\n283: \n284: Lane B benchmarks a model or prompt framework instead of mutating an agent file. Command: `/deep:start-model-benchmark-loop`. Runtime entry is `scripts/shared/loop-host.cjs --mode=model-benchmark`. It reuses the three pluggable seams (candidate-source, dispatcher, scorer) and keeps the default agent-improvement path byte-identical when no mode flag is set.\n285: \n286: 1. **Entry point**: `scripts/shared/loop-host.cjs` resolves the mode. `--mode=agent-improvement` (or no flag) routes to `scripts/agent-improvement/score-candidate.cjs`. `--mode=model-benchmark` runs `scripts/shared/materialize-benchmark-fixtures.cjs` then `scripts/model-benchmark/run-benchmark.cjs`. An unknown mode warns and falls back to agent-improvement.\n287: 2. **Dispatcher**: `scripts/model-benchmark/dispatch-model.cjs` is the model-agnostic dispatcher (executor-routing map across cli-opencode, cli-claude-code, cli-codex, cli-gemini, cli-devin). It is loaded only on the model-benchmark path, never in agent-improvement mode.\n288: 3. **Scorer selection**: `run-benchmark.cjs --scorer pattern` (default) uses the heading/pattern matcher. `--scorer 5dim` routes materialized outputs through `scripts/model-benchmark/scorer/score-model-variant.cjs`, the ported 120/003 five-dimension scorer (deterministic checks plus a pluggable grader). `--grader noop` (default) stays deterministic with no model dispatch. `--grader mock` or `--grader llm` select the stub or real grader.\n289: 4. **Mode-aware records and promotion path**: every state record carries `mode: agent-improvement` or `mode: model-benchmark`, and benchmark reports carry `scoringMethod: pattern|5dim`, so the reducer (`reduce-state.cjs`) and downstream consumers can attribute results per lane. Record-level mode metadata lives in the reducer, NOT in the promoter. Lane A promotes a scored candidate through the agent-scored gates in `promote-candidate.cjs`. Lane B promotes from the benchmark report: pass `promote-candidate.cjs --benchmark-report <report.json>`, and when the report status is `benchmark-complete` with a passing benchmark recommendation, the benchmark-report path drives promotion and bypasses the agent-scored-file requirement. The promoter is NOT otherwise lane-branching beyond this benchmark-report path, both lanes share the same single canonical-target guard, archive, and runtime-mirror sync.\n290: 5. **Hardening env gates**: set `DEEP_AGENT_ALLOW_CRITERIA_EXEC=0` to refuse criteria-driven shell execution in the 5-dim scorer. When the gate is off, BOTH criteria-exec paths are refused: the deterministic-criterion `execSync` in `score-model-variant.cjs` AND the bundle-gate Layer-3 acceptance-command `execSync` in `bundle-gate.cjs`. Set `DEEP_AGENT_GRADER_CACHE_RAW=0` to redact raw grader output from the on-disk cache. Both default to the permissive value for backward-compat. **Trusted-author default rationale (DOCUMENT-ACCEPT)**: criteria commands originate only from benchmark profiles authored by the operator running the loop, and the deterministic criterion runs in the same trust domain as the loop itself, so the default-on behavior is an intended trusted-author boundary rather than an untrusted-input risk. A shipped backward-compat test asserts the criterion runs by default, so flipping the default would be a behavior change with test impact, not a silent hardening. Hardened or shared-runner deployments set `DEEP_AGENT_ALLOW_CRITERIA_EXEC=0` to fail closed, and `DEEP_AGENT_GRADER_CACHE_RAW=0` to redact cached grader output.\n291: \n292: ---\n293: \n294: ## 5. SUCCESS CRITERIA\n295: \n296: - The loop stays proposal-first unless an explicit guarded promotion path is requested\n297: - Benchmark evidence, prompt scoring, and mirror-sync evidence remain separate\n298: - Reducer outputs make the best-known state, rejected runs, infrastructure failures, and stop conditions easy to review\n299: - Operators can onboard a bounded target without weakening boundary or evaluator guardrails\n300: \n301: ---\n302: \n303: ## 6. MULTI-ITER METHODOLOGY\n304: \n305: For multi-iter evaluation sweeps, a mixed-executor split plus an adjudication pass gives better breadth, better synthesis, and less noise than a single-executor run.\n306: \n307: - **Mixed-executor 8+2 split**: run breadth iterations on cli-devin SWE-1.6 and synthesis iterations on cli-codex gpt-5.5. For a 10-iter sweep, that is iters 1-8 breadth and iters 9-10 synthesis.\n308: - **Adjudication iter**: insert a false-positive filter pass before the synthesis iterations (typically the iter-7 mark) so only confirmed findings carry forward. In validation this delivers a 90%+ false-positive reduction, with one pass dropping 9 false-positive and 4 outdated items to take a 20-item queue down to 7.\n309: \n310: See `references/model-benchmark/mixed_executor_methodology.md` for the split mechanics, adjudication details, and the full validation evidence.\n311: \n312: ---\n313: \n314: ## 7. RUNTIME TRUTH CONTRACTS\n315: \n316: ### Stop-Reason Taxonomy\n317: \n318: Every improvement session termination MUST produce both a `stopReason` (why) and a `sessionOutcome` (what happened).\n319: \n320: **stopReason** (WHY the session ended):\n321: \n322: | Reason | Trigger Condition |\n323: | --- | --- |\n324: | `converged` | All legal-stop gate bundles pass and dimension trajectory is stable |\n325: | `maxIterationsReached` | Iteration counter equals `maxIterations` config |\n326: | `blockedStop` | One or more legal-stop gate bundles fail when convergence math would otherwise trigger stop |\n327: | `manualStop` | Operator cancels the session |\n328: | `error` | Infra failure, script crash, or unrecoverable condition |\n329: | `stuckRecovery` | Session detected stuck state and exhausted recovery options |\n330: \n331: **sessionOutcome** (WHAT happened to the candidate):\n332: \n333: | Outcome | When Used |\n334: | --- | --- |\n335: | `keptBaseline` | Baseline was retained because candidate did not improve |\n336: | `promoted` | Candidate was promoted to canonical target |\n337: | `rolledBack` | Promoted candidate was rolled back to prior state |\n338: | `advisoryOnly` | Session completed for assessment only; no mutation attempted |\n339: \n340: ### Audit Journal Protocol\n341: \n342: All journal emission is orchestrator-only (ADR-001). The journal (`improvement-journal.jsonl`) is an append-only JSONL file capturing lifecycle events. Separate from the existing `agent-improvement-state.jsonl` which tracks proposal/evaluation data.\n343: \n344: **Script**: `scripts/shared/improvement-journal.cjs`\n345: \n346: Event types: `session_start`, `session_initialized`, `integration_scanned`, `candidate_generated`, `candidate_scored`, `benchmark_completed`, `gate_evaluation`, `legal_stop_evaluated`, `blocked_stop`, `promotion_attempt`, `promotion_result`, `rollback`, `rollback_result`, `trade_off_detected`, `mutation_proposed`, `mutation_outcome`, `session_ended`, `session_end`\n347: \n348: ### Static Benchmark Assets\n349: \n350: The reusable benchmark contract ships with the skill, not with each spec packet:\n351: \n352: - Profile: `assets/model-benchmark/benchmark-profiles/default.json`\n353: - Fixtures: `assets/model-benchmark/benchmark-fixtures/*.json`\n354: - Materializer: `scripts/shared/materialize-benchmark-fixtures.cjs`\n355: - Runner: `scripts/model-benchmark/run-benchmark.cjs`\n356: \n357: The command workflow first materializes static fixture JSON into packet-local markdown under `{spec_folder}/improvement/benchmark-outputs/{fixture.id}.md`, then runs `run-benchmark.cjs --profile .opencode/skills/deep-improvement/assets/model-benchmark/benchmark-profiles/default.json --outputs-dir {spec_folder}/improvement/benchmark-outputs`. The runner writes `{spec_folder}/improvement/benchmark-outputs/report.json` with `status:\"benchmark-complete\"` and appends a `benchmark_run` row to `{spec_folder}/improvement/agent-improvement-state.jsonl`.\n358: \n359: `benchmark_completed` may be emitted only after `benchmark-outputs/report.json` exists. Repeatability output from `benchmark-stability.cjs` is separate evidence and does not by itself prove benchmark completion.\n360: \n361: ### Legal-Stop Gate Bundles\n362: \n363: A session may NOT claim `converged` unless all five gate bundles pass: `contractGate`, `behaviorGate`, `integrationGate`, `evidenceGate`, and `improvementGate`. The orchestrator emits `legal_stop_evaluated` with nested `details.gateResults` before any `session_end`. Failures emit `blocked_stop` with `failedGates[]` and `stopReason:\"blockedStop\"`.\n364: \n365: ### Resume/Continuation Semantics (current release)\n366: \n367: Sessions support a single lineage mode today: `new`. Every invocation of the `/deep:start-agent-improvement-loop` workflow starts a fresh session with a new session id and generation 1. Multi-generation lineage modes (`resume`, `restart`, `fork`, `completed-continue`) were described in earlier drafts but have no shipped runtime wiring in the deep-improvement workflow, reducer, or journal consumer.\n368: \n369: Operators who want to continue evaluating an agent after a prior session SHOULD archive the prior session folder (e.g. move `improve/` to `improve_archive/{timestamp}/`) and re-invoke the command, which starts a new `new`-mode session. The reducer treats each session independently and does not carry ancestry across sessions.\n370: \n371: If the long-form lineage feature is implemented later, it will arrive with first-class event emission in `deep_start-agent-improvement-loop_{auto,confirm}.yaml`, reducer ancestry handling in `deep-improvement/scripts/shared/reduce-state.cjs`, and replay fixtures. Until then, treat every session as a standalone evaluation.\n372: \n373: ### Mutation Coverage Graph\n374: \n375: **Script**: `scripts/shared/mutation-coverage.cjs`\n376: \n377: Tracks explored dimensions, tried mutation types per dimension, and exhausted mutation sets using `loop_type: \"improvement\"` namespace isolation (ADR-002). The orchestrator skips mutation types already in the exhausted log.\n378: \n379: #### Mutation Signature Dedup\n380: \n381: Each mutation entry in `mutation-coverage.json` carries a `signature` field computed as:\n382: \n383: ```text\n384: signature = sha256(dimension + \"\\u001f\" + mutationType + \"\\u001f\" + targetSection + \"\\u001f\" + normalizedBody64)\n385: ```\n386: \n387: Where `normalizedBody64` = whitespace-collapsed, lowercased, first 64 characters of the mutation body.\n388: \n389: **Dedup behavior:**\n390: - Before proposing a new mutation, `isSignatureSeen()` scans existing `mutations[]` and `exhausted[]` arrays\n391: - If the signature matches, the candidate is skipped with `reason: \"EXHAUSTED-FROM: iter-NNN\"` recorded in `exhausted[]`\n392: - The `EXHAUSTED-FROM` format references the iteration where the original mutation was tried\n393: \n394: **Bypass:**\n395: ```bash\n396: export DEEP_AGENT_IMPROVEMENT_SKIP_DEDUP=1  # Force re-evaluation of previously seen signatures\n397: ```\n398: When set, `isSignatureSeen()` always returns `{ seen: false }`. Every mutation is considered fresh.\n399: \n400: **Backward compatibility:** Legacy `mutation-coverage.json` entries without `signature` field fall back to the existing `dimension::mutationType` dedup in the reducer. No migration required.\n401: \n402: **Authoritative storage:** `mutation-coverage.json` `mutations[]` array. `signature` is written by `recordMutation()` and read by `isSignatureSeen()` and `reduce-state.cjs`.\n403: \n404: ### Dimension Trajectory\n405: \n406: Trajectory data records per-iteration dimension scores. Two distinct convergence signals run side by side and must not be conflated. `mutation-coverage.cjs` `checkConvergenceEligibility()` marks a profile convergence-eligible when it has at least 3 data points and every dimension delta across the last 3 points is within `DEFAULT_STABILITY_DELTA` (+/-2), a tolerance band. Separately, `reduce-state.cjs` `stopOnDimensionPlateau` fires the plateau stop only when a dimension's last 3 scores are identical (exact-repeat). The +/-2 trajectory eligibility and the exact-repeat plateau stop are different checks.\n407: \n408: Stop-condition counters (`maxConsecutiveTies`, `maxInfraFailuresPerProfile`, `maxWeakBenchmarkRunsPerProfile`) default to disabled, with no cap, unless the runtime config sets them. Only configured counters can trigger `blockedStop`.\n409: \n410: ### Trade-Off Detection\n411: \n412: **Script**: `scripts/agent-improvement/trade-off-detector.cjs`\n413: \n414: Detects Pareto trade-offs: flags when improvement > +3 in one dimension causes regression < -3 in hard dimensions (structural, integration, systemFitness) or < -5 in soft dimensions (ruleCoherence, outputQuality). Blocks promotion for Pareto-dominated candidates.\n415: \n416: ### Parallel Candidate Waves (Optional)\n417: \n418: **Script**: `scripts/agent-improvement/candidate-lineage.cjs`\n419: \n420: Disabled by default (`parallelWaves.enabled: false` in config, ADR-004). When enabled, spawns 2-3 candidates with different mutation strategies. Activation requires: exploration-breadth score above threshold, 3+ unresolved mutation families, and 2 consecutive tie/plateau iterations.\n421: \n422: ### Weight Optimizer (Advisory Only)\n423: \n424: **Script**: `scripts/agent-improvement/benchmark-stability.cjs`\n425: \n426: Reads historical session data and emits a weight-recommendation report. Recommendations do NOT auto-apply (ADR-005). Requires minimum session count threshold before producing recommendations.\n427: \n428: ---\n429: \n430: ### Journal Wiring Contract\n431: \n432: Journal emission is orchestrator-only. The target agent being evaluated never writes journal rows directly. Only the visible YAML workflow or an operator-side wrapper invokes `scripts/shared/improvement-journal.cjs`.\n433: \n434: The CLI contract is:\n435: \n436: ```bash\n437: node .opencode/skills/deep-improvement/scripts/shared/improvement-journal.cjs --emit <eventType> --journal <journal_path> --details '<json>'\n438: ```\n439: \n440: The helper validates event type plus `session_end` or `session_ended` details, and the CLI entrypoint stores boundary context under `details`. Top-level `iteration` and `candidateId` fields are available only through the JS API, not through the CLI wrapper used by the YAML workflows.\n441: \n442: ### Boundary Points\n443: \n444: Journal boundaries are `session_start` after baseline setup, per-iteration candidate/scoring/gate events, and `session_end` after synthesis or terminal stop. Required details include session id, target, iteration/candidate paths, scores, stop reason, session outcome, and total iterations.\n445: \n446: ### Frozen Helper Enums\n447: \n448: `improvement-journal.cjs` currently exports and validates the following enums:\n449: \n450: - `STOP_REASONS`: `converged`, `maxIterationsReached`, `blockedStop`, `manualStop`, `error`, `stuckRecovery`\n451: - `SESSION_OUTCOMES`: `keptBaseline`, `promoted`, `rolledBack`, `advisoryOnly`\n452: \n453: Keep session-end emissions aligned to those helper-owned values until the helper contract itself changes. Labels such as `convergedImprovement`, `plateau`, `benchmarkPlateau`, `rejected`, `deferred`, `blocked`, or `errored` are not accepted by the current CLI validator. Plateau detection is a reducer/stop-rule condition. It must reconcile to one of the canonical stop reasons above when emitted as `details.stopReason`.\n454: \n455: ### Orchestrator Ownership\n456: \n457: - Auto mode emits `session_start` after `step_record_baseline`, then emits `candidate_generated`, `candidate_scored`, and `gate_evaluation` inside each loop iteration, and finally emits `session_end` after synthesis.\n458: - Confirm mode mirrors the same boundaries, with `gate_evaluation` emitted after the operator-facing approval gate is resolved.\n459: - Operators invoking the helper manually must use the same boundary order so replay and reducer consumers see a consistent journal shape.\n460: \n461: ### Reducer Consumer Side\n462: \n463: The reducer is the consumer for replay artifacts on refresh. Every `scripts/shared/reduce-state.cjs` pass now attempts to read:\n464: \n465: - `improvement-journal.jsonl`\n466: - `candidate-lineage.json`\n467: - `mutation-coverage.json`\n468: \n469: These inputs remain optional. Missing files do not fail the reducer. The corresponding registry field is set to `null` so dashboard and registry refreshes still complete.\n470: \n471: For legal-stop replay, the reducer consumes `details.gateResults` from the latest `legal_stop_evaluated` event and surfaces it as `journalSummary.latestLegalStop.gateResults` in `experiment-registry.json` plus the dashboard's latest legal-stop table.\n472: \n473: ### Journal Replay Consumer\n474: \n475: The reducer consumes replay artifacts instead of running a separate orchestrator-only synthesis step. During each refresh pass, `scripts/shared/reduce-state.cjs` reads the following artifacts when present:\n476: \n477: - `improvement-journal.jsonl` to summarize last session boundaries, total replayed events, per-event counts, and terminal `stopReason` / `sessionOutcome`\n478: - `candidate-lineage.json` to summarize lineage depth, total candidate count, and the latest candidate leaf\n479: - `mutation-coverage.json` to summarize mutation coverage ratio and uncovered mutations\n480: \n481: The reducer writes these summaries into new top-level registry fields:\n482: \n483: - `journalSummary`\n484: - `candidateLineage`\n485: - `mutationCoverage`\n486: \n487: Graceful degradation is required: if any artifact is missing, unreadable, or not yet generated for the current runtime, the reducer preserves the rest of the registry and records `null` for that field instead of throwing.\n488: \n489: The dashboard now also includes a dedicated **Sample Quality** section. This separates replay/stability sample sufficiency from benchmark failures so operators can tell the difference between a true regression and an iteration that simply lacked enough data for trade-off or replay-stability trust.\n490: \n491: ## 8. RULES\n492: \n493: ### ✅ ALWAYS\n494: \n495: - Read the charter, boundary file, and target profile before creating a candidate\n496: - Keep the ledger append-only\n497: - Treat the scorer as independent from the mutator\n498: - Preserve repeatability evidence when benchmark claims are made\n499: - Prefer the simpler candidate when scores tie\n500: - Keep benchmark evidence separate from mirror-drift packaging work\n501: - Require integration evidence to name each expected runtime mirror path explicitly (`.claude/agents`, `.codex/agents`, `.gemini/agents`, plus any declared extra mirrors) before trusting `integrationGate`\n502: \n503: ### ❌ NEVER\n504: \n505: - Mutate the canonical target during proposal-only mode\n506: - Broaden scope beyond the active boundary\n507: - Treat runtime mirrors as experiment truth in the same phase as canonical evaluation\n508: - Treat a stale placeholder mirror path as equivalent to a real runtime mirror\n509: - Hide rejected runs, weak benchmark results, or infra failures\n510: - Promote non-canonical targets even if they benchmark well\n511: \n512: ### ⚠️ ESCALATE IF\n513: \n514: - The target profile and boundary file disagree about mutability or target family\n515: - The benchmark runner cannot produce stable repeatability results\n516: - Promotion evidence is incomplete but canonical mutation is still being requested\n517: - Documentation edits would change the trust boundary rather than clarify it\n518: \n519: ---\n520: \n521: ## 9. REFERENCES\n522: \n523: Core references: `README.md`, `references/shared/quick_reference.md`, `references/shared/loop_protocol.md`, evaluator/promotion/rollback/no-go/onboarding docs, runtime assets under `assets/`, benchmark assets, and helper scripts for scoring, reduction, promotion, rollback, scanning, drift, journal, mutation coverage, trade-offs, candidate lineage, and benchmark stability.\n524: \n525: ---\n526: \n527: ## 10. INTEGRATION POINTS\n528: \n529: - `/deep:start-agent-improvement-loop` initializes and runs the Lane A bounded workflow\n530: - `/deep:start-model-benchmark-loop` initializes and runs the Lane B model-benchmark workflow\n531: - `.opencode/agents/deep-improvement.md` provides the mutator surface for deep-improvement runs\n532: - `sk-doc` validators enforce package-shape, README, and markdown document consistency\n533: - `system-spec-kit` packet validation proves phase records remain truthful\n534: \n535: ---\n536: \n537: ## 11. REFERENCES AND RELATED RESOURCES\n538: \n539: The router discovers reference, asset, and script docs dynamically. Start with `references/shared/loop_protocol.md`, `references/shared/quick_reference.md`, `references/model-benchmark/benchmark_operator_guide.md`, `references/model-benchmark/evaluator_contract.md`, `references/agent-improvement/integration_scanning.md`, `references/agent-improvement/mirror_drift_policy.md`, `references/shared/promotion_rules.md`, then load task-specific resources from `references/`, templates from `assets/`, and automation from `scripts/` when present.\n540: \n541: Scripts: `scripts/agent-improvement/benchmark-stability.cjs`, `scripts/agent-improvement/candidate-lineage.cjs`, `scripts/agent-improvement/check-mirror-drift.cjs`, `scripts/agent-improvement/generate-profile.cjs`, `scripts/shared/improvement-journal.cjs`, `scripts/shared/materialize-benchmark-fixtures.cjs`, `scripts/shared/mutation-coverage.cjs`, `scripts/shared/promote-candidate.cjs`, `scripts/shared/reduce-state.cjs`, `scripts/agent-improvement/rollback-candidate.cjs`, `scripts/model-benchmark/run-benchmark.cjs`, `scripts/agent-improvement/scan-integration.cjs`, `scripts/agent-improvement/score-candidate.cjs`, `scripts/agent-improvement/trade-off-detector.cjs`.\n542: \n543: Related skills: `sk-doc` for package-shape and markdown validation, `system-spec-kit` for packet validation, and `sk-prompt` when prompt surfaces need evaluator-backed rewriting.\n\n(End of file - total 543 lines)\n</content>","metadata":{"preview":"---\nname: deep-improvement\ndescription: \"Evaluator-first bounded agent improvement: 5-dim scoring, dynamic profiling, packet-local candidates, guarded promotion.\"\nallowed-tools: [Read, Write, Edit, Bash, Glob, Grep]\nversion: 1.9.0.0\ntriggers:\n  - deep-improvement\n  - agent improvement loop\n  - bounded agent improvement\n  - 5-dimension scoring\n  - integration scanner\n  - dynamic profiling\n  - model-benchmark mode\n  - benchmark a model or prompt framework\n---\n\n<!-- Keywords: deep-improvement, deep-improvement, agent-improvement, benchmark-harness, score-candidate, promote-candidate, rollback-candidate -->\n\n# Recursive Agent: Evaluator-First Improvement Orchestrator\n","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/SKILL.md","time":{"start":1780205053527,"end":1780205053542}},"id":"prt_e7c7d6477001xb6zLzc1mZavb4","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7d56df001ymVMwvqeQDRJE6"}}
