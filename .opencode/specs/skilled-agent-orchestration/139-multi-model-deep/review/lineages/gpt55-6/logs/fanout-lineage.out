nv,\n1296:       SPECKIT_BACKEND_ONLY: '1',\n1297:     },\n1298:     stdio: spawnIo.stdio,\n1299:     detached: spawnIo.detached,\n1300:   });\n1301:   // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n1302:   if (reelectionEnabled) childProcess.unref();\n1303:   const childPid = childProcess.pid;\n1304:   const refreshed = refreshOwnerLeaseFile(process.pid);\n1305:   if (!refreshed) {\n1306:     log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n1307:   }\n1308:   startOwnerLeaseHeartbeat(process.pid);\n1309:   writeLeaseFile(childPid);\n1310:   startRssWatchdog(childPid);\n1311: \n1312:   childProcess.on('exit', (code, signal) => {\n1313:     if (launcherShutdownInProgress) {\n1314:       return;\n1315:     }\n1316:     const result = superviseChildExit(\n1317:       { code, signal, childPid, intentional: false },\n1318:       {\n1319:         crashLoopGuard,\n1320:         clearLease: clearAllLeaseFiles,\n1321:         reapProcessGroup: reapProcessTreeGroups,\n1322:         mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n1323:         exit: (exitCode) => process.exit(exitCode),\n1324:         scheduleRelaunch: (backoffMs) => {\n1325:           log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n1326:           supervisorRelaunchTimer = setTimeout(() => {\n1327:             // Owner-disposal race guard: by the time the backoff fires, re-check that this\n1328:             // launcher is still live AND its owning runtime is still present. Respawning the\n1329:             // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n1330:             // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n1331:             // unaffected — both run with the owning runtime alive and no shutdown in progress.\n1332:             if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n1333:               log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n1334:               clearAllLeaseFiles();\n\n(Showing lines 1260-1334 of 1612. Use offset=1335 to continue.)\n</content>","metadata":{"preview":"        if (statErr.code === 'ENOTEMPTY') continue;\n        throw statErr;\n      }\n      if (artifactsReady() && !requireLock) {\n        return false;\n      }\n      if (Date.now() > deadline) {\n        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n      }\n      await sleep(1000);\n    }\n  }\n}\n\nfunction launchServer() {\n  if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n    log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n    return false;\n  }\n  if (shouldSkipLaunch(childProcess)) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"        if (statErr.code === 'ENOTEMPTY') continue;\n        throw statErr;\n      }\n      if (artifactsReady() && !requireLock) {\n        return false;\n      }\n      if (Date.now() > deadline) {\n        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n      }\n      await sleep(1000);\n    }\n  }\n}\n\nfunction launchServer() {\n  if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n    log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n    return false;\n  }\n  if (shouldSkipLaunch(childProcess)) {\n    log('launchServer skipped: a context-server child is already running in this launcher process');\n    return false;\n  }\n  if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n  if (supervisorRelaunchTimer) {\n    clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = null;\n  }\n  const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n  const nodeArgs = getContextServerNodeArgs();\n  const reelectionEnabled = daemonReelectionEnabled();\n  const spawnIo = contextServerSpawnIo(reelectionEnabled);\n  childProcess = spawn(process.execPath, [...nodeArgs, server], {\n    cwd: root,\n    env: {\n      ...process.env,\n      SPECKIT_BACKEND_ONLY: '1',\n    },\n    stdio: spawnIo.stdio,\n    detached: spawnIo.detached,\n  });\n  // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n  if (reelectionEnabled) childProcess.unref();\n  const childPid = childProcess.pid;\n  const refreshed = refreshOwnerLeaseFile(process.pid);\n  if (!refreshed) {\n    log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n  }\n  startOwnerLeaseHeartbeat(process.pid);\n  writeLeaseFile(childPid);\n  startRssWatchdog(childPid);\n\n  childProcess.on('exit', (code, signal) => {\n    if (launcherShutdownInProgress) {\n      return;\n    }\n    const result = superviseChildExit(\n      { code, signal, childPid, intentional: false },\n      {\n        crashLoopGuard,\n        clearLease: clearAllLeaseFiles,\n        reapProcessGroup: reapProcessTreeGroups,\n        mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n        exit: (exitCode) => process.exit(exitCode),\n        scheduleRelaunch: (backoffMs) => {\n          log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n          supervisorRelaunchTimer = setTimeout(() => {\n            // Owner-disposal race guard: by the time the backoff fires, re-check that this\n            // launcher is still live AND its owning runtime is still present. Respawning the\n            // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n            // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n            // unaffected — both run with the owning runtime alive and no shutdown in progress.\n            if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n              log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n              clearAllLeaseFiles();","lineStart":1260,"lineEnd":1334,"totalLines":1612,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780907854662,"end":1780907854674}},"metadata":{"openai":{"itemId":"fc_0c8532fea6ca3b6b016a267f4e2dfc8191abe0442983e4c7de"}},"id":"prt_ea66149850012cFabb22Zb3kEq","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea6610d86001EiriBw5TXf1jK6"}}
