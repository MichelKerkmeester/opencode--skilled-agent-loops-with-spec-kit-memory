rn(`[memory-save] N3-lite consolidation skipped after save [requestId=${requestId}]: ${message}`);\n\n  Line 866:     tool: 'memory_save',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/validation-responses.ts:\n  Line 24: // Feature catalog: Dry-run preflight for memory_save\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/pe-orchestration.ts:\n  Line 20: // Feature catalog: Memory indexing (memory_save)\n\n  Line 127:             reason: 'memory_save: reinforced existing memory via prediction-error gate',\n\n  Line 132:               tool: 'memory_save',\n\n  Line 138:             actor: 'mcp:memory_save',\n\n  Line 179:           reason: 'memory_save: updated existing memory via prediction-error gate',\n\n  Line 184:             tool: 'memory_save',\n\n  Line 190:           actor: 'mcp:memory_save',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts:\n  Line 29:   deleteIdempotencyReceiptByKey,\n\n  Line 31:   isMemoryIdempotencyEnabled,\n\n  Line 32:   lookupIdempotencyReceipt,\n\n  Line 33:   lookupIdempotencyReceiptByKey,\n\n  Line 35:   storeIdempotencyReceipt,\n\n  Line 36:   type IdempotencyReceiptKey,\n\n  Line 37: } from '../lib/storage/idempotency-receipts.js';\n\n  Line 154:   // Generate requestId for incident correlation in error responses\n\n  Line 155:   const requestId = randomUUID();\n\n  Line 223:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  Line 225:   if (database && isMemoryIdempotencyEnabled()) {\n\n  Line 236:       const lookup = lookupIdempotencyReceipt(database, {\n\n  Line 245:         // payloadHash always equals requestFingerprintHash and the receiptKey is\n\n  Line 259:       idempotencyKey = lookup.key;\n\n  Line 261:         // A receipt is a replay cache, not proof the cached response still\n\n  Line 263:         // honor the replay ONLY when it still matches the receipt's content_hash\n\n  Line 265:         // revert leaves the receipt for A intact while the row moved on, and a\n\n  Line 279:         // Stale receipt for this attempt: drop the cache entry so the live\n\n  Line 282:         // stale receipt), then fall through to the normal update path.\n\n  Line 283:         deleteIdempotencyReceiptByKey(database, lookup.key);\n\n  Line 291:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n\n  Line 292:           code: 'idempotency_key_conflict',\n\n  Line 293:           details: { requestId, receiptKey: lookup.key.receiptKey, id },\n\n  Line 301:       console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n\n  Line 302:       idempotencyKey = null;\n\n  Line 312:     console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n\n  Line 324:         console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n\n  Line 328:         console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n\n  Line 456:             console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n\n  Line 458:             console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n\n  Line 587:   if (database && idempotencyKey) {\n\n  Line 589:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n\n  Line 591:         // Same lost-store semantics as memory_save: a same-payload loser\n\n  Line 594:         // visible rather than silently diverging from the receipt.\n\n  Line 595:         