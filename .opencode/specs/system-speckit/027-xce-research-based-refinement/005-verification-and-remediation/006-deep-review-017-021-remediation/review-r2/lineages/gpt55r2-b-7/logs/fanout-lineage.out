   const message = toErrorMessage(err);\n1347:       console.warn('[memory-index-scan] Causal chain creation failed:', message);\n1348:     }\n1349:   }\n1350: \n1351:   if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1352:     runScanInvalidationHooks({\n1353:       indexed: results.indexed,\n1354:       updated: results.updated,\n1355:       staleDeleted: results.staleDeleted,\n1356:       staleDeleteFailed: results.staleDeleteFailed,\n1357:       ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n1358:         ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n1359:         : {}),\n1360:       ...(results.postInsertEnrichmentRepaired > 0\n1361:         ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n1362:         : {}),\n1363:       ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n1364:         ? {\n1365:             orphanSwept: results.orphanSwept,\n1366:             orphanSweepFailed: results.orphanSweepFailed,\n1367:           }\n1368:         : {}),\n1369:     }, scanAppliedActions);\n1370:   }\n1371: \n1372:   runScanHygieneSubscribers(scanAppliedActions);\n1373: \n1374:   const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n1375: \n1376:   const hints: string[] = [];\n1377:   if (results.failed > 0) {\n1378:     hints.push(`${results.failed} files failed to index - check file format`);\n1379:   }\n1380:   if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n1381:     hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n1382:   }\n1383:   if (results.staleDeleted > 0) {\n1384:     hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n1385:   }\n1386:   if (results.staleDeleteFailed > 0) {\n1387:     hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n1388:   }\n1389:   if (results.orphanSwept > 0) {\n1390:     hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n1391:   }\n1392:   if (results.postInsertEnrichmentRepaired > 0) {\n1393:     hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n1394:   }\n1395:   if (results.nearDuplicateRepaired > 0) {\n1396:     hints.push(`Repaired ${results.nearDuplicateRepaired} near-duplicate marker(s)`);\n1397:   }\n1398:   if (results.triggerEmbeddingBackfill?.readyRows) {\n1399:     hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n1400:   }\n1401:   if (results.triggerEmbeddingBackfill?.failedRows) {\n1402:     hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n1403:   }\n1404:   if (results.orphanSweepFailed > 0) {\n1405:     hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n1406:   }\n1407:   if (results.dedup.duplicatesSkipped > 0) {\n1408:     hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n1409:   }\n1410:   if (results.aliasConflicts.groups > 0) {\n1411:     hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n1412:   }\n1413:   if (results.aliasConflicts.divergentHashGroups > 0) {\n1414:     hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n1415:   }\n1416:   if (results.divergenceReconcile.retriesScheduled > 0) {\n1417:     hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n1418:   }\n1419:   if (results.divergenceReconcile.escalated > 0) {\n1420:     hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n1421:   }\n1422:   if (results.divergenceReconcile.errors.length > 0) {\n1423:     hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n1424:   }\n1425:   if (results.checkpointRepair.cleared) {\n1426:     hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n1427:   }\n1428:   if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n1429:     hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n1430:   }\n1431:   if (results.checkpointRepair.error) {\n1432:     hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n1433:   }\n1434:   if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n1435:     hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n1436:   }\n1437:   if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n1438:     hints.push('All files already up-to-date. Use force: true to re-index');\n1439:   }\n1440: \n1441:   await releaseScanLease();\n1442: \n1443:   recordMaintenanceRun('memory_index_scan', {\n1444:     status: 'success',\n1445:     counts: {\n1446:       scanned: results.scanned,\n1447:       indexed: results.indexed,\n1448:       updated: results.updated,\n1449:       unchanged: results.unchanged,\n1450:       failed: results.failed,\n1451:       staleDeleted: results.staleDeleted,\n1452:       staleDeleteFailed: results.staleDeleteFailed,\n1453:       orphanSwept: results.orphanSwept,\n1454:     },\n1455:     staleCandidates: filesToDelete.length,\n1456:   });\n1457: \n1458:   return createMCPSuccessResponse({\n1459:     tool: 'memory_index_scan',\n1460:     summary,\n1461:     data: {\n1462:       status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n1463:       ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n1464:       scanKey,\n1465:       batchSize: scanBatchSize,\n1466:       ...results,\n1467:       ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n1468:         ? {\n1469:             _debug_fileCounts: {\n1470:               constitutionalFiles: constitutionalFiles.length,\n1471:               specDocFiles: specDocFiles.length,\n1472:               totalFiles: files.length,\n1473:               mergedFiles: mergedFiles.length,\n1474:               dedupSkipped: dedupDuplicatesSkipped,\n1475:               includeSpecDocs: include_spec_docs,\n1476:               workspacePath,\n1477:             },\n1478:           }\n1479:         : {})\n1480:     },\n1481:     hints\n1482:   });\n1483:   } finally {\n1484:     if (leaseHeartbeat) {\n1485:       clearInterval(leaseHeartbeat);\n1486:       leaseHeartbeat = null;\n1487:     }\n1488:     if (loopLagTimer) {\n1489:       clearInterval(loopLagTimer);\n1490:       loopLagTimer = null;\n1491:       console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n1492:     }\n1493:     await releaseScanLease();\n1494:   }\n1495: }\n1496: \n1497: /** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n1498:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1499: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1500:   if (!args.background) {\n1501:     return runIndexScan(args, {});\n1502:   }\n1503: \n1504:   const jobId = createJobId();\n1505:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1506: \n1507:   setImmediate(() => {\n1508:     void (async () => {\n1509:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1510:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1511:       // background-embedding queue draining this scan's deferred embeddings can\n1512:       // keep it held past the scan itself.\n1513:       const maintenance = beginMaintenance('index_scan');\n1514:       try {\n1515:         await setJobState(jobId, 'running');\n1516:         const response = await runIndexScan(args, {\n1517:           isCancelled: () => isCancelRequestedFast(jobId),\n1518:           onPhase: (phase) => {\n1519:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1520:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1521:             maintenance.refresh();\n1522:             void setJobPhase(jobId, phase).catch(() => {});\n1523:           },\n1524:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1525:         });\n1526:         const scanData = extractEnvelopeData(response);\n1527:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1528:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1529:         if (wasCancelled) {\n1530:           // The run itself short-circuited on cancellation. A cancel that arrives\n1531:           // after the scan already finished does not retroactively cancel it.\n1532:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1533:         } else if (response.isError === true) {\n1534:           // An error envelope (not a thrown error) still means the scan failed.\n1535:           await appendJobError(jobId, '__scan__', scanData);\n1536:           await setJobState(jobId, 'failed');\n1537:         } else {\n1538:           await completeJob(jobId, { state: 'complete', result: scanData });\n1539:         }\n1540:       } catch (error: unknown) {\n1541:         try {\n1542:           await appendJobError(jobId, '__job__', error);\n1543:           await setJobState(jobId, 'failed');\n1544:         } catch (_secondaryError: unknown) {\n1545:           // Best-effort failure record; never surface a background unhandled rejection.\n1546:         }\n1547:       } finally {\n1548:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1549:         // Release this scan's hold; the marker stays present only while the\n1550:         // background-embedding queue still holds it.\n1551:         maintenance.end();\n1552:       }\n1553:     })();\n1554:   });\n1555: \n1556:   return createMCPSuccessResponse({\n1557:     tool: 'memory_index_scan',\n1558:     summary: `Queued background index scan ${jobId}`,\n1559:     data: { jobId, state: 'queued', background: true },\n1560:     hints: [\n1561:       'Use memory_index_scan_status with jobId to poll progress',\n1562:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1563:     ],\n1564:   });\n1565: }\n1566: \n1567: /* ───────────────────────────────────────────────────────────────\n1568:    9. EXPORTS\n1569: ──────────────────────────────────────────────────────────────── */\n1570: \n1571: export {\n1572:   handleMemoryIndexScan,\n1573:   indexSingleFile,\n1574:   findConstitutionalFiles,\n1575:   findSpecDocuments,\n1576:   detectSpecLevel,\n1577:   summarizeAliasConflicts,\n1578:   runDivergenceReconcileHooks,\n1579: };\n1580: \n1581: // Backward-compatible aliases (snake_case)\n1582: const handle_memory_index_scan = handleMemoryIndexScan;\n1583: const index_single_file = indexSingleFile;\n1584: const find_constitutional_files = findConstitutionalFiles;\n1585: const find_spec_documents = findSpecDocuments;\n1586: const detect_spec_level = detectSpecLevel;\n1587: const summarize_alias_conflicts = summarizeAliasConflicts;\n1588: const run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n1589: \n1590: export {\n1591:   handle_memory_index_scan,\n1592:   index_single_file,\n1593:   find_constitutional_files,\n1594:   find_spec_documents,\n1595:   detect_spec_level,\n\n(Showing lines 1316-1595 of 1598. Use offset=1596 to continue.)\n</content>","metadata":{"preview":"          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }\n\n  if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    runScanInvalidationHooks({\n      indexed: results.indexed,\n      updated: results.updated,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n        ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n        : {}),\n      ...(results.postInsertEnrichmentRepaired > 0\n        ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n        : {}),\n      ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n        ? {\n            orphanSwept: results.orphanSwept,\n            orphanSweepFailed: results.orphanSweepFailed,\n          }\n        : {}),\n    }, scanAppliedActions);\n  }\n\n  runScanHygieneSubscribers(scanAppliedActions);\n\n  const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n\n  const hints: string[] = [];\n  if (results.failed > 0) {\n    hints.push(`${results.failed} files failed to index - check file format`);\n  }\n  if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n    hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n  }\n  if (results.staleDeleted > 0) {\n    hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n  }\n  if (results.staleDeleteFailed > 0) {\n    hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n  }\n  if (results.orphanSwept > 0) {\n    hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n  }\n  if (results.postInsertEnrichmentRepaired > 0) {\n    hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n  }\n  if (results.nearDuplicateRepaired > 0) {\n    hints.push(`Repaired ${results.nearDuplicateRepaired} near-duplicate marker(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.readyRows) {\n    hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.failedRows) {\n    hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n  }\n  if (results.orphanSweepFailed > 0) {\n    hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n  }\n  if (results.dedup.duplicatesSkipped > 0) {\n    hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n  }\n  if (results.aliasConflicts.groups > 0) {\n    hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n  }\n  if (results.aliasConflicts.divergentHashGroups > 0) {\n    hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n  }\n  if (results.divergenceReconcile.retriesScheduled > 0) {\n    hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n  }\n  if (results.divergenceReconcile.escalated > 0) {\n    hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n  }\n  if (results.divergenceReconcile.errors.length > 0) {\n    hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n  }\n  if (results.checkpointRepair.cleared) {\n    hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n  }\n  if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n    hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n  }\n  if (results.checkpointRepair.error) {\n    hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n  }\n  if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n    hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n  }\n  if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n    hints.push('All files already up-to-date. Use force: true to re-index');\n  }\n\n  await releaseScanLease();\n\n  recordMaintenanceRun('memory_index_scan', {\n    status: 'success',\n    counts: {\n      scanned: results.scanned,\n      indexed: results.indexed,\n      updated: results.updated,\n      unchanged: results.unchanged,\n      failed: results.failed,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      orphanSwept: results.orphanSwept,\n    },\n    staleCandidates: filesToDelete.length,\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})\n    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_index_scan = handleMemoryIndexScan;\nconst index_single_file = indexSingleFile;\nconst find_constitutional_files = findConstitutionalFiles;\nconst find_spec_documents = findSpecDocuments;\nconst detect_spec_level = detectSpecLevel;\nconst summarize_alias_conflicts = summarizeAliasConflicts;\nconst run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n\nexport {\n  handle_memory_index_scan,\n  index_single_file,\n  find_constitutional_files,\n  find_spec_documents,\n  detect_spec_level,","lineStart":1316,"lineEnd":1595,"totalLines":1598,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781763312586,"end":1781763312598}},"metadata":{"openai":{"itemId":"fc_05a093e907fbe1ec016a338cf07ea88191afbcbf5adcef53e4"}},"id":"prt_ed95e8b9b001zLOyBgrOpuMoaZ","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95e70aa001S29XM3M7DY3F41"}}
{"type":"tool_use","timestamp":1781763312607,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_59o9vvEkFpHF0WJ72ammVGvv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":180,"limit":470},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see — aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n341: \n342: function appendRetentionLedger(\n343:   database: Database.Database,\n344:   deletedIds: number[],\n345:   candidates: RetentionExpiredRow[],\n346: ): boolean {\n347:   try {\n348:     mutationLedger.initLedger(database);\n349:     mutationLedger.appendEntry(database, {\n350:       mutation_type: 'delete',\n351:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n352:       prior_hash: null,\n353:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n354:       linked_memory_ids: deletedIds.slice(0, 50),\n355:       decision_meta: {\n356:         tool: 'memory_retention_sweep',\n357:         reason: 'retention_expired',\n358:         totalDeleted: deletedIds.length,\n359:         originalDeleteAfter: candidates\n360:           .filter((candidate) => deletedIds.includes(candidate.id))\n361:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n362:       },\n363:       actor: 'mcp:memory_retention_sweep',\n364:     });\n365:     return true;\n366:   } catch (error: unknown) {\n367:     const message = error instanceof Error ? error.message : String(error);\n368:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n369:     return false;\n370:   }\n371: }\n372: \n373: function runPostDeleteMaintenance(database: Database.Database): void {\n374:   try {\n375:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n376:   } catch (error: unknown) {\n377:     const message = error instanceof Error ? error.message : String(error);\n378:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n379:   }\n380: \n381:   const maintenance = new BetterSqliteMaintenance(database, {\n382:     onMaintenanceError: reportRetentionMaintenanceError,\n383:   });\n384:   maintenance.vacuum();\n385:   maintenance.checkpoint({ mode: 'truncate' });\n386: }\n387: \n388: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n389:   const message = error instanceof Error ? error.message : String(error);\n390:   if (operation === 'auto_vacuum') {\n391:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n392:   } else if (operation === 'incremental_vacuum') {\n393:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n394:   } else if (operation === 'wal_checkpoint') {\n395:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n396:   }\n397: }\n398: \n399: /**\n400:  * Sweep expired governed memory rows.\n401:  *\n402:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n403:  * to enforce the ISO timestamps persisted by governed ingest.\n404:  */\n405: export function runMemoryRetentionSweep(\n406:   database: Database.Database,\n407:   args: MemoryRetentionSweepArgs = {},\n408: ): MemoryRetentionSweepResult {\n409:   const startTime = Date.now();\n410:   const dryRun = args.dryRun === true;\n411:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n412: \n413:   if (!hasTable(database, 'memory_index')) {\n414:     return {\n415:       swept: 0,\n416:       retained: 0,\n417:       protectedCount: 0,\n418:       dryRun,\n419:       durationMs: Date.now() - startTime,\n420:       candidates: [],\n421:       deletedIds: [],\n422:       protectedIds: [],\n423:       ledgerRecorded: null,\n424:       tombstoneState: {\n425:         usesPurgeablePartition: false,\n426:         usingPurgeableIndex: false,\n427:         candidateCount: 0,\n428:         deletedCount: 0,\n429:       },\n430:       edgeState: {\n431:         causalEdgesTablePresent: false,\n432:         candidateEdgeCount: 0,\n433:       },\n434:     };\n435:   }\n436: \n437:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n438:   const initialEdgeState = buildEdgeState(database, candidates);\n439:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n440:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n441:     : null;\n442: \n443:   if (dryRun || candidates.length === 0) {\n444:     const totalRows = countRows(database);\n445:     const dryRunProtectedIds = candidates\n446:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n447:       .map((candidate) => candidate.id);\n448:     return {\n449:       swept: 0,\n450:       retained: totalRows,\n451:       protectedCount: dryRunProtectedIds.length,\n452:       dryRun,\n453:       durationMs: Date.now() - startTime,\n454:       candidates,\n455:       deletedIds: [],\n456:       protectedIds: dryRunProtectedIds,\n457:       ledgerRecorded: null,\n458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n459:       edgeState: initialEdgeState,\n460:       ...(feedbackRetention ? { feedbackRetention } : {}),\n461:     };\n462:   }\n463: \n464:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n465:     const auditTx = database.transaction(() => {\n466:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n467:         database,\n468:         candidates,\n469:         feedbackRetention,\n470:         false,\n471:       );\n472:     });\n473:     auditTx();\n474: \n475:     return {\n476:       swept: 0,\n477:       retained: countRows(database),\n478:       protectedCount: feedbackRetention.protectedIds.length,\n479:       dryRun,\n480:       durationMs: Date.now() - startTime,\n481:       candidates,\n482:       deletedIds: [],\n483:       protectedIds: feedbackRetention.protectedIds,\n484:       extendedIds: [],\n485:       ledgerRecorded: null,\n486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n487:       edgeState: initialEdgeState,\n488:       feedbackRetention,\n489:     };\n490:   }\n491: \n492:   initHistory(database);\n493: \n494:   const deletedIds: number[] = [];\n495:   const protectedIds: number[] = [];\n496:   const extendedIds: number[] = [];\n497:   let ledgerRecorded: boolean | null = null;\n498: \n499:   const sweepTx = database.transaction(() => {\n500:     for (const candidate of candidates) {\n501:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n502:       const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n503:       if (!currentCandidate) {\n504:         continue;\n505:       }\n506:       let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n507:       if (feedbackRetention) {\n508:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n509:         if (!decision) {\n510:           continue;\n511:         }\n512: \n513:         if (decision.decision === 'protect') {\n514:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n515:           protectedIds.push(candidate.id);\n516:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n517:             mode: feedbackRetention.mode,\n518:             applied: true,\n519:             activeGatePassed: feedbackRetention.activeGatePassed,\n520:           });\n521:           feedbackRetention.auditCount += 1;\n522:           continue;\n523:         }\n524: \n525:         if (decision.decision === 'extend') {\n526:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n527:             decision.nextDeleteAfter,\n528:             candidate.id,\n529:           );\n530:           extendedIds.push(candidate.id);\n531:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n532:             mode: feedbackRetention.mode,\n533:             applied: true,\n534:             activeGatePassed: feedbackRetention.activeGatePassed,\n535:           });\n536:           feedbackRetention.auditCount += 1;\n537:           continue;\n538:         }\n539:         feedbackDeleteDecision = decision;\n540:       }\n541:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n542:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n543:       if (isProtectedFromRetentionDelete(currentCandidate)) {\n544:         if (feedbackRetention && feedbackDeleteDecision) {\n545:           recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n546:             mode: feedbackRetention.mode,\n547:             applied: false,\n548:             activeGatePassed: feedbackRetention.activeGatePassed,\n549:           });\n550:           feedbackRetention.auditCount += 1;\n551:         }\n552:         protectedIds.push(currentCandidate.id);\n553:         recordGovernanceAudit(database, {\n554:           action: 'retention_sweep',\n555:           decision: 'deny',\n556:           memoryId: currentCandidate.id,\n557:           logicalKey: currentCandidate.filePath,\n558:           tenantId: currentCandidate.tenantId ?? undefined,\n559:           userId: currentCandidate.userId ?? undefined,\n560:           agentId: currentCandidate.agentId ?? undefined,\n561:           sessionId: currentCandidate.sessionId ?? undefined,\n562:           reason: 'retention_tier_protected',\n563:           metadata: {\n564:             originalDeleteAfter: currentCandidate.deleteAfter,\n565:             importanceTier: currentCandidate.importanceTier,\n566:             isPinned: currentCandidate.isPinned,\n567:             specFolder: currentCandidate.specFolder,\n568:             filePath: currentCandidate.filePath,\n569:           },\n570:         });\n571:         continue;\n572:       }\n573:       if (feedbackRetention && feedbackDeleteDecision) {\n574:         recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n575:           mode: feedbackRetention.mode,\n576:           applied: true,\n577:           activeGatePassed: feedbackRetention.activeGatePassed,\n578:         });\n579:         feedbackRetention.auditCount += 1;\n580:       }\n581:       const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n582:       if (!deleted) {\n583:         continue;\n584:       }\n585: \n586:       deletedIds.push(currentCandidate.id);\n587: \n588:       recordHistory(\n589:         currentCandidate.id,\n590:         'DELETE',\n591:         {\n592:           reason: 'retention_expired',\n593:           deleteAfter: currentCandidate.deleteAfter,\n594:           filePath: currentCandidate.filePath,\n595:         },\n596:         null,\n597:         'mcp:memory_retention_sweep',\n598:         currentCandidate.specFolder,\n599:       );\n600: \n601:       recordGovernanceAudit(database, {\n602:         action: 'retention_sweep',\n603:         decision: 'delete',\n604:         memoryId: currentCandidate.id,\n605:         logicalKey: currentCandidate.filePath,\n606:         tenantId: currentCandidate.tenantId ?? undefined,\n607:         userId: currentCandidate.userId ?? undefined,\n608:         agentId: currentCandidate.agentId ?? undefined,\n609:         sessionId: currentCandidate.sessionId ?? undefined,\n610:         reason: 'retention_expired',\n611:         metadata: {\n612:           originalDeleteAfter: currentCandidate.deleteAfter,\n613:           delete_after: currentCandidate.deleteAfter,\n614:           specFolder: currentCandidate.specFolder,\n615:           filePath: currentCandidate.filePath,\n616:         },\n617:       });\n618:     }\n619: \n620:     if (deletedIds.length > 0) {\n621:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n622:     }\n623:   });\n624: \n625:   sweepTx();\n626:   if (deletedIds.length > 0) {\n627:     runPostDeleteMaintenance(database);\n628:   }\n629:   if (feedbackRetention) {\n630:     feedbackRetention.extendedIds = extendedIds;\n631:     feedbackRetention.protectedIds = protectedIds;\n632:     feedbackRetention.deletedIds = deletedIds;\n633:   }\n634: \n635:   return {\n636:     swept: deletedIds.length,\n637:     retained: countRows(database),\n638:     protectedCount: protectedIds.length,\n639:     dryRun,\n640:     durationMs: Date.now() - startTime,\n641:     candidates,\n642:     deletedIds,\n643:     protectedIds,\n644:     ledgerRecorded,\n645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n646:     edgeState: initialEdgeState,\n647:     ...(feedbackRetention ? { extendedIds } : {}),\n648:     ...(feedbackRetention ? { feedbackRetention } : {}),\n649:   };\n\n(Showing lines 180-649 of 650. Use offset=650 to continue.)\n</content>","metadata":{"preview":" * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":" * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see — aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n      if (!currentCandidate) {\n        continue;\n      }\n      let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n        feedbackDeleteDecision = decision;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(currentCandidate)) {\n        if (feedbackRetention && feedbackDeleteDecision) {\n          recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n            mode: feedbackRetention.mode,\n            applied: false,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n        }\n        protectedIds.push(currentCandidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: currentCandidate.id,\n          logicalKey: currentCandidate.filePath,\n          tenantId: currentCandidate.tenantId ?? undefined,\n          userId: currentCandidate.userId ?? undefined,\n          agentId: currentCandidate.agentId ?? undefined,\n          sessionId: currentCandidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: currentCandidate.deleteAfter,\n            importanceTier: currentCandidate.importanceTier,\n            isPinned: currentCandidate.isPinned,\n            specFolder: currentCandidate.specFolder,\n            filePath: currentCandidate.filePath,\n          },\n        });\n        continue;\n      }\n      if (feedbackRetention && feedbackDeleteDecision) {\n        recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(currentCandidate.id);\n\n      recordHistory(\n        currentCandidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: currentCandidate.deleteAfter,\n          filePath: currentCandidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        currentCandidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: currentCandidate.id,\n        logicalKey: currentCandidate.filePath,\n        tenantId: currentCandidate.tenantId ?? undefined,\n        userId: currentCandidate.userId ?? undefined,\n        agentId: currentCandidate.agentId ?? undefined,\n        sessionId: currentCandidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: currentCandidate.deleteAfter,\n          delete_after: currentCandidate.deleteAfter,\n          specFolder: currentCandidate.specFolder,\n          filePath: currentCandidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),\n    ...(feedbackRetention ? { feedbackRetention } : {}),\n  };","lineStart":180,"lineEnd":649,"totalLines":650,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781763312600,"end":1781763312606}},"metadata":{"openai":{"itemId":"fc_05a093e907fbe1ec016a338cf07ebc819187d82bb0a854b059"}},"id":"prt_ed95e8bd4001xKupllJeZl4UHq","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95e70aa001S29XM3M7DY3F41"}}
{"type":"tool_use","timestamp":1781763312612,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_FeZVOmefEnTISbbZ8uSw4vrM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","offset":1,"limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Batch Processor\n3: // ───────────────────────────────────────────────────────────────\n4: import { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n5: \n6: // ───────────────────────────────────────────────────────────────\n7: // 1. TYPES\n8: \n9: // ───────────────────────────────────────────────────────────────\n10: /** Retry options for batch processing */\n11: export interface RetryOptions {\n12:   maxRetries?: number;\n13:   retryDelay?: number;\n14:   // Early-abort hook. When it returns true the batch loop stops immediately,\n15:   // skipping every remaining batch AND its inter-batch pacing delay. Without\n16:   // this a cancelled long run still drains thousands of no-op batches (and their\n17:   // delays) before the caller's post-loop cancel check is reached.\n18:   shouldAbort?: () => boolean;\n19: }\n20: \n21: /** Default retry configuration */\n22: export interface RetryDefaults {\n23:   maxRetries: number;\n24:   retryDelay: number;\n25: }\n26: \n27: /** Error result from a failed retry operation */\n28: export interface RetryErrorResult {\n29:   error: string;\n30:   errorDetail?: string;\n31:   item: unknown;\n32:   retries_failed: boolean;\n33: }\n34: \n35: /** Processor function type */\n36: export type ItemProcessor<T, R> = (item: T) => Promise<R>;\n37: \n38: // ───────────────────────────────────────────────────────────────\n39: // 2. CONFIGURATION CONSTANTS\n40: \n41: // ───────────────────────────────────────────────────────────────\n42: // Single source of truth for batch config — imported from core/config.ts\n43: import { BATCH_SIZE, BATCH_DELAY_MS } from '../core/config.js';\n44: export { BATCH_SIZE, BATCH_DELAY_MS };\n45: export const MAX_BATCH_SIZE = 100;\n46: const COOPERATIVE_YIELD_EVERY = 50;\n47: \n48: /** Default retry configuration */\n49: export const DEFAULT_RETRY_OPTIONS: Readonly<RetryDefaults> = {\n50:   maxRetries: 2,\n51:   retryDelay: 1000\n52: } as const;\n53: \n54: function normalizeRetryValue(value: number | undefined, fallback: number): number {\n55:   if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {\n56:     return fallback;\n57:   }\n58:   return Math.floor(value);\n59: }\n60: \n61: function cooperativeYield(): Promise<void> {\n62:   return new Promise<void>(resolve => setImmediate(resolve));\n63: }\n64: \n65: // ───────────────────────────────────────────────────────────────\n66: // 3. RETRY LOGIC\n67: \n68: // ───────────────────────────────────────────────────────────────\n69: /**\n70:  * Process a single item with retry logic for transient failures.\n71:  * Uses exponential backoff strategy for retries.\n72:  */\n73: export async function processWithRetry<T, R>(\n74:   item: T,\n75:   processor: ItemProcessor<T, R>,\n76:   options: RetryOptions = {}\n77: ): Promise<R | RetryErrorResult> {\n78:   const maxRetries = normalizeRetryValue(options.maxRetries, DEFAULT_RETRY_OPTIONS.maxRetries);\n79:   const retryDelay = normalizeRetryValue(options.retryDelay, DEFAULT_RETRY_OPTIONS.retryDelay);\n80:   let last_error: Error | undefined;\n81: \n82:   for (let attempt = 0; attempt <= maxRetries; attempt++) {\n83:     try {\n84:       return await processor(item);\n85:     } catch (err: unknown) {\n86:       last_error = err instanceof Error ? err : new Error(String(err));\n87:       // Only retry transient errors\n88:       if (attempt < maxRetries && isTransientError(last_error)) {\n89:         const delay = retryDelay * (attempt + 1); // Exponential backoff\n90:         console.error(`[batch-retry] Attempt ${attempt + 1}/${maxRetries + 1} failed, retrying in ${delay}ms: ${last_error.message}`);\n91:         await new Promise<void>(r => setTimeout(r, delay));\n92:       } else if (attempt < maxRetries) {\n93:         // Non-transient error, don't retry\n94:         break;\n95:       }\n96:     }\n97:   }\n98:   if (!last_error) {\n99:     last_error = new Error('Retry loop exited without processor result');\n100:   }\n101: \n102:   return {\n103:     error: userFriendlyError(last_error),\n104:     errorDetail: last_error.message,\n105:     item,\n106:     retries_failed: true,\n107:   };\n108: }\n109: \n110: // ───────────────────────────────────────────────────────────────\n111: // 4. BATCH PROCESSING\n112: \n113: // ───────────────────────────────────────────────────────────────\n114: /**\n115:  * Process items in batches with concurrency control and retry logic.\n116:  * Provides controlled execution to prevent resource exhaustion.\n117:  *\n118:  * @throws {Error} If batchSize is not a positive finite integer.\n119:  * Validates batchSize BEFORE any processing to prevent\n120:  *   infinite loops (batchSize=0) or nonsensical iteration (NaN, negative,\n121:  *   Infinity, fractional values).\n122:  */\n123: export async function processBatches<T, R>(\n124:   items: T[],\n125:   processor: ItemProcessor<T, R>,\n126:   batchSize: number = BATCH_SIZE,\n127:   delayMs: number = BATCH_DELAY_MS,\n128:   retryOptions: RetryOptions = {}\n129: ): Promise<Array<R | RetryErrorResult>> {\n130:   // Validate batchSize before any processing.\n131:   // NaN <= 0 is false, so the original <= 0 check alone would miss NaN.\n132:   // Also reject Infinity and non-integer values for safety.\n133:   if (typeof batchSize !== 'number' || !Number.isFinite(batchSize) || batchSize <= 0 || batchSize !== Math.floor(batchSize)) {\n134:     throw new Error(`batchSize must be a positive integer, got: ${batchSize}`);\n135:   }\n136: \n137:   const effectiveBatchSize = Math.min(batchSize, MAX_BATCH_SIZE);\n138:   if (effectiveBatchSize !== batchSize) {\n139:     console.warn(\n140:       `[batch-processor] Clamped batch size ${batchSize} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n141:     );\n142:   }\n143: \n144:   const results: Array<R | RetryErrorResult> = [];\n145:   const totalBatches = Math.ceil(items.length / effectiveBatchSize);\n146:   let currentBatch = 0;\n147:   let processedSinceYield = 0;\n148: \n149:   for (let i = 0; i < items.length; i += effectiveBatchSize) {\n150:     if (retryOptions.shouldAbort?.()) break;\n151:     currentBatch++;\n152:     console.error(`[batch-processor] Processing batch ${currentBatch}/${totalBatches}`);\n153: \n154:     const batch = items.slice(i, i + effectiveBatchSize);\n155:     const batchResults = await Promise.all(\n156:       batch.map(async (item, index) => {\n157:         if (index > 0 && index % COOPERATIVE_YIELD_EVERY === 0) {\n158:           await cooperativeYield();\n159:         }\n160:         return processWithRetry(item, processor, retryOptions);\n161:       })\n162:     );\n163:     results.push(...batchResults);\n164:     processedSinceYield += batchResults.length;\n165: \n166:     if (processedSinceYield >= COOPERATIVE_YIELD_EVERY) {\n167:       await cooperativeYield();\n168:       processedSinceYield %= COOPERATIVE_YIELD_EVERY;\n169:     }\n170: \n171:     // Small delay between batches to prevent resource exhaustion.\n172:     // Skip the pacing delay once cancellation is requested, so a cancelled run\n173:     // does not wait one extra inter-batch delay before the top-of-loop break.\n174:     if (i + effectiveBatchSize < items.length && delayMs > 0 && !retryOptions.shouldAbort?.()) {\n175:       await new Promise<void>(resolve => setTimeout(resolve, delayMs));\n176:     }\n177:   }\n178: \n179:   return results;\n180: }\n181: \n182: /**\n183:  * Process items sequentially (one at a time) with retry logic.\n184:  * Use when order matters or for resource-constrained operations.\n185:  */\n186: export async function processSequentially<T, R>(\n187:   items: T[],\n188:   processor: ItemProcessor<T, R>,\n189:   retryOptions: RetryOptions = {}\n190: ): Promise<Array<R | RetryErrorResult>> {\n191:   const results: Array<R | RetryErrorResult> = [];\n192: \n193:   for (let i = 0; i < items.length; i++) {\n194:     console.error(`[batch-processor] Processing item ${i + 1}/${items.length}`);\n195:     const result = await processWithRetry(items[i], processor, retryOptions);\n196:     results.push(result);\n197:   }\n198: \n199:   return results;\n200: }\n201: \n202: /* ───────────────────────────────────────────────────────────────\n203:    5. (ESM exports above — no CommonJS module.exports needed)\n204:    ──────────────────────────────────────────────────────────────── */\n\n(End of file - total 204 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Batch Processor\n// ───────────────────────────────────────────────────────────────\nimport { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Retry options for batch processing */\nexport interface RetryOptions {\n  maxRetries?: number;\n  retryDelay?: number;\n  // Early-abort hook. When it returns true the batch loop stops immediately,\n  // skipping every remaining batch AND its inter-batch pacing delay. Without\n  // this a cancelled long run still drains thousands of no-op batches (and their\n  // delays) before the caller's post-loop cancel check is reached.\n  shouldAbort?: () => boolean;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Batch Processor\n// ───────────────────────────────────────────────────────────────\nimport { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Retry options for batch processing */\nexport interface RetryOptions {\n  maxRetries?: number;\n  retryDelay?: number;\n  // Early-abort hook. When it returns true the batch loop stops immediately,\n  // skipping every remaining batch AND its inter-batch pacing delay. Without\n  // this a cancelled long run still drains thousands of no-op batches (and their\n  // delays) before the caller's post-loop cancel check is reached.\n  shouldAbort?: () => boolean;\n}\n\n/** Default retry configuration */\nexport interface RetryDefaults {\n  maxRetries: number;\n  retryDelay: number;\n}\n\n/** Error result from a failed retry operation */\nexport interface RetryErrorResult {\n  error: string;\n  errorDetail?: string;\n  item: unknown;\n  retries_failed: boolean;\n}\n\n/** Processor function type */\nexport type ItemProcessor<T, R> = (item: T) => Promise<R>;\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONFIGURATION CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\n// Single source of truth for batch config — imported from core/config.ts\nimport { BATCH_SIZE, BATCH_DELAY_MS } from '../core/config.js';\nexport { BATCH_SIZE, BATCH_DELAY_MS };\nexport const MAX_BATCH_SIZE = 100;\nconst COOPERATIVE_YIELD_EVERY = 50;\n\n/** Default retry configuration */\nexport const DEFAULT_RETRY_OPTIONS: Readonly<RetryDefaults> = {\n  maxRetries: 2,\n  retryDelay: 1000\n} as const;\n\nfunction normalizeRetryValue(value: number | undefined, fallback: number): number {\n  if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {\n    return fallback;\n  }\n  return Math.floor(value);\n}\n\nfunction cooperativeYield(): Promise<void> {\n  return new Promise<void>(resolve => setImmediate(resolve));\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. RETRY LOGIC\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Process a single item with retry logic for transient failures.\n * Uses exponential backoff strategy for retries.\n */\nexport async function processWithRetry<T, R>(\n  item: T,\n  processor: ItemProcessor<T, R>,\n  options: RetryOptions = {}\n): Promise<R | RetryErrorResult> {\n  const maxRetries = normalizeRetryValue(options.maxRetries, DEFAULT_RETRY_OPTIONS.maxRetries);\n  const retryDelay = normalizeRetryValue(options.retryDelay, DEFAULT_RETRY_OPTIONS.retryDelay);\n  let last_error: Error | undefined;\n\n  for (let attempt = 0; attempt <= maxRetries; attempt++) {\n    try {\n      return await processor(item);\n    } catch (err: unknown) {\n      last_error = err instanceof Error ? err : new Error(String(err));\n      // Only retry transient errors\n      if (attempt < maxRetries && isTransientError(last_error)) {\n        const delay = retryDelay * (attempt + 1); // Exponential backoff\n        console.error(`[batch-retry] Attempt ${attempt + 1}/${maxRetries + 1} failed, retrying in ${delay}ms: ${last_error.message}`);\n        await new Promise<void>(r => setTimeout(r, delay));\n      } else if (attempt < maxRetries) {\n        // Non-transient error, don't retry\n        break;\n      }\n    }\n  }\n  if (!last_error) {\n    last_error = new Error('Retry loop exited without processor result');\n  }\n\n  return {\n    error: userFriendlyError(last_error),\n    errorDetail: last_error.message,\n    item,\n    retries_failed: true,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. BATCH PROCESSING\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Process items in batches with concurrency control and retry logic.\n * Provides controlled execution to prevent resource exhaustion.\n *\n * @throws {Error} If batchSize is not a positive finite integer.\n * Validates batchSize BEFORE any processing to prevent\n *   infinite loops (batchSize=0) or nonsensical iteration (NaN, negative,\n *   Infinity, fractional values).\n */\nexport async function processBatches<T, R>(\n  items: T[],\n  processor: ItemProcessor<T, R>,\n  batchSize: number = BATCH_SIZE,\n  delayMs: number = BATCH_DELAY_MS,\n  retryOptions: RetryOptions = {}\n): Promise<Array<R | RetryErrorResult>> {\n  // Validate batchSize before any processing.\n  // NaN <= 0 is false, so the original <= 0 check alone would miss NaN.\n  // Also reject Infinity and non-integer values for safety.\n  if (typeof batchSize !== 'number' || !Number.isFinite(batchSize) || batchSize <= 0 || batchSize !== Math.floor(batchSize)) {\n    throw new Error(`batchSize must be a positive integer, got: ${batchSize}`);\n  }\n\n  const effectiveBatchSize = Math.min(batchSize, MAX_BATCH_SIZE);\n  if (effectiveBatchSize !== batchSize) {\n    console.warn(\n      `[batch-processor] Clamped batch size ${batchSize} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n    );\n  }\n\n  const results: Array<R | RetryErrorResult> = [];\n  const totalBatches = Math.ceil(items.length / effectiveBatchSize);\n  let currentBatch = 0;\n  let processedSinceYield = 0;\n\n  for (let i = 0; i < items.length; i += effectiveBatchSize) {\n    if (retryOptions.shouldAbort?.()) break;\n    currentBatch++;\n    console.error(`[batch-processor] Processing batch ${currentBatch}/${totalBatches}`);\n\n    const batch = items.slice(i, i + effectiveBatchSize);\n    const batchResults = await Promise.all(\n      batch.map(async (item, index) => {\n        if (index > 0 && index % COOPERATIVE_YIELD_EVERY === 0) {\n          await cooperativeYield();\n        }\n        return processWithRetry(item, processor, retryOptions);\n      })\n    );\n    results.push(...batchResults);\n    processedSinceYield += batchResults.length;\n\n    if (processedSinceYield >= COOPERATIVE_YIELD_EVERY) {\n      await cooperativeYield();\n      processedSinceYield %= COOPERATIVE_YIELD_EVERY;\n    }\n\n    // Small delay between batches to prevent resource exhaustion.\n    // Skip the pacing delay once cancellation is requested, so a cancelled run\n    // does not wait one extra inter-batch delay before the top-of-loop break.\n    if (i + effectiveBatchSize < items.length && delayMs > 0 && !retryOptions.shouldAbort?.()) {\n      await new Promise<void>(resolve => setTimeout(resolve, delayMs));\n    }\n  }\n\n  return results;\n}\n\n/**\n * Process items sequentially (one at a time) with retry logic.\n * Use when order matters or for resource-constrained operations.\n */\nexport async function processSequentially<T, R>(\n  items: T[],\n  processor: ItemProcessor<T, R>,\n  retryOptions: RetryOptions = {}\n): Promise<Array<R | RetryErrorResult>> {\n  const results: Array<R | RetryErrorResult> = [];\n\n  for (let i = 0; i < items.length; i++) {\n    console.error(`[batch-processor] Processing item ${i + 1}/${items.length}`);\n    const result = await processWithRetry(items[i], processor, retryOptions);\n    results.push(result);\n  }\n\n  return results;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. (ESM exports above — no CommonJS module.exports needed)\n   ──────────────────────────────────────────────────────────────── */","lineStart":1,"lineEnd":204,"totalLines":204,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","time":{"start":1781763312603,"end":1781763312611}},"metadata":{"openai":{"itemId":"fc_05a093e907fbe1ec016a338cf07ec48191bb7e4addaa7b7d68"}},"id":"prt_ed95e8bd9001lyVb7lNpX5pwlL","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95e70aa001S29XM3M7DY3F41"}}
