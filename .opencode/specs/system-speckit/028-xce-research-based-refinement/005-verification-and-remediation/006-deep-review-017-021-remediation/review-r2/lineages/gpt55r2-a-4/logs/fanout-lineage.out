  // When SPECKIT_MEMORY_SUMMARIES is enabled (default-ON) and scale gate is\n  // Met (>5000 indexed), run a parallel search on summary embeddings and merge\n  // Results. Pattern follows embedding expansion: run in parallel, merge\n  // + deduplicate by ID.\n  if (isMemorySummariesEnabled()) {\n    try {\n      const db = requireDb();\n      if (checkScaleGate(db)) {\n        const summaryEmbedding: Float32Array | number[] | null =\n          queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n        if (summaryEmbedding) {\n          const summaryResults = querySummaryEmbeddings(db, summaryEmbedding, limit);\n          if (summaryResults.length > 0) {\n            const existingIds = new Set(candidates.map((r) => String(r.id)));\n            const newSummaryHits: PipelineRow[] = [];\n\n            // F02-003: Batch-fetch instead of N+1 per-item queries\n            const newSummaryIds = summaryResults\n              .filter((sr) => !existingIds.has(String(sr.memoryId)))\n              .map((sr) => sr.memoryId);\n\n            if (newSummaryIds.length > 0) {\n              const placeholders = newSummaryIds.map(() => '?').join(', ');\n              const memRows = db.prepare(\n                `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n              ).all(...newSummaryIds) as PipelineRow[];\n\n              const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n              for (const sr of summaryResults) {\n                if (!existingIds.has(String(sr.memoryId))) {\n                  const memRow = memRowMap.get(sr.memoryId);\n                  if (memRow) {\n                    newSummaryHits.push({\n                      ...memRow,\n                      similarity: sr.similarity * 100,\n                      score: sr.similarity,\n                    });\n                    existingIds.add(String(sr.memoryId));\n                  }\n                }\n              }\n            }\n\n            const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n            const folderFilteredSummaryHits = applyFolderFilter(archiveFilteredSummaryHits, specFolder);\n            const tierFilteredSummaryHits = applyTierFilter(folderFilteredSummaryHits, tier);\n            const contextFilteredSummaryHits = contextType\n              ? tierFilteredSummaryHits.filter((r) => resolveRowContextType(r) === contextType)\n              : tierFilteredSummaryHits;\n            const scopeFilteredSummaryHits = shouldApplyScopeFiltering\n              ? filterRowsByScope(contextFilteredSummaryHits, scopeFilter)\n              : contextFilteredSummaryHits;\n\n            // Apply the same quality threshold that other candidates go through\n            const backfilledSummaryHits = backfillMissingQualityScores(scopeFilteredSummaryHits);\n            const filteredSummaryHits = filterByMinQualityScore(backfilledSummaryHits, qualityThreshold);\n\n            if (filteredSummaryHits.length > 0) {\n              candidates = [...candidates, ...filteredSummaryHits];\n              channelCount++;\n\n              if (trace) {","lineStart":1290,"lineEnd":1359,"totalLines":1510,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781761986677,"end":1781761986681}},"metadata":{"openai":{"itemId":"fc_05fce0a1f1825a85016a3387c236e48191b736943e6d962f62"}},"id":"prt_ed94a5013001RByGXwmaxQqE81","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a12c5001SPqQudSq1aBJpq"}}
{"type":"tool_use","timestamp":1781761986720,"sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","part":{"type":"tool","tool":"read","callID":"call_WT1jpqQ0NlsWOpTxjQaFuVz1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts","offset":145,"limit":65},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts</path>\n<type>file</type>\n<content>\n145: }\n146: \n147: /**\n148:  * Vector search on summary embeddings — parallel channel for stage1.\n149:  *\n150:  * 1. SELECT id, memory_id, summary_embedding FROM memory_summaries\n151:  *    WHERE summary_embedding IS NOT NULL\n152:  * 2. Compute cosine similarity between query embedding and each summary embedding\n153:  * 3. Return top `limit` results sorted by similarity descending\n154:  * 4. Convert BLOB back to Float32Array for comparison\n155:  *\n156:  * @param db - SQLite database instance\n157:  * @param queryEmbedding - Query vector to compare against stored summaries\n158:  * @param limit - Maximum number of results to return\n159:  * @returns Array of summary search results sorted by similarity descending\n160:  */\n161: export function querySummaryEmbeddings(\n162:   db: Database.Database,\n163:   queryEmbedding: Float32Array | number[],\n164:   limit: number\n165: ): SummarySearchResult[] {\n166:   try {\n167:     // Cap rows fetched to avoid full-table scans on large databases.\n168:     // Over-fetch by a factor so that after cosine ranking we can still return `limit` results.\n169:     const fetchCap = Math.max(limit * 10, 1000);\n170:     const rows = db.prepare(`\n171:       SELECT id, memory_id, summary_embedding\n172:       FROM memory_summaries\n173:       WHERE summary_embedding IS NOT NULL\n174:       LIMIT ?\n175:     `).all(fetchCap) as Array<{ id: number; memory_id: number; summary_embedding: Buffer }>;\n176: \n177:     const results: SummarySearchResult[] = [];\n178: \n179:     for (const row of rows) {\n180:       const storedEmbedding = bufferToFloat32(row.summary_embedding);\n181:       const similarity = cosineSimilarity(queryEmbedding, storedEmbedding);\n182: \n183:       results.push({\n184:         id: row.id,\n185:         memoryId: row.memory_id,\n186:         similarity,\n187:       });\n188:     }\n189: \n190:     // Sort by similarity descending, take top `limit`\n191:     results.sort((a, b) => b.similarity - a.similarity);\n192:     return results.slice(0, limit);\n193:   } catch (error: unknown) {\n194:     console.warn(\n195:       '[memory-summaries] Failed to query summary embeddings:',\n196:       error instanceof Error ? error.message : error\n197:     );\n198:     return [];\n199:   }\n200: }\n201: \n202: /**\n203:  * Runtime scale gate check: returns true when >5000 indexed memories.\n204:  * Used to determine if the summary search channel should be activated\n205:  * as an additional retrieval source.\n206:  *\n207:  * @param db - SQLite database instance\n208:  * @returns True if indexed memory count exceeds 5000\n209:  */\n\n(Showing lines 145-209 of 242. Use offset=210 to continue.)\n</content>","metadata":{"preview":"}\n\n/**\n * Vector search on summary embeddings — parallel channel for stage1.\n *\n * 1. SELECT id, memory_id, summary_embedding FROM memory_summaries\n *    WHERE summary_embedding IS NOT NULL\n * 2. Compute cosine similarity between query embedding and each summary embedding\n * 3. Return top `limit` results sorted by similarity descending\n * 4. Convert BLOB back to Float32Array for comparison\n *\n * @param db - SQLite database instance\n * @param queryEmbedding - Query vector to compare against stored summaries\n * @param limit - Maximum number of results to return\n * @returns Array of summary search results sorted by similarity descending\n */\nexport function querySummaryEmbeddings(\n  db: Database.Database,\n  queryEmbedding: Float32Array | number[],\n  limit: number","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts","text":"}\n\n/**\n * Vector search on summary embeddings — parallel channel for stage1.\n *\n * 1. SELECT id, memory_id, summary_embedding FROM memory_summaries\n *    WHERE summary_embedding IS NOT NULL\n * 2. Compute cosine similarity between query embedding and each summary embedding\n * 3. Return top `limit` results sorted by similarity descending\n * 4. Convert BLOB back to Float32Array for comparison\n *\n * @param db - SQLite database instance\n * @param queryEmbedding - Query vector to compare against stored summaries\n * @param limit - Maximum number of results to return\n * @returns Array of summary search results sorted by similarity descending\n */\nexport function querySummaryEmbeddings(\n  db: Database.Database,\n  queryEmbedding: Float32Array | number[],\n  limit: number\n): SummarySearchResult[] {\n  try {\n    // Cap rows fetched to avoid full-table scans on large databases.\n    // Over-fetch by a factor so that after cosine ranking we can still return `limit` results.\n    const fetchCap = Math.max(limit * 10, 1000);\n    const rows = db.prepare(`\n      SELECT id, memory_id, summary_embedding\n      FROM memory_summaries\n      WHERE summary_embedding IS NOT NULL\n      LIMIT ?\n    `).all(fetchCap) as Array<{ id: number; memory_id: number; summary_embedding: Buffer }>;\n\n    const results: SummarySearchResult[] = [];\n\n    for (const row of rows) {\n      const storedEmbedding = bufferToFloat32(row.summary_embedding);\n      const similarity = cosineSimilarity(queryEmbedding, storedEmbedding);\n\n      results.push({\n        id: row.id,\n        memoryId: row.memory_id,\n        similarity,\n      });\n    }\n\n    // Sort by similarity descending, take top `limit`\n    results.sort((a, b) => b.similarity - a.similarity);\n    return results.slice(0, limit);\n  } catch (error: unknown) {\n    console.warn(\n      '[memory-summaries] Failed to query summary embeddings:',\n      error instanceof Error ? error.message : error\n    );\n    return [];\n  }\n}\n\n/**\n * Runtime scale gate check: returns true when >5000 indexed memories.\n * Used to determine if the summary search channel should be activated\n * as an additional retrieval source.\n *\n * @param db - SQLite database instance\n * @returns True if indexed memory count exceeds 5000\n */","lineStart":145,"lineEnd":209,"totalLines":242,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts","time":{"start":1781761986716,"end":1781761986720}},"metadata":{"openai":{"itemId":"fc_05fce0a1f1825a85016a3387c236e881919aa039271686fe24"}},"id":"prt_ed94a50880013MKVB3wnd5sJt6","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a12c5001SPqQudSq1aBJpq"}}
