opencode/skills/sk-design/design-audit/references/ai_fingerprint_tells.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/hardening_edge_cases.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/evidence_capture.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/critique_hardening.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/anti_patterns_production.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/transform_remediation.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/audit_contract.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/corpus_map.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-audit/references/accessibility_performance.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-motion/references/motion_strategy.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-motion/references/micro_interactions.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-motion/references/animation_decision_framework.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-motion/references/corpus_map.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-motion/references/performance_reduced_motion.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-des