   174	
   175	def load_template_rules(script_dir: Path) -> Dict[str, Any]:
   176	    """Load template_rules.json from assets folder."""
   177	    rules_path = script_dir.parent / "assets" / "template-rules.json"
   178	    if not rules_path.exists():
   179	        print(f"Error: template_rules.json not found at {rules_path}", file=sys.stderr)
   180	        sys.exit(2)
   181	
   182	    with open(rules_path, 'r', encoding='utf-8') as f:
   183	        return json.load(f)
   184	
   185	
   186	def load_rules() -> Dict[str, Any]:
   187	    """Load template rules for callers importing the validator module."""
   188	    return load_template_rules(Path(__file__).parent)
   189	
   190	
   191	def detect_document_type(file_path: str, content: str, rules: Dict[str, Any]) -> str:
   192	    """Detect document type from file path or content."""
   193	    path_lower = str(file_path).lower()
   194	    assert_supported_root_path(path_lower)
   195	    portable_path = PurePosixPath(path_lower.replace('\\', '/'))
   196	
   197	    if any(f'/{name}/' in path_lower or f'\\{name}\\' in path_lower for name in PLAYBOOK_DIR_NAMES):
   198	        # A per-feature playbook leaf sits one level below the category root
   199	        # (manual-testing-playbook/<category>/<feature>.md). Classify by that structural
   200	        # position rather than an ordinal folder-name prefix, so category folders can be
   201	        # named by meaning alone. The root index file (whose parent IS the
   202	        # manual_testing_playbook dir) is intentionally excluded.
   203	        if portable_path.parent.parent.name in PLAYBOOK_DIR_NAMES:
   204	            return 'playbook_feature'
   205	    # Per-feature catalog leaves sit one level below the catalog root
   206	    # (feature-catalog/<category>/<feature>.md). These carry the Validation And Tests
   207	    # table whose Type taxonomy and placeholder rows the generic readme path misses.
   208	    # Classify by structural position rather than an ordinal folder-name prefix; the
   209	    # root index file (whose parent IS the feature_catalog dir) stays excluded.
   210	    if any(f'/{name}/' in path_lower or f'\\{name}\\' in path_lower for name in CATALOG_DIR_NAMES):
   211	        if portable_path.parent.parent.name in CATALOG_DIR_NAMES:
   212	            return 'feature_catalog'
   213	    if '/command/' in path_lower or '\\command\\' in path_lower or '/commands/' in path_lower or '\\commands\\' in path_lower:
   214	        return 'command'
   215	    if '/install-guides/' in path_lower or '\\install_guides\\' in path_lower:
   216	        return 'install_guide'
   217	    if 'install_guide' in Path(path_lower).stem or 'install-guide' in Path(path_lower).stem:
   218	        return 'install_guide'
   219	    # Changelog files: under .opencode/changelog/, .opencode/skills/*/changelog/,
   220	    # or spec-folder nested changelog/ subdirectories. Files match v{VERSION}.md or changelog-*.md
   221	    if '/changelog/' in path_lower or '\\changelog\\' in path_lower:
   222	        return 'changelog'
   223	    if path_lower.endswith('readme.md'):
   224	        return 'readme'
   225	    if path_lower.endswith('skill.md'):
   226	        return 'skill'
   227	    if '/specs/' in path_lower or '\\specs\\' in path_lower:
   228	        return 'spec'
   229	    if '/agents/' in path_lower or '\\agents\\' in path_lower or '/agent/' in path_lower or '\\agent\\' in path_lower:
   230	        return 'agent'
   231	    if '/references/' in path_lower or '\\references\\' in path_lower:
   232	        return 'reference'
   233	    if '/assets/' in path_lower or '\\assets\\' in path_lower:
   234	        return 'asset'
   235	
   236	    # Default to readme for general markdown
   237	    return 'readme'
   238	
   239	
   240	def has_emoji(text: str) -> bool:
   241	    """Check if text contains an emoji."""
   242	    return bool(EMOJI_PATTERN.search(text))
   243	
   244	
   245	def extract_first_emoji(text: str) -> Optional[str]:
   246	    """Extract the first emoji from text."""
   247	    match = EMOJI_PATTERN.search(text)
   248	    return match.group(0) if match else None
   249	
   250	
   250	
   251	def normalize_section_name(name: str) -> str:
   252	    """Normalize section name for lookup in rules."""
   253	    name = EMOJI_PATTERN.sub('', name)
   254	    name = name.strip().lower().replace(' ', '_')
   255	    name = re.sub(r'[^a-z0-9_]', '', name)
   256	    return name
   257	
   258	
   259	def extract_section_name_text(text: str) -> str:
   260	    """
   261	    Extract the section name text after removing number prefix and emoji.
   262	
   263	    Examples:
   264	        "1. 📖 Overview" -> "Overview"
   265	        "📖 OVERVIEW" -> "OVERVIEW"
   266	        "1. Overview" -> "Overview"
   267	    """
   268	    # Remove leading number and dot (e.g., "1. ")
   269	    text = re.sub(r'^\d+\.\s*', '', text)
   270	    # Remove emoji
   271	    text = EMOJI_PATTERN.sub('', text)
   272	    # Clean up whitespace
   273	    return text.strip()
   274	
   275	
   276	def is_uppercase_section(text: str) -> bool:
   277	    """
   278	    Check if section name is ALL CAPS.
   279	
   280	    Handles special characters like &, ', -, etc.
   281	    Only checks alphabetic characters for case.
   282	
   283	    Examples:
   284	        "OVERVIEW" -> True
   285	        "Overview" -> False
   286	        "INSTALLATION & SETUP" -> True
   287	        "WHAT'S NEXT?" -> True
   288	        "MCP TOOLS" -> True
   289	    """
   290	    section_name = extract_section_name_text(text)
   291	    # Check if all alphabetic characters are uppercase
   292	    alpha_chars = [c for c in section_name if c.isalpha()]
   293	    if not alpha_chars:
   294	        return True  # No alphabetic chars, consider valid
   295	    return all(c.isupper() for c in alpha_chars)
   296	
   297	
   298	def make_uppercase_section(text: str) -> str:
   299	    """
   300	    Convert section name to ALL CAPS while preserving structure.
   301	
   302	    Examples:
   303	        "Overview" -> "OVERVIEW"
   304	        "Quick Start" -> "QUICK START"
   305	        "What's Next?" -> "WHAT'S NEXT?"
   306	    """
   307	    return text.upper()
   308	
   309	
   310	# ───────────────────────────────────────────────────────────────
   311	# 3. TOC VALIDATION
   312	# ───────────────────────────────────────────────────────────────
   313	
   314	def validate_toc(content: str, doc_type_rules: Dict[str, Any], rules: Dict[str, Any]) -> List[Dict[str, Any]]:
   315	    """Validate TABLE OF CONTENTS section."""
   316	    errors = []
   317	
   318	    if not doc_type_rules.get('tocRequired', False):
   319	        return errors
   320	
   321	    # Accept variations with emoji (📑) or without
   322	    # Pattern: ## [optional emoji] TABLE OF CONTENTS
   323	    toc_match = re.search(
   324	        r'## (?:[^\w\s]\s+)?TABLE OF CONTENTS\s*\n(.*?)(?=\n---|\n## |\Z)',
   325	        content,
   326	        re.DOTALL | re.IGNORECASE
   327	    )
   328	
   329	    if not toc_match:
   330	        errors.append({
   331	            'type': 'missing_toc',
   332	            'severity': 'blocking',
   333	            'message': 'Missing TABLE OF CONTENTS section',
   334	            'fix_hint': 'Add "## TABLE OF CONTENTS" section with linked entries'
   335	        })
   336	        return errors
   337	
   338	    toc_content = toc_match.group(1)
   339	
   340	    for line_num, line in enumerate(toc_content.strip().split('\n'), start=1):
   341	        line = line.strip()
   342	        if not line.startswith('- ['):
   343	            continue
   344	
   345	        # Double-dash anchors required for GitHub compatibility
   346	        anchor_match = re.search(r'\(#(\d+)-([a-z])', line)
   347	        if anchor_match:
   348	            errors.append({
   349	                'type': 'toc_single_dash_anchor',
   350	                'severity': 'blocking',
   351	                'message': f'TOC anchor uses single dash instead of double dash',
   352	                'line': line,
   353	                'fix_hint': f'Change "#N-" to "#N--" in anchor',
   354	                'auto_fixable': True,
   355	                'fix': line.replace(f'#{anchor_match.group(1)}-', f'#{anchor_match.group(1)}--')
   356	            })
   357	
   358	        entry_match = re.search(r'\[(.+?)\]', line)
   359	        if entry_match:
   360	            entry_text = entry_match.group(1)
   361	
   362	            # Check for ALL CAPS (only for readme type which requires it)
   363	            uppercase_required = doc_type_rules.get('tocUppercaseRequired', False)
   364	            if uppercase_required and not is_uppercase_section(entry_text):
   365	                section_text = extract_section_name_text(entry_text)
   366	                # Build fixed entry: preserve number and emoji, uppercase the name
   367	                # Pattern: "N. EMOJI name" -> "N. EMOJI NAME"
   368	                fixed_entry = re.sub(
   369	                    r'^(\d+\.\s*)([^\w\s]\s*)?(.+)$',
   370	                    lambda m: f"{m.group(1)}{m.group(2) or ''}{m.group(3).upper()}",
   371	                    entry_text
   372	                )
   373	                fixed_line = line.replace(f'[{entry_text}]', f'[{fixed_entry}]')
   374	
   375	                errors.append({
   376	                    'type': 'toc_not_uppercase',
   377	                    'severity': 'blocking',
   378	                    'message': f'TOC entry not ALL CAPS: "{entry_text}"',
   379	                    'line': line,
   380	                    'auto_fixable': True,
   381	                    'fix': fixed_line,
   382	                    'fix_hint': f'Change "{section_text}" to "{section_text.upper()}"'
   383	                })
   384	
   385	    return errors
   386	
   387	
   388	# ───────────────────────────────────────────────────────────────
   389	# 4. HEADER VALIDATION
   390	# ───────────────────────────────────────────────────────────────
   391	
   392	def _fenced_line_numbers(content: str) -> set:
   393	    """1-based line numbers that fall inside fenced code blocks.
   394	
   395	    Tracks the opening fence's backtick length so a longer outer fence (```` )
   396	    keeps shorter inner fences (```) literal, and a closing fence must be at least
   397	    as long as its opener with no info string. This is why a naive "any ``` opens,
   398	    a bare ``` closes" scan mis-nests 4-backtick doc examples. Used so section
   399	    numbering ignores numbered headers shown inside a copy-able template example —
   400	    they are content, not document sections.
   401	    """
   402	    fenced = set()
   403	    fence_len = 0
   404	    for i, line in enumerate(content.split('\n'), start=1):
   405	        stripped = line.strip()
   406	        if stripped.startswith('```'):
   407	            ticks = len(stripped) - len(stripped.lstrip('`'))
   408	            info = stripped[ticks:].strip()
   409	            fenced.add(i)
   410	            if fence_len == 0:
   411	                fence_len = ticks
   412	            elif ticks >= fence_len and info == '':
   413	                fence_len = 0
   414	            continue
   415	        if fence_len > 0:
   416	            fenced.add(i)
   417	    return fenced
   418	
   419	
   420	def validate_h2_headers(content: str, doc_type_rules: Dict[str, Any], rules: Dict[str, Any]) -> List[Dict[str, Any]]:
   421	    """Validate H2 header format and emojis."""
   422	    errors = []
   423	
   424	    h2_pattern = re.compile(r'^## (\d+)\.\s+(.+)$', re.MULTILINE)
   425	    matches = list(h2_pattern.finditer(content))
   426	    fenced_lines = _fenced_line_numbers(content)
   427	
   428	    if not matches:
   429	        # No numbered H2 headers found - check if this is expected
   430	        # Some documents might use different header styles
   431	        return errors
   432	
   433	    expected_num = 1
   434	    emoji_required = doc_type_rules.get('h2EmojiRequired', True)
   435	    section_emojis = doc_type_rules.get('sectionEmojis', {})
   436	    section_aliases = doc_type_rules.get('sectionAliases', {})
   437	
   438	    for match in matches:
   439	        num = int(match.group(1))
   440	        title = match.group(2).strip()
   441	        line = match.group(0)
   442	
   443	        # A numbered header inside a fenced example (a copy-able skeleton) is
   444	        # content, not a section, so it must not break or advance the outer
   445	        # document sequence. Emoji/uppercase checks below intentionally still
   446	        # apply to every match, keeping their behavior unchanged.
   447	        header_line = content.count('\n', 0, match.start()) + 1
   448	        if header_line not in fenced_lines:
   449	            if num != expected_num:
   450	                errors.append({
   451	                    'type': 'non_sequential_numbering',
   452	                    'severity': 'warning',
   453	                    'message': f'Non-sequential section number: expected {expected_num}, found {num}',
   454	                    'line': line
   455	                })
   456	            expected_num = num + 1
   457	
   458	        if emoji_required:
   459	            title_has_emoji = has_emoji(title)
   460	
   461	            if not title_has_emoji:
   462	                section_name = normalize_section_name(title)
   463	
   464	                if section_name in section_aliases:
   465	                    section_name = section_aliases[section_name]
   466	
   467	                expected_emoji = section_emojis.get(section_name)
   468	
   469	                # Fallback: match ignoring underscores for flexibility
   470	                if not expected_emoji:
   471	                    section_name_no_underscore = section_name.replace('_', '')
   472	                    for key, emoji in section_emojis.items():
   473	                        if key.replace('_', '') == section_name_no_underscore:
   474	                            expected_emoji = emoji
   475	                            break
   476	
   477	                errors.append({
   478	                    'type': 'missing_h2_emoji',
   479	                    'severity': 'blocking',
   480	                    'message': f'H2 header missing emoji: "{line}"',
   481	                    'line': line,
   482	                    'section_name': section_name,
   483	                    'expected_emoji': expected_emoji,
   484	                    'auto_fixable': expected_emoji is not None,
   485	                    'fix': f'## {num}. {expected_emoji} {title}' if expected_emoji else None,
   486	                    'fix_hint': f'Add {expected_emoji} after "{num}."' if expected_emoji else 'Add appropriate emoji after section number'
   487	                })
   488	
   489	        # Check for ALL CAPS (only for document types that require it)
   490	        uppercase_required = doc_type_rules.get('h2UppercaseRequired', False)
   491	        if uppercase_required and not is_uppercase_section(title):
   492	            section_text = extract_section_name_text(title)
   493	            # Extract emoji if present
   494	            emoji = extract_first_emoji(title)
   495	
   496	            if emoji:
   497	                # Has emoji: "EMOJI name" -> "EMOJI NAME"
   498	                title_after_emoji = EMOJI_PATTERN.sub('', title).strip()
   499	                fixed_title = f'{emoji} {title_after_emoji.upper()}'
   500	            else:
   501	                # No emoji: just uppercase
   502	                fixed_title = title.upper()
   503	
   504	            errors.append({
   505	                'type': 'h2_not_uppercase',
   506	                'severity': 'blocking',
   507	                'message': f'H2 header not ALL CAPS: "{line}"',
   508	                'line': line,
   509	                'auto_fixable': True,
   510	                'fix': f'## {num}. {fixed_title}',
   511	                'fix_hint': f'Change "{section_text}" to "{section_text.upper()}"'
   512	            })
   513	
   514	    return errors
   515	
   516	
   517	# ───────────────────────────────────────────────────────────────
   518	# 5. SECTION VALIDATION
   519	# ───────────────────────────────────────────────────────────────
   520	
   521	def validate_required_sections(content: str, doc_type_rules: Dict[str, Any]) -> List[Dict[str, Any]]:
   522	    """Check that required sections are present."""
   523	    errors = []
   524	
   525	    required = doc_type_rules.get('requiredSections', [])
   526	    section_aliases = doc_type_rules.get('sectionAliases', {})
   527	
   528	    # Compiled-contract commands are thin runtime dispatchers whose section content is
   529	    # rendered from a compiled source at invocation, not written in the .md file, so
   530	    # there is no prose section shape to require here.
   531	    contract_marker = doc_type_rules.get('compiledContractMarker')
   532	    if contract_marker and contract_marker in content:
   533	        return errors
   534	
   535	    # Build reverse alias map
   536	    reverse_aliases = {}
   537	    for alias, canonical in section_aliases.items():
   538	        reverse_aliases.setdefault(canonical, []).append(alias)
   539	
   540	    h2_pattern = re.compile(r'^## \d+\.\s+[^\n]+', re.MULTILINE)
   541	    headers = h2_pattern.findall(content)
   542	
   543	    # Keep both normalized and raw names for partial matching fallback
   544	    found_sections = set()
   545	    found_sections_raw = []
   546	    for header in headers:
   547	        match = re.search(r'^## \d+\.\s+(?:[^\w\s]\s+)?(.+)$', header)
   548	        if match:
   549	            raw_name = match.group(1).strip().lower()
   550	            section_name = normalize_section_name(raw_name)
   551	            found_sections.add(section_name)
   552	            found_sections_raw.append(raw_name)
   553	
   554	            if section_name in section_aliases:
   555	                found_sections.add(section_aliases[section_name])
   556	
   557	    # A router command is a thin dispatcher (verify agent -> resolve mode/args -> hand
   558	    # off to owned presentation/workflow assets). It carries a router-specific section
   559	    # vocabulary instead of the general purpose/instructions sections, so detect that
   560	    # shape and require only the minimal router core, treating the rest as recommended.
   560	    # shape and require only the minimal router core, treating the rest as recommended.
   561	    # A section counts as present if its canonical name is a found header OR a known
   562	    # space-form alias of it normalizes (space->underscore) to a found header.
   563	    def section_present(canonical: str) -> bool:
   564	        if canonical in found_sections:
   565	            return True
   566	        for alias in reverse_aliases.get(canonical, []):
   567	            if alias.replace(' ', '_') in found_sections:
   568	                return True
   569	        return False
   570	
   571	    detect_primary = doc_type_rules.get('routerDetectPrimary', [])
   572	    structural = doc_type_rules.get('routerStructuralSections', [])
   573	    is_router = (
   574	        any(section_present(sig) for sig in detect_primary)
   575	        or sum(1 for sig in structural if section_present(sig)) >= 2
   576	    )
   577	    if is_router:
   578	        required = doc_type_rules.get('routerRequiredSections', required)
   579	
   580	    for req_section in required:
   581	        found = req_section in found_sections
   582	
   583	        if not found:
   584	            aliases = reverse_aliases.get(req_section, [])
   585	            for alias in aliases:
   586	                if alias.replace(' ', '_') in found_sections:
   587	                    found = True
   588	                    break
   589	
   590	        # Fuzzy match: accept if all required words appear in section name
   591	        if not found:
   592	            req_words = req_section.replace('_', ' ').split()
   593	            for raw_section in found_sections_raw:
   594	                if all(word in raw_section for word in req_words):
   595	                    found = True
   596	                    break
   597	
   598	        if not found:
   599	            errors.append({
   600	                'type': 'missing_required_section',
   601	                'severity': 'blocking',
   602	                'message': f'Missing required section: {req_section}',
   603	                'fix_hint': f'Add section with name containing "{req_section}"'
   604	            })
   605	
   606	    # Router shape beyond the minimal core is recommended, not required: surface any
   607	    # missing canonical router section as a non-blocking warning so authors converge on
   608	    # the full vocabulary without failing incremental migrations.
   609	    if is_router:
   610	        for rec_section in doc_type_rules.get('routerRecommendedSections', []):
   611	            if not section_present(rec_section):
   612	                errors.append({
   613	                    'type': 'missing_recommended_router_section',
   614	                    'severity': 'warning',
   615	                    'message': f'Missing recommended router section: {rec_section}',
   616	                    'fix_hint': f'Add a "{rec_section}" section (recommended for router commands)'
   617	                })
   618	
   619	    return errors
   620	
   621	
   622	# ───────────────────────────────────────────────────────────────
   623	# 6. AUTO-FIX
   624	# ───────────────────────────────────────────────────────────────
   625	
   626	def apply_fixes(content: str, errors: List[Dict[str, Any]]) -> Tuple[str, List[Dict[str, Any]]]:
   627	    """
   628	    Apply auto-fixes to content.
   629	
   630	    Uses iterative approach: after each fix, re-validates and applies more fixes
   631	    until no more fixes can be applied. This handles cases where multiple fixes
   632	    affect the same line (e.g., single-dash anchor AND missing emoji).
   633	    """
   634	    fixed_content = content
   635	    all_fixes_applied = []
   636	    max_iterations = 10  # Safety limit
   637	
   638	    for iteration in range(max_iterations):
   639	        fixes_this_round = []
   640	
   641	        for error in errors:
   642	            if not error.get('auto_fixable'):
   643	                continue
   644	
   645	            fix = error.get('fix')
   646	            original = error.get('line')
   647	
   648	            if fix and original and original in fixed_content:
   649	                fixed_content = fixed_content.replace(original, fix, 1)
   650	                fixes_this_round.append({
   651	                    'type': error['type'],
   652	                    'original': original,
   653	                    'fixed': fix
   654	                })
   655	
   656	        if not fixes_this_round:
   657	            # No more fixes could be applied
   658	            break
   659	
   660	        all_fixes_applied.extend(fixes_this_round)
   661	
   662	        # Re-validate to get updated error list with new line content
   663	        # This allows subsequent fixes to find the modified lines
   664	        # Re-run validation on the fixed content to get fresh errors
   665	        script_dir = Path(__file__).parent
   666	        rules = load_template_rules(script_dir)
   667	
   668	        # Detect doc type from original errors or default to readme
   669	        doc_type = 'readme'
   670	        for e in errors:
   671	            if 'skill' in str(e.get('line', '')).lower():
   672	                doc_type = 'skill'
   673	                break
   674	
   675	        # Get fresh errors based on current fixed content
   676	        doc_type_rules = rules.get('documentTypes', {}).get(doc_type, {})
   677	        errors = []
   678	        errors.extend(validate_toc(fixed_content, doc_type_rules, rules))
   679	        errors.extend(validate_h2_headers(fixed_content, doc_type_rules, rules))
   680	
   681	    return fixed_content, all_fixes_applied
   682	
   683	
   684	# ───────────────────────────────────────────────────────────────
   685	# 7. MAIN VALIDATION
   686	# ───────────────────────────────────────────────────────────────
   687	
   688	def validate_feature_catalog_table(content: str, doc_type_rules: Dict[str, Any]) -> List[Dict[str, Any]]:
   689	    """Validate a feature-catalog leaf's 'Validation And Tests' table.
   690	
   691	    The generic readme path misses two drift classes here: placeholder rows (an em-dash File and Role
   692	    with a filler Type) that pass as 'valid' while documenting no real coverage, and off-taxonomy Type
   693	    values. The per-feature template defines Type as exactly {Automated test | Manual playbook}; anything
   694	    else (Integration, Manual scenario contract, a bare em-dash) hides missing or mislabeled tests.
   695	    Un-filled template rows (`{TEST_FILE_1}`) are skipped so a fresh scaffold does not fail.
   696	    """
   697	    errors: List[Dict[str, Any]] = []
   698	    allowed = set(doc_type_rules.get('allowedValidationTypes', ['Automated test', 'Manual playbook']))
   699	    dash = {'—', '-', '–', ''}
   700	    lines = content.split('\n')
   701	    in_table = False
   702	    for i, line in enumerate(lines):
   703	        stripped = line.strip()
   704	        if re.match(r'^\|\s*File\s*\|\s*Type\s*\|\s*Role\s*\|', stripped):
   705	            in_table = True
   706	            continue
   707	        if not in_table:
   708	            continue
   709	        if not stripped.startswith('|'):
   710	            in_table = False
   711	            continue
   712	        if re.match(r'^\|[\s|:\-]+\|$', stripped):  # |---|---|---| separator
   713	            continue
   714	        cells = [c.strip() for c in stripped.strip('|').split('|')]
   715	        if len(cells) < 3:
   716	            continue
   717	        file_cell, type_cell, role_cell = cells[0], cells[1], cells[2]
   718	        if '{' in file_cell or '{' in type_cell:  # un-filled template row
   719	            continue
   720	        if file_cell in dash and role_cell in dash:
   721	            errors.append({
   722	                'type': 'placeholder_validation_row',
   723	                'line': i + 1, 'severity': 'blocking', 'auto_fixable': False,
   724	                'message': (f"Placeholder validation-table row (File and Role are em-dashes, Type "
   725	                            f"'{type_cell}') — replace with a real test file + role, or remove the row."),
   726	            })
   727	        type_bare = type_cell.strip('`').strip()
   728	        # Advisory only: the live corpus uses ~35 descriptive Type values (Vitest, Fixture, MCP
   729	        # integration test, ...), so the template's 2-value taxonomy is de-facto stale. Warn to
   730	        # surface the inconsistency for a normalization decision rather than block a third of catalogs.
   731	        if type_bare and type_bare not in allowed:
   732	            errors.append({
   733	                'type': 'off_taxonomy_validation_type',
   734	                'line': i + 1, 'severity': 'warning', 'auto_fixable': False,
   735	                'message': (f"Off-taxonomy validation Type '{type_bare}' — template canon is "
   736	                            f"{' | '.join(sorted(allowed))} (advisory: taxonomy needs normalization)."),
   737	            })
   738	    return errors
   739	
   740	
   741	def validate_agent_frontmatter(content: str, file_path: str) -> List[Dict[str, Any]]:
   742	    """Validate an agent file's frontmatter against its runtime-specific schema.
   743	
   744	    `.claude/agents/` files must use the `tools:` allow-list — Claude Code enforces only
   745	    `tools:` and silently ignores `permission:`; an absent `tools:` inherits the parent
   746	    session's full, unrestricted tool set (the AGT-02 defect class).
   747	    `.opencode/agents/` files must use the `permission:` object — OpenCode enforces only
   748	    `permission:` and silently ignores `tools:`.
   749	    Runtime is detected from the file's own path (never a global default), matching the
   750	    same path-resolution invariant AGT-01 depends on.
   751	    """
   752	    errors: List[Dict[str, Any]] = []
   753	
   754	    path_str = str(file_path).replace('\\', '/')
