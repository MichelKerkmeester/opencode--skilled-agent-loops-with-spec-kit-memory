= pg_insert(OrganizationSettings).values(org_id=tenant_id, settings=merged)\n\n  Line 846:         pg_insert(OrganizationSettingsAudit).values(org_id=tenant_id, changed_by=changed_by, diff=diff)\n","metadata":{"matches":17,"truncated":false},"title":"OrganizationSettingsAudit|diff|changed_by|insert","time":{"start":1780727767451,"end":1780727767467}},"metadata":{"openai":{"itemId":"fc_0084bcace3164019016a23bfd656c88191b89a16ebf7215bd8"}},"id":"prt_e9ba55d54001CQPhiSIec6xUcN","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba5513a001QyjtQ0spafTYOZ"}}
