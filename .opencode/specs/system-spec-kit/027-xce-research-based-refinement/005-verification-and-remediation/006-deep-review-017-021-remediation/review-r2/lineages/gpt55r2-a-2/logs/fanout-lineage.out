annotations.evidenceGapWarning && formatted?.content?.[0]?.text) {\n1414:       try {\n1415:         const parsed = JSON.parse(formatted.content[0].text) as Record<string, unknown>;\n1416:         if (typeof parsed.summary === 'string') {\n1417:           parsed.summary = `${pipelineResult.annotations.evidenceGapWarning}\\n\\n${parsed.summary}`;\n1418:           formatted.content[0].text = JSON.stringify(parsed, null, 2);\n1419:         }\n1420:       } catch (_error: unknown) {\n1421:         // Non-fatal\n1422:       }\n1423:     }\n1424:     if (isProgressiveDisclosureEnabled()) {\n1425:       const parsedFormatted = parseResponseEnvelope(formatted);\n1426:       if (parsedFormatted) {\n1427:         const data = parsedFormatted.envelope.data && typeof parsedFormatted.envelope.data === 'object'\n1428:           ? parsedFormatted.envelope.data as Record<string, unknown>\n1429:           : {};\n1430:         data.progressiveDisclosure = buildProgressiveResponse(\n1431:           resultsForFormatting,\n1432:           undefined,\n1433:           effectiveQuery,\n1434:           { scopeKey: progressiveScopeKey },\n1435:         );\n1436:         parsedFormatted.envelope.data = data;\n1437:         formatted = replaceResponseEnvelope(formatted, parsedFormatted.firstEntry, parsedFormatted.envelope);\n1438:       }\n1439:     }\n1440: \n1441:     formatted = applyPublicationGateToResponse(formatted);\n1442: \n1443:     const cachePayload = extractSearchCachePayload(formatted);\n1444:     if (cachePayload && cacheEnabled) {\n1445:       toolCache.set(cacheKey, cachePayload, { toolName: 'memory_search' });\n1446:     }\n1447: \n1448:     responseToReturn = cachePayload\n1449:       ? buildSearchResponseFromPayload(cachePayload, _searchStartTime, false)\n1450:       : formatted;\n1451:   }\n1452: \n1453:   responseToReturn = applyPublicationGateToResponse(responseToReturn);\n1454: \n1455:   if (sessionId && isSessionRetrievalStateEnabled() && !sessionManager.isEnabled()) {\n1456:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1457:     const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n1458:       ? parsedResponse.envelope.data as Record<string, unknown>\n1459:       : null;\n1460:     const existingResults = Array.isArray(data?.results) ? data.results as SessionAwareResult[] : null;\n1461: \n1462:     if (parsedResponse && data && existingResults && existingResults.length > 0) {\n1463:       const deduped = deduplicateWithSessionState(existingResults, sessionId);\n1464:       reconcilePostFormatResultSet(data, deduped.results as Array<Record<string, unknown>>);\n1465:       data.sessionDedup = deduped.metadata;\n1466:       parsedResponse.envelope.data = data;\n1467:       responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n1468:     }\n1469:   }\n1470: \n1471:   // Apply session deduplication AFTER cache\n1472:   if (sessionId && enableDedup && sessionManager.isEnabled()) {\n1473:     let resultsData: Record<string, unknown> | null = null;\n1474:     if (responseToReturn?.content?.[0]?.text && typeof responseToReturn.content[0].text === 'string') {\n1475:       try {\n1476:         resultsData = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1477:       } catch (err: unknown) {\n1478:         const message = toErrorMessage(err);\n1479:         console.warn('[memory-search] Failed to parse cached response for dedup:', message);\n1480:         resultsData = null;\n1481:       }\n1482:     } else if (responseToReturn && typeof responseToReturn === 'object') {\n1483:       resultsData = responseToReturn as unknown as Record<string, unknown>;\n1484:     }\n1485: \n1486:     // Validate response shape before dedup. If the cached response\n1487:     // Doesn't have the expected data.results array, log a warning and skip dedup\n1488:     // Rather than silently falling through to the un-deduped response.\n1489:     const data = (resultsData && typeof resultsData.data === 'object' && resultsData.data !== null)\n1490:       ? resultsData.data as Record<string, unknown>\n1491:       : null;\n1492:     const existingResults = Array.isArray(data?.results) ? data.results as MemorySearchRow[] : null;\n1493: \n1494:     if (resultsData && !data) {\n1495:       console.warn('[memory-search] Cached response shape mismatch: missing \"data\" object, skipping dedup');\n1496:     } else if (data && !existingResults) {\n1497:       console.warn('[memory-search] Cached response shape mismatch: \"data.results\" is not an array, skipping dedup');\n1498:     }\n1499: \n1500:     if (resultsData && data && existingResults && existingResults.length > 0) {\n1501:       const { results: dedupedResults } = applySessionDedup(\n1502:         existingResults,\n1503:         sessionId,\n1504:         enableDedup\n1505:       );\n1506: \n1507:       const originalCount = existingResults.length;\n1508:       const dedupedCount = dedupedResults.length;\n1509:       const filteredCount = originalCount - dedupedCount;\n1510: \n1511:       const tokensSaved = filteredCount * 200;\n1512:       const savingsPercent = originalCount > 0\n1513:         ? Math.round((filteredCount / originalCount) * 100)\n1514:         : 0;\n1515: \n1516:       reconcilePostFormatResultSet(data, dedupedResults as Array<Record<string, unknown>>);\n1517: \n1518:       const dedupStats = {\n1519:         enabled: true,\n1520:         sessionId,\n1521:         originalCount: originalCount,\n1522:         returnedCount: dedupedCount,\n1523:         filteredCount: filteredCount,\n1524:         tokensSaved: tokensSaved,\n1525:         savingsPercent: savingsPercent,\n1526:         tokenSavingsEstimate: tokensSaved > 0 ? `~${tokensSaved} tokens` : '0'\n1527:       };\n1528:       resultsData.dedupStats = dedupStats;\n1529: \n1530:       if (resultsData.meta && typeof resultsData.meta === 'object') {\n1531:         (resultsData.meta as Record<string, unknown>).dedupStats = dedupStats;\n1532:       }\n1533: \n1534:       if (filteredCount > 0 && typeof resultsData.summary === 'string') {\n1535:         resultsData.summary += ` (${filteredCount} duplicates filtered, ~${tokensSaved} tokens saved)`;\n1536:       }\n1537: \n1538:       responseToReturn = {\n1539:         ...responseToReturn,\n1540:         content: [{ type: 'text', text: JSON.stringify(resultsData, null, 2) }]\n1541:       } as MCPResponse;\n1542:     }\n1543:   }\n1544: \n1545:   if (sessionId && isSessionRetrievalStateEnabled()) {\n1546:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1547:     const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n1548:       ? parsedResponse.envelope.data as Record<string, unknown>\n1549:       : null;\n1550:     const existingResults = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1551: \n1552:     if (parsedResponse && data) {\n1553:       const returnedIds = existingResults\n1554:         .map((result) => result.id ?? result.resultId)\n1555:         .filter((id): id is string | number => typeof id === 'string' || typeof id === 'number');\n1556: \n1557:       if (returnedIds.length > 0) {\n1558:         retrievalSessionStateManager.markSeen(sessionId, returnedIds);\n1559:       }\n1560: \n1561:       data.sessionState = buildSessionStatePayload(sessionId);\n1562:       if (goalRefinementPayload) {\n1563:         data.goalRefinement = goalRefinementPayload;\n1564:       }\n1565: \n1566:       parsedResponse.envelope.data = data;\n1567:       responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n1568:     }\n1569:   }\n1570: \n1571:   if (includeTrace && sessionTransition) {\n1572:     responseToReturn = attachSessionTransitionTrace(responseToReturn, sessionTransition);\n1573:   }\n1574: \n1575:   if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n1576:     const telemetry = retrievalTelemetry.createTelemetry();\n1577:     retrievalTelemetry.recordTransitionDiagnostics(telemetry, sessionTransition);\n1578:     retrievalTelemetry.recordGraphWalkDiagnostics(\n1579:       telemetry,\n1580:       summarizeGraphWalkDiagnostics(extractResponseResults(responseToReturn)),\n1581:     );\n1582:     responseToReturn = attachTelemetryMeta(responseToReturn, retrievalTelemetry.toJSON(telemetry));\n1583:   }\n1584: \n1585:   if (searchDecisionEnvelope) {\n1586:     recordSearchDecision({\n1587:       ...searchDecisionEnvelope,\n1588:       latencyMs: Date.now() - _searchStartTime,\n1589:     });\n1590:   }\n1591: \n1592:   // Consumption instrumentation — log search event (fail-safe, never throws)\n1593:   try {\n1594:     const db = (() => { try { return requireDb(); } catch (_error: unknown) { return null; } })();\n1595:     if (db) {\n1596:       initConsumptionLog(db);\n1597:       let resultIds: number[] = [];\n1598:       let resultCount = 0;\n1599:       try {\n1600:         if (responseToReturn?.content?.[0]?.text) {\n1601:           const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1602:           const data = parsed?.data as Record<string, unknown> | undefined;\n1603:           const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1604:           resultIds = results.map(r => r.id as number).filter(id => typeof id === 'number');\n1605:           resultCount = Array.isArray(data?.results) ? (data.results as unknown[]).length : 0;\n1606:         }\n1607:       } catch (_error: unknown) { /* ignore parse errors */ }\n1608:       logConsumptionEvent(db, {\n1609:         event_type: 'search',\n1610:         query: effectiveQuery || null,\n1611:         intent: detectedIntent,\n1612:         result_count: resultCount,\n1613:         result_ids: resultIds,\n1614:         session_id: sessionId ?? null,\n1615:         latency_ms: Date.now() - _searchStartTime,\n1616:         spec_folder_filter: specFolder ?? null,\n1617:       });\n1618:     }\n1619:   } catch (_error: unknown) { /* instrumentation must never cause search to fail */ }\n1620: \n1621:   // Eval logger — capture final results at pipeline exit (fail-safe)\n1622:   try {\n1623:     if (_evalRunId && _evalQueryId) {\n1624:       let finalMemoryIds: number[] = [];\n1625:       let finalScores: number[] = [];\n1626:       try {\n1627:         if (responseToReturn?.content?.[0]?.text) {\n1628:           const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1629:           const data = parsed?.data as Record<string, unknown> | undefined;\n1630:           const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1631:           finalMemoryIds = results.map(r => r.id as number).filter(id => typeof id === 'number');\n1632:           finalScores = results.map(r => (r.score ?? r.similarity ?? 0) as number);\n1633:         }\n1634:       } catch (_error: unknown) { /* ignore parse errors */ }\n1635:       logFinalResult({\n1636:         evalRunId: _evalRunId,\n1637:         queryId: _evalQueryId,\n1638:         resultMemoryIds: finalMemoryIds,\n1639:         scores: finalScores,\n1640:         fusionMethod: 'rrf',\n1641:         latencyMs: Date.now() - _searchStartTime,\n1642:       });\n1643: \n1644:       for (const payload of _evalChannelPayloads) {\n1645:         logChannelResult({\n1646:           evalRunId: _evalRunId,\n1647:           queryId: _evalQueryId,\n1648:           channel: payload.channel,\n1649:           resultMemoryIds: payload.resultMemoryIds,\n1650:           scores: payload.scores,\n1651:           hitCount: payload.resultMemoryIds.length,\n1652:         });\n1653:       }\n1654:     }\n1655:   } catch (_error: unknown) { /* eval logging must never break search */ }\n1656: \n1657:   // Implicit feedback — log search_shown events for returned results\n1658:   // Shadow-only: no ranking side effects. Fail-safe, never throws.\n1659:   try {\n1660:     if (isImplicitFeedbackLogEnabled()) {\n1661:       const db = (() => { try { return requireDb(); } catch (_error: unknown) { return null; } })();\n1662:       if (db) {\n1663:         let shownMemoryIds: number[] = [];\n1664:         try {\n1665:           if (responseToReturn?.content?.[0]?.text) {\n1666:             const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1667:             const data = parsed?.data as Record<string, unknown> | undefined;\n1668:             const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1669:             shownMemoryIds = results.map(r => r.id as number).filter(id => typeof id === 'number');\n1670:           }\n1671:         } catch (_error: unknown) { /* ignore parse errors */ }\n1672: \n1673:         if (shownMemoryIds.length > 0) {\n1674:           const queryId = _evalQueryId ? String(_evalQueryId) : String(_searchStartTime);\n1675:           const feedbackEvents: FeedbackEvent[] = shownMemoryIds.map(memId => ({\n1676:             type: 'search_shown',\n1677:             memoryId: String(memId),\n1678:             queryId,\n1679:             confidence: 'weak',\n1680:             timestamp: _searchStartTime,\n1681:             sessionId: sessionId ?? null,\n1682:           }));\n1683:           logFeedbackEvents(db, feedbackEvents);\n1684:         }\n1685:       }\n1686:     }\n1687:   } catch (_error: unknown) { /* feedback logging must never break search */ }\n1688: \n1689:   // Query flow tracking + result_cited for includeContent searches\n1690:   // Shadow-only: emits query_reformulated, same_topic_requery, and result_cited events.\n1691:   try {\n1692:     if (isImplicitFeedbackLogEnabled()) {\n1693:       const db = (() => { try { return requireDb(); } catch (_error: unknown) { return null; } })();\n1694:       if (db) {\n1695:         // Extract shown memory IDs from response (reuse parsed data if available)\n1696:         let shownIds: string[] = [];\n1697:         try {\n1698:           if (responseToReturn?.content?.[0]?.text) {\n1699:             const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1700:             const data = parsed?.data as Record<string, unknown> | undefined;\n1701:             const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1702:             shownIds = results.flatMap((result) => {\n1703:               const candidate = result.id;\n1704:               if (typeof candidate !== 'number' && typeof candidate !== 'string') {\n1705:                 return [];\n1706:               }\n1707:               const normalizedId = String(candidate).trim();\n1708:               if (!normalizedId || normalizedId === 'undefined' || normalizedId === 'null') {\n1709:                 return [];\n1710:               }\n1711:               return [normalizedId];\n1712:             });\n1713:           }\n1714:         } catch (_error: unknown) { /* ignore parse errors */ }\n1715: \n1716:         const queryId = _evalQueryId ? String(_evalQueryId) : String(_searchStartTime);\n1717: \n1718:         // Track query flow — detects reformulations and same-topic re-queries\n1719:         if (normalizedQuery) {\n1720:           trackQueryAndDetect(db, sessionId ?? null, normalizedQuery, queryId, shownIds);\n1721:         }\n1722: \n1723:         // Log result_cited for includeContent searches (content was embedded = cited)\n1724:         if (includeContent && shownIds.length > 0) {\n1725:           logResultCited(db, sessionId ?? null, queryId, shownIds);\n1726:         }\n1727:       }\n1728:     }\n1729:   } catch (_error: unknown) { /* query flow tracking must never break search */ }\n1730: \n1731:   // Apply presentation profile when flag is enabled and profile is specified.\n1732:   // Phase C: effectiveProfile includes auto-routed profile from intent detection.\n1733:   if (effectiveProfile && typeof effectiveProfile === 'string' && isResponseProfileEnabled()) {\n1734:     const firstEntry = responseToReturn?.content?.[0];\n1735:     if (firstEntry && typeof firstEntry.text === 'string') {\n1736:       try {\n1737:         const profiled = applyProfileToEnvelope(effectiveProfile, firstEntry.text);\n1738:         if (profiled !== firstEntry.text) {\n1739:           responseToReturn = {\n1740:             ...responseToReturn,\n1741:             content: [{ ...firstEntry, text: profiled }],\n1742:           } as MCPResponse;\n1743:         }\n1744:       } catch (_profileError: unknown) {\n1745:         // Profile formatting is best-effort — never breaks search\n1746:       }\n1747:     }\n1748:   }\n1749: \n1750:   responseToReturn = attachLexicalCapabilityMetadata(\n1751:     responseToReturn,\n1752:     getLastLexicalCapabilitySnapshot(),\n1753:   );\n1754: \n1755:   return responseToReturn;\n1756: }\n1757: \n1758: /* ───────────────────────────────────────────────────────────────\n1759:    11. EXPORTS\n1760: ──────────────────────────────────────────────────────────────── */\n1761: \n1762: export {\n1763:   handleMemorySearch,\n1764: };\n1765: \n1766: export const __testables = {\n1767:   filterByMinQualityScore,\n1768:   resolveQualityThreshold,\n1769:   buildCacheArgs,\n1770:   resolveRowContextType,\n1771:   resolveArtifactRoutingQuery,\n1772:   applyArtifactRouting,\n1773:   collapseAndReassembleChunkResults,\n1774:   attachLexicalCapabilityMetadata,\n1775:   collectEvalChannelsFromRow,\n1776:   buildEvalChannelPayloads,\n1777:   filterCanonicalSourceRows,\n1778:   stampFinalRankScores,\n1779:   applyFolderBoostRanking,\n1780:   reconcilePostFormatResultSet,\n1781: };\n1782: \n1783: // Backward-compatible aliases (snake_case)\n1784: const handle_memory_search = handleMemorySearch;\n1785: \n1786: export {\n1787:   handle_memory_search,\n1788: };\n\n(End of file - total 1788 lines)\n</content>","metadata":{"preview":"        extraData.adaptive_shadow = adaptiveShadow;\n      }\n    } catch (_error: unknown) {\n      // Adaptive proposal logging is best-effort only\n    }\n\n    const appliedBoosts: Record<string, unknown> = {\n      session: { applied: pipelineResult.metadata.stage2.sessionBoostApplied },\n      causal: { applied: pipelineResult.metadata.stage2.causalBoostApplied },\n    };\n    if (folderBoost && folderBoost.folder) {\n      appliedBoosts.folder = { applied: true, folder: folderBoost.folder, factor: folderBoost.factor };\n    }\n    if (communityFallbackApplied) {\n      appliedBoosts.communityFallback = { applied: true, retrievalLevel };\n    }\n    extraData.appliedBoosts = appliedBoosts;\n    extraData.applied_boosts = appliedBoosts;\n\n    let formatted = await formatSearchResults(","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"        extraData.adaptive_shadow = adaptiveShadow;\n      }\n    } catch (_error: unknown) {\n      // Adaptive proposal logging is best-effort only\n    }\n\n    const appliedBoosts: Record<string, unknown> = {\n      session: { applied: pipelineResult.metadata.stage2.sessionBoostApplied },\n      causal: { applied: pipelineResult.metadata.stage2.causalBoostApplied },\n    };\n    if (folderBoost && folderBoost.folder) {\n      appliedBoosts.folder = { applied: true, folder: folderBoost.folder, factor: folderBoost.factor };\n    }\n    if (communityFallbackApplied) {\n      appliedBoosts.communityFallback = { applied: true, retrievalLevel };\n    }\n    extraData.appliedBoosts = appliedBoosts;\n    extraData.applied_boosts = appliedBoosts;\n\n    let formatted = await formatSearchResults(\n      resultsForFormatting as RawSearchResult[],\n      pipelineConfig.searchType,\n      includeContent,\n      anchors,\n      null,\n      null,\n      extraData,\n      includeTrace,\n      normalizedQuery,   // pass query for recovery + confidence context\n      specFolder ?? null // pass specFolder for recovery narrowing detection\n    );\n\n    // Prepend evidence gap warning if present\n    if (pipelineResult.annotations.evidenceGapWarning && formatted?.content?.[0]?.text) {\n      try {\n        const parsed = JSON.parse(formatted.content[0].text) as Record<string, unknown>;\n        if (typeof parsed.summary === 'string') {\n          parsed.summary = `${pipelineResult.annotations.evidenceGapWarning}\\n\\n${parsed.summary}`;\n          formatted.content[0].text = JSON.stringify(parsed, null, 2);\n        }\n      } catch (_error: unknown) {\n        // Non-fatal\n      }\n    }\n    if (isProgressiveDisclosureEnabled()) {\n      const parsedFormatted = parseResponseEnvelope(formatted);\n      if (parsedFormatted) {\n        const data = parsedFormatted.envelope.data && typeof parsedFormatted.envelope.data === 'object'\n          ? parsedFormatted.envelope.data as Record<string, unknown>\n          : {};\n        data.progressiveDisclosure = buildProgressiveResponse(\n          resultsForFormatting,\n          undefined,\n          effectiveQuery,\n          { scopeKey: progressiveScopeKey },\n        );\n        parsedFormatted.envelope.data = data;\n        formatted = replaceResponseEnvelope(formatted, parsedFormatted.firstEntry, parsedFormatted.envelope);\n      }\n    }\n\n    formatted = applyPublicationGateToResponse(formatted);\n\n    const cachePayload = extractSearchCachePayload(formatted);\n    if (cachePayload && cacheEnabled) {\n      toolCache.set(cacheKey, cachePayload, { toolName: 'memory_search' });\n    }\n\n    responseToReturn = cachePayload\n      ? buildSearchResponseFromPayload(cachePayload, _searchStartTime, false)\n      : formatted;\n  }\n\n  responseToReturn = applyPublicationGateToResponse(responseToReturn);\n\n  if (sessionId && isSessionRetrievalStateEnabled() && !sessionManager.isEnabled()) {\n    const parsedResponse = parseResponseEnvelope(responseToReturn);\n    const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n      ? parsedResponse.envelope.data as Record<string, unknown>\n      : null;\n    const existingResults = Array.isArray(data?.results) ? data.results as SessionAwareResult[] : null;\n\n    if (parsedResponse && data && existingResults && existingResults.length > 0) {\n      const deduped = deduplicateWithSessionState(existingResults, sessionId);\n      reconcilePostFormatResultSet(data, deduped.results as Array<Record<string, unknown>>);\n      data.sessionDedup = deduped.metadata;\n      parsedResponse.envelope.data = data;\n      responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n    }\n  }\n\n  // Apply session deduplication AFTER cache\n  if (sessionId && enableDedup && sessionManager.isEnabled()) {\n    let resultsData: Record<string, unknown> | null = null;\n    if (responseToReturn?.content?.[0]?.text && typeof responseToReturn.content[0].text === 'string') {\n      try {\n        resultsData = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n      } catch (err: unknown) {\n        const message = toErrorMessage(err);\n        console.warn('[memory-search] Failed to parse cached response for dedup:', message);\n        resultsData = null;\n      }\n    } else if (responseToReturn && typeof responseToReturn === 'object') {\n      resultsData = responseToReturn as unknown as Record<string, unknown>;\n    }\n\n    // Validate response shape before dedup. If the cached response\n    // Doesn't have the expected data.results array, log a warning and skip dedup\n    // Rather than silently falling through to the un-deduped response.\n    const data = (resultsData && typeof resultsData.data === 'object' && resultsData.data !== null)\n      ? resultsData.data as Record<string, unknown>\n      : null;\n    const existingResults = Array.isArray(data?.results) ? data.results as MemorySearchRow[] : null;\n\n    if (resultsData && !data) {\n      console.warn('[memory-search] Cached response shape mismatch: missing \"data\" object, skipping dedup');\n    } else if (data && !existingResults) {\n      console.warn('[memory-search] Cached response shape mismatch: \"data.results\" is not an array, skipping dedup');\n    }\n\n    if (resultsData && data && existingResults && existingResults.length > 0) {\n      const { results: dedupedResults } = applySessionDedup(\n        existingResults,\n        sessionId,\n        enableDedup\n      );\n\n      const originalCount = existingResults.length;\n      const dedupedCount = dedupedResults.length;\n      const filteredCount = originalCount - dedupedCount;\n\n      const tokensSaved = filteredCount * 200;\n      const savingsPercent = originalCount > 0\n        ? Math.round((filteredCount / originalCount) * 100)\n        : 0;\n\n      reconcilePostFormatResultSet(data, dedupedResults as Array<Record<string, unknown>>);\n\n      const dedupStats = {\n        enabled: true,\n        sessionId,\n        originalCount: originalCount,\n        returnedCount: dedupedCount,\n        filteredCount: filteredCount,\n        tokensSaved: tokensSaved,\n        savingsPercent: savingsPercent,\n        tokenSavingsEstimate: tokensSaved > 0 ? `~${tokensSaved} tokens` : '0'\n      };\n      resultsData.dedupStats = dedupStats;\n\n      if (resultsData.meta && typeof resultsData.meta === 'object') {\n        (resultsData.meta as Record<string, unknown>).dedupStats = dedupStats;\n      }\n\n      if (filteredCount > 0 && typeof resultsData.summary === 'string') {\n        resultsData.summary += ` (${filteredCount} duplicates filtered, ~${tokensSaved} tokens saved)`;\n      }\n\n      responseToReturn = {\n        ...responseToReturn,\n        content: [{ type: 'text', text: JSON.stringify(resultsData, null, 2) }]\n      } as MCPResponse;\n    }\n  }\n\n  if (sessionId && isSessionRetrievalStateEnabled()) {\n    const parsedResponse = parseResponseEnvelope(responseToReturn);\n    const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n      ? parsedResponse.envelope.data as Record<string, unknown>\n      : null;\n    const existingResults = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n\n    if (parsedResponse && data) {\n      const returnedIds = existingResults\n        .map((result) => result.id ?? result.resultId)\n        .filter((id): id is string | number => typeof id === 'string' || typeof id === 'number');\n\n      if (returnedIds.length > 0) {\n        retrievalSessionStateManager.markSeen(sessionId, returnedIds);\n      }\n\n      data.sessionState = buildSessionStatePayload(sessionId);\n      if (goalRefinementPayload) {\n        data.goalRefinement = goalRefinementPayload;\n      }\n\n      parsedResponse.envelope.data = data;\n      responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n    }\n  }\n\n  if (includeTrace && sessionTransition) {\n    responseToReturn = attachSessionTransitionTrace(responseToReturn, sessionTransition);\n  }\n\n  if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n    const telemetry = retrievalTelemetry.createTelemetry();\n    retrievalTelemetry.recordTransitionDiagnostics(telemetry, sessionTransition);\n    retrievalTelemetry.recordGraphWalkDiagnostics(\n      telemetry,\n      summarizeGraphWalkDiagnostics(extractResponseResults(responseToReturn)),\n    );\n    responseToReturn = attachTelemetryMeta(responseToReturn, retrievalTelemetry.toJSON(telemetry));\n  }\n\n  if (searchDecisionEnvelope) {\n    recordSearchDecision({\n      ...searchDecisionEnvelope,\n      latencyMs: Date.now() - _searchStartTime,\n    });\n  }\n\n  // Consumption instrumentation — log search event (fail-safe, never throws)\n  try {\n    const db = (() => { try { return requireDb(); } catch (_error: unknown) { return null; } })();\n    if (db) {\n      initConsumptionLog(db);\n      let resultIds: number[] = [];\n      let resultCount = 0;\n      try {\n        if (responseToReturn?.content?.[0]?.text) {\n          const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n          const data = parsed?.data as Record<string, unknown> | undefined;\n          const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n          resultIds = results.map(r => r.id as number).filter(id => typeof id === 'number');\n          resultCount = Array.isArray(data?.results) ? (data.results as unknown[]).length : 0;\n        }\n      } catch (_error: unknown) { /* ignore parse errors */ }\n      logConsumptionEvent(db, {\n        event_type: 'search',\n        query: effectiveQuery || null,\n        intent: detectedIntent,\n        result_count: resultCount,\n        result_ids: resultIds,\n        session_id: sessionId ?? null,\n        latency_ms: Date.now() - _searchStartTime,\n        spec_folder_filter: specFolder ?? null,\n      });\n    }\n  } catch (_error: unknown) { /* instrumentation must never cause search to fail */ }\n\n  // Eval logger — capture final results at pipeline exit (fail-safe)\n  try {\n    if (_evalRunId && _evalQueryId) {\n      let finalMemoryIds: number[] = [];\n      let finalScores: number[] = [];\n      try {\n        if (responseToReturn?.content?.[0]?.text) {\n          const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n          const data = parsed?.data as Record<string, unknown> | undefined;\n          const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n          finalMemoryIds = results.map(r => r.id as number).filter(id => typeof id === 'number');\n          finalScores = results.map(r => (r.score ?? r.similarity ?? 0) as number);\n        }\n      } catch (_error: unknown) { /* ignore parse errors */ }\n      logFinalResult({\n        evalRunId: _evalRunId,\n        queryId: _evalQueryId,\n        resultMemoryIds: finalMemoryIds,\n        scores: finalScores,\n        fusionMethod: 'rrf',\n        latencyMs: Date.now() - _searchStartTime,\n      });\n\n      for (const payload of _evalChannelPayloads) {\n        logChannelResult({\n          evalRunId: _evalRunId,\n          queryId: _evalQueryId,\n          channel: payload.channel,\n          resultMemoryIds: payload.resultMemoryIds,\n          scores: payload.scores,\n          hitCount: payload.resultMemoryIds.length,\n        });\n      }\n    }\n  } catch (_error: unknown) { /* eval logging must never break search */ }\n\n  // Implicit feedback — log search_shown events for returned results\n  // Shadow-only: no ranking side effects. Fail-safe, never throws.\n  try {\n    if (isImplicitFeedbackLogEnabled()) {\n      const db = (() => { try { return requireDb(); } catch (_error: unknown) { return null; } })();\n      if (db) {\n        let shownMemoryIds: number[] = [];\n        try {\n          if (responseToReturn?.content?.[0]?.text) {\n            const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n            const data = parsed?.data as Record<string, unknown> | undefined;\n            const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n            shownMemoryIds = results.map(r => r.id as number).filter(id => typeof id === 'number');\n          }\n        } catch (_error: unknown) { /* ignore parse errors */ }\n\n        if (shownMemoryIds.length > 0) {\n          const queryId = _evalQueryId ? String(_evalQueryId) : String(_searchStartTime);\n          const feedbackEvents: FeedbackEvent[] = shownMemoryIds.map(memId => ({\n            type: 'search_shown',\n            memoryId: String(memId),\n            queryId,\n            confidence: 'weak',\n            timestamp: _searchStartTime,\n            sessionId: sessionId ?? null,\n          }));\n          logFeedbackEvents(db, feedbackEvents);\n        }\n      }\n    }\n  } catch (_error: unknown) { /* feedback logging must never break search */ }\n\n  // Query flow tracking + result_cited for includeContent searches\n  // Shadow-only: emits query_reformulated, same_topic_requery, and result_cited events.\n  try {\n    if (isImplicitFeedbackLogEnabled()) {\n      const db = (() => { try { return requireDb(); } catch (_error: unknown) { return null; } })();\n      if (db) {\n        // Extract shown memory IDs from response (reuse parsed data if available)\n        let shownIds: string[] = [];\n        try {\n          if (responseToReturn?.content?.[0]?.text) {\n            const parsed = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n            const data = parsed?.data as Record<string, unknown> | undefined;\n            const results = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n            shownIds = results.flatMap((result) => {\n              const candidate = result.id;\n              if (typeof candidate !== 'number' && typeof candidate !== 'string') {\n                return [];\n              }\n              const normalizedId = String(candidate).trim();\n              if (!normalizedId || normalizedId === 'undefined' || normalizedId === 'null') {\n                return [];\n              }\n              return [normalizedId];\n            });\n          }\n        } catch (_error: unknown) { /* ignore parse errors */ }\n\n        const queryId = _evalQueryId ? String(_evalQueryId) : String(_searchStartTime);\n\n        // Track query flow — detects reformulations and same-topic re-queries\n        if (normalizedQuery) {\n          trackQueryAndDetect(db, sessionId ?? null, normalizedQuery, queryId, shownIds);\n        }\n\n        // Log result_cited for includeContent searches (content was embedded = cited)\n        if (includeContent && shownIds.length > 0) {\n          logResultCited(db, sessionId ?? null, queryId, shownIds);\n        }\n      }\n    }\n  } catch (_error: unknown) { /* query flow tracking must never break search */ }\n\n  // Apply presentation profile when flag is enabled and profile is specified.\n  // Phase C: effectiveProfile includes auto-routed profile from intent detection.\n  if (effectiveProfile && typeof effectiveProfile === 'string' && isResponseProfileEnabled()) {\n    const firstEntry = responseToReturn?.content?.[0];\n    if (firstEntry && typeof firstEntry.text === 'string') {\n      try {\n        const profiled = applyProfileToEnvelope(effectiveProfile, firstEntry.text);\n        if (profiled !== firstEntry.text) {\n          responseToReturn = {\n            ...responseToReturn,\n            content: [{ ...firstEntry, text: profiled }],\n          } as MCPResponse;\n        }\n      } catch (_profileError: unknown) {\n        // Profile formatting is best-effort — never breaks search\n      }\n    }\n  }\n\n  responseToReturn = attachLexicalCapabilityMetadata(\n    responseToReturn,\n    getLastLexicalCapabilitySnapshot(),\n  );\n\n  return responseToReturn;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   11. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemorySearch,\n};\n\nexport const __testables = {\n  filterByMinQualityScore,\n  resolveQualityThreshold,\n  buildCacheArgs,\n  resolveRowContextType,\n  resolveArtifactRoutingQuery,\n  applyArtifactRouting,\n  collapseAndReassembleChunkResults,\n  attachLexicalCapabilityMetadata,\n  collectEvalChannelsFromRow,\n  buildEvalChannelPayloads,\n  filterCanonicalSourceRows,\n  stampFinalRankScores,\n  applyFolderBoostRanking,\n  reconcilePostFormatResultSet,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_search = handleMemorySearch;\n\nexport {\n  handle_memory_search,\n};","lineStart":1380,"lineEnd":1788,"totalLines":1788,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781761461705,"end":1781761461710}},"metadata":{"openai":{"itemId":"fc_0f1c4e9a802a812e016a3385b5a6088191b844d3233ce8cd71"}},"id":"prt_ed9424dc30014Imudngg5uuXAU","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed9421d3d001fIaymXsx6pDkWD"}}
{"type":"tool_use","timestamp":1781761461748,"sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","part":{"type":"tool","tool":"read","callID":"call_b3nPynRxjlGT2NBYMrjykS3F","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","offset":1,"limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Orchestrator\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-stage pipeline execution with per-stage error handling and timeouts.\n5: //\n6: // Each stage is wrapped in try/catch with withTimeout().\n7: // Stage 1 is mandatory (throws on failure — no candidates = no results).\n8: // Stages 2-4 fall back to previous stage output with degraded metadata.\n9: // Timing is recorded for latency observability.\n10: //\n11: // I/O CONTRACT:\n12: // Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n13: // Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n14: // Key invariants:\n15: //     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n16: //     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n17: //     - Stage metadata for all four stages is included for observability\n18: //     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n19: // Side effects:\n20: //     - Delegates to each stage; see individual stage modules for their side effects\n21: \n22: import type {\n23:   PipelineConfig,\n24:   PipelineResult,\n25:   Stage1Output,\n26:   Stage2Output,\n27:   Stage3Output,\n28:   Stage4Output,\n29:   Stage4ReadonlyRow,\n30:   SignalStatus,\n31: } from './types.js';\n32: \n33: import { executeStage1 } from './stage1-candidate-gen.js';\n34: import { executeStage2 } from './stage2-fusion.js';\n35: import { executeStage3 } from './stage3-rerank.js';\n36: import { executeStage4 } from './stage4-filter.js';\n37: import { MemoryError, withTimeout } from '../../errors/core.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: 4-stage pipeline refactor\n41: \n42: \n43: /** Per-stage timeout in milliseconds. */\n44: const STAGE_TIMEOUT_MS = 10_000;\n45: \n46: /**\n47:  * Execute the 4-stage retrieval pipeline with per-stage error handling.\n48:  *\n49:  * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n50:  * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n51:  * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n52:  * Stage 4: Filter + Annotate — falls back to unfiltered results\n53:  *\n54:  * @param config Pipeline configuration derived from search args\n55:  * @returns Pipeline result with stage metadata and timing\n56:  */\n57: export async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n58:   const timing: Record<string, number> = {};\n59:   const pipelineStart = Date.now();\n60:   let degraded = false;\n61: \n62:   // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n63:   let stage1Result: Stage1Output;\n64:   try {\n65:     const t0 = Date.now();\n66:     stage1Result = await withTimeout(\n67:       executeStage1({ config }),\n68:       STAGE_TIMEOUT_MS,\n69:       'Stage 1: Candidate Generation',\n70:     );\n71:     timing.stage1 = Date.now() - t0;\n72:   } catch (err) {\n73:     throw new MemoryError(\n74:       'PIPELINE_STAGE1_FAILED',\n75:       `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n76:       { cause: err instanceof Error ? err.message : String(err) },\n77:     );\n78:   }\n79: \n80:   // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n81:   let stage2Result: Stage2Output;\n82:   try {\n83:     const t0 = Date.now();\n84:     stage2Result = await withTimeout(\n85:       executeStage2({\n86:         candidates: stage1Result.candidates,\n87:         config,\n88:         stage1Metadata: stage1Result.metadata,\n89:       }),\n90:       STAGE_TIMEOUT_MS,\n91:       'Stage 2: Fusion',\n92:     );\n93:     timing.stage2 = Date.now() - t0;\n94:   } catch (err) {\n95:     const msg = err instanceof Error ? err.message : String(err);\n96:     console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n97:     degraded = true;\n98:     stage2Result = {\n99:       scored: stage1Result.candidates,\n100:       metadata: {\n101:         sessionBoostApplied: 'failed' as SignalStatus,\n102:         causalBoostApplied: 'failed' as SignalStatus,\n103:         intentWeightsApplied: 'failed' as SignalStatus,\n104:         artifactRoutingApplied: 'failed' as SignalStatus,\n105:         feedbackSignalsApplied: 'failed' as SignalStatus,\n106:         qualityFiltered: 0,\n107:         durationMs: 0,\n108:       },\n109:     };\n110:     timing.stage2 = 0;\n111:   }\n112: \n113:   // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n114:   let stage3Result: Stage3Output;\n115:   try {\n116:     const t0 = Date.now();\n117:     stage3Result = await withTimeout(\n118:       executeStage3({\n119:         scored: stage2Result.scored,\n120:         config,\n121:       }),\n122:       STAGE_TIMEOUT_MS,\n123:       'Stage 3: Rerank',\n124:     );\n125:     timing.stage3 = Date.now() - t0;\n126:   } catch (err) {\n127:     const msg = err instanceof Error ? err.message : String(err);\n128:     console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n129:     degraded = true;\n130:     stage3Result = {\n131:       reranked: stage2Result.scored,\n132:       metadata: {\n133:         rerankApplied: false,\n134:         chunkReassemblyStats: {\n135:           collapsedChunkHits: 0,\n136:           chunkParents: 0,\n137:           reassembled: 0,\n138:           fallback: 0,\n139:         },\n140:         durationMs: 0,\n141:       },\n142:     };\n143:     timing.stage3 = 0;\n144:   }\n145: \n146:   // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n147:   let stage4Result: Stage4Output;\n148:   try {\n149:     const t0 = Date.now();\n150:     stage4Result = await withTimeout(\n151:       executeStage4({\n152:         results: stage3Result.reranked as Stage4ReadonlyRow[],\n153:         config,\n154:         stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n155:       }),\n156:       STAGE_TIMEOUT_MS,\n157:       'Stage 4: Filter',\n158:     );\n159:     timing.stage4 = Date.now() - t0;\n160:   } catch (err) {\n161:     const msg = err instanceof Error ? err.message : String(err);\n162:     console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n163:     degraded = true;\n164:     stage4Result = {\n165:       final: stage3Result.reranked as Stage4ReadonlyRow[],\n166:       metadata: {\n167:         stateFiltered: 0,\n168:         constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n169:         evidenceGapDetected: false,\n170:         durationMs: 0,\n171:       },\n172:       annotations: {\n173:         stateStats: {},\n174:         featureFlags: {},\n175:       },\n176:     };\n177:     timing.stage4 = 0;\n178:   }\n179: \n180:   timing.total = Date.now() - pipelineStart;\n181: \n182:   return {\n183:     results: stage4Result.final,\n184:     metadata: {\n185:       stage1: stage1Result.metadata,\n186:       stage2: stage2Result.metadata,\n187:       stage3: stage3Result.metadata,\n188:       stage4: stage4Result.metadata,\n189:       timing,\n190:       degraded: degraded || undefined,\n191:     },\n192:     annotations: stage4Result.annotations,\n193:     trace: config.trace,\n194:   };\n195: }\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects\n\nimport type {\n  PipelineConfig,\n  PipelineResult,\n  Stage1Output,\n  Stage2Output,\n  Stage3Output,\n  Stage4Output,\n  Stage4ReadonlyRow,\n  SignalStatus,\n} from './types.js';\n\nimport { executeStage1 } from './stage1-candidate-gen.js';\nimport { executeStage2 } from './stage2-fusion.js';\nimport { executeStage3 } from './stage3-rerank.js';\nimport { executeStage4 } from './stage4-filter.js';\nimport { MemoryError, withTimeout } from '../../errors/core.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: 4-stage pipeline refactor\n\n\n/** Per-stage timeout in milliseconds. */\nconst STAGE_TIMEOUT_MS = 10_000;\n\n/**\n * Execute the 4-stage retrieval pipeline with per-stage error handling.\n *\n * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n * Stage 4: Filter + Annotate — falls back to unfiltered results\n *\n * @param config Pipeline configuration derived from search args\n * @returns Pipeline result with stage metadata and timing\n */\nexport async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n  const timing: Record<string, number> = {};\n  const pipelineStart = Date.now();\n  let degraded = false;\n\n  // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n  let stage1Result: Stage1Output;\n  try {\n    const t0 = Date.now();\n    stage1Result = await withTimeout(\n      executeStage1({ config }),\n      STAGE_TIMEOUT_MS,\n      'Stage 1: Candidate Generation',\n    );\n    timing.stage1 = Date.now() - t0;\n  } catch (err) {\n    throw new MemoryError(\n      'PIPELINE_STAGE1_FAILED',\n      `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n      { cause: err instanceof Error ? err.message : String(err) },\n    );\n  }\n\n  // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n  let stage2Result: Stage2Output;\n  try {\n    const t0 = Date.now();\n    stage2Result = await withTimeout(\n      executeStage2({\n        candidates: stage1Result.candidates,\n        config,\n        stage1Metadata: stage1Result.metadata,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 2: Fusion',\n    );\n    timing.stage2 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n    degraded = true;\n    stage2Result = {\n      scored: stage1Result.candidates,\n      metadata: {\n        sessionBoostApplied: 'failed' as SignalStatus,\n        causalBoostApplied: 'failed' as SignalStatus,\n        intentWeightsApplied: 'failed' as SignalStatus,\n        artifactRoutingApplied: 'failed' as SignalStatus,\n        feedbackSignalsApplied: 'failed' as SignalStatus,\n        qualityFiltered: 0,\n        durationMs: 0,\n      },\n    };\n    timing.stage2 = 0;\n  }\n\n  // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n  let stage3Result: Stage3Output;\n  try {\n    const t0 = Date.now();\n    stage3Result = await withTimeout(\n      executeStage3({\n        scored: stage2Result.scored,\n        config,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 3: Rerank',\n    );\n    timing.stage3 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n    degraded = true;\n    stage3Result = {\n      reranked: stage2Result.scored,\n      metadata: {\n        rerankApplied: false,\n        chunkReassemblyStats: {\n          collapsedChunkHits: 0,\n          chunkParents: 0,\n          reassembled: 0,\n          fallback: 0,\n        },\n        durationMs: 0,\n      },\n    };\n    timing.stage3 = 0;\n  }\n\n  // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n  let stage4Result: Stage4Output;\n  try {\n    const t0 = Date.now();\n    stage4Result = await withTimeout(\n      executeStage4({\n        results: stage3Result.reranked as Stage4ReadonlyRow[],\n        config,\n        stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 4: Filter',\n    );\n    timing.stage4 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n    degraded = true;\n    stage4Result = {\n      final: stage3Result.reranked as Stage4ReadonlyRow[],\n      metadata: {\n        stateFiltered: 0,\n        constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n        evidenceGapDetected: false,\n        durationMs: 0,\n      },\n      annotations: {\n        stateStats: {},\n        featureFlags: {},\n      },\n    };\n    timing.stage4 = 0;\n  }\n\n  timing.total = Date.now() - pipelineStart;\n\n  return {\n    results: stage4Result.final,\n    metadata: {\n      stage1: stage1Result.metadata,\n      stage2: stage2Result.metadata,\n      stage3: stage3Result.metadata,\n      stage4: stage4Result.metadata,\n      timing,\n      degraded: degraded || undefined,\n    },\n    annotations: stage4Result.annotations,\n    trace: config.trace,\n  };\n}","lineStart":1,"lineEnd":195,"totalLines":195,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","time":{"start":1781761461741,"end":1781761461747}},"metadata":{"openai":{"itemId":"fc_0f1c4e9a802a812e016a3385b5a61c8191a79d5cec1a36f8a6"}},"id":"prt_ed9424dca001gE6FXQkgPC6EYx","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed9421d3d001fIaymXsx6pDkWD"}}
{"type":"tool_use","timestamp":1781761461768,"sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","part":{"type":"tool","tool":"read","callID":"call_WDYTYpZow6lHZCNWPW6a3Z7Q","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage4 Filter\n3: // ───────────────────────────────────────────────────────────────\n4: // Final stage of the 4-stage retrieval pipeline.\n5: //\n6: // ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n7: // Any ordering change after Stage 3 is a bug. Score fields on\n8: // Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n9: // Via captureScoreSnapshot / verifyScoreInvariant provides a second\n10: // Defence-in-depth layer.\n11: //\n12: // I/O CONTRACT:\n13: // Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n14: // Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n15: // Key invariants:\n16: //     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n17: // AttentionScore, importance_weight) may change between input and output\n18: //     - Ordering from Stage 3 is preserved for all surviving rows\n19: //     - final contains only rows at or above config.minState priority\n20: // Side effects:\n21: //     - None — this stage is read-only with respect to the database\n22: //\n23: // FILTER APPLICATION ORDER (within filterByMemoryState):\n24: // 1. memoryState priority filter — rows below minState are removed\n25: // 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n26: //\n27: // Responsibilities (in execution order):\n28: // 1. Capture score snapshot BEFORE any operations (runtime invariant)\n29: // 2. Apply memory-state filtering (filterByMemoryState)\n30: // 3. Apply evidence gap detection via TRM (Z-score confidence check)\n31: // 4. Add annotation metadata (feature flags, state stats, etc.)\n32: // 5. Verify score invariant AFTER all operations\n33: //\n34: // NOT in Stage 4: session dedup — that happens after cache in the\n35: // Main handler to avoid double-counting and cache pollution.\n36: \n37: import type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\n38: import { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\n39: import { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\n40: import { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\n41: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n42: \n43: // Feature catalog: 4-stage pipeline architecture\n44: // Feature catalog: Confidence-based result truncation\n45: \n46: \n47: // ───────────────────────────────────────────────────────────────\n48: // 2. CONSTANTS\n49: \n50: \n51: // ───────────────────────────────────────────────────────────────\n52: /**\n53:  * Memory state priority map. Higher number = higher priority.\n54:  * Used to compare states numerically so filtering is O(1) per row.\n55:  */\n56: const STATE_PRIORITY: Record<string, number> = {\n57:   HOT: 5,\n58:   WARM: 4,\n59:   COLD: 3,\n60:   DORMANT: 2,\n61:   ARCHIVED: 1,\n62: };\n63: \n64: /**\n65:  * Per-tier hard limits applied when `applyStateLimits` is true.\n66:  * Prevents any single tier from monopolising the result window.\n67:  */\n68: export const STATE_LIMITS: Record<string, number> = {\n69:   HOT: 50,\n70:   WARM: 30,\n71:   COLD: 20,\n72:   DORMANT: 10,\n73:   ARCHIVED: 5,\n74: };\n75: \n76: /** Fallback priority for unknown/missing memoryState values.\n77:  * Set above HOT (5) so UNKNOWN memories always pass state filters.\n78:  * memoryState column doesn't exist yet — all memories are UNKNOWN.\n79:  * Reset to 0 when the TRM state column is implemented. */\n80: const UNKNOWN_STATE_PRIORITY = 6;\n81: \n82: function normalizeStateValue(state: unknown): string | null {\n83:   if (typeof state !== 'string') {\n84:     return null;\n85:   }\n86:   const normalizedState = state.toUpperCase();\n87:   return normalizedState in STATE_PRIORITY ? normalizedState : null;\n88: }\n89: \n90: function resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n91:   const explicitState = normalizeStateValue(row.memoryState);\n92:   if (explicitState) {\n93:     return explicitState;\n94:   }\n95: \n96:   return 'UNKNOWN';\n97: }\n98: \n99: // ───────────────────────────────────────────────────────────────\n100: // 3. TYPES\n101: \n102: \n103: // ───────────────────────────────────────────────────────────────\n104: /**\n105:  * Per-state tally produced by `filterByMemoryState`.\n106:  * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n107:  */\n108: export type StateStats = Record<string, number>;\n109: \n110: /**\n111:  * Return value of the internal `filterByMemoryState` function.\n112:  */\n113: export interface FilterResult {\n114:   /** Rows that survived state filtering, in original order. */\n115:   filtered: Stage4ReadonlyRow[];\n116:   /** Pre-filter per-state counts (includes removed rows). */\n117:   statsBefore: StateStats;\n118:   /** Post-filter per-state counts. */\n119:   statsAfter: StateStats;\n120:   /** Total number of rows removed. */\n121:   removedCount: number;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    3. INTERNAL: filterByMemoryState\n126:    ──────────────────────────────────────────────────────────────── */\n127: \n128: /**\n129:  * Remove rows whose `memoryState` falls below `minState` priority and,\n130:  * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n131:  *\n132:  * IMPORTANT: This function ONLY removes items — it never reorders or\n133:  * modifies score fields. The original ordering from Stage 3 is preserved\n134:  * for all rows that survive.\n135:  *\n136:  * @param results        - Read-only rows from Stage 3 output.\n137:  * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n138:  * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n139:  * @returns FilterResult with the surviving rows and before/after stats.\n140:  */\n141: export function filterByMemoryState(\n142:   results: Stage4ReadonlyRow[],\n143:   minState: string,\n144:   applyStateLimits: boolean,\n145: ): FilterResult {\n146:   const normalizedMinState = normalizeStateValue(minState);\n147:   const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n148: \n149:   // -- 3a. Tally states before filtering --\n150:   const statsBefore: StateStats = {};\n151:   for (const row of results) {\n152:     const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n153:     statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n154:   }\n155: \n156:   // -- 3b. State-priority filter --\n157:   let passing = results.filter(row => {\n158:     const state = resolveStateForFiltering(row);\n159:     const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n160:     return priority >= minPriority;\n161:   });\n162: \n163:   // -- 3c. Per-tier limits (optional) --\n164:   if (applyStateLimits) {\n165:     const tierCounters: Record<string, number> = {};\n166:     const limitPassing: Stage4ReadonlyRow[] = [];\n167: \n168:     for (const row of passing) {\n169:       const state = resolveStateForFiltering(row);\n170:       const limit = STATE_LIMITS[state] ?? Infinity;\n171:       const count = tierCounters[state] ?? 0;\n172: \n173:       if (count < limit) {\n174:         tierCounters[state] = count + 1;\n175:         limitPassing.push(row);\n176:       }\n177:       // Rows exceeding the per-tier limit are silently dropped (no score change).\n178:     }\n179: \n180:     passing = limitPassing;\n181:   }\n182: \n183:   // -- 3d. Tally states after filtering --\n184:   const statsAfter: StateStats = {};\n185:   for (const row of passing) {\n186:     const state = resolveStateForFiltering(row);\n187:     statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n188:   }\n189: \n190:   return {\n191:     filtered: passing,\n192:     statsBefore,\n193:     statsAfter,\n194:     removedCount: results.length - passing.length,\n195:   };\n196: }\n197: \n198: /* ───────────────────────────────────────────────────────────────\n199:    4. INTERNAL: extractScoringValues\n200:    ──────────────────────────────────────────────────────────────── */\n201: \n202: /**\n203:  * Extract the best available numeric score from a row for evidence-gap\n204:  * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n205:  * so scoring, sorting, and filtering all agree on precedence and normalization.\n206:  *\n207:  * A1 FIX: Previously used a different precedence order (rrfScore first) and\n208:  * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n209:  * that only had the similarity field set.\n210:  *\n211:  * @param row - A Stage4ReadonlyRow to inspect.\n212:  * @returns The best available numeric score clamped to [0,1], or 0.\n213:  */\n214: export function extractScoringValue(row: Stage4ReadonlyRow): number {\n215:   return resolveEffectiveScore(row as unknown as PipelineRow);\n216: }\n217: \n218: /* ───────────────────────────────────────────────────────────────\n219:    5. MAIN: executeStage4\n220:    ──────────────────────────────────────────────────────────────── */\n221: \n222: /**\n223:  * Execute Stage 4 of the 4-stage retrieval pipeline: Filter + Annotate.\n224:  *\n225:  * Stage 4 is the final pipeline stage. It removes results that fall below\n226:  * the configured minimum memory state, runs the Transparent Reasoning Module\n227:  * (TRM) evidence-gap check, attaches annotation metadata, and verifies the\n228:  * score invariant before returning.\n229:  *\n230:  * **Score invariant:** No score fields are modified in Stage 4. The compile-time\n231:  * guarantee is enforced via Stage4ReadonlyRow readonly fields; the runtime check\n232:  * via captureScoreSnapshot / verifyScoreInvariant provides defence-in-depth. If\n233:  * verifyScoreInvariant throws, it indicates a Stage 4 implementation bug.\n234:  *\n235:  * **Session dedup:** Session deduplication is intentionally NOT performed here.\n236:  * It happens after the cache layer in the main handler to avoid cache pollution.\n237:  *\n238:  * @param input - Stage4Input containing read-only results and pipeline config.\n239:  * @returns Stage4Output with filtered/annotated results and metadata.\n240:  * @throws Error if verifyScoreInvariant detects any score mutation (Stage 4 bug).\n241:  */\n242: export async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n243:   const stageStart = Date.now();\n244:   const { results, config } = input;\n245: \n246:   // -- Step 1: Capture score snapshot (runtime invariant) --\n247:   //\n248:   // This snapshot is the source-of-truth for the \"no score changes\" assertion.\n249:   // It is taken over the FULL input set BEFORE any operations, so rows that\n250:   // Are subsequently filtered out are still in the before-snapshot. The\n251:   // VerifyScoreInvariant call skips rows not present in the after-set.\n252:   const scoresBefore = captureScoreSnapshot(results);\n253: \n254:   // -- Step 2: State filtering --\n255:   const filterResult = filterByMemoryState(\n256:     results,\n257:     config.minState,\n258:     config.applyStateLimits,\n259:   );\n260: \n261:   let workingResults: Stage4ReadonlyRow[] = filterResult.filtered;\n262:   const stateFiltered = filterResult.removedCount;\n263: \n264:   // -- Step 3: Evidence gap detection (TRM) --\n265:   let evidenceGapDetected = false;\n266:   let evidenceGapWarning: string | undefined;\n267: \n268:   if (isTRMEnabled()) {\n269:     const scores = workingResults.map(extractScoringValue);\n270:     const trm = detectEvidenceGap(scores);\n271: \n272:     evidenceGapDetected = trm.gapDetected;\n273: \n274:     if (trm.gapDetected) {\n275:       evidenceGapWarning = formatEvidenceGapWarning(trm);\n276: \n277:       // Annotate each result with the gap metadata (non-score field).\n278:       workingResults = workingResults.map(row => ({\n279:         ...row,\n280:         evidenceGap: { gapDetected: true, warning: evidenceGapWarning },\n281:       }));\n282:     }\n283:   }\n284: \n285:   // -- Step 4: Build annotation metadata --\n286:   const featureFlags: Record<string, boolean> = {\n287:     trmEnabled: isTRMEnabled(),\n288:     multiQueryEnabled: isMultiQueryEnabled(),\n289:     stateLimitsApplied: config.applyStateLimits,\n290:   };\n291: \n292:   const stateStats: Record<string, unknown> = {\n293:     minState: config.minState,\n294:     before: filterResult.statsBefore,\n295:     after: filterResult.statsAfter,\n296:     removed: stateFiltered,\n297:   };\n298: \n299:   const annotations: Stage4Output['annotations'] = {\n300:     evidenceGapWarning,\n301:     stateStats,\n302:     featureFlags,\n303:   };\n304: \n305:   // -- Step 4b: Final limit cap --\n306:   // Enforce caller's limit after all filtering to prevent degraded paths exceeding requested count\n307:   if (typeof config.limit === 'number' && config.limit > 0 && workingResults.length > config.limit) {\n308:     workingResults = workingResults.slice(0, config.limit);\n309:   }\n310: \n311:   // -- Step 5: Verify score invariant (defence-in-depth) --\n312:   //\n313:   // VerifyScoreInvariant checks every row that survived filtering.\n314:   // Rows removed by filterByMemoryState are absent from workingResults,\n315:   // So the function correctly skips them (see types.ts implementation).\n316:   // Throws [Stage4Invariant] Error if any score field was mutated.\n317:   verifyScoreInvariant(scoresBefore, workingResults);\n318: \n319:   const durationMs = Date.now() - stageStart;\n320: \n321:   // -- Trace entry --\n322:   if (config.trace) {\n323:     addTraceEntry(\n324:       config.trace,\n325:       'filter',\n326:       results.length,\n327:       workingResults.length,\n328:       durationMs,\n329:       {\n330:         stateFiltered,\n331:         evidenceGapDetected,\n332:         trmEnabled: isTRMEnabled(),\n333:         applyStateLimits: config.applyStateLimits,\n334:         minState: config.minState,\n335:       },\n336:     );\n337:   }\n338: \n339:   return {\n340:     final: workingResults,\n341:     metadata: {\n342:       stateFiltered,\n343:       // sessionDeduped removed; dedup is post-cache in main handler\n344:       // constitutionalInjected passed from Stage 1 metadata\n345:       constitutionalInjected: input.stage1Metadata?.constitutionalInjected ?? 0,\n346:       evidenceGapDetected,\n347:       durationMs,\n348:     },\n349:     annotations,\n350:   };\n351: }\n352: \n353: // ───────────────────────────────────────────────────────────────\n354: // 4. TEST SURFACE\n355: \n356: \n357: // ───────────────────────────────────────────────────────────────\n358: /**\n359:  * Exported internals for unit testing.\n360:  * Not intended for production use outside the test harness.\n361:  */\n362: export const __testables = {\n363:   filterByMemoryState,\n364:   resolveStateForFiltering,\n365:   normalizeStateValue,\n366:   extractScoringValue,\n367:   STATE_PRIORITY,\n368:   STATE_LIMITS,\n369:   UNKNOWN_STATE_PRIORITY,\n370: } as const;\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:\n//     - None — this stage is read-only with respect to the database\n//\n// FILTER APPLICATION ORDER (within filterByMemoryState):\n// 1. memoryState priority filter — rows below minState are removed\n// 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n//\n// Responsibilities (in execution order):\n// 1. Capture score snapshot BEFORE any operations (runtime invariant)\n// 2. Apply memory-state filtering (filterByMemoryState)\n// 3. Apply evidence gap detection via TRM (Z-score confidence check)\n// 4. Add annotation metadata (feature flags, state stats, etc.)\n// 5. Verify score invariant AFTER all operations\n//\n// NOT in Stage 4: session dedup — that happens after cache in the\n// Main handler to avoid double-counting and cache pollution.\n\nimport type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\nimport { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\nimport { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\nimport { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Confidence-based result truncation\n\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Memory state priority map. Higher number = higher priority.\n * Used to compare states numerically so filtering is O(1) per row.\n */\nconst STATE_PRIORITY: Record<string, number> = {\n  HOT: 5,\n  WARM: 4,\n  COLD: 3,\n  DORMANT: 2,\n  ARCHIVED: 1,\n};\n\n/**\n * Per-tier hard limits applied when `applyStateLimits` is true.\n * Prevents any single tier from monopolising the result window.\n */\nexport const STATE_LIMITS: Record<string, number> = {\n  HOT: 50,\n  WARM: 30,\n  COLD: 20,\n  DORMANT: 10,\n  ARCHIVED: 5,\n};\n\n/** Fallback priority for unknown/missing memoryState values.\n * Set above HOT (5) so UNKNOWN memories always pass state filters.\n * memoryState column doesn't exist yet — all memories are UNKNOWN.\n * Reset to 0 when the TRM state column is implemented. */\nconst UNKNOWN_STATE_PRIORITY = 6;\n\nfunction normalizeStateValue(state: unknown): string | null {\n  if (typeof state !== 'string') {\n    return null;\n  }\n  const normalizedState = state.toUpperCase();\n  return normalizedState in STATE_PRIORITY ? normalizedState : null;\n}\n\nfunction resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n  const explicitState = normalizeStateValue(row.memoryState);\n  if (explicitState) {\n    return explicitState;\n  }\n\n  return 'UNKNOWN';\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. TYPES\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Per-state tally produced by `filterByMemoryState`.\n * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n */\nexport type StateStats = Record<string, number>;\n\n/**\n * Return value of the internal `filterByMemoryState` function.\n */\nexport interface FilterResult {\n  /** Rows that survived state filtering, in original order. */\n  filtered: Stage4ReadonlyRow[];\n  /** Pre-filter per-state counts (includes removed rows). */\n  statsBefore: StateStats;\n  /** Post-filter per-state counts. */\n  statsAfter: StateStats;\n  /** Total number of rows removed. */\n  removedCount: number;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. INTERNAL: filterByMemoryState\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Remove rows whose `memoryState` falls below `minState` priority and,\n * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n *\n * IMPORTANT: This function ONLY removes items — it never reorders or\n * modifies score fields. The original ordering from Stage 3 is preserved\n * for all rows that survive.\n *\n * @param results        - Read-only rows from Stage 3 output.\n * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n * @returns FilterResult with the surviving rows and before/after stats.\n */\nexport function filterByMemoryState(\n  results: Stage4ReadonlyRow[],\n  minState: string,\n  applyStateLimits: boolean,\n): FilterResult {\n  const normalizedMinState = normalizeStateValue(minState);\n  const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n\n  // -- 3a. Tally states before filtering --\n  const statsBefore: StateStats = {};\n  for (const row of results) {\n    const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n    statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n  }\n\n  // -- 3b. State-priority filter --\n  let passing = results.filter(row => {\n    const state = resolveStateForFiltering(row);\n    const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n    return priority >= minPriority;\n  });\n\n  // -- 3c. Per-tier limits (optional) --\n  if (applyStateLimits) {\n    const tierCounters: Record<string, number> = {};\n    const limitPassing: Stage4ReadonlyRow[] = [];\n\n    for (const row of passing) {\n      const state = resolveStateForFiltering(row);\n      const limit = STATE_LIMITS[state] ?? Infinity;\n      const count = tierCounters[state] ?? 0;\n\n      if (count < limit) {\n        tierCounters[state] = count + 1;\n        limitPassing.push(row);\n      }\n      // Rows exceeding the per-tier limit are silently dropped (no score change).\n    }\n\n    passing = limitPassing;\n  }\n\n  // -- 3d. Tally states after filtering --\n  const statsAfter: StateStats = {};\n  for (const row of passing) {\n    const state = resolveStateForFiltering(row);\n    statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n  }\n\n  return {\n    filtered: passing,\n    statsBefore,\n    statsAfter,\n    removedCount: results.length - passing.length,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INTERNAL: extractScoringValues\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Extract the best available numeric score from a row for evidence-gap\n * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n * so scoring, sorting, and filtering all agree on precedence and normalization.\n *\n * A1 FIX: Previously used a different precedence order (rrfScore first) and\n * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n * that only had the similarity field set.\n *\n * @param row - A Stage4ReadonlyRow to inspect.\n * @returns The best available numeric score clamped to [0,1], or 0.\n */\nexport function extractScoringValue(row: Stage4ReadonlyRow): number {\n  return resolveEffectiveScore(row as unknown as PipelineRow);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. MAIN: executeStage4\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Execute Stage 4 of the 4-stage retrieval pipeline: Filter + Annotate.\n *\n * Stage 4 is the final pipeline stage. It removes results that fall below\n * the configured minimum memory state, runs the Transparent Reasoning Module\n * (TRM) evidence-gap check, attaches annotation metadata, and verifies the\n * score invariant before returning.\n *\n * **Score invariant:** No score fields are modified in Stage 4. The compile-time\n * guarantee is enforced via Stage4ReadonlyRow readonly fields; the runtime check\n * via captureScoreSnapshot / verifyScoreInvariant provides defence-in-depth. If\n * verifyScoreInvariant throws, it indicates a Stage 4 implementation bug.\n *\n * **Session dedup:** Session deduplication is intentionally NOT performed here.\n * It happens after the cache layer in the main handler to avoid cache pollution.\n *\n * @param input - Stage4Input containing read-only results and pipeline config.\n * @returns Stage4Output with filtered/annotated results and metadata.\n * @throws Error if verifyScoreInvariant detects any score mutation (Stage 4 bug).\n */\nexport async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n  const stageStart = Date.now();\n  const { results, config } = input;\n\n  // -- Step 1: Capture score snapshot (runtime invariant) --\n  //\n  // This snapshot is the source-of-truth for the \"no score changes\" assertion.\n  // It is taken over the FULL input set BEFORE any operations, so rows that\n  // Are subsequently filtered out are still in the before-snapshot. The\n  // VerifyScoreInvariant call skips rows not present in the after-set.\n  const scoresBefore = captureScoreSnapshot(results);\n\n  // -- Step 2: State filtering --\n  const filterResult = filterByMemoryState(\n    results,\n    config.minState,\n    config.applyStateLimits,\n  );\n\n  let workingResults: Stage4ReadonlyRow[] = filterResult.filtered;\n  const stateFiltered = filterResult.removedCount;\n\n  // -- Step 3: Evidence gap detection (TRM) --\n  let evidenceGapDetected = false;\n  let evidenceGapWarning: string | undefined;\n\n  if (isTRMEnabled()) {\n    const scores = workingResults.map(extractScoringValue);\n    const trm = detectEvidenceGap(scores);\n\n    evidenceGapDetected = trm.gapDetected;\n\n    if (trm.gapDetected) {\n      evidenceGapWarning = formatEvidenceGapWarning(trm);\n\n      // Annotate each result with the gap metadata (non-score field).\n      workingResults = workingResults.map(row => ({\n        ...row,\n        evidenceGap: { gapDetected: true, warning: evidenceGapWarning },\n      }));\n    }\n  }\n\n  // -- Step 4: Build annotation metadata --\n  const featureFlags: Record<string, boolean> = {\n    trmEnabled: isTRMEnabled(),\n    multiQueryEnabled: isMultiQueryEnabled(),\n    stateLimitsApplied: config.applyStateLimits,\n  };\n\n  const stateStats: Record<string, unknown> = {\n    minState: config.minState,\n    before: filterResult.statsBefore,\n    after: filterResult.statsAfter,\n    removed: stateFiltered,\n  };\n\n  const annotations: Stage4Output['annotations'] = {\n    evidenceGapWarning,\n    stateStats,\n    featureFlags,\n  };\n\n  // -- Step 4b: Final limit cap --\n  // Enforce caller's limit after all filtering to prevent degraded paths exceeding requested count\n  if (typeof config.limit === 'number' && config.limit > 0 && workingResults.length > config.limit) {\n    workingResults = workingResults.slice(0, config.limit);\n  }\n\n  // -- Step 5: Verify score invariant (defence-in-depth) --\n  //\n  // VerifyScoreInvariant checks every row that survived filtering.\n  // Rows removed by filterByMemoryState are absent from workingResults,\n  // So the function correctly skips them (see types.ts implementation).\n  // Throws [Stage4Invariant] Error if any score field was mutated.\n  verifyScoreInvariant(scoresBefore, workingResults);\n\n  const durationMs = Date.now() - stageStart;\n\n  // -- Trace entry --\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'filter',\n      results.length,\n      workingResults.length,\n      durationMs,\n      {\n        stateFiltered,\n        evidenceGapDetected,\n        trmEnabled: isTRMEnabled(),\n        applyStateLimits: config.applyStateLimits,\n        minState: config.minState,\n      },\n    );\n  }\n\n  return {\n    final: workingResults,\n    metadata: {\n      stateFiltered,\n      // sessionDeduped removed; dedup is post-cache in main handler\n      // constitutionalInjected passed from Stage 1 metadata\n      constitutionalInjected: input.stage1Metadata?.constitutionalInjected ?? 0,\n      evidenceGapDetected,\n      durationMs,\n    },\n    annotations,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. TEST SURFACE\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Exported internals for unit testing.\n * Not intended for production use outside the test harness.\n */\nexport const __testables = {\n  filterByMemoryState,\n  resolveStateForFiltering,\n  normalizeStateValue,\n  extractScoringValue,\n  STATE_PRIORITY,\n  STATE_LIMITS,\n  UNKNOWN_STATE_PRIORITY,\n} as const;","lineStart":1,"lineEnd":370,"totalLines":370,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","time":{"start":1781761461765,"end":1781761461767}},"metadata":{"openai":{"itemId":"fc_0f1c4e9a802a812e016a3385b5a624819183eb6b7f67bf35bf"}},"id":"prt_ed9424dfe001HI7DWo5NJ8jPie","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed9421d3d001fIaymXsx6pDkWD"}}
{"type":"tool_use","timestamp":1781761461778,"sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","part":{"type":"tool","tool":"read","callID":"call_IoBxkgl3XxJa9eWqO8IDvBhK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","offset":1,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage3 Rerank\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-Stage Retrieval Pipeline: Stage 3 of 4\n5: //\n6: // Responsibilities (in execution order):\n7: // 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n8: // 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n9: //\n10: // Pipeline position constraint:\n11: // MPAB MUST remain AFTER RRF fusion (Stage 2).\n12: // Stage 3 is the only stage that may change scores after Stage 2.\n13: //\n14: // I/O CONTRACT:\n15: // Input:  Stage3Input { scored: PipelineRow[], config }\n16: // Output: Stage3Output { reranked: PipelineRow[], metadata }\n17: // Key invariants:\n18: //     - reranked is sorted descending by effective score after all steps\n19: //     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n20: //     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'\n21: // Side effects:\n22: //     - DB reads to fetch parent content during MPAB reassembly\n23: //\n24: // Score changes: YES\n25: \n26: import { resolveEffectiveScore } from './types.js';\n27: import type { Stage3Input, Stage3Output, PipelineRow } from './types.js';\n28: import { isMMREnabled } from '../search-flags.js';\n29: import { computeMPAB } from '../../scoring/mpab-aggregation.js';\n30: import { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\n31: import type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\n32: import { INTENT_LAMBDA_MAP } from '../intent-classifier.js';\n33: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n34: import { requireDb } from '../../../utils/index.js';\n35: import { toErrorMessage } from '../../../utils/index.js';\n36: import type Database from 'better-sqlite3';\n37: import { compareDeterministicRows, sortDeterministicRows } from './ranking-contract.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: Hybrid search pipeline\n41: \n42: \n43: // -- Constants --------------------------------------------------\n44: \n45: /** Minimum number of candidates required before MMR diversity pruning is worthwhile. */\n46: const MMR_MIN_CANDIDATES = 2;\n47: \n48: /** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\n49: const MMR_DEFAULT_LAMBDA = 0.7;\n50: \n51: /**\n52:  * Enforce non-negative score outputs at Stage 3 boundaries.\n53:  */\n54: function floorScore(value: number): number {\n55:   return Math.max(0, value);\n56: }\n57: \n58: // -- Internal Interfaces ----------------------------------------\n59: \n60: /**\n61:  * Aggregated statistics from the MPAB chunk-collapse pass.\n62:  */\n63: interface ChunkReassemblyStats {\n64:   /** Number of child chunk rows removed from the result set. */\n65:   collapsedChunkHits: number;\n66:   /** Number of distinct parent IDs encountered among chunk hits. */\n67:   chunkParents: number;\n68:   /** Number of parents whose content was successfully reassembled from DB. */\n69:   reassembled: number;\n70:   /** Number of parents that fell back to using best-chunk content. */\n71:   fallback: number;\n72: }\n73: \n74: /**\n75:  * Internal representation of a chunk group — all chunks belonging\n76:  * to a single parent, ready for collapse and reassembly.\n77:  */\n78: interface ChunkGroup {\n79:   parentId: number;\n80:   chunks: PipelineRow[];\n81:   /** The chunk with the highest similarity/score — the representative row. */\n82:   bestChunk: PipelineRow;\n83:   /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n84:   parentScore: number;\n85: }\n86: \n87: type RerankProvider = 'fallback-sort' | 'none';\n88: \n89: // -- Stage 3 Entry Point ----------------------------------------\n90: \n91: /**\n92:  * Execute Stage 3: Rerank + Aggregate.\n93:  *\n94:  * Applies MMR diversity reranking (when enabled) and then collapses\n95:  * chunked memory hits into their parent documents (MPAB). Stage 3\n96:  * reduces near-duplicate chunks before parent reassembly aggregates\n97:  * the result set.\n98:  *\n99:  * @param input - Stage 3 input containing scored results from Stage 2\n100:  *   and the shared pipeline configuration.\n101:  * @returns Stage 3 output with reranked, aggregated results and metadata.\n102:  */\n103: export async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n104:   const stageStart = Date.now();\n105:   const { scored, config } = input;\n106: \n107:   let results = scored;\n108: \n109:   // -- Step 1: (removed) model-based cross-encoder reranking -----\n110:   // The cross-encoder / local-GGUF reranking layer was removed: it had no\n111:   // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n112:   // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n113:   // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n114:   // These constants preserve the unchanged metadata/envelope shape.\n115:   const rerankApplied = false;\n116:   const rerankProvider: RerankProvider = 'none';\n117: \n118:   // -- Step 2: MMR diversity pruning ----------------------------\n119:   // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n120:   // Vec_memories and applies Maximal Marginal Relevance to diversify\n121:   // The result set, matching the V1 hybrid-search behavior.\n122:   if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n123:     try {\n124:       const db = requireDb() as Database.Database;\n125:       const numericIds = results\n126:         .map(r => r.id)\n127:         .filter((id): id is number => typeof id === 'number');\n128: \n129:       if (numericIds.length >= MMR_MIN_CANDIDATES) {\n130:         const placeholders = numericIds.map(() => '?').join(', ');\n131:         const embRows = (db.prepare(\n132:           `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n133:         ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n134: \n135:         const embeddingMap = new Map<number, Float32Array>();\n136:         for (const row of embRows) {\n137:           if (Buffer.isBuffer(row.embedding)) {\n138:             embeddingMap.set(\n139:               row.rowid,\n140:               new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n141:             );\n142:           }\n143:         }\n144: \n145:         const mmrCandidates: MMRCandidate[] = [];\n146:         for (const r of results) {\n147:           const emb = embeddingMap.get(r.id);\n148:           if (emb) {\n149:             mmrCandidates.push({\n150:               id: r.id,\n151:               // Use effectiveScore() for consistent fallback chain\n152:               score: floorScore(effectiveScore(r)),\n153:               embedding: emb,\n154:             });\n155:           }\n156:         }\n157: \n158:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n159:           const originalPositionMap = new Map<number | string, number>();\n160:           results.forEach((row, index) => originalPositionMap.set(row.id, index));\n161:           const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n162:           const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n163:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n164: \n165:           // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n166:           // rows (lexical-only hits, graph injections) must be preserved and merged\n167:           // back in their original relative order instead of being silently dropped.\n168:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n169:           const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n170: \n171:           // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n172:           const rowMap = new Map<number | string, PipelineRow>();\n173:           for (const r of results) rowMap.set(r.id, r);\n174: \n175:           const diversifiedRows = diversified.map((candidate): PipelineRow => {\n176:             const existing = rowMap.get(candidate.id);\n177:             if (existing) return existing;\n178:             return { id: candidate.id as number, score: candidate.score };\n179:           });\n180: \n181:           const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n182:           diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n183:           nonEmbeddedRows.forEach((row) => {\n184:             const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n185:             positioned.push({ row, pos: originalPosition });\n186:           });\n187: \n188:           positioned.sort((left, right) => left.pos - right.pos);\n189:           results = positioned.map(({ row }) => row);\n190:         }\n191:       }\n192:     } catch (mmrErr: unknown) {\n193:       // Non-critical — MMR failure does not block pipeline\n194:       console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n195:     }\n196:   }\n197: \n198:   // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n199:   //\n200:   // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n201:   // Here in Stage 3 — never move it upstream.\n202:   const mpabStart = Date.now();\n203:   const beforeMpab = results.length;\n204: \n205:   const { results: aggregated, stats: chunkStats } =\n206:     await collapseAndReassembleChunkResults(results);\n207: \n208:   results = aggregated;\n209: \n210:   if (config.trace) {\n211:     addTraceEntry(\n212:       config.trace,\n213:       'final-rank',\n214:       beforeMpab,\n215:       results.length,\n216:       Date.now() - mpabStart,\n217:       {\n218:         collapsedChunkHits: chunkStats.collapsedChunkHits,\n219:         chunkParents: chunkStats.chunkParents,\n220:         reassembled: chunkStats.reassembled,\n221:         fallback: chunkStats.fallback,\n222:       }\n223:     );\n224:   }\n225: \n226:   const metadata = {\n227:     rerankApplied,\n228:     rerankProvider,\n229:     chunkReassemblyStats: chunkStats,\n230:     durationMs: Date.now() - stageStart,\n231:   };\n232: \n233:   return {\n234:     reranked: results,\n235:     metadata,\n236:   };\n237: }\n238: \n239: // -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n240: \n241: /**\n242:  * Collapse chunk-level hits and reassemble parent memory documents.\n243:  *\n244:  * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n245:  *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n246:  *   2. Group chunks by `parent_id`.\n247:  *   3. For each group, elect the best chunk (highest score).\n248:  *   4. Attempt to load the full parent content from the database.\n249:  *   5. If the DB query succeeds, emit a reassembled parent row.\n250:  *   6. If the DB query fails, fall back to the best-chunk content.\n251:  *   7. Merge non-chunks + reassembled parents, sort by score descending.\n252:  *\n253:  * Pipeline position constraint: this function MUST NOT be called before\n254:  * RRF fusion (Stage 2). It is intentionally placed in Stage 3.\n255:  *\n256:  * @param results - Scored pipeline rows from Stage 3.\n257:  * @returns Object with aggregated rows and chunk reassembly statistics.\n258:  */\n259: async function collapseAndReassembleChunkResults(\n260:   results: PipelineRow[]\n261: ): Promise<{ results: PipelineRow[]; stats: ChunkReassemblyStats }> {\n262:   const stats: ChunkReassemblyStats = {\n263:     collapsedChunkHits: 0,\n264:     chunkParents: 0,\n265:     reassembled: 0,\n266:     fallback: 0,\n267:   };\n268: \n269:   // Separate chunks from non-chunks\n270:   const nonChunks: PipelineRow[] = [];\n271:   const chunksByParent = new Map<number, PipelineRow[]>();\n272: \n273:   for (const row of results) {\n274:     const parentId = row.parent_id ?? row.parentId;\n275:     if (parentId != null && typeof parentId === 'number') {\n276:       // This row is a chunk — group by parent\n277:       const group = chunksByParent.get(parentId);\n278:       if (group) {\n279:         group.push(row);\n280:       } else {\n281:         chunksByParent.set(parentId, [row]);\n282:       }\n283:     } else {\n284:       nonChunks.push(row);\n285:     }\n286:   }\n287: \n288:   if (chunksByParent.size === 0) {\n289:     // No chunks to collapse — return results unchanged\n290:     return { results, stats };\n291:   }\n292: \n293:   stats.chunkParents = chunksByParent.size;\n294: \n295:   // Build chunk groups, electing the best chunk for each parent\n296:   const chunkGroups: ChunkGroup[] = [];\n297:   for (const [parentId, chunks] of chunksByParent) {\n298:     const bestChunk = electBestChunk(chunks);\n299:     const bestChunkScore = resolveEffectiveScore(bestChunk);\n300:     const chunkScores = chunks.map(c => resolveEffectiveScore(c));\n301:     const mpabScore = computeMPAB(chunkScores);\n302:     const parentScore = Math.max(mpabScore, bestChunkScore);\n303:     // Sort chunks by chunk_index (document order) for correct reassembly,\n304:     // Not by score order which is the default from upstream stages\n305:     chunks.sort((a, b) => {\n306:       const aIdx = ((a.chunk_index ?? a.chunkIndex) as number | undefined) ?? 0;\n307:       const bIdx = ((b.chunk_index ?? b.chunkIndex) as number | undefined) ?? 0;\n308:       return aIdx - bIdx;\n309:     });\n310:     chunkGroups.push({ parentId, chunks, bestChunk, parentScore });\n311:     // All chunks beyond the best one are collapsed\n312:     stats.collapsedChunkHits += chunks.length - 1;\n313:   }\n314: \n315:   // Attempt DB reassembly for each parent group (in parallel)\n316:   const reassembledRows = await Promise.all(\n317:     chunkGroups.map((group) => reassembleParentRow(group, stats))\n318:   );\n319: \n320:   // Merge non-chunks + reassembled parent rows, deduplicate by id (prefer highest score),\n321:   // Then sort by effective score.\n322:   // Parent rows could appear in both nonChunks and reassembledRows\n323:   // When a parent exists as a standalone row AND has chunk children.\n324:   const mergedMap = new Map<unknown, PipelineRow>();\n325:   for (const row of [...nonChunks, ...reassembledRows]) {\n326:     const existing = mergedMap.get(row.id);\n327:     if (!existing || floorScore(effectiveScore(row)) > floorScore(effectiveScore(existing))) {\n328:       mergedMap.set(row.id, row);\n329:     }\n330:   }\n331:   const merged = sortDeterministicRows(Array.from(mergedMap.values()) as Array<PipelineRow & { id: number }>);\n332: \n333:   return { results: merged, stats };\n334: }\n335: \n336: /**\n337:  * Elect the best representative chunk from a chunk group.\n338:  * Selection criteria: highest `score`, breaking ties by `similarity`.\n339:  *\n340:  * @param chunks - All chunk rows for a single parent.\n341:  * @returns The chunk with the highest effective score.\n342:  */\n343: function electBestChunk(chunks: PipelineRow[]): PipelineRow {\n344:   return chunks.reduce((best, current) => (\n345:     compareDeterministicRows(\n346:       { ...current, score: floorScore(effectiveScore(current)) } as Record<string, unknown> & { id: number },\n347:       { ...best, score: floorScore(effectiveScore(best)) } as Record<string, unknown> & { id: number },\n348:     ) < 0 ? current : best\n349:   ));\n350: }\n351: \n352: /**\n353:  * Compute the effective numeric score for a pipeline row.\n354:  * Checks all score fields in priority order to avoid silently\n355:  * discarding Stage 2 signal enrichment.\n356:  *\n357:  * Fallback chain expanded to include intentAdjustedScore\n358:  * and rrfScore before raw score/similarity, matching Stage 2's\n359:  * resolveBaseScore() pattern for defensive correctness.\n360:  *\n361:  * @param row - A pipeline result row.\n362:  * @returns Numeric score value in [0, 1] for comparison.\n363:  */\n364: // Replaced local implementation with\n365: // Shared resolveEffectiveScore() from types.ts for consistency with Stage 2.\n366: const effectiveScore = resolveEffectiveScore;\n367: \n368: /**\n369:  * Attempt to reassemble a full parent memory row from the database.\n370:  *\n371:  * On success, returns a PipelineRow that merges:\n372:  *   - All best-chunk fields as the base\n373:  *   - Parent-level content from the DB (if available)\n374:  *   - `contentSource: 'reassembled_chunks'` to mark provenance\n375:  *\n376:  * On failure, returns the best-chunk row with\n377:  *   `contentSource: 'file_read_fallback'`.\n378:  *\n379:  * @param group  - The chunk group (parentId + chunks + bestChunk).\n380:  * @param stats  - Mutable stats object updated in place.\n381:  * @returns A PipelineRow representing the parent document.\n382:  */\n383: async function reassembleParentRow(\n384:   group: ChunkGroup,\n385:   stats: ChunkReassemblyStats\n386: ): Promise<PipelineRow> {\n387:   const { parentId, bestChunk, parentScore } = group;\n388: \n389:   try {\n390:     const db = requireDb();\n391: \n392:     // Query the parent memory row for content and metadata\n393:     const parentRow = db\n394:       .prepare(\n395:         `SELECT id, file_path, content_text, importance_tier, importance_weight,\n396:                 quality_score, created_at, context_type\n397:          FROM memory_index\n398:          WHERE id = ?\n399:          LIMIT 1`\n400:       )\n401:       .get(parentId) as Record<string, unknown> | undefined;\n402: \n403:     if (!parentRow) {\n404:       // Parent not found in DB — use best chunk as fallback\n405:       stats.fallback++;\n406:       return markFallback(bestChunk, parentScore);\n407:     }\n408: \n409:     const reassembledContent =\n410:       (parentRow.content_text as string | undefined) ?? bestChunk.content;\n411: \n412:     // Merge parent metadata onto the best-chunk base row\n413:     const reassembled: PipelineRow = {\n414:       ...bestChunk,\n415:       // Override identity fields with parent values\n416:       id: parentId,\n417:       file_path: (parentRow.file_path as string | undefined) ?? bestChunk.file_path,\n418:       importance_tier: (parentRow.importance_tier as string | undefined) ?? bestChunk.importance_tier,\n419:       importance_weight: (parentRow.importance_weight as number | undefined) ?? bestChunk.importance_weight,\n420:       quality_score: (parentRow.quality_score as number | undefined) ?? bestChunk.quality_score,\n421:       created_at: (parentRow.created_at as string | undefined) ?? bestChunk.created_at,\n422:       context_type: (parentRow.context_type as string | undefined) ?? bestChunk.context_type,\n423:       // FIX #8: Sync content with precomputedContent after reassembly.\n424:       // Previously, `content` still had the chunk fragment while\n425:       // `precomputedContent` had the full reassembled parent text.\n426:       content: reassembledContent,\n427:       precomputedContent: reassembledContent,\n428:       contentSource: 'reassembled_chunks',\n429:       score: parentScore,\n430:       rrfScore: parentScore,\n431:       intentAdjustedScore: parentScore,\n432:       // Clear chunk-specific fields on the reassembled parent\n433:       parent_id: null,\n434:       parentId: null,\n435:       chunk_index: null,\n436:       chunkIndex: null,\n437:       chunk_label: null,\n438:       chunkLabel: null,\n439:       isChunk: false,\n440:     };\n441: \n442:     stats.reassembled++;\n443:     return reassembled;\n444:   } catch (err: unknown) {\n445:     // DB error — gracefully fall back to best-chunk content\n446:     console.warn(\n447:       `[stage3-rerank] MPAB DB reassembly failed for parent ${parentId}: ${toErrorMessage(err)} — using chunk fallback`\n448:     );\n449:     stats.fallback++;\n450:     return markFallback(bestChunk, parentScore);\n451:   }\n452: }\n453: \n454: /**\n455:  * Mark a pipeline row as a chunk-content fallback.\n456:  * Clears chunk-specific identity fields and marks the content source.\n457:  *\n458:  * @param chunk - The elected best-chunk row.\n459:  * @param parentScore - Parent-level score after MPAB aggregation.\n460:  * @returns A new PipelineRow annotated as a fallback parent representation.\n461:  */\n462: function markFallback(chunk: PipelineRow, parentScore: number): PipelineRow {\n463:   const parentId =\n464:     chunk.parent_id ??\n465:     chunk.parentId ??\n466:     (chunk as { parentMemoryId?: number | null }).parentMemoryId ??\n467:     chunk.id;\n468: \n469:   return {\n470:     ...chunk,\n471:     id: parentId,\n472:     contentSource: 'file_read_fallback',\n473:     score: parentScore,\n474:     rrfScore: parentScore,\n475:     intentAdjustedScore: parentScore,\n476:     // Promote chunk to parent-level identity by clearing chunk markers\n477:     parent_id: null,\n478:     parentId: null,\n479:     chunk_index: undefined,\n480:     chunkIndex: undefined,\n481:     chunk_label: null,\n482:     chunkLabel: null,\n483:     isChunk: false,\n484:     is_chunk: false,\n485:   };\n486: }\n487: \n488: // -- Test Exports -----------------------------------------------\n489: \n490: /**\n491:  * Internal functions exported for unit testing.\n492:  * Do not rely on these in production code — the API is not stable.\n493:  *\n494:  * @internal\n495:  */\n496: export const __testables = {\n497:   collapseAndReassembleChunkResults,\n498:   electBestChunk,\n499:   effectiveScore,\n500:   reassembleParentRow,\n501:   markFallback,\n502: };\n\n(End of file - total 502 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage3 Rerank\n// ───────────────────────────────────────────────────────────────\n// 4-Stage Retrieval Pipeline: Stage 3 of 4\n//\n// Responsibilities (in execution order):\n// 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n// 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n//\n// Pipeline position constraint:\n// MPAB MUST remain AFTER RRF fusion (Stage 2).\n// Stage 3 is the only stage that may change scores after Stage 2.\n//\n// I/O CONTRACT:\n// Input:  Stage3Input { scored: PipelineRow[], config }\n// Output: Stage3Output { reranked: PipelineRow[], metadata }\n// Key invariants:\n//     - reranked is sorted descending by effective score after all steps\n//     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n//     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage3 Rerank\n// ───────────────────────────────────────────────────────────────\n// 4-Stage Retrieval Pipeline: Stage 3 of 4\n//\n// Responsibilities (in execution order):\n// 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n// 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n//\n// Pipeline position constraint:\n// MPAB MUST remain AFTER RRF fusion (Stage 2).\n// Stage 3 is the only stage that may change scores after Stage 2.\n//\n// I/O CONTRACT:\n// Input:  Stage3Input { scored: PipelineRow[], config }\n// Output: Stage3Output { reranked: PipelineRow[], metadata }\n// Key invariants:\n//     - reranked is sorted descending by effective score after all steps\n//     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n//     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'\n// Side effects:\n//     - DB reads to fetch parent content during MPAB reassembly\n//\n// Score changes: YES\n\nimport { resolveEffectiveScore } from './types.js';\nimport type { Stage3Input, Stage3Output, PipelineRow } from './types.js';\nimport { isMMREnabled } from '../search-flags.js';\nimport { computeMPAB } from '../../scoring/mpab-aggregation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP } from '../intent-classifier.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/index.js';\nimport { toErrorMessage } from '../../../utils/index.js';\nimport type Database from 'better-sqlite3';\nimport { compareDeterministicRows, sortDeterministicRows } from './ranking-contract.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Hybrid search pipeline\n\n\n// -- Constants --------------------------------------------------\n\n/** Minimum number of candidates required before MMR diversity pruning is worthwhile. */\nconst MMR_MIN_CANDIDATES = 2;\n\n/** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\nconst MMR_DEFAULT_LAMBDA = 0.7;\n\n/**\n * Enforce non-negative score outputs at Stage 3 boundaries.\n */\nfunction floorScore(value: number): number {\n  return Math.max(0, value);\n}\n\n// -- Internal Interfaces ----------------------------------------\n\n/**\n * Aggregated statistics from the MPAB chunk-collapse pass.\n */\ninterface ChunkReassemblyStats {\n  /** Number of child chunk rows removed from the result set. */\n  collapsedChunkHits: number;\n  /** Number of distinct parent IDs encountered among chunk hits. */\n  chunkParents: number;\n  /** Number of parents whose content was successfully reassembled from DB. */\n  reassembled: number;\n  /** Number of parents that fell back to using best-chunk content. */\n  fallback: number;\n}\n\n/**\n * Internal representation of a chunk group — all chunks belonging\n * to a single parent, ready for collapse and reassembly.\n */\ninterface ChunkGroup {\n  parentId: number;\n  chunks: PipelineRow[];\n  /** The chunk with the highest similarity/score — the representative row. */\n  bestChunk: PipelineRow;\n  /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n  parentScore: number;\n}\n\ntype RerankProvider = 'fallback-sort' | 'none';\n\n// -- Stage 3 Entry Point ----------------------------------------\n\n/**\n * Execute Stage 3: Rerank + Aggregate.\n *\n * Applies MMR diversity reranking (when enabled) and then collapses\n * chunked memory hits into their parent documents (MPAB). Stage 3\n * reduces near-duplicate chunks before parent reassembly aggregates\n * the result set.\n *\n * @param input - Stage 3 input containing scored results from Stage 2\n *   and the shared pipeline configuration.\n * @returns Stage 3 output with reranked, aggregated results and metadata.\n */\nexport async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n  const stageStart = Date.now();\n  const { scored, config } = input;\n\n  let results = scored;\n\n  // -- Step 1: (removed) model-based cross-encoder reranking -----\n  // The cross-encoder / local-GGUF reranking layer was removed: it had no\n  // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n  // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n  // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n  // These constants preserve the unchanged metadata/envelope shape.\n  const rerankApplied = false;\n  const rerankProvider: RerankProvider = 'none';\n\n  // -- Step 2: MMR diversity pruning ----------------------------\n  // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n  // Vec_memories and applies Maximal Marginal Relevance to diversify\n  // The result set, matching the V1 hybrid-search behavior.\n  if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n    try {\n      const db = requireDb() as Database.Database;\n      const numericIds = results\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length >= MMR_MIN_CANDIDATES) {\n        const placeholders = numericIds.map(() => '?').join(', ');\n        const embRows = (db.prepare(\n          `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n        ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n        const embeddingMap = new Map<number, Float32Array>();\n        for (const row of embRows) {\n          if (Buffer.isBuffer(row.embedding)) {\n            embeddingMap.set(\n              row.rowid,\n              new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n            );\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of results) {\n          const emb = embeddingMap.get(r.id);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id,\n              // Use effectiveScore() for consistent fallback chain\n              score: floorScore(effectiveScore(r)),\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const originalPositionMap = new Map<number | string, number>();\n          results.forEach((row, index) => originalPositionMap.set(row.id, index));\n          const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n          const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n\n          // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n          // rows (lexical-only hits, graph injections) must be preserved and merged\n          // back in their original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n\n          // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n          const rowMap = new Map<number | string, PipelineRow>();\n          for (const r of results) rowMap.set(r.id, r);\n\n          const diversifiedRows = diversified.map((candidate): PipelineRow => {\n            const existing = rowMap.get(candidate.id);\n            if (existing) return existing;\n            return { id: candidate.id as number, score: candidate.score };\n          });\n\n          const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n          diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n          nonEmbeddedRows.forEach((row) => {\n            const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n            positioned.push({ row, pos: originalPosition });\n          });\n\n          positioned.sort((left, right) => left.pos - right.pos);\n          results = positioned.map(({ row }) => row);\n        }\n      }\n    } catch (mmrErr: unknown) {\n      // Non-critical — MMR failure does not block pipeline\n      console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n    }\n  }\n\n  // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n  //\n  // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n  // Here in Stage 3 — never move it upstream.\n  const mpabStart = Date.now();\n  const beforeMpab = results.length;\n\n  const { results: aggregated, stats: chunkStats } =\n    await collapseAndReassembleChunkResults(results);\n\n  results = aggregated;\n\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'final-rank',\n      beforeMpab,\n      results.length,\n      Date.now() - mpabStart,\n      {\n        collapsedChunkHits: chunkStats.collapsedChunkHits,\n        chunkParents: chunkStats.chunkParents,\n        reassembled: chunkStats.reassembled,\n        fallback: chunkStats.fallback,\n      }\n    );\n  }\n\n  const metadata = {\n    rerankApplied,\n    rerankProvider,\n    chunkReassemblyStats: chunkStats,\n    durationMs: Date.now() - stageStart,\n  };\n\n  return {\n    reranked: results,\n    metadata,\n  };\n}\n\n// -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n\n/**\n * Collapse chunk-level hits and reassemble parent memory documents.\n *\n * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n *   2. Group chunks by `parent_id`.\n *   3. For each group, elect the best chunk (highest score).\n *   4. Attempt to load the full parent content from the database.\n *   5. If the DB query succeeds, emit a reassembled parent row.\n *   6. If the DB query fails, fall back to the best-chunk content.\n *   7. Merge non-chunks + reassembled parents, sort by score descending.\n *\n * Pipeline position constraint: this function MUST NOT be called before\n * RRF fusion (Stage 2). It is intentionally placed in Stage 3.\n *\n * @param results - Scored pipeline rows from Stage 3.\n * @returns Object with aggregated rows and chunk reassembly statistics.\n */\nasync function collapseAndReassembleChunkResults(\n  results: PipelineRow[]\n): Promise<{ results: PipelineRow[]; stats: ChunkReassemblyStats }> {\n  const stats: ChunkReassemblyStats = {\n    collapsedChunkHits: 0,\n    chunkParents: 0,\n    reassembled: 0,\n    fallback: 0,\n  };\n\n  // Separate chunks from non-chunks\n  const nonChunks: PipelineRow[] = [];\n  const chunksByParent = new Map<number, PipelineRow[]>();\n\n  for (const row of results) {\n    const parentId = row.parent_id ?? row.parentId;\n    if (parentId != null && typeof parentId === 'number') {\n      // This row is a chunk — group by parent\n      const group = chunksByParent.get(parentId);\n      if (group) {\n        group.push(row);\n      } else {\n        chunksByParent.set(parentId, [row]);\n      }\n    } else {\n      nonChunks.push(row);\n    }\n  }\n\n  if (chunksByParent.size === 0) {\n    // No chunks to collapse — return results unchanged\n    return { results, stats };\n  }\n\n  stats.chunkParents = chunksByParent.size;\n\n  // Build chunk groups, electing the best chunk for each parent\n  const chunkGroups: ChunkGroup[] = [];\n  for (const [parentId, chunks] of chunksByParent) {\n    const bestChunk = electBestChunk(chunks);\n    const bestChunkScore = resolveEffectiveScore(bestChunk);\n    const chunkScores = chunks.map(c => resolveEffectiveScore(c));\n    const mpabScore = computeMPAB(chunkScores);\n    const parentScore = Math.max(mpabScore, bestChunkScore);\n    // Sort chunks by chunk_index (document order) for correct reassembly,\n    // Not by score order which is the default from upstream stages\n    chunks.sort((a, b) => {\n      const aIdx = ((a.chunk_index ?? a.chunkIndex) as number | undefined) ?? 0;\n      const bIdx = ((b.chunk_index ?? b.chunkIndex) as number | undefined) ?? 0;\n      return aIdx - bIdx;\n    });\n    chunkGroups.push({ parentId, chunks, bestChunk, parentScore });\n    // All chunks beyond the best one are collapsed\n    stats.collapsedChunkHits += chunks.length - 1;\n  }\n\n  // Attempt DB reassembly for each parent group (in parallel)\n  const reassembledRows = await Promise.all(\n    chunkGroups.map((group) => reassembleParentRow(group, stats))\n  );\n\n  // Merge non-chunks + reassembled parent rows, deduplicate by id (prefer highest score),\n  // Then sort by effective score.\n  // Parent rows could appear in both nonChunks and reassembledRows\n  // When a parent exists as a standalone row AND has chunk children.\n  const mergedMap = new Map<unknown, PipelineRow>();\n  for (const row of [...nonChunks, ...reassembledRows]) {\n    const existing = mergedMap.get(row.id);\n    if (!existing || floorScore(effectiveScore(row)) > floorScore(effectiveScore(existing))) {\n      mergedMap.set(row.id, row);\n    }\n  }\n  const merged = sortDeterministicRows(Array.from(mergedMap.values()) as Array<PipelineRow & { id: number }>);\n\n  return { results: merged, stats };\n}\n\n/**\n * Elect the best representative chunk from a chunk group.\n * Selection criteria: highest `score`, breaking ties by `similarity`.\n *\n * @param chunks - All chunk rows for a single parent.\n * @returns The chunk with the highest effective score.\n */\nfunction electBestChunk(chunks: PipelineRow[]): PipelineRow {\n  return chunks.reduce((best, current) => (\n    compareDeterministicRows(\n      { ...current, score: floorScore(effectiveScore(current)) } as Record<string, unknown> & { id: number },\n      { ...best, score: floorScore(effectiveScore(best)) } as Record<string, unknown> & { id: number },\n    ) < 0 ? current : best\n  ));\n}\n\n/**\n * Compute the effective numeric score for a pipeline row.\n * Checks all score fields in priority order to avoid silently\n * discarding Stage 2 signal enrichment.\n *\n * Fallback chain expanded to include intentAdjustedScore\n * and rrfScore before raw score/similarity, matching Stage 2's\n * resolveBaseScore() pattern for defensive correctness.\n *\n * @param row - A pipeline result row.\n * @returns Numeric score value in [0, 1] for comparison.\n */\n// Replaced local implementation with\n// Shared resolveEffectiveScore() from types.ts for consistency with Stage 2.\nconst effectiveScore = resolveEffectiveScore;\n\n/**\n * Attempt to reassemble a full parent memory row from the database.\n *\n * On success, returns a PipelineRow that merges:\n *   - All best-chunk fields as the base\n *   - Parent-level content from the DB (if available)\n *   - `contentSource: 'reassembled_chunks'` to mark provenance\n *\n * On failure, returns the best-chunk row with\n *   `contentSource: 'file_read_fallback'`.\n *\n * @param group  - The chunk group (parentId + chunks + bestChunk).\n * @param stats  - Mutable stats object updated in place.\n * @returns A PipelineRow representing the parent document.\n */\nasync function reassembleParentRow(\n  group: ChunkGroup,\n  stats: ChunkReassemblyStats\n): Promise<PipelineRow> {\n  const { parentId, bestChunk, parentScore } = group;\n\n  try {\n    const db = requireDb();\n\n    // Query the parent memory row for content and metadata\n    const parentRow = db\n      .prepare(\n        `SELECT id, file_path, content_text, importance_tier, importance_weight,\n                quality_score, created_at, context_type\n         FROM memory_index\n         WHERE id = ?\n         LIMIT 1`\n      )\n      .get(parentId) as Record<string, unknown> | undefined;\n\n    if (!parentRow) {\n      // Parent not found in DB — use best chunk as fallback\n      stats.fallback++;\n      return markFallback(bestChunk, parentScore);\n    }\n\n    const reassembledContent =\n      (parentRow.content_text as string | undefined) ?? bestChunk.content;\n\n    // Merge parent metadata onto the best-chunk base row\n    const reassembled: PipelineRow = {\n      ...bestChunk,\n      // Override identity fields with parent values\n      id: parentId,\n      file_path: (parentRow.file_path as string | undefined) ?? bestChunk.file_path,\n      importance_tier: (parentRow.importance_tier as string | undefined) ?? bestChunk.importance_tier,\n      importance_weight: (parentRow.importance_weight as number | undefined) ?? bestChunk.importance_weight,\n      quality_score: (parentRow.quality_score as number | undefined) ?? bestChunk.quality_score,\n      created_at: (parentRow.created_at as string | undefined) ?? bestChunk.created_at,\n      context_type: (parentRow.context_type as string | undefined) ?? bestChunk.context_type,\n      // FIX #8: Sync content with precomputedContent after reassembly.\n      // Previously, `content` still had the chunk fragment while\n      // `precomputedContent` had the full reassembled parent text.\n      content: reassembledContent,\n      precomputedContent: reassembledContent,\n      contentSource: 'reassembled_chunks',\n      score: parentScore,\n      rrfScore: parentScore,\n      intentAdjustedScore: parentScore,\n      // Clear chunk-specific fields on the reassembled parent\n      parent_id: null,\n      parentId: null,\n      chunk_index: null,\n      chunkIndex: null,\n      chunk_label: null,\n      chunkLabel: null,\n      isChunk: false,\n    };\n\n    stats.reassembled++;\n    return reassembled;\n  } catch (err: unknown) {\n    // DB error — gracefully fall back to best-chunk content\n    console.warn(\n      `[stage3-rerank] MPAB DB reassembly failed for parent ${parentId}: ${toErrorMessage(err)} — using chunk fallback`\n    );\n    stats.fallback++;\n    return markFallback(bestChunk, parentScore);\n  }\n}\n\n/**\n * Mark a pipeline row as a chunk-content fallback.\n * Clears chunk-specific identity fields and marks the content source.\n *\n * @param chunk - The elected best-chunk row.\n * @param parentScore - Parent-level score after MPAB aggregation.\n * @returns A new PipelineRow annotated as a fallback parent representation.\n */\nfunction markFallback(chunk: PipelineRow, parentScore: number): PipelineRow {\n  const parentId =\n    chunk.parent_id ??\n    chunk.parentId ??\n    (chunk as { parentMemoryId?: number | null }).parentMemoryId ??\n    chunk.id;\n\n  return {\n    ...chunk,\n    id: parentId,\n    contentSource: 'file_read_fallback',\n    score: parentScore,\n    rrfScore: parentScore,\n    intentAdjustedScore: parentScore,\n    // Promote chunk to parent-level identity by clearing chunk markers\n    parent_id: null,\n    parentId: null,\n    chunk_index: undefined,\n    chunkIndex: undefined,\n    chunk_label: null,\n    chunkLabel: null,\n    isChunk: false,\n    is_chunk: false,\n  };\n}\n\n// -- Test Exports -----------------------------------------------\n\n/**\n * Internal functions exported for unit testing.\n * Do not rely on these in production code — the API is not stable.\n *\n * @internal\n */\nexport const __testables = {\n  collapseAndReassembleChunkResults,\n  electBestChunk,\n  effectiveScore,\n  reassembleParentRow,\n  markFallback,\n};","lineStart":1,"lineEnd":502,"totalLines":502,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","time":{"start":1781761461769,"end":1781761461776}},"metadata":{"openai":{"itemId":"fc_0f1c4e9a802a812e016a3385b5a6288191a6c565fb56f5576c"}},"id":"prt_ed9424e05001EPZs5lfQaZBZzA","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed9421d3d001fIaymXsx6pDkWD"}}
{"type":"tool_use","timestamp":1781761461781,"sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","part":{"type":"tool","tool":"read","callID":"call_8H5VJGNPs33ITg4dc7egcG87","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":520,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n520:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n521:   }\n522: \n523:   const vectorSource = getActiveVectorSourceForQuery(database);\n524:   for (const emb of concepts) {\n525:     if (!emb || emb.length !== vectorSource.dim) {\n526:       throw new VectorIndexError(\n527:         `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n528:         VectorIndexErrorCode.QUERY_FAILED,\n529:       );\n530:     }\n531:   }\n532: \n533:   const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n534: \n535:   const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n536:   const max_distance = 2 * (1 - minSimilarity / 100);\n537: \n538:   const distance_expressions = concept_buffers.map((_, i) =>\n539:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n540:   ).join(', ');\n541: \n542:   const distance_filters = concept_buffers.map((_, _i) =>\n543:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n544:   ).join(' AND ');\n545: \n546:   const folder_filter = specFolder ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\" : '';\n547:   const similarity_select = concept_buffers.map((_, i) =>\n548:     `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n549:   ).join(', ');\n550: \n551:   const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n552: \n553:   const sql = `\n554:     SELECT\n555:       sub.*,\n556:       ${similarity_select},\n557:       (${avg_distance_expr}) / ${concepts.length} as avg_distance\n558:     FROM (\n559:       SELECT\n560:         m.*,\n561:         ${distance_expressions}\n562:       FROM memory_index m\n563:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n564:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n565:       WHERE m.embedding_status = 'success'\n566:         AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n567:         ${folder_filter}\n568:         AND ${distance_filters}\n569:     ) sub\n570:     ORDER BY avg_distance ASC\n571:     LIMIT ?\n572:   `;\n573: \n574:   const params = [\n575:     ...concept_buffers,\n576:     ...(specFolder ? [specFolder, specFolderLikePattern(specFolder)] : []),\n577:     ...concept_buffers.flatMap(b => [b, max_distance]),\n578:     limit\n579:   ];\n580: \n581:   const rows = database.prepare(sql).all(...params);\n582: \n583:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n584:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n585:     row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n586:     row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n587:     row.isConstitutional = row.importance_tier === 'constitutional';\n588:     return row;\n589:   });\n590: }\n591: \n592: /* ───────────────────────────────────────────────────────────────\n593:    CONTENT EXTRACTION HELPERS\n594: ----------------------------------------------------------------*/\n595: \n596: /**\n597:  * Extracts a display title from indexed content.\n598:  * @param content - The content to inspect.\n599:  * @param filename - The optional source filename.\n600:  * @returns The extracted title.\n601:  */\n602: export function extract_title(content: unknown, filename?: string): string {\n603:   if (!content || typeof content !== 'string') {\n604:     return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n605:   }\n606: \n607:   const h1_match = content.match(/^#\\s+(.+)$/m);\n608:   if (h1_match && h1_match[1]) {\n609:     return h1_match[1].trim();\n610:   }\n611: \n612:   const h2_match = content.match(/^##\\s+(.+)$/m);\n613:   if (h2_match && h2_match[1]) {\n614:     return h2_match[1].trim();\n615:   }\n616: \n617:   const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n618:   if (yaml_match && yaml_match[1]) {\n619:     return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n620:   }\n621: \n622:   const lines = content.split('\\n').filter(l => l.trim().length > 0);\n623:   if (lines.length > 0) {\n624:     const first_line = lines[0].trim();\n625:     return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n626:   }\n627: \n628:   return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n629: }\n630: \n631: /**\n632:  * Extracts a preview snippet from indexed content.\n633:  * @param content - The content to inspect.\n634:  * @param max_length - The maximum snippet length.\n635:  * @returns The extracted snippet.\n636:  */\n637: export function extract_snippet(content: unknown, max_length = 200): string {\n638:   if (!content || typeof content !== 'string') {\n639:     return '';\n640:   }\n641: \n642:   const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n643:   const lines = text.split('\\n');\n644:   const snippet_lines: string[] = [];\n645: \n646:   for (const line of lines) {\n647:     const trimmed = line.trim();\n648: \n649:     if (!trimmed || /^#+\\s/.test(trimmed)) {\n650:       if (snippet_lines.length > 0) {\n651:         break;\n652:       }\n653:       continue;\n654:     }\n655: \n656:     if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n657:       continue;\n658:     }\n659: \n660:     snippet_lines.push(trimmed);\n661: \n662:     const current_length = snippet_lines.join(' ').length;\n663:     if (current_length >= max_length) {\n664:       break;\n665:     }\n666:   }\n667: \n668:   let snippet = snippet_lines.join(' ');\n669: \n670:   if (snippet.length > max_length) {\n671:     snippet = snippet.substring(0, max_length);\n672:     const last_space = snippet.lastIndexOf(' ');\n673:     if (last_space > max_length * 0.7) {\n674:       snippet = snippet.substring(0, last_space);\n675:     }\n676:     snippet += '...';\n677:   }\n678: \n679:   return snippet;\n680: }\n681: \n682: /**\n683:  * Extracts tags from indexed content.\n684:  * @param content - The content to inspect.\n685:  * @returns The extracted tags.\n686:  */\n687: export function extract_tags(content: unknown): string[] {\n688:   if (!content || typeof content !== 'string') {\n689:     console.warn('[vector-index] extract_tags: invalid content type, expected string');\n690:     return [];\n691:   }\n692: \n693:   const tags = new Set<string>();\n694: \n695:   const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n696:   if (yaml_tags_match && yaml_tags_match[1]) {\n697:     yaml_tags_match[1].split(',').forEach(tag => {\n698:       const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n699:       if (cleaned) tags.add(cleaned.toLowerCase());\n700:     });\n701:   }\n702: \n703:   const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n704:   if (yaml_list_match && yaml_list_match[1]) {\n705:     yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n706:       const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n707:       if (tag) tags.add(tag.toLowerCase());\n708:     });\n709:   }\n710: \n711:   const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n712:   if (hashtag_matches) {\n713:     hashtag_matches.forEach(match => {\n714:       const tag = match.trim().replace(/^#/, '');\n715:       if (tag && !tag.match(/^[0-9]+$/)) {\n716:         tags.add(tag.toLowerCase());\n717:       }\n718:     });\n719:   }\n720: \n721:   return Array.from(tags);\n722: }\n723: \n724: /**\n725:  * Extracts a relevant date from indexed content or path.\n726:  * @param content - The content to inspect.\n727:  * @param file_path - The optional source file path.\n728:  * @returns The extracted date, if available.\n729:  */\n730: export function extract_date(content: unknown, file_path?: string): string | null {\n731:   if (content && typeof content === 'string') {\n732:     const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n733:     if (date_match && date_match[1]) {\n734:       const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n735:       try {\n736:         const parsed = new Date(date_str);\n737:         if (!isNaN(parsed.getTime())) {\n738:           return parsed.toISOString().split('T')[0];\n739:         }\n740:       } catch (_e: unknown) {\n741:         console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n742:       }\n743:     }\n744:   }\n745: \n746:   if (file_path) {\n747:     const filename = path.basename(file_path);\n748: \n749:     const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n750:     if (iso_match) {\n751:       return iso_match[1];\n752:     }\n753: \n754:     const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n755:     if (ddmmyy_match) {\n756:       const [, day, month, year] = ddmmyy_match;\n757:       const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n758:       return `${full_year}-${month}-${day}`;\n759:     }\n760:   }\n761: \n762:   return null;\n763: }\n764: \n765: /* ───────────────────────────────────────────────────────────────\n766:    EMBEDDING GENERATION WRAPPER\n767: ----------------------------------------------------------------*/\n768: \n769: /**\n770:  * Generates an embedding for a search query.\n771:  * @param query - The search query.\n772:  * @returns A promise that resolves to the embedding, if generated.\n773:  */\n774: export async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n775:   if (!query || typeof query !== 'string' || query.trim().length === 0) {\n776:     console.warn('[vector-index] Empty query provided for embedding');\n777:     return null;\n778:   }\n779: \n780:   try {\n781:     const database = initialize_db();\n782:     const active = getActiveEmbedder(database);\n783:     const trimmedQuery = query.trim();\n784:     const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n785:       ? active.name\n786:       : embeddingsProvider.getModelName();\n787:     const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n788:       ? active.dim\n789:       : embeddingsProvider.getEmbeddingDimension();\n790:     const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n791:     const contentHash = computeContentHash(trimmedQuery);\n792:     const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n793:       profileKey,\n794:       inputKind: 'query',\n795:     });\n796:     if (cached) {\n797:       return new Float32Array(\n798:         cached.buffer,\n799:         cached.byteOffset,\n800:         Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n801:       );\n802:     }\n803: \n804:     const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n805:       ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n806:       : getStartupEmbeddingProfile().provider;\n807:     const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n808:     const activeAdapter = adapter as typeof adapter & {\n809:       embed: (\n810:         texts: ReadonlyArray<string>,\n811:         options?: { inputType?: 'query' | 'document' },\n812:       ) => Promise<Float32Array[]>;\n813:     };\n814:     const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n815:     const embedding: Float32Array | null = activeEmbedding ?? null;\n816: \n817:     if (embedding) {\n818:       storeEmbedding(\n819:         database,\n820:         contentHash,\n821:         modelId,\n822:         Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n823:         embedding.length,\n824:         { profileKey, inputKind: 'query' },\n825:       );\n826:     }\n827: \n828:     return embedding;\n829:   } catch (error: unknown) {\n830:     console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n831:     return null;\n832:   }\n833: }\n834: \n835: /* ───────────────────────────────────────────────────────────────\n836:    KEYWORD SEARCH FALLBACK\n837: ----------------------------------------------------------------*/\n838: \n839: /**\n840:  * Searches indexed memories using keyword matching.\n841:  * @param query - The search query.\n842:  * @param options - Search options.\n843:  * @returns The matching memory rows.\n844:  */\n845: export function keyword_search(\n846:   query: string,\n847:   options: { limit?: number; specFolder?: string | null } = {},\n848:   database: Database.Database = initialize_db(),\n849: ): MemoryRow[] {\n850:   const { limit = 20, specFolder = null } = options;\n851: \n852:   if (!query || typeof query !== 'string') {\n853:     console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n854:     return [];\n855:   }\n856: \n857:   const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n858:   if (search_terms.length === 0) {\n859:     console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n860:     return [];\n861:   }\n862: \n863:   let where_clause = '1=1';\n864:   const params: unknown[] = [];\n865: \n866:   if (specFolder) {\n867:     where_clause += \" AND (spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')\";\n868:     params.push(specFolder, specFolderLikePattern(specFolder));\n869:   }\n870: \n871:   const sql = `\n872:     SELECT m.* FROM memory_index m\n873:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n874:     WHERE ${where_clause}\n875:     ORDER BY m.importance_weight DESC, m.created_at DESC\n876:   `;\n877: \n878:   const rows = database.prepare(sql).all(...params);\n879: \n880:   const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n881:     let score = 0;\n882:     const searchable_text = [\n883:       row.title || '',\n884:       parse_trigger_phrases(row.trigger_phrases).join(' '),\n885:       row.spec_folder || '',\n886:       row.file_path || ''\n887:     ].join(' ').toLowerCase();\n888: \n889:     for (const term of search_terms) {\n890:       if (searchable_text.includes(term)) {\n891:         score += 1;\n892:         if ((row.title || '').toLowerCase().includes(term)) {\n893:           score += 2;\n894:         }\n895:         if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n896:           score += 1.5;\n897:         }\n898:       }\n899:     }\n900: \n901:     score *= (0.5 + (row.importance_weight ?? 0));\n902:     return { ...row, keyword_score: score };\n903:   });\n904: \n905:   const filtered = scored\n906:     .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n907:     .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n908:     .slice(0, limit);\n909: \n910:   return filtered.map((row: MemoryRow) => {\n911:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n912:     row.isConstitutional = row.importance_tier === 'constitutional';\n913:     return row;\n914:   });\n915: }\n916: \n917: /* ───────────────────────────────────────────────────────────────\n918:    ENRICHED VECTOR SEARCH\n919: ----------------------------------------------------------------*/\n920: \n921: /**\n922:  * Runs enriched vector search for a text query.\n923:  * @param query - The search query.\n924:  * @param limit - The maximum number of results to return.\n925:  * @param options - Search options.\n926:  * @returns A promise that resolves to enriched search results.\n927:  * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n928:  * @example\n929:  * ```ts\n930:  * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n931:  * ```\n932:  */\n933: export async function vector_search_enriched(\n934:   query: string,\n935:   limit = 20,\n936:   options: { specFolder?: string | null; minSimilarity?: number } = {},\n937:   database: Database.Database = initialize_db(),\n938: ): Promise<EnrichedSearchResult[]> {\n939:   const start_time = Date.now();\n\n(Showing lines 520-939 of 1742. Use offset=940 to continue.)\n</content>","metadata":{"preview":"    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  for (const emb of concepts) {\n    if (!emb || emb.length !== vectorSource.dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n        VectorIndexErrorCode.QUERY_FAILED,\n      );\n    }\n  }\n\n  const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  const distance_expressions = concept_buffers.map((_, i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  for (const emb of concepts) {\n    if (!emb || emb.length !== vectorSource.dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n        VectorIndexErrorCode.QUERY_FAILED,\n      );\n    }\n  }\n\n  const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  const distance_expressions = concept_buffers.map((_, i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n  ).join(', ');\n\n  const distance_filters = concept_buffers.map((_, _i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n  ).join(' AND ');\n\n  const folder_filter = specFolder ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\" : '';\n  const similarity_select = concept_buffers.map((_, i) =>\n    `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n  ).join(', ');\n\n  const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n\n  const sql = `\n    SELECT\n      sub.*,\n      ${similarity_select},\n      (${avg_distance_expr}) / ${concepts.length} as avg_distance\n    FROM (\n      SELECT\n        m.*,\n        ${distance_expressions}\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE m.embedding_status = 'success'\n        AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n        ${folder_filter}\n        AND ${distance_filters}\n    ) sub\n    ORDER BY avg_distance ASC\n    LIMIT ?\n  `;\n\n  const params = [\n    ...concept_buffers,\n    ...(specFolder ? [specFolder, specFolderLikePattern(specFolder)] : []),\n    ...concept_buffers.flatMap(b => [b, max_distance]),\n    limit\n  ];\n\n  const rows = database.prepare(sql).all(...params);\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n    row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CONTENT EXTRACTION HELPERS\n----------------------------------------------------------------*/\n\n/**\n * Extracts a display title from indexed content.\n * @param content - The content to inspect.\n * @param filename - The optional source filename.\n * @returns The extracted title.\n */\nexport function extract_title(content: unknown, filename?: string): string {\n  if (!content || typeof content !== 'string') {\n    return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n  }\n\n  const h1_match = content.match(/^#\\s+(.+)$/m);\n  if (h1_match && h1_match[1]) {\n    return h1_match[1].trim();\n  }\n\n  const h2_match = content.match(/^##\\s+(.+)$/m);\n  if (h2_match && h2_match[1]) {\n    return h2_match[1].trim();\n  }\n\n  const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n  if (yaml_match && yaml_match[1]) {\n    return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n  }\n\n  const lines = content.split('\\n').filter(l => l.trim().length > 0);\n  if (lines.length > 0) {\n    const first_line = lines[0].trim();\n    return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n  }\n\n  return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n}\n\n/**\n * Extracts a preview snippet from indexed content.\n * @param content - The content to inspect.\n * @param max_length - The maximum snippet length.\n * @returns The extracted snippet.\n */\nexport function extract_snippet(content: unknown, max_length = 200): string {\n  if (!content || typeof content !== 'string') {\n    return '';\n  }\n\n  const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n  const lines = text.split('\\n');\n  const snippet_lines: string[] = [];\n\n  for (const line of lines) {\n    const trimmed = line.trim();\n\n    if (!trimmed || /^#+\\s/.test(trimmed)) {\n      if (snippet_lines.length > 0) {\n        break;\n      }\n      continue;\n    }\n\n    if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n      continue;\n    }\n\n    snippet_lines.push(trimmed);\n\n    const current_length = snippet_lines.join(' ').length;\n    if (current_length >= max_length) {\n      break;\n    }\n  }\n\n  let snippet = snippet_lines.join(' ');\n\n  if (snippet.length > max_length) {\n    snippet = snippet.substring(0, max_length);\n    const last_space = snippet.lastIndexOf(' ');\n    if (last_space > max_length * 0.7) {\n      snippet = snippet.substring(0, last_space);\n    }\n    snippet += '...';\n  }\n\n  return snippet;\n}\n\n/**\n * Extracts tags from indexed content.\n * @param content - The content to inspect.\n * @returns The extracted tags.\n */\nexport function extract_tags(content: unknown): string[] {\n  if (!content || typeof content !== 'string') {\n    console.warn('[vector-index] extract_tags: invalid content type, expected string');\n    return [];\n  }\n\n  const tags = new Set<string>();\n\n  const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n  if (yaml_tags_match && yaml_tags_match[1]) {\n    yaml_tags_match[1].split(',').forEach(tag => {\n      const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n      if (cleaned) tags.add(cleaned.toLowerCase());\n    });\n  }\n\n  const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n  if (yaml_list_match && yaml_list_match[1]) {\n    yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n      const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n      if (tag) tags.add(tag.toLowerCase());\n    });\n  }\n\n  const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n  if (hashtag_matches) {\n    hashtag_matches.forEach(match => {\n      const tag = match.trim().replace(/^#/, '');\n      if (tag && !tag.match(/^[0-9]+$/)) {\n        tags.add(tag.toLowerCase());\n      }\n    });\n  }\n\n  return Array.from(tags);\n}\n\n/**\n * Extracts a relevant date from indexed content or path.\n * @param content - The content to inspect.\n * @param file_path - The optional source file path.\n * @returns The extracted date, if available.\n */\nexport function extract_date(content: unknown, file_path?: string): string | null {\n  if (content && typeof content === 'string') {\n    const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n    if (date_match && date_match[1]) {\n      const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n      try {\n        const parsed = new Date(date_str);\n        if (!isNaN(parsed.getTime())) {\n          return parsed.toISOString().split('T')[0];\n        }\n      } catch (_e: unknown) {\n        console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n      }\n    }\n  }\n\n  if (file_path) {\n    const filename = path.basename(file_path);\n\n    const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n    if (iso_match) {\n      return iso_match[1];\n    }\n\n    const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n    if (ddmmyy_match) {\n      const [, day, month, year] = ddmmyy_match;\n      const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n      return `${full_year}-${month}-${day}`;\n    }\n  }\n\n  return null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EMBEDDING GENERATION WRAPPER\n----------------------------------------------------------------*/\n\n/**\n * Generates an embedding for a search query.\n * @param query - The search query.\n * @returns A promise that resolves to the embedding, if generated.\n */\nexport async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n  if (!query || typeof query !== 'string' || query.trim().length === 0) {\n    console.warn('[vector-index] Empty query provided for embedding');\n    return null;\n  }\n\n  try {\n    const database = initialize_db();\n    const active = getActiveEmbedder(database);\n    const trimmedQuery = query.trim();\n    const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.name\n      : embeddingsProvider.getModelName();\n    const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.dim\n      : embeddingsProvider.getEmbeddingDimension();\n    const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n    const contentHash = computeContentHash(trimmedQuery);\n    const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n      profileKey,\n      inputKind: 'query',\n    });\n    if (cached) {\n      return new Float32Array(\n        cached.buffer,\n        cached.byteOffset,\n        Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n      );\n    }\n\n    const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n      : getStartupEmbeddingProfile().provider;\n    const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n    const activeAdapter = adapter as typeof adapter & {\n      embed: (\n        texts: ReadonlyArray<string>,\n        options?: { inputType?: 'query' | 'document' },\n      ) => Promise<Float32Array[]>;\n    };\n    const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n    const embedding: Float32Array | null = activeEmbedding ?? null;\n\n    if (embedding) {\n      storeEmbedding(\n        database,\n        contentHash,\n        modelId,\n        Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n        embedding.length,\n        { profileKey, inputKind: 'query' },\n      );\n    }\n\n    return embedding;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n    return null;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   KEYWORD SEARCH FALLBACK\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories using keyword matching.\n * @param query - The search query.\n * @param options - Search options.\n * @returns The matching memory rows.\n */\nexport function keyword_search(\n  query: string,\n  options: { limit?: number; specFolder?: string | null } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { limit = 20, specFolder = null } = options;\n\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n  if (search_terms.length === 0) {\n    console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n    return [];\n  }\n\n  let where_clause = '1=1';\n  const params: unknown[] = [];\n\n  if (specFolder) {\n    where_clause += \" AND (spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')\";\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  const sql = `\n    SELECT m.* FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE ${where_clause}\n    ORDER BY m.importance_weight DESC, m.created_at DESC\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    let score = 0;\n    const searchable_text = [\n      row.title || '',\n      parse_trigger_phrases(row.trigger_phrases).join(' '),\n      row.spec_folder || '',\n      row.file_path || ''\n    ].join(' ').toLowerCase();\n\n    for (const term of search_terms) {\n      if (searchable_text.includes(term)) {\n        score += 1;\n        if ((row.title || '').toLowerCase().includes(term)) {\n          score += 2;\n        }\n        if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n          score += 1.5;\n        }\n      }\n    }\n\n    score *= (0.5 + (row.importance_weight ?? 0));\n    return { ...row, keyword_score: score };\n  });\n\n  const filtered = scored\n    .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n    .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n    .slice(0, limit);\n\n  return filtered.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   ENRICHED VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched vector search for a text query.\n * @param query - The search query.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n * @example\n * ```ts\n * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function vector_search_enriched(\n  query: string,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {},\n  database: Database.Database = initialize_db(),\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();","lineStart":520,"lineEnd":939,"totalLines":1742,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781761461772,"end":1781761461778}},"metadata":{"openai":{"itemId":"fc_0f1c4e9a802a812e016a3385b5a6388191894b54af7f79d4ed"}},"id":"prt_ed9424e0b001vwLukDgCbg9oTg","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed9421d3d001fIaymXsx6pDkWD"}}
{"type":"tool_use","timestamp":1781761461781,"sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","part":{"type":"tool","tool":"read","callID":"call_7BetD0PuftzdDbq9CXsXLDzR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1600,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1600:         keywordFusionResults,\n1601:         fusionWeights,\n1602:         {\n1603:           graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n1604:           additionalLists: passthroughLists,\n1605:         },\n1606:       )\n1607:       : fuseResultsMulti(fusionLists);\n1608: \n1609:     const keywordSourceMap = new Map<string, string[]>();\n1610:     for (const result of keywordFusionResults) {\n1611:       const sources = Array.isArray((result as Record<string, unknown>).sources)\n1612:         ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n1613:         : [];\n1614:       if (sources.length > 0) {\n1615:         keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n1616:       }\n1617:     }\n1618:     const triggerScoreMap = new Map<string, number>();\n1619:     for (const result of triggerChannelResults) {\n1620:       if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n1621:         triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n1622:       }\n1623:     }\n1624: \n1625:     const fusedResults = fused.map(toHybridResult).map((row) => {\n1626:       const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n1627:       if (keywordSources && keywordSources.length > 0) {\n1628:         const rowSources = Array.isArray(row.sources)\n1629:           ? row.sources.filter((source): source is string => typeof source === 'string')\n1630:           : [];\n1631:         const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n1632:         row = {\n1633:           ...row,\n1634:           sources,\n1635:           channelAttribution: sources,\n1636:           source: row.source === 'keyword'\n1637:             ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n1638:             : row.source,\n1639:         };\n1640:       }\n1641:       const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n1642:       if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n1643:         row = {\n1644:           ...row,\n1645:           triggerScore,\n1646:           exactTriggerMatch: triggerScore >= 0.94,\n1647:         };\n1648:       }\n1649:       const rowRecord = row as Record<string, unknown>;\n1650:       if (rowRecord.parentMemoryId !== undefined) return row;\n1651:       const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n1652:       if (normalizedParentMemoryId === undefined) return row;\n1653:       return {\n1654:         ...row,\n1655:         parentMemoryId: normalizedParentMemoryId,\n1656:       };\n1657:     });\n1658: \n1659:     return {\n1660:       evaluationMode,\n1661:       intent,\n1662:       lists,\n1663:       routeResult,\n1664:       budgetResult,\n1665:       s3meta,\n1666:       vectorEmbeddingCache,\n1667:       fusedResults,\n1668:     };\n1669:   } catch (error: unknown) {\n1670:     const msg = error instanceof Error ? error.message : String(error);\n1671:     console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n1672:     return null;\n1673:   }\n1674: }\n1675: \n1676: async function enrichFusedResults(\n1677:   query: string,\n1678:   execution: HybridFusionExecution,\n1679:   options: HybridSearchOptions = {},\n1680:   initialResults: HybridSearchResult[] = execution.fusedResults\n1681: ): Promise<HybridSearchResult[]> {\n1682:   enrichFusedResultsObserver?.();\n1683: \n1684:   const {\n1685:     evaluationMode,\n1686:     intent,\n1687:     lists,\n1688:     routeResult,\n1689:     budgetResult,\n1690:     s3meta,\n1691:     vectorEmbeddingCache,\n1692:   } = execution;\n1693:   let fusedHybridResults = initialResults;\n1694:   const limit = options.limit || DEFAULT_LIMIT;\n1695: \n1696:   // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n1697:   // When enabled, collapses chunk-level results back to their parent memory\n1698:   // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n1699:   // Multiple chunks from the same document dominating the result list.\n1700:   // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n1701:   if (isDocscoreAggregationEnabled()) {\n1702:     try {\n1703:       const chunkResults = fusedHybridResults.filter(\n1704:         r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n1705:       );\n1706:       if (chunkResults.length > 0) {\n1707:         const nonChunkResults = fusedHybridResults.filter(\n1708:           r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n1709:         );\n1710:         const collapsed = collapseAndReassembleChunkResults(\n1711:           chunkResults.map(r => ({\n1712:             id: r.id,\n1713:             parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n1714:             chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n1715:             score: r.score,\n1716:           }))\n1717:         );\n1718:         // Merge collapsed chunk results with non-chunk results\n1719:         fusedHybridResults = [\n1720:           ...collapsed.map(c => ({\n1721:             id: c.parentMemoryId,\n1722:             score: c.mpabScore,\n1723:             source: 'mpab' as string,\n1724:             _chunkHits: c._chunkHits,\n1725:           } as HybridSearchResult)),\n1726:           ...nonChunkResults,\n1727:         ];\n1728:       }\n1729:     } catch (_mpabErr: unknown) {\n1730:       // Non-critical — MPAB failure does not block pipeline\n1731:       const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n1732:       console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n1733:     }\n1734:   }\n1735: \n1736:   // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n1737:   // Ensures every channel that returned results has at least one representative\n1738:   // In the top-k window. Prevents single-channel dominance in fusion output.\n1739:   // When disabled, passes results through unchanged.\n1740:   try {\n1741:     const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n1742:     for (const list of lists) {\n1743:       channelResultSets.set(list.source, list.results.map(r => ({\n1744:         ...r,\n1745:         id: r.id,\n1746:         score: typeof (r as Record<string, unknown>).score === 'number'\n1747:           ? (r as Record<string, unknown>).score as number\n1748:           : typeof (r as Record<string, unknown>).similarity === 'number'\n1749:             ? ((r as Record<string, unknown>).similarity as number) / 100\n1750:             : 0,\n1751:       })));\n1752:     }\n1753: \n1754:     const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n1755:       fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n1756:       channelResultSets,\n1757:       limit,\n1758:     );\n1759: \n1760:     if (enforcementResult.enforcement.applied) {\n1761:       fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n1762:       s3meta.enforcement = {\n1763:         applied: true,\n1764:         promotedCount: enforcementResult.enforcement.promotedCount,\n1765:         underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n1766:       };\n1767:     }\n1768:   } catch (err: unknown) {\n1769:     // Non-critical — enforcement failure does not block pipeline\n1770:     console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n1771:   }\n1772: \n1773:   // Preserve non-enumerable eval metadata across later array reallocations.\n1774:   const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n1775:   const s4shadowMeta = shadowMeta._s4shadow;\n1776:   const s4attributionMeta = shadowMeta._s4attribution;\n1777:   const degradationMeta = shadowMeta._degradation;\n1778: \n1779:   // MMR reranking with request-scoped embedding cache.\n1780:   // Reuse embeddings already returned by the vector channel when present and\n1781:   // only query vec_memories for missing IDs.\n1782:   let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n1783: \n1784:   if (db && isMMREnabled()) {\n1785:     const numericIds = reranked\n1786:       .map(r => r.id)\n1787:       .filter((id): id is number => typeof id === 'number');\n1788: \n1789:     if (numericIds.length >= MMR_MIN_CANDIDATES) {\n1790:       try {\n1791:         const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n1792:         const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n1793: \n1794:         if (missingIds.length > 0) {\n1795:           const placeholders = missingIds.map(() => '?').join(', ');\n1796:           const embRows = (db.prepare(\n1797:             `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n1798:           ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n1799: \n1800:           for (const row of embRows) {\n1801:             if (Buffer.isBuffer(row.embedding)) {\n1802:               embeddingMap.set(\n1803:                 row.rowid,\n1804:                 new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n1805:               );\n1806:             }\n1807:           }\n1808:         }\n1809: \n1810:         const mmrCandidates: MMRCandidate[] = [];\n1811:         for (const r of reranked) {\n1812:           const emb = embeddingMap.get(r.id as number);\n1813:           if (emb) {\n1814:             mmrCandidates.push({\n1815:               id: r.id as number,\n1816:               score: (r.score as number) ?? 0,\n1817:               embedding: emb,\n1818:             });\n1819:           }\n1820:         }\n1821: \n1822:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n1823:           const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n1824:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n1825: \n1826:           // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n1827:           // rows that have embeddings. Non-embedded rows (lexical-only hits,\n1828:           // graph injections) must be preserved and merged back in their\n1829:           // original relative order instead of being silently dropped.\n1830:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n1831:           const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n1832:           const rerankedById = new Map<string, HybridSearchResult>(\n1833:             reranked.map((result) => [canonicalResultId(result.id), result])\n1834:           );\n1835: \n1836:           const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n1837:             const existing = rerankedById.get(canonicalResultId(candidate.id));\n1838:             if (existing) {\n1839:               return existing;\n1840:             }\n1841: \n1842:             return {\n1843:               id: candidate.id,\n1844:               score: candidate.score,\n1845:               source: 'vector',\n1846:             };\n1847:           });\n1848: \n1849:           // Merge: diversified embedded rows first (MMR-ordered), then\n1850:           // non-embedded rows in their original relative order.\n1851:           reranked = [...diversifiedRows, ...nonEmbeddedRows];\n1852:         }\n1853:       } catch (embErr: unknown) {\n1854:         const msg = embErr instanceof Error ? embErr.message : String(embErr);\n1855:         console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n1856:       }\n1857:     }\n1858:   }\n1859: \n1860:   // Co-activation spreading — enrich with temporal neighbors\n1861:   const topIds = reranked\n1862:     .slice(0, SPREAD_ACTIVATION_TOP_N)\n1863:     .map(r => r.id)\n1864:     .filter((id): id is number => typeof id === 'number');\n1865:   if (topIds.length > 0) {\n1866:     try {\n1867:       const spreadResults: SpreadResult[] = spreadActivation(topIds);\n1868:       // Boost scores of results that appear in co-activation graph\n1869:       if (spreadResults.length > 0) {\n1870:         const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n1871:         for (const result of reranked) {\n1872:           const boost = spreadMap.get(result.id as number);\n1873:           if (boost !== undefined) {\n1874:             // Update all score aliases so downstream consumers see the boost.\n1875:             const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n1876:             (result as Record<string, unknown>).score = boostedScore;\n1877:             if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n1878:             if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n1879:           }\n1880:         }\n1881:       }\n1882:       // Re-sort after co-activation boost to ensure boosted results\n1883:       // Are promoted to their correct position in the ranking\n1884:       reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n1885:     } catch (err: unknown) {\n1886:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1887:       console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n1888:     }\n1889:   }\n1890: \n1891:   // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n1892:   if (db && isFolderScoringEnabled() && reranked.length > 0) {\n1893:     try {\n1894:       const numericIds = reranked\n1895:         .map(r => r.id)\n1896:         .filter((id): id is number => typeof id === 'number');\n1897: \n1898:       if (numericIds.length > 0) {\n1899:         const folderMap = lookupFolders(db, numericIds);\n1900:         if (folderMap.size > 0) {\n1901:           const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n1902:           const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n1903:           const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n1904:           const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n1905: \n1906:           const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n1907:           const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n1908:           reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n1909:         }\n1910:       }\n1911:     } catch (_folderErr: unknown) {\n1912:       // Folder scoring is optional and must not break retrieval\n1913:     }\n1914:   }\n1915: \n1916:   // -- Stage D: Confidence Truncation (SPECKIT_CONFIDENCE_TRUNCATION) --\n1917:   // Run after the ranking pipeline so later boosts/promotions can rescue\n1918:   // candidates before low-confidence tails are trimmed.\n1919:   if (!evaluationMode) {\n1920:     try {\n1921:       const truncationResult: TruncationResult = truncateByConfidence(\n1922:         reranked.map(r => ({ ...r, id: r.id, score: r.score })),\n1923:       );\n1924: \n1925:       if (truncationResult.truncated) {\n1926:         reranked = truncationResult.results.map(r => r as HybridSearchResult);\n1927:         s3meta.truncation = {\n1928:           truncated: true,\n1929:           originalCount: truncationResult.originalCount,\n1930:           truncatedCount: truncationResult.truncatedCount,\n1931:           medianGap: truncationResult.medianGap,\n1932:           cutoffGap: truncationResult.cutoffGap,\n1933:           cutoffIndex: truncationResult.cutoffIndex,\n1934:           thresholdMultiplier: GAP_THRESHOLD_MULTIPLIER,\n1935:           minResultsGuaranteed: DEFAULT_MIN_RESULTS,\n1936:           featureFlagEnabled: isConfidenceTruncationEnabled(),\n1937:         };\n1938:       }\n1939:     } catch (err: unknown) {\n1940:       // Non-critical — truncation failure does not block pipeline\n1941:       console.warn('[hybrid-search] confidence truncation failed:', err instanceof Error ? err.message : String(err));\n1942:     }\n1943:   }\n1944: \n1945:   // Preserve routing and Stage 4 trace metadata as explicit result fields so downstream\n1946:   // Formatters can opt-in to provenance-rich envelopes without relying on\n1947:   // Non-enumerable array shadow properties.\n1948:   if (reranked.length > 0) {\n1949:     reranked = reranked.map((row): HybridSearchResult => {\n1950:       const existingTraceMetadata =\n1951:         typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n1952:           ? row.traceMetadata\n1953:           : {};\n1954: \n1955:       return {\n1956:         ...row,\n1957:         traceMetadata: {\n1958:           ...existingTraceMetadata,\n1959:           ...(s4shadowMeta !== undefined ? { stage4: s4shadowMeta } : {}),\n1960:           ...(s4attributionMeta !== undefined ? { attribution: s4attributionMeta } : {}),\n1961:           ...(degradationMeta !== undefined ? { degradation: degradationMeta } : {}),\n1962:           evaluationMode,\n1963:           // Wire queryComplexity from router classification into trace\n1964:           queryComplexity: routeResult.tier,\n1965:           // Wire confidence truncation metadata into per-result trace (036)\n1966:           ...(s3meta.truncation ? {\n1967:             confidenceTruncation: {\n1968:               truncated: s3meta.truncation.truncated,\n1969:               originalCount: s3meta.truncation.originalCount,\n1970:               truncatedCount: s3meta.truncation.truncatedCount,\n1971:               medianGap: s3meta.truncation.medianGap,\n1972:               cutoffGap: s3meta.truncation.cutoffGap,\n1973:               cutoffIndex: s3meta.truncation.cutoffIndex,\n1974:               thresholdMultiplier: s3meta.truncation.thresholdMultiplier,\n1975:               minResultsGuaranteed: s3meta.truncation.minResultsGuaranteed,\n1976:             },\n1977:           } : {}),\n1978:         },\n1979:       };\n1980:     });\n1981:   }\n1982: \n1983:   if (isContextHeadersEnabled() && reranked.length > 0) {\n1984:     const descriptionCache = buildDescriptionTailMap();\n1985:     if (descriptionCache.size > 0) {\n1986:       reranked = reranked.map((row) => injectContextualTree(row, descriptionCache));\n1987:     }\n1988:   }\n1989: \n1990:   let budgetTruncated = false;\n1991:   let budgetLimit: number | undefined;\n1992:   if (evaluationMode) {\n1993:     reranked = applyResultLimit(reranked, options.limit);\n1994:   } else {\n1995:     // Apply token budget truncation after trace/header enrichment so token\n1996:     // estimates reflect the actual returned payload shape.\n1997:     const headerOverhead = isContextHeadersEnabled()\n1998:       ? reranked.length * CONTEXT_HEADER_TOKEN_OVERHEAD\n1999:       : 0;\n2000:     const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n2001: \n2002:     if (s3meta.tokenBudget) {\n2003:       s3meta.tokenBudget.headerOverhead = headerOverhead;\n2004:       s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n2005:     }\n2006: \n2007:     const budgeted = truncateToBudget(reranked, adjustedBudget, {\n2008:       includeContent: options.includeContent ?? false,\n2009:       queryId: `hybrid-${Date.now()}`,\n2010:       limit: options.limit,\n2011:       query,\n2012:     });\n2013:     reranked = budgeted.results;\n2014:     budgetTruncated = budgeted.truncated;\n2015:     budgetLimit = budgetResult.budget;\n2016: \n2017:     // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n2018:     // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n2019:     // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n2020:     // the budgeted survivors it is the last word on order without disturbing the\n2021:     // budget membership decision. Skipped in evaluationMode so the labeled-set\n2022:     // top-K window stays exactly as fused.\n2023:     if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n2024:       reranked = reorderTopNByCosine(reranked);\n2025:     }\n2026:   }\n2027: \n2028:   if (reranked.length > 0) {\n2029:     reranked = reranked.map((row): HybridSearchResult => {\n2030:       const existingTraceMetadata =\n2031:         typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n2032:           ? row.traceMetadata\n2033:           : {};\n2034: \n2035:       return {\n2036:         ...row,\n2037:         traceMetadata: {\n2038:           ...existingTraceMetadata,\n2039:           budgetTruncated,\n2040:           ...(budgetLimit !== undefined ? { budgetLimit } : {}),\n2041:         },\n2042:       };\n2043:     });\n2044:   }\n2045: \n2046:   if (s4shadowMeta !== undefined && reranked.length > 0) {\n2047:     Object.defineProperty(reranked, '_s4shadow', {\n2048:       value: s4shadowMeta,\n2049:       enumerable: false,\n2050:       configurable: true,\n2051:     });\n2052:   }\n2053: \n2054:   if (s4attributionMeta !== undefined && reranked.length > 0) {\n2055:     Object.defineProperty(reranked, '_s4attribution', {\n2056:       value: s4attributionMeta,\n2057:       enumerable: false,\n2058:       configurable: true,\n2059:     });\n2060:   }\n2061: \n2062:   // Attach pipeline metadata to results for eval/debugging\n2063:   // Metadata is attached as non-enumerable _s3meta property to avoid\n2064:   // Polluting result serialization while remaining accessible for debugging.\n2065:   if (Object.keys(s3meta).length > 0 && reranked.length > 0) {\n2066:     Object.defineProperty(reranked, '_s3meta', { value: s3meta, enumerable: false, configurable: true });\n2067:   }\n2068: \n2069:   return reranked;\n2070: }\n2071: \n2072: /**\n2073:  * Collect pipeline candidates through the adaptive fallback chain, returning\n2074:  * immediately after intra-query fusion and before downstream aggregation,\n2075:  * reranking, or post-processing.\n2076:  *\n2077:  * @param query - The search query string.\n2078:  * @param embedding - Optional embedding vector for semantic search.\n2079:  * @param options - Hybrid search configuration options.\n2080:  * @returns Unfused candidate results from the first non-empty collection stage.\n2081:  */\n2082: async function collectRawCandidates(\n2083:   query: string,\n2084:   embedding: Float32Array | number[] | null,\n2085:   options: HybridSearchOptions = {}\n2086: ): Promise<HybridSearchResult[]> {\n2087:   const { allowedChannels, stages } = await executeFallbackPlan(\n2088:     query,\n2089:     embedding,\n2090:     options,\n2091:     isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n2092:     { stopAfterFusion: true }\n2093:   );\n2094: \n2095:   const primaryResults = stages[0]?.results ?? [];\n2096:   const retryResults = stages[1]?.results ?? [];\n2097: \n2098:   if (isSearchFallbackEnabled()) {\n2099:     const mergedResults = retryResults.length > 0\n2100:       ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n2101:       : primaryResults;\n2102:     if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n2103:   } else {\n2104:     const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n2105:     if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n2106:   }\n2107: \n2108:   if (allowedChannels.has('fts')) {\n2109:     const ftsFallback = collectCandidatesFromLists(\n2110:       [{ source: 'fts', results: ftsSearch(query, options) }],\n2111:       options.limit\n2112:     );\n2113:     if (ftsFallback.length > 0) return ftsFallback;\n2114:   }\n2115: \n2116:   if (allowedChannels.has('bm25')) {\n2117:     const bm25Fallback = collectCandidatesFromLists(\n2118:       [{ source: 'bm25', results: bm25Search(query, options) }],\n2119:       options.limit\n2120:     );\n2121:     if (bm25Fallback.length > 0) return bm25Fallback;\n2122:   }\n2123: \n2124:   console.warn('[hybrid-search] Raw candidate collection returned empty results');\n2125:   return [];\n2126: }\n2127: \n2128: /**\n2129:  * Search with automatic fallback chain.\n2130:  * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n2131:    * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n2132:  * fallback — primary at minSimilarity=30, retry at 17.\n2133:  *\n2134:  * @param query - The search query string.\n2135:  * @param embedding - Optional embedding vector for semantic search.\n2136:  * @param options - Hybrid search configuration options.\n2137:  * @returns Results from the first non-empty stage.\n2138:  */\n2139: async function searchWithFallback(\n2140:   query: string,\n2141:   embedding: Float32Array | number[] | null,\n2142:   options: HybridSearchOptions = {}\n2143: ): Promise<HybridSearchResult[]> {\n2144:   // PI-A2: Delegate to tiered fallback when flag is enabled\n2145:   if (isSearchFallbackEnabled()) {\n2146:     return searchWithFallbackTiered(query, embedding, options);\n2147:   }\n2148: \n2149:   // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n2150:   // Where no result exceeds the primary threshold — chosen empirically via eval.\n2151:   // Use hybridSearchEnhanced (with RRF fusion) instead of\n2152:   // The naive hybridSearch that merges raw scores\n2153:   const { allowedChannels, stages } = await executeFallbackPlan(\n2154:     query,\n2155:     embedding,\n2156:     options,\n2157:     'adaptive'\n2158:   );\n2159:   const primaryStage = stages[0];\n2160:   const retryStage = stages[1];\n2161:   const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n2162:   if (finalStage?.results.length) {\n2163:     return finalStage.execution\n2164:       ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n2165:       : finalStage.results;\n2166:   }\n2167: \n2168:   // Fallback to FTS only\n2169:   if (allowedChannels.has('fts')) {\n2170:     const ftsResults = ftsSearch(query, options);\n2171:     if (ftsResults.length > 0) return ftsResults;\n2172:   }\n2173: \n2174:   // Fallback to BM25 only\n2175:   if (allowedChannels.has('bm25')) {\n2176:     const bm25Results = bm25Search(query, options);\n2177:     if (bm25Results.length > 0) return bm25Results;\n2178:   }\n2179: \n2180:   console.warn('[hybrid-search] All search methods returned empty results');\n2181:   return [];\n2182: }\n2183: \n2184: // 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n2185: \n2186: /**\n2187:  * PI-A2: Last-resort structural search against the memory_index table.\n2188:  * Retrieves memories ordered by importance tier and weight, without\n2189:  * requiring embeddings or text similarity. Pure SQL fallback.\n2190:  *\n2191:  * @param options - Search options (specFolder for filtering, limit for cap).\n2192:  * @returns Array of HybridSearchResult with source='structural'.\n2193:  */\n2194: function structuralSearch(\n2195:   options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n2196: ): HybridSearchResult[] {\n2197:   if (!db) {\n2198:     console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n2199:     return [];\n2200:   }\n2201: \n2202:   const limit = options.limit ?? DEFAULT_LIMIT;\n2203: \n2204:   try {\n2205:     // Build SQL with optional specFolder filter\n2206:     // Exclude archived rows unless explicitly requested\n2207:     const conditions = [\n2208:       `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n2209:     ];\n2210:     const params: unknown[] = [];\n2211: \n2212:     if (options.specFolder) {\n2213:       conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n2214:       params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n2215:     }\n2216: \n2217:     const whereClause = conditions.join(' AND ');\n2218: \n2219:     const sql = `\n2220:       SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n2221:       FROM memory_index\n2222:       WHERE ${whereClause}\n2223:       ORDER BY\n2224:         CASE importance_tier\n2225:           WHEN 'constitutional' THEN 1\n2226:           WHEN 'critical' THEN 2\n2227:           WHEN 'important' THEN 3\n2228:           WHEN 'normal' THEN 4\n2229:           WHEN 'temporary' THEN 5\n2230:           ELSE 6\n2231:         END ASC,\n2232:         importance_weight DESC,\n2233:         created_at DESC\n2234:       LIMIT ?\n2235:     `;\n2236:     params.push(limit);\n2237: \n2238:     const stmt = db.prepare(sql);\n2239:     const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n2240: \n2241:     return rows.map((row, index) => ({\n2242:       id: row.id as number,\n2243:       score: Math.max(0, 1.0 - index * 0.05),\n2244:       source: 'structural',\n2245:       title: (row.title as string) ?? undefined,\n2246:       file_path: row.file_path as string,\n2247:       importance_tier: row.importance_tier as string,\n2248:       spec_folder: row.spec_folder as string,\n2249:     }));\n2250:   } catch (error: unknown) {\n2251:     const msg = error instanceof Error ? error.message : String(error);\n2252:     console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n2253:     return [];\n2254:   }\n2255: }\n2256: \n2257: /**\n2258:  * Normalize result IDs to a canonical key used for deduplication and source tracking.\n2259:  * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n2260:  */\n2261: function canonicalResultId(id: number | string): string {\n2262:   if (typeof id === 'number') {\n2263:     return String(id);\n2264:   }\n2265: \n2266:   const raw = String(id).trim();\n2267:   const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n2268:   if (memPrefixed) {\n2269:     return String(Number(memPrefixed[1]));\n2270:   }\n2271: \n2272:   if (/^\\d+$/.test(raw)) {\n2273:     return String(Number(raw));\n2274:   }\n2275: \n2276:   return raw;\n2277: }\n2278: \n2279: function truncateChars(input: string, maxChars: number): string {\n2280:   if (input.length <= maxChars) return input;\n2281:   if (maxChars <= 1) return input.slice(0, maxChars);\n2282:   return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n2283: }\n2284: \n2285: function extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n2286:   const normalized = filePath.replace(/\\\\/g, '/');\n2287:   const splitToken = '/specs/';\n2288:   const splitIdx = normalized.lastIndexOf(splitToken);\n2289:   if (splitIdx < 0) return null;\n2290: \n2291:   const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n2292:   const parts = relative.split('/').filter(Boolean);\n2293:   if (parts.length < 2) return null;\n2294: \n2295:   // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n2296:   // For canonical memory paths like:\n2297:   // .../specs/<parent>/<child>/memory/<file>.md\n2298:   const memoryIdx = parts.indexOf('memory');\n2299:   const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n2300:   const tailParts = scopeParts.slice(-2);\n2301:   if (tailParts.length < 2) return null;\n2302: \n2303:   return {\n2304:     left: tailParts[0],\n2305:     right: tailParts[1],\n2306:     tailKey: tailParts.join('/'),\n2307:   };\n2308: }\n2309: \n2310: // Memoize description map to avoid rebuilding on every search query.\n2311: // Cache invalidates after 60 seconds so folder renames are eventually picked up.\n2312: // Return stale cache immediately and refresh asynchronously to avoid\n2313: // blocking the search hot path with synchronous filesystem crawls.\n2314: let descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\n2315: let descMapRefreshing = false;\n2316: const DESC_MAP_TTL_MS = 60_000;\n2317: \n2318: function rebuildDescriptionTailMap(): Map<string, string> {\n2319:   const descByTail = new Map<string, string>();\n2320:   const cache = ensureDescriptionCache(getSpecsBasePaths());\n2321:   if (!cache || !Array.isArray(cache.folders)) {\n2322:     return descByTail;\n2323:   }\n2324: \n2325:   for (const entry of cache.folders) {\n2326:     const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n2327:     const description = typeof entry.description === 'string' ? entry.description : '';\n2328:     if (!specFolder || !description) continue;\n2329:     const folderParts = specFolder.split('/').filter(Boolean);\n2330:     if (folderParts.length < 2) continue;\n2331:     const tailKey = folderParts.slice(-2).join('/');\n2332:     if (!descByTail.has(tailKey)) {\n2333:       descByTail.set(tailKey, description);\n2334:     }\n2335:   }\n2336: \n2337:   return descByTail;\n2338: }\n2339: \n2340: function buildDescriptionTailMap(): Map<string, string> {\n2341:   // Fresh cache — return immediately\n2342:   if (descMapCache && (Date.now() - descMapCache.timestamp) < DESC_MAP_TTL_MS) {\n2343:     return descMapCache.map;\n2344:   }\n2345: \n2346:   // Stale cache — return it and schedule async refresh (fail open)\n2347:   if (descMapCache) {\n2348:     if (!descMapRefreshing) {\n2349:       descMapRefreshing = true;\n2350:       setTimeout(() => {\n2351:         try {\n2352:           const freshMap = rebuildDescriptionTailMap();\n2353:           descMapCache = { map: freshMap, timestamp: Date.now() };\n2354:         } catch (_error: unknown) {\n2355:           // Non-fatal: stale cache remains usable\n2356:         } finally {\n2357:           descMapRefreshing = false;\n2358:         }\n2359:       }, 0);\n2360:     }\n2361:     return descMapCache.map;\n2362:   }\n2363: \n2364:   // Cold start — synchronous build required (no stale data to return)\n2365:   const freshMap = rebuildDescriptionTailMap();\n2366:   descMapCache = { map: freshMap, timestamp: Date.now() };\n2367:   return freshMap;\n2368: }\n2369: \n2370: function injectContextualTree(row: HybridSearchResult, descCache: Map<string, string>): HybridSearchResult {\n2371:   const rowData = row as Record<string, unknown>;\n2372:   const content = rowData.content;\n2373:   const filePath = typeof rowData.file_path === 'string' ? rowData.file_path : null;\n2374: \n2375:   if (typeof content !== 'string' || content.length === 0 || !filePath) {\n2376:     return row;\n2377:   }\n2378: \n2379:   const segments = extractSpecSegments(filePath);\n2380:   if (!segments) {\n2381:     return row;\n2382:   }\n2383: \n2384:   const descriptionRaw = descCache.get(segments.tailKey) ?? '';\n2385:   const description = truncateChars(descriptionRaw, 60);\n2386:   const base = `[${segments.left} > ${segments.right}`;\n2387:   const withDesc = description.length > 0 ? `${base} — ${description}]` : `${base}]`;\n2388:   const header = truncateChars(withDesc, CONTEXT_HEADER_MAX_CHARS);\n2389: \n2390:   return {\n2391:     ...row,\n2392:     content: `${header}\\n${content}`,\n2393:   };\n2394: }\n2395: \n2396: function dedupeResultsByCanonicalId(results: HybridSearchResult[]): HybridSearchResult[] {\n2397:   const deduped = new Map<string, HybridSearchResult>();\n2398:   for (const result of results) {\n2399:     const key = canonicalResultId(result.id);\n2400:     if (!deduped.has(key)) {\n2401:       deduped.set(key, result);\n2402:     }\n2403:   }\n2404:   return Array.from(deduped.values());\n2405: }\n2406: \n2407: /** Apply caller limit after merges that can expand result count. */\n2408: function applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n2409:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n2410:     return results;\n2411:   }\n2412:   return results.slice(0, limit);\n2413: }\n2414: \n2415: /** Depth of the result head rebalanced by the cosine-primary reorder. */\n2416: const COSINE_TOPN_REORDER_DEPTH = 10;\n2417: \n2418: /**\n2419:  * Cosine-primary reorder of the result head.\n2420:  *\n2421:  * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n2422:  * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n2423:  * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n2424:  * decisive for downstream consumers — is rebalanced toward the strongest absolute\n2425:  * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n2426:  * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n2427:  * and membership are invariant — this only permutes the head.\n2428:  */\n2429: function reorderTopNByCosine(\n2430:   results: HybridSearchResult[],\n2431:   depth: number = COSINE_TOPN_REORDER_DEPTH\n2432: ): HybridSearchResult[] {\n2433:   const headCount = Math.min(depth, results.length);\n2434:   if (headCount <= 1) return results;\n2435: \n2436:   const head = results.slice(0, headCount);\n2437:   // Decorate with the original index so equal-relevance ties resolve to fused\n2438:   // order regardless of the engine's sort stability.\n2439:   const reordered = head\n2440:     .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n2441:     .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n2442:     .map((entry) => entry.row);\n2443: \n2444:   return [...reordered, ...results.slice(headCount)];\n2445: }\n2446: \n2447: /** Tier-3 structural results are capped at this fraction of the top existing score. */\n2448: const TIER3_CAP_RATIO = 0.5;\n2449: /** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\n2450: const TIER3_DECAY_PER_RANK = 0.08;\n2451: \n2452: /**\n2453:  * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n2454:  * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n2455:  */\n2456: function calibrateTier3Scores(\n2457:   existing: HybridSearchResult[],\n2458:   tier3: HybridSearchResult[]\n2459: ): HybridSearchResult[] {\n2460:   const topExisting = existing.reduce((max, row) => {\n2461:     if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n2462:       return max;\n2463:     }\n2464:     return Math.max(max, row.score);\n2465:   }, 0);\n2466: \n2467:   if (topExisting <= 0) {\n2468:     return tier3;\n2469:   }\n2470: \n2471:   const topCap = topExisting * TIER3_CAP_RATIO;\n2472:   const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n2473: \n2474:   return tier3.map((row, index) => {\n2475:     const calibrated = Math.max(0, topCap - (index * decayPerRank));\n2476:     return {\n2477:       ...row,\n2478:       score: Math.min(row.score, calibrated),\n2479:     };\n2480:   });\n2481: }\n2482: \n2483: // 13. TIERED FALLBACK (PI-A2)\n2484: \n2485: /**\n2486:  * Evaluate whether results meet quality thresholds.\n2487:  * Returns null if thresholds are met, or a DegradationTrigger if not.\n2488:  */\n2489: function checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n2490:   const scores = results\n2491:     .map(r => r.score)\n2492:     .filter((score): score is number => typeof score === 'number' && Number.isFinite(score))\n2493:     .sort((a, b) => b - a);\n2494: \n2495:   const topScore = scores[0] ?? 0;\n2496:   const secondScore = scores[1] ?? 0;\n2497:   const relativeGap = topScore > 0 ? (topScore - secondScore) / topScore : 0;\n2498:   const count = results.length;\n2499: \n\n(Showing lines 1600-2499 of 2972. Use offset=2500 to continue.)\n</content>","metadata":{"preview":"        keywordFusionResults,\n        fusionWeights,\n        {\n          graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n          additionalLists: passthroughLists,\n        },\n      )\n      : fuseResultsMulti(fusionLists);\n\n    const keywordSourceMap = new Map<string, string[]>();\n    for (const result of keywordFusionResults) {\n      const sources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      if (sources.length > 0) {\n        keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n      }\n    }\n    const triggerScoreMap = new Map<string, number>();\n    for (const result of triggerChannelResults) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"        keywordFusionResults,\n        fusionWeights,\n        {\n          graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n          additionalLists: passthroughLists,\n        },\n      )\n      : fuseResultsMulti(fusionLists);\n\n    const keywordSourceMap = new Map<string, string[]>();\n    for (const result of keywordFusionResults) {\n      const sources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      if (sources.length > 0) {\n        keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n      }\n    }\n    const triggerScoreMap = new Map<string, number>();\n    for (const result of triggerChannelResults) {\n      if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n        triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n      }\n    }\n\n    const fusedResults = fused.map(toHybridResult).map((row) => {\n      const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n      if (keywordSources && keywordSources.length > 0) {\n        const rowSources = Array.isArray(row.sources)\n          ? row.sources.filter((source): source is string => typeof source === 'string')\n          : [];\n        const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n        row = {\n          ...row,\n          sources,\n          channelAttribution: sources,\n          source: row.source === 'keyword'\n            ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n            : row.source,\n        };\n      }\n      const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n      if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n        row = {\n          ...row,\n          triggerScore,\n          exactTriggerMatch: triggerScore >= 0.94,\n        };\n      }\n      const rowRecord = row as Record<string, unknown>;\n      if (rowRecord.parentMemoryId !== undefined) return row;\n      const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n      if (normalizedParentMemoryId === undefined) return row;\n      return {\n        ...row,\n        parentMemoryId: normalizedParentMemoryId,\n      };\n    });\n\n    return {\n      evaluationMode,\n      intent,\n      lists,\n      routeResult,\n      budgetResult,\n      s3meta,\n      vectorEmbeddingCache,\n      fusedResults,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n    return null;\n  }\n}\n\nasync function enrichFusedResults(\n  query: string,\n  execution: HybridFusionExecution,\n  options: HybridSearchOptions = {},\n  initialResults: HybridSearchResult[] = execution.fusedResults\n): Promise<HybridSearchResult[]> {\n  enrichFusedResultsObserver?.();\n\n  const {\n    evaluationMode,\n    intent,\n    lists,\n    routeResult,\n    budgetResult,\n    s3meta,\n    vectorEmbeddingCache,\n  } = execution;\n  let fusedHybridResults = initialResults;\n  const limit = options.limit || DEFAULT_LIMIT;\n\n  // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n  // When enabled, collapses chunk-level results back to their parent memory\n  // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n  // Multiple chunks from the same document dominating the result list.\n  // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n  if (isDocscoreAggregationEnabled()) {\n    try {\n      const chunkResults = fusedHybridResults.filter(\n        r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n      );\n      if (chunkResults.length > 0) {\n        const nonChunkResults = fusedHybridResults.filter(\n          r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n        );\n        const collapsed = collapseAndReassembleChunkResults(\n          chunkResults.map(r => ({\n            id: r.id,\n            parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n            chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n            score: r.score,\n          }))\n        );\n        // Merge collapsed chunk results with non-chunk results\n        fusedHybridResults = [\n          ...collapsed.map(c => ({\n            id: c.parentMemoryId,\n            score: c.mpabScore,\n            source: 'mpab' as string,\n            _chunkHits: c._chunkHits,\n          } as HybridSearchResult)),\n          ...nonChunkResults,\n        ];\n      }\n    } catch (_mpabErr: unknown) {\n      // Non-critical — MPAB failure does not block pipeline\n      const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n      console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n    }\n  }\n\n  // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n  // Ensures every channel that returned results has at least one representative\n  // In the top-k window. Prevents single-channel dominance in fusion output.\n  // When disabled, passes results through unchanged.\n  try {\n    const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n    for (const list of lists) {\n      channelResultSets.set(list.source, list.results.map(r => ({\n        ...r,\n        id: r.id,\n        score: typeof (r as Record<string, unknown>).score === 'number'\n          ? (r as Record<string, unknown>).score as number\n          : typeof (r as Record<string, unknown>).similarity === 'number'\n            ? ((r as Record<string, unknown>).similarity as number) / 100\n            : 0,\n      })));\n    }\n\n    const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n      fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n      channelResultSets,\n      limit,\n    );\n\n    if (enforcementResult.enforcement.applied) {\n      fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n      s3meta.enforcement = {\n        applied: true,\n        promotedCount: enforcementResult.enforcement.promotedCount,\n        underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n      };\n    }\n  } catch (err: unknown) {\n    // Non-critical — enforcement failure does not block pipeline\n    console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n  }\n\n  // Preserve non-enumerable eval metadata across later array reallocations.\n  const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n  const s4shadowMeta = shadowMeta._s4shadow;\n  const s4attributionMeta = shadowMeta._s4attribution;\n  const degradationMeta = shadowMeta._degradation;\n\n  // MMR reranking with request-scoped embedding cache.\n  // Reuse embeddings already returned by the vector channel when present and\n  // only query vec_memories for missing IDs.\n  let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n\n  if (db && isMMREnabled()) {\n    const numericIds = reranked\n      .map(r => r.id)\n      .filter((id): id is number => typeof id === 'number');\n\n    if (numericIds.length >= MMR_MIN_CANDIDATES) {\n      try {\n        const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n        const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n\n        if (missingIds.length > 0) {\n          const placeholders = missingIds.map(() => '?').join(', ');\n          const embRows = (db.prepare(\n            `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n          ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n          for (const row of embRows) {\n            if (Buffer.isBuffer(row.embedding)) {\n              embeddingMap.set(\n                row.rowid,\n                new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n              );\n            }\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of reranked) {\n          const emb = embeddingMap.get(r.id as number);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id as number,\n              score: (r.score as number) ?? 0,\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n\n          // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n          // rows that have embeddings. Non-embedded rows (lexical-only hits,\n          // graph injections) must be preserved and merged back in their\n          // original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n          const rerankedById = new Map<string, HybridSearchResult>(\n            reranked.map((result) => [canonicalResultId(result.id), result])\n          );\n\n          const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n            const existing = rerankedById.get(canonicalResultId(candidate.id));\n            if (existing) {\n              return existing;\n            }\n\n            return {\n              id: candidate.id,\n              score: candidate.score,\n              source: 'vector',\n            };\n          });\n\n          // Merge: diversified embedded rows first (MMR-ordered), then\n          // non-embedded rows in their original relative order.\n          reranked = [...diversifiedRows, ...nonEmbeddedRows];\n        }\n      } catch (embErr: unknown) {\n        const msg = embErr instanceof Error ? embErr.message : String(embErr);\n        console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n      }\n    }\n  }\n\n  // Co-activation spreading — enrich with temporal neighbors\n  const topIds = reranked\n    .slice(0, SPREAD_ACTIVATION_TOP_N)\n    .map(r => r.id)\n    .filter((id): id is number => typeof id === 'number');\n  if (topIds.length > 0) {\n    try {\n      const spreadResults: SpreadResult[] = spreadActivation(topIds);\n      // Boost scores of results that appear in co-activation graph\n      if (spreadResults.length > 0) {\n        const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n        for (const result of reranked) {\n          const boost = spreadMap.get(result.id as number);\n          if (boost !== undefined) {\n            // Update all score aliases so downstream consumers see the boost.\n            const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n            (result as Record<string, unknown>).score = boostedScore;\n            if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n            if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n          }\n        }\n      }\n      // Re-sort after co-activation boost to ensure boosted results\n      // Are promoted to their correct position in the ranking\n      reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n  if (db && isFolderScoringEnabled() && reranked.length > 0) {\n    try {\n      const numericIds = reranked\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length > 0) {\n        const folderMap = lookupFolders(db, numericIds);\n        if (folderMap.size > 0) {\n          const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n          const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n          const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n          const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n\n          const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n          const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n          reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n        }\n      }\n    } catch (_folderErr: unknown) {\n      // Folder scoring is optional and must not break retrieval\n    }\n  }\n\n  // -- Stage D: Confidence Truncation (SPECKIT_CONFIDENCE_TRUNCATION) --\n  // Run after the ranking pipeline so later boosts/promotions can rescue\n  // candidates before low-confidence tails are trimmed.\n  if (!evaluationMode) {\n    try {\n      const truncationResult: TruncationResult = truncateByConfidence(\n        reranked.map(r => ({ ...r, id: r.id, score: r.score })),\n      );\n\n      if (truncationResult.truncated) {\n        reranked = truncationResult.results.map(r => r as HybridSearchResult);\n        s3meta.truncation = {\n          truncated: true,\n          originalCount: truncationResult.originalCount,\n          truncatedCount: truncationResult.truncatedCount,\n          medianGap: truncationResult.medianGap,\n          cutoffGap: truncationResult.cutoffGap,\n          cutoffIndex: truncationResult.cutoffIndex,\n          thresholdMultiplier: GAP_THRESHOLD_MULTIPLIER,\n          minResultsGuaranteed: DEFAULT_MIN_RESULTS,\n          featureFlagEnabled: isConfidenceTruncationEnabled(),\n        };\n      }\n    } catch (err: unknown) {\n      // Non-critical — truncation failure does not block pipeline\n      console.warn('[hybrid-search] confidence truncation failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Preserve routing and Stage 4 trace metadata as explicit result fields so downstream\n  // Formatters can opt-in to provenance-rich envelopes without relying on\n  // Non-enumerable array shadow properties.\n  if (reranked.length > 0) {\n    reranked = reranked.map((row): HybridSearchResult => {\n      const existingTraceMetadata =\n        typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n          ? row.traceMetadata\n          : {};\n\n      return {\n        ...row,\n        traceMetadata: {\n          ...existingTraceMetadata,\n          ...(s4shadowMeta !== undefined ? { stage4: s4shadowMeta } : {}),\n          ...(s4attributionMeta !== undefined ? { attribution: s4attributionMeta } : {}),\n          ...(degradationMeta !== undefined ? { degradation: degradationMeta } : {}),\n          evaluationMode,\n          // Wire queryComplexity from router classification into trace\n          queryComplexity: routeResult.tier,\n          // Wire confidence truncation metadata into per-result trace (036)\n          ...(s3meta.truncation ? {\n            confidenceTruncation: {\n              truncated: s3meta.truncation.truncated,\n              originalCount: s3meta.truncation.originalCount,\n              truncatedCount: s3meta.truncation.truncatedCount,\n              medianGap: s3meta.truncation.medianGap,\n              cutoffGap: s3meta.truncation.cutoffGap,\n              cutoffIndex: s3meta.truncation.cutoffIndex,\n              thresholdMultiplier: s3meta.truncation.thresholdMultiplier,\n              minResultsGuaranteed: s3meta.truncation.minResultsGuaranteed,\n            },\n          } : {}),\n        },\n      };\n    });\n  }\n\n  if (isContextHeadersEnabled() && reranked.length > 0) {\n    const descriptionCache = buildDescriptionTailMap();\n    if (descriptionCache.size > 0) {\n      reranked = reranked.map((row) => injectContextualTree(row, descriptionCache));\n    }\n  }\n\n  let budgetTruncated = false;\n  let budgetLimit: number | undefined;\n  if (evaluationMode) {\n    reranked = applyResultLimit(reranked, options.limit);\n  } else {\n    // Apply token budget truncation after trace/header enrichment so token\n    // estimates reflect the actual returned payload shape.\n    const headerOverhead = isContextHeadersEnabled()\n      ? reranked.length * CONTEXT_HEADER_TOKEN_OVERHEAD\n      : 0;\n    const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n\n    if (s3meta.tokenBudget) {\n      s3meta.tokenBudget.headerOverhead = headerOverhead;\n      s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n    }\n\n    const budgeted = truncateToBudget(reranked, adjustedBudget, {\n      includeContent: options.includeContent ?? false,\n      queryId: `hybrid-${Date.now()}`,\n      limit: options.limit,\n      query,\n    });\n    reranked = budgeted.results;\n    budgetTruncated = budgeted.truncated;\n    budgetLimit = budgetResult.budget;\n\n    // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n    // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n    // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n    // the budgeted survivors it is the last word on order without disturbing the\n    // budget membership decision. Skipped in evaluationMode so the labeled-set\n    // top-K window stays exactly as fused.\n    if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n      reranked = reorderTopNByCosine(reranked);\n    }\n  }\n\n  if (reranked.length > 0) {\n    reranked = reranked.map((row): HybridSearchResult => {\n      const existingTraceMetadata =\n        typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n          ? row.traceMetadata\n          : {};\n\n      return {\n        ...row,\n        traceMetadata: {\n          ...existingTraceMetadata,\n          budgetTruncated,\n          ...(budgetLimit !== undefined ? { budgetLimit } : {}),\n        },\n      };\n    });\n  }\n\n  if (s4shadowMeta !== undefined && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s4shadow', {\n      value: s4shadowMeta,\n      enumerable: false,\n      configurable: true,\n    });\n  }\n\n  if (s4attributionMeta !== undefined && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s4attribution', {\n      value: s4attributionMeta,\n      enumerable: false,\n      configurable: true,\n    });\n  }\n\n  // Attach pipeline metadata to results for eval/debugging\n  // Metadata is attached as non-enumerable _s3meta property to avoid\n  // Polluting result serialization while remaining accessible for debugging.\n  if (Object.keys(s3meta).length > 0 && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s3meta', { value: s3meta, enumerable: false, configurable: true });\n  }\n\n  return reranked;\n}\n\n/**\n * Collect pipeline candidates through the adaptive fallback chain, returning\n * immediately after intra-query fusion and before downstream aggregation,\n * reranking, or post-processing.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Unfused candidate results from the first non-empty collection stage.\n */\nasync function collectRawCandidates(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n    { stopAfterFusion: true }\n  );\n\n  const primaryResults = stages[0]?.results ?? [];\n  const retryResults = stages[1]?.results ?? [];\n\n  if (isSearchFallbackEnabled()) {\n    const mergedResults = retryResults.length > 0\n      ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n      : primaryResults;\n    if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n  } else {\n    const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n    if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n  }\n\n  if (allowedChannels.has('fts')) {\n    const ftsFallback = collectCandidatesFromLists(\n      [{ source: 'fts', results: ftsSearch(query, options) }],\n      options.limit\n    );\n    if (ftsFallback.length > 0) return ftsFallback;\n  }\n\n  if (allowedChannels.has('bm25')) {\n    const bm25Fallback = collectCandidatesFromLists(\n      [{ source: 'bm25', results: bm25Search(query, options) }],\n      options.limit\n    );\n    if (bm25Fallback.length > 0) return bm25Fallback;\n  }\n\n  console.warn('[hybrid-search] Raw candidate collection returned empty results');\n  return [];\n}\n\n/**\n * Search with automatic fallback chain.\n * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n   * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n * fallback — primary at minSimilarity=30, retry at 17.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Results from the first non-empty stage.\n */\nasync function searchWithFallback(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  // PI-A2: Delegate to tiered fallback when flag is enabled\n  if (isSearchFallbackEnabled()) {\n    return searchWithFallbackTiered(query, embedding, options);\n  }\n\n  // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n  // Where no result exceeds the primary threshold — chosen empirically via eval.\n  // Use hybridSearchEnhanced (with RRF fusion) instead of\n  // The naive hybridSearch that merges raw scores\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    'adaptive'\n  );\n  const primaryStage = stages[0];\n  const retryStage = stages[1];\n  const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n  if (finalStage?.results.length) {\n    return finalStage.execution\n      ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n      : finalStage.results;\n  }\n\n  // Fallback to FTS only\n  if (allowedChannels.has('fts')) {\n    const ftsResults = ftsSearch(query, options);\n    if (ftsResults.length > 0) return ftsResults;\n  }\n\n  // Fallback to BM25 only\n  if (allowedChannels.has('bm25')) {\n    const bm25Results = bm25Search(query, options);\n    if (bm25Results.length > 0) return bm25Results;\n  }\n\n  console.warn('[hybrid-search] All search methods returned empty results');\n  return [];\n}\n\n// 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n\n/**\n * PI-A2: Last-resort structural search against the memory_index table.\n * Retrieves memories ordered by importance tier and weight, without\n * requiring embeddings or text similarity. Pure SQL fallback.\n *\n * @param options - Search options (specFolder for filtering, limit for cap).\n * @returns Array of HybridSearchResult with source='structural'.\n */\nfunction structuralSearch(\n  options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n): HybridSearchResult[] {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n    return [];\n  }\n\n  const limit = options.limit ?? DEFAULT_LIMIT;\n\n  try {\n    // Build SQL with optional specFolder filter\n    // Exclude archived rows unless explicitly requested\n    const conditions = [\n      `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n    ];\n    const params: unknown[] = [];\n\n    if (options.specFolder) {\n      conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n      params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n    }\n\n    const whereClause = conditions.join(' AND ');\n\n    const sql = `\n      SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n      FROM memory_index\n      WHERE ${whereClause}\n      ORDER BY\n        CASE importance_tier\n          WHEN 'constitutional' THEN 1\n          WHEN 'critical' THEN 2\n          WHEN 'important' THEN 3\n          WHEN 'normal' THEN 4\n          WHEN 'temporary' THEN 5\n          ELSE 6\n        END ASC,\n        importance_weight DESC,\n        created_at DESC\n      LIMIT ?\n    `;\n    params.push(limit);\n\n    const stmt = db.prepare(sql);\n    const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n\n    return rows.map((row, index) => ({\n      id: row.id as number,\n      score: Math.max(0, 1.0 - index * 0.05),\n      source: 'structural',\n      title: (row.title as string) ?? undefined,\n      file_path: row.file_path as string,\n      importance_tier: row.importance_tier as string,\n      spec_folder: row.spec_folder as string,\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Normalize result IDs to a canonical key used for deduplication and source tracking.\n * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n */\nfunction canonicalResultId(id: number | string): string {\n  if (typeof id === 'number') {\n    return String(id);\n  }\n\n  const raw = String(id).trim();\n  const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n  if (memPrefixed) {\n    return String(Number(memPrefixed[1]));\n  }\n\n  if (/^\\d+$/.test(raw)) {\n    return String(Number(raw));\n  }\n\n  return raw;\n}\n\nfunction truncateChars(input: string, maxChars: number): string {\n  if (input.length <= maxChars) return input;\n  if (maxChars <= 1) return input.slice(0, maxChars);\n  return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n}\n\nfunction extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n  const normalized = filePath.replace(/\\\\/g, '/');\n  const splitToken = '/specs/';\n  const splitIdx = normalized.lastIndexOf(splitToken);\n  if (splitIdx < 0) return null;\n\n  const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n  const parts = relative.split('/').filter(Boolean);\n  if (parts.length < 2) return null;\n\n  // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n  // For canonical memory paths like:\n  // .../specs/<parent>/<child>/memory/<file>.md\n  const memoryIdx = parts.indexOf('memory');\n  const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n  const tailParts = scopeParts.slice(-2);\n  if (tailParts.length < 2) return null;\n\n  return {\n    left: tailParts[0],\n    right: tailParts[1],\n    tailKey: tailParts.join('/'),\n  };\n}\n\n// Memoize description map to avoid rebuilding on every search query.\n// Cache invalidates after 60 seconds so folder renames are eventually picked up.\n// Return stale cache immediately and refresh asynchronously to avoid\n// blocking the search hot path with synchronous filesystem crawls.\nlet descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\nlet descMapRefreshing = false;\nconst DESC_MAP_TTL_MS = 60_000;\n\nfunction rebuildDescriptionTailMap(): Map<string, string> {\n  const descByTail = new Map<string, string>();\n  const cache = ensureDescriptionCache(getSpecsBasePaths());\n  if (!cache || !Array.isArray(cache.folders)) {\n    return descByTail;\n  }\n\n  for (const entry of cache.folders) {\n    const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n    const description = typeof entry.description === 'string' ? entry.description : '';\n    if (!specFolder || !description) continue;\n    const folderParts = specFolder.split('/').filter(Boolean);\n    if (folderParts.length < 2) continue;\n    const tailKey = folderParts.slice(-2).join('/');\n    if (!descByTail.has(tailKey)) {\n      descByTail.set(tailKey, description);\n    }\n  }\n\n  return descByTail;\n}\n\nfunction buildDescriptionTailMap(): Map<string, string> {\n  // Fresh cache — return immediately\n  if (descMapCache && (Date.now() - descMapCache.timestamp) < DESC_MAP_TTL_MS) {\n    return descMapCache.map;\n  }\n\n  // Stale cache — return it and schedule async refresh (fail open)\n  if (descMapCache) {\n    if (!descMapRefreshing) {\n      descMapRefreshing = true;\n      setTimeout(() => {\n        try {\n          const freshMap = rebuildDescriptionTailMap();\n          descMapCache = { map: freshMap, timestamp: Date.now() };\n        } catch (_error: unknown) {\n          // Non-fatal: stale cache remains usable\n        } finally {\n          descMapRefreshing = false;\n        }\n      }, 0);\n    }\n    return descMapCache.map;\n  }\n\n  // Cold start — synchronous build required (no stale data to return)\n  const freshMap = rebuildDescriptionTailMap();\n  descMapCache = { map: freshMap, timestamp: Date.now() };\n  return freshMap;\n}\n\nfunction injectContextualTree(row: HybridSearchResult, descCache: Map<string, string>): HybridSearchResult {\n  const rowData = row as Record<string, unknown>;\n  const content = rowData.content;\n  const filePath = typeof rowData.file_path === 'string' ? rowData.file_path : null;\n\n  if (typeof content !== 'string' || content.length === 0 || !filePath) {\n    return row;\n  }\n\n  const segments = extractSpecSegments(filePath);\n  if (!segments) {\n    return row;\n  }\n\n  const descriptionRaw = descCache.get(segments.tailKey) ?? '';\n  const description = truncateChars(descriptionRaw, 60);\n  const base = `[${segments.left} > ${segments.right}`;\n  const withDesc = description.length > 0 ? `${base} — ${description}]` : `${base}]`;\n  const header = truncateChars(withDesc, CONTEXT_HEADER_MAX_CHARS);\n\n  return {\n    ...row,\n    content: `${header}\\n${content}`,\n  };\n}\n\nfunction dedupeResultsByCanonicalId(results: HybridSearchResult[]): HybridSearchResult[] {\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const result of results) {\n    const key = canonicalResultId(result.id);\n    if (!deduped.has(key)) {\n      deduped.set(key, result);\n    }\n  }\n  return Array.from(deduped.values());\n}\n\n/** Apply caller limit after merges that can expand result count. */\nfunction applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return results;\n  }\n  return results.slice(0, limit);\n}\n\n/** Depth of the result head rebalanced by the cosine-primary reorder. */\nconst COSINE_TOPN_REORDER_DEPTH = 10;\n\n/**\n * Cosine-primary reorder of the result head.\n *\n * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n * decisive for downstream consumers — is rebalanced toward the strongest absolute\n * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n * and membership are invariant — this only permutes the head.\n */\nfunction reorderTopNByCosine(\n  results: HybridSearchResult[],\n  depth: number = COSINE_TOPN_REORDER_DEPTH\n): HybridSearchResult[] {\n  const headCount = Math.min(depth, results.length);\n  if (headCount <= 1) return results;\n\n  const head = results.slice(0, headCount);\n  // Decorate with the original index so equal-relevance ties resolve to fused\n  // order regardless of the engine's sort stability.\n  const reordered = head\n    .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n    .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n    .map((entry) => entry.row);\n\n  return [...reordered, ...results.slice(headCount)];\n}\n\n/** Tier-3 structural results are capped at this fraction of the top existing score. */\nconst TIER3_CAP_RATIO = 0.5;\n/** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\nconst TIER3_DECAY_PER_RANK = 0.08;\n\n/**\n * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n */\nfunction calibrateTier3Scores(\n  existing: HybridSearchResult[],\n  tier3: HybridSearchResult[]\n): HybridSearchResult[] {\n  const topExisting = existing.reduce((max, row) => {\n    if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n      return max;\n    }\n    return Math.max(max, row.score);\n  }, 0);\n\n  if (topExisting <= 0) {\n    return tier3;\n  }\n\n  const topCap = topExisting * TIER3_CAP_RATIO;\n  const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n\n  return tier3.map((row, index) => {\n    const calibrated = Math.max(0, topCap - (index * decayPerRank));\n    return {\n      ...row,\n      score: Math.min(row.score, calibrated),\n    };\n  });\n}\n\n// 13. TIERED FALLBACK (PI-A2)\n\n/**\n * Evaluate whether results meet quality thresholds.\n * Returns null if thresholds are met, or a DegradationTrigger if not.\n */\nfunction checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n  const scores = results\n    .map(r => r.score)\n    .filter((score): score is number => typeof score === 'number' && Number.isFinite(score))\n    .sort((a, b) => b - a);\n\n  const topScore = scores[0] ?? 0;\n  const secondScore = scores[1] ?? 0;\n  const relativeGap = topScore > 0 ? (topScore - secondScore) / topScore : 0;\n  const count = results.length;\n","lineStart":1600,"lineEnd":2499,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781761461771,"end":1781761461779}},"metadata":{"openai":{"itemId":"fc_0f1c4e9a802a812e016a3385b5a630819181e6d15a66b48120"}},"id":"prt_ed9424e0a0017pIhjkyzQ7Shm0","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed9421d3d001fIaymXsx6pDkWD"}}
