NTEGER NOT NULL DEFAULT 0,\n1164:             created_at TEXT DEFAULT (datetime('now'))\n1165:           )\n1166:         `);\n1167:         database.exec('CREATE INDEX IF NOT EXISTS idx_entity_catalog_name ON entity_catalog(canonical_name)');\n1168:         logger.info('Migration v20: Created entity_catalog table (S5)');\n1169:       } catch (e: unknown) {\n1170:         if (!get_error_message(e).includes('already exists')) {\n1171:           console.warn('[VectorIndex] Migration v20 warning (entity_catalog):', get_error_message(e));\n1172:         }\n1173:       }\n1174:     }\n1175:   };\n1176: \n1177:   // V20 -> v21: Add learned_triggers column (learned feedback)\n1178:   migrations[21] = () => {\n1179:     try {\n1180:       database.exec(\"ALTER TABLE memory_index ADD COLUMN learned_triggers TEXT DEFAULT '[]'\");\n1181:       logger.info('Migration v21: Added learned_triggers column (R11)');\n1182:     } catch (e: unknown) {\n1183:       if (!get_error_message(e).includes('duplicate column') && !get_error_message(e).includes('already exists')) {\n1184:         console.warn('[VectorIndex] Migration v21 warning (learned_triggers):', get_error_message(e));\n1185:       }\n1186:     }\n1187:   };\n1188: \n1189:   migrations[22] = () => {\n1190:     try {\n1191:       ensureLineageTables(database);\n1192:       logger.info('Migration v22: Created memory lineage tables and indexes');\n1193:     } catch (e: unknown) {\n1194:       if (!get_error_message(e).includes('already exists')) {\n1195:         console.warn('[VectorIndex] Migration v22 warning (memory lineage):', get_error_message(e));\n1196:       }\n1197:     }\n1198:   };\n1199: \n1200:   // V22 -> V23: One-time re-canonicalization of spec_folder values\n1201:   migrations[23] = () => {\n1202:     const rows = database.prepare(`\n1203:       SELECT id, file_path, spec_folder FROM memory_index\n1204:       WHERE file_path IS NOT NULL AND file_path != ''\n1205:     `).all() as Array<{ id: number; file_path: string; spec_folder: string }>;\n1206: \n1207:     // Filter in JS with normalized separators (not SQL LIKE)\n1208:     const specRows = rows.filter(row => {\n1209:       const normalized = row.file_path.replace(/\\\\/g, '/');\n1210:       return normalized.includes('/specs/') || normalized.startsWith('specs/');\n1211:     });\n1212: \n1213:     const updates: Array<{ id: number; canonical: string; oldSpecFolder: string }> = [];\n1214:     for (const row of specRows) {\n1215:       try {\n1216:         const canonical = extractSpecFolder(row.file_path);\n1217:         if (canonical !== row.spec_folder) {\n1218:           updates.push({ id: row.id, canonical, oldSpecFolder: row.spec_folder });\n1219:         }\n1220:       } catch {\n1221:         logger.warn(`Migration v23: Skipping row ${row.id} — canonicalization failed`);\n1222:       }\n1223:     }\n1224: \n1225:     if (updates.length > 0) {\n1226:       const updateStmt = database.prepare(\n1227:         'UPDATE memory_index SET spec_folder = ? WHERE id = ? AND spec_folder = ?'\n1228:       );\n1229:       for (const u of updates) {\n1230:         updateStmt.run(u.canonical, u.id, u.oldSpecFolder);\n1231:       }\n1232:       logger.info(`Migration v23: Re-canonicalized spec_folder for ${updates.length} memory rows`);\n1233:     }\n1234: \n1235:     // Migrate session_state.spec_folder using old→new mapping\n1236:     migrateSessionStateSpecFolders(database, updates);\n1237:     migrateHistorySpecFolders(database, updates);\n1238:   };\n1239: \n1240:   migrations[24] = () => {\n1241:     createRequiredIndex(\n1242:       database,\n1243:       'idx_trigger_cache_source',\n1244:       `CREATE INDEX IF NOT EXISTS idx_trigger_cache_source\n1245:        ON memory_index(embedding_status, id)\n1246:        WHERE embedding_status = 'success'\n1247:          AND trigger_phrases IS NOT NULL\n1248:          AND trigger_phrases != '[]'\n1249:          AND trigger_phrases != ''`,\n1250:       'Migration v24',\n1251:     );\n1252:     createRequiredIndex(\n1253:       database,\n1254:       'idx_spec_folder_created_at',\n1255:       'CREATE INDEX IF NOT EXISTS idx_spec_folder_created_at ON memory_index(spec_folder, created_at DESC)',\n1256:       'Migration v24',\n1257:     );\n1258:     logger.info('Migration v24: Created trigger-cache source and temporal contiguity indexes');\n1259:   };\n1260: \n1261:   migrations[25] = () => {\n1262:     // Normalize legacy context_type values and rebuild CHECK constraint.\n1263:     // Step 1: UPDATE legacy values to canonical forms\n1264:     const updated = database.prepare(`\n1265:       UPDATE memory_index SET context_type = 'planning' WHERE context_type = 'decision'\n1266:     `).run();\n1267:     const updatedDiscovery = database.prepare(`\n1268:       UPDATE memory_index SET context_type = 'general' WHERE context_type = 'discovery'\n1269:     `).run();\n1270:     logger.info(`Migration v25: Normalized context_type values (${updated.changes} decision→planning, ${updatedDiscovery.changes} discovery→general)`);\n1271: \n1272:     // Step 2: Rebuild table with strict CHECK constraint (canonical types only).\n1273:     // SQLite doesn't support ALTER CONSTRAINT, so we rebuild the table.\n1274:     const hasContextTypeColumn = database.prepare(\n1275:       `SELECT COUNT(*) as cnt FROM pragma_table_info('memory_index') WHERE name = 'context_type'`\n1276:     ).get() as { cnt: number };\n1277: \n1278:     if (hasContextTypeColumn.cnt > 0) {\n1279:       // Get current table SQL to check if CHECK constraint needs updating\n1280:       const tableInfo = database.prepare(\n1281:         `SELECT sql FROM sqlite_master WHERE type='table' AND name='memory_index'`\n1282:       ).get() as { sql: string } | undefined;\n1283: \n1284:       if (tableInfo?.sql && !tableInfo.sql.includes(\"context_type IN ('research', 'implementation', 'planning', 'general')\")) {\n1285:         // Table needs rebuilding — current CHECK is either missing or includes legacy values\n1286:         // Get all column names from the existing table\n1287:         const columns = database.prepare(`PRAGMA table_info(memory_index)`).all() as Array<{ name: string }>;\n1288:         const columnNames = columns.map(c => c.name).join(', ');\n1289: \n1290:         // Get all indexes to recreate after rebuild\n1291:         const indexes = database.prepare(\n1292:           `SELECT sql FROM sqlite_master WHERE type='index' AND tbl_name='memory_index' AND sql IS NOT NULL`\n1293:         ).all() as Array<{ sql: string }>;\n1294: \n1295:         // Rebuild: rename → create new → copy → drop old\n1296:         database.exec(`ALTER TABLE memory_index RENAME TO memory_index_v24_backup`);\n1297: \n1298:         // Get the CREATE TABLE statement and replace the CHECK constraint\n1299:         let createSql = tableInfo.sql;\n1300:         // Replace any existing CHECK on context_type with strict canonical-only constraint\n1301:         createSql = createSql.replace(\n1302:           /CHECK\\s*\\(\\s*context_type\\s+IN\\s*\\([^)]+\\)\\s*\\)/i,\n1303:           \"CHECK(context_type IN ('research', 'implementation', 'planning', 'general'))\"\n1304:         );\n1305:         // If no CHECK existed (column added via ALTER TABLE), add one\n1306:         if (!createSql.includes('CHECK(context_type')) {\n1307:           createSql = createSql.replace(\n1308:             /context_type\\s+TEXT\\s+DEFAULT\\s+'general'/i,\n1309:             \"context_type TEXT DEFAULT 'general' CHECK(context_type IN ('research', 'implementation', 'planning', 'general'))\"\n1310:           );\n1311:         }\n1312:         database.exec(createSql);\n1313: \n1314:         // Copy data\n1315:         database.exec(`INSERT INTO memory_index SELECT ${columnNames} FROM memory_index_v24_backup`);\n1316:         database.exec(`DROP TABLE memory_index_v24_backup`);\n1317: \n1318:         // Recreate indexes\n1319:         for (const idx of indexes) {\n\n(Showing lines 980-1319 of 2784. Use offset=1