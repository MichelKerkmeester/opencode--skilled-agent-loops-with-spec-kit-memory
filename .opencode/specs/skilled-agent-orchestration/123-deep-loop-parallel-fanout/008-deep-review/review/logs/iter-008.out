   483	/**
   484	 * Delete a node and its connected edges inside a namespace.
   485	 *
   486	 * @param ns - Namespace for scoping.
   487	 * @param id - Node ID to delete.
   488	 * @returns True if a node was deleted.
   489	 */
   490	export function deleteNode(ns: Namespace, id: string): boolean {
   491	  if (!ns.sessionId) return false;
   492	  const d = getDb();
   493	  const tx = d.transaction(() => {
   494	    prepareStatement(
   495	      'DELETE FROM coverage_edges WHERE spec_folder = ? AND loop_type = ? AND session_id = ? AND (source_id = ? OR target_id = ?)',
   496	    ).run(ns.specFolder, ns.loopType, ns.sessionId, id, id);
   497	    const result = prepareStatement(
   498	      'DELETE FROM coverage_nodes WHERE spec_folder = ? AND loop_type = ? AND session_id = ? AND id = ?',
   499	    ).run(ns.specFolder, ns.loopType, ns.sessionId, id);
   500	    return result.changes > 0;
   501	  });
   502	  return tx();
   503	}
