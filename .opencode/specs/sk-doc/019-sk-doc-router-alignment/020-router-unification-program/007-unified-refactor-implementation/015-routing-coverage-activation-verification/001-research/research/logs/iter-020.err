   126	def iter_code_files(roots: Iterable[str]) -> Iterable[str]:
   127	    seen_paths: Set[str] = set()
   128	    for root in roots:
   129	        abs_root = os.path.realpath(root)
   130	        for current_root, dirs, files in os.walk(abs_root):
   131	            dirs[:] = [entry for entry in dirs if entry not in EXCLUDED_DIRS]
   132	            for filename in files:
   133	                extension = os.path.splitext(filename)[1].lower()
   134	                if extension in SUPPORTED_EXTENSIONS:
   135	                    candidate = os.path.realpath(os.path.join(current_root, filename))
   136	                    if candidate in seen_paths:
   137	                        continue
   138	                    seen_paths.add(candidate)
   139	                    yield candidate
   140	
   141	
   142	def find_line(lines: List[str], pattern: str) -> int:
   143	    regex = re.compile(pattern)
   144	    for index, value in enumerate(lines, start=1):
   145	        if regex.search(value):
   146	            return index
   147	    return 0
   148	
