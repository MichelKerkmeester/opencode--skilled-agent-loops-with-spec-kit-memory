replaces all `{variableName}` tokens\n48:  * with values from the variables map.\n49:  *\n50:  * @param templatePath - Path to the prompt pack template file.\n51:  * @param variables - Mapping of variable names to replacement values.\n52:  * @returns Rendered template string with all variables substituted.\n53:  * @throws {@link PromptPackError} If any required variables are missing.\n54:  */\n55: export function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {\n56:   const template = readFileSync(templatePath, 'utf8');\n57:   const missingVariables = new Set<string>();\n58: \n59:   const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {\n60:     if (!(tokenName in variables)) {\n61:       missingVariables.add(tokenName);\n62:       return `{${tokenName}}`;\n63:     }\n64: \n65:     return String(variables[tokenName]);\n66:   });\n67: \n68:   if (missingVariables.size > 0) {\n69:     throw new PromptPackError([...missingVariables]);\n70:   }\n71: \n72:   return rendered;\n73: }\n74: \n75: /**\n76:  * Validate that a prompt pack template contains expected variables.\n77:  *\n78:  * @param templatePath - Path to the prompt pack template file.\n79:  * @param expectedVariables - Variable names that should be present.\n80:  * @returns Report with present, missing, and extra variables.\n81:  */\n82: export function validatePromptPackTemplate(\n83:   templatePath: string,\n84:   expectedVariables: string[],\n85: ): { present: string[]; missing: string[]; extra: string[] } {\n86:   const template = readFileSync(templatePath, 'utf8');\n87:   const templateTokens = extractTemplateTokens(template);\n88:   const templateTokenSet = new Set(templateTokens);\n89:   const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));\n90: \n91:   return {\n92:     present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),\n93:     missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),\n94:     extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),\n95:   };\n96: }\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"// MODULE: Deep-Loop Prompt Pack Renderer\n\nimport { readFileSync } from 'node:fs';\nimport { z } from '../../../system-spec-kit/mcp_server/node_modules/zod/index.js';\n\n// ───── TYPE DEFINITIONS ─────\n\nexport type PromptPackVariables = Record<string, string | number>;\n\n// ───── CONSTANTS ─────\n\nconst PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\nconst promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n\n// ───── DOMAIN ERRORS ─────\n\nexport class PromptPackError extends Error {\n  missingVariables: string[];\n\n  constructor(missingVariables: string[]) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts","text":"// MODULE: Deep-Loop Prompt Pack Renderer\n\nimport { readFileSync } from 'node:fs';\nimport { z } from '../../../system-spec-kit/mcp_server/node_modules/zod/index.js';\n\n// ───── TYPE DEFINITIONS ─────\n\nexport type PromptPackVariables = Record<string, string | number>;\n\n// ───── CONSTANTS ─────\n\nconst PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\nconst promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n\n// ───── DOMAIN ERRORS ─────\n\nexport class PromptPackError extends Error {\n  missingVariables: string[];\n\n  constructor(missingVariables: string[]) {\n    super(`Missing prompt pack variables: ${missingVariables.join(', ')}`);\n    this.name = 'PromptPackError';\n    this.missingVariables = missingVariables;\n  }\n}\n\n// ───── HELPERS ─────\n\nfunction extractTemplateTokens(template: string): string[] {\n  const tokens = new Set<string>();\n\n  for (const match of template.matchAll(PROMPT_PACK_TOKEN_PATTERN)) {\n    const tokenName = match[1];\n    if (promptPackVariableNameSchema.safeParse(tokenName).success) {\n      tokens.add(tokenName);\n    }\n  }\n\n  return [...tokens];\n}\n\n// ───── EXPORTS ─────\n\n/**\n * Render a prompt pack template by substituting variables.\n *\n * Reads the template file and replaces all `{variableName}` tokens\n * with values from the variables map.\n *\n * @param templatePath - Path to the prompt pack template file.\n * @param variables - Mapping of variable names to replacement values.\n * @returns Rendered template string with all variables substituted.\n * @throws {@link PromptPackError} If any required variables are missing.\n */\nexport function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {\n  const template = readFileSync(templatePath, 'utf8');\n  const missingVariables = new Set<string>();\n\n  const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {\n    if (!(tokenName in variables)) {\n      missingVariables.add(tokenName);\n      return `{${tokenName}}`;\n    }\n\n    return String(variables[tokenName]);\n  });\n\n  if (missingVariables.size > 0) {\n    throw new PromptPackError([...missingVariables]);\n  }\n\n  return rendered;\n}\n\n/**\n * Validate that a prompt pack template contains expected variables.\n *\n * @param templatePath - Path to the prompt pack template file.\n * @param expectedVariables - Variable names that should be present.\n * @returns Report with present, missing, and extra variables.\n */\nexport function validatePromptPackTemplate(\n  templatePath: string,\n  expectedVariables: string[],\n): { present: string[]; missing: string[]; extra: string[] } {\n  const template = readFileSync(templatePath, 'utf8');\n  const templateTokens = extractTemplateTokens(template);\n  const templateTokenSet = new Set(templateTokens);\n  const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));\n\n  return {\n    present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),\n    missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),\n    extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),\n  };\n}","lineStart":1,"lineEnd":96,"totalLines":96,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts","time":{"start":1781518893243,"end":1781518893248}},"id":"prt_ecacd00b7001RENJg7HXZRmXu9","sessionID":"ses_13537258affeqeTEqC63wDuxy2","messageID":"msg_ecaccf2f90015GXkq00MS8mLHQ"}}
