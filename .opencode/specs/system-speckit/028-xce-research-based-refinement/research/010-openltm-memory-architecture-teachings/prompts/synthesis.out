-Kit Bug [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/049-system-analysis-bugs/spec]\",\n          \"matched_phrases\": [\n            \"system\",\n            \"spec\",\n            \"kit\",\n            \"analysis\"\n          ]\n        },\n        {\n          \"memory_id\": 6831,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/042-post-merge-refinement-5\",\n          \"title\": \"Spec Kit [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/042-post-merge-refinement-5/decision-record]\",\n          \"matched_phrases\": [\n            \"spec\",\n            \"kit\",\n            \"memory\",\n            \"system\"\n          ]\n        },\n        {\n          \"memory_id\": 6769,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/033-ux-deep-analysis\",\n          \"title\": \"UX Deep Analysis - Memory [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/033-ux-deep-analysis/spec]\",\n          \"matched_phrases\": [\n            \"analysis\",\n            \"memory\",\n            \"systems\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 6742,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/027-memory-plugin-and-refinement/001-memory-repo-analysis\",\n          \"title\": \"...spec-kit/z_archive/001-fix-command-dispatch/z_archive/027-memory-plugin-and-refinement/001-memory-repo-analysis/spec]\",\n          \"matched_phrases\": [\n            \"memory\",\n            \"system\",\n            \"analysis\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 8514,\n          \"spec_folder\": \"system-spec-kit/z_archive/023-hybrid-rag-fusion-refinement\",\n          \"title\": \"Deep Research: Spec Kit Memory Feature Audit & Quality [system-spec-kit/023-hybrid-rag-fusion-refinement/research]\",\n          \"matched_phrases\": [\n       