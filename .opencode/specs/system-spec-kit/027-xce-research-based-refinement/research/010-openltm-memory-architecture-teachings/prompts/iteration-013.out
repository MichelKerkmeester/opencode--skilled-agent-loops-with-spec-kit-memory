ROM memory_provenance\n  WHERE memory_provenance.memory_id = memories.id\n  ORDER BY created_at ASC\n  LIMIT 1\n)\nWHERE created_by IS NULL;","lineStart":1,"lineEnd":13,"totalLines":13,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/013_add_created_by.sql","time":{"start":1780929075829,"end":1780929075833}},"metadata":{"openai":{"itemId":"fc_07fcd20aec7abfc2016a26d2339e7881918c904733b884259e"}},"id":"prt_ea7a51a28001LpmfjGlBvqERgV","sessionID":"ses_1585c7ef3ffeE8bQgxmNtEsbEj","messageID":"msg_ea7a4fbdd001oFevnJBPW0uMCH"}}
