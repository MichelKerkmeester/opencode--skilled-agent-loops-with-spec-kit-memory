───────────────────────────────────────── */\n35: \n36: type SessionStatus = 'ok' | 'warning' | 'stale';\n37: // Section-level trust state reuses the canonical\n38: // SharedPayloadTrustState vocabulary ('live' / 'stale' / 'absent' /\n39: // 'unavailable'). Keeping the alias narrows to just the four states\n40: // session-health observes (it never emits 'cached'/'imported'/etc.).\n41: type SessionHealthSectionTrustState = Extract<\n42:   SharedPayloadTrustState,\n43:   'live' | 'stale' | 'absent' | 'unavailable'\n44: >;\n45: \n46: interface SessionHealthDetails {\n47:   sessionAgeMs: number;\n48:   lastToolCallAgoMs: number;\n49:   graphFreshness: 'fresh' | 'stale' | 'empty' | 'error';\n50:   specFolder: string | null;\n51:   primingStatus: 'primed' | 'not_primed';\n52: }\n53: \n54: interface SessionHealthSectionStructuralTrust {\n55:   state: SessionHealthSectionTrustState;\n56:   trustedAt: string;\n57: }\n58: \n59: interface SessionHealthSection {\n60:   key: string;\n61:   title: string;\n62:   content: string;\n63:   source: SharedPayloadSection['source'];\n64:   structuralTrust: SessionHealthSectionStructuralTrust;\n65: }\n66: \n67: interface SessionHealthResult {\n68:   status: SessionStatus;\n69:   details: SessionHealthDetails;\n70:   qualityScore: QualityScore;\n71:   sections: SessionHealthSection[];\n72:   structuralContext?: StructuralBootstrapContract;\n73:   payloadContract?: SharedPayloadEnvelope;\n74:   graphOps?: CodeGraphOpsContract;\n75:   hints: string[];\n76: }\n77: \n78: /* ───────────────────────────────────────────────────────────────\n79:    2. CONSTANTS\n80: ──────────────────────────────────────────────────────────────── */\n\n(Showing lines 1-80 of 301. Use offset=81 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Session Health Handler\n// ───────────────────────────────────────────────────────────────\n// MCP tool handler for session_health — reports session\n// readiness, code graph freshness, and priming status.\n\nimport {\n  isSessionPrimed,\n  getSessionTimestamps,\n  getLastActiveSessionId,\n  getCodeGraphStatusSnapshot,\n} from '../hooks/memory-surface.js';\n\nimport { computeQualityScore, getLastToolCallAt } from '../lib/session/context-metrics.js';\nimport { buildStructuralBootstrapContract } from '../lib/session/session-snapshot.js';\nimport type { StructuralBootstrapContract } from '../lib/session/session-snapshot.js';\nimport type { QualityScore } from '../lib/session/context-metrics.js';\nimport {\n  buildStructuralContextTrust,\n  createSharedPayloadEnvelope,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/session-health.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Session Health Handler\n// ───────────────────────────────────────────────────────────────\n// MCP tool handler for session_health — reports session\n// readiness, code graph freshness, and priming status.\n\nimport {\n  isSessionPrimed,\n  getSessionTimestamps,\n  getLastActiveSessionId,\n  getCodeGraphStatusSnapshot,\n} from '../hooks/memory-surface.js';\n\nimport { computeQualityScore, getLastToolCallAt } from '../lib/session/context-metrics.js';\nimport { buildStructuralBootstrapContract } from '../lib/session/session-snapshot.js';\nimport type { StructuralBootstrapContract } from '../lib/session/session-snapshot.js';\nimport type { QualityScore } from '../lib/session/context-metrics.js';\nimport {\n  buildStructuralContextTrust,\n  createSharedPayloadEnvelope,\n  trustStateFromStructuralStatus,\n  type SharedPayloadEnvelope,\n  type SharedPayloadSection,\n  type SharedPayloadTrustState,\n} from '../lib/context/shared-payload.js';\nimport {\n  buildCodeGraphOpsContract,\n  type CodeGraphOpsContract,\n} from '@spec-kit/shared/code-graph-contracts';\nimport type { MCPResponse } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ntype SessionStatus = 'ok' | 'warning' | 'stale';\n// Section-level trust state reuses the canonical\n// SharedPayloadTrustState vocabulary ('live' / 'stale' / 'absent' /\n// 'unavailable'). Keeping the alias narrows to just the four states\n// session-health observes (it never emits 'cached'/'imported'/etc.).\ntype SessionHealthSectionTrustState = Extract<\n  SharedPayloadTrustState,\n  'live' | 'stale' | 'absent' | 'unavailable'\n>;\n\ninterface SessionHealthDetails {\n  sessionAgeMs: number;\n  lastToolCallAgoMs: number;\n  graphFreshness: 'fresh' | 'stale' | 'empty' | 'error';\n  specFolder: string | null;\n  primingStatus: 'primed' | 'not_primed';\n}\n\ninterface SessionHealthSectionStructuralTrust {\n  state: SessionHealthSectionTrustState;\n  trustedAt: string;\n}\n\ninterface SessionHealthSection {\n  key: string;\n  title: string;\n  content: string;\n  source: SharedPayloadSection['source'];\n  structuralTrust: SessionHealthSectionStructuralTrust;\n}\n\ninterface SessionHealthResult {\n  status: SessionStatus;\n  details: SessionHealthDetails;\n  qualityScore: QualityScore;\n  sections: SessionHealthSection[];\n  structuralContext?: StructuralBootstrapContract;\n  payloadContract?: SharedPayloadEnvelope;\n  graphOps?: CodeGraphOpsContract;\n  hints: string[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONSTANTS\n──────────────────────────────────────────────────────────────── */","lineStart":1,"lineEnd":80,"totalLines":301,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/session-health.ts","time":{"start":1780736601210,"end":1780736601217}},"id":"prt_e9c2c2c750014IGZTV4GqXbfFq","sessionID":"ses_163d5466cffeJfZ1lzw3MIVtCp","messageID":"msg_e9c2c21160018387vLQEFgZgHe"}}
