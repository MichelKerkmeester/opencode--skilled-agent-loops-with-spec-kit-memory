   125	# 2. SURFACE WALKING
   126	# ───────────────────────────────────────────────────────────────
   127	
   128	
   129	@dataclass
   130	class Item:
   131	    name: str
   132	    surface: str  # 'skill' | 'command' | 'agent'
   133	    path: str
   134	    description: str
   135	    length: int
   136	    mirrored_paths: List[str] = field(default_factory=list)
   137	
   138	    @property
   139	    def soft_target(self) -> int:
   140	        return (
   141	            DESCRIPTION_SOFT_TARGET_COMMAND
   142	            if self.surface == "command"
   143	            else DESCRIPTION_SOFT_TARGET_SKILL
   144	        )
   145	
   146	    @property
   147	    def status(self) -> str:
   148	        if self.length > DESCRIPTION_HARD_CAP:
   149	            return "HARD-FAIL"
   150	        if self.length > self.soft_target:
   151	            return "OVER-SOFT"
   152	        return "OK"
   153	
   154	
   155	def walk_skills(repo: Path) -> List[Item]:
   156	    items: List[Item] = []
   157	    base = repo / ".opencode" / "skill"
   158	    if not base.is_dir():
   159	        return items
   160	    for skill_dir in sorted(base.iterdir()):
   161	        skill_md = skill_dir / "SKILL.md"
   162	        if not skill_md.is_file():
   163	            continue
   164	        try:
   165	            text = skill_md.read_text(encoding="utf-8")
   166	        except OSError:
   167	            continue
   168	        desc = parse_yaml_frontmatter_description(text)
   169	        if desc is None:
   170	            continue
   171	        items.append(
   172	            Item(
   173	                name=skill_dir.name,
   174	                surface="skill",
   175	                path=str(skill_md.relative_to(repo)),
   176	                description=desc,
   177	                length=len(desc),
   178	            )
   179	        )
   180	    return items
   181	
   182	
   183	def walk_commands(repo: Path) -> List[Item]:
   184	    items: List[Item] = []
   185	    base = repo / ".opencode" / "command"
   186	    if not base.is_dir():
   187	        return items
   188	    for cmd in sorted(base.rglob("*.md")):
   189	        # Skip nested asset markdown files
   190	        if "assets" in cmd.parts or "scripts" in cmd.parts:
   191	            continue
   192	        try:
   193	            text = cmd.read_text(encoding="utf-8")
   194	        except OSError:
   195	            continue
   196	        desc = parse_yaml_frontmatter_description(text)
   197	        if desc is None:
   198	            continue
   199	        rel = cmd.relative_to(base)
   200	        # Name: use folder/basename for namespaced commands (e.g., "memory/save")
   201	        if rel.parent != Path("."):
   202	            display_name = f"{rel.parent}/{rel.stem}"
   203	        else:
   204	            display_name = rel.stem
   205	        items.append(
   206	            Item(
   207	                name=display_name,
   208	                surface="command",
   209	                path=str(cmd.relative_to(repo)),
   210	                description=desc,
   211	                length=len(desc),
   212	            )
   213	        )
   214	    return items
   215	
   216	
   217	def walk_agents(repo: Path) -> List[Item]:
   218	    """Walk all four runtime agent surfaces, dedupe by name, annotate mirrors."""
   219	    surfaces = [
   220	        (repo / ".opencode" / "agent", "yaml"),
   221	        (repo / ".claude" / "agents", "yaml"),
   222	        (repo / ".gemini" / "agents", "yaml"),
   223	        (repo / ".codex" / "agents", "toml"),
   224	    ]
   225	    by_name: Dict[str, Item] = {}
   226	    for base, fmt in surfaces:
   227	        if not base.is_dir():
   228	            continue
   229	        pattern = "*.md" if fmt == "yaml" else "*.toml"
   230	        for path in sorted(base.glob(pattern)):
   231	            try:
   232	                text = path.read_text(encoding="utf-8")
   233	            except OSError:
   234	                continue
   235	            desc = (
   236	                parse_yaml_frontmatter_description(text)
   237	                if fmt == "yaml"
   238	                else parse_toml_description(text)
   239	            )
   240	            if desc is None:
   241	                continue
   242	            name = path.stem
   243	            rel_path = str(path.relative_to(repo))
   244	            if name in by_name:
   245	                existing = by_name[name]
   246	                existing.mirrored_paths.append(rel_path)
   247	                continue
   248	            by_name[name] = Item(
   249	                name=name,
   250	                surface="agent",
   251	                path=rel_path,
   252	                description=desc,
   253	                length=len(desc),
   254	                mirrored_paths=[rel_path],
   255	            )
   256	    return list(by_name.values())
   257	
   258	
   259	# ───────────────────────────────────────────────────────────────
   260	# 3. REPORTING

