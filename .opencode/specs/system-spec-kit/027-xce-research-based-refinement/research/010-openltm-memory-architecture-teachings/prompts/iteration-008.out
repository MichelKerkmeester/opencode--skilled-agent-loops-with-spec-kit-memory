":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/adapterTypes.ts","text":"/** Configuration injected by the host adapter (Claude Code, OpenCode, Pi). */\nexport interface LtmCoreConfig {\n  dbPath: string;\n  schemaPath?: string;\n  migrationsDir?: string;\n  docsDir?: string;\n  decayEnabled?: boolean;\n  graphReasoning?: boolean;\n  semanticFallback?: boolean;\n  autoRelate?: boolean;\n}\n\n/** Session context passed from the host to openltm-core hooks. */\nexport interface LtmAdapterContext {\n  cwd: string;\n  project?: string;\n}\n\n/** Options provided to the adapter factory. */\nexport interface LtmAdapterOptions {\n  config: LtmCoreConfig;\n  pluginDataDir?: string;\n}","lineStart":1,"lineEnd":23,"totalLines":23,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/adapterTypes.ts","time":{"start":1780925725548,"end":1780925725555}},"metadata":{"openai":{"itemId":"fc_0742f1a721999b37016a26c51c2de48191b0b1789a5c4c0db6"}},"id":"prt_ea771fb52001UZT50rP9NqsYz4","sessionID":"ses_158903c29ffee2t6kDIK4biSQu","messageID":"msg_ea7716c47001NQwkPTuh9YcrGh"}}
