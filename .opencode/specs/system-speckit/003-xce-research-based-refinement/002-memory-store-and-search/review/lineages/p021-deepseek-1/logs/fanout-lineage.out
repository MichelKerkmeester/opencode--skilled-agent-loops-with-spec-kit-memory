ts.postInsertEnrichmentRepaired > 0\n1353:         ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n1354:         : {}),\n1355:       ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n1356:         ? {\n1357:             orphanSwept: results.orphanSwept,\n1358:             orphanSweepFailed: results.orphanSweepFailed,\n1359:           }\n1360:         : {}),\n1361:     }, scanAppliedActions);\n1362:   }\n1363: \n1364:   runScanHygieneSubscribers(scanAppliedActions);\n1365: \n1366:   const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n1367: \n1368:   const hints: string[] = [];\n1369:   if (results.failed > 0) {\n1370:     hints.push(`${results.failed} files failed to index - check file format`);\n1371:   }\n1372:   if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n1373:     hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n1374:   }\n1375:   if (results.staleDeleted > 0) {\n1376:     hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n1377:   }\n1378:   if (results.staleDeleteFailed > 0) {\n1379:     hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n1380:   }\n1381:   if (results.orphanSwept > 0) {\n1382:     hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n1383:   }\n1384:   if (results.postInsertEnrichmentRepaired > 0) {\n1385:     hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n1386:   }\n1387:   if (results.triggerEmbeddingBackfill?.readyRows) {\n1388:     hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n1389:   }\n1390:   if (results.triggerEmbeddingBackfill?.failedRows) {\n1391:     hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n1392:   }\n1393:   if (results.orphanSweepFailed > 0) {\n1394:     hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n1395:   }\n1396:   if (results.dedup.duplicatesSkipped > 0) {\n1397:     hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n1398:   }\n1399:   if (results.aliasConflicts.groups > 0) {\n1400:     hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n1401:   }\n1402:   if (results.aliasConflicts.divergentHashGroups > 0) {\n1403:     hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n1404:   }\n1405:   if (results.divergenceReconcile.retriesScheduled > 0) {\n1406:     hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n1407:   }\n1408:   if (results.divergenceReconcile.escalated > 0) {\n1409:     hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n1410:   }\n1411:   if (results.divergenceReconcile.errors.length > 0) {\n1412:     hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n1413:   }\n1414:   if (results.checkpointRepair.cleared) {\n1415:     hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n1416:   }\n1417:   if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n1418:     hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n1419:   }\n1420:   if (results.checkpointRepair.error) {\n1421:     hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n1422:   }\n1423:   if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n1424:     hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n1425:   }\n1426:   if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n1427:     hints.push('All files already up-to-date. Use force: true to re-index');\n1428:   }\n1429: \n1430:   await releaseScanLease();\n1431: \n1432:   recordMaintenanceRun('memory_index_scan', {\n1433:     status: 'success',\n1434:     counts: {\n1435:       scanned: results.scanned,\n1436:       indexed: results.indexed,\n1437:       updated: results.updated,\n1438:       unchanged: results.unchanged,\n1439:       failed: results.failed,\n1440:       staleDeleted: results.staleDeleted,\n1441:       staleDeleteFailed: results.staleDeleteFailed,\n1442:       orphanSwept: results.orphanSwept,\n1443:     },\n1444:     staleCandidates: filesToDelete.length,\n1445:   });\n1446: \n1447:   return createMCPSuccessResponse({\n1448:     tool: 'memory_index_scan',\n1449:     summary,\n1450:     data: {\n1451:       status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n1452:       ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n1453:       scanKey,\n1454:       batchSize: scanBatchSize,\n1455:       ...results,\n1456:       ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n1457:         ? {\n1458:             _debug_fileCounts: {\n1459:               constitutionalFiles: constitutionalFiles.length,\n1460:               specDocFiles: specDocFiles.length,\n1461:               totalFiles: files.length,\n1462:               mergedFiles: mergedFiles.length,\n1463:               dedupSkipped: dedupDuplicatesSkipped,\n1464:               includeSpecDocs: include_spec_docs,\n1465:               workspacePath,\n1466:             },\n1467:           }\n1468:         : {})\n1469:     },\n1470:     hints\n1471:   });\n1472:   } finally {\n1473:     if (leaseHeartbeat) {\n1474:       clearInterval(leaseHeartbeat);\n1475:       leaseHeartbeat = null;\n1476:     }\n1477:     if (loopLagTimer) {\n1478:       clearInterval(loopLagTimer);\n1479:       loopLagTimer = null;\n1480:       console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n1481:     }\n1482:     await releaseScanLease();\n1483:   }\n1484: }\n1485: \n1486: /** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n1487:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1488: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1489:   if (!args.background) {\n1490:     return runIndexScan(args, {});\n1491:   }\n1492: \n1493:   const jobId = createJobId();\n1494:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1495: \n1496:   setImmediate(() => {\n1497:     void (async () => {\n1498:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1499:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1500:       // background-embedding queue draining this scan's deferred embeddings can\n1501:       // keep it held past the scan itself.\n1502:       const maintenance = beginMaintenance('index_scan');\n1503:       try {\n1504:         await setJobState(jobId, 'running');\n1505:         const response = await runIndexScan(args, {\n1506:           isCancelled: () => isCancelRequestedFast(jobId),\n1507:           onPhase: (phase) => {\n1508:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1509:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1510:             maintenance.refresh();\n1511:             void setJobPhase(jobId, phase).catch(() => {});\n1512:           },\n1513:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1514:         });\n1515:         const scanData = extractEnvelopeData(response);\n1516:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1517:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1518:         if (wasCancelled) {\n1519:           // The run itself short-circuited on cancellation. A cancel that arrives\n1520:           // after the scan already finished does not retroactively cancel it.\n1521:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1522:         } else if (response.isError === true) {\n1523:           // An error envelope (not a thrown error) still means the scan failed.\n1524:           await appendJobError(jobId, '__scan__', scanData);\n1525:           await setJobState(jobId, 'failed');\n1526:         } else {\n1527:           await completeJob(jobId, { state: 'complete', result: scanData });\n1528:         }\n1529:       } catch (error: unknown) {\n1530:         try {\n1531:           await appendJobError(jobId, '__job__', error);\n1532:           await setJobState(jobId, 'failed');\n1533:         } catch (_secondaryError: unknown) {\n1534:           // Best-effort failure record; never surface a background unhandled rejection.\n1535:         }\n1536:       } finally {\n1537:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1538:         // Release this scan's hold; the marker stays present only while the\n1539:         // background-embedding queue still holds it.\n1540:         maintenance.end();\n1541:       }\n1542:     })();\n1543:   });\n1544: \n1545:   return createMCPSuccessResponse({\n1546:     tool: 'memory_index_scan',\n1547:     summary: `Queued background index scan ${jobId}`,\n1548:     data: { jobId, state: 'queued', background: true },\n1549:     hints: [\n1550:       'Use memory_index_scan_status with jobId to poll progress',\n1551:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1552:     ],\n1553:   });\n1554: }\n1555: \n1556: /* ───────────────────────────────────────────────────────────────\n1557:    9. EXPORTS\n1558: ──────────────────────────────────────────────────────────────── */\n1559: \n1560: export {\n1561:   handleMemoryIndexScan,\n1562:   indexSingleFile,\n1563:   findConstitutionalFiles,\n1564:   findSpecDocuments,\n1565:   detectSpecLevel,\n1566:   summarizeAliasConflicts,\n1567:   runDivergenceReconcileHooks,\n1568: };\n1569: \n1570: // Backward-compatible aliases (snake_case)\n1571: const handle_memory_index_scan = handleMemoryIndexScan;\n1572: const index_single_file = indexSingleFile;\n1573: const find_constitutional_files = findConstitutionalFiles;\n1574: const find_spec_documents = findSpecDocuments;\n1575: const detect_spec_level = detectSpecLevel;\n1576: const summarize_alias_conflicts = summarizeAliasConflicts;\n1577: const run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n1578: \n1579: export {\n1580:   handle_memory_index_scan,\n1581:   index_single_file,\n1582:   find_constitutional_files,\n1583:   find_spec_documents,\n1584:   detect_spec_level,\n1585:   summarize_alias_conflicts,\n1586:   run_divergence_reconcile_hooks,\n1587: };\n\n(End of file - total 1587 lines)\n</content>","metadata":{"preview":"              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }\n\n  if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    runScanInvalidationHooks({\n      indexed: results.indexed,\n      updated: results.updated,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n        ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n        : {}),\n      ...(results.postInsertEnrichmentRepaired > 0\n        ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n        : {}),\n      ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n        ? {\n            orphanSwept: results.orphanSwept,\n            orphanSweepFailed: results.orphanSweepFailed,\n          }\n        : {}),\n    }, scanAppliedActions);\n  }\n\n  runScanHygieneSubscribers(scanAppliedActions);\n\n  const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n\n  const hints: string[] = [];\n  if (results.failed > 0) {\n    hints.push(`${results.failed} files failed to index - check file format`);\n  }\n  if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n    hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n  }\n  if (results.staleDeleted > 0) {\n    hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n  }\n  if (results.staleDeleteFailed > 0) {\n    hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n  }\n  if (results.orphanSwept > 0) {\n    hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n  }\n  if (results.postInsertEnrichmentRepaired > 0) {\n    hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.readyRows) {\n    hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.failedRows) {\n    hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n  }\n  if (results.orphanSweepFailed > 0) {\n    hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n  }\n  if (results.dedup.duplicatesSkipped > 0) {\n    hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n  }\n  if (results.aliasConflicts.groups > 0) {\n    hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n  }\n  if (results.aliasConflicts.divergentHashGroups > 0) {\n    hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n  }\n  if (results.divergenceReconcile.retriesScheduled > 0) {\n    hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n  }\n  if (results.divergenceReconcile.escalated > 0) {\n    hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n  }\n  if (results.divergenceReconcile.errors.length > 0) {\n    hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n  }\n  if (results.checkpointRepair.cleared) {\n    hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n  }\n  if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n    hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n  }\n  if (results.checkpointRepair.error) {\n    hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n  }\n  if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n    hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n  }\n  if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n    hints.push('All files already up-to-date. Use force: true to re-index');\n  }\n\n  await releaseScanLease();\n\n  recordMaintenanceRun('memory_index_scan', {\n    status: 'success',\n    counts: {\n      scanned: results.scanned,\n      indexed: results.indexed,\n      updated: results.updated,\n      unchanged: results.unchanged,\n      failed: results.failed,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      orphanSwept: results.orphanSwept,\n    },\n    staleCandidates: filesToDelete.length,\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})\n    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_index_scan = handleMemoryIndexScan;\nconst index_single_file = indexSingleFile;\nconst find_constitutional_files = findConstitutionalFiles;\nconst find_spec_documents = findSpecDocuments;\nconst detect_spec_level = detectSpecLevel;\nconst summarize_alias_conflicts = summarizeAliasConflicts;\nconst run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n\nexport {\n  handle_memory_index_scan,\n  index_single_file,\n  find_constitutional_files,\n  find_spec_documents,\n  detect_spec_level,\n  summarize_alias_conflicts,\n  run_divergence_reconcile_hooks,\n};","lineStart":1322,"lineEnd":1587,"totalLines":1587,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781716675669,"end":1781716675676}},"id":"prt_ed696ea4c001GSgLRoDKCVA49b","sessionID":"ses_12969ccceffeNZhLAWy8uWT1Wq","messageID":"msg_ed696d7f8001JCdegtKjkzzFel"}}
{"type":"tool_use","timestamp":1781716676091,"sessionID":"ses_12969ccceffeNZhLAWy8uWT1Wq","part":{"type":"tool","tool":"read","callID":"call_01_ILwYmKPaLTScpEuxdAux5958","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n2: import Database from 'better-sqlite3';\n3: \n4: import {\n5:   createSchema,\n6:   ensureSchemaVersion,\n7: } from '../lib/search/vector-index-schema';\n8: import { runTriggerEmbeddingBackfill } from '../lib/search/trigger-embedding-backfill';\n9: \n10: const embeddingMocks = vi.hoisted(() => ({\n11:   generateDocumentEmbedding: vi.fn(),\n12:   getEmbeddingProfile: vi.fn(),\n13:   getEmbeddingDimension: vi.fn(),\n14:   getModelName: vi.fn(),\n15: }));\n16: \n17: vi.mock('../lib/providers/embeddings', () => embeddingMocks);\n18: \n19: function createBackfillDatabase(): Database.Database {\n20:   const database = new Database(':memory:');\n21:   createSchema(database, {\n22:     sqlite_vec_available: false,\n23:     get_embedding_dim: () => 3,\n24:   });\n25:   ensureSchemaVersion(database);\n26:   return database;\n27: }\n28: \n29: function insertMemory(database: Database.Database, id: number, phrases: string[]): void {\n30:   database.prepare(`\n31:     INSERT INTO memory_index (\n32:       id, spec_folder, file_path, title, trigger_phrases,\n33:       created_at, updated_at, importance_tier, context_type, embedding_status\n34:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n35:   `).run(\n36:     id,\n37:     'trigger/backfill',\n38:     `/workspace/trigger/backfill/${id}.md`,\n39:     `Memory ${id}`,\n40:     JSON.stringify(phrases),\n41:     '2026-06-10T00:00:00.000Z',\n42:     '2026-06-10T00:00:00.000Z',\n43:     'normal',\n44:     'implementation',\n45:     'pending',\n46:   );\n47: }\n48: \n49: describe('trigger embedding backfill', () => {\n50:   let database: Database.Database;\n51:   let previousFlag: string | undefined;\n52: \n53:   beforeEach(() => {\n54:     previousFlag = process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n55:     delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n56:     database = createBackfillDatabase();\n57:     embeddingMocks.generateDocumentEmbedding.mockReset();\n58:     embeddingMocks.generateDocumentEmbedding.mockResolvedValue(new Float32Array([0.1, 0.2, 0.3]));\n59:     embeddingMocks.getEmbeddingProfile.mockReset();\n60:     embeddingMocks.getEmbeddingProfile.mockReturnValue({ provider: 'test', model: 'test-model', dim: 3 });\n61:     embeddingMocks.getEmbeddingDimension.mockReset();\n62:     embeddingMocks.getEmbeddingDimension.mockReturnValue(3);\n63:     embeddingMocks.getModelName.mockReset();\n64:     embeddingMocks.getModelName.mockReturnValue('test-model');\n65:   });\n66: \n67:   afterEach(() => {\n68:     database.close();\n69:     if (previousFlag === undefined) {\n70:       delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n71:     } else {\n72:       process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL = previousFlag;\n73:     }\n74:   });\n75: \n76:   it('is default-off and does not create trigger embedding rows', async () => {\n77:     insertMemory(database, 1, ['save context']);\n78: \n79:     const result = await runTriggerEmbeddingBackfill(database);\n80: \n81:     const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n82:     expect(result).toMatchObject({ enabled: false, status: 'skipped_default_off' });\n83:     expect(derivedCount.count).toBe(0);\n84:     expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n85:   });\n86: \n87:   it('backfills ready rows once and re-runs without duplicate rows', async () => {\n88:     insertMemory(database, 1, ['save context', 'save the current state']);\n89: \n90:     const first = await runTriggerEmbeddingBackfill(database, { enabled: true });\n91:     const second = await runTriggerEmbeddingBackfill(database, { enabled: true });\n92: \n93:     const rows = database.prepare(`\n94:       SELECT memory_id, embedding_status, profile_key, input_kind, model_id, dimensions\n95:       FROM memory_trigger_embeddings\n96:       ORDER BY phrase_hash\n97:     `).all() as Array<{\n98:       memory_id: number;\n99:       embedding_status: string;\n100:       profile_key: string;\n101:       input_kind: string;\n102:       model_id: string;\n103:       dimensions: number;\n104:     }>;\n105:     const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n106: \n107:     expect(first).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 2, readyRows: 2, generated: 2 });\n108:     expect(second).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 0, readyRows: 0, generated: 0 });\n109:     expect(rows).toHaveLength(2);\n110:     expect(rows).toEqual(rows.map((row) => ({\n111:       ...row,\n112:       memory_id: 1,\n113:       embedding_status: 'ready',\n114:       profile_key: 'test-model:3',\n115:       input_kind: 'document',\n116:       model_id: 'test-model',\n117:       dimensions: 3,\n118:     })));\n119:     expect(cacheCount.count).toBe(2);\n120:     expect(embeddingMocks.generateDocumentEmbedding).toHaveBeenCalledTimes(2);\n121:   });\n122: \n123:   it('does not mark a row ready when the cache store fails', async () => {\n124:     insertMemory(database, 1, ['save context']);\n125:     database.exec(`\n126:       CREATE TRIGGER fail_embedding_cache_insert\n127:       BEFORE INSERT ON embedding_cache\n128:       BEGIN\n129:         SELECT RAISE(ABORT, 'store failed');\n130:       END;\n131:     `);\n132: \n133:     const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n134: \n135:     const row = database.prepare(`\n136:       SELECT embedding_status, failure_reason\n137:       FROM memory_trigger_embeddings\n138:       WHERE memory_id = 1\n139:     `).get() as { embedding_status: string; failure_reason: string | null };\n140:     const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n141: \n142:     expect(result).toMatchObject({ enabled: true, status: 'complete', pendingRows: 1, readyRows: 0, failedRows: 1 });\n143:     expect(row.embedding_status).toBe('failed');\n144:     expect(row.failure_reason).toContain('store failed');\n145:     expect(cacheCount.count).toBe(0);\n146:   });\n147: \n148:   // Returns false for the first `n` calls, then true. Lets a test cancel at a\n149:   // precise loop boundary (the cancel check sits at the top of each chunk/row).\n150:   function cancelAfter(n: number): () => boolean {\n151:     let calls = 0;\n152:     return () => ++calls > n;\n153:   }\n154: \n155:   it('cancels before any phrase sync when isCancelled is immediately true', async () => {\n156:     for (let id = 1; id <= 300; id++) {\n157:       insertMemory(database, id, [`trigger phrase ${id}`]);\n158:     }\n159: \n160:     const result = await runTriggerEmbeddingBackfill(database, {\n161:       enabled: true,\n162:       isCancelled: cancelAfter(0),\n163:     });\n164: \n165:     const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n166:     expect(result.status).toBe('cancelled');\n167:     expect(derivedCount.count).toBe(0);\n168:     expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n169:   });\n170: \n171:   it('cancels at a chunk boundary, leaving a partial sync and never reaching embedding generation', async () => {\n172:     // 300 rows span two 200-row phrase-sync chunks. Cancelling on the second chunk\n173:     // check proves the corpus is processed in self-contained chunks (whole-corpus\n174:     // atomicity would leave 0 or 300, never a clean chunk-sized partial).\n175:     for (let id = 1; id <= 300; id++) {\n176:       insertMemory(database, id, [`trigger phrase ${id}`]);\n177:     }\n178: \n179:     const result = await runTriggerEmbeddingBackfill(database, {\n180:       enabled: true,\n181:       isCancelled: cancelAfter(1),\n182:     });\n183: \n184:     const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n185:     expect(result.status).toBe('cancelled');\n186:     expect(derivedCount.count).toBe(200);\n187:     expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n188:   });\n189: \n190:   it('yields the event loop during a multi-chunk backfill so concurrent work can run', async () => {\n191:     for (let id = 1; id <= 500; id++) {\n192:       insertMemory(database, id, [`trigger phrase ${id}`]);\n193:     }\n194: \n195:     // A competing macrotask loop: it can only advance if the backfill releases the\n196:     // event loop. With a single blocking transaction it would never tick until the\n197:     // backfill returned; chunk-and-yield lets it interleave.\n198:     let ticks = 0;\n199:     let running = true;\n200:     const tick = (): void => {\n201:       if (running) {\n202:         ticks += 1;\n203:         setImmediate(tick);\n204:       }\n205:     };\n206:     setImmediate(tick);\n207: \n208:     const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n209:     running = false;\n210: \n211:     // 500 phrases exceed the default per-run limit, so a healthy run reports\n212:     // complete_with_pending; either success value proves it was not cancelled/failed.\n213:     expect(['complete', 'complete_with_pending']).toContain(result.status);\n214:     expect(ticks).toBeGreaterThan(0);\n215:   });\n216: });\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport {\n  createSchema,\n  ensureSchemaVersion,\n} from '../lib/search/vector-index-schema';\nimport { runTriggerEmbeddingBackfill } from '../lib/search/trigger-embedding-backfill';\n\nconst embeddingMocks = vi.hoisted(() => ({\n  generateDocumentEmbedding: vi.fn(),\n  getEmbeddingProfile: vi.fn(),\n  getEmbeddingDimension: vi.fn(),\n  getModelName: vi.fn(),\n}));\n\nvi.mock('../lib/providers/embeddings', () => embeddingMocks);\n\nfunction createBackfillDatabase(): Database.Database {\n  const database = new Database(':memory:');","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts","text":"import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport {\n  createSchema,\n  ensureSchemaVersion,\n} from '../lib/search/vector-index-schema';\nimport { runTriggerEmbeddingBackfill } from '../lib/search/trigger-embedding-backfill';\n\nconst embeddingMocks = vi.hoisted(() => ({\n  generateDocumentEmbedding: vi.fn(),\n  getEmbeddingProfile: vi.fn(),\n  getEmbeddingDimension: vi.fn(),\n  getModelName: vi.fn(),\n}));\n\nvi.mock('../lib/providers/embeddings', () => embeddingMocks);\n\nfunction createBackfillDatabase(): Database.Database {\n  const database = new Database(':memory:');\n  createSchema(database, {\n    sqlite_vec_available: false,\n    get_embedding_dim: () => 3,\n  });\n  ensureSchemaVersion(database);\n  return database;\n}\n\nfunction insertMemory(database: Database.Database, id: number, phrases: string[]): void {\n  database.prepare(`\n    INSERT INTO memory_index (\n      id, spec_folder, file_path, title, trigger_phrases,\n      created_at, updated_at, importance_tier, context_type, embedding_status\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    id,\n    'trigger/backfill',\n    `/workspace/trigger/backfill/${id}.md`,\n    `Memory ${id}`,\n    JSON.stringify(phrases),\n    '2026-06-10T00:00:00.000Z',\n    '2026-06-10T00:00:00.000Z',\n    'normal',\n    'implementation',\n    'pending',\n  );\n}\n\ndescribe('trigger embedding backfill', () => {\n  let database: Database.Database;\n  let previousFlag: string | undefined;\n\n  beforeEach(() => {\n    previousFlag = process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n    delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n    database = createBackfillDatabase();\n    embeddingMocks.generateDocumentEmbedding.mockReset();\n    embeddingMocks.generateDocumentEmbedding.mockResolvedValue(new Float32Array([0.1, 0.2, 0.3]));\n    embeddingMocks.getEmbeddingProfile.mockReset();\n    embeddingMocks.getEmbeddingProfile.mockReturnValue({ provider: 'test', model: 'test-model', dim: 3 });\n    embeddingMocks.getEmbeddingDimension.mockReset();\n    embeddingMocks.getEmbeddingDimension.mockReturnValue(3);\n    embeddingMocks.getModelName.mockReset();\n    embeddingMocks.getModelName.mockReturnValue('test-model');\n  });\n\n  afterEach(() => {\n    database.close();\n    if (previousFlag === undefined) {\n      delete process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL;\n    } else {\n      process.env.SPECKIT_TRIGGER_EMBEDDING_BACKFILL = previousFlag;\n    }\n  });\n\n  it('is default-off and does not create trigger embedding rows', async () => {\n    insertMemory(database, 1, ['save context']);\n\n    const result = await runTriggerEmbeddingBackfill(database);\n\n    const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n    expect(result).toMatchObject({ enabled: false, status: 'skipped_default_off' });\n    expect(derivedCount.count).toBe(0);\n    expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n  });\n\n  it('backfills ready rows once and re-runs without duplicate rows', async () => {\n    insertMemory(database, 1, ['save context', 'save the current state']);\n\n    const first = await runTriggerEmbeddingBackfill(database, { enabled: true });\n    const second = await runTriggerEmbeddingBackfill(database, { enabled: true });\n\n    const rows = database.prepare(`\n      SELECT memory_id, embedding_status, profile_key, input_kind, model_id, dimensions\n      FROM memory_trigger_embeddings\n      ORDER BY phrase_hash\n    `).all() as Array<{\n      memory_id: number;\n      embedding_status: string;\n      profile_key: string;\n      input_kind: string;\n      model_id: string;\n      dimensions: number;\n    }>;\n    const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n\n    expect(first).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 2, readyRows: 2, generated: 2 });\n    expect(second).toMatchObject({ enabled: true, status: 'complete', phrasesSeen: 2, pendingRows: 0, readyRows: 0, generated: 0 });\n    expect(rows).toHaveLength(2);\n    expect(rows).toEqual(rows.map((row) => ({\n      ...row,\n      memory_id: 1,\n      embedding_status: 'ready',\n      profile_key: 'test-model:3',\n      input_kind: 'document',\n      model_id: 'test-model',\n      dimensions: 3,\n    })));\n    expect(cacheCount.count).toBe(2);\n    expect(embeddingMocks.generateDocumentEmbedding).toHaveBeenCalledTimes(2);\n  });\n\n  it('does not mark a row ready when the cache store fails', async () => {\n    insertMemory(database, 1, ['save context']);\n    database.exec(`\n      CREATE TRIGGER fail_embedding_cache_insert\n      BEFORE INSERT ON embedding_cache\n      BEGIN\n        SELECT RAISE(ABORT, 'store failed');\n      END;\n    `);\n\n    const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n\n    const row = database.prepare(`\n      SELECT embedding_status, failure_reason\n      FROM memory_trigger_embeddings\n      WHERE memory_id = 1\n    `).get() as { embedding_status: string; failure_reason: string | null };\n    const cacheCount = database.prepare('SELECT COUNT(*) AS count FROM embedding_cache').get() as { count: number };\n\n    expect(result).toMatchObject({ enabled: true, status: 'complete', pendingRows: 1, readyRows: 0, failedRows: 1 });\n    expect(row.embedding_status).toBe('failed');\n    expect(row.failure_reason).toContain('store failed');\n    expect(cacheCount.count).toBe(0);\n  });\n\n  // Returns false for the first `n` calls, then true. Lets a test cancel at a\n  // precise loop boundary (the cancel check sits at the top of each chunk/row).\n  function cancelAfter(n: number): () => boolean {\n    let calls = 0;\n    return () => ++calls > n;\n  }\n\n  it('cancels before any phrase sync when isCancelled is immediately true', async () => {\n    for (let id = 1; id <= 300; id++) {\n      insertMemory(database, id, [`trigger phrase ${id}`]);\n    }\n\n    const result = await runTriggerEmbeddingBackfill(database, {\n      enabled: true,\n      isCancelled: cancelAfter(0),\n    });\n\n    const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n    expect(result.status).toBe('cancelled');\n    expect(derivedCount.count).toBe(0);\n    expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n  });\n\n  it('cancels at a chunk boundary, leaving a partial sync and never reaching embedding generation', async () => {\n    // 300 rows span two 200-row phrase-sync chunks. Cancelling on the second chunk\n    // check proves the corpus is processed in self-contained chunks (whole-corpus\n    // atomicity would leave 0 or 300, never a clean chunk-sized partial).\n    for (let id = 1; id <= 300; id++) {\n      insertMemory(database, id, [`trigger phrase ${id}`]);\n    }\n\n    const result = await runTriggerEmbeddingBackfill(database, {\n      enabled: true,\n      isCancelled: cancelAfter(1),\n    });\n\n    const derivedCount = database.prepare('SELECT COUNT(*) AS count FROM memory_trigger_embeddings').get() as { count: number };\n    expect(result.status).toBe('cancelled');\n    expect(derivedCount.count).toBe(200);\n    expect(embeddingMocks.generateDocumentEmbedding).not.toHaveBeenCalled();\n  });\n\n  it('yields the event loop during a multi-chunk backfill so concurrent work can run', async () => {\n    for (let id = 1; id <= 500; id++) {\n      insertMemory(database, id, [`trigger phrase ${id}`]);\n    }\n\n    // A competing macrotask loop: it can only advance if the backfill releases the\n    // event loop. With a single blocking transaction it would never tick until the\n    // backfill returned; chunk-and-yield lets it interleave.\n    let ticks = 0;\n    let running = true;\n    const tick = (): void => {\n      if (running) {\n        ticks += 1;\n        setImmediate(tick);\n      }\n    };\n    setImmediate(tick);\n\n    const result = await runTriggerEmbeddingBackfill(database, { enabled: true });\n    running = false;\n\n    // 500 phrases exceed the default per-run limit, so a healthy run reports\n    // complete_with_pending; either success value proves it was not cancelled/failed.\n    expect(['complete', 'complete_with_pending']).toContain(result.status);\n    expect(ticks).toBeGreaterThan(0);\n  });\n});","lineStart":1,"lineEnd":216,"totalLines":216,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/trigger-embedding-backfill.vitest.ts","time":{"start":1781716676087,"end":1781716676090}},"id":"prt_ed696ec76001nv58lyHQ9VDecK","sessionID":"ses_12969ccceffeNZhLAWy8uWT1Wq","messageID":"msg_ed696d7f8001JCdegtKjkzzFel"}}
