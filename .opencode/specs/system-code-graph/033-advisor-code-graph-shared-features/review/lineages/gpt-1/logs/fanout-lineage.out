 }\n1120:     importedBy.set(edge.importedFilePath, importers);\n1121:   }\n1122: \n1123:   const affectedByFile = new Map<string, { depth: number; why_included?: BlastRadiusWhyIncluded }>();\n1124:   const normalizedSources = [...new Set(sourceFiles)];\n1125:   let depthTruncated = false;\n1126:   let overflowed = false;\n1127: \n1128:   const buildWhyIncluded = (\n1129:     depth: number,\n1130:     path: ReadonlyArray<GraphBfsPathStep<string, BlastRadiusDependency>>,\n1131:     truncationReason: BlastRadiusWhyIncluded['truncationReason'],\n1132:   ): BlastRadiusWhyIncluded => {\n1133:     const edgeChain = path.map((step) => ({\n1134:       fromFile: step.payload.importedFilePath,\n1135:       toFile: step.payload.importerFilePath,\n1136:       edgeType: 'IMPORTS' as const,\n1137:       confidence: step.payload.confidence,\n1138:     }));\n1139:     const confidence = edgeChain.reduce(\n1140:       (minimum, step) => Math.min(minimum, step.confidence),\n1141:       edgeChain.length > 0 ? 1 : 1,\n1142:     );\n1143:     return {\n1144:       depth,\n1145:       edgeChain,\n1146:       confidence,\n1147:       ambiguous: ambiguityCandidates.length > 0,\n1148:       truncationReason,\n1149:     };\n1150:   };\n1151: \n1152:   for (const sourceFile of normalizedSources) {\n1153:     const traversal = traverseGraphBfs<string, BlastRadiusDependency, BlastRadiusAffectedFile>({\n1154:       startIds: [sourceFile],\n1155:       maxDepth,\n1156:       preVisitedIds: [sourceFile],\n1157:       visitTiming: 'enqueue',\n1158:       inspectDepthBoundary: true,\n1159:       getNeighbors: (item) => [...(importedBy.get(item.id) ?? [])]\n1160:         .sort((left, right) => left.importerFilePath.localeCompare(right.importerFilePath))\n1161:         .map((edge) => ({\n1162:           id: edge.importerFilePath,\n1163:           payload: edge,\n1164:         })),\n1165:       mapResult: (visit) => normalizedSources.includes(visit.id)\n1166:         ? null\n1167:         : {\n1168:           filePath: visit.id,\n1169:           depth: visit.depth,\n1170:           ...(includeTrace\n1171:             ? { why_included: buildWhyIncluded(visit.depth, visit.path, null) }\n1172:             : {}),\n1173:         },\n1174:     });\n1175: \n1176:     depthTruncated ||= traversal.depthTruncated;\n1177:     const maxDepthTruncatedFrom = new Set(traversal.truncated.map((entry) => entry.fromId));\n1178:     for (const affectedFile of traversal.results.map((entry) => entry.value)) {\n1179:       if (includeTrace && affectedFile.why_included && maxDepthTruncatedFrom.has(affectedFile.filePath)) {\n1180:         affectedFile.why_included = {\n1181:           ...affectedFile.why_included,\n1182:           truncationReason: 'max_depth',\n1183:         };\n1184:       }\n1185:       const previous = affectedByFile.get(affectedFile.filePath);\n1186:       if (previous === undefined || affectedFile.depth < previous.depth) {\n1187:         affectedByFile.set(affectedFile.filePath, {\n1188:           depth: affectedFile.depth,\n1189:           ...(affectedFile.why_included ? { why_included: affectedFile.why_included } : {}),\n1190:         });\n1191:       }\n1192:     }\n1193:   }\n1194: \n1195:   // Detect true overflow by comparing the full traversal size against `limit`\n1196:   // BEFORE slicing. Previously `affectedFiles.length >= limit`\n1197:   // false-positived whenever the reachable set happened to equal `limit`\n1198:   // exactly. We over-collect (`limit + 1` semantically — here the whole\n1199:   // BFS frontier is already in `affectedByFile`) and slice down only after\n1200:   // recording overflow.\n1201:   const totalAffectedBeforeSlice = affectedByFile.size;\n1202:   let affectedFiles = [...affectedByFile.entries()]\n1203:     .map(([filePath, entry]) => ({\n1204:       filePath,\n1205:       depth: entry.depth,\n1206:       ...(entry.why_included ? { why_included: entry.why_included } : {}),\n1207:     }))\n1208:     .sort((left, right) => left.depth - right.depth || left.filePath.localeCompare(right.filePath))\n1209:     .slice(0, limit);\n1210:   overflowed = totalAffectedBeforeSlice > limit;\n1211:   if (includeTrace && overflowed && affectedFiles.length > 0) {\n1212:     const lastIncluded = affectedFiles[affectedFiles.length - 1];\n1213:     if (lastIncluded.why_included && lastIncluded.why_included.truncationReason == null) {\n1214:       lastIncluded.why_included = {\n1215:         ...lastIncluded.why_included,\n1216:         truncationReason: 'result_limit',\n1217:       };\n1218:     }\n1219:   }\n1220:   const breadcrumbByFile = new Map(\n1221:     buildHotFileBreadcrumbs([\n1222:       ...normalizedSources,\n1223:       ...affectedFiles.map((entry) => entry.filePath),\n1224:     ]).map((entry) => [entry.filePath, entry.hotFileBreadcrumb]),\n1225:   );\n1226:   affectedFiles = affectedFiles.map((entry) => ({\n1227:     ...entry,\n1228:     ...(breadcrumbByFile.get(entry.filePath) ? { hotFileBreadcrumb: breadcrumbByFile.get(entry.filePath) } : {}),\n1229:   }));\n1230: \n1231:   const seedNodes = normalizedSources.map((filePath) => ({\n1232:     filePath,\n1233:     depth: 0,\n1234:     isSeed: true,\n1235:     ...(includeTrace\n1236:       ? {\n1237:         why_included: buildWhyIncluded(0, [], null),\n1238:       }\n1239:       : {}),\n1240:     ...(breadcrumbByFile.get(filePath) ? { hotFileBreadcrumb: breadcrumbByFile.get(filePath) } : {}),\n1241:   }));\n1242:   const depthGroups = buildDepthGroups(affectedFiles, maxDepth);\n1243: \n1244:   return {\n1245:     sourceFiles: normalizedSources,\n1246:     nodes: [\n1247:       ...seedNodes,\n1248:       ...affectedFiles,\n1249:     ],\n1250:     affectedFiles,\n1251:     depthGroups,\n1252:     riskLevel: classifyBlastRadiusRisk(depthGroups, ambiguityCandidates),\n1253:     minConfidence,\n1254:     ambiguityCandidates,\n1255:     hotFileBreadcrumbs: [...breadcrumbByFile.entries()].map(([filePath, hotFileBreadcrumb]) => ({\n1256:       filePath,\n12