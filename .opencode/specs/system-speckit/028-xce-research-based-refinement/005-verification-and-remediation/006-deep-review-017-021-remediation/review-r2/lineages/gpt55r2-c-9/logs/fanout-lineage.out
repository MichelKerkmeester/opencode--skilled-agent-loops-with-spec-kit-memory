    ]\n        },\n        {\n          \"memory_id\": 8514,\n          \"spec_folder\": \"system-spec-kit/z_archive/023-hybrid-rag-fusion-refinement\",\n          \"title\": \"Deep Research: Spec Kit Memory Feature Audit & Quality [system-spec-kit/023-hybrid-rag-fusion-refinement/research]\",\n          \"matched_phrases\": [\n            \"deep\",\n            \"research\",\n            \"spec\",\n            \"kit\"\n          ]\n        },\n        {\n          \"memory_id\": 7164,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/087-speckit-deep-analysis\",\n          \"title\": \"Tasks: System-Spec-Ki [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/087-speckit-deep-analysis/tasks]\",\n          \"matched_phrases\": [\n            \"system\",\n            \"spec\",\n            \"kit\",\n            \"deep\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-06-18T06:23:17.075Z\",\n      \"latencyMs\": 1433\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781763795637,"end":1781763797141}},"metadata":{"openai":{"itemId":"fc_0f215627de50185a016a338ecec388819189b097ee9c980650"}},"id":"prt_ed965d7d0001SGl5N0vQypgi6D","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed965c45e001Rn4Ddi9hdt0dxu"}}
