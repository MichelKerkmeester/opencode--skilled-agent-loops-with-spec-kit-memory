{"type":"tool_use","timestamp":1783915553586,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_TyI7uJzskw8mf7FZp66Vepvo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":634,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n634:                fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n635:                candidate_coverage_gate_pass = boolean\n636:                candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n637:                candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n638:                graphless_fallback_gate_pass = boolean\n639:                graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n640:                graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n641:                graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n642:                recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n643:           6. COMBINED STOP RULE:\n644:                a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n645:                b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n646:                     decision = \"BLOCKED\"\n647:                     stop_blocked = true\n648:                     stopReason = \"blockedStop\"\n649:                     # Blocked-stop closure: blockedBy must be string[] per the\n650:                     # published review blocked-stop contract. Extract the `.type`\n651:                     # field from each structured graph blocker; preserve the full\n652:                     # objects in graph_blocker_detail_json for operator inspection.\n653:                     blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n654:                     blocked_by_csv = graph_blockers_csv\n655:                     graph_blocker_detail_json = graph_blockers_json\n656:                     recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n657:                c) if STOP is legal AND graph_decision == \"CONTINUE\":\n658:                     decision = \"CONTINUE\"\n659:                     stop_blocked = false\n660:                     reason = \"graph_convergence_continue\"\n661:                d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n662:         outputs:\n663:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n664:           - reason: \"Human-readable stop reason\"\n665:           - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n666:           - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n667:           - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n668:           - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n669:           - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n670:           - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n671:           - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n672:           - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n673:           - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n674:           - active_p0_count: \"Active P0 finding count at stop-check time\"\n675:           - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n676:           - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n677:           - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n678:           - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n679:           - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n680:           - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n681:           - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n682:           - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n683:           - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n684:           - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n685:           - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n686:           - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n687:           - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n688:           - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n689:           - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n690:           - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n691:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n692:           - graph_signals_json: \"JSON object returned by graph convergence\"\n693:           - graph_blockers_json: \"JSON array of graph blockers\"\n694:           - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n695:           - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n696: \n697:       step_emit_blocked_stop:\n698:         action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n699:         if_blocked:\n700:           append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n701:           log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n702:         if_not_blocked:\n703:           proceed: true\n704: \n705:       step_handle_convergence:\n706:         action: \"Act on convergence decision\"\n707:         if_stop:\n708:           branch_on: \"convergence_mode == 'divergent' AND reason == 'all_dimensions_clean'\"\n709:           if_divergent_eligible:\n710:             eligibility_contract:\n711:               required_decision: \"STOP\"\n712:               eligible_reasons: [all_dimensions_clean]\n713:               excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n714:               fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot. The nine legal-stop gates have already run and remain unchanged.\"\n715:             steps:\n716:               step_prepare_divergent_pivot:\n717:                 action: \"Generate state-grounded read-only review candidates and prepare or resume the pivot transaction\"\n718:                 command: |\n719:                   node --experimental-strip-types --input-type=module <<'EOF'\n720:                   import {\n721:                     buildReviewPivotPreparationInput,\n722:                     renderReviewPivotSeatPrompt,\n723:                   } from './.opencode/skills/system-deep-loop/deep-review/scripts/divergent-review-pivot.ts';\n724:                   import {\n725:                     preparePivotTransaction,\n726:                   } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n727: \n728:                   const input = buildReviewPivotPreparationInput({\n729:                     artifactRoot: '{state_paths.packet_dir}',\n730:                     configPath: '{state_paths.config}',\n731:                     stateLogPath: '{state_paths.state_log}',\n732:                     strategyPath: '{state_paths.strategy}',\n733:                     registryPath: '{state_paths.findings_registry}',\n734:                     currentIteration: Number('{current_iteration}'),\n735:                     maxIterations: Number('{max_iterations}'),\n736:                     triggerReason: '{reason}',\n737:                   });\n738:                   const prepared = await preparePivotTransaction(input);\n739:                   const seatPrompts = prepared.status === 'pending'\n740:                     ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n741:                         seat.id,\n742:                         renderReviewPivotSeatPrompt(seat, prepared.dispatchContext),\n743:                       ]))\n744:                     : {};\n745:                   process.stdout.write(`${JSON.stringify({\n746:                     ...prepared,\n747:                     seatPrompts,\n748:                     boundaryRejections: input.boundaryRejections,\n749:                   })}\\n`);\n750:                   EOF\n751:                 working_directory: \"{repo_root}\"\n752:                 outputs:\n753:                   - pivot_prepare_json: \"The complete parsed JSON result\"\n754:                   - pivot_prepare_status: \"status from the prepare result\"\n755:                   - pivot_id: \"pivotId from the prepare result\"\n756:                   - pivot_paths_json: \"paths from the prepare result as JSON\"\n757:                   - pivot_resumed: \"resumed from the prepare result\"\n758:                   - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n759:                   - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n760:                   - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n761:                   - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n762:                   - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n763:                   - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n764:                   - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n765:                   - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n766:                 short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n767: \n768:               step_dispatch_pivot_seat_001:\n769:                 action: \"Natively dispatch the analytical read-only review direction-selection seat\"\n770:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n771:                 capture_timing: true\n772:                 if_native:\n773:                   dispatch:\n774:                     agent: deep-review\n775:                     model: opus\n776:                     context_source: \"pivot_seat_001_prompt\"\n777:                   wait_for_completion: true\n778:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n779:                 outputs:\n780:                   - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n781:                   - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n782:                   - pivot_seat_001_error_json: \"{name,message} when rejected\"\n783:                   - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n784:                   - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n785:                   - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n786: \n787:               step_record_pivot_seat_001:\n788:                 action: \"Durably record the seat-001 native dispatch outcome\"\n789:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n790:                 command: |\n791:                   node --experimental-strip-types --input-type=module <<'EOF'\n792:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n793:                   const status = '{pivot_seat_001_dispatch_status}';\n794:                   const outcome = status === 'fulfilled'\n795:                     ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n796:                     : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n797:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n798:                   EOF\n799:                 working_directory: \"{repo_root}\"\n800: \n801:               step_dispatch_pivot_seat_002:\n802:                 action: \"Natively dispatch the critical read-only review direction-selection seat\"\n803:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n804:                 capture_timing: true\n805:                 if_native:\n806:                   dispatch:\n807:                     agent: deep-review\n808:                     model: opus\n809:                     context_source: \"pivot_seat_002_prompt\"\n810:                   wait_for_completion: true\n811:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n812:                 outputs:\n813:                   - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n814:                   - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n815:                   - pivot_seat_002_error_json: \"{name,message} when rejected\"\n816:                   - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n817:                   - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n818:                   - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n819: \n820:               step_record_pivot_seat_002:\n821:                 action: \"Durably record the seat-002 native dispatch outcome\"\n822:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n823:                 command: |\n824:                   node --experimental-strip-types --input-type=module <<'EOF'\n825:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n826:                   const status = '{pivot_seat_002_dispatch_status}';\n827:                   const outcome = status === 'fulfilled'\n828:                     ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n829:                     : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n830:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n831:                   EOF\n832:                 working_directory: \"{repo_root}\"\n833: \n834:               step_dispatch_pivot_seat_003:\n835:                 action: \"Natively dispatch the pragmatic read-only review direction-selection seat\"\n836:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n837:                 capture_timing: true\n838:                 if_native:\n839:                   dispatch:\n840:                     agent: deep-review\n841:                     model: opus\n842:                     context_source: \"pivot_seat_003_prompt\"\n843:                   wait_for_completion: true\n844:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n845:                 outputs:\n846:                   - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n847:                   - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n848:                   - pivot_seat_003_error_json: \"{name,message} when rejected\"\n849:                   - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n850:                   - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n851:                   - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n852: \n853:               step_record_pivot_seat_003:\n854:                 action: \"Durably record the seat-003 native dispatch outcome\"\n855:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n856:                 command: |\n857:                   node --experimental-strip-types --input-type=module <<'EOF'\n858:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n859:                   const status = '{pivot_seat_003_dispatch_status}';\n860:                   const outcome = status === 'fulfilled'\n861:                     ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n862:                     : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n863:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n864:                   EOF\n865:                 working_directory: \"{repo_root}\"\n866: \n867:               step_finalize_divergent_pivot:\n868:                 action: \"Finalize the prepared pivot after all missing native seats are durable\"\n869:                 skip_when: \"pivot_prepare_status != 'pending'\"\n870:                 command: |\n871:                   node --experimental-strip-types --input-type=module <<'EOF'\n872:                   import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n873:                   process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n874:                   EOF\n875:                 working_directory: \"{repo_root}\"\n876:                 outputs:\n877:                   - pivot_finalize_json: \"The complete parsed final result\"\n878: \n879:               step_resolve_divergent_pivot_result:\n880:                 action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n881:                 branch_on: \"pivot_prepare_status\"\n882:                 if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n883:                 if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n884: \n885:               step_apply_divergent_pivot_result:\n886:                 action: \"Adopt a successful read-only review direction or fail closed to the existing synthesis path\"\n887:                 branch_on: \"pivot_result.status\"\n888:                 if_completed:\n889:                   set:\n890:                     next_dimension: \"{pivot_result.restoredFocus}\"\n891:                     pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n892:                     saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n893:                   command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder}\"\n894:                   log: \"Divergent review pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n895:                   proceed_to: step_normalize_pause_events\n896:                 if_failed:\n897:                   log: \"Divergent review pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n898:                   skip_to: phase_synthesis\n899:             on_error:\n900:               log: \"Divergent review pivot integration error; failing closed to the existing synthesis path.\"\n901:               skip_to: phase_synthesis\n902:           if_existing_terminal_path:\n903:             log: \"Loop stopping. Reason: {reason}\"\n904:             skip_to: phase_synthesis\n905:         if_blocked:\n906:           log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n907:         if_stuck_recovery:\n908:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n909:           recovery_strategies:\n910:             - \"Change granularity: file-level → function-level → line-level review\"\n911:             - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n912:             - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n913:           pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n914:           set:\n915:             next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n916:             pending_stop_event: \"stuck_recovery\"\n917:             pending_stop_reason: \"stuckRecovery\"\n918:             pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n919:           reset: { stuck_count: 0 }\n920:         if_continue:\n921:           log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n922: \n923:       step_normalize_pause_events:\n924:         action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n925:         if_pending_pause_event:\n926:           append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n927:           message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n928:           reset:\n929:             pending_stop_event: null\n930:             pending_stop_reason: null\n931:             pending_stop_detail: null\n932:           halt: true\n933:         if_pending_stuck_recovery:\n934:           append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n935:           reset:\n936:             pending_stop_event: null\n937:             pending_stop_reason: null\n938:             pending_stop_detail: null\n939:         if_no_pending_event:\n940:           proceed: true\n941: \n942:       step_generate_state_summary:\n943:         action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n944:         generate: |\n945:           STATE SUMMARY (auto-generated):\n946:           Iteration: {current_iteration} of {max_iterations}\n947:           Dimension: {next_dimension}\n948:           Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n949:           Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n950:           Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n951:           {resource_map_prompt_line}\n952:           Coverage Age: {coverage_age}\n953:           Last 2 ratios: {ratio_prev} -> {ratio_latest}\n954:           Stuck count: {stuck_count}\n955:           Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n956: \n957:       step_marker_scan:\n958:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n959:         algorithm: |\n960:           if current_iteration > 1:\n961:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n962:             if file_exists(PREV_PROMPT_PATH):\n963:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n964:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n965:                 log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n966:                 halt with exit code 2\n967:         note: |\n968:           False-positive prevention: only matches when the first line is exactly one of the\n969:           three canonical markers. Markers appearing in comments or body text are ignored.\n970:           True-positive triggers only when a previous iteration's rendered prompt literally\n971:           starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n972: \n973:       step_dispatch_iteration:\n974:         action: \"Dispatch @deep-review agent for one review iteration\"\n975:         resolve_executor:\n976:           source: \"config.executor\"\n977:           loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n978:         pre_dispatch:\n979:           generate_summary: |\n980:             STATE SUMMARY (auto-generated):\n981:             Iteration: {current_iteration} of {max_iterations}\n982:             Dimension: {next_dimension}\n983:             Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n984:             Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n985:             Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n986:             {resource_map_prompt_line}\n987:             Coverage Age: {coverage_age}\n988:             Last 2 ratios: {ratio_prev} -> {ratio_latest}\n989:             Stuck count: {stuck_count}\n990:             Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n991:           render_prompt_pack:\n992:             template_path: \".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n993:             renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n994:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n995:             variables:\n996:               state_summary: \"{state_summary}\"\n997:               current_iteration: \"{current_iteration}\"\n998:               max_iterations: \"{max_iterations}\"\n999:               next_dimension: \"{next_dimension}\"\n1000:               review_target: \"{review_target}\"\n1001:               review_scope_files: \"{review_scope_files}\"\n1002:               p0_count: \"{p0_count}\"\n1003:               p1_count: \"{p1_count}\"\n1004:               p2_count: \"{p2_count}\"\n1005:               pivot_lineage: \"{pivot_lineage}\"\n1006:               saturated_directions: \"{saturated_directions}\"\n1007:               state_paths_config: \"{state_paths.config}\"\n1008:               state_paths_state_log: \"{state_paths.state_log}\"\n1009:               state_paths_findings_registry: \"{state_paths.findings_registry}\"\n1010:               state_paths_strategy: \"{state_paths.strategy}\"\n1011:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n1012:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n1013:         pre_dispatch_audit:\n1014:           skip_when: \"config.executor.kind == 'native'\"\n1015:           call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n1016:           args:\n1017:             stateLogPath: \"{state_paths.state_log}\"\n1018:             executor: \"{config.executor}\"\n1019:             iteration: \"{current_iteration}\"\n1020:         branch_on: \"config.executor.kind\"\n1021:         if_native:\n1022:           dispatch:\n1023:             agent: deep-review\n1024:             model: opus\n1025:             context_source: \"rendered_prompt_pack\"\n1026:           wait_for_completion: true\n1027:         if_cli_copilot:\n1028:           command: |\n1029:             node --experimental-strip-types --input-type=module <<'EOF'\n1030:             import { readFileSync, writeFileSync } from 'node:fs';\n1031:             import { createHash } from 'node:crypto';\n1032: \n1033:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1034:             import { buildCopilotPromptArg } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n1035: \n1036:             const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n1037:             const prompt = readFileSync(promptPath, 'utf8');\n1038: \n1039:             // Workflow-resolved spec folder is the only legal write authority.\n1040:             // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n1041:             // is the single source of truth for rejecting empty / unresolved\n1042:             // template / whitespace-only / string-coerced empty values. The\n1043:             // YAML hands the raw `{spec_folder}` directly; on rejection the\n1044:             // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n1045:             // enforcement, --allow-all-tools stripped).\n1046:             const specFolderRaw = '{spec_folder}';\n1047:             const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n1048: \n1049:             const baseArgs = [\n1050:               '-p',\n1051:               prompt,\n1052:               '--model',\n1053:               '{config.executor.model}',\n1054:               '--allow-all-tools',\n1055:               '--no-ask-user',\n1056:             ];\n1057: \n1058:             const built = buildCopilotPromptArg({\n1059:               promptPath,\n1060:               prompt,\n1061:               targetAuthority,\n1062:               baseArgv: baseArgs,\n1063:             });\n1064: \n1065:             // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n1066:             // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n1067:             // Write it to disk so the file Copilot reads via @path opens with\n1068:             // the authority block. Without this, recovered/bootstrap folder\n1069:             // mentions inside the file could still anchor the model.\n1070:             if (built.promptFileBody !== undefined) {\n1071:               writeFileSync(promptPath, built.promptFileBody, 'utf8');\n1072:             }\n1073: \n1074:             // Copilot is routed through the audited executor wrapper so it produces\n1075:             // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n1076:             // There is no cli-copilot kind in the executor schema, so it\n1077:             // dispatches as kind:'native' (full env passthrough, no recursion-guard\n1078:             // layer configured for copilot); the receipt still records the real\n1079:             // 'copilot' command + built.argv as facts.\n1080:             const dispatchFacts = {\n1081:               command: 'deep/review',\n1082:               mode: 'review',\n1083:               specFolder: '{spec_folder}',\n1084:               artifactDir: '{state_paths.packet_dir}',\n1085:               iteration: Number('{current_iteration}'),\n1086:               executorKind: '{config.executor.kind}',\n1087:               branchId: '{config.executor.kind}',\n1088:               sessionId: '{session_id}',\n1089:               generation: Number('{generation}'),\n1090:             };\n1091:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1092:             process.exit(\n1093:               runAuditedExecutorCommand({\n1094:                 command: 'copilot',\n1095:                 args: built.argv,\n1096:                 cwd: '{repo_root}',\n1097:                 timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1098:                 stateLogPath: '{state_paths.state_log}',\n1099:                 executor: {\n1100:                   kind: 'native',\n1101:                   model: '{config.executor.model}',\n1102:                   configDir: null,\n1103:                   reasoningEffort: null,\n1104:                   serviceTier: null,\n1105:                   sandboxMode: null,\n1106:                   timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1107:                   governor: null,\n1108:                 },\n1109:                 iteration: Number('{current_iteration}'),\n1110:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1111:                 dispatchId,\n1112:               }),\n1113:             );\n1114:             EOF\n1115:           working_directory: \"{repo_root}\"\n1116:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1117:           wait_for_completion: true\n1118:           notes:\n1119:             - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n1120:             - \"copilot has no stdin support; prompt is positional\"\n1121:             - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n1122:             - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n1123:             - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n1124:             - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n1125:             - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n1126:         if_cli_claude_code:\n1127:           command: |\n1128:             node --experimental-strip-types --input-type=module <<'EOF'\n1129:             import { readFileSync } from 'node:fs';\n1130:             import { createHash } from 'node:crypto';\n1131: \n1132:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1133: \n1134:             const configDir = '{optional_claude_config_dir}';\n1135:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1136:             const executor = {\n1137:               kind: 'cli-claude-code',\n1138:               model: '{config.executor.model}',\n1139:               configDir: configDir || null,\n1140:               reasoningEffort,\n1141:               serviceTier: null,\n1142:               sandboxMode: null,\n1143:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1144:               governor: null,\n1145:             };\n1146:             const args = [\n1147:               '-p',\n1148:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n1149:               '--model',\n1150:               executor.model,\n1151:               '--permission-mode',\n1152:               'acceptEdits',\n1153:               '--output-format',\n1154:               'text',\n1155:             ];\n1156:             if (executor.reasoningEffort) {\n1157:               args.push('--effort', executor.reasoningEffort);\n1158:             }\n1159: \n1160:             // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n1161:             // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n1162:             const parentEnv = { ...process.env };\n1163:             if (configDir) {\n1164:               parentEnv.CLAUDE_CONFIG_DIR = configDir;\n1165:             }\n1166: \n1167:             const dispatchFacts = {\n1168:               command: 'deep/review',\n1169:               mode: 'review',\n1170:               specFolder: '{spec_folder}',\n1171:               artifactDir: '{state_paths.packet_dir}',\n1172:               iteration: Number('{current_iteration}'),\n1173:               executorKind: '{config.executor.kind}',\n1174:               branchId: '{config.executor.kind}',\n1175:               sessionId: '{session_id}',\n1176:               generation: Number('{generation}'),\n1177:             };\n1178:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1179:             process.exit(\n1180:               runAuditedExecutorCommand({\n1181:                 command: 'claude',\n1182:                 args,\n1183:                 cwd: '{repo_root}',\n1184:                 timeoutSeconds: executor.timeoutSeconds,\n1185:                 stateLogPath: '{state_paths.state_log}',\n1186:                 executor,\n1187:                 iteration: Number('{current_iteration}'),\n1188:                 guardContext: { env: parentEnv },\n1189:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1190:                 dispatchId,\n1191:               }),\n1192:             );\n1193:             EOF\n1194:           working_directory: \"{repo_root}\"\n1195:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1196:           wait_for_completion: true\n1197:           render_hint:\n1198:             optional_claude_config_dir: |\n1199:               If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n1200:               Otherwise expand to empty string.\n1201:           notes:\n1202:             - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1203:             - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n1204:             - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n1205:             - \"claude-code supports --effort for reasoning depth\"\n1206:         if_cli_opencode:\n1207:           command: |\n1208:             node --experimental-strip-types --input-type=module <<'EOF'\n1209:             import { readFileSync } from 'node:fs';\n1210:             import { createHash } from 'node:crypto';\n1211: \n1212:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1213: \n1214:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1215:             const executor = {\n1216:               kind: 'cli-opencode',\n1217:               model: '{config.executor.model}',\n1218:               configDir: null,\n1219:               reasoningEffort,\n1220:               serviceTier: null,\n1221:               sandboxMode: null,\n1222:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1223:               governor: null,\n1224:             };\n1225:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1226:             const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n1227:               + '\\n\\n'\n1228:               + promptBody;\n1229:             const args = [\n1230:               'run',\n1231:               '--model',\n1232:               executor.model,\n1233:               '--format',\n1234:               'json',\n1235:               '--dangerously-skip-permissions',\n1236:               '--pure',\n1237:               '--dir',\n1238:               '{repo_root}',\n1239:             ];\n1240:             if (executor.reasoningEffort) {\n1241:               args.push('--variant', executor.reasoningEffort);\n1242:             }\n1243:             args.push(message);\n1244: \n1245:             const dispatchFacts = {\n1246:               command: 'deep/review',\n1247:               mode: 'review',\n1248:               specFolder: '{spec_folder}',\n1249:               artifactDir: '{state_paths.packet_dir}',\n1250:               iteration: Number('{current_iteration}'),\n1251:               executorKind: '{config.executor.kind}',\n1252:               branchId: '{config.executor.kind}',\n1253:               sessionId: '{session_id}',\n1254:               generation: Number('{generation}'),\n1255:             };\n1256:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1257:             process.exit(\n1258:               runAuditedExecutorCommand({\n1259:                 command: 'opencode',\n1260:                 args,\n1261:                 cwd: '{repo_root}',\n1262:                 timeoutSeconds: executor.timeoutSeconds,\n1263:                 stateLogPath: '{state_paths.state_log}',\n1264:                 executor,\n1265:                 iteration: Number('{current_iteration}'),\n1266:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1267:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1268:                 input: '',\n1269:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1270:                 dispatchId,\n1271:               }),\n1272:             );\n1273:             EOF\n1274:           working_directory: \"{repo_root}\"\n1275:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1276:           wait_for_completion: true\n1277:           notes:\n1278:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1279:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n1280:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1281:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1282:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1283:             - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1284:         post_dispatch_validate:\n1285:           validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1286:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1287:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1288:           assert_exists: \"{state_paths.iteration_pattern}\"\n1289:           assert_appended: \"{state_paths.state_log}\"\n1290:           assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n1291:           route_proof:\n1292:             mode: review\n1293:             target_agent: deep-review\n1294:             agent_definition_loaded: true\n1295:             resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n1296:           dispatchReceipt:\n1297:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1298:             dispatchId: \"review-i{current_iteration}-g{generation}\"\n1299:           assert_canonical_type: \"iteration\"\n1300:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1301:           assert_delta_file_has_iteration_record: true\n1302:           failure_reasons:\n1303:             - iteration_file_missing\n1304:             - iteration_file_empty\n1305:             - jsonl_not_appended\n1306:             - jsonl_missing_fields\n1307:             - jsonl_parse_error\n1308:             - jsonl_wrong_type\n1309:             - delta_file_missing\n1310:             - delta_file_empty\n1311:             - delta_file_missing_iteration_record\n1312:             - executor_missing\n1313:             - dispatch_failure_logged\n1314:             - v2_missing_ledger\n1315:             - v2_uncited_ledger_row\n1316:             - v2_broken_linked_finding\n1317:             - v2_shallow_finding_details\n1318:             - delta_iteration_id_mismatch\n1319:             - state_delta_iteration_mismatch\n1320:             - route_proof_missing\n1321:             - route_proof_mismatch\n1322:           warning_surface:\n1323:             source: \"result.warnings\"\n1324:             action: \"emit schema_advisory canonical conflict event\"\n1325:             severity: \"advisory\"\n1326:             event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1327:             note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n1328:           on_failure:\n1329:             action: \"emit schema_mismatch canonical conflict event\"\n1330:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n1331:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1332:         record_executor_audit:\n1333:           skip_when: \"config.executor.kind == 'native'\"\n1334:           target: \"{state_paths.state_log}\"\n1335:           field: \"executor\"\n1336:           value:\n1337:             kind: \"{config.executor.kind}\"\n1338:             model: \"{config.executor.model}\"\n1339:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1340:             serviceTier: \"{config.executor.serviceTier}\"\n1341: \n1342:       step_evaluate_results:\n1343:         action: \"Verify iteration outputs and extract metrics\"\n1344:         verify:\n1345:           - file_exists: \"{state_paths.iteration_pattern}\"\n1346:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1347:           - strategy_updated: \"Strategy.md has been modified\"\n1348:         extract:\n1349:           - newFindingsRatio: \"From latest JSONL iteration record\"\n1350:           - findings_count: \"From latest JSONL iteration record\"\n1351:           - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n1352:           - dimensions: \"From latest JSONL iteration record\"\n1353:           - files_reviewed: \"From latest JSONL iteration record\"\n1354:           - status: \"From latest JSONL iteration record\"\n1355:           - reviewed_artifacts: \"From latest JSONL iteration record\"\n1356:           - traceability_checks: \"From latest JSONL iteration record when present\"\n1357:         on_missing_outputs:\n1358:           action: \"Mark iteration as 'error', continue to next\"\n1359:           # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n1360:           # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1361:           append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n1362: \n1363:       step_post_iteration_claim_adjudication:\n1364:         action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n1365:         verify:\n1366:           - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n1367:           - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n1368:           - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n1369:         on_pass:\n1370:           set:\n1371:             claim_adjudication_passed: true\n1372:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1373:           log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n1374:         on_fail:\n1375:           action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n1376:           set:\n1377:             claim_adjudication_passed: false\n1378:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1379:           log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n1380: \n1381:       step_reduce_review_state:\n1382:         action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n1383:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder}\"\n1384:         read:\n1385:           - \"{state_paths.state_log}\"\n1386:           - \"{state_paths.iteration_pattern}\"\n1387:           - \"{state_paths.findings_registry}\"\n1388:           - \"{state_paths.strategy}\"\n1389:         write:\n1390:           - \"{state_paths.findings_registry}\"\n1391:           - \"{state_paths.dashboard}\"\n1392:           - \"{state_paths.strategy}\"\n1393:         failure_modes:\n1394:           malformed_delta: \"skip + warn\"\n1395:           missing_iteration_file: \"no-op + error\"\n1396:           schema_mismatch: \"reject + conflict event\"\n1397:         guarantee: \"Idempotent for identical inputs\"\n1398:         note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n1399: \n1400:       step_graph_upsert:\n\n(Output capped at 50 KB. Showing lines 634-1400. Use offset=1401 to continue.)\n</content>","metadata":{"preview":"               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n          6. COMBINED STOP RULE:\n               a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n               b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n                    decision = \"BLOCKED\"\n                    stop_blocked = true\n                    stopReason = \"blockedStop\"\n                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n          6. COMBINED STOP RULE:\n               a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n               b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n                    decision = \"BLOCKED\"\n                    stop_blocked = true\n                    stopReason = \"blockedStop\"\n                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n                    blocked_by_csv = graph_blockers_csv\n                    graph_blocker_detail_json = graph_blockers_json\n                    recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n               c) if STOP is legal AND graph_decision == \"CONTINUE\":\n                    decision = \"CONTINUE\"\n                    stop_blocked = false\n                    reason = \"graph_convergence_continue\"\n               d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n          - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n          - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n          - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n          - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n          - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n          - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n          - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n          - active_p0_count: \"Active P0 finding count at stop-check time\"\n          - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n          - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n          - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n          - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n          - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n          - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n          - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:\n        action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n        if_blocked:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          branch_on: \"convergence_mode == 'divergent' AND reason == 'all_dimensions_clean'\"\n          if_divergent_eligible:\n            eligibility_contract:\n              required_decision: \"STOP\"\n              eligible_reasons: [all_dimensions_clean]\n              excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n              fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot. The nine legal-stop gates have already run and remain unchanged.\"\n            steps:\n              step_prepare_divergent_pivot:\n                action: \"Generate state-grounded read-only review candidates and prepare or resume the pivot transaction\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import {\n                    buildReviewPivotPreparationInput,\n                    renderReviewPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-review/scripts/divergent-review-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildReviewPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.findings_registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),\n                    triggerReason: '{reason}',\n                  });\n                  const prepared = await preparePivotTransaction(input);\n                  const seatPrompts = prepared.status === 'pending'\n                    ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n                        seat.id,\n                        renderReviewPivotSeatPrompt(seat, prepared.dispatchContext),\n                      ]))\n                    : {};\n                  process.stdout.write(`${JSON.stringify({\n                    ...prepared,\n                    seatPrompts,\n                    boundaryRejections: input.boundaryRejections,\n                  })}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_prepare_json: \"The complete parsed JSON result\"\n                  - pivot_prepare_status: \"status from the prepare result\"\n                  - pivot_id: \"pivotId from the prepare result\"\n                  - pivot_paths_json: \"paths from the prepare result as JSON\"\n                  - pivot_resumed: \"resumed from the prepare result\"\n                  - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n                  - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n                  - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n                  - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n                  - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n                  - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n                  - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n                  - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n                short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n\n              step_dispatch_pivot_seat_001:\n                action: \"Natively dispatch the analytical read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_001_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n                outputs:\n                  - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_001_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_001:\n                action: \"Durably record the seat-001 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_001_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_002:\n                action: \"Natively dispatch the critical read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_002_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n                outputs:\n                  - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_002_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_002:\n                action: \"Durably record the seat-002 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_002_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_003:\n                action: \"Natively dispatch the pragmatic read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_003_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n                outputs:\n                  - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_003_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_003:\n                action: \"Durably record the seat-003 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_003_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_finalize_divergent_pivot:\n                action: \"Finalize the prepared pivot after all missing native seats are durable\"\n                skip_when: \"pivot_prepare_status != 'pending'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_finalize_json: \"The complete parsed final result\"\n\n              step_resolve_divergent_pivot_result:\n                action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n                branch_on: \"pivot_prepare_status\"\n                if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n                if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n\n              step_apply_divergent_pivot_result:\n                action: \"Adopt a successful read-only review direction or fail closed to the existing synthesis path\"\n                branch_on: \"pivot_result.status\"\n                if_completed:\n                  set:\n                    next_dimension: \"{pivot_result.restoredFocus}\"\n                    pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n                    saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n                  command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder}\"\n                  log: \"Divergent review pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n                  proceed_to: step_normalize_pause_events\n                if_failed:\n                  log: \"Divergent review pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n                  skip_to: phase_synthesis\n            on_error:\n              log: \"Divergent review pivot integration error; failing closed to the existing synthesis path.\"\n              skip_to: phase_synthesis\n          if_existing_terminal_path:\n            log: \"Loop stopping. Reason: {reason}\"\n            skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:\n            next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n            pending_stop_event: \"stuck_recovery\"\n            pending_stop_reason: \"stuckRecovery\"\n            pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n\n      step_normalize_pause_events:\n        action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n        if_pending_pause_event:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n          halt: true\n        if_pending_stuck_recovery:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n        if_no_pending_event:\n          proceed: true\n\n      step_generate_state_summary:\n        action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n        generate: |\n          STATE SUMMARY (auto-generated):\n          Iteration: {current_iteration} of {max_iterations}\n          Dimension: {next_dimension}\n          Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n          Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n          Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n          {resource_map_prompt_line}\n          Coverage Age: {coverage_age}\n          Last 2 ratios: {ratio_prev} -> {ratio_latest}\n          Stuck count: {stuck_count}\n          Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch @deep-review agent for one review iteration\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Iteration: {current_iteration} of {max_iterations}\n            Dimension: {next_dimension}\n            Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n            Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n            Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n            {resource_map_prompt_line}\n            Coverage Age: {coverage_age}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest}\n            Stuck count: {stuck_count}\n            Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n          render_prompt_pack:\n            template_path: \".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_dimension: \"{next_dimension}\"\n              review_target: \"{review_target}\"\n              review_scope_files: \"{review_scope_files}\"\n              p0_count: \"{p0_count}\"\n              p1_count: \"{p1_count}\"\n              p2_count: \"{p2_count}\"\n              pivot_lineage: \"{pivot_lineage}\"\n              saturated_directions: \"{saturated_directions}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_findings_registry: \"{state_paths.findings_registry}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.kind\"\n        if_native:\n          dispatch:\n            agent: deep-review\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_copilot:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync, writeFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n            import { buildCopilotPromptArg } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n\n            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n            const prompt = readFileSync(promptPath, 'utf8');\n\n            // Workflow-resolved spec folder is the only legal write authority.\n            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n            // is the single source of truth for rejecting empty / unresolved\n            // template / whitespace-only / string-coerced empty values. The\n            // YAML hands the raw `{spec_folder}` directly; on rejection the\n            // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n            // enforcement, --allow-all-tools stripped).\n            const specFolderRaw = '{spec_folder}';\n            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n\n            const baseArgs = [\n              '-p',\n              prompt,\n              '--model',\n              '{config.executor.model}',\n              '--allow-all-tools',\n              '--no-ask-user',\n            ];\n\n            const built = buildCopilotPromptArg({\n              promptPath,\n              prompt,\n              targetAuthority,\n              baseArgv: baseArgs,\n            });\n\n            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n            // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n            // Write it to disk so the file Copilot reads via @path opens with\n            // the authority block. Without this, recovered/bootstrap folder\n            // mentions inside the file could still anchor the model.\n            if (built.promptFileBody !== undefined) {\n              writeFileSync(promptPath, built.promptFileBody, 'utf8');\n            }\n\n            // Copilot is routed through the audited executor wrapper so it produces\n            // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n            // There is no cli-copilot kind in the executor schema, so it\n            // dispatches as kind:'native' (full env passthrough, no recursion-guard\n            // layer configured for copilot); the receipt still records the real\n            // 'copilot' command + built.argv as facts.\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'copilot',\n                args: built.argv,\n                cwd: '{repo_root}',\n                timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                stateLogPath: '{state_paths.state_log}',\n                executor: {\n                  kind: 'native',\n                  model: '{config.executor.model}',\n                  configDir: null,\n                  reasoningEffort: null,\n                  serviceTier: null,\n                  sandboxMode: null,\n                  timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                  governor: null,\n                },\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n            - \"copilot has no stdin support; prompt is positional\"\n            - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n            - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n            - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n            - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n            - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const configDir = '{optional_claude_config_dir}';\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              configDir: configDir || null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              'acceptEdits',\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n            // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n            const parentEnv = { ...process.env };\n            if (configDir) {\n              parentEnv.CLAUDE_CONFIG_DIR = configDir;\n            }\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                guardContext: { env: parentEnv },\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_claude_config_dir: |\n              If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n              Otherwise expand to empty string.\n          notes:\n            - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n            - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          route_proof:\n            mode: review\n            target_agent: deep-review\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"review-i{current_iteration}-g{generation}\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:\n            - iteration_file_missing\n            - iteration_file_empty\n            - jsonl_not_appended\n            - jsonl_missing_fields\n            - jsonl_parse_error\n            - jsonl_wrong_type\n            - delta_file_missing\n            - delta_file_empty\n            - delta_file_missing_iteration_record\n            - executor_missing\n            - dispatch_failure_logged\n            - v2_missing_ledger\n            - v2_uncited_ledger_row\n            - v2_broken_linked_finding\n            - v2_shallow_finding_details\n            - delta_iteration_id_mismatch\n            - state_delta_iteration_mismatch\n            - route_proof_missing\n            - route_proof_mismatch\n          warning_surface:\n            source: \"result.warnings\"\n            action: \"emit schema_advisory canonical conflict event\"\n            severity: \"advisory\"\n            event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n        record_executor_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.kind}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Strategy.md has been modified\"\n        extract:\n          - newFindingsRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n          - dimensions: \"From latest JSONL iteration record\"\n          - files_reviewed: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - reviewed_artifacts: \"From latest JSONL iteration record\"\n          - traceability_checks: \"From latest JSONL iteration record when present\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n          # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n\n      step_post_iteration_claim_adjudication:\n        action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n        verify:\n          - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n          - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n          - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n        on_pass:\n          set:\n            claim_adjudication_passed: true\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n        on_fail:\n          action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n          set:\n            claim_adjudication_passed: false\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n\n      step_reduce_review_state:\n        action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder}\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.iteration_pattern}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        write:\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n        guarantee: \"Idempotent for identical inputs\"\n        note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n\n      step_graph_upsert:","lineStart":634,"lineEnd":1400,"totalLines":1401,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1783915553550,"end":1783915553577}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217c8c8191a77f1f248dc5fdcd"}},"id":"prt_f59a722e6001vVNKAhStYZcYzv","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553586,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_u2OCl5Zs54xQ17FSSMEks9TB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_reducer_registry.md","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_reducer_registry.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Deep Review State Reducer And Registry\"\n3: description: \"Focused reference for reducer ownership, findings registry semantics, fail-closed behavior, and reconstruction rules.\"\n4: trigger_phrases:\n5:   - \"deep review reducer registry\"\n6:   - \"review findings registry\"\n7:   - \"deep review reducer ownership\"\n8:   - \"review state reconstruction\"\n9: importance_tier: important\n10: contextType: implementation\n11: version: 1.11.0.4\n12: ---\n13: \n14: # Deep Review State Reducer And Registry\n15: \n16: The reducer is the single writer for derived review state. Iteration agents append evidence; the reducer reconciles it into registry, dashboard, and strategy views.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: The reducer turns append-only review evidence into the current findings registry, dashboard, and strategy state. It is the authority for derived outputs, not a second source of truth.\n23: \n24: ---\n25: \n26: ## 2. OWNERSHIP\n27: \n28: | Surface | Writer | Rule |\n29: |---------|--------|------|\n30: | JSONL state | Workflow plus validated iteration append | Append-only |\n31: | Findings registry | `scripts/reduce-state.cjs` | Regenerate from JSONL |\n32: | Dashboard | `scripts/reduce-state.cjs` | Regenerate from registry and latest events |\n33: | Strategy machine sections | `scripts/reduce-state.cjs` | Update from coverage and findings |\n34: | Iteration markdown | Review iteration agent | Write-once |\n35: | Review report | Synthesis | Final handoff |\n36: \n37: No agent should hand-edit reducer-owned derived state as the authoritative fix. Repair JSONL or rerun the reducer.\n38: \n39: ---\n40: \n41: ## 3. FINDINGS REGISTRY\n42: \n43: The registry groups findings into:\n44: \n45: - Active findings.\n46: - Resolved findings.\n47: - Repeated findings.\n48: - Blocked or disputed findings.\n49: - Claim-adjudicated severity changes.\n50: \n51: Each active finding needs severity, category, file:line evidence, finding class, content hash, first-seen iteration, and latest-seen iteration.\n52: \n53: ---\n54: \n55: ## 4. FAIL-CLOSED BEHAVIOR\n56: \n57: The reducer must refuse to publish derived state when JSONL is corrupt in strict mode. That protects dashboards and verdict previews from silently losing findings.\n58: \n59: Recovery order:\n60: \n61: 1. Identify the malformed JSONL line.\n62: 2. Repair or remove only the invalid appended record with an audit note.\n63: 3. Re-run the reducer.\n64: 4. Confirm registry and dashboard regenerate from the repaired log.\n65: \n66: ---\n67: \n68: ## 5. RECONSTRUCTION\n69: \n70: When derived files are missing but JSONL and iteration markdown exist:\n71: \n72: 1. Rebuild the registry from JSONL finding details.\n73: 2. Rebuild dashboard metrics from registry and latest convergence events.\n74: 3. Rebuild strategy from completed dimensions and active findings.\n75: 4. Re-run synthesis only after reducer outputs are consistent.\n76: \n77: If JSONL is incomplete but iteration files exist, recovery is manual and must be recorded before release readiness is claimed.\n78: \n79: ---\n80: \n81: ## 6. FINDING DEDUPLICATION\n82: \n83: The reducer deduplicates findings at synthesis time using a two-tier match.\n84: \n85: ### Two-Tier Match\n86: \n87: 1. **PRIMARY: content_hash** = `sha256(file_path + line_range + finding_type + normalized_description_80chars)`\n88:    - `file_path`: repo-relative path of the finding\n89:    - `line_range`: e.g., `\"42\"` or `\"42-56\"`\n90:    - `finding_type`: one of `security`, `correctness`, `performance`, `maintainability`, `test_quality`, `contract_safety`, `removal`\n91:    - `normalized_description_80chars`: first 80 characters of the description, whitespace-collapsed and lowercased\n92: 2. **FALLBACK (legacy records): file:line + normalized_title** - applied when one or both records lack a `content_hash`, preserving existing behavior unchanged.\n93: \n94: ### Synthesis Behavior\n95: \n96: When the same `content_hash` appears across iterations from different dimensions, synthesis collapses them to ONE entry with `dimensions: [<all dimensions that emitted it>]` rather than emitting multiple records. Records without `content_hash` fall back to `file:line + normalized_title`; no migration is required for existing JSONL state.\n97: \n98: ### Emission Requirement\n99: \n100: Every finding emitted into the JSONL delta (`findingDetails[]`) MUST include a `content_hash` field computed per the two-tier match. `reduce-state.cjs` reads this field for synthesis dedup.\n101: \n102: ---\n103: \n104: ## 7. RELATED RESOURCES\n105: \n106: - `scripts/reduce-state.cjs` is the reducer implementation.\n107: - `references/state/state_format.md` defines state records.\n108: - `references/state/state_outputs.md` defines operator-visible outputs.\n109: - `references/convergence/convergence_signals.md` defines STOP fields reducer views display.\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Deep Review State Reducer And Registry\"\ndescription: \"Focused reference for reducer ownership, findings registry semantics, fail-closed behavior, and reconstruction rules.\"\ntrigger_phrases:\n  - \"deep review reducer registry\"\n  - \"review findings registry\"\n  - \"deep review reducer ownership\"\n  - \"review state reconstruction\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.4\n---\n\n# Deep Review State Reducer And Registry\n\nThe reducer is the single writer for derived review state. Iteration agents append evidence; the reducer reconciles it into registry, dashboard, and strategy views.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_reducer_registry.md","text":"---\ntitle: \"Deep Review State Reducer And Registry\"\ndescription: \"Focused reference for reducer ownership, findings registry semantics, fail-closed behavior, and reconstruction rules.\"\ntrigger_phrases:\n  - \"deep review reducer registry\"\n  - \"review findings registry\"\n  - \"deep review reducer ownership\"\n  - \"review state reconstruction\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.4\n---\n\n# Deep Review State Reducer And Registry\n\nThe reducer is the single writer for derived review state. Iteration agents append evidence; the reducer reconciles it into registry, dashboard, and strategy views.\n\n---\n\n## 1. OVERVIEW\n\nThe reducer turns append-only review evidence into the current findings registry, dashboard, and strategy state. It is the authority for derived outputs, not a second source of truth.\n\n---\n\n## 2. OWNERSHIP\n\n| Surface | Writer | Rule |\n|---------|--------|------|\n| JSONL state | Workflow plus validated iteration append | Append-only |\n| Findings registry | `scripts/reduce-state.cjs` | Regenerate from JSONL |\n| Dashboard | `scripts/reduce-state.cjs` | Regenerate from registry and latest events |\n| Strategy machine sections | `scripts/reduce-state.cjs` | Update from coverage and findings |\n| Iteration markdown | Review iteration agent | Write-once |\n| Review report | Synthesis | Final handoff |\n\nNo agent should hand-edit reducer-owned derived state as the authoritative fix. Repair JSONL or rerun the reducer.\n\n---\n\n## 3. FINDINGS REGISTRY\n\nThe registry groups findings into:\n\n- Active findings.\n- Resolved findings.\n- Repeated findings.\n- Blocked or disputed findings.\n- Claim-adjudicated severity changes.\n\nEach active finding needs severity, category, file:line evidence, finding class, content hash, first-seen iteration, and latest-seen iteration.\n\n---\n\n## 4. FAIL-CLOSED BEHAVIOR\n\nThe reducer must refuse to publish derived state when JSONL is corrupt in strict mode. That protects dashboards and verdict previews from silently losing findings.\n\nRecovery order:\n\n1. Identify the malformed JSONL line.\n2. Repair or remove only the invalid appended record with an audit note.\n3. Re-run the reducer.\n4. Confirm registry and dashboard regenerate from the repaired log.\n\n---\n\n## 5. RECONSTRUCTION\n\nWhen derived files are missing but JSONL and iteration markdown exist:\n\n1. Rebuild the registry from JSONL finding details.\n2. Rebuild dashboard metrics from registry and latest convergence events.\n3. Rebuild strategy from completed dimensions and active findings.\n4. Re-run synthesis only after reducer outputs are consistent.\n\nIf JSONL is incomplete but iteration files exist, recovery is manual and must be recorded before release readiness is claimed.\n\n---\n\n## 6. FINDING DEDUPLICATION\n\nThe reducer deduplicates findings at synthesis time using a two-tier match.\n\n### Two-Tier Match\n\n1. **PRIMARY: content_hash** = `sha256(file_path + line_range + finding_type + normalized_description_80chars)`\n   - `file_path`: repo-relative path of the finding\n   - `line_range`: e.g., `\"42\"` or `\"42-56\"`\n   - `finding_type`: one of `security`, `correctness`, `performance`, `maintainability`, `test_quality`, `contract_safety`, `removal`\n   - `normalized_description_80chars`: first 80 characters of the description, whitespace-collapsed and lowercased\n2. **FALLBACK (legacy records): file:line + normalized_title** - applied when one or both records lack a `content_hash`, preserving existing behavior unchanged.\n\n### Synthesis Behavior\n\nWhen the same `content_hash` appears across iterations from different dimensions, synthesis collapses them to ONE entry with `dimensions: [<all dimensions that emitted it>]` rather than emitting multiple records. Records without `content_hash` fall back to `file:line + normalized_title`; no migration is required for existing JSONL state.\n\n### Emission Requirement\n\nEvery finding emitted into the JSONL delta (`findingDetails[]`) MUST include a `content_hash` field computed per the two-tier match. `reduce-state.cjs` reads this field for synthesis dedup.\n\n---\n\n## 7. RELATED RESOURCES\n\n- `scripts/reduce-state.cjs` is the reducer implementation.\n- `references/state/state_format.md` defines state records.\n- `references/state/state_outputs.md` defines operator-visible outputs.\n- `references/convergence/convergence_signals.md` defines STOP fields reducer views display.","lineStart":1,"lineEnd":109,"totalLines":109,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/state/state_reducer_registry.md","time":{"start":1783915553559,"end":1783915553580}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217ca48191880f6fcba263d17e"}},"id":"prt_f59a72315001DVGiG39c1N0rjE","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553586,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_LHZFWnPhAKqQiFCIpHtKC7lR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_jsonl.md","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_jsonl.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review State Log Records\n3: description: JSONL state-log record schemas (config, iteration, event, lineage) and the Review Depth Schema v2 for the deep review loop.\n4: trigger_phrases:\n5:   - \"deep review state jsonl\"\n6:   - \"review jsonl record schemas\"\n7:   - \"review depth schema\"\n8:   - \"review traceability checks\"\n9:   - \"review graph events\"\n10: importance_tier: important\n11: contextType: implementation\n12: version: 1.11.0.5\n13: ---\n14: \n15: # Deep Review State Log Records\n16: \n17: The `deep-review-state.jsonl` log is the append-only source of truth for a review run. This reference documents the config, iteration, event, and lineage record schemas plus the Review Depth Schema (v2) that the reducer consumes.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: ### Purpose\n24: \n25: This reference defines the append-only JSONL records that preserve deep-review run state. It covers config, iteration, event, lineage, graph, verdict, traceability, and Review Depth Schema v2 records so reducers and validators can replay the loop deterministically.\n26: \n27: ### When to Use\n28: \n29: - Validating `deep-review-state.jsonl` shape before changing reducers, dashboards, or workflow emission.\n30: - Debugging malformed state records, blocked-stop events, graph convergence events, or lineage fields.\n31: - Adding or checking Review Depth Schema v2 target selection, search coverage, and ledger fields.\n32: - Confirming which fields are required before writing iteration, synthesis, pause, or recovery events.\n33: \n34: ### Key Sources\n35: \n36: | Source | Purpose |\n37: |--------|---------|\n38: | Config record | Establishes session identity, lineage, thresholds, and spec folder routing. |\n39: | Iteration record | Captures focus, reviewed files, findings, convergence ratios, and graph events. |\n40: | Event records | Persist synthesis, blocked-stop, graph convergence, pause, and stuck-recovery decisions. |\n41: | Review Depth Schema v2 | Adds target selection, search coverage, and ledger proof for deeper review iterations. |\n42: \n43: ---\n44: \n45: ## 2. STATE LOG (DEEP-REVIEW-STATE.JSONL)\n46: \n47: Append-only JSON Lines file. One JSON object per line.\n48: \n49: ### Line 1: Config Record\n50: \n51: ```json\n52: {\"type\":\"config\",\"mode\":\"review\",\"topic\":\"...\",\"reviewTarget\":\"...\",\"sessionId\":\"rvw-...\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":7,\"convergenceThreshold\":0.10,\"createdAt\":\"2026-03-24T14:00:00Z\",\"specFolder\":\"...\"}\n53: ```\n54: \n55: ### Iteration Records\n56: \n57: ```json\n58: {\n59:   \"type\": \"iteration\", \"mode\": \"review\", \"run\": 3, \"status\": \"complete\",\n60:   \"focus\": \"D3 Traceability - skill/runtime alignment\",\n61:   \"dimensions\": [\"traceability\", \"maintainability\"],\n62:   \"filesReviewed\": [\".opencode/skills/system-deep-loop/deep-research/README.md\"],\n63:   \"sessionId\": \"rvw-2026-04-03T12-00-00Z\",\n64:   \"parentSessionId\": null,\n65:   \"lineageMode\": \"resume\",\n66:   \"generation\": 1,\n67:   \"continuedFromRun\": null,\n68:   \"findingsCount\": 4,\n69:   \"findingsSummary\": { \"P0\": 0, \"P1\": 1, \"P2\": 3 },\n70:   \"findingsNew\": { \"P0\": 0, \"P1\": 1, \"P2\": 1 },\n71:   \"findingDetails\": [\n72:     {\n73:       \"id\": \"P1-001\",\n74:       \"severity\": \"P1\",\n75:       \"title\": \"Missing consumer update\",\n76:       \"dimension\": \"correctness\",\n77:       \"file\": \"path/to/file.ts:42\",\n78:       \"evidence\": \"Observed consumer still reads the old field.\",\n79:       \"recommendation\": \"Update the consumer and add verification.\",\n80:       \"disposition\": \"active\",\n81:       \"findingClass\": \"cross-consumer\",\n82:       \"scopeProof\": \"rg evidence covering producers and consumers\",\n83:       \"affectedSurfaceHints\": [\"producer/helper\", \"consumer/status\"]\n84:     }\n85:   ],\n86:   \"newFindingsRatio\": 0.32,\n87:   \"timestamp\": \"2026-03-24T14:30:00Z\", \"durationMs\": 52000\n88: }\n89: ```\n90: \n91: **Required fields:** `type`, `mode`, `run`, `status`, `focus`, `dimensions`, `filesReviewed`, `findingsCount`, `findingsSummary`, `findingsNew`, `findingDetails`, `newFindingsRatio`, `sessionId`, `generation`, `lineageMode`, `timestamp`, `durationMs`\n92: \n93: **Optional fields:** `parentSessionId`, `continuedFromRun`, `findingsRefined`, `findingRefs`, `traceabilityChecks`, `coverage`, `noveltyJustification`, `ruledOut`, `focusTrack`, `scoreEstimate`, `segment`, `convergenceSignals`, `graphEvents`\n94: \n95: | Required Field | Type | Description |\n96: |---------------|------|-------------|\n97: | mode | `\"review\"` | Session mode discriminator |\n98: | dimensions | string[] | Review dimensions addressed this iteration |\n99: | filesReviewed | string[] | Files examined |\n100: | sessionId | string | Current lineage session identifier |\n101: | generation | number | Lineage generation number |\n102: | lineageMode | string | Lifecycle mode used for this run |\n103: | findingsSummary | object | Total active findings: `{ P0, P1, P2 }` |\n104: | findingsNew | object | Net-new findings this iteration: `{ P0, P1, P2 }` |\n105: | findingDetails | array | Active findings with `id`, `severity`, `title`, `dimension`, `file`, `evidence`, `recommendation`, `disposition`, `findingClass`, `scopeProof`, and `affectedSurfaceHints`, use `[]` when there are no findings |\n106: | newFindingsRatio | number | Severity-weighted new findings ratio (0.0-1.0) |\n107: \n108: ### Convergence Signals\n109: \n110: | Signal | Weight | Description |\n111: |--------|--------|-------------|\n112: | rollingAvg | 0.30 | Rolling average of severity-weighted new findings |\n113: | madScore | 0.25 | Noise-floor test against MAD-derived churn |\n114: | dimensionCoverage | 0.45 | Required dimension + protocol coverage stability |\n115: | compositeStop | -- | Weighted stop score (stop if > 0.60) |\n116: \n117: **Severity math:** `refinementMultiplier: 0.5`, `p0OverrideMinRatio: 0.50`, `noFindingsRatio: 0.0`\n118: \n119: ### Graph Events\n120: \n121: The optional `graphEvents` array records coverage graph mutations emitted by a review iteration. The MCP coverage graph handlers (`mcp_server/handlers/coverage-graph/upsert.ts`) consume these events and persist them into `deep-loop-graph.sqlite`, where they become the source of truth for graph-assisted convergence, hotspot saturation, and blocked-stop evidence.\n122: \n123: ```json\n124: {\n125:   \"type\": \"iteration\", \"mode\": \"review\", \"run\": 4, \"status\": \"complete\",\n126:   \"focus\": \"correctness\",\n127:   \"dimensions\": [\"correctness\"],\n128:   \"filesReviewed\": [\"src/api/session.ts\"],\n129:   \"findingsSummary\": { \"P0\": 0, \"P1\": 1, \"P2\": 0 },\n130:   \"findingsNew\": { \"P0\": 0, \"P1\": 1, \"P2\": 0 },\n131:   \"newFindingsRatio\": 0.18,\n132:   \"sessionId\": \"rvw-2026-03-24T10-00-00Z\",\n133:   \"generation\": 1,\n134:   \"lineageMode\": \"new\",\n135:   \"graphEvents\": [\n136:     { \"type\": \"dimension\", \"id\": \"d-correctness\", \"label\": \"correctness\" },\n137:     { \"type\": \"file\", \"id\": \"file-session-ts\", \"label\": \"src/api/session.ts\" },\n138:     { \"type\": \"finding\", \"id\": \"f-001\", \"label\": \"Missing CSRF token check on session POST\" },\n139:     { \"type\": \"evidence\", \"id\": \"ev-001\", \"label\": \"src/api/session.ts:42\" },\n140:     { \"type\": \"edge\", \"id\": \"e-in-dim-f-001\", \"relation\": \"IN_DIMENSION\", \"source\": \"f-001\", \"target\": \"d-correctness\" },\n141:     { \"type\": \"edge\", \"id\": \"e-in-file-f-001\", \"relation\": \"IN_FILE\", \"source\": \"f-001\", \"target\": \"file-session-ts\" },\n142:     { \"type\": \"edge\", \"id\": \"e-evidence-f-001\", \"relation\": \"EVIDENCE_FOR\", \"source\": \"ev-001\", \"target\": \"f-001\" }\n143:   ],\n144:   \"timestamp\": \"2026-03-24T10:12:00Z\",\n145:   \"durationMs\": 51000\n146: }\n147: ```\n148: \n149: #### Event payload shape\n150: \n151: | Field | Type | Required | Description |\n152: |-------|------|----------|-------------|\n153: | type | `\"dimension\"` \\| `\"file\"` \\| `\"finding\"` \\| `\"evidence\"` \\| `\"remediation\"` \\| `\"edge\"` | Yes | Review-loop node kind or the literal `\"edge\"` for relation rows |\n154: | id | string | Yes | Caller-chosen logical id. Must be unique **within** a single `(specFolder, loopType, sessionId)` namespace, see Namespace Rules below |\n155: | label | string | Yes | Human-readable name/caption (dimension, path, finding title, evidence anchor, etc.) |\n156: | relation | `\"COVERS\"` \\| `\"EVIDENCE_FOR\"` \\| `\"CONTRADICTS\"` \\| `\"RESOLVES\"` \\| `\"CONFIRMS\"` \\| `\"ESCALATES\"` \\| `\"IN_DIMENSION\"` \\| `\"IN_FILE\"` | edges only | Review relation type. Required when `type == \"edge\"` |\n157: | source | string | edges only | `id` of the source node inside the current namespace |\n158: | target | string | edges only | `id` of the target node inside the current namespace. Self-loops are rejected by the upsert handler |\n159: | metadata | object | No | Optional free-form metadata persisted alongside the row (e.g. `{ \"hotspot_score\": 2 }`) |\n160: \n161: #### Namespace Rules (REQ-028, REQ-029)\n162: \n163: `graphEvents` entries are scoped by the session that emits them. The coverage graph DB uses a composite primary key of `(spec_folder, loop_type, session_id, id)`, so two independent review sessions in the same spec folder MAY reuse the same logical `id` without collision, each session gets its own row.\n164: \n165: Concrete obligations for producers:\n166: \n167: 1. **Session-local uniqueness**: within one session, an `id` must resolve to exactly one node (or edge) for its entire lifetime. Re-emitting the same `id` is an upsert against the existing row in that session only.\n168: 2. **No cross-session global uniqueness requirement**: callers MUST NOT prefix ids with the session id or random salt to \"avoid collisions\". The DB layer handles namespace isolation. Salting ids only makes provenance harder to read.\n169: 3. **Edge source/target locality**: `source` and `target` in an edge event must name nodes already present in the same namespace. Cross-session edges are not a supported shape.\n170: 4. **Persistence gate**: the reducer refuses to roll graph events forward when a record is missing `sessionId` on the surrounding iteration record, because the DB cannot route the write.\n171: \n172: The collision regression in `.opencode/skills/system-spec-kit/scripts/tests/session-isolation.vitest.ts` (\"shared-ID collisions\" block) exercises this contract directly: two sessions upsert identical node and edge ids, and both rows must survive independently.\n173: \n174: ### Synthesis Event\n175: \n176: ```json\n177: {\n178:   \"type\": \"event\", \"event\": \"synthesis_complete\", \"mode\": \"review\",\n179:   \"totalIterations\": 6, \"verdict\": \"PASS\",\n180:   \"activeP0\": 0, \"activeP1\": 0, \"activeP2\": 2,\n181:   \"dimensionCoverage\": 1.0, \"stopReason\": \"composite_converged\",\n182:   \"timestamp\": \"2026-03-24T15:02:00Z\"\n183: }\n184: ```\n185: \n186: **Required:** `type`, `event`, `mode`, `totalIterations`, `verdict`, `activeP0`, `activeP1`, `activeP2`, `dimensionCoverage`, `stopReason`, `timestamp`\n187: \n188: ### Blocked-Stop Event\n189: \n190: When the review legal-stop decision tree returns `blocked`, append a first-class `blocked_stop` event instead of silently overriding STOP to CONTINUE.\n191: \n192: ```json\n193: {\n194:   \"type\": \"event\",\n195:   \"event\": \"blocked_stop\",\n196:   \"mode\": \"review\",\n197:   \"run\": 4,\n198:   \"blockedBy\": [\"dimensionCoverageGate\", \"p0ResolutionGate\"],\n199:   \"gateResults\": {\n200:     \"convergenceGate\": { \"pass\": true, \"score\": 0.72 },\n201:     \"dimensionCoverageGate\": {\n202:       \"pass\": false,\n203:       \"covered\": [\"correctness\", \"security\"],\n204:       \"missing\": [\"traceability\", \"maintainability\"]\n205:     },\n206:     \"p0ResolutionGate\": { \"pass\": false, \"activeP0\": 1 },\n207:     \"evidenceDensityGate\": { \"pass\": true, \"avgEvidencePerFinding\": 1.5 },\n208:     \"hotspotSaturationGate\": { \"pass\": true },\n209:     \"claimAdjudicationGate\": { \"pass\": true, \"activeP0P1\": 2 },\n210:     \"fixCompletenessReplayGate\": { \"pass\": true, \"securitySensitive\": false, \"requiredRows\": 0, \"passingRows\": 0 },\n211:     \"candidateCoverageGate\": { \"pass\": true, \"searchDebt\": [], \"missing\": [] },\n212:     \"graphlessFallbackGate\": { \"pass\": true, \"mode\": \"graph_available\", \"missing\": [], \"unavailabilityReason\": \"\" }\n213:   },\n214:   \"recoveryStrategy\": \"Cover the missing review dimensions, then resolve the active P0.\",\n215:   \"timestamp\": \"2026-04-11T09:45:00Z\",\n216:   \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n217:   \"generation\": 1\n218: }\n219: ```\n220: \n221: `gateResults` carries the full 9-gate set emitted by `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`: `convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, and `graphlessFallbackGate`. The last two are v2-rollout gates that pass trivially when the review-depth-v2 search path is inactive. See `../convergence/convergence.md` §Section-1 for the authoritative shape.\n222: \n223: **Required:** `type`, `event`, `mode`, `run`, `blockedBy`, `gateResults`, `recoveryStrategy`, `timestamp`, `sessionId`, `generation`\n224: \n225: ### Graph Convergence Event\n226: \n227: Before the inline 3-signal review vote is allowed to finalize STOP, the workflow must append a `graph_convergence` event for the current review lineage.\n228: \n229: ```json\n230: {\n231:   \"type\": \"event\",\n232:   \"event\": \"graph_convergence\",\n233:   \"mode\": \"review\",\n234:   \"run\": 4,\n235:   \"decision\": \"STOP_ALLOWED\",\n236:   \"signals\": {\n237:     \"dimensionCoverage\": 1,\n238:     \"findingStability\": 0.88,\n239:     \"p0ResolutionRate\": 1,\n240:     \"evidenceDensity\": 1.4,\n241:     \"hotspotSaturation\": 0.75\n242:   },\n243:   \"blockers\": [],\n244:   \"timestamp\": \"2026-04-11T09:44:00Z\",\n245:   \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n246:   \"generation\": 1\n247: }\n248: ```\n249: \n250: **Required:** `type`, `event`, `mode`, `run`, `decision`, `signals`, `blockers`, `timestamp`, `sessionId`, `generation`\n251: \n252: **Decision enum:** `CONTINUE`, `STOP_ALLOWED`, `STOP_BLOCKED`\n253: \n254: **Combined-stop rule:** Final STOP is legal only when the inline review convergence decision says STOP and the latest `graph_convergence.decision == \"STOP_ALLOWED\"`. If the latest graph decision is `STOP_BLOCKED`, set `stop_blocked=true`, emit `blocked_stop`, and continue recovery instead of stopping. If the latest graph decision is `CONTINUE`, downgrade the inline STOP candidate to CONTINUE.\n255: \n256: ### Normalized Pause and Recovery Events\n257: \n258: Pause and recovery events MUST use the frozen shared stop-reason enum at emission time:\n259: \n260: `converged`, `maxIterationsReached`, `blockedStop`, `stuckRecovery`, `error`, `manualStop`, `userPaused`\n261: \n262: Raw `paused` and `stuck_recovery` labels are not legal persisted event names in the review JSONL contract. The workflow must rewrite them before appending JSONL rows.\n263: \n264: ```json\n265: {\n266:   \"type\": \"event\",\n267:   \"event\": \"userPaused\",\n268:   \"mode\": \"review\",\n269:   \"stopReason\": \"userPaused\",\n270:   \"reason\": \"sentinel file detected\",\n271:   \"timestamp\": \"2026-04-11T09:32:00Z\",\n272:   \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n273:   \"generation\": 1\n274: }\n275: ```\n276: \n277: ```json\n278: {\n279:   \"type\": \"event\",\n280:   \"event\": \"stuckRecovery\",\n281:   \"mode\": \"review\",\n282:   \"stopReason\": \"stuckRecovery\",\n283:   \"fromIteration\": 5,\n284:   \"strategy\": \"Traceability protocol replay: re-run unresolved core or overlay checks\",\n285:   \"targetDimension\": \"traceability\",\n286:   \"outcome\": \"pending\",\n287:   \"reason\": \"Recovery path activated after repeated no-progress iterations\",\n288:   \"timestamp\": \"2026-04-11T09:40:00Z\",\n289:   \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n290:   \"generation\": 1\n291: }\n292: ```\n293: \n294: **Emission rule:** If runtime logic first identifies a raw `paused` or `stuck_recovery` condition, the workflow MUST normalize it to `userPaused` or `stuckRecovery` before writing the JSONL line. Reducers and dashboards may assume persisted event names are already normalized.\n295: \n296: ### Verdict Rules\n297: \n298: | Verdict | Condition | Next Command |\n299: |---------|-----------|--------------|\n300: | FAIL | `activeP0 > 0` OR quality gate failure | `/speckit:plan` |\n301: | CONDITIONAL | `activeP0 == 0` AND `activeP1 > 0` | `/speckit:plan` |\n302: | PASS | `activeP0 == 0` AND `activeP1 == 0` | `/create:changelog` |\n303: \n304: When `activeP2 > 0` on PASS, set `hasAdvisories: true`.\n305: \n306: ### traceabilityChecks Schema\n307: \n308: ```json\n309: {\n310:   \"traceabilityChecks\": {\n311:     \"summary\": {\n312:       \"required\": 2, \"executed\": 3, \"pass\": 1, \"partial\": 1,\n313:       \"fail\": 1, \"blocked\": 0, \"notApplicable\": 0, \"gatingFailures\": 1\n314:     },\n315:     \"results\": [{\n316:       \"protocolId\": \"spec_code\", \"status\": \"fail\", \"gateClass\": \"hard\",\n317:       \"applicable\": true, \"counts\": { \"pass\": 0, \"partial\": 0, \"fail\": 1 },\n318:       \"evidence\": [\"README.md:48\"], \"findingRefs\": [\"F004\"],\n319:       \"summary\": \"README claimed the old report contract.\"\n320:     }]\n321:   }\n322: }\n323: ```\n324: \n325: | Field | Type | Required | Description |\n326: |-------|------|----------|-------------|\n327: | summary.required / executed / pass / partial / fail / blocked / notApplicable | number | Yes | Protocol execution counts |\n328: | summary.gatingFailures | number | Yes | Hard-gate failures blocking STOP |\n329: | results[].protocolId | string | Yes | Canonical protocol identifier |\n330: | results[].status | string | Yes | `pass`, `partial`, `fail`, `blocked`, `notApplicable` |\n331: | results[].gateClass | string | Yes | `hard` or `advisory` |\n332: | results[].applicable | boolean | Yes | Whether the protocol applied |\n333: | results[].counts | object | Yes | Protocol-local summary counts |\n334: | results[].evidence | string[] | No | Supporting file:line refs |\n335: | results[].findingRefs | string[] | No | Related finding identifiers |\n336: | results[].summary | string | Yes | Human-readable one-line result |\n337: \n338: ### Validation Rules\n339: \n340: - Each line must be valid JSON with a `type` field\n341: - `mode` must be `\"review\"` on all iteration and synthesis records\n342: - `run` values must be sequential. `newFindingsRatio` must be 0.0-1.0\n343: - `findingsSummary` and `findingsNew` must each contain `P0`, `P1`, `P2` keys\n344: - `findingDetails` must be an array. Each active item must include `findingClass`, `scopeProof`, and `affectedSurfaceHints`\n345: \n346: ## 3. REVIEW DEPTH SCHEMA (V2)\n347: \n348: `reviewDepthSchemaVersion: 2` is the discriminator for the v2 search-depth contract. Absent values, `null`, or any value other than `2` mean v1 legacy: readers keep today's behavior, and validator hard enforcement applies only when the discriminator is present.\n349: \n350: Frozen v2 contract:\n351: \n352: Top-level review iteration fields when `reviewDepthSchemaVersion: 2`:\n353: - `reviewDepthSchemaVersion: 2`, discriminator\n354: - `reviewDepthApplicability`, `{ scopeClass: 'trivial'|'standard'|'complex', enforcement: 'strict'|'warn'|'skip', reason: string, evidenceRefs: string[] }`\n355: - `targetSelection`, `{ selectedTargets: string[], selectionReason: string, discoveryMethods: string[], omittedHighRiskTargets: string[], graphStatus: 'available'|'unavailable'|'partial', semanticSearchStatus: 'available'|'unavailable'|'partial', evidenceRefs: string[] }`\n356: - `searchCoverage`, `{ requiredBugClasses: string[], covered: string[], ruledOut: string[], deferred: string[], blocked: string[], graphCoverageMode: 'graph'|'graphless_fallback'|'unavailable_blocked' }`\n357: - `searchLedger[]`, array of ledger rows\n358: \n359: Ledger row fields:\n360: - Required: `id, dimension, targetRefs, bugClass, disposition, rationale`\n361: - `hypothesis` (string) OR `invariant` (string), at least one\n362: - `searchActions[]`, `{ method: string, queryOrPath: string, result: string, evidenceRefs: string[] }`\n363: - Disposition-specific link (exactly one):\n364:   - `finding` → `linkedFindingId` (must reference an id present in `findingDetails[]`)\n365:   - `ruled_out` → `ruledOutReason`\n366:   - `deferred` → `deferredReason`\n367:   - `blocked` → `blockedReason`\n368:   - `not_applicable` → `notApplicableReason`\n369: \n370: Trivial-scope exemption: when `reviewDepthApplicability.scopeClass === 'trivial'` AND `reviewDepthApplicability.enforcement === 'skip'`, ledger may be `[]` with cited scope proof in `reviewDepthApplicability.evidenceRefs`.\n371: \n372: ### Applicability\n373: \n374: | Field | Type | Required | Semantics |\n375: |-------|------|----------|-----------|\n376: | `scopeClass` | `'trivial' \\| 'standard' \\| 'complex'` | Yes | Classifies how much depth proof the review target warrants. |\n377: | `enforcement` | `'strict' \\| 'warn' \\| 'skip'` | Yes | `strict` means v2 validators fail shallow records, `warn` emits advisory rollout feedback, `skip` is valid only for trivial scope with proof. |\n378: | `reason` | string | Yes | Human-readable justification for the chosen scope/enforcement pair. |\n379: | `evidenceRefs` | string[] | Yes | File/path refs proving scope classification, required even for skipped trivial ledgers. |\n380: \n381: ### Target Selection\n382: \n383: | Field | Type | Required | Semantics |\n384: |-------|------|----------|-----------|\n385: | `selectedTargets` | string[] | Yes | Files, folders, specs, or surfaces actually searched this iteration. |\n386: | `selectionReason` | string | Yes | Why these targets were highest-value for the dimension or bug class. |\n387: | `discoveryMethods` | string[] | Yes | Methods such as direct read, exact search, semantic search, graph query, producer trace, consumer trace, or negative-test search. |\n388: | `omittedHighRiskTargets` | string[] | Yes | High-risk targets not searched, use `[]` when none were identified. |\n389: | `graphStatus` | `'available' \\| 'unavailable' \\| 'partial'` | Yes | Code/coverage graph availability for this iteration's target selection. |\n390: | `semanticSearchStatus` | `'available' \\| 'unavailable' \\| 'partial'` | Yes | Semantic/code search availability for this iteration. |\n391: | `evidenceRefs` | string[] | Yes | Evidence for target selection and omitted-target claims. |\n392: \n393: ### Search Coverage\n394: \n395: | Field | Type | Required | Semantics |\n396: |-------|------|----------|-----------|\n397: | `requiredBugClasses` | string[] | Yes | Bug classes or invariant families that should be searched for this scope. |\n398: | `covered` | string[] | Yes | Required classes searched with conclusive finding or clean proof. |\n399: | `ruledOut` | string[] | Yes | Required classes searched and explicitly ruled out. |\n400: | `deferred` | string[] | Yes | Required classes postponed with a reason in ledger rows. |\n401: | `blocked` | string[] | Yes | Required classes blocked by missing access, graph/search outage, ambiguity, or scope conflict. |\n402: | `graphCoverageMode` | `'graph' \\| 'graphless_fallback' \\| 'unavailable_blocked'` | Yes | `graph` uses graph evidence, `graphless_fallback` uses direct text/JSON proof, and `unavailable_blocked` records insufficient fallback proof. |\n403: \n404: ### Search Ledger\n405: \n406: | Field | Type | Required | Semantics |\n407: |-------|------|----------|-----------|\n408: | `id` | string | Yes | Stable ledger-row id unique within the iteration record. |\n409: | `dimension` | string | Yes | Review dimension addressed by this row. |\n410: | `targetRefs` | string[] | Yes | Targets searched, should overlap `targetSelection.selectedTargets`. |\n411: | `bugClass` | string | Yes | Candidate bug class or invariant family. |\n412: | `hypothesis` / `invariant` | string | Conditional | At least one must be present and non-empty. |\n413: | `searchActions` | array | Yes | Each action has `method`, `queryOrPath`, `result`, and `evidenceRefs`. |\n414: | `disposition` | string | Yes | One of `finding`, `ruled_out`, `deferred`, `blocked`, `not_applicable`. |\n415: | `rationale` | string | Yes | Why this disposition follows from the evidence. |\n416: \n417: | Disposition | Required link | Rule |\n418: |-------------|---------------|------|\n419: | `finding` | `linkedFindingId` | Must reference an `id` present in `findingDetails[]`. |\n420: | `ruled_out` | `ruledOutReason` | Must explain the negative evidence. |\n421: | `deferred` | `deferredReason` | Must explain why later search is acceptable. |\n422: | `blocked` | `blockedReason` | Must name the blocker and expected recovery path. |\n423: | `not_applicable` | `notApplicableReason` | Must explain why the bug class does not apply to this target. |\n424: \n425: Representative v2 record:\n426: \n427: ```json\n428: {\n429:   \"type\": \"iteration\",\n430:   \"mode\": \"review\",\n431:   \"iteration\": 3,\n432:   \"run\": 3,\n433:   \"status\": \"complete\",\n434:   \"dimensions\": [\"correctness\"],\n435:   \"filesReviewed\": [\"src/review-target.ts\"],\n436:   \"findingsSummary\": { \"P0\": 0, \"P1\": 0, \"P2\": 0 },\n437:   \"findingsNew\": { \"P0\": 0, \"P1\": 0, \"P2\": 0 },\n438:   \"findingDetails\": [],\n439:   \"newFindingsRatio\": 0,\n440:   \"sessionId\": \"rvw-example\",\n441:   \"generation\": 1,\n442:   \"lineageMode\": \"new\",\n443:   \"timestamp\": \"2026-05-22T00:00:00Z\",\n444:   \"durationMs\": 120000,\n445:   \"reviewDepthSchemaVersion\": 2,\n446:   \"reviewDepthApplicability\": { \"scopeClass\": \"standard\", \"enforcement\": \"strict\", \"reason\": \"non-trivial state transition target\", \"evidenceRefs\": [\"src/review-target.ts:1\"] },\n447:   \"targetSelection\": { \"selectedTargets\": [\"src/review-target.ts\"], \"selectionReason\": \"state mutation path under review\", \"discoveryMethods\": [\"direct_read\", \"exact_search\"], \"omittedHighRiskTargets\": [], \"graphStatus\": \"unavailable\", \"semanticSearchStatus\": \"partial\", \"evidenceRefs\": [\"src/review-target.ts:1\"] },\n448:   \"searchCoverage\": { \"requiredBugClasses\": [\"state_transition\"], \"covered\": [], \"ruledOut\": [\"state_transition\"], \"deferred\": [], \"blocked\": [], \"graphCoverageMode\": \"graphless_fallback\" },\n449:   \"searchLedger\": [{ \"id\": \"SL-001\", \"dimension\": \"correctness\", \"targetRefs\": [\"src/review-target.ts\"], \"bugClass\": \"state_transition\", \"hypothesis\": \"state transition can skip validation\", \"searchActions\": [{ \"method\": \"direct_read\", \"queryOrPath\": \"src/review-target.ts\", \"result\": \"validation guard present on all branches\", \"evidenceRefs\": [\"src/review-target.ts:42\"] }], \"disposition\": \"ruled_out\", \"rationale\": \"all mutation branches call the validator\", \"ruledOutReason\": \"guard verified by direct read\" }]\n450: }\n451: ```\n452: \n453: ### Compatibility and Downstream Obligations\n454: \n455: | Record Shape | Reader Behavior | Validator Behavior |\n456: |--------------|-----------------|--------------------|\n457: | v1 legacy: discriminator absent or not `2` | Parse as today's iteration record. | Phase D may warn, but must not hard-fail only because v2 fields are absent. |\n458: | v2 trivial+skip | Parse v2 applicability, `searchLedger: []` allowed with cited scope proof. | Validate `reviewDepthApplicability.evidenceRefs`, skip ledger-depth requirements. |\n459: | v2 standard/complex | Parse v2 fields in addition to v1 required fields. | Enforce v2 shape, ledger linkage, coverage reconciliation, and evidence refs. |\n460: \n461: Phase E reducer/dashboard/report work must preserve and expose `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, `cleanSearchProof`, and `searchCoverage`. Until Phase E ships, these are contract obligations only. `deep-review-findings-registry.json`, `deep-review-dashboard.md`, and `review-report.md` are not expected to persist them.\n462: \n463: ---\n\n(End of file - total 463 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review State Log Records\ndescription: JSONL state-log record schemas (config, iteration, event, lineage) and the Review Depth Schema v2 for the deep review loop.\ntrigger_phrases:\n  - \"deep review state jsonl\"\n  - \"review jsonl record schemas\"\n  - \"review depth schema\"\n  - \"review traceability checks\"\n  - \"review graph events\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.5\n---\n\n# Deep Review State Log Records\n\nThe `deep-review-state.jsonl` log is the append-only source of truth for a review run. This reference documents the config, iteration, event, and lineage record schemas plus the Review Depth Schema (v2) that the reducer consumes.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_jsonl.md","text":"---\ntitle: Deep Review State Log Records\ndescription: JSONL state-log record schemas (config, iteration, event, lineage) and the Review Depth Schema v2 for the deep review loop.\ntrigger_phrases:\n  - \"deep review state jsonl\"\n  - \"review jsonl record schemas\"\n  - \"review depth schema\"\n  - \"review traceability checks\"\n  - \"review graph events\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.5\n---\n\n# Deep Review State Log Records\n\nThe `deep-review-state.jsonl` log is the append-only source of truth for a review run. This reference documents the config, iteration, event, and lineage record schemas plus the Review Depth Schema (v2) that the reducer consumes.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis reference defines the append-only JSONL records that preserve deep-review run state. It covers config, iteration, event, lineage, graph, verdict, traceability, and Review Depth Schema v2 records so reducers and validators can replay the loop deterministically.\n\n### When to Use\n\n- Validating `deep-review-state.jsonl` shape before changing reducers, dashboards, or workflow emission.\n- Debugging malformed state records, blocked-stop events, graph convergence events, or lineage fields.\n- Adding or checking Review Depth Schema v2 target selection, search coverage, and ledger fields.\n- Confirming which fields are required before writing iteration, synthesis, pause, or recovery events.\n\n### Key Sources\n\n| Source | Purpose |\n|--------|---------|\n| Config record | Establishes session identity, lineage, thresholds, and spec folder routing. |\n| Iteration record | Captures focus, reviewed files, findings, convergence ratios, and graph events. |\n| Event records | Persist synthesis, blocked-stop, graph convergence, pause, and stuck-recovery decisions. |\n| Review Depth Schema v2 | Adds target selection, search coverage, and ledger proof for deeper review iterations. |\n\n---\n\n## 2. STATE LOG (DEEP-REVIEW-STATE.JSONL)\n\nAppend-only JSON Lines file. One JSON object per line.\n\n### Line 1: Config Record\n\n```json\n{\"type\":\"config\",\"mode\":\"review\",\"topic\":\"...\",\"reviewTarget\":\"...\",\"sessionId\":\"rvw-...\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":7,\"convergenceThreshold\":0.10,\"createdAt\":\"2026-03-24T14:00:00Z\",\"specFolder\":\"...\"}\n```\n\n### Iteration Records\n\n```json\n{\n  \"type\": \"iteration\", \"mode\": \"review\", \"run\": 3, \"status\": \"complete\",\n  \"focus\": \"D3 Traceability - skill/runtime alignment\",\n  \"dimensions\": [\"traceability\", \"maintainability\"],\n  \"filesReviewed\": [\".opencode/skills/system-deep-loop/deep-research/README.md\"],\n  \"sessionId\": \"rvw-2026-04-03T12-00-00Z\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"resume\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"findingsCount\": 4,\n  \"findingsSummary\": { \"P0\": 0, \"P1\": 1, \"P2\": 3 },\n  \"findingsNew\": { \"P0\": 0, \"P1\": 1, \"P2\": 1 },\n  \"findingDetails\": [\n    {\n      \"id\": \"P1-001\",\n      \"severity\": \"P1\",\n      \"title\": \"Missing consumer update\",\n      \"dimension\": \"correctness\",\n      \"file\": \"path/to/file.ts:42\",\n      \"evidence\": \"Observed consumer still reads the old field.\",\n      \"recommendation\": \"Update the consumer and add verification.\",\n      \"disposition\": \"active\",\n      \"findingClass\": \"cross-consumer\",\n      \"scopeProof\": \"rg evidence covering producers and consumers\",\n      \"affectedSurfaceHints\": [\"producer/helper\", \"consumer/status\"]\n    }\n  ],\n  \"newFindingsRatio\": 0.32,\n  \"timestamp\": \"2026-03-24T14:30:00Z\", \"durationMs\": 52000\n}\n```\n\n**Required fields:** `type`, `mode`, `run`, `status`, `focus`, `dimensions`, `filesReviewed`, `findingsCount`, `findingsSummary`, `findingsNew`, `findingDetails`, `newFindingsRatio`, `sessionId`, `generation`, `lineageMode`, `timestamp`, `durationMs`\n\n**Optional fields:** `parentSessionId`, `continuedFromRun`, `findingsRefined`, `findingRefs`, `traceabilityChecks`, `coverage`, `noveltyJustification`, `ruledOut`, `focusTrack`, `scoreEstimate`, `segment`, `convergenceSignals`, `graphEvents`\n\n| Required Field | Type | Description |\n|---------------|------|-------------|\n| mode | `\"review\"` | Session mode discriminator |\n| dimensions | string[] | Review dimensions addressed this iteration |\n| filesReviewed | string[] | Files examined |\n| sessionId | string | Current lineage session identifier |\n| generation | number | Lineage generation number |\n| lineageMode | string | Lifecycle mode used for this run |\n| findingsSummary | object | Total active findings: `{ P0, P1, P2 }` |\n| findingsNew | object | Net-new findings this iteration: `{ P0, P1, P2 }` |\n| findingDetails | array | Active findings with `id`, `severity`, `title`, `dimension`, `file`, `evidence`, `recommendation`, `disposition`, `findingClass`, `scopeProof`, and `affectedSurfaceHints`, use `[]` when there are no findings |\n| newFindingsRatio | number | Severity-weighted new findings ratio (0.0-1.0) |\n\n### Convergence Signals\n\n| Signal | Weight | Description |\n|--------|--------|-------------|\n| rollingAvg | 0.30 | Rolling average of severity-weighted new findings |\n| madScore | 0.25 | Noise-floor test against MAD-derived churn |\n| dimensionCoverage | 0.45 | Required dimension + protocol coverage stability |\n| compositeStop | -- | Weighted stop score (stop if > 0.60) |\n\n**Severity math:** `refinementMultiplier: 0.5`, `p0OverrideMinRatio: 0.50`, `noFindingsRatio: 0.0`\n\n### Graph Events\n\nThe optional `graphEvents` array records coverage graph mutations emitted by a review iteration. The MCP coverage graph handlers (`mcp_server/handlers/coverage-graph/upsert.ts`) consume these events and persist them into `deep-loop-graph.sqlite`, where they become the source of truth for graph-assisted convergence, hotspot saturation, and blocked-stop evidence.\n\n```json\n{\n  \"type\": \"iteration\", \"mode\": \"review\", \"run\": 4, \"status\": \"complete\",\n  \"focus\": \"correctness\",\n  \"dimensions\": [\"correctness\"],\n  \"filesReviewed\": [\"src/api/session.ts\"],\n  \"findingsSummary\": { \"P0\": 0, \"P1\": 1, \"P2\": 0 },\n  \"findingsNew\": { \"P0\": 0, \"P1\": 1, \"P2\": 0 },\n  \"newFindingsRatio\": 0.18,\n  \"sessionId\": \"rvw-2026-03-24T10-00-00Z\",\n  \"generation\": 1,\n  \"lineageMode\": \"new\",\n  \"graphEvents\": [\n    { \"type\": \"dimension\", \"id\": \"d-correctness\", \"label\": \"correctness\" },\n    { \"type\": \"file\", \"id\": \"file-session-ts\", \"label\": \"src/api/session.ts\" },\n    { \"type\": \"finding\", \"id\": \"f-001\", \"label\": \"Missing CSRF token check on session POST\" },\n    { \"type\": \"evidence\", \"id\": \"ev-001\", \"label\": \"src/api/session.ts:42\" },\n    { \"type\": \"edge\", \"id\": \"e-in-dim-f-001\", \"relation\": \"IN_DIMENSION\", \"source\": \"f-001\", \"target\": \"d-correctness\" },\n    { \"type\": \"edge\", \"id\": \"e-in-file-f-001\", \"relation\": \"IN_FILE\", \"source\": \"f-001\", \"target\": \"file-session-ts\" },\n    { \"type\": \"edge\", \"id\": \"e-evidence-f-001\", \"relation\": \"EVIDENCE_FOR\", \"source\": \"ev-001\", \"target\": \"f-001\" }\n  ],\n  \"timestamp\": \"2026-03-24T10:12:00Z\",\n  \"durationMs\": 51000\n}\n```\n\n#### Event payload shape\n\n| Field | Type | Required | Description |\n|-------|------|----------|-------------|\n| type | `\"dimension\"` \\| `\"file\"` \\| `\"finding\"` \\| `\"evidence\"` \\| `\"remediation\"` \\| `\"edge\"` | Yes | Review-loop node kind or the literal `\"edge\"` for relation rows |\n| id | string | Yes | Caller-chosen logical id. Must be unique **within** a single `(specFolder, loopType, sessionId)` namespace, see Namespace Rules below |\n| label | string | Yes | Human-readable name/caption (dimension, path, finding title, evidence anchor, etc.) |\n| relation | `\"COVERS\"` \\| `\"EVIDENCE_FOR\"` \\| `\"CONTRADICTS\"` \\| `\"RESOLVES\"` \\| `\"CONFIRMS\"` \\| `\"ESCALATES\"` \\| `\"IN_DIMENSION\"` \\| `\"IN_FILE\"` | edges only | Review relation type. Required when `type == \"edge\"` |\n| source | string | edges only | `id` of the source node inside the current namespace |\n| target | string | edges only | `id` of the target node inside the current namespace. Self-loops are rejected by the upsert handler |\n| metadata | object | No | Optional free-form metadata persisted alongside the row (e.g. `{ \"hotspot_score\": 2 }`) |\n\n#### Namespace Rules (REQ-028, REQ-029)\n\n`graphEvents` entries are scoped by the session that emits them. The coverage graph DB uses a composite primary key of `(spec_folder, loop_type, session_id, id)`, so two independent review sessions in the same spec folder MAY reuse the same logical `id` without collision, each session gets its own row.\n\nConcrete obligations for producers:\n\n1. **Session-local uniqueness**: within one session, an `id` must resolve to exactly one node (or edge) for its entire lifetime. Re-emitting the same `id` is an upsert against the existing row in that session only.\n2. **No cross-session global uniqueness requirement**: callers MUST NOT prefix ids with the session id or random salt to \"avoid collisions\". The DB layer handles namespace isolation. Salting ids only makes provenance harder to read.\n3. **Edge source/target locality**: `source` and `target` in an edge event must name nodes already present in the same namespace. Cross-session edges are not a supported shape.\n4. **Persistence gate**: the reducer refuses to roll graph events forward when a record is missing `sessionId` on the surrounding iteration record, because the DB cannot route the write.\n\nThe collision regression in `.opencode/skills/system-spec-kit/scripts/tests/session-isolation.vitest.ts` (\"shared-ID collisions\" block) exercises this contract directly: two sessions upsert identical node and edge ids, and both rows must survive independently.\n\n### Synthesis Event\n\n```json\n{\n  \"type\": \"event\", \"event\": \"synthesis_complete\", \"mode\": \"review\",\n  \"totalIterations\": 6, \"verdict\": \"PASS\",\n  \"activeP0\": 0, \"activeP1\": 0, \"activeP2\": 2,\n  \"dimensionCoverage\": 1.0, \"stopReason\": \"composite_converged\",\n  \"timestamp\": \"2026-03-24T15:02:00Z\"\n}\n```\n\n**Required:** `type`, `event`, `mode`, `totalIterations`, `verdict`, `activeP0`, `activeP1`, `activeP2`, `dimensionCoverage`, `stopReason`, `timestamp`\n\n### Blocked-Stop Event\n\nWhen the review legal-stop decision tree returns `blocked`, append a first-class `blocked_stop` event instead of silently overriding STOP to CONTINUE.\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"blocked_stop\",\n  \"mode\": \"review\",\n  \"run\": 4,\n  \"blockedBy\": [\"dimensionCoverageGate\", \"p0ResolutionGate\"],\n  \"gateResults\": {\n    \"convergenceGate\": { \"pass\": true, \"score\": 0.72 },\n    \"dimensionCoverageGate\": {\n      \"pass\": false,\n      \"covered\": [\"correctness\", \"security\"],\n      \"missing\": [\"traceability\", \"maintainability\"]\n    },\n    \"p0ResolutionGate\": { \"pass\": false, \"activeP0\": 1 },\n    \"evidenceDensityGate\": { \"pass\": true, \"avgEvidencePerFinding\": 1.5 },\n    \"hotspotSaturationGate\": { \"pass\": true },\n    \"claimAdjudicationGate\": { \"pass\": true, \"activeP0P1\": 2 },\n    \"fixCompletenessReplayGate\": { \"pass\": true, \"securitySensitive\": false, \"requiredRows\": 0, \"passingRows\": 0 },\n    \"candidateCoverageGate\": { \"pass\": true, \"searchDebt\": [], \"missing\": [] },\n    \"graphlessFallbackGate\": { \"pass\": true, \"mode\": \"graph_available\", \"missing\": [], \"unavailabilityReason\": \"\" }\n  },\n  \"recoveryStrategy\": \"Cover the missing review dimensions, then resolve the active P0.\",\n  \"timestamp\": \"2026-04-11T09:45:00Z\",\n  \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n  \"generation\": 1\n}\n```\n\n`gateResults` carries the full 9-gate set emitted by `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`: `convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, and `graphlessFallbackGate`. The last two are v2-rollout gates that pass trivially when the review-depth-v2 search path is inactive. See `../convergence/convergence.md` §Section-1 for the authoritative shape.\n\n**Required:** `type`, `event`, `mode`, `run`, `blockedBy`, `gateResults`, `recoveryStrategy`, `timestamp`, `sessionId`, `generation`\n\n### Graph Convergence Event\n\nBefore the inline 3-signal review vote is allowed to finalize STOP, the workflow must append a `graph_convergence` event for the current review lineage.\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"graph_convergence\",\n  \"mode\": \"review\",\n  \"run\": 4,\n  \"decision\": \"STOP_ALLOWED\",\n  \"signals\": {\n    \"dimensionCoverage\": 1,\n    \"findingStability\": 0.88,\n    \"p0ResolutionRate\": 1,\n    \"evidenceDensity\": 1.4,\n    \"hotspotSaturation\": 0.75\n  },\n  \"blockers\": [],\n  \"timestamp\": \"2026-04-11T09:44:00Z\",\n  \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n  \"generation\": 1\n}\n```\n\n**Required:** `type`, `event`, `mode`, `run`, `decision`, `signals`, `blockers`, `timestamp`, `sessionId`, `generation`\n\n**Decision enum:** `CONTINUE`, `STOP_ALLOWED`, `STOP_BLOCKED`\n\n**Combined-stop rule:** Final STOP is legal only when the inline review convergence decision says STOP and the latest `graph_convergence.decision == \"STOP_ALLOWED\"`. If the latest graph decision is `STOP_BLOCKED`, set `stop_blocked=true`, emit `blocked_stop`, and continue recovery instead of stopping. If the latest graph decision is `CONTINUE`, downgrade the inline STOP candidate to CONTINUE.\n\n### Normalized Pause and Recovery Events\n\nPause and recovery events MUST use the frozen shared stop-reason enum at emission time:\n\n`converged`, `maxIterationsReached`, `blockedStop`, `stuckRecovery`, `error`, `manualStop`, `userPaused`\n\nRaw `paused` and `stuck_recovery` labels are not legal persisted event names in the review JSONL contract. The workflow must rewrite them before appending JSONL rows.\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"userPaused\",\n  \"mode\": \"review\",\n  \"stopReason\": \"userPaused\",\n  \"reason\": \"sentinel file detected\",\n  \"timestamp\": \"2026-04-11T09:32:00Z\",\n  \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n  \"generation\": 1\n}\n```\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"stuckRecovery\",\n  \"mode\": \"review\",\n  \"stopReason\": \"stuckRecovery\",\n  \"fromIteration\": 5,\n  \"strategy\": \"Traceability protocol replay: re-run unresolved core or overlay checks\",\n  \"targetDimension\": \"traceability\",\n  \"outcome\": \"pending\",\n  \"reason\": \"Recovery path activated after repeated no-progress iterations\",\n  \"timestamp\": \"2026-04-11T09:40:00Z\",\n  \"sessionId\": \"rvw-2026-04-11T09-00-00Z\",\n  \"generation\": 1\n}\n```\n\n**Emission rule:** If runtime logic first identifies a raw `paused` or `stuck_recovery` condition, the workflow MUST normalize it to `userPaused` or `stuckRecovery` before writing the JSONL line. Reducers and dashboards may assume persisted event names are already normalized.\n\n### Verdict Rules\n\n| Verdict | Condition | Next Command |\n|---------|-----------|--------------|\n| FAIL | `activeP0 > 0` OR quality gate failure | `/speckit:plan` |\n| CONDITIONAL | `activeP0 == 0` AND `activeP1 > 0` | `/speckit:plan` |\n| PASS | `activeP0 == 0` AND `activeP1 == 0` | `/create:changelog` |\n\nWhen `activeP2 > 0` on PASS, set `hasAdvisories: true`.\n\n### traceabilityChecks Schema\n\n```json\n{\n  \"traceabilityChecks\": {\n    \"summary\": {\n      \"required\": 2, \"executed\": 3, \"pass\": 1, \"partial\": 1,\n      \"fail\": 1, \"blocked\": 0, \"notApplicable\": 0, \"gatingFailures\": 1\n    },\n    \"results\": [{\n      \"protocolId\": \"spec_code\", \"status\": \"fail\", \"gateClass\": \"hard\",\n      \"applicable\": true, \"counts\": { \"pass\": 0, \"partial\": 0, \"fail\": 1 },\n      \"evidence\": [\"README.md:48\"], \"findingRefs\": [\"F004\"],\n      \"summary\": \"README claimed the old report contract.\"\n    }]\n  }\n}\n```\n\n| Field | Type | Required | Description |\n|-------|------|----------|-------------|\n| summary.required / executed / pass / partial / fail / blocked / notApplicable | number | Yes | Protocol execution counts |\n| summary.gatingFailures | number | Yes | Hard-gate failures blocking STOP |\n| results[].protocolId | string | Yes | Canonical protocol identifier |\n| results[].status | string | Yes | `pass`, `partial`, `fail`, `blocked`, `notApplicable` |\n| results[].gateClass | string | Yes | `hard` or `advisory` |\n| results[].applicable | boolean | Yes | Whether the protocol applied |\n| results[].counts | object | Yes | Protocol-local summary counts |\n| results[].evidence | string[] | No | Supporting file:line refs |\n| results[].findingRefs | string[] | No | Related finding identifiers |\n| results[].summary | string | Yes | Human-readable one-line result |\n\n### Validation Rules\n\n- Each line must be valid JSON with a `type` field\n- `mode` must be `\"review\"` on all iteration and synthesis records\n- `run` values must be sequential. `newFindingsRatio` must be 0.0-1.0\n- `findingsSummary` and `findingsNew` must each contain `P0`, `P1`, `P2` keys\n- `findingDetails` must be an array. Each active item must include `findingClass`, `scopeProof`, and `affectedSurfaceHints`\n\n## 3. REVIEW DEPTH SCHEMA (V2)\n\n`reviewDepthSchemaVersion: 2` is the discriminator for the v2 search-depth contract. Absent values, `null`, or any value other than `2` mean v1 legacy: readers keep today's behavior, and validator hard enforcement applies only when the discriminator is present.\n\nFrozen v2 contract:\n\nTop-level review iteration fields when `reviewDepthSchemaVersion: 2`:\n- `reviewDepthSchemaVersion: 2`, discriminator\n- `reviewDepthApplicability`, `{ scopeClass: 'trivial'|'standard'|'complex', enforcement: 'strict'|'warn'|'skip', reason: string, evidenceRefs: string[] }`\n- `targetSelection`, `{ selectedTargets: string[], selectionReason: string, discoveryMethods: string[], omittedHighRiskTargets: string[], graphStatus: 'available'|'unavailable'|'partial', semanticSearchStatus: 'available'|'unavailable'|'partial', evidenceRefs: string[] }`\n- `searchCoverage`, `{ requiredBugClasses: string[], covered: string[], ruledOut: string[], deferred: string[], blocked: string[], graphCoverageMode: 'graph'|'graphless_fallback'|'unavailable_blocked' }`\n- `searchLedger[]`, array of ledger rows\n\nLedger row fields:\n- Required: `id, dimension, targetRefs, bugClass, disposition, rationale`\n- `hypothesis` (string) OR `invariant` (string), at least one\n- `searchActions[]`, `{ method: string, queryOrPath: string, result: string, evidenceRefs: string[] }`\n- Disposition-specific link (exactly one):\n  - `finding` → `linkedFindingId` (must reference an id present in `findingDetails[]`)\n  - `ruled_out` → `ruledOutReason`\n  - `deferred` → `deferredReason`\n  - `blocked` → `blockedReason`\n  - `not_applicable` → `notApplicableReason`\n\nTrivial-scope exemption: when `reviewDepthApplicability.scopeClass === 'trivial'` AND `reviewDepthApplicability.enforcement === 'skip'`, ledger may be `[]` with cited scope proof in `reviewDepthApplicability.evidenceRefs`.\n\n### Applicability\n\n| Field | Type | Required | Semantics |\n|-------|------|----------|-----------|\n| `scopeClass` | `'trivial' \\| 'standard' \\| 'complex'` | Yes | Classifies how much depth proof the review target warrants. |\n| `enforcement` | `'strict' \\| 'warn' \\| 'skip'` | Yes | `strict` means v2 validators fail shallow records, `warn` emits advisory rollout feedback, `skip` is valid only for trivial scope with proof. |\n| `reason` | string | Yes | Human-readable justification for the chosen scope/enforcement pair. |\n| `evidenceRefs` | string[] | Yes | File/path refs proving scope classification, required even for skipped trivial ledgers. |\n\n### Target Selection\n\n| Field | Type | Required | Semantics |\n|-------|------|----------|-----------|\n| `selectedTargets` | string[] | Yes | Files, folders, specs, or surfaces actually searched this iteration. |\n| `selectionReason` | string | Yes | Why these targets were highest-value for the dimension or bug class. |\n| `discoveryMethods` | string[] | Yes | Methods such as direct read, exact search, semantic search, graph query, producer trace, consumer trace, or negative-test search. |\n| `omittedHighRiskTargets` | string[] | Yes | High-risk targets not searched, use `[]` when none were identified. |\n| `graphStatus` | `'available' \\| 'unavailable' \\| 'partial'` | Yes | Code/coverage graph availability for this iteration's target selection. |\n| `semanticSearchStatus` | `'available' \\| 'unavailable' \\| 'partial'` | Yes | Semantic/code search availability for this iteration. |\n| `evidenceRefs` | string[] | Yes | Evidence for target selection and omitted-target claims. |\n\n### Search Coverage\n\n| Field | Type | Required | Semantics |\n|-------|------|----------|-----------|\n| `requiredBugClasses` | string[] | Yes | Bug classes or invariant families that should be searched for this scope. |\n| `covered` | string[] | Yes | Required classes searched with conclusive finding or clean proof. |\n| `ruledOut` | string[] | Yes | Required classes searched and explicitly ruled out. |\n| `deferred` | string[] | Yes | Required classes postponed with a reason in ledger rows. |\n| `blocked` | string[] | Yes | Required classes blocked by missing access, graph/search outage, ambiguity, or scope conflict. |\n| `graphCoverageMode` | `'graph' \\| 'graphless_fallback' \\| 'unavailable_blocked'` | Yes | `graph` uses graph evidence, `graphless_fallback` uses direct text/JSON proof, and `unavailable_blocked` records insufficient fallback proof. |\n\n### Search Ledger\n\n| Field | Type | Required | Semantics |\n|-------|------|----------|-----------|\n| `id` | string | Yes | Stable ledger-row id unique within the iteration record. |\n| `dimension` | string | Yes | Review dimension addressed by this row. |\n| `targetRefs` | string[] | Yes | Targets searched, should overlap `targetSelection.selectedTargets`. |\n| `bugClass` | string | Yes | Candidate bug class or invariant family. |\n| `hypothesis` / `invariant` | string | Conditional | At least one must be present and non-empty. |\n| `searchActions` | array | Yes | Each action has `method`, `queryOrPath`, `result`, and `evidenceRefs`. |\n| `disposition` | string | Yes | One of `finding`, `ruled_out`, `deferred`, `blocked`, `not_applicable`. |\n| `rationale` | string | Yes | Why this disposition follows from the evidence. |\n\n| Disposition | Required link | Rule |\n|-------------|---------------|------|\n| `finding` | `linkedFindingId` | Must reference an `id` present in `findingDetails[]`. |\n| `ruled_out` | `ruledOutReason` | Must explain the negative evidence. |\n| `deferred` | `deferredReason` | Must explain why later search is acceptable. |\n| `blocked` | `blockedReason` | Must name the blocker and expected recovery path. |\n| `not_applicable` | `notApplicableReason` | Must explain why the bug class does not apply to this target. |\n\nRepresentative v2 record:\n\n```json\n{\n  \"type\": \"iteration\",\n  \"mode\": \"review\",\n  \"iteration\": 3,\n  \"run\": 3,\n  \"status\": \"complete\",\n  \"dimensions\": [\"correctness\"],\n  \"filesReviewed\": [\"src/review-target.ts\"],\n  \"findingsSummary\": { \"P0\": 0, \"P1\": 0, \"P2\": 0 },\n  \"findingsNew\": { \"P0\": 0, \"P1\": 0, \"P2\": 0 },\n  \"findingDetails\": [],\n  \"newFindingsRatio\": 0,\n  \"sessionId\": \"rvw-example\",\n  \"generation\": 1,\n  \"lineageMode\": \"new\",\n  \"timestamp\": \"2026-05-22T00:00:00Z\",\n  \"durationMs\": 120000,\n  \"reviewDepthSchemaVersion\": 2,\n  \"reviewDepthApplicability\": { \"scopeClass\": \"standard\", \"enforcement\": \"strict\", \"reason\": \"non-trivial state transition target\", \"evidenceRefs\": [\"src/review-target.ts:1\"] },\n  \"targetSelection\": { \"selectedTargets\": [\"src/review-target.ts\"], \"selectionReason\": \"state mutation path under review\", \"discoveryMethods\": [\"direct_read\", \"exact_search\"], \"omittedHighRiskTargets\": [], \"graphStatus\": \"unavailable\", \"semanticSearchStatus\": \"partial\", \"evidenceRefs\": [\"src/review-target.ts:1\"] },\n  \"searchCoverage\": { \"requiredBugClasses\": [\"state_transition\"], \"covered\": [], \"ruledOut\": [\"state_transition\"], \"deferred\": [], \"blocked\": [], \"graphCoverageMode\": \"graphless_fallback\" },\n  \"searchLedger\": [{ \"id\": \"SL-001\", \"dimension\": \"correctness\", \"targetRefs\": [\"src/review-target.ts\"], \"bugClass\": \"state_transition\", \"hypothesis\": \"state transition can skip validation\", \"searchActions\": [{ \"method\": \"direct_read\", \"queryOrPath\": \"src/review-target.ts\", \"result\": \"validation guard present on all branches\", \"evidenceRefs\": [\"src/review-target.ts:42\"] }], \"disposition\": \"ruled_out\", \"rationale\": \"all mutation branches call the validator\", \"ruledOutReason\": \"guard verified by direct read\" }]\n}\n```\n\n### Compatibility and Downstream Obligations\n\n| Record Shape | Reader Behavior | Validator Behavior |\n|--------------|-----------------|--------------------|\n| v1 legacy: discriminator absent or not `2` | Parse as today's iteration record. | Phase D may warn, but must not hard-fail only because v2 fields are absent. |\n| v2 trivial+skip | Parse v2 applicability, `searchLedger: []` allowed with cited scope proof. | Validate `reviewDepthApplicability.evidenceRefs`, skip ledger-depth requirements. |\n| v2 standard/complex | Parse v2 fields in addition to v1 required fields. | Enforce v2 shape, ledger linkage, coverage reconciliation, and evidence refs. |\n\nPhase E reducer/dashboard/report work must preserve and expose `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, `cleanSearchProof`, and `searchCoverage`. Until Phase E ships, these are contract obligations only. `deep-review-findings-registry.json`, `deep-review-dashboard.md`, and `review-report.md` are not expected to persist them.\n\n---","lineStart":1,"lineEnd":463,"totalLines":463,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/state/state_jsonl.md","time":{"start":1783915553561,"end":1783915553581}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cac8191b93be8fbd5cafc01"}},"id":"prt_f59a72318001XdnE7pKK7I7eis","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553586,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_YWNxQint7vtIUY5QZK8zcxuV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Completion Criteria\n3: description: Full definition-of-done checklist for a deep-review loop -- loop completion conditions, the binary quality gates that must pass before STOP, and release-readiness validation success criteria.\n4: trigger_phrases:\n5:   - \"review loop completion criteria\"\n6:   - \"review success criteria\"\n7:   - \"review definition of done\"\n8:   - \"review release readiness validation\"\n9: importance_tier: important\n10: contextType: implementation\n11: version: 1.11.0.0\n12: ---\n13: \n14: # Deep Review Completion Criteria\n15: \n16: Full definition-of-done checklist for a deep-review loop: loop completion conditions, the binary quality gates STOP must clear, and release-readiness validation success criteria.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: This reference is the authoritative checklist for \"is this review loop actually done.\" SKILL.md §6 SUCCESS CRITERIA carries a condensed summary and links here for the full enumeration; use this file when verifying a completed run, debugging a premature STOP, or reconciling completion metadata against the loop's real state.\n25: \n26: ### When to Use\n27: \n28: - Verifying a review loop's completion before accepting its verdict.\n29: - Debugging why STOP was blocked or why synthesis produced an incomplete report.\n30: - Reconciling `review-report.md` claims against the canonical state files.\n31: - Auditing a run for the release-readiness handoff.\n32: \n33: ### Relationship to `loop_state_and_gates.md`\n34: \n35: `references/protocol/loop_state_and_gates.md` defines the three state-machine-level binary gates (Evidence, Scope, Coverage) that block a STOP *decision* inside the convergence check. This file is the broader definition-of-done: it also covers artifact existence, report structure, severity-field completeness, and the release-readiness handoff -- checked once the loop believes it has already reached STOP.\n36: \n37: ---\n38: \n39: ## 2. LOOP COMPLETION\n40: \n41: A review loop is considered complete when every item below holds:\n42: \n43: - The loop reached convergence (composite stop score above `compositeStopScore`, with required gates green) OR hit `maxIterations` without false-positive STOP.\n44: - Every configured review dimension has at least one full iteration of coverage recorded in `deep-review-state.jsonl` and reflected in `deep-review-strategy.md`.\n45: - Required traceability protocols (`spec_code`, `checklist_evidence`) executed at least once. Overlay protocols that apply to the target type ran or were explicitly marked N/A.\n46: - All canonical state files exist and parse cleanly: `deep-review-config.json`, `deep-review-state.jsonl`, `deep-review-findings-registry.json`, `deep-review-strategy.md`, `deep-review-dashboard.md`, and one `iterations/iteration-NNN.md` per dispatched iteration.\n47: - `review/resource-map.md` was emitted from converged delta evidence unless `config.resource_map.emit == false` (operator flag `--no-resource-map`).\n48: - `review/review-report.md` carries all 9 core sections (Executive Summary, Planning Trigger, Active Finding Registry, Remediation Workstreams, Spec Seed, Plan Seed, Traceability Status, Deferred Items, Audit Appendix) plus the conditional `## Resource Map Coverage Gate` section when `resource_map_present == true`.\n49: - Canonical continuity surfaces updated via `generate-context.js` (description.json, graph-metadata.json, indexed memory entries).\n50: \n51: ---\n52: \n53: ## 3. QUALITY GATES\n54: \n55: Each gate is binary: pass or block. STOP cannot be legal until every gate passes.\n56: \n57: - **Config validity**: `deep-review-config.json` parses, names every required field, and lineage block matches the current run (`sessionId`, `parentSessionId`, `lineageMode`, `generation`, `continuedFromRun`, `releaseReadinessState`).\n58: - **Strategy initialization**: `deep-review-strategy.md` carries the Files Under Review table, Cross-Reference Status grouped by core vs overlay, Known Context, and Review Boundaries.\n59: - **State consistency**: `deep-review-state.jsonl` opens with the config record and appends one iteration record per dispatched iteration. Reducer-owned fields in `deep-review-findings-registry.json` reconcile against JSONL totals.\n60: - **Iteration completeness**: every dispatched iteration produced both an `iterations/iteration-NNN.md` (non-empty, ending with the canonical `Review verdict: PASS|CONDITIONAL|FAIL` line) AND a JSONL delta record with `findingDetails[]`, `findingsSummary`, `newFindingsRatio`.\n61: - **Severity coverage**: every reported finding carries `severity` in {P0, P1, P2}, `category`, `file:line` evidence, `finding_class`, and a `content_hash` for synthesis dedup.\n62: - **Advisory numeric score**: `riskScore` may appear in finding details as non-gating context only; verdict logic must ignore it.\n63: - **Adversarial replay**: every P0 finding survived adversarial self-check. Rejected P0s downgraded with rationale recorded in the iteration narrative.\n64: - **Coverage threshold**: `dimensions_covered_count == configured_dimensions_count` AND required traceability protocols covered, stable for at least `minStabilizationPasses` iterations.\n65: - **Acceptance coverage**: when the spec-folder lifecycle predicate is active, the final report records `AC_COVERAGE` status, covered/total, floor, and next action; default-off INFO output is advisory and does not by itself block STOP.\n66: - **Security-sensitive override**: when the run targets security, path handling, env precedence, schema boundaries, persistence, or shared policy, the gates from `references/convergence/convergence.md` \"Security-Sensitive Fix Overrides\" apply (`minStabilizationPasses=2`, closed-finding replay required, fix-completeness gate enforced).\n67: \n68: ---\n69: \n70: ## 4. VALIDATION SUCCESS\n71: \n72: The release-readiness handoff is valid when:\n73: \n74: - The final report records stop reason, iteration count, dimension coverage, severity counts (P0/P1/P2), verdict (PASS / CONDITIONAL / FAIL), and release-readiness state (`in-progress`, `converged`, `release-blocking`).\n75: - Verdict logic matches: PASS = no P0/P1 findings (P2 advisories permitted with `hasAdvisories: true`). CONDITIONAL = P1 findings present with remediation plan. FAIL = any P0 confirmed after adversarial self-check.\n76: - `resource-map.md` Phase-5 Augmentation section (if present) lists novel logic gaps with iteration source links, or explicitly records the empty-result case.\n77: - `skill_advisor.py \"run a deep review loop\" --threshold 0.8` still surfaces the skill after any graph-metadata edits.\n78: - `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh <spec-folder> --strict` exits 0 on the target spec folder.\n79: \n80: ---\n81: \n82: ## 5. RELATED RESOURCES\n83: \n84: - `references/protocol/loop_state_and_gates.md` -- state transitions, error handling, and the Evidence/Scope/Coverage STOP-decision gates.\n85: - `references/state/state_outputs.md` -- packet file ownership and the `review-report.md` section list.\n86: - `references/state/state_format.md` -- schemas for every state file referenced above.\n87: - `references/convergence/convergence.md` -- composite stop score, `minStabilizationPasses`, and Security-Sensitive Fix Overrides.\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Completion Criteria\ndescription: Full definition-of-done checklist for a deep-review loop -- loop completion conditions, the binary quality gates that must pass before STOP, and release-readiness validation success criteria.\ntrigger_phrases:\n  - \"review loop completion criteria\"\n  - \"review success criteria\"\n  - \"review definition of done\"\n  - \"review release readiness validation\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.0\n---\n\n# Deep Review Completion Criteria\n\nFull definition-of-done checklist for a deep-review loop: loop completion conditions, the binary quality gates STOP must clear, and release-readiness validation success criteria.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md","text":"---\ntitle: Deep Review Completion Criteria\ndescription: Full definition-of-done checklist for a deep-review loop -- loop completion conditions, the binary quality gates that must pass before STOP, and release-readiness validation success criteria.\ntrigger_phrases:\n  - \"review loop completion criteria\"\n  - \"review success criteria\"\n  - \"review definition of done\"\n  - \"review release readiness validation\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.0\n---\n\n# Deep Review Completion Criteria\n\nFull definition-of-done checklist for a deep-review loop: loop completion conditions, the binary quality gates STOP must clear, and release-readiness validation success criteria.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis reference is the authoritative checklist for \"is this review loop actually done.\" SKILL.md §6 SUCCESS CRITERIA carries a condensed summary and links here for the full enumeration; use this file when verifying a completed run, debugging a premature STOP, or reconciling completion metadata against the loop's real state.\n\n### When to Use\n\n- Verifying a review loop's completion before accepting its verdict.\n- Debugging why STOP was blocked or why synthesis produced an incomplete report.\n- Reconciling `review-report.md` claims against the canonical state files.\n- Auditing a run for the release-readiness handoff.\n\n### Relationship to `loop_state_and_gates.md`\n\n`references/protocol/loop_state_and_gates.md` defines the three state-machine-level binary gates (Evidence, Scope, Coverage) that block a STOP *decision* inside the convergence check. This file is the broader definition-of-done: it also covers artifact existence, report structure, severity-field completeness, and the release-readiness handoff -- checked once the loop believes it has already reached STOP.\n\n---\n\n## 2. LOOP COMPLETION\n\nA review loop is considered complete when every item below holds:\n\n- The loop reached convergence (composite stop score above `compositeStopScore`, with required gates green) OR hit `maxIterations` without false-positive STOP.\n- Every configured review dimension has at least one full iteration of coverage recorded in `deep-review-state.jsonl` and reflected in `deep-review-strategy.md`.\n- Required traceability protocols (`spec_code`, `checklist_evidence`) executed at least once. Overlay protocols that apply to the target type ran or were explicitly marked N/A.\n- All canonical state files exist and parse cleanly: `deep-review-config.json`, `deep-review-state.jsonl`, `deep-review-findings-registry.json`, `deep-review-strategy.md`, `deep-review-dashboard.md`, and one `iterations/iteration-NNN.md` per dispatched iteration.\n- `review/resource-map.md` was emitted from converged delta evidence unless `config.resource_map.emit == false` (operator flag `--no-resource-map`).\n- `review/review-report.md` carries all 9 core sections (Executive Summary, Planning Trigger, Active Finding Registry, Remediation Workstreams, Spec Seed, Plan Seed, Traceability Status, Deferred Items, Audit Appendix) plus the conditional `## Resource Map Coverage Gate` section when `resource_map_present == true`.\n- Canonical continuity surfaces updated via `generate-context.js` (description.json, graph-metadata.json, indexed memory entries).\n\n---\n\n## 3. QUALITY GATES\n\nEach gate is binary: pass or block. STOP cannot be legal until every gate passes.\n\n- **Config validity**: `deep-review-config.json` parses, names every required field, and lineage block matches the current run (`sessionId`, `parentSessionId`, `lineageMode`, `generation`, `continuedFromRun`, `releaseReadinessState`).\n- **Strategy initialization**: `deep-review-strategy.md` carries the Files Under Review table, Cross-Reference Status grouped by core vs overlay, Known Context, and Review Boundaries.\n- **State consistency**: `deep-review-state.jsonl` opens with the config record and appends one iteration record per dispatched iteration. Reducer-owned fields in `deep-review-findings-registry.json` reconcile against JSONL totals.\n- **Iteration completeness**: every dispatched iteration produced both an `iterations/iteration-NNN.md` (non-empty, ending with the canonical `Review verdict: PASS|CONDITIONAL|FAIL` line) AND a JSONL delta record with `findingDetails[]`, `findingsSummary`, `newFindingsRatio`.\n- **Severity coverage**: every reported finding carries `severity` in {P0, P1, P2}, `category`, `file:line` evidence, `finding_class`, and a `content_hash` for synthesis dedup.\n- **Advisory numeric score**: `riskScore` may appear in finding details as non-gating context only; verdict logic must ignore it.\n- **Adversarial replay**: every P0 finding survived adversarial self-check. Rejected P0s downgraded with rationale recorded in the iteration narrative.\n- **Coverage threshold**: `dimensions_covered_count == configured_dimensions_count` AND required traceability protocols covered, stable for at least `minStabilizationPasses` iterations.\n- **Acceptance coverage**: when the spec-folder lifecycle predicate is active, the final report records `AC_COVERAGE` status, covered/total, floor, and next action; default-off INFO output is advisory and does not by itself block STOP.\n- **Security-sensitive override**: when the run targets security, path handling, env precedence, schema boundaries, persistence, or shared policy, the gates from `references/convergence/convergence.md` \"Security-Sensitive Fix Overrides\" apply (`minStabilizationPasses=2`, closed-finding replay required, fix-completeness gate enforced).\n\n---\n\n## 4. VALIDATION SUCCESS\n\nThe release-readiness handoff is valid when:\n\n- The final report records stop reason, iteration count, dimension coverage, severity counts (P0/P1/P2), verdict (PASS / CONDITIONAL / FAIL), and release-readiness state (`in-progress`, `converged`, `release-blocking`).\n- Verdict logic matches: PASS = no P0/P1 findings (P2 advisories permitted with `hasAdvisories: true`). CONDITIONAL = P1 findings present with remediation plan. FAIL = any P0 confirmed after adversarial self-check.\n- `resource-map.md` Phase-5 Augmentation section (if present) lists novel logic gaps with iteration source links, or explicitly records the empty-result case.\n- `skill_advisor.py \"run a deep review loop\" --threshold 0.8` still surfaces the skill after any graph-metadata edits.\n- `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh <spec-folder> --strict` exits 0 on the target spec folder.\n\n---\n\n## 5. RELATED RESOURCES\n\n- `references/protocol/loop_state_and_gates.md` -- state transitions, error handling, and the Evidence/Scope/Coverage STOP-decision gates.\n- `references/state/state_outputs.md` -- packet file ownership and the `review-report.md` section list.\n- `references/state/state_format.md` -- schemas for every state file referenced above.\n- `references/convergence/convergence.md` -- composite stop score, `minStabilizationPasses`, and Security-Sensitive Fix Overrides.","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md","time":{"start":1783915553564,"end":1783915553583}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cb481918962afde838e6b4f"}},"id":"prt_f59a7231b001llyug0c2PC6gdi","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553587,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_Yg2hzJsu35kNk4DJiN7TRQbD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_state_and_gates.md","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_state_and_gates.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review State Transitions and Quality Gates\n3: description: State-transition rules, error handling, and review quality gates for the deep review loop.\n4: trigger_phrases:\n5:   - \"review state transitions\"\n6:   - \"review quality gates\"\n7:   - \"tiered error recovery\"\n8:   - \"review iteration status enum\"\n9: importance_tier: normal\n10: contextType: implementation\n11: version: 1.11.0.3\n12: ---\n13: \n14: # Deep Review State Transitions and Quality Gates\n15: \n16: This reference defines how a review run moves between states and what must hold before it can stop: the state-transition rules, error handling, and the binary review quality gates.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: This reference defines the state machine that controls a deep-review run and the gates that must pass before the loop can stop. It pairs transition rules with error recovery and binary quality gates so operators can distinguish safe STOP decisions from forced continuation.\n25: \n26: ### When to Use\n27: \n28: - Checking how a review run moves from initialization through iteration, synthesis, save, and completion.\n29: - Debugging pause, stuck-recovery, timeout, malformed state, or repeated failure behavior.\n30: - Verifying quality-gate requirements before accepting a convergence STOP decision.\n31: - Updating workflow logic that emits guard violations or recovery actions.\n32: \n33: ### Key Principle\n34: \n35: STOP is only final after convergence and quality gates agree.\n36: \n37: | Gate | Requirement |\n38: |------|-------------|\n39: | Evidence | Active findings cite concrete `file:line` evidence and avoid inference-only claims. |\n40: | Scope | Findings stay inside the declared review target and configured boundaries. |\n41: | Coverage | Required dimensions and traceability protocols are complete before STOP. |\n42: \n43: ---\n44: \n45: ## 2. STATE TRANSITIONS\n46: \n47: ```\n48: [INITIALIZED] --> config + strategy + state created, scope discovered\n49:     |\n50: [ITERATING] --> @deep-review agent dispatched, executing review cycle\n51:     |\n52: [EVALUATING] --> iteration complete, checking convergence\n53:     |\n54:     |-- newFindingsRatio >= threshold --> [ITERATING]\n55:     |-- stuck_count >= 2 --> [STUCK_RECOVERY]\n56:     |-- converged + gates pass --> [SYNTHESIZING]\n57:     |-- max_iterations reached --> [SYNTHESIZING]\n58:     |\n59: [STUCK_RECOVERY] --> change granularity / protocol replay / escalate severity\n60:     |\n61:     |-- recovered (new P0/P1 or coverage advance) --> [ITERATING]\n62:     |-- still stuck + dimensions covered --> [SYNTHESIZING] (gaps documented)\n63:     |-- still stuck + dimensions remaining --> [ITERATING] (next dimension)\n64:     |\n65: [PAUSED] --> sentinel detected, loop suspended\n66:     |\n67:     |-- sentinel removed --> [ITERATING] (resume)\n68:     |\n69: [SYNTHESIZING] --> finding dedup, severity reconcile, replay validate, compile report\n70:     |\n71: [SAVING] --> memory context preservation via generate-context.js\n72:     |\n73: [COMPLETE] --> all artifacts created, loop finished\n74: ```\n75: \n76: ### Iteration Status Enum\n77: \n78: `complete | timeout | error | stuck | insight`\n79: \n80: - `complete`: Normal iteration with findings processed\n81: - `timeout`: Iteration exceeded budget limits\n82: - `error`: Iteration failed with unrecoverable error\n83: - `stuck`: Iteration produced no meaningful new findings\n84: - `insight`: Low `newFindingsRatio` but important finding that changes the verdict trajectory\n85: \n86: ---\n87: \n88: ## 3. ERROR HANDLING\n89: \n90: | Error | Phase | Action |\n91: |-------|-------|--------|\n92: | Agent dispatch timeout | Loop | Retry once with reduced scope. If second timeout, mark iteration as \"timeout\" and continue |\n93: | State file missing | Init/Loop | Apply state recovery cascade (Section 6) |\n94: | JSONL malformed | Loop | Skip malformed lines, reconstruct from valid entries |\n95: | 3+ consecutive failures | Loop | Halt loop, enter synthesis with partial findings |\n96: | Agent dispatch failure (API overload, timeout) | Loop | Escalate through recovery tiers in order |\n97: | Memory save fails | Save | Preserve the current `review/` packet as backup, then log the error |\n98: | Iteration file not written | Loop | Mark iteration as failed, log error, continue to next |\n99: \n100: ### Tiered Error Recovery\n101: \n102: Five escalating tiers, attempted in order:\n103: \n104: | Tier | Trigger | Action | Max Attempts |\n105: |------|---------|--------|-------------|\n106: | 1 | Tool/source failure | Retry with alternative source or broader pattern | 2 per source |\n107: | 2 | Focus exhaustion (2+ low-value iterations on same focus) | Pivot to different dimension or file set | 2 pivots |\n108: | 3 | State corruption | Reconstruct JSONL from iteration files | 1 attempt |\n109: | 4 | Agent dispatch failure | Direct mode fallback (reference-only unless runtime supports it) | 1 attempt |\n110: | 5 | Repeated systemic failure | Escalate to user with diagnostic summary | 1 attempt |\n111: \n112: ---\n113: \n114: ## 4. REVIEW QUALITY GATES\n115: \n116: Evidence, Scope, and Coverage are the contract-level binary gates defined in `review_mode_contract.yaml` under `qualityGates`, evaluated after the composite convergence score exceeds the `compositeStopScore` threshold. They are necessary but not sufficient on their own: the review-specific legal-stop decision expands them into a **9-gate bundle** (`convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, `graphlessFallbackGate`) emitted by `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`. STOP is legal only when the full 9-gate bundle passes together. The authoritative gate model, event shape, and evaluation pseudocode live in `references/convergence/convergence.md` §6 \"Legal-Stop Gate Bundle\"; the 3-gate table and pseudocode below illustrate the contract-level layer only, not the complete STOP-legality check.\n117: \n118: ### Gate Definitions\n119: \n120: | Gate | Rule | Fail Action |\n121: |------|------|-------------|\n122: | **Evidence** | Every active finding has concrete `file:line` evidence and is not inference-only | Block STOP, continue loop (persisted via the `blocked_stop` event below) |\n123: | **Scope** | Findings and reviewed files stay within the declared review scope | Block STOP, continue loop (persisted via the `blocked_stop` event below) |\n124: | **Coverage** | Configured dimensions and required traceability protocols must be covered before STOP is allowed | Block STOP, continue loop (persisted via the `blocked_stop` event below) |\n125: \n126: ### Gate Evaluation Pseudocode\n127: \n128: ```\n129: function checkReviewQualityGates(state, config, coverage):\n130:   violations = []\n131: \n132:   // Evidence gate\n133:   for f in state.findings where f.status == \"active\":\n134:     if not f.hasFileLineCitation or f.evidenceType == \"inference-only\":\n135:       violations.push({ gate: \"evidence\", findingId: f.id,\n136:                         detail: \"Active finding lacks evidence or is inference-only\" })\n137: \n138:   // Scope gate\n139:   reviewScope = resolveReviewScope(config.reviewTarget, config.reviewTargetType)\n140:   for f in state.findings where f.status == \"active\":\n141:     if f.filePath not in reviewScope:\n142:       violations.push({ gate: \"scope\", findingId: f.id,\n143:                         detail: \"Finding outside declared review scope\" })\n144: \n145:   // Coverage gate\n146:   if coverage.dimensionCoverage < 1.0:\n147:     violations.push({ gate: \"coverage\",\n148:                       detail: \"Not all configured review dimensions are covered\" })\n149:   if not coverage.requiredProtocolsCovered:\n150:     violations.push({ gate: \"coverage\",\n151:                       detail: \"Required traceability protocols are incomplete\" })\n152: \n153:   if len(violations) > 0:\n154:     return { passed: false, violations }\n155:   return { passed: true }\n156: ```\n157: \n158: The contract-level check above is illustrative; it is the review-specific 9-gate bundle that actually gates STOP. When that bundle fails, the workflow does not silently override STOP to CONTINUE -- it persists a first-class `blocked_stop` event with the failing gate names and the full `gateResults` bundle:\n159: \n160: ```json\n161: {\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":N,\"blockedBy\":[\"<gate-name>\", \"...\"],\"gateResults\":{\"...\":\"...\"},\"recoveryStrategy\":\"<reason>\",\"timestamp\":\"<ISO-8601>\",\"sessionId\":\"<session-id>\",\"generation\":N}\n162: ```\n163: \n164: Full event shape and the complete 9-gate `gateResults` schema: `references/state/state_jsonl.md` \"Blocked-Stop Event\" and `references/convergence/convergence.md` §6.\n165: \n166: ---\n\n(End of file - total 166 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review State Transitions and Quality Gates\ndescription: State-transition rules, error handling, and review quality gates for the deep review loop.\ntrigger_phrases:\n  - \"review state transitions\"\n  - \"review quality gates\"\n  - \"tiered error recovery\"\n  - \"review iteration status enum\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.11.0.3\n---\n\n# Deep Review State Transitions and Quality Gates\n\nThis reference defines how a review run moves between states and what must hold before it can stop: the state-transition rules, error handling, and the binary review quality gates.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_state_and_gates.md","text":"---\ntitle: Deep Review State Transitions and Quality Gates\ndescription: State-transition rules, error handling, and review quality gates for the deep review loop.\ntrigger_phrases:\n  - \"review state transitions\"\n  - \"review quality gates\"\n  - \"tiered error recovery\"\n  - \"review iteration status enum\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.11.0.3\n---\n\n# Deep Review State Transitions and Quality Gates\n\nThis reference defines how a review run moves between states and what must hold before it can stop: the state-transition rules, error handling, and the binary review quality gates.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis reference defines the state machine that controls a deep-review run and the gates that must pass before the loop can stop. It pairs transition rules with error recovery and binary quality gates so operators can distinguish safe STOP decisions from forced continuation.\n\n### When to Use\n\n- Checking how a review run moves from initialization through iteration, synthesis, save, and completion.\n- Debugging pause, stuck-recovery, timeout, malformed state, or repeated failure behavior.\n- Verifying quality-gate requirements before accepting a convergence STOP decision.\n- Updating workflow logic that emits guard violations or recovery actions.\n\n### Key Principle\n\nSTOP is only final after convergence and quality gates agree.\n\n| Gate | Requirement |\n|------|-------------|\n| Evidence | Active findings cite concrete `file:line` evidence and avoid inference-only claims. |\n| Scope | Findings stay inside the declared review target and configured boundaries. |\n| Coverage | Required dimensions and traceability protocols are complete before STOP. |\n\n---\n\n## 2. STATE TRANSITIONS\n\n```\n[INITIALIZED] --> config + strategy + state created, scope discovered\n    |\n[ITERATING] --> @deep-review agent dispatched, executing review cycle\n    |\n[EVALUATING] --> iteration complete, checking convergence\n    |\n    |-- newFindingsRatio >= threshold --> [ITERATING]\n    |-- stuck_count >= 2 --> [STUCK_RECOVERY]\n    |-- converged + gates pass --> [SYNTHESIZING]\n    |-- max_iterations reached --> [SYNTHESIZING]\n    |\n[STUCK_RECOVERY] --> change granularity / protocol replay / escalate severity\n    |\n    |-- recovered (new P0/P1 or coverage advance) --> [ITERATING]\n    |-- still stuck + dimensions covered --> [SYNTHESIZING] (gaps documented)\n    |-- still stuck + dimensions remaining --> [ITERATING] (next dimension)\n    |\n[PAUSED] --> sentinel detected, loop suspended\n    |\n    |-- sentinel removed --> [ITERATING] (resume)\n    |\n[SYNTHESIZING] --> finding dedup, severity reconcile, replay validate, compile report\n    |\n[SAVING] --> memory context preservation via generate-context.js\n    |\n[COMPLETE] --> all artifacts created, loop finished\n```\n\n### Iteration Status Enum\n\n`complete | timeout | error | stuck | insight`\n\n- `complete`: Normal iteration with findings processed\n- `timeout`: Iteration exceeded budget limits\n- `error`: Iteration failed with unrecoverable error\n- `stuck`: Iteration produced no meaningful new findings\n- `insight`: Low `newFindingsRatio` but important finding that changes the verdict trajectory\n\n---\n\n## 3. ERROR HANDLING\n\n| Error | Phase | Action |\n|-------|-------|--------|\n| Agent dispatch timeout | Loop | Retry once with reduced scope. If second timeout, mark iteration as \"timeout\" and continue |\n| State file missing | Init/Loop | Apply state recovery cascade (Section 6) |\n| JSONL malformed | Loop | Skip malformed lines, reconstruct from valid entries |\n| 3+ consecutive failures | Loop | Halt loop, enter synthesis with partial findings |\n| Agent dispatch failure (API overload, timeout) | Loop | Escalate through recovery tiers in order |\n| Memory save fails | Save | Preserve the current `review/` packet as backup, then log the error |\n| Iteration file not written | Loop | Mark iteration as failed, log error, continue to next |\n\n### Tiered Error Recovery\n\nFive escalating tiers, attempted in order:\n\n| Tier | Trigger | Action | Max Attempts |\n|------|---------|--------|-------------|\n| 1 | Tool/source failure | Retry with alternative source or broader pattern | 2 per source |\n| 2 | Focus exhaustion (2+ low-value iterations on same focus) | Pivot to different dimension or file set | 2 pivots |\n| 3 | State corruption | Reconstruct JSONL from iteration files | 1 attempt |\n| 4 | Agent dispatch failure | Direct mode fallback (reference-only unless runtime supports it) | 1 attempt |\n| 5 | Repeated systemic failure | Escalate to user with diagnostic summary | 1 attempt |\n\n---\n\n## 4. REVIEW QUALITY GATES\n\nEvidence, Scope, and Coverage are the contract-level binary gates defined in `review_mode_contract.yaml` under `qualityGates`, evaluated after the composite convergence score exceeds the `compositeStopScore` threshold. They are necessary but not sufficient on their own: the review-specific legal-stop decision expands them into a **9-gate bundle** (`convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, `graphlessFallbackGate`) emitted by `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`. STOP is legal only when the full 9-gate bundle passes together. The authoritative gate model, event shape, and evaluation pseudocode live in `references/convergence/convergence.md` §6 \"Legal-Stop Gate Bundle\"; the 3-gate table and pseudocode below illustrate the contract-level layer only, not the complete STOP-legality check.\n\n### Gate Definitions\n\n| Gate | Rule | Fail Action |\n|------|------|-------------|\n| **Evidence** | Every active finding has concrete `file:line` evidence and is not inference-only | Block STOP, continue loop (persisted via the `blocked_stop` event below) |\n| **Scope** | Findings and reviewed files stay within the declared review scope | Block STOP, continue loop (persisted via the `blocked_stop` event below) |\n| **Coverage** | Configured dimensions and required traceability protocols must be covered before STOP is allowed | Block STOP, continue loop (persisted via the `blocked_stop` event below) |\n\n### Gate Evaluation Pseudocode\n\n```\nfunction checkReviewQualityGates(state, config, coverage):\n  violations = []\n\n  // Evidence gate\n  for f in state.findings where f.status == \"active\":\n    if not f.hasFileLineCitation or f.evidenceType == \"inference-only\":\n      violations.push({ gate: \"evidence\", findingId: f.id,\n                        detail: \"Active finding lacks evidence or is inference-only\" })\n\n  // Scope gate\n  reviewScope = resolveReviewScope(config.reviewTarget, config.reviewTargetType)\n  for f in state.findings where f.status == \"active\":\n    if f.filePath not in reviewScope:\n      violations.push({ gate: \"scope\", findingId: f.id,\n                        detail: \"Finding outside declared review scope\" })\n\n  // Coverage gate\n  if coverage.dimensionCoverage < 1.0:\n    violations.push({ gate: \"coverage\",\n                      detail: \"Not all configured review dimensions are covered\" })\n  if not coverage.requiredProtocolsCovered:\n    violations.push({ gate: \"coverage\",\n                      detail: \"Required traceability protocols are incomplete\" })\n\n  if len(violations) > 0:\n    return { passed: false, violations }\n  return { passed: true }\n```\n\nThe contract-level check above is illustrative; it is the review-specific 9-gate bundle that actually gates STOP. When that bundle fails, the workflow does not silently override STOP to CONTINUE -- it persists a first-class `blocked_stop` event with the failing gate names and the full `gateResults` bundle:\n\n```json\n{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":N,\"blockedBy\":[\"<gate-name>\", \"...\"],\"gateResults\":{\"...\":\"...\"},\"recoveryStrategy\":\"<reason>\",\"timestamp\":\"<ISO-8601>\",\"sessionId\":\"<session-id>\",\"generation\":N}\n```\n\nFull event shape and the complete 9-gate `gateResults` schema: `references/state/state_jsonl.md` \"Blocked-Stop Event\" and `references/convergence/convergence.md` §6.\n\n---","lineStart":1,"lineEnd":166,"totalLines":166,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/protocol/loop_state_and_gates.md","time":{"start":1783915553566,"end":1783915553584}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cb88191b8ccefd3a400bdd7"}},"id":"prt_f59a7231d0012QktUEknBMt1n0","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553598,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_aDbJ0UCfmDopqvhm00XEWB5T","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"topic\": \"\",\n3:   \"sessionId\": \"\",\n4:   \"parentSessionId\": null,\n5:   \"lineageMode\": \"new\",\n6:   \"generation\": 1,\n7:   \"continuedFromRun\": null,\n8:   \"migrationWindowEndsAt\": \"\",\n9:   \"maxIterations\": 7,\n10:   \"convergenceThreshold\": 0.10,\n11:   \"antiConvergence\": {\n12:     \"minIterations\": 2,\n13:     \"convergenceMode\": \"default\",\n14:     \"stopPolicy\": \"fail-closed\"\n15:   },\n16:   \"stuckThreshold\": 2,\n17:   \"maxDurationMinutes\": 120,\n18:   \"maxToolCallsPerIteration\": 12,\n19:   \"maxMinutesPerIteration\": 10,\n20:   \"progressiveSynthesis\": false,\n21:   \"specFolder\": \"\",\n22:   \"createdAt\": \"\",\n23:   \"status\": \"initialized\",\n24:   \"releaseReadinessState\": \"in-progress\",\n25:   \"executionMode\": \"auto\",\n26:   \"executor\": {\n27:     \"kind\": \"native\",\n28:     \"model\": null,\n29:     \"reasoningEffort\": null,\n30:     \"serviceTier\": null,\n31:     \"sandboxMode\": null,\n32:     \"timeoutSeconds\": 900\n33:   },\n34:   \"mode\": \"review\",\n35:   \"reviewTarget\": \"\",\n36:   \"reviewTargetType\": \"spec-folder\",\n37:   \"reviewDimensions\": [\n38:     \"correctness\",\n39:     \"security\",\n40:     \"traceability\",\n41:     \"maintainability\"\n42:   ],\n43:   \"severityThreshold\": \"P2\",\n44:   \"crossReference\": {\n45:     \"core\": [\n46:       \"spec_code\",\n47:       \"checklist_evidence\"\n48:     ],\n49:     \"overlay\": [\n50:       \"skill_agent\",\n51:       \"agent_cross_runtime\",\n52:       \"feature_catalog_code\",\n53:       \"playbook_capability\"\n54:     ]\n55:   },\n56:   \"qualityGateThreshold\": true,\n57:   \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-review/scripts/runtime-capabilities.cjs\",\n58:   \"reducerScriptPath\": \".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs\",\n59:   \"fileProtection\": {\n60:     \"deep-review-config.json\": \"immutable\",\n61:     \"deep-review-state.jsonl\": \"append-only\",\n62:     \"deep-review-findings-registry.json\": \"auto-generated\",\n63:     \"deep-review-strategy.md\": \"mutable\",\n64:     \"deep-review-dashboard.md\": \"auto-generated\",\n65:     \".deep-review-pause\": \"operator-controlled\",\n66:     \"review-report.md\": \"mutable\",\n67:     \"review-report-v*.md\": \"write-once\",\n68:     \"iteration-*.md\": \"write-once\"\n69:   },\n70:   \"reducer\": {\n71:     \"enabled\": true,\n72:     \"inputs\": [\n73:       \"latestJSONLDelta\",\n74:       \"newIterationFile\",\n75:       \"priorReducedState\"\n76:     ],\n77:     \"outputs\": [\n78:       \"findingsRegistry\",\n79:       \"dashboardMetrics\",\n80:       \"strategyUpdates\"\n81:     ],\n82:     \"metrics\": [\n83:       \"dimensionsCovered\",\n84:       \"findingsBySeverity\",\n85:       \"openFindings\",\n86:       \"resolvedFindings\",\n87:       \"convergenceScore\"\n88:     ]\n89:   },\n90:   \"_optimizerManaged\": {\n91:     \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n92:     \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n93:     \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n94:     \"lockedFields\": [\"lineageMode\", \"reducer\", \"fileProtection\", \"sessionId\", \"mode\", \"reviewDimensions\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n95:     \"promotionMode\": \"advisory-only\"\n96:   }\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"{\n  \"topic\": \"\",\n  \"sessionId\": \"\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"migrationWindowEndsAt\": \"\",\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"antiConvergence\": {\n    \"minIterations\": 2,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json","text":"{\n  \"topic\": \"\",\n  \"sessionId\": \"\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"migrationWindowEndsAt\": \"\",\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"antiConvergence\": {\n    \"minIterations\": 2,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"releaseReadinessState\": \"in-progress\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",\n    \"model\": null,\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900\n  },\n  \"mode\": \"review\",\n  \"reviewTarget\": \"\",\n  \"reviewTargetType\": \"spec-folder\",\n  \"reviewDimensions\": [\n    \"correctness\",\n    \"security\",\n    \"traceability\",\n    \"maintainability\"\n  ],\n  \"severityThreshold\": \"P2\",\n  \"crossReference\": {\n    \"core\": [\n      \"spec_code\",\n      \"checklist_evidence\"\n    ],\n    \"overlay\": [\n      \"skill_agent\",\n      \"agent_cross_runtime\",\n      \"feature_catalog_code\",\n      \"playbook_capability\"\n    ]\n  },\n  \"qualityGateThreshold\": true,\n  \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-review/scripts/runtime-capabilities.cjs\",\n  \"reducerScriptPath\": \".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs\",\n  \"fileProtection\": {\n    \"deep-review-config.json\": \"immutable\",\n    \"deep-review-state.jsonl\": \"append-only\",\n    \"deep-review-findings-registry.json\": \"auto-generated\",\n    \"deep-review-strategy.md\": \"mutable\",\n    \"deep-review-dashboard.md\": \"auto-generated\",\n    \".deep-review-pause\": \"operator-controlled\",\n    \"review-report.md\": \"mutable\",\n    \"review-report-v*.md\": \"write-once\",\n    \"iteration-*.md\": \"write-once\"\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"inputs\": [\n      \"latestJSONLDelta\",\n      \"newIterationFile\",\n      \"priorReducedState\"\n    ],\n    \"outputs\": [\n      \"findingsRegistry\",\n      \"dashboardMetrics\",\n      \"strategyUpdates\"\n    ],\n    \"metrics\": [\n      \"dimensionsCovered\",\n      \"findingsBySeverity\",\n      \"openFindings\",\n      \"resolvedFindings\",\n      \"convergenceScore\"\n    ]\n  },\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n    \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n    \"lockedFields\": [\"lineageMode\", \"reducer\", \"fileProtection\", \"sessionId\", \"mode\", \"reviewDimensions\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n    \"promotionMode\": \"advisory-only\"\n  }\n}","lineStart":1,"lineEnd":97,"totalLines":97,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json","time":{"start":1783915553588,"end":1783915553593}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cc08191add533c6cfe56ab6"}},"id":"prt_f59a7231f001ueFX2eKFD752nh","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553598,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_WYWz7XyM5EPmU8m43eDAgEqx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Strategy Template\n3: description: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\n4: trigger_phrases:\n5:   - \"deep review strategy template\"\n6:   - \"review dimension tracking\"\n7:   - \"exhausted review approaches\"\n8:   - \"review session tracking\"\n9: importance_tier: normal\n10: contextType: planning\n11: version: 1.11.0.13\n12: ---\n13: \n14: # Deep Review Strategy - Session Tracking Template\n15: \n16: Runtime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n17: \n18: ## 1. OVERVIEW\n19: \n20: ### Purpose\n21: \n22: Serves as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n23: \n24: ### Usage\n25: \n26: - **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n27: - **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n28: - **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.\n29: - **Protection:** None (shared mutable state). Orchestrator validates consistency on resume.\n30: - **Ownership:** Machine-managed metrics and coverage blocks are wrapped in explicit ownership markers. Human commentary and operator overrides live outside those markers.\n31: \n32: ---\n33: \n34: ## 2. TOPIC\n35: [Review target description from config -- set during initialization]\n36: \n37: ---\n38: \n39: ## 3. REVIEW DIMENSIONS (remaining)\n40: <!-- MACHINE-OWNED: START -->\n41: - [ ] D1 Correctness, Logic errors, off-by-one, wrong return types, broken invariants\n42: - [ ] D2 Security, Injection, auth bypass, secrets exposure, unsafe deserialization\n43: - [ ] D3 Traceability, Spec/code alignment, checklist evidence, cross-reference integrity\n44: - [ ] D4 Maintainability, Patterns, clarity, documentation quality, safe follow-on change cost\n45: <!-- MACHINE-OWNED: END -->\n46: \n47: ---\n48: \n49: ## 4. NON-GOALS\n50: [What this review session is NOT trying to assess -- populated during initialization]\n51: \n52: ---\n53: \n54: ## 5. STOP CONDITIONS\n55: [Explicit conditions beyond convergence that should end the session -- populated during initialization]\n56: \n57: ---\n58: \n59: ## 6. COMPLETED DIMENSIONS\n60: <!-- MACHINE-OWNED: START -->\n61: [None yet -- populated as iterations complete dimension reviews]\n62: \n63: | Dimension | Verdict | Iteration | Summary |\n64: |-----------|---------|-----------|---------|\n65: | [D1 Correctness] | [PASS/CONDITIONAL/FAIL] | [N] | [1-sentence result] |\n66: <!-- MACHINE-OWNED: END -->\n67: \n68: ---\n69: \n70: ## 7. RUNNING FINDINGS\n71: <!-- MACHINE-OWNED: START -->\n72: - **P0 (Critical):** 0 active\n73: - **P1 (Major):** 0 active\n74: - **P2 (Minor):** 0 active\n75: - **Delta this iteration:** +0 P0, +0 P1, +0 P2\n76: \n77: [Findings are tracked in `deep-review-findings-registry.json`. This section provides a running count summary updated after each iteration.]\n78: <!-- MACHINE-OWNED: END -->\n79: \n80: ---\n81: \n82: ## 8. WHAT WORKED\n83: [First iteration -- populated after iteration 1 completes]\n84: - [Approach]: [Why it worked] (iteration N)\n85: \n86: ---\n87: \n88: ## 9. WHAT FAILED\n89: [First iteration -- populated after iteration 1 completes]\n90: - [Approach]: [Why it failed] (iteration N)\n91: \n92: ---\n93: \n94: ## 10. EXHAUSTED APPROACHES (do not retry)\n95: [Populated when a review approach has been tried from multiple angles without yielding new findings]\n96: \n97: ### [Category Name] -- BLOCKED (iteration N, N attempts)\n98: - What was tried: [specific review approaches attempted]\n99: - Why blocked: [root cause of exhaustion]\n100: - Do NOT retry: [explicit prohibition]\n101: \n102: ### [Category Name] -- PRODUCTIVE (iteration N)\n103: - What worked: [successful review approaches in this category]\n104: - Prefer for: [related dimensions where this category may help]\n105: \n106: ---\n107: \n108: ## 10A. SATURATED / SWEPT DIMENSIONS AND EXPANSION FRONTIER\n109: <!-- MACHINE-OWNED: START -->\n110: - Completed pivots: 0\n111: - Failed pivots: 0\n112: - Audited overrides: 0\n113: - Swept: none yet\n114: - Pivot lineage: none yet\n115: - Remaining frontier: none recorded\n116: <!-- MACHINE-OWNED: END -->\n117: \n118: ---\n119: \n120: ## 11. RULED OUT DIRECTIONS\n121: [Review angles that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n122: - [Approach]: [Why ruled out] (iteration N, evidence: [source])\n123: \n124: ---\n125: \n126: ## 12. NEXT FOCUS\n127: <!-- MACHINE-OWNED: START -->\n128: [Recommended focus area for the next iteration -- updated at end of each iteration. Includes target dimension and/or specific files to review.]\n129: <!-- MACHINE-OWNED: END -->\n130: \n131: ---\n132: \n133: ## 13. KNOWN CONTEXT\n134: [Populated during initialization from memory_context() results, if any prior work exists]\n135: \n136: ### Bounded Context Snapshot\n137: \n138: Populate during initialization before the first review dimension runs. Keep this pointer-based and scoped to the declared review target:\n139: \n140: - Target pointers: files, specs, symbols, or resource-map entries under review.\n141: - Behavior claims: acceptance criteria, public contracts, or docs to verify.\n142: - Reuse and conventions: existing patterns that define expected implementation shape.\n143: - Review risks and gaps: stale graph or memory caveats, missing files, and out-of-scope areas.\n144: \n145: Do not inline full source bodies. Do not dispatch the retired standalone context loop. Use this snapshot only to seed review dimensions and final traceability.\n146: \n147: ---\n148: \n149: ## 14. CROSS-REFERENCE STATUS\n150: <!-- MACHINE-OWNED: START -->\n151: [Alignment checks completed across core and overlay protocols]\n152: \n153: | Protocol | Level | Status | Iteration | Notes |\n154: |----------|-------|--------|-----------|-------|\n155: | `spec_code` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n156: | `checklist_evidence` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n157: | `skill_agent` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n158: | `agent_cross_runtime` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n159: | `feature_catalog_code` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n160: | `playbook_capability` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n161: <!-- MACHINE-OWNED: END -->\n162: \n163: ---\n164: \n165: ## 15. FILES UNDER REVIEW\n166: <!-- MACHINE-OWNED: START -->\n167: [Per-file coverage state table -- populated during initialization from scope discovery]\n168: \n169: | File | Dimensions Reviewed | Last Iteration | Findings | Status |\n170: |------|-------------------|----------------|----------|--------|\n171: | [path/to/file] | [D1, D3] | [N] | [0 P0, 1 P1, 2 P2] | [partial/complete] |\n172: <!-- MACHINE-OWNED: END -->\n173: \n174: ---\n175: \n176: ## 16. REVIEW BOUNDARIES\n177: <!-- MACHINE-OWNED: START -->\n178: - Max iterations: [from config]\n179: - Convergence threshold: [from config]\n180: - Rolling STOP threshold: 0.08\n181: - No-progress threshold: 0.05\n182: - Coverage stabilization passes required: 1\n183: - Session lineage: sessionId=[from config.sessionId], parentSessionId=[from config.parentSessionId], generation=[from config.generation], lineageMode=[from config.lineageMode]\n184: - Findings registry: `deep-review-findings-registry.json`\n185: - Release-readiness states: in-progress | converged | release-blocking\n186: - Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n187: - Severity threshold: [from config.severityThreshold]\n188: - Review target type: [from config.reviewTargetType]\n189: - Cross-reference checks: core=[from config.crossReference.core], overlay=[from config.crossReference.overlay]\n190: - Started: [timestamp]\n191: <!-- MACHINE-OWNED: END -->\n192: \n193: ---\n194: \n195: ## 17. EXAMPLE (POPULATED)\n196: \n197: Reference snippet showing a partially populated strategy file mid-review. Use this as a visual anchor when opening a live strategy doc.\n198: \n199: ```markdown\n200: ## 1. REVIEW CHARTER\n201: - Target: .opencode/skills/system-deep-loop/deep-research (skill, v1.4.0)\n202: - Dimensions: correctness, test-coverage, cross-runtime-parity, observability\n203: - Stop conditions: rolling newInfoRatio < 0.08 for 2 iterations OR all dimensions converged OR max=7 reached\n204: - Success criteria: zero P0 in correctness; test-coverage P0 resolved or deferred with rationale\n205: \n206: ## 4. NEXT FOCUS\n207: - Dimension: test-coverage\n208: - Files: .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs, .opencode/skills/system-spec-kit/scripts/tests/deep-research-contract-parity.vitest.ts\n209: - Why: Iteration 2 surfaced a P0 (convergence-path coverage gap); needs a focused follow-up before correctness can terminate PASS.\n210: \n211: ## 9. COVERAGE MATRIX\n212: | Dimension            | Status     | Iterations touched |\n213: |----------------------|------------|--------------------|\n214: | correctness          | converged  | 1                  |\n215: | test-coverage        | converging | 2, 4               |\n216: | cross-runtime-parity | converging | 3                  |\n217: | observability        | converging | 4                  |\n218: ```\n\n(End of file - total 218 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Strategy Template\ndescription: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep review strategy template\"\n  - \"review dimension tracking\"\n  - \"exhausted review approaches\"\n  - \"review session tracking\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.11.0.13\n---\n\n# Deep Review Strategy - Session Tracking Template\n\nRuntime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md","text":"---\ntitle: Deep Review Strategy Template\ndescription: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep review strategy template\"\n  - \"review dimension tracking\"\n  - \"exhausted review approaches\"\n  - \"review session tracking\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.11.0.13\n---\n\n# Deep Review Strategy - Session Tracking Template\n\nRuntime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose\n\nServes as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n\n### Usage\n\n- **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n- **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n- **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.\n- **Protection:** None (shared mutable state). Orchestrator validates consistency on resume.\n- **Ownership:** Machine-managed metrics and coverage blocks are wrapped in explicit ownership markers. Human commentary and operator overrides live outside those markers.\n\n---\n\n## 2. TOPIC\n[Review target description from config -- set during initialization]\n\n---\n\n## 3. REVIEW DIMENSIONS (remaining)\n<!-- MACHINE-OWNED: START -->\n- [ ] D1 Correctness, Logic errors, off-by-one, wrong return types, broken invariants\n- [ ] D2 Security, Injection, auth bypass, secrets exposure, unsafe deserialization\n- [ ] D3 Traceability, Spec/code alignment, checklist evidence, cross-reference integrity\n- [ ] D4 Maintainability, Patterns, clarity, documentation quality, safe follow-on change cost\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 4. NON-GOALS\n[What this review session is NOT trying to assess -- populated during initialization]\n\n---\n\n## 5. STOP CONDITIONS\n[Explicit conditions beyond convergence that should end the session -- populated during initialization]\n\n---\n\n## 6. COMPLETED DIMENSIONS\n<!-- MACHINE-OWNED: START -->\n[None yet -- populated as iterations complete dimension reviews]\n\n| Dimension | Verdict | Iteration | Summary |\n|-----------|---------|-----------|---------|\n| [D1 Correctness] | [PASS/CONDITIONAL/FAIL] | [N] | [1-sentence result] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 7. RUNNING FINDINGS\n<!-- MACHINE-OWNED: START -->\n- **P0 (Critical):** 0 active\n- **P1 (Major):** 0 active\n- **P2 (Minor):** 0 active\n- **Delta this iteration:** +0 P0, +0 P1, +0 P2\n\n[Findings are tracked in `deep-review-findings-registry.json`. This section provides a running count summary updated after each iteration.]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 8. WHAT WORKED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it worked] (iteration N)\n\n---\n\n## 9. WHAT FAILED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it failed] (iteration N)\n\n---\n\n## 10. EXHAUSTED APPROACHES (do not retry)\n[Populated when a review approach has been tried from multiple angles without yielding new findings]\n\n### [Category Name] -- BLOCKED (iteration N, N attempts)\n- What was tried: [specific review approaches attempted]\n- Why blocked: [root cause of exhaustion]\n- Do NOT retry: [explicit prohibition]\n\n### [Category Name] -- PRODUCTIVE (iteration N)\n- What worked: [successful review approaches in this category]\n- Prefer for: [related dimensions where this category may help]\n\n---\n\n## 10A. SATURATED / SWEPT DIMENSIONS AND EXPANSION FRONTIER\n<!-- MACHINE-OWNED: START -->\n- Completed pivots: 0\n- Failed pivots: 0\n- Audited overrides: 0\n- Swept: none yet\n- Pivot lineage: none yet\n- Remaining frontier: none recorded\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 11. RULED OUT DIRECTIONS\n[Review angles that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n- [Approach]: [Why ruled out] (iteration N, evidence: [source])\n\n---\n\n## 12. NEXT FOCUS\n<!-- MACHINE-OWNED: START -->\n[Recommended focus area for the next iteration -- updated at end of each iteration. Includes target dimension and/or specific files to review.]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 13. KNOWN CONTEXT\n[Populated during initialization from memory_context() results, if any prior work exists]\n\n### Bounded Context Snapshot\n\nPopulate during initialization before the first review dimension runs. Keep this pointer-based and scoped to the declared review target:\n\n- Target pointers: files, specs, symbols, or resource-map entries under review.\n- Behavior claims: acceptance criteria, public contracts, or docs to verify.\n- Reuse and conventions: existing patterns that define expected implementation shape.\n- Review risks and gaps: stale graph or memory caveats, missing files, and out-of-scope areas.\n\nDo not inline full source bodies. Do not dispatch the retired standalone context loop. Use this snapshot only to seed review dimensions and final traceability.\n\n---\n\n## 14. CROSS-REFERENCE STATUS\n<!-- MACHINE-OWNED: START -->\n[Alignment checks completed across core and overlay protocols]\n\n| Protocol | Level | Status | Iteration | Notes |\n|----------|-------|--------|-----------|-------|\n| `spec_code` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n| `checklist_evidence` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n| `skill_agent` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `agent_cross_runtime` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `feature_catalog_code` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `playbook_capability` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 15. FILES UNDER REVIEW\n<!-- MACHINE-OWNED: START -->\n[Per-file coverage state table -- populated during initialization from scope discovery]\n\n| File | Dimensions Reviewed | Last Iteration | Findings | Status |\n|------|-------------------|----------------|----------|--------|\n| [path/to/file] | [D1, D3] | [N] | [0 P0, 1 P1, 2 P2] | [partial/complete] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 16. REVIEW BOUNDARIES\n<!-- MACHINE-OWNED: START -->\n- Max iterations: [from config]\n- Convergence threshold: [from config]\n- Rolling STOP threshold: 0.08\n- No-progress threshold: 0.05\n- Coverage stabilization passes required: 1\n- Session lineage: sessionId=[from config.sessionId], parentSessionId=[from config.parentSessionId], generation=[from config.generation], lineageMode=[from config.lineageMode]\n- Findings registry: `deep-review-findings-registry.json`\n- Release-readiness states: in-progress | converged | release-blocking\n- Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n- Severity threshold: [from config.severityThreshold]\n- Review target type: [from config.reviewTargetType]\n- Cross-reference checks: core=[from config.crossReference.core], overlay=[from config.crossReference.overlay]\n- Started: [timestamp]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 17. EXAMPLE (POPULATED)\n\nReference snippet showing a partially populated strategy file mid-review. Use this as a visual anchor when opening a live strategy doc.\n\n```markdown\n## 1. REVIEW CHARTER\n- Target: .opencode/skills/system-deep-loop/deep-research (skill, v1.4.0)\n- Dimensions: correctness, test-coverage, cross-runtime-parity, observability\n- Stop conditions: rolling newInfoRatio < 0.08 for 2 iterations OR all dimensions converged OR max=7 reached\n- Success criteria: zero P0 in correctness; test-coverage P0 resolved or deferred with rationale\n\n## 4. NEXT FOCUS\n- Dimension: test-coverage\n- Files: .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs, .opencode/skills/system-spec-kit/scripts/tests/deep-research-contract-parity.vitest.ts\n- Why: Iteration 2 surfaced a P0 (convergence-path coverage gap); needs a focused follow-up before correctness can terminate PASS.\n\n## 9. COVERAGE MATRIX\n| Dimension            | Status     | Iterations touched |\n|----------------------|------------|--------------------|\n| correctness          | converged  | 1                  |\n| test-coverage        | converging | 2, 4               |\n| cross-runtime-parity | converging | 3                  |\n| observability        | converging | 4                  |\n```","lineStart":1,"lineEnd":218,"totalLines":218,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md","time":{"start":1783915553590,"end":1783915553594}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cc88191a9d70c2680689b2f"}},"id":"prt_f59a72335001w0yJvAGgSFCahY","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553609,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_ZOHNFH4w8yW4TDaQGZNmXlNm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl</path>\n<type>file</type>\n<content>\n1: DEEP-REVIEW\n2: Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true\n3: \n4: # Deep-Review Iteration Prompt Pack\n5: \n6: This prompt pack renders the per-iteration context for the `@deep-review` LEAF agent (native executor) or a CLI executor (e.g. `opencode run`). Tokens use curly-brace syntax and are substituted by `renderPromptPack` before dispatch.\n7: \n8: ## STATE\n9: \n10: {state_summary}\n11: \n12: Review Iteration: {current_iteration} of {max_iterations}\n13: Mode: review\n14: Dimension: {next_dimension}\n15: Review Target: {review_target}\n16: Review Scope Files: {review_scope_files}\n17: Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n18: \n19: ## PIVOT LINEAGE\n20: \n21: {pivot_lineage}\n22: \n23: Swept or saturated review directions that MUST NOT be re-entered:\n24: {saturated_directions}\n25: \n26: ## SHARED DOCTRINE\n27: \n28: Load `.opencode/skills/sk-code/code-review/references/review_core.md` before final severity calls.\n29: \n30: ## REVIEW DIMENSIONS\n31: \n32: correctness, security, traceability, maintainability\n33: \n34: ## TRACEABILITY PROTOCOLS\n35: \n36: - **Core**: spec_code, checklist_evidence\n37: - **Overlay**: skill_agent, agent_cross_runtime, feature_catalog_code, playbook_capability\n38: \n39: ## QUALITY GATES\n40: \n41: evidence, scope, coverage\n42: \n43: ## VERDICTS\n44: \n45: `FAIL | CONDITIONAL | PASS`, PASS may set `hasAdvisories=true` when only P2 remain.\n46: \n47: ## CLAIM ADJUDICATION\n48: \n49: Every new P0/P1 must include: claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, and downgradeTrigger.\n50: \n51: ## STATE FILES\n52: \n53: All paths are relative to the repo root.\n54: \n55: - Config: {state_paths_config}\n56: - State Log: {state_paths_state_log}\n57: - Findings Registry: {state_paths_findings_registry}\n58: - Strategy: {state_paths_strategy}\n59: - Write iteration narrative to: {state_paths_iteration_pattern}\n60: - Write per-iteration delta file to: {state_paths_delta_pattern}\n61: \n62: ## CONSTRAINTS\n63: \n64: - You are a LEAF agent. Do NOT dispatch sub-agents.\n65: - Target 9 tool calls. Soft max 12, hard max 13.\n66: - Write ALL findings to files. Do not hold in context.\n67: - Review target is READ-ONLY. Do not modify reviewed files.\n68: - Do not re-enter or restate any direction listed as swept or saturated above. The pivot-selected focus is a new read-only review direction, never permission to change the target.\n69: - Do not implement fixes during review. Report findings only; implementation is a separate follow-up step.\n70: - **ALLOWED WRITE PATHS (the ONLY paths you may create, modify, or append to)**:\n71:   - `{state_paths_iteration_pattern}`, this iteration's narrative markdown\n72:   - `{state_paths_state_log}`, append-only JSONL state log\n73:   - `{state_paths_delta_pattern}`, this iteration's delta JSONL\n74:   - `{state_paths_strategy}`, strategy.md (in-place updates only)\n75: - **BANNED OPERATIONS (NEVER execute against any path)**: `rm`, `rm -rf`, `git rm`, `mv`, `sed -i` (including `sed -i ''`), `rmdir`, `find ... -delete`, shell output-redirect truncate `>` against any file not in the allowed-write list, and any tool call whose effect is to delete, rename, or replace a file outside the allowed-write list. Reading is unrestricted; **writing, renaming, and deleting are scoped**.\n76: - **SCOPE VIOLATION PROTOCOL**: if your plan would require modifying any path NOT in the allowed-write list, you MUST STOP that action and emit a finding instead. Record the would-be mutation as a `scope_violation` entry in the iteration narrative (under a `## SCOPE VIOLATIONS` heading) and continue the review. NEVER execute the out-of-scope mutation. The review packet (`{state_paths_iteration_pattern}` directory and parents) is the only zone for your writes; the reviewed target spec/code is off-limits.\n77: - Append JSONL record with dimensions, filesReviewed, findingsSummary, findingsNew, traceabilityChecks, newFindingsRatio, and optional graphEvents.\n78: - When emitting the iteration JSONL record, include an optional `graphEvents` array representing coverage graph nodes and edges discovered this iteration. Omit the field when no graph events are produced. Each event MUST use one of these two EXACT shapes. The reducer discriminates node vs edge by `type`, then validates each node's `kind` against the node vocabulary and each edge's `relation` against the relation vocabulary — any event outside these vocabularies is silently dropped, and if every event is dropped the convergence graph stays empty (nodeCount 0, empty signals):\n79:   - Node: `{\"type\":\"node\",\"id\":\"<stable-id>\",\"kind\":\"<SLICE|DIMENSION|FILE|FINDING|EVIDENCE|REMEDIATION|BUG_CLASS|INVARIANT|PRODUCER|CONSUMER|TEST>\",\"label\":\"<short human name>\"}` — the semantic kind goes in the dedicated `kind` field (uppercase, one of those listed); `label` is a free-text display name ONLY, never the kind.\n80:   - Edge: `{\"type\":\"edge\",\"id\":\"<stable-id>\",\"source\":\"<nodeId>\",\"target\":\"<nodeId>\",\"relation\":\"<COVERS|EVIDENCE_FOR|CONTRADICTS|RESOLVES|CONFIRMS|ESCALATES|IN_DIMENSION|IN_FILE>\"}` — use `source`/`target`/`relation` (NOT `from`/`to`/`label`); `source` and `target` must reference node `id`s.\n81: \n82: ## OUTPUT CONTRACT\n83: \n84: You MUST produce THREE artifacts per iteration. The YAML-owned post_dispatch_validate step emits a `schema_mismatch` conflict event if any is missing or malformed.\n85: \n86: 1. **Iteration narrative markdown** at `{state_paths_iteration_pattern}` (path pre-substituted for the current iteration number). Structure: headings for Dimension, Files Reviewed, Findings by Severity (P0/P1/P2), Traceability Checks, Verdict, Next Dimension.\n87: \n88: 2. **Canonical JSONL iteration record** APPENDED to `{state_paths_state_log}`. The record MUST use `\"type\":\"iteration\"` EXACTLY, NOT `\"iteration_delta\"` or any other variant. The reducer counts records where `type === \"iteration\"` only; other types are silently ignored. Required schema:\n89: \n90: ```json\n91: {\"type\":\"iteration\",\"iteration\":<n>,\"mode\":\"review\",\"target_agent\":\"deep-review\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=review target_agent=deep-review\",\"run\":\"<run-id>\",\"status\":\"complete\",\"focus\":\"<dimension-or-focus>\",\"dimensions\":[\"...\"],\"filesReviewed\":[\"path:line\"],\"findingsCount\":<n>,\"findingsSummary\":{\"P0\":<n>,\"P1\":<n>,\"P2\":<n>},\"findingsNew\":[],\"findingDetails\":[],\"traceabilityChecks\":{},\"newFindingsRatio\":<0..1>,\"sessionId\":\"<session-id>\",\"generation\":<n>,\"lineageMode\":\"new\",\"timestamp\":\"<ISO-8601>\",\"durationMs\":<n>,\"graphEvents\":[/* optional */]}\n92: ```\n93: \n94: ### v2 Search Depth Output (when scopeClass is standard or complex)\n95: \n96: For standard or complex review scope, set `\"reviewDepthSchemaVersion\":2` on the same iteration JSONL record and include these v2 fields in addition to the v1 fields above:\n97: \n98: - `reviewDepthApplicability`: `{scopeClass,enforcement,reason,evidenceRefs}` where `scopeClass` is `trivial`, `standard`, or `complex`; `enforcement` is `strict`, `warn`, or `skip`.\n99: - `targetSelection`: `{selectedTargets,selectionReason,discoveryMethods,omittedHighRiskTargets,graphStatus,semanticSearchStatus,evidenceRefs}`. Name how targets were chosen, what high-risk targets were omitted, and whether graph/semantic search was available, unavailable, or partial.\n100: - `searchCoverage`: `{requiredBugClasses,covered,ruledOut,deferred,blocked,graphCoverageMode}` where `graphCoverageMode` is `graph`, `graphless_fallback`, or `unavailable_blocked`.\n101: - `searchLedger[]`: ledger rows with required `id`, `dimension`, `targetRefs`, `bugClass`, `disposition`, and `rationale`; include `hypothesis` or `invariant` (at least one); include `searchActions[]` with `{method,queryOrPath,result,evidenceRefs}`.\n102: - Each ledger row needs exactly one disposition link: `linkedFindingId` for `finding` (must match an id in `findingDetails[]`), `ruledOutReason` for `ruled_out`, `deferredReason` for `deferred`, `blockedReason` for `blocked`, or `notApplicableReason` for `not_applicable`.\n103: \n104: Trivial-scope exemption: when `scopeClass` is `trivial` and `enforcement` is `skip`, `searchLedger` may be `[]`, but `reviewDepthApplicability.evidenceRefs` MUST cite proof that the target is trivial.\n105: \n106: Compact v2 example:\n107: \n108: ```json\n109: {\"reviewDepthSchemaVersion\":2,\"reviewDepthApplicability\":{\"scopeClass\":\"standard\",\"enforcement\":\"strict\",\"reason\":\"non-trivial target\",\"evidenceRefs\":[\"path/to/file.ts:42\"]},\"targetSelection\":{\"selectedTargets\":[\"path/to/file.ts\"],\"selectionReason\":\"state transition producer\",\"discoveryMethods\":[\"direct_read\",\"exact_search\"],\"omittedHighRiskTargets\":[],\"graphStatus\":\"unavailable\",\"semanticSearchStatus\":\"partial\",\"evidenceRefs\":[\"path/to/file.ts:42\"]},\"searchCoverage\":{\"requiredBugClasses\":[\"state_transition\"],\"covered\":[],\"ruledOut\":[\"state_transition\"],\"deferred\":[],\"blocked\":[],\"graphCoverageMode\":\"graphless_fallback\"},\"searchLedger\":[{\"id\":\"SL-001\",\"dimension\":\"correctness\",\"targetRefs\":[\"path/to/file.ts\"],\"bugClass\":\"state_transition\",\"hypothesis\":\"state transition can skip validation\",\"searchActions\":[{\"method\":\"direct_read\",\"queryOrPath\":\"path/to/file.ts\",\"result\":\"guard present on all branches\",\"evidenceRefs\":[\"path/to/file.ts:42\"]}],\"disposition\":\"ruled_out\",\"rationale\":\"all branches call the guard\",\"ruledOutReason\":\"verified by direct read\"}]}\n110: ```\n111: \n112: Legacy unversioned records remain valid during rollout. Phase D validator behavior should warn on legacy shallow records and strictly enforce this shape only for explicit v2 records.\n113: \n114: Append via single-line JSON with newline terminator, e.g. `echo '<single-line-json>' >> {state_paths_state_log}`. Do NOT pretty-print. Do NOT print to stdout only; it MUST land in the state log file.\n115: \n116: 3. **Per-iteration delta file** at `{state_paths_delta_pattern}` (path pre-substituted, e.g. `deltas/iter-001.jsonl`). This file holds the structured delta stream for this iteration: one `{\"type\":\"iteration\",...}` record (same as the state-log append) plus per-event structured records (one per graphEvent, finding, classification, traceability-check, ruled_out direction). Each record on its own JSON line.\n117: \n118: Example delta file contents (one review iteration):\n119: ```json\n120: {\"type\":\"iteration\",\"iteration\":3,\"mode\":\"review\",\"target_agent\":\"deep-review\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=review target_agent=deep-review\",\"run\":\"run-001\",\"status\":\"complete\",\"focus\":\"correctness\",\"dimensions\":[\"correctness\"],\"filesReviewed\":[\"path/to/file.ts:42\"],\"findingsCount\":7,\"findingsSummary\":{\"P0\":0,\"P1\":2,\"P2\":5},\"findingsNew\":[],\"findingDetails\":[],\"newFindingsRatio\":0.41,\"sessionId\":\"session-001\",\"generation\":1,\"lineageMode\":\"new\",\"timestamp\":\"2026-04-30T00:00:00Z\",\"durationMs\":120000,\"graphEvents\":[]}\n121: {\"type\":\"finding\",\"id\":\"R3-P1-001\",\"severity\":\"P1\",\"cluster\":\"...\",\"file\":\"path:line\",\"title\":\"...\",\"iteration\":3}\n122: {\"type\":\"classification\",\"detail\":\"...\",\"iteration\":3}\n123: {\"type\":\"ruled_out\",\"direction\":\"...\",\"reason\":\"...\",\"iteration\":3}\n124: ```\n125: \n126: All three artifacts are REQUIRED. The post_dispatch_validate step fails the iteration if any artifact is missing, malformed, or if the state-log append uses the wrong record type (`iteration_delta` etc.).\n\n(End of file - total 126 lines)\n</content>","metadata":{"preview":"DEEP-REVIEW\nResolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true\n\n# Deep-Review Iteration Prompt Pack\n\nThis prompt pack renders the per-iteration context for the `@deep-review` LEAF agent (native executor) or a CLI executor (e.g. `opencode run`). Tokens use curly-brace syntax and are substituted by `renderPromptPack` before dispatch.\n\n## STATE\n\n{state_summary}\n\nReview Iteration: {current_iteration} of {max_iterations}\nMode: review\nDimension: {next_dimension}\nReview Target: {review_target}\nReview Scope Files: {review_scope_files}\nPrior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n\n## PIVOT LINEAGE\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl","text":"DEEP-REVIEW\nResolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true\n\n# Deep-Review Iteration Prompt Pack\n\nThis prompt pack renders the per-iteration context for the `@deep-review` LEAF agent (native executor) or a CLI executor (e.g. `opencode run`). Tokens use curly-brace syntax and are substituted by `renderPromptPack` before dispatch.\n\n## STATE\n\n{state_summary}\n\nReview Iteration: {current_iteration} of {max_iterations}\nMode: review\nDimension: {next_dimension}\nReview Target: {review_target}\nReview Scope Files: {review_scope_files}\nPrior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n\n## PIVOT LINEAGE\n\n{pivot_lineage}\n\nSwept or saturated review directions that MUST NOT be re-entered:\n{saturated_directions}\n\n## SHARED DOCTRINE\n\nLoad `.opencode/skills/sk-code/code-review/references/review_core.md` before final severity calls.\n\n## REVIEW DIMENSIONS\n\ncorrectness, security, traceability, maintainability\n\n## TRACEABILITY PROTOCOLS\n\n- **Core**: spec_code, checklist_evidence\n- **Overlay**: skill_agent, agent_cross_runtime, feature_catalog_code, playbook_capability\n\n## QUALITY GATES\n\nevidence, scope, coverage\n\n## VERDICTS\n\n`FAIL | CONDITIONAL | PASS`, PASS may set `hasAdvisories=true` when only P2 remain.\n\n## CLAIM ADJUDICATION\n\nEvery new P0/P1 must include: claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, and downgradeTrigger.\n\n## STATE FILES\n\nAll paths are relative to the repo root.\n\n- Config: {state_paths_config}\n- State Log: {state_paths_state_log}\n- Findings Registry: {state_paths_findings_registry}\n- Strategy: {state_paths_strategy}\n- Write iteration narrative to: {state_paths_iteration_pattern}\n- Write per-iteration delta file to: {state_paths_delta_pattern}\n\n## CONSTRAINTS\n\n- You are a LEAF agent. Do NOT dispatch sub-agents.\n- Target 9 tool calls. Soft max 12, hard max 13.\n- Write ALL findings to files. Do not hold in context.\n- Review target is READ-ONLY. Do not modify reviewed files.\n- Do not re-enter or restate any direction listed as swept or saturated above. The pivot-selected focus is a new read-only review direction, never permission to change the target.\n- Do not implement fixes during review. Report findings only; implementation is a separate follow-up step.\n- **ALLOWED WRITE PATHS (the ONLY paths you may create, modify, or append to)**:\n  - `{state_paths_iteration_pattern}`, this iteration's narrative markdown\n  - `{state_paths_state_log}`, append-only JSONL state log\n  - `{state_paths_delta_pattern}`, this iteration's delta JSONL\n  - `{state_paths_strategy}`, strategy.md (in-place updates only)\n- **BANNED OPERATIONS (NEVER execute against any path)**: `rm`, `rm -rf`, `git rm`, `mv`, `sed -i` (including `sed -i ''`), `rmdir`, `find ... -delete`, shell output-redirect truncate `>` against any file not in the allowed-write list, and any tool call whose effect is to delete, rename, or replace a file outside the allowed-write list. Reading is unrestricted; **writing, renaming, and deleting are scoped**.\n- **SCOPE VIOLATION PROTOCOL**: if your plan would require modifying any path NOT in the allowed-write list, you MUST STOP that action and emit a finding instead. Record the would-be mutation as a `scope_violation` entry in the iteration narrative (under a `## SCOPE VIOLATIONS` heading) and continue the review. NEVER execute the out-of-scope mutation. The review packet (`{state_paths_iteration_pattern}` directory and parents) is the only zone for your writes; the reviewed target spec/code is off-limits.\n- Append JSONL record with dimensions, filesReviewed, findingsSummary, findingsNew, traceabilityChecks, newFindingsRatio, and optional graphEvents.\n- When emitting the iteration JSONL record, include an optional `graphEvents` array representing coverage graph nodes and edges discovered this iteration. Omit the field when no graph events are produced. Each event MUST use one of these two EXACT shapes. The reducer discriminates node vs edge by `type`, then validates each node's `kind` against the node vocabulary and each edge's `relation` against the relation vocabulary — any event outside these vocabularies is silently dropped, and if every event is dropped the convergence graph stays empty (nodeCount 0, empty signals):\n  - Node: `{\"type\":\"node\",\"id\":\"<stable-id>\",\"kind\":\"<SLICE|DIMENSION|FILE|FINDING|EVIDENCE|REMEDIATION|BUG_CLASS|INVARIANT|PRODUCER|CONSUMER|TEST>\",\"label\":\"<short human name>\"}` — the semantic kind goes in the dedicated `kind` field (uppercase, one of those listed); `label` is a free-text display name ONLY, never the kind.\n  - Edge: `{\"type\":\"edge\",\"id\":\"<stable-id>\",\"source\":\"<nodeId>\",\"target\":\"<nodeId>\",\"relation\":\"<COVERS|EVIDENCE_FOR|CONTRADICTS|RESOLVES|CONFIRMS|ESCALATES|IN_DIMENSION|IN_FILE>\"}` — use `source`/`target`/`relation` (NOT `from`/`to`/`label`); `source` and `target` must reference node `id`s.\n\n## OUTPUT CONTRACT\n\nYou MUST produce THREE artifacts per iteration. The YAML-owned post_dispatch_validate step emits a `schema_mismatch` conflict event if any is missing or malformed.\n\n1. **Iteration narrative markdown** at `{state_paths_iteration_pattern}` (path pre-substituted for the current iteration number). Structure: headings for Dimension, Files Reviewed, Findings by Severity (P0/P1/P2), Traceability Checks, Verdict, Next Dimension.\n\n2. **Canonical JSONL iteration record** APPENDED to `{state_paths_state_log}`. The record MUST use `\"type\":\"iteration\"` EXACTLY, NOT `\"iteration_delta\"` or any other variant. The reducer counts records where `type === \"iteration\"` only; other types are silently ignored. Required schema:\n\n```json\n{\"type\":\"iteration\",\"iteration\":<n>,\"mode\":\"review\",\"target_agent\":\"deep-review\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=review target_agent=deep-review\",\"run\":\"<run-id>\",\"status\":\"complete\",\"focus\":\"<dimension-or-focus>\",\"dimensions\":[\"...\"],\"filesReviewed\":[\"path:line\"],\"findingsCount\":<n>,\"findingsSummary\":{\"P0\":<n>,\"P1\":<n>,\"P2\":<n>},\"findingsNew\":[],\"findingDetails\":[],\"traceabilityChecks\":{},\"newFindingsRatio\":<0..1>,\"sessionId\":\"<session-id>\",\"generation\":<n>,\"lineageMode\":\"new\",\"timestamp\":\"<ISO-8601>\",\"durationMs\":<n>,\"graphEvents\":[/* optional */]}\n```\n\n### v2 Search Depth Output (when scopeClass is standard or complex)\n\nFor standard or complex review scope, set `\"reviewDepthSchemaVersion\":2` on the same iteration JSONL record and include these v2 fields in addition to the v1 fields above:\n\n- `reviewDepthApplicability`: `{scopeClass,enforcement,reason,evidenceRefs}` where `scopeClass` is `trivial`, `standard`, or `complex`; `enforcement` is `strict`, `warn`, or `skip`.\n- `targetSelection`: `{selectedTargets,selectionReason,discoveryMethods,omittedHighRiskTargets,graphStatus,semanticSearchStatus,evidenceRefs}`. Name how targets were chosen, what high-risk targets were omitted, and whether graph/semantic search was available, unavailable, or partial.\n- `searchCoverage`: `{requiredBugClasses,covered,ruledOut,deferred,blocked,graphCoverageMode}` where `graphCoverageMode` is `graph`, `graphless_fallback`, or `unavailable_blocked`.\n- `searchLedger[]`: ledger rows with required `id`, `dimension`, `targetRefs`, `bugClass`, `disposition`, and `rationale`; include `hypothesis` or `invariant` (at least one); include `searchActions[]` with `{method,queryOrPath,result,evidenceRefs}`.\n- Each ledger row needs exactly one disposition link: `linkedFindingId` for `finding` (must match an id in `findingDetails[]`), `ruledOutReason` for `ruled_out`, `deferredReason` for `deferred`, `blockedReason` for `blocked`, or `notApplicableReason` for `not_applicable`.\n\nTrivial-scope exemption: when `scopeClass` is `trivial` and `enforcement` is `skip`, `searchLedger` may be `[]`, but `reviewDepthApplicability.evidenceRefs` MUST cite proof that the target is trivial.\n\nCompact v2 example:\n\n```json\n{\"reviewDepthSchemaVersion\":2,\"reviewDepthApplicability\":{\"scopeClass\":\"standard\",\"enforcement\":\"strict\",\"reason\":\"non-trivial target\",\"evidenceRefs\":[\"path/to/file.ts:42\"]},\"targetSelection\":{\"selectedTargets\":[\"path/to/file.ts\"],\"selectionReason\":\"state transition producer\",\"discoveryMethods\":[\"direct_read\",\"exact_search\"],\"omittedHighRiskTargets\":[],\"graphStatus\":\"unavailable\",\"semanticSearchStatus\":\"partial\",\"evidenceRefs\":[\"path/to/file.ts:42\"]},\"searchCoverage\":{\"requiredBugClasses\":[\"state_transition\"],\"covered\":[],\"ruledOut\":[\"state_transition\"],\"deferred\":[],\"blocked\":[],\"graphCoverageMode\":\"graphless_fallback\"},\"searchLedger\":[{\"id\":\"SL-001\",\"dimension\":\"correctness\",\"targetRefs\":[\"path/to/file.ts\"],\"bugClass\":\"state_transition\",\"hypothesis\":\"state transition can skip validation\",\"searchActions\":[{\"method\":\"direct_read\",\"queryOrPath\":\"path/to/file.ts\",\"result\":\"guard present on all branches\",\"evidenceRefs\":[\"path/to/file.ts:42\"]}],\"disposition\":\"ruled_out\",\"rationale\":\"all branches call the guard\",\"ruledOutReason\":\"verified by direct read\"}]}\n```\n\nLegacy unversioned records remain valid during rollout. Phase D validator behavior should warn on legacy shallow records and strictly enforce this shape only for explicit v2 records.\n\nAppend via single-line JSON with newline terminator, e.g. `echo '<single-line-json>' >> {state_paths_state_log}`. Do NOT pretty-print. Do NOT print to stdout only; it MUST land in the state log file.\n\n3. **Per-iteration delta file** at `{state_paths_delta_pattern}` (path pre-substituted, e.g. `deltas/iter-001.jsonl`). This file holds the structured delta stream for this iteration: one `{\"type\":\"iteration\",...}` record (same as the state-log append) plus per-event structured records (one per graphEvent, finding, classification, traceability-check, ruled_out direction). Each record on its own JSON line.\n\nExample delta file contents (one review iteration):\n```json\n{\"type\":\"iteration\",\"iteration\":3,\"mode\":\"review\",\"target_agent\":\"deep-review\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=review target_agent=deep-review\",\"run\":\"run-001\",\"status\":\"complete\",\"focus\":\"correctness\",\"dimensions\":[\"correctness\"],\"filesReviewed\":[\"path/to/file.ts:42\"],\"findingsCount\":7,\"findingsSummary\":{\"P0\":0,\"P1\":2,\"P2\":5},\"findingsNew\":[],\"findingDetails\":[],\"newFindingsRatio\":0.41,\"sessionId\":\"session-001\",\"generation\":1,\"lineageMode\":\"new\",\"timestamp\":\"2026-04-30T00:00:00Z\",\"durationMs\":120000,\"graphEvents\":[]}\n{\"type\":\"finding\",\"id\":\"R3-P1-001\",\"severity\":\"P1\",\"cluster\":\"...\",\"file\":\"path:line\",\"title\":\"...\",\"iteration\":3}\n{\"type\":\"classification\",\"detail\":\"...\",\"iteration\":3}\n{\"type\":\"ruled_out\",\"direction\":\"...\",\"reason\":\"...\",\"iteration\":3}\n```\n\nAll three artifacts are REQUIRED. The post_dispatch_validate step fails the iteration if any artifact is missing, malformed, or if the state-log append uses the wrong record type (`iteration_delta` etc.).","lineStart":1,"lineEnd":126,"totalLines":126,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl","time":{"start":1783915553603,"end":1783915553607}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cd48191985d2e1ac05d73a9"}},"id":"prt_f59a7233d001Kr7c42JZWUMDts","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
{"type":"tool_use","timestamp":1783915553610,"sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","part":{"type":"tool","tool":"read","callID":"call_PIdEWXX5FckzAG5BVDEogNJW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml","offset":1,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml</path>\n<type>file</type>\n<content>\n1: # Canonical review-mode contract for deep-review.\n2: # This file is the single source of truth for review-mode taxonomy,\n3: # convergence settings, cross-reference protocols, downstream render targets,\n4: # and validation expectations.\n5: \n6: meta:\n7:   ownerSkill: deep-review\n8:   reviewModeVersion: 2\n9:   generatedNotice:\n10:     warning: \"Exactly one artifact is machine-generated from this file: render.artifacts[0] (review-contract-snapshot). Its begin/end markers live on that artifact entry, not here. Every other contract-taxonomy consumer is hand-authored; see authoredArtifacts.\"\n11:   sourceOfTruth: .opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml\n12: \n13: # Core contract definitions consumed by workflows, agents, docs, and validators.\n14: contract:\n15:   defaultTargetType: spec-folder\n16: \n17:   contextSnapshot:\n18:     requiredAtInit: true\n19:     ownerArtifact: deep-review-strategy.md\n20:     section: Known Context\n21:     source: bounded-review-context-snapshot\n22:     bounded: true\n23:     pointerBased: true\n24:     includes:\n25:       - targetPointers\n26:       - behaviorClaims\n27:       - reuseAndConventionPointers\n28:       - riskAreasAndContextGaps\n29:     forbids:\n30:       - deepContextDispatch\n31:       - fullSourceBodyInlining\n32:       - contextLoopReportCreation\n33:       - scopeWideningBeyondReviewTarget\n34: \n35:   # Review target taxonomy.\n36:   targetTypes:\n37:     - id: spec-folder\n38:       cliValue: spec-folder\n39:       label: Spec Folder\n40:       description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n41:     - id: skill\n42:       cliValue: skill\n43:       label: Skill\n44:       description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n45:     - id: agent\n46:       cliValue: agent\n47:       label: Agent\n48:       description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n49:     - id: track\n50:       cliValue: track\n51:       label: Track\n52:       description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n53:     - id: files\n54:       cliValue: files\n55:       label: Files\n56:       description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n57: \n58:   # Simplified review dimensions. Traceability and maintainability absorb the\n59:   # prior seven-dimension model's overlap.\n60:   dimensions:\n61:     - id: correctness\n62:       priority: 1\n63:       label: Correctness\n64:       checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n65:       requiredForSeverityCoverage: true\n66:     - id: security\n67:       priority: 2\n68:       label: Security\n69:       checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n70:       requiredForSeverityCoverage: true\n71:     - id: traceability\n72:       priority: 3\n73:       label: Traceability\n74:       checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n75:       requiredForSeverityCoverage: false\n76:     - id: maintainability\n77:       priority: 4\n78:       label: Maintainability\n79:       checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n80:       requiredForSeverityCoverage: false\n81: \n82:   # Severity contract stays stable across review outputs.\n83:   severities:\n84:     - id: P0\n85:       weight: 10.0\n86:       label: Blocker\n87:       requiresFileLineEvidence: true\n88:     - id: P1\n89:       weight: 5.0\n90:       label: Required\n91:       requiresFileLineEvidence: true\n92:     - id: P2\n93:       weight: 1.0\n94:       label: Suggestion\n95:       requiresFileLineEvidence: true\n96: \n97:   # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n98:   verdicts:\n99:     - id: FAIL\n100:       label: Fail\n101:       condition: \"activeP0 > 0 OR any required quality gate fails\"\n102:       nextCommand: /speckit:plan\n103:     - id: CONDITIONAL\n104:       label: Conditional\n105:       condition: \"activeP0 == 0 AND activeP1 > 0\"\n106:       nextCommand: /speckit:plan\n107:     - id: PASS\n108:       label: Pass\n109:       condition: \"activeP0 == 0 AND activeP1 == 0\"\n110:       hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n111:       nextCommand: /create:changelog\n112: \n113:   # Binary gates applied after convergence math votes STOP.\n114:   qualityGates:\n115:     - id: evidence\n116:       label: Evidence\n117:       binary: true\n118:       combines:\n119:         - evidence-completeness\n120:         - no-inference-only\n121:       rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n122:     - id: scope\n123:       label: Scope\n124:       binary: true\n125:       combines:\n126:         - scope-alignment\n127:       rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n128:     - id: coverage\n129:       label: Coverage\n130:       binary: true\n131:       combines:\n132:         - severity-coverage\n133:         - cross-reference\n134:       rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n135: \n136:   # Review-specific convergence settings calibrated from the v2 research.\n137:   convergence:\n138:     defaults:\n139:       maxIterations: 7\n140:       convergenceThreshold: 0.10\n141:       stuckThreshold: 2\n142:     signals:\n143:       - id: rolling-average\n144:         weight: 0.30\n145:         description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n146:       - id: mad-noise-floor\n147:         weight: 0.25\n148:         description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n149:       - id: dimension-coverage\n150:         weight: 0.45\n151:         description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n152:     severityMath:\n153:       refinementMultiplier: 0.5\n154:       p0OverrideMinRatio: 0.50\n155:       noFindingsRatio: 0.0\n156:     coverageAge:\n157:       minStabilizationPasses: 1\n158:     thresholds:\n159:       rollingStopThreshold: 0.08\n160:       noProgressThreshold: 0.05\n161:       compositeStopScore: 0.60\n162: \n163:   lifecycleModes:\n164:     - id: new\n165:       description: Create a brand-new review lineage with generation 1 and no parent session.\n166:     - id: resume\n167:       description: Continue the current review lineage without changing generation.\n168:     - id: restart\n169:       description: Start a new generation for the same target and archive the prior review packet state.\n170:     - id: fork\n171:       status: deferred\n172:       description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n173:     - id: completed-continue\n174:       status: deferred\n175:       description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n176: \n177:   lineageFields:\n178:     - sessionId\n179:     - parentSessionId\n180:     - lineageMode\n181:     - generation\n182:     - continuedFromRun\n183: \n184:   reducer:\n185:     enabled: true\n186:     inputs:\n187:       - latestJSONLDelta\n188:       - newIterationFile\n189:       - priorReducedState\n190:     outputs:\n191:       - findingsRegistry\n192:       - dashboardMetrics\n193:       - strategyUpdates\n194:     failureModes:\n195:       malformedDelta: skip-and-warn\n196:       missingIterationFile: no-op-with-error\n197:       schemaMismatch: reject-with-conflict-event\n198:     idempotent: true\n199: \n200:   releaseReadinessStates:\n201:     - id: in-progress\n202:       description: Review is ongoing or coverage is incomplete.\n203:     - id: converged\n204:       description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n205:     - id: release-blocking\n206:       description: At least one unresolved P0 finding is present.\n207: \n208:   # Cross-reference protocols are typed traceability checks. Core protocols are\n209:   # hard gates; overlay protocols apply only to matching target types.\n210:   crossReferenceProtocols:\n211:     - id: spec_code\n212:       dimension: traceability\n213:       level: core\n214:       appliesTo: [spec-folder, skill, agent, track, files]\n215:       gateClass: hard\n216:       passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n217:       partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n218:       failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n219:     - id: checklist_evidence\n220:       dimension: traceability\n221:       level: core\n222:       appliesTo: [spec-folder, skill, agent, track, files]\n223:       gateClass: hard\n224:       passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n225:       partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n226:       failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n227:     - id: skill_agent\n228:       dimension: traceability\n229:       level: overlay\n230:       appliesTo: [skill]\n231:       gateClass: advisory\n232:       passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n233:       partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n234:       failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n235:     - id: agent_cross_runtime\n236:       dimension: traceability\n237:       level: overlay\n238:       appliesTo: [agent]\n239:       gateClass: advisory\n240:       passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n241:       partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n242:       failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n243:     - id: feature_catalog_code\n244:       dimension: traceability\n245:       level: overlay\n246:       appliesTo: [skill, spec-folder, track, files]\n247:       gateClass: advisory\n248:       passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n249:       partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n250:       failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n251:     - id: playbook_capability\n252:       dimension: traceability\n253:       level: overlay\n254:       appliesTo: [skill, agent, spec-folder]\n255:       gateClass: advisory\n256:       passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n257:       partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n258:       failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n259: \n260:   # Output contracts consumed by synthesis and replay tooling.\n261:   outputs:\n262:     config:\n263:       pathPattern: \"{artifact_dir}/deep-review-config.json\"\n264:       machineOwned: false\n265:       fields:\n266:         - sessionId\n267:         - parentSessionId\n268:         - lineageMode\n269:         - generation\n270:         - continuedFromRun\n271:         - releaseReadinessState\n272:     findingsRegistry:\n273:       pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n274:       machineOwned: true\n275:       sections:\n276:         - openFindings\n277:         - resolvedFindings\n278:         - repeatedFindings\n279:         - dimensionCoverage\n280:         - findingsBySeverity\n281:         - convergenceScore\n282:     reviewReport:\n283:       pathPattern: \"{artifact_dir}/review-report.md\"\n284:       sections:\n285:         - executive-summary\n286:         - planning-trigger\n287:         - active-finding-registry\n288:         - remediation-workstreams\n289:         - spec-seed\n290:         - plan-seed\n291:         - traceability-status\n292:         - deferred-items\n293:         - audit-appendix\n294:     strategy:\n295:       pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n296:       requiredSections:\n297:         - topic\n298:         - review-dimensions\n299:         - completed-dimensions\n300:         - running-findings\n301:         - what-worked\n302:         - what-failed\n303:         - exhausted-approaches\n304:         - ruled-out-directions\n305:         - next-focus\n306:         - known-context\n307:         - cross-reference-status\n308:         - files-under-review\n309:         - review-boundaries\n310:     dashboard:\n311:       pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n312:       machineOwned: true\n313:       sections:\n314:         - status\n315:         - findings-summary\n316:         - dimension-coverage\n317:         - progress\n318:         - next-focus\n319:     pauseSentinel:\n320:       pathPattern: \"{artifact_dir}/.deep-review-pause\"\n321:       machineOwned: false\n322:       description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n323:     jsonl:\n324:       pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n325:       iterationRecord:\n326:         required:\n327:           - type\n328:           - mode\n329:           - run\n330:           - status\n331:           - focus\n332:           - dimensions\n333:           - filesReviewed\n334:           - findingsCount\n335:           - findingsSummary\n336:           - findingsNew\n337:           - findingDetails\n338:           - newFindingsRatio\n339:           - sessionId\n340:           - generation\n341:           - lineageMode\n342:           - timestamp\n343:           - durationMs\n344:         optional:\n345:           - parentSessionId\n346:           - continuedFromRun\n347:           - findingsRefined\n348:           - findingRefs\n349:           - traceabilityChecks\n350:           - coverage\n351:           - noveltyJustification\n352:           - ruledOut\n353:           - focusTrack\n354:           - scoreEstimate\n355:           - segment\n356:           - convergenceSignals\n357:           - graphEvents\n358:       synthesisEvent:\n359:         required:\n360:           - type\n361:           - event\n362:           - mode\n363:           - totalIterations\n364:           - verdict\n365:           - activeP0\n366:           - activeP1\n367:           - activeP2\n368:           - dimensionCoverage\n369:           - stopReason\n370:           - timestamp\n371: \n372: # Render targets define machine-generated contract fragments. Exactly one\n373: # target is real: the human-readable snapshot rendered by\n374: # render-contract-snapshot.cjs. Everything else that mentions this contract's\n375: # taxonomy (target types, dimensions, severities, verdicts, quality gates,\n376: # convergence, cross-reference protocols) is hand-authored — see\n377: # authoredArtifacts below, not rendered from this file.\n378: render:\n379:   artifacts:\n380:     - id: review-contract-snapshot\n381:       path: .opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract_snapshot.md\n382:       ownership: generated\n383:       generator: .opencode/skills/system-deep-loop/deep-review/scripts/render-contract-snapshot.cjs\n384:       format: markdown\n385:       markers:\n386:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n387:         end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n388:       sections:\n389:         - meta\n390:         - target-types\n391:         - dimensions\n392:         - severities\n393:         - verdicts\n394:         - quality-gates\n395:         - convergence\n396:         - cross-reference-protocols\n397:         - outputs\n398:         - validation\n399: \n400: # Authored artifacts reference this manifest's taxonomy in hand-written prose\n401: # or YAML. They are not machine-rendered and carry no generated markers;\n402: # operators keep them in sync by hand when this contract changes. Each\n403: # entry's enumParityChecked list is mechanically enforced (not aspirational):\n404: # deep-review-contract-parity.vitest.ts confirms every id in those families\n405: # still appears literally in the target file, as a lightweight drift\n406: # tripwire that does not require full rendering.\n407: authoredArtifacts:\n408:   - id: workflow-auto\n409:     path: .opencode/commands/deep/assets/deep_review_auto.yaml\n410:     ownership: authored\n411:     format: yaml\n412:     enumParityChecked:\n413:       - dimensions\n414:       - severities\n415:       - verdicts\n416:       - cross-reference-protocols\n417:     note: Hand-maintained workflow YAML for the :auto command path. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n418:   - id: workflow-confirm\n419:     path: .opencode/commands/deep/assets/deep_review_confirm.yaml\n420:     ownership: authored\n421:     format: yaml\n422:     enumParityChecked:\n423:       - dimensions\n424:       - severities\n425:       - verdicts\n426:       - cross-reference-protocols\n427:     note: Hand-maintained workflow YAML for the :confirm command path. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n428:   - id: agent-opencode\n429:     path: .opencode/agents/deep-review.md\n430:     ownership: authored\n431:     format: markdown\n432:     enumParityChecked:\n433:       - dimensions\n434:       - severities\n435:       - verdicts\n436:     note: Hand-maintained OpenCode agent definition. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n437:   - id: agent-claude\n438:     path: .claude/agents/deep-review.md\n439:     ownership: authored\n440:     format: markdown\n441:     enumParityChecked:\n442:       - dimensions\n443:       - severities\n444:       - verdicts\n445:     note: Hand-maintained Claude Code agent definition. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n446:   - id: quick-reference-review-mode\n447:     path: .opencode/skills/system-deep-loop/deep-review/references/protocol/quick_reference.md\n448:     ownership: authored\n449:     format: markdown\n450:     enumParityChecked:\n451:       - dimensions\n452:       - severities\n453:       - verdicts\n454:     note: Hand-maintained quick reference. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n455: \n456: # Validator contract for CI, render verification, and drift detection.\n457: validation:\n458:   schemaVersion: 1\n459:   checks:\n460:     - id: schema\n461:       description: Validate this manifest against the canonical review-mode contract schema.\n462:     - id: render-verify\n463:       description: \"Re-render the single review-contract-snapshot artifact (node render-contract-snapshot.cjs --check) and fail on drift. The five authoredArtifacts entries are hand-maintained and are not re-rendered by this check.\"\n464:     - id: marker-integrity\n465:       description: Ensure the review-contract-snapshot artifact contains intact begin/end markers with no overlapping generated blocks.\n466:     - id: enum-parity\n467:       description: \"Confirm the dimension, severity, and verdict ids (plus cross-reference-protocol ids for the two workflow YAMLs) declared in each authoredArtifacts entry's enumParityChecked are still literally present in that file; see deep-review-contract-parity.vitest.ts.\"\n468:     - id: jsonl-parity\n469:       description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n470:     - id: lifecycle-parity\n471:       description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n472:     - id: reducer-contract\n473:       description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n474:     - id: duplicate-literal-lint\n475:       description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n476:     - id: runtime-coverage\n477:       description: Ensure every supported runtime deep-review agent has a declared authoredArtifacts entry and parity coverage.\n478:     - id: playbook-assertions\n479:       description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.\n\n(End of file - total 479 lines)\n</content>","metadata":{"preview":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Exactly one artifact is machine-generated from this file: render.artifacts[0] (review-contract-snapshot). Its begin/end markers live on that artifact entry, not here. Every other contract-taxonomy consumer is hand-authored; see authoredArtifacts.\"\n  sourceOfTruth: .opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  contextSnapshot:\n    requiredAtInit: true\n    ownerArtifact: deep-review-strategy.md\n    section: Known Context","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml","text":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Exactly one artifact is machine-generated from this file: render.artifacts[0] (review-contract-snapshot). Its begin/end markers live on that artifact entry, not here. Every other contract-taxonomy consumer is hand-authored; see authoredArtifacts.\"\n  sourceOfTruth: .opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  contextSnapshot:\n    requiredAtInit: true\n    ownerArtifact: deep-review-strategy.md\n    section: Known Context\n    source: bounded-review-context-snapshot\n    bounded: true\n    pointerBased: true\n    includes:\n      - targetPointers\n      - behaviorClaims\n      - reuseAndConventionPointers\n      - riskAreasAndContextGaps\n    forbids:\n      - deepContextDispatch\n      - fullSourceBodyInlining\n      - contextLoopReportCreation\n      - scopeWideningBeyondReviewTarget\n\n  # Review target taxonomy.\n  targetTypes:\n    - id: spec-folder\n      cliValue: spec-folder\n      label: Spec Folder\n      description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n    - id: skill\n      cliValue: skill\n      label: Skill\n      description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n    - id: agent\n      cliValue: agent\n      label: Agent\n      description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n    - id: track\n      cliValue: track\n      label: Track\n      description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n    - id: files\n      cliValue: files\n      label: Files\n      description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n\n  # Simplified review dimensions. Traceability and maintainability absorb the\n  # prior seven-dimension model's overlap.\n  dimensions:\n    - id: correctness\n      priority: 1\n      label: Correctness\n      checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n      requiredForSeverityCoverage: true\n    - id: security\n      priority: 2\n      label: Security\n      checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n      requiredForSeverityCoverage: true\n    - id: traceability\n      priority: 3\n      label: Traceability\n      checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n      requiredForSeverityCoverage: false\n    - id: maintainability\n      priority: 4\n      label: Maintainability\n      checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n      requiredForSeverityCoverage: false\n\n  # Severity contract stays stable across review outputs.\n  severities:\n    - id: P0\n      weight: 10.0\n      label: Blocker\n      requiresFileLineEvidence: true\n    - id: P1\n      weight: 5.0\n      label: Required\n      requiresFileLineEvidence: true\n    - id: P2\n      weight: 1.0\n      label: Suggestion\n      requiresFileLineEvidence: true\n\n  # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n  verdicts:\n    - id: FAIL\n      label: Fail\n      condition: \"activeP0 > 0 OR any required quality gate fails\"\n      nextCommand: /speckit:plan\n    - id: CONDITIONAL\n      label: Conditional\n      condition: \"activeP0 == 0 AND activeP1 > 0\"\n      nextCommand: /speckit:plan\n    - id: PASS\n      label: Pass\n      condition: \"activeP0 == 0 AND activeP1 == 0\"\n      hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n      nextCommand: /create:changelog\n\n  # Binary gates applied after convergence math votes STOP.\n  qualityGates:\n    - id: evidence\n      label: Evidence\n      binary: true\n      combines:\n        - evidence-completeness\n        - no-inference-only\n      rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n    - id: scope\n      label: Scope\n      binary: true\n      combines:\n        - scope-alignment\n      rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n    - id: coverage\n      label: Coverage\n      binary: true\n      combines:\n        - severity-coverage\n        - cross-reference\n      rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n\n  # Review-specific convergence settings calibrated from the v2 research.\n  convergence:\n    defaults:\n      maxIterations: 7\n      convergenceThreshold: 0.10\n      stuckThreshold: 2\n    signals:\n      - id: rolling-average\n        weight: 0.30\n        description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n      - id: mad-noise-floor\n        weight: 0.25\n        description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n      - id: dimension-coverage\n        weight: 0.45\n        description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n    severityMath:\n      refinementMultiplier: 0.5\n      p0OverrideMinRatio: 0.50\n      noFindingsRatio: 0.0\n    coverageAge:\n      minStabilizationPasses: 1\n    thresholds:\n      rollingStopThreshold: 0.08\n      noProgressThreshold: 0.05\n      compositeStopScore: 0.60\n\n  lifecycleModes:\n    - id: new\n      description: Create a brand-new review lineage with generation 1 and no parent session.\n    - id: resume\n      description: Continue the current review lineage without changing generation.\n    - id: restart\n      description: Start a new generation for the same target and archive the prior review packet state.\n    - id: fork\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n    - id: completed-continue\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n\n  lineageFields:\n    - sessionId\n    - parentSessionId\n    - lineageMode\n    - generation\n    - continuedFromRun\n\n  reducer:\n    enabled: true\n    inputs:\n      - latestJSONLDelta\n      - newIterationFile\n      - priorReducedState\n    outputs:\n      - findingsRegistry\n      - dashboardMetrics\n      - strategyUpdates\n    failureModes:\n      malformedDelta: skip-and-warn\n      missingIterationFile: no-op-with-error\n      schemaMismatch: reject-with-conflict-event\n    idempotent: true\n\n  releaseReadinessStates:\n    - id: in-progress\n      description: Review is ongoing or coverage is incomplete.\n    - id: converged\n      description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n    - id: release-blocking\n      description: At least one unresolved P0 finding is present.\n\n  # Cross-reference protocols are typed traceability checks. Core protocols are\n  # hard gates; overlay protocols apply only to matching target types.\n  crossReferenceProtocols:\n    - id: spec_code\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n      partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n      failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n    - id: checklist_evidence\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n      partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n      failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n    - id: skill_agent\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill]\n      gateClass: advisory\n      passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n      partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n      failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n    - id: agent_cross_runtime\n      dimension: traceability\n      level: overlay\n      appliesTo: [agent]\n      gateClass: advisory\n      passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n      partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n      failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n    - id: feature_catalog_code\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, spec-folder, track, files]\n      gateClass: advisory\n      passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n      partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n      failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n    - id: playbook_capability\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, agent, spec-folder]\n      gateClass: advisory\n      passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n      partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n      failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n\n  # Output contracts consumed by synthesis and replay tooling.\n  outputs:\n    config:\n      pathPattern: \"{artifact_dir}/deep-review-config.json\"\n      machineOwned: false\n      fields:\n        - sessionId\n        - parentSessionId\n        - lineageMode\n        - generation\n        - continuedFromRun\n        - releaseReadinessState\n    findingsRegistry:\n      pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n      machineOwned: true\n      sections:\n        - openFindings\n        - resolvedFindings\n        - repeatedFindings\n        - dimensionCoverage\n        - findingsBySeverity\n        - convergenceScore\n    reviewReport:\n      pathPattern: \"{artifact_dir}/review-report.md\"\n      sections:\n        - executive-summary\n        - planning-trigger\n        - active-finding-registry\n        - remediation-workstreams\n        - spec-seed\n        - plan-seed\n        - traceability-status\n        - deferred-items\n        - audit-appendix\n    strategy:\n      pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n      requiredSections:\n        - topic\n        - review-dimensions\n        - completed-dimensions\n        - running-findings\n        - what-worked\n        - what-failed\n        - exhausted-approaches\n        - ruled-out-directions\n        - next-focus\n        - known-context\n        - cross-reference-status\n        - files-under-review\n        - review-boundaries\n    dashboard:\n      pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n      machineOwned: true\n      sections:\n        - status\n        - findings-summary\n        - dimension-coverage\n        - progress\n        - next-focus\n    pauseSentinel:\n      pathPattern: \"{artifact_dir}/.deep-review-pause\"\n      machineOwned: false\n      description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n    jsonl:\n      pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n      iterationRecord:\n        required:\n          - type\n          - mode\n          - run\n          - status\n          - focus\n          - dimensions\n          - filesReviewed\n          - findingsCount\n          - findingsSummary\n          - findingsNew\n          - findingDetails\n          - newFindingsRatio\n          - sessionId\n          - generation\n          - lineageMode\n          - timestamp\n          - durationMs\n        optional:\n          - parentSessionId\n          - continuedFromRun\n          - findingsRefined\n          - findingRefs\n          - traceabilityChecks\n          - coverage\n          - noveltyJustification\n          - ruledOut\n          - focusTrack\n          - scoreEstimate\n          - segment\n          - convergenceSignals\n          - graphEvents\n      synthesisEvent:\n        required:\n          - type\n          - event\n          - mode\n          - totalIterations\n          - verdict\n          - activeP0\n          - activeP1\n          - activeP2\n          - dimensionCoverage\n          - stopReason\n          - timestamp\n\n# Render targets define machine-generated contract fragments. Exactly one\n# target is real: the human-readable snapshot rendered by\n# render-contract-snapshot.cjs. Everything else that mentions this contract's\n# taxonomy (target types, dimensions, severities, verdicts, quality gates,\n# convergence, cross-reference protocols) is hand-authored — see\n# authoredArtifacts below, not rendered from this file.\nrender:\n  artifacts:\n    - id: review-contract-snapshot\n      path: .opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract_snapshot.md\n      ownership: generated\n      generator: .opencode/skills/system-deep-loop/deep-review/scripts/render-contract-snapshot.cjs\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n      sections:\n        - meta\n        - target-types\n        - dimensions\n        - severities\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n        - outputs\n        - validation\n\n# Authored artifacts reference this manifest's taxonomy in hand-written prose\n# or YAML. They are not machine-rendered and carry no generated markers;\n# operators keep them in sync by hand when this contract changes. Each\n# entry's enumParityChecked list is mechanically enforced (not aspirational):\n# deep-review-contract-parity.vitest.ts confirms every id in those families\n# still appears literally in the target file, as a lightweight drift\n# tripwire that does not require full rendering.\nauthoredArtifacts:\n  - id: workflow-auto\n    path: .opencode/commands/deep/assets/deep_review_auto.yaml\n    ownership: authored\n    format: yaml\n    enumParityChecked:\n      - dimensions\n      - severities\n      - verdicts\n      - cross-reference-protocols\n    note: Hand-maintained workflow YAML for the :auto command path. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n  - id: workflow-confirm\n    path: .opencode/commands/deep/assets/deep_review_confirm.yaml\n    ownership: authored\n    format: yaml\n    enumParityChecked:\n      - dimensions\n      - severities\n      - verdicts\n      - cross-reference-protocols\n    note: Hand-maintained workflow YAML for the :confirm command path. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n  - id: agent-opencode\n    path: .opencode/agents/deep-review.md\n    ownership: authored\n    format: markdown\n    enumParityChecked:\n      - dimensions\n      - severities\n      - verdicts\n    note: Hand-maintained OpenCode agent definition. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n  - id: agent-claude\n    path: .claude/agents/deep-review.md\n    ownership: authored\n    format: markdown\n    enumParityChecked:\n      - dimensions\n      - severities\n      - verdicts\n    note: Hand-maintained Claude Code agent definition. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n  - id: quick-reference-review-mode\n    path: .opencode/skills/system-deep-loop/deep-review/references/protocol/quick_reference.md\n    ownership: authored\n    format: markdown\n    enumParityChecked:\n      - dimensions\n      - severities\n      - verdicts\n    note: Hand-maintained quick reference. References this contract's taxonomy in prose; not machine-rendered from this manifest.\n\n# Validator contract for CI, render verification, and drift detection.\nvalidation:\n  schemaVersion: 1\n  checks:\n    - id: schema\n      description: Validate this manifest against the canonical review-mode contract schema.\n    - id: render-verify\n      description: \"Re-render the single review-contract-snapshot artifact (node render-contract-snapshot.cjs --check) and fail on drift. The five authoredArtifacts entries are hand-maintained and are not re-rendered by this check.\"\n    - id: marker-integrity\n      description: Ensure the review-contract-snapshot artifact contains intact begin/end markers with no overlapping generated blocks.\n    - id: enum-parity\n      description: \"Confirm the dimension, severity, and verdict ids (plus cross-reference-protocol ids for the two workflow YAMLs) declared in each authoredArtifacts entry's enumParityChecked are still literally present in that file; see deep-review-contract-parity.vitest.ts.\"\n    - id: jsonl-parity\n      description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n    - id: lifecycle-parity\n      description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n    - id: reducer-contract\n      description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n    - id: duplicate-literal-lint\n      description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n    - id: runtime-coverage\n      description: Ensure every supported runtime deep-review agent has a declared authoredArtifacts entry and parity coverage.\n    - id: playbook-assertions\n      description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.","lineStart":1,"lineEnd":479,"totalLines":479,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/assets/review_mode_contract.yaml","time":{"start":1783915553595,"end":1783915553608}},"metadata":{"openai":{"itemId":"fc_0a39a121d4f1de4a016a5464217cd0819185c479ebdceb97f8"}},"id":"prt_f59a72337001esz1QqhK2rEQrk","sessionID":"ses_0a65ac472ffeMi6luqm6mHU9Lf","messageID":"msg_f59a6cd7b001Bhmr5bgI3wrxhz"}}
