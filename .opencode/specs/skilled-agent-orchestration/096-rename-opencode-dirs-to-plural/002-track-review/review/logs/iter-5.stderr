ype\\\":\\\"event\\\",\\\"event\\\":\\\"graph_convergence\\\",\\\"mode\\\":\\\"research\\\",\\\"run\\\":{current_iteration},\\\"decision\\\":{graph_decision_json},\\\"signals\\\":{graph_signals_json},\\\"blockers\\\":{graph_blockers_json},\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\",\\\"sessionId\\\":\\\"{config.lineage.sessionId}\\\",\\\"generation\\\":{config.lineage.generation}}'\\n.opencode/specs/skilled-agent-orchestration/042-sk-deep-research-review-improvement-2/review/iterations/iteration-002.md:1962:.opencode/specs/skilled-agent-orchestration/042-sk-deep-research-review-improvement-2/review/iterations/iteration-001.md:3865:.opencode/commands/spec_kit/assets/spec_kit_deep-research_confirm.yaml:369:          append_to_jsonl: '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"blocked_stop\\\",\\\"mode\\\":\\\"research\\\",\\\"run\\\":{current_iteration},\\\"blockedBy\\\":{blocked_by_json},\\\"gateResults\\\":{\\\"convergence\\\":{\\\"pass\\\":{gate_convergence_pass},\\\"score\\\":{gate_convergence_score}},\\\"keyQuestionCoverage\\\":{\\\"pass\\\":{gate_key_question_coverage_pass},\\\"answered\\\":{answered_count},\\\"total\\\":{total_questions}},\\\"evidenceDensity\\\":{\\\"pass\\\":{gate_evidence_density_pass},\\\"sources\\\":{gate_evidence_density_sources}},\\\"hotspotSaturation\\\":{\\\"pass\\\":{gate_hotspot_saturation_pass}}},\\\"recoveryStrategy\\\":\\\"{recovery_strategy}\\\",\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\",\\\"sessionId\\\":\\\"{config.lineage.sessionId}\\\",\\\"generation\\\":{config.lineage.generation}}'\\n.opencode/specs/skilled-agent-orchestration/042-sk-deep-research-review-improvement-2/review/iterations/iteration-002.md:1963:.opencode/specs/skilled-agent-orchestration/042-sk-deep-research-review-improvement-2/review/iterations/iteration-001.md:3867:.opencode/commands/spec_kit/assets/spec_kit_deep-research_auto.yaml:273:        append_to_jsonl: '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"graph_convergence\\\",\\\"mode\\\":\\\"research\\\",\\\