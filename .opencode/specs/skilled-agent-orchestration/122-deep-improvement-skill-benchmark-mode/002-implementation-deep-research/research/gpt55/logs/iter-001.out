     2	// MODULE: Advisor Scorer Lane Registry
     3	// ───────────────────────────────────────────────────────────────
     4	
     5	import type { LaneDampingConfig } from './types.js';
     6	
     7	const LANE_DEFINITIONS = [
     8	  { id: 'explicit_author', defaultWeight: 0.42, defaultShadowWeight: 0.40, live: true },
     9	  { id: 'lexical', defaultWeight: 0.28, defaultShadowWeight: 0.25, live: true },
    10	  { id: 'graph_causal', defaultWeight: 0.13, defaultShadowWeight: 0.20, live: true },
    11	  { id: 'derived_generated', defaultWeight: 0.12, defaultShadowWeight: 0.10, live: true },
    12	  { id: 'semantic_shadow', defaultWeight: 0.05, defaultShadowWeight: 0.05, live: true },
    13	] as const satisfies readonly {
    14	  readonly id: string;
    15	  readonly defaultWeight: number;
    16	  readonly defaultShadowWeight: number;
    17	  readonly live: boolean;
    18	}[];
    19	
    20	export type ScorerLaneId = (typeof LANE_DEFINITIONS)[number]['id'];
    21	
    22	const DEFAULT_WEIGHTS = Object.fromEntries(
    23	  LANE_DEFINITIONS.map((lane) => [lane.id, lane.defaultWeight]),
    24	) as Record<ScorerLaneId, number>;
    25	
    26	const DEFAULT_SHADOW_WEIGHTS = Object.fromEntries(
    27	  LANE_DEFINITIONS.map((lane) => [lane.id, lane.defaultShadowWeight]),
    28	) as Record<ScorerLaneId, number>;
    29	
    30	function resolveLaneWeightsOverride(
    31	  envKey: string,
    32	  defaults: Record<ScorerLaneId, number>,
    33	): Record<ScorerLaneId, number> {
    34	  const raw = process.env[envKey];
    35	  if (typeof raw !== 'string' || raw.trim() === '') return defaults;
    36	  let parsed: unknown;
    37	  try {
    38	    parsed = JSON.parse(raw);
    39	  } catch {
    40	    return defaults;
    41	  }
    42	  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {
    43	    return defaults;
    44	  }
    45	  const merged: Record<ScorerLaneId, number> = { ...defaults };
    46	  for (const key of Object.keys(parsed) as ScorerLaneId[]) {
    47	    if (!(key in defaults)) continue;
    48	    const value = (parsed as Record<string, unknown>)[key];
    49	    if (typeof value === 'number' && Number.isFinite(value) && value >= 0 && value <= 1) {
    50	      merged[key] = value;
    51	    }
    52	  }
    53	  return merged;
    54	}
    55	
    56	const RESOLVED_WEIGHTS = resolveLaneWeightsOverride(
    57	  'SPECKIT_ADVISOR_LANE_WEIGHTS_JSON',
    58	  DEFAULT_WEIGHTS,
    59	);
    60	const RESOLVED_SHADOW_WEIGHTS = resolveLaneWeightsOverride(
    61	  'SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON',
    62	  DEFAULT_SHADOW_WEIGHTS,
    63	);
    64	
    65	export const SCORER_LANE_REGISTRY: readonly {
    66	  readonly id: ScorerLaneId;
    67	  readonly weight: number;
    68	  readonly shadowWeight: number;
    69	  readonly live: boolean;
    70	  readonly damping?: LaneDampingConfig;
    71	}[] = LANE_DEFINITIONS.map((lane) => ({
    72	  id: lane.id,
    73	  weight: RESOLVED_WEIGHTS[lane.id],
    74	  shadowWeight: RESOLVED_SHADOW_WEIGHTS[lane.id],
    75	  live: lane.live,
    76	}));
    77	
    78	export const SCORER_LANE_IDS = SCORER_LANE_REGISTRY.map((lane) => lane.id) as [
