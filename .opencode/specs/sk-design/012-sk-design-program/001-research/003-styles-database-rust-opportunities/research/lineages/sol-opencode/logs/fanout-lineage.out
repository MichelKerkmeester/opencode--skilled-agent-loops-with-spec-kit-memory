Config({ kind: 'cli-claude-code', model: 'claude-opus-4-6', reasoningEffort: 'high' }),\n\n  Line 129:       parseExecutorConfig({ kind: 'cli-claude-code', model: 'claude-fable-5', configDir: '~/.claude-account2' }),\n\n  Line 138:     expect(() => parseExecutorConfig({ kind: 'cli-claude-code', model: 'claude-fable-5', configDir: '   ' })).toThrow(\n\n  Line 144:     expect(() => parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', configDir: '~/.claude-account2' })).toThrowError(\n\n  Line 150:     expect(() => parseExecutorConfig({ kind: 'mystery-cli', model: 'x' })).toThrow(ExecutorConfigError);\n\n  Line 154:     expect(() => parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', reasoningEffort: 'super' })).toThrow(\n\n  Line 160:     expect(() => parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', serviceTier: 'slow' })).toThrow(\n\n  Line 166:     expect(() => parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', timeoutSeconds: 0 })).toThrow(\n\n  Line 172:     expect(parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1' }).timeoutSeconds).toBe(900);\n\n  Line 177:       parseExecutorConfig({ kind: 'cli-claude-code', model: 'claude-opus-4-6', serviceTier: 'fast' }),\n\n  Line 182:     expect(() => parseExecutorConfig({ kind: 'native', model: 'foo' })).toThrowError(\n\n  Line 193:       parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', reasoningEffort: 'high' }),\n\n  Line 203:       parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/qwen3.6-plus', sandboxMode: 'workspace-write' }),\n\n  Line 213:       parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', serviceTier: 'fast' }),\n\n  Line 218:     expect(parseExecutorConfig({ kind: 'cli-opencode' })).toMatchObject({\n\n  Line 442:       parseExecutorConfig({ kind: 'cli-opencode', model: 'opencode-go/glm-5.1', timeoutSeconds: 3601 }),\n\n  Line 448:     