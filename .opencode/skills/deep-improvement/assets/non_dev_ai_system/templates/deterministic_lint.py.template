#!/usr/bin/env python3
"""Deterministic hard-blocker linter for {{SYSTEM_NAME}} outputs.

Usage: deterministic_lint.py <file>   ->  prints JSON {file, clean, violations:[{type,count,samples}]}

This is a CODE gate, not an LLM judge (council requirement: gates checked by code, never a
model that can be talked past). It checks the high-confidence, low-false-positive hard
blockers only.

It strips ANSI + opencode tool-log lines + the attestation/score meta before checking, so it
inspects the deliverable body rather than the harness wrapper.
"""
import sys, json, re

AI_VOCAB = {{HARD_BLOCKER_WORDS}}
PATTERNS = {{HARD_BLOCKER_PATTERNS}}
SOFT_PHRASES = {{SOFT_PHRASE_PATTERNS}}

ANSI = re.compile(r"\x1b\[[0-9;]*m")
TOOL_LOG = re.compile(r"^\s*[→✱←$]\s|^\s*>\s*build\s|^\s*Wrote file|^\s*-rw-r")
META = re.compile(r"^\s*(Attestation:|MEQT|HVR|Mode:|Framework:|Template:|Export-equivalent|Export path|Perspectives:|Kernel-Version|Processing Summary|Key Design Decisions|Quality Validation|DEPTH Analysis|DEAL Analysis|\*\*[DEPTH] [—-])", re.I)
DELIM = re.compile(r"<DELIVERABLE>(.*?)</DELIVERABLE>", re.S | re.I)
FENCE = re.compile(r"```[a-zA-Z]*\n(.*?)```", re.S)


def extract_deliverable(raw: str):
    """Return (text, confidence). Prefer explicit <DELIVERABLE> tags, then fenced blocks,
    else fall back to the whole body (low confidence — reasoning will contaminate)."""
    raw = ANSI.sub("", raw)
    tags = DELIM.findall(raw)
    if tags:
        return "\n".join(tags), "high"
    fences = FENCE.findall(raw)
    if fences:
        body = "\n".join("\n".join(l for l in f.splitlines() if not META.search(l)) for f in fences)
        return body, "medium"
    kept = [l for l in raw.splitlines() if not TOOL_LOG.search(l) and not META.search(l)]
    return "\n".join(kept), "low"


def samples(pattern, text, n=2):
    out = []
    for m in pattern.finditer(text):
        s = text[max(0, m.start() - 25): m.end() + 25].replace("\n", " ")
        out.append(s.strip())
        if len(out) >= n:
            break
    return out


def lint(text: str):
    v = []

    def add(kind, pat, severity="hard"):
        hits = list(pat.finditer(text))
        if hits:
            v.append({"type": kind, "severity": severity, "count": len(hits), "samples": samples(pat, text)})

    for entry in PATTERNS:
        add(entry["label"], re.compile(entry["regex"], re.I), severity=entry.get("severity", "hard"))
    for w in AI_VOCAB:
        add(f"ai_vocab:{w}", re.compile(r"\b" + re.escape(w) + r"\b", re.I))
    for p in SOFT_PHRASES:
        add(f"phrase:{p}", re.compile(re.escape(p), re.I), severity="soft")
    return v


def main():
    path = sys.argv[1]
    raw = open(path, encoding="utf-8", errors="replace").read()
    text, confidence = extract_deliverable(raw)
    viols = lint(text)
    hard = [x for x in viols if x["severity"] == "hard"]
    print(json.dumps({
        "file": path,
        "extraction_confidence": confidence,
        "clean": len(hard) == 0,
        "hard_violations": len(hard),
        "violations": viols,
    }, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
