{"type":"tool_use","timestamp":1781150554432,"sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","part":{"type":"tool","tool":"read","callID":"call_HHdOYc3B5PafYb1GOJR5vBx0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/scripts/reduce-state.cjs","offset":1201,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1201: function buildRegistry(strategyDimensions, iterationFiles, iterationRecords, config, corruptionWarnings = [], deltaRecords = []) {\n1202:   const terminalStop = buildTerminalStopState(iterationRecords);\n1203:   const lineage = buildLineageState(config, iterationRecords, terminalStop);\n1204:   const { openFindings, resolvedFindings } = buildFindingRegistry(iterationFiles, iterationRecords, deltaRecords);\n1205:   const dimensionCoverage = buildDimensionCoverage(iterationRecords, strategyDimensions);\n1206:   const findingsBySeverity = buildFindingsBySeverity(openFindings);\n1207:   const convergenceScore = computeConvergenceScore(iterationRecords);\n1208:   const graphConvergence = buildGraphConvergenceRollup(iterationRecords);\n1209:   const blockedStopHistory = buildBlockedStopHistory(iterationRecords);\n1210:   const searchLedgerState = buildSearchLedgerState(iterationRecords);\n1211:   const traceability = buildTraceabilityRollup(iterationRecords);\n1212:   const fieldWarnings = validateReviewRecordFields(iterationRecords);\n1213:   const status = deriveDashboardStatus(config, iterationRecords, terminalStop);\n1214: \n1215:   // Split repeatedFindings into two semantically distinct buckets\n1216:   // so persistent-same-severity findings and severity-churn findings don't collapse.\n1217:   const persistentSameSeverity = openFindings.filter((finding) => {\n1218:     if (finding.lastSeen - finding.firstSeen < 1) return false;\n1219:     const transitions = Array.isArray(finding.transitions) ? finding.transitions : [];\n1220:     // Exclude the initial discovery transition from the \"no change\" count\n1221:     const nontrivialTransitions = transitions.filter((t) => t.from !== null);\n1222:     return nontrivialTransitions.length === 0;\n1223:   });\n1224: \n1225:   const severityChanged = openFindings.filter((finding) => {\n1226:     const transitions = Array.isArray(finding.transitions) ? finding.transitions : [];\n1227:     const nontrivialTransitions = transitions.filter((t) => t.from !== null);\n1228:     return nontrivialTransitions.length > 0;\n1229:   });\n1230: \n1231:   // Deprecated: keep repeatedFindings for backward compatibility with older consumers.\n1232:   // New code should read persistentSameSeverity + severityChanged directly.\n1233:   const repeatedFindings = openFindings.filter((finding) => finding.lastSeen - finding.firstSeen >= 1);\n1234: \n1235:   return {\n1236:     sessionId: lineage.sessionId,\n1237:     parentSessionId: lineage.parentSessionId,\n1238:     generation: lineage.generation,\n1239:     lineageMode: lineage.lineageMode,\n1240:     continuedFromRun: lineage.continuedFromRun,\n1241:     terminalStop,\n1242:     status,\n1243:     openFindings,\n1244:     resolvedFindings,\n1245:     blockedStopHistory,\n1246:     persistentSameSeverity,\n1247:     severityChanged,\n1248:     repeatedFindings,\n1249:     dimensionCoverage,\n1250:     findingsBySeverity,\n1251:     openFindingsCount: openFindings.length,\n1252:     resolvedFindingsCount: resolvedFindings.length,\n1253:     convergenceScore,\n1254:     graphConvergenceScore: graphConvergence.score,\n1255:     graphDecision: graphConvergence.decision,\n1256:     graphBlockers: graphConvergence.blockers,\n1257:     candidateCoverage: searchLedgerState.candidateCoverage,\n1258:     searchDebt: searchLedgerState.searchDebt,\n1259:     ruledOutCandidates: searchLedgerState.ruledOutCandidates,\n1260:     cleanSearchProof: searchLedgerState.cleanSearchProof,\n1261:     searchCoverage: searchLedgerState.searchCoverage,\n1262:     traceability,\n1263:     fieldWarnings,\n1264:     corruptionWarnings,\n1265:   };\n1266: }\n1267: \n1268: function blockFromBulletList(items) {\n1269:   if (!items.length) {\n1270:     return '[None yet]';\n1271:   }\n1272:   return items.map((item) => `- ${item}`).join('\\n');\n1273: }\n1274: \n1275: function summarizeSearchEntry(entry) {\n1276:   const evidence = Array.isArray(entry.evidenceRefs) && entry.evidenceRefs.length\n1277:     ? ` evidence=${entry.evidenceRefs.join(', ')}`\n1278:     : ' evidence=UNKNOWN';\n1279:   return `iteration ${entry.iteration ?? '?'} ${entry.bugClass || 'UNKNOWN'} (${entry.disposition || 'UNKNOWN'}): ${entry.reason || entry.proof || entry.rationale || 'UNKNOWN'};${evidence}`;\n1280: }\n1281: \n1282: function renderSearchDebtSection(registry) {\n1283:   const debt = Array.isArray(registry.searchDebt) ? registry.searchDebt : [];\n1284:   const ruledOut = Array.isArray(registry.ruledOutCandidates) ? registry.ruledOutCandidates : [];\n1285:   const cleanProof = Array.isArray(registry.cleanSearchProof) ? registry.cleanSearchProof : [];\n1286:   const coverage = registry.searchCoverage && typeof registry.searchCoverage === 'object'\n1287:     ? registry.searchCoverage\n1288:     : {};\n1289:   const candidateCoverage = registry.candidateCoverage && typeof registry.candidateCoverage === 'object'\n1290:     ? registry.candidateCoverage\n1291:     : {};\n1292: \n1293:   if (!debt.length && !ruledOut.length && !cleanProof.length) {\n1294:     return [\n1295:       '- No search-depth state captured (legacy v1 record).',\n1296:       `- graphCoverageMode: ${coverage.graphCoverageMode || 'none'}`,\n1297:     ].join('\\n');\n1298:   }\n1299: \n1300:   return [\n1301:     `- graphCoverageMode: ${coverage.graphCoverageMode || 'none'}`,\n1302:     `- candidateCoverage: covered=${(candidateCoverage.covered || []).length}, ruledOut=${(candidateCoverage.ruledOut || []).length}, deferred=${(candidateCoverage.deferred || []).length}, blocked=${(candidateCoverage.blocked || []).length}`,\n1303:     '',\n1304:     '### Search Debt',\n1305:     blockFromBulletList(debt.map(summarizeSearchEntry)),\n1306:     '',\n1307:     '### Ruled-Out Candidates',\n1308:     blockFromBulletList(ruledOut.map(summarizeSearchEntry)),\n1309:     '',\n1310:     '### Clean Search Proof',\n1311:     blockFromBulletList(cleanProof.map(summarizeSearchEntry)),\n1312:   ].join('\\n');\n1313: }\n1314: \n1315: function buildExhaustedApproaches(iterationFiles) {\n1316:   const grouped = new Map();\n1317: \n1318:   for (const iteration of iterationFiles) {\n1319:     for (const entry of iteration.deadEnds.concat(iteration.ruledOut)) {\n1320:       const bucket = grouped.get(entry) || [];\n1321:       bucket.push(iteration.run);\n1322:       grouped.set(entry, bucket);\n1323:     }\n1324:   }\n1325: \n1326:   if (!grouped.size) {\n1327:     return '[No exhausted approach categories yet]';\n1328:   }\n1329: \n1330:   return Array.from(grouped.entries())\n1331:     .sort(([left], [right]) => left.localeCompare(right))\n1332:     .map(([entry, runs]) => {\n1333:       const attemptCount = runs.length;\n1334:       const lastRun = Math.max(...runs);\n1335:       return [\n1336:         `### ${entry} -- BLOCKED (iteration ${lastRun}, ${attemptCount} attempts)`,\n1337:         `- What was tried: ${entry}`,\n1338:         `- Why blocked: Repeated iteration evidence ruled this direction out.`,\n1339:         `- Do NOT retry: ${entry}`,\n1340:       ].join('\\n');\n1341:     })\n1342:     .join('\\n\\n');\n1343: }\n1344: \n1345: function replaceAnchorSection(content, anchorId, heading, body, options = {}) {\n1346:   const pattern = new RegExp(`<!-- ANCHOR:${anchorId} -->[\\\\s\\\\S]*?<!-- \\\\/ANCHOR:${anchorId} -->`, 'm');\n1347:   const replacement = [\n1348:     `<!-- ANCHOR:${anchorId} -->`,\n1349:     `## ${heading}`,\n1350:     body.trim() ? body.trim() : '[None yet]',\n1351:     '',\n1352:     `<!-- /ANCHOR:${anchorId} -->`,\n1353:   ].join('\\n');\n1354: \n1355:   if (!pattern.test(content)) {\n1356:     if (options.createMissing) {\n1357:       const suffix = content.endsWith('\\n') ? '' : '\\n';\n1358:       return `${content}${suffix}\\n${replacement}\\n`;\n1359:     }\n1360:     throw new Error(\n1361:       `Missing machine-owned anchor \"${anchorId}\" in deep-review strategy file. `\n1362:       + 'Pass createMissing:true (or the reducer CLI flag --create-missing-anchors) to bootstrap.',\n1363:     );\n1364:   }\n1365:   return content.replace(pattern, replacement);\n1366: }\n1367: \n1368: function updateStrategyContent(strategyContent, registry, iterationFiles, options = {}, iterationRecords = []) {\n1369:   // Early return when there is no strategy file to update. Empty content\n1370:   // cannot contain the machine-owned anchors and replaceAnchorSection would\n1371:   // correctly fail-close — but for that specific case we intentionally skip\n1372:   // rather than throw so bootstrap flows (no strategy yet) still work.\n1373:   if (!strategyContent) {\n1374:     return strategyContent;\n1375:   }\n1376: \n1377:   const anchorOptions = { createMissing: Boolean(options.createMissingAnchors) };\n1378:   const severity = registry.findingsBySeverity;\n1379:   const runningFindings = [\n1380:     `- P0 (Blockers): ${severity.P0}`,\n1381:     `- P1 (Required): ${severity.P1}`,\n1382:     `- P2 (Suggestions): ${severity.P2}`,\n1383:     `- Resolved: ${registry.resolvedFindingsCount}`,\n1384:   ].join('\\n');\n1385: \n1386:   const completedDimensions = REQUIRED_DIMENSIONS\n1387:     .filter((dimension) => registry.dimensionCoverage[dimension])\n1388:     .map((dimension) => `- [x] ${dimension}`)\n1389:     .join('\\n') || '[None yet]';\n1390: \n1391:   const remainingDimensions = REQUIRED_DIMENSIONS\n1392:     .filter((dimension) => !registry.dimensionCoverage[dimension])\n1393:     .map((dimension) => `- [ ] ${dimension}`)\n1394:     .join('\\n') || '[All dimensions complete]';\n1395: \n1396:   // Default next-focus comes from latest iteration → first uncovered dimension → fallback.\n1397:   let nextFocus = iterationFiles.map((iteration) => iteration.nextFocus).filter(Boolean).at(-1)\n1398:     || REQUIRED_DIMENSIONS.find((dimension) => !registry.dimensionCoverage[dimension])\n1399:     || '[All dimensions covered]';\n1400: \n1401:   // Prefer the latest blocked-stop\n1402:   // recovery only when blocked-stop is genuinely the most recent loop event.\n1403:   // The earlier implementation read timestamps from the markdown iteration\n1404:   // files, but parseIterationFile() never captures timestamps, so\n1405:   // latestIterationTimestamp was always undefined and any historical\n1406:   // blocked-stop permanently pinned next-focus. Fix: source recency from the\n1407:   // JSONL iteration records (which do carry timestamps) instead.\n1408:   const latestBlockedStop = registry.blockedStopHistory?.at(-1);\n1409:   if (latestBlockedStop && latestBlockedStop.timestamp) {\n1410:     const latestIterationTimestamp = iterationRecords\n1411:       .filter((record) => record?.type === 'iteration' && typeof record.timestamp === 'string')\n1412:       .map((record) => record.timestamp)\n1413:       .at(-1);\n1414:     const blockedIsMostRecent = !latestIterationTimestamp\n1415:       || latestBlockedStop.timestamp >= latestIterationTimestamp;\n1416:     if (blockedIsMostRecent) {\n1417:       const blockers = formatBlockedByList(latestBlockedStop.blockedBy);\n1418:       const recovery = latestBlockedStop.recoveryStrategy || '[no recovery strategy provided]';\n1419:       nextFocus = [\n1420:         `BLOCKED on: ${blockers}`,\n1421:         `Recovery: ${recovery}`,\n1422:         'Address the blocking gates before the next iteration.',\n1423:       ].join('\\n');\n1424:     }\n1425:   }\n1426: \n1427:   let updated = strategyContent;\n1428:   updated = replaceAnchorSection(updated, 'review-dimensions', '3. REVIEW DIMENSIONS (remaining)', remainingDimensions, anchorOptions);\n1429:   updated = replaceAnchorSection(updated, 'completed-dimensions', '4. COMPLETED DIMENSIONS', completedDimensions, anchorOptions);\n1430:   updated = replaceAnchorSection(updated, 'running-findings', '5. RUNNING FINDINGS', runningFindings, anchorOptions);\n1431:   updated = replaceAnchorSection(\n1432:     updated,\n1433:     'exhausted-approaches',\n1434:     '9. EXHAUSTED APPROACHES (do not retry)',\n1435:     buildExhaustedApproaches(iterationFiles),\n1436:     anchorOptions,\n1437:   );\n1438:   updated = replaceAnchorSection(updated, 'next-focus', '11. NEXT FOCUS', nextFocus, anchorOptions);\n1439:   return updated;\n1440: }\n1441: \n1442: function renderDashboard(config, registry, iterationRecords, iterationFiles) {\n1443:   const latestIteration = iterationRecords.filter((record) => record.type === 'iteration').at(-1);\n1444:   const ratios = iterationRecords\n1445:     .filter((record) => record.type === 'iteration')\n1446:     .map((record) => (typeof record.newFindingsRatio === 'number' ? record.newFindingsRatio : null))\n1447:     .filter((value) => value !== null);\n1448:   const lastThreeRatios = ratios.slice(-3).map((value) => value.toFixed(2)).join(' -> ') || 'N/A';\n1449:   const nextFocus = iterationFiles.map((iteration) => iteration.nextFocus).filter(Boolean).at(-1)\n1450:     || REQUIRED_DIMENSIONS.find((dimension) => !registry.dimensionCoverage[dimension])\n1451:     || '[All dimensions covered]';\n1452: \n1453:   const severity = registry.findingsBySeverity;\n1454:   const hasSearchDebt = Array.isArray(registry.searchDebt) && registry.searchDebt.length > 0;\n1455:   const verdict = severity.P0 > 0\n1456:     ? 'FAIL'\n1457:     : severity.P1 > 0 || hasSearchDebt\n1458:       ? 'CONDITIONAL'\n1459:       : 'PASS';\n1460:   const hasAdvisories = verdict === 'PASS' && severity.P2 > 0;\n1461: \n1462:   const progressRows = iterationRecords\n1463:     .filter((record) => record.type === 'iteration')\n1464:     .map((record) => {\n1465:       const dimensions = Array.isArray(record.dimensions) ? record.dimensions.join('/') : '-';\n1466:       const ratio = typeof record.newFindingsRatio === 'number' ? record.newFindingsRatio.toFixed(2) : '0.00';\n1467:       const summary = record.findingsSummary || {};\n1468:       const findings = `${summary.P0 ?? 0}/${summary.P1 ?? 0}/${summary.P2 ?? 0}`;\n1469:       return `| ${record.run} | ${record.focus || 'unknown'} | ${dimensions} | ${ratio} | ${findings} | ${record.status || 'complete'} |`;\n1470:     })\n1471:     .join('\\n') || '| 0 | none yet | - | 0.00 | 0/0/0 | initialized |';\n1472: \n1473:   const dimensionRows = REQUIRED_DIMENSIONS\n1474:     .map((dimension) => {\n1475:       const covered = registry.dimensionCoverage[dimension];\n1476:       const status = covered ? 'covered' : 'pending';\n1477:       const openInDimension = registry.openFindings.filter((finding) => finding.dimension === dimension).length;\n1478:       return `| ${dimension} | ${status} | ${openInDimension} |`;\n1479:     })\n1480:     .join('\\n');\n1481: \n1482:   return [\n1483:     '---',\n1484:     'title: Deep Review Dashboard',\n1485:     'description: Auto-generated reducer view over the review packet.',\n1486:     '---',\n1487:     '',\n1488:     '# Deep Review Dashboard - Session Overview',\n1489:     '',\n1490:     'Auto-generated from JSONL state log, iteration files, findings registry, and strategy state. Never manually edited.',\n1491:     '',\n1492:     '<!-- ANCHOR:overview -->',\n1493:     '## 1. OVERVIEW',\n1494:     '',\n1495:     'Reducer-generated observability surface for the active review packet.',\n1496:     '',\n1497:     '<!-- /ANCHOR:overview -->',\n1498:     '<!-- ANCHOR:status -->',\n1499:     '## 2. STATUS',\n1500:     `- Review Target: ${config.reviewTarget || '[Unknown target]'} (${config.reviewTargetType || 'unknown'})`,\n1501:     `- Started: ${config.createdAt || '[Unknown start]'}`,\n1502:     `- Status: ${registry.status || String(config.status || 'initialized').toUpperCase()}`,\n1503:     `- Iteration: ${iterationRecords.filter((record) => record.type === 'iteration').length} of ${config.maxIterations || 0}`,\n1504:     `- Provisional Verdict: ${verdict}`,\n1505:     `- hasSearchDebt: ${hasSearchDebt}`,\n1506:     `- hasAdvisories: ${hasAdvisories}`,\n1507:     `- Session ID: ${registry.sessionId || '[Unknown session]'}`,\n1508:     `- Parent Session: ${registry.parentSessionId ?? 'none'}`,\n1509:     `- Lifecycle Mode: ${registry.lineageMode || 'new'}`,\n1510:     `- Generation: ${registry.generation ?? 1}`,\n1511:     `- continuedFromRun: ${registry.continuedFromRun ?? 'none'}`,\n1512:     ...(registry.terminalStop?.stopReason ? [`- stopReason: ${registry.terminalStop.stopReason}`] : []),\n1513:     '',\n1514:     '<!-- /ANCHOR:status -->',\n1515:     '<!-- ANCHOR:findings-summary -->',\n1516:     '## 3. FINDINGS SUMMARY',\n1517:     '',\n1518:     '| Severity | Count |',\n1519:     '|----------|------:|',\n1520:     `| P0 (Blockers) | ${severity.P0} |`,\n1521:     `| P1 (Required) | ${severity.P1} |`,\n1522:     `| P2 (Suggestions) | ${severity.P2} |`,\n1523:     `| Resolved | ${registry.resolvedFindingsCount} |`,\n1524:     '',\n1525:     '<!-- /ANCHOR:findings-summary -->',\n1526:     '<!-- ANCHOR:progress -->',\n1527:     '## 4. PROGRESS',\n1528:     '',\n1529:     '| # | Focus | Dimensions | Ratio | P0/P1/P2 | Status |',\n1530:     '|---|-------|------------|-------|----------|--------|',\n1531:     progressRows,\n1532:     '',\n1533:     '<!-- /ANCHOR:progress -->',\n1534:     '<!-- ANCHOR:dimension-coverage -->',\n1535:     '## 5. DIMENSION COVERAGE',\n1536:     '',\n1537:     '| Dimension | Status | Open findings |',\n1538:     '|-----------|--------|--------------:|',\n1539:     dimensionRows,\n1540:     '',\n1541:     '<!-- /ANCHOR:dimension-coverage -->',\n1542:     '<!-- ANCHOR:blocked-stops -->',\n1543:     '## 6. BLOCKED STOPS',\n1544:     ...(registry.blockedStopHistory && registry.blockedStopHistory.length > 0\n1545:       ? registry.blockedStopHistory.flatMap((entry) => {\n1546:           const blockers = formatBlockedByList(entry.blockedBy);\n1547:           const gateSummary = entry.gateResults && typeof entry.gateResults === 'object'\n1548:             ? Object.entries(entry.gateResults)\n1549:                 .map(([gate, result]) => {\n1550:                   const pass = result && typeof result === 'object' && 'pass' in result ? result.pass : '?';\n1551:                   return `${gate}: ${pass}`;\n1552:                 })\n1553:                 .join(', ')\n1554:             : '[no gate results]';\n1555:           return [\n1556:             `### Iteration ${entry.run} — blocked by [${blockers}]`,\n1557:             `- Recovery: ${entry.recoveryStrategy || '[no recovery strategy recorded]'}`,\n1558:             `- Gate results: ${gateSummary}`,\n1559:             `- Timestamp: ${entry.timestamp || '[no timestamp]'}`,\n1560:             '',\n1561:           ];\n1562:         })\n1563:       : ['No blocked-stop events recorded.', '']),\n1564:     '<!-- /ANCHOR:blocked-stops -->',\n1565:     '<!-- ANCHOR:graph-convergence -->',\n1566:     '## 7. GRAPH CONVERGENCE',\n1567:     `- graphConvergenceScore: ${Number(registry.graphConvergenceScore || 0).toFixed(2)}`,\n1568:     `- graphDecision: ${registry.graphDecision || 'none'}`,\n1569:     ...(Array.isArray(registry.graphBlockers) && registry.graphBlockers.length > 0\n1570:       ? [`- graphBlockers: ${registry.graphBlockers.map((b) => (typeof b === 'string' ? b : JSON.stringify(b))).join(', ')}`]\n1571:       : ['- graphBlockers: none']),\n1572:     '',\n1573:     '<!-- /ANCHOR:graph-convergence -->',\n1574:     '<!-- ANCHOR:trend -->',\n1575:     '## 8. TREND',\n1576:     `- Last 3 ratios: ${lastThreeRatios}`,\n1577:     `- convergenceScore: ${Number(registry.convergenceScore || 0).toFixed(2)}`,\n1578:     `- openFindings: ${registry.openFindingsCount}`,\n1579:     `- persistentSameSeverity: ${(registry.persistentSameSeverity || []).length}`,\n1580:     `- severityChanged: ${(registry.severityChanged || []).length}`,\n1581:     `- repeatedFindings (deprecated combined bucket): ${registry.repeatedFindings.length}`,\n1582:     '',\n1583:     '<!-- /ANCHOR:trend -->',\n1584:     '<!-- ANCHOR:corruption-warnings -->',\n1585:     '## 9. CORRUPTION WARNINGS',\n1586:     ...(Array.isArray(registry.corruptionWarnings) && registry.corruptionWarnings.length > 0\n1587:       ? registry.corruptionWarnings.map((w) => `- Line ${w.line}: ${w.error} (raw: ${w.raw})`)\n1588:       : ['No corrupt JSONL lines detected.']),\n1589:     '',\n1590:     '<!-- /ANCHOR:corruption-warnings -->',\n1591:     '<!-- ANCHOR:search-debt -->',\n1592:     '## 10. SEARCH DEBT',\n1593:     renderSearchDebtSection(registry),\n1594:     '',\n1595:     '<!-- /ANCHOR:search-debt -->',\n1596:     '<!-- ANCHOR:next-focus -->',\n1597:     '## 11. NEXT FOCUS',\n1598:     nextFocus,\n1599:     '',\n1600:     '<!-- /ANCHOR:next-focus -->',\n1601:     '<!-- ANCHOR:active-risks -->',\n1602:     '## 12. ACTIVE RISKS',\n1603:     ...(function buildActiveRisks() {\n1604:       // Surface non-P0 release-readiness debt alongside P0s so the dashboard\n1605:       // cannot hide P1 debt behind a\n1606:       // \"None active\" summary when activeP0 == 0. Gate debt on the latest\n1607:       // `blocked_stop` and `claim_adjudication` events so operators see\n1608:       // claim-adjudication and legal-stop gate failures, not just severity.\n1609:       const lines = [];\n1610:       if (latestIteration?.status === 'error') {\n1611:         lines.push('- Latest iteration reported error status.');\n1612:       }\n1613:       if (severity.P0 > 0) {\n1614:         lines.push(`- ${severity.P0} active P0 finding(s) blocking release.`);\n1615:       }\n1616:       if (severity.P1 > 0) {\n1617:         lines.push(`- ${severity.P1} active P1 finding(s) — required before release; not a P0 but still blocks PASS.`);\n1618:       }\n1619:       const latestClaimAdjudication = [...iterationRecords]\n1620:         .reverse()\n1621:         .find((record) => record\n1622:           && record.type === 'event'\n1623:           && record.event === 'claim_adjudication'\n1624:           && typeof getNestedField(record, 'passed') === 'boolean'\n1625:           && !normalizeText(getNestedField(record, 'findingId') || ''));\n1626:       const activeP0P1 = severity.P0 + severity.P1;\n1627:       const adjudicationActiveCount = isFiniteNumber(getNestedField(latestClaimAdjudication, 'activeP0P1'))\n1628:         ? getNestedField(latestClaimAdjudication, 'activeP0P1')\n1629:         : activeP0P1;\n1630:       if (latestClaimAdjudication && getNestedField(latestClaimAdjudication, 'passed') === false && activeP0P1 > 0 && adjudicationActiveCount > 0) {\n1631:         const missingPackets = getNestedField(latestClaimAdjudication, 'missingPackets');\n1632:         const missing = Array.isArray(missingPackets) && missingPackets.length > 0\n1633:           ? ` (missing packets: ${missingPackets.join(', ')})`\n1634:           : '';\n1635:         lines.push(`- Claim-adjudication gate last failed at run ${latestClaimAdjudication.run ?? '?'}${missing}. STOP is vetoed until every active P0/P1 has a typed claim-adjudication packet.`);\n1636:       }\n1637:       const latestBlockedStop = registry.blockedStopHistory?.at(-1);\n1638:       if (latestBlockedStop && Array.isArray(latestBlockedStop.blockedBy) && latestBlockedStop.blockedBy.length > 0) {\n1639:         lines.push(`- Latest blocked_stop at run ${latestBlockedStop.run ?? '?'}: ${formatBlockedByList(latestBlockedStop.blockedBy)}. Recovery: ${latestBlockedStop.recoveryStrategy || 'see dashboard §BLOCKED STOPS'}.`);\n1640:       }\n1641:       if (hasSearchDebt) {\n1642:         lines.push(`- ${registry.searchDebt.length} search-debt obligation(s) remain deferred or blocked. Verdict is CONDITIONAL until they are covered or ruled out.`);\n1643:       }\n1644:       if (severity.P2 > 0 && lines.length === 0) {\n1645:         lines.push(`- ${severity.P2} active P2 finding(s) — advisory only; release is not blocked by P2 alone, but the debt is tracked here so it does not disappear.`);\n1646:       }\n1647:       if (lines.length === 0) {\n1648:         lines.push('- None active beyond normal review uncertainty.');\n1649:       }\n1650:       return lines;\n1651:     })(),\n1652:     '',\n1653:     '<!-- /ANCHOR:active-risks -->',\n1654:     '',\n1655:   ].join('\\n');\n1656: }\n1657: \n1658: /**\n1659:  * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n1660:  * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n1661:  *\n1662:  * @param {string} specFolder - Path to the target spec folder for the review packet\n1663:  * @param {Object} [options] - Reducer options\n1664:  * @param {boolean} [options.write=true] - Write outputs to disk when true\n1665:  * @returns {Object} Paths and content for registry, strategy, and dashboard\n1666:  */\n1667: function reduceReviewState(specFolder, options = {}) {\n1668:   const write = options.write !== false;\n1669:   const lenient = Boolean(options.lenient);\n1670:   const createMissingAnchors = Boolean(options.createMissingAnchors);\n1671:   const emitResourceMapOutput = Boolean(options.emitResourceMap);\n1672:   const resolvedSpecFolder = path.resolve(specFolder);\n1673:   const { artifactDir: reviewDir } = resolveArtifactRoot(resolvedSpecFolder, 'review');\n1674:   const configPath = path.join(reviewDir, 'deep-review-config.json');\n1675:   const stateLogPath = path.join(reviewDir, 'deep-review-state.jsonl');\n1676:   const strategyPath = path.join(reviewDir, 'deep-review-strategy.md');\n1677:   const registryPath = path.join(reviewDir, 'deep-review-findings-registry.json');\n1678:   const dashboardPath = path.join(reviewDir, 'deep-review-dashboard.md');\n1679:   const resourceMapPath = path.join(reviewDir, 'resource-map.md');\n1680:   const iterationDir = path.join(reviewDir, 'iterations');\n1681:   const deltaDir = path.join(reviewDir, 'deltas');\n1682: \n1683:   const config = readJson(configPath);\n1684:   const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(stateLogPath));\n1685:   const terminalStop = buildTerminalStopState(records);\n1686:   const lineage = buildLineageState(config, records, terminalStop);\n1687:   config.sessionId = lineage.sessionId || config.sessionId || '';\n1688:   config.parentSessionId = lineage.parentSessionId;\n1689:   config.lineageMode = lineage.lineageMode;\n1690:   config.generation = lineage.generation;\n1691:   config.continuedFromRun = lineage.continuedFromRun;\n1692:   if (terminalStop?.stopReason) {\n1693:     config.stopReason = terminalStop.stopReason;\n1694:   }\n1695:   const strategyContent = fs.existsSync(strategyPath) ? readUtf8(strategyPath) : '';\n1696:   const strategyDimensions = parseStrategyDimensions(strategyContent);\n1697:   const iterationFiles = fs.existsSync(iterationDir)\n1698:     ? fs.readdirSync(iterationDir)\n1699:         .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n1700:         .sort()\n1701:         .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n1702:     : [];\n1703: \n1704:   // P1-026 fix: load delta payloads up-front so the finding registry can be\n1705:   // built from {type:\"finding\"} delta records (primary source) rather than\n1706:   // relying solely on iteration markdown parsing (legacy/fallback). The\n1707:   // resource-map emit path below reuses these loaded payloads.\n1708:   const deltaPayloads = fs.existsSync(deltaDir) ? loadDeltaPayloads(deltaDir) : [];\n1709:   const flattenedDeltaRecords = deltaPayloads\n1710:     .flat()\n1711:     .filter((record) => record !== null && record !== undefined);\n1712: \n1713:   const registry = buildRegistry(strategyDimensions, iterationFiles, records, config, corruptionWarnings, flattenedDeltaRecords);\n1714:   const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, { createMissingAnchors }, records);\n1715:   const dashboard = renderDashboard(config, registry, records, iterationFiles);\n1716:   let resourceMap = null;\n1717:   let resourceMapSkipped = true;\n1718:   let resourceMapSkipReason = null;\n1719: \n1720:   if (corruptionWarnings.length > 0 && !lenient) {\n1721:     throw createCorruptionError(stateLogPath, corruptionWarnings);\n1722:   }\n1723: \n1724:   if (emitResourceMapOutput) {\n1725:     if (getResourceMapEmitSetting(config) === false) {\n1726:       resourceMapSkipReason = 'config.resource_map.emit=false';\n1727:     } else {\n1728:       // Reuse the deltaPayloads already loaded above (P1-026 fix) — avoids re-reading.\n1729:       if (!deltaPayloads.length) {\n1730:         resourceMapSkipReason = 'no delta files found';\n1731:       } else {\n1732:         resourceMap = emitResourceMap({\n1733:           shape: 'review',\n1734:           deltas: deltaPayloads,\n1735:           packet: {\n1736:             title: config.reviewTarget || path.basename(resolvedSpecFolder),\n1737:             specFolder: resolvedSpecFolder,\n1738:           },\n1739:           scope: `review convergence output for ${path.basename(resolvedSpecFolder)}`,\n1740:           createdAt: new Date().toISOString(),\n1741:         });\n1742:         resourceMapSkipped = false;\n1743:       }\n1744:     }\n1745:   }\n1746: \n1747:   if (write) {\n1748:     writeUtf8(registryPath, `${JSON.stringify(registry, null, 2)}\\n`);\n1749:     if (strategyContent) {\n1750:       writeUtf8(strategyPath, strategy.endsWith('\\n') ? strategy : `${strategy}\\n`);\n1751:     }\n1752:     writeUtf8(dashboardPath, dashboard);\n1753:     if (emitResourceMapOutput && resourceMap) {\n1754:       writeUtf8(resourceMapPath, resourceMap);\n1755:     }\n1756:   }\n1757: \n1758:   return {\n1759:     configPath,\n1760:     stateLogPath,\n1761:     strategyPath,\n1762:     registryPath,\n1763:     dashboardPath,\n1764:     resourceMapPath,\n1765:     registry,\n1766:     strategy,\n1767:     dashboard,\n1768:     resourceMap,\n1769:     resourceMapSkipped,\n1770:     resourceMapSkipReason,\n1771:     corruptionWarnings,\n1772:     hasCorruption: corruptionWarnings.length > 0,\n1773:   };\n1774: }\n1775: \n1776: // ─────────────────────────────────────────────────────────────────────────────\n1777: // 6. CLI ENTRY POINT\n1778: // ─────────────────────────────────────────────────────────────────────────────\n1779: \n1780: if (require.main === module) {\n1781:   const args = process.argv.slice(2);\n1782:   const lenient = args.includes('--lenient');\n1783:   const createMissingAnchors = args.includes('--create-missing-anchors');\n1784:   const emitResourceMapOutput = args.includes('--emit-resource-map');\n1785:   const positional = args.filter((arg) => !arg.startsWith('--'));\n1786:   const specFolder = positional[0];\n1787: \n1788:   if (!specFolder) {\n1789:     process.stderr.write(\n1790:       'Usage: node .opencode/skills/deep-review/scripts/reduce-state.cjs <spec-folder> [--lenient] [--create-missing-anchors] [--emit-resource-map]\\n',\n1791:     );\n1792:     process.exit(1);\n1793:   }\n1794: \n1795:   try {\n1796:     const result = reduceReviewState(specFolder, {\n1797:       write: true,\n1798:       lenient,\n1799:       createMissingAnchors,\n1800:       emitResourceMap: emitResourceMapOutput,\n1801:     });\n1802:     process.stdout.write(\n1803:       `${JSON.stringify(\n1804:         {\n1805:           registryPath: result.registryPath,\n1806:           dashboardPath: result.dashboardPath,\n1807:           strategyPath: result.strategyPath,\n1808:           openFindingsCount: result.registry.openFindingsCount,\n1809:           resolvedFindingsCount: result.registry.resolvedFindingsCount,\n1810:           convergenceScore: result.registry.convergenceScore,\n1811:           graphConvergenceScore: result.registry.graphConvergenceScore,\n1812:           searchDebtCount: Array.isArray(result.registry.searchDebt) ? result.registry.searchDebt.length : 0,\n1813:           corruptionCount: result.corruptionWarnings.length,\n1814:           resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n1815:           resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n1816:           resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n1817:         },\n1818:         null,\n1819:         2,\n1820:       )}\\n`,\n1821:     );\n1822:   } catch (error) {\n1823:     if (error && error.code === 'STATE_CORRUPTION') {\n1824:       process.stderr.write(`${error.message}\\n`);\n1825:       process.exit(2);\n1826:     }\n1827:     process.stderr.write(`[deep-review] reducer failed: ${error instanceof Error ? error.message : String(error)}\\n`);\n1828:     process.exit(3);\n1829:   }\n1830: }\n1831: \n1832: // ─────────────────────────────────────────────────────────────────────────────\n1833: // 7. EXPORTS\n1834: // ─────────────────────────────────────────────────────────────────────────────\n1835: \n1836: module.exports = {\n1837:   REQUIRED_DIMENSIONS,\n1838:   SEVERITY_KEYS,\n1839:   SEVERITY_WEIGHTS,\n1840:   buildGraphConvergenceRollup,\n1841:   parseIterationFile,\n1842:   parseJsonl,\n1843:   parseJsonlDetailed,\n1844:   parseFindingLine,\n1845:   replaceAnchorSection,\n1846:   reduceReviewState,\n1847:   deltaRecordToFinding,\n1848:   deriveDashboardStatus,\n1849:   collapseFindingsByDedupKey,\n1850:   findingDedupKey,\n1851:   buildTraceabilityRollup,\n1852:   validateReviewRecordFields,\n1853: };\n\n(End of file - total 1853 lines)\n</content>","metadata":{"preview":"function buildRegistry(strategyDimensions, iterationFiles, iterationRecords, config, corruptionWarnings = [], deltaRecords = []) {\n  const terminalStop = buildTerminalStopState(iterationRecords);\n  const lineage = buildLineageState(config, iterationRecords, terminalStop);\n  const { openFindings, resolvedFindings } = buildFindingRegistry(iterationFiles, iterationRecords, deltaRecords);\n  const dimensionCoverage = buildDimensionCoverage(iterationRecords, strategyDimensions);\n  const findingsBySeverity = buildFindingsBySeverity(openFindings);\n  const convergenceScore = computeConvergenceScore(iterationRecords);\n  const graphConvergence = buildGraphConvergenceRollup(iterationRecords);\n  const blockedStopHistory = buildBlockedStopHistory(iterationRecords);\n  const searchLedgerState = buildSearchLedgerState(iterationRecords);\n  const traceability = buildTraceabilityRollup(iterationRecords);\n  const fieldWarnings = validateReviewRecordFields(iterationRecords);\n  const status = deriveDashboardStatus(config, iterationRecords, terminalStop);\n\n  // Split repeatedFindings into two semantically distinct buckets\n  // so persistent-same-severity findings and severity-churn findings don't collapse.\n  const persistentSameSeverity = openFindings.filter((finding) => {\n    if (finding.lastSeen - finding.firstSeen < 1) return false;\n    const transitions = Array.isArray(finding.transitions) ? finding.transitions : [];\n    // Exclude the initial discovery transition from the \"no change\" count","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/scripts/reduce-state.cjs","text":"function buildRegistry(strategyDimensions, iterationFiles, iterationRecords, config, corruptionWarnings = [], deltaRecords = []) {\n  const terminalStop = buildTerminalStopState(iterationRecords);\n  const lineage = buildLineageState(config, iterationRecords, terminalStop);\n  const { openFindings, resolvedFindings } = buildFindingRegistry(iterationFiles, iterationRecords, deltaRecords);\n  const dimensionCoverage = buildDimensionCoverage(iterationRecords, strategyDimensions);\n  const findingsBySeverity = buildFindingsBySeverity(openFindings);\n  const convergenceScore = computeConvergenceScore(iterationRecords);\n  const graphConvergence = buildGraphConvergenceRollup(iterationRecords);\n  const blockedStopHistory = buildBlockedStopHistory(iterationRecords);\n  const searchLedgerState = buildSearchLedgerState(iterationRecords);\n  const traceability = buildTraceabilityRollup(iterationRecords);\n  const fieldWarnings = validateReviewRecordFields(iterationRecords);\n  const status = deriveDashboardStatus(config, iterationRecords, terminalStop);\n\n  // Split repeatedFindings into two semantically distinct buckets\n  // so persistent-same-severity findings and severity-churn findings don't collapse.\n  const persistentSameSeverity = openFindings.filter((finding) => {\n    if (finding.lastSeen - finding.firstSeen < 1) return false;\n    const transitions = Array.isArray(finding.transitions) ? finding.transitions : [];\n    // Exclude the initial discovery transition from the \"no change\" count\n    const nontrivialTransitions = transitions.filter((t) => t.from !== null);\n    return nontrivialTransitions.length === 0;\n  });\n\n  const severityChanged = openFindings.filter((finding) => {\n    const transitions = Array.isArray(finding.transitions) ? finding.transitions : [];\n    const nontrivialTransitions = transitions.filter((t) => t.from !== null);\n    return nontrivialTransitions.length > 0;\n  });\n\n  // Deprecated: keep repeatedFindings for backward compatibility with older consumers.\n  // New code should read persistentSameSeverity + severityChanged directly.\n  const repeatedFindings = openFindings.filter((finding) => finding.lastSeen - finding.firstSeen >= 1);\n\n  return {\n    sessionId: lineage.sessionId,\n    parentSessionId: lineage.parentSessionId,\n    generation: lineage.generation,\n    lineageMode: lineage.lineageMode,\n    continuedFromRun: lineage.continuedFromRun,\n    terminalStop,\n    status,\n    openFindings,\n    resolvedFindings,\n    blockedStopHistory,\n    persistentSameSeverity,\n    severityChanged,\n    repeatedFindings,\n    dimensionCoverage,\n    findingsBySeverity,\n    openFindingsCount: openFindings.length,\n    resolvedFindingsCount: resolvedFindings.length,\n    convergenceScore,\n    graphConvergenceScore: graphConvergence.score,\n    graphDecision: graphConvergence.decision,\n    graphBlockers: graphConvergence.blockers,\n    candidateCoverage: searchLedgerState.candidateCoverage,\n    searchDebt: searchLedgerState.searchDebt,\n    ruledOutCandidates: searchLedgerState.ruledOutCandidates,\n    cleanSearchProof: searchLedgerState.cleanSearchProof,\n    searchCoverage: searchLedgerState.searchCoverage,\n    traceability,\n    fieldWarnings,\n    corruptionWarnings,\n  };\n}\n\nfunction blockFromBulletList(items) {\n  if (!items.length) {\n    return '[None yet]';\n  }\n  return items.map((item) => `- ${item}`).join('\\n');\n}\n\nfunction summarizeSearchEntry(entry) {\n  const evidence = Array.isArray(entry.evidenceRefs) && entry.evidenceRefs.length\n    ? ` evidence=${entry.evidenceRefs.join(', ')}`\n    : ' evidence=UNKNOWN';\n  return `iteration ${entry.iteration ?? '?'} ${entry.bugClass || 'UNKNOWN'} (${entry.disposition || 'UNKNOWN'}): ${entry.reason || entry.proof || entry.rationale || 'UNKNOWN'};${evidence}`;\n}\n\nfunction renderSearchDebtSection(registry) {\n  const debt = Array.isArray(registry.searchDebt) ? registry.searchDebt : [];\n  const ruledOut = Array.isArray(registry.ruledOutCandidates) ? registry.ruledOutCandidates : [];\n  const cleanProof = Array.isArray(registry.cleanSearchProof) ? registry.cleanSearchProof : [];\n  const coverage = registry.searchCoverage && typeof registry.searchCoverage === 'object'\n    ? registry.searchCoverage\n    : {};\n  const candidateCoverage = registry.candidateCoverage && typeof registry.candidateCoverage === 'object'\n    ? registry.candidateCoverage\n    : {};\n\n  if (!debt.length && !ruledOut.length && !cleanProof.length) {\n    return [\n      '- No search-depth state captured (legacy v1 record).',\n      `- graphCoverageMode: ${coverage.graphCoverageMode || 'none'}`,\n    ].join('\\n');\n  }\n\n  return [\n    `- graphCoverageMode: ${coverage.graphCoverageMode || 'none'}`,\n    `- candidateCoverage: covered=${(candidateCoverage.covered || []).length}, ruledOut=${(candidateCoverage.ruledOut || []).length}, deferred=${(candidateCoverage.deferred || []).length}, blocked=${(candidateCoverage.blocked || []).length}`,\n    '',\n    '### Search Debt',\n    blockFromBulletList(debt.map(summarizeSearchEntry)),\n    '',\n    '### Ruled-Out Candidates',\n    blockFromBulletList(ruledOut.map(summarizeSearchEntry)),\n    '',\n    '### Clean Search Proof',\n    blockFromBulletList(cleanProof.map(summarizeSearchEntry)),\n  ].join('\\n');\n}\n\nfunction buildExhaustedApproaches(iterationFiles) {\n  const grouped = new Map();\n\n  for (const iteration of iterationFiles) {\n    for (const entry of iteration.deadEnds.concat(iteration.ruledOut)) {\n      const bucket = grouped.get(entry) || [];\n      bucket.push(iteration.run);\n      grouped.set(entry, bucket);\n    }\n  }\n\n  if (!grouped.size) {\n    return '[No exhausted approach categories yet]';\n  }\n\n  return Array.from(grouped.entries())\n    .sort(([left], [right]) => left.localeCompare(right))\n    .map(([entry, runs]) => {\n      const attemptCount = runs.length;\n      const lastRun = Math.max(...runs);\n      return [\n        `### ${entry} -- BLOCKED (iteration ${lastRun}, ${attemptCount} attempts)`,\n        `- What was tried: ${entry}`,\n        `- Why blocked: Repeated iteration evidence ruled this direction out.`,\n        `- Do NOT retry: ${entry}`,\n      ].join('\\n');\n    })\n    .join('\\n\\n');\n}\n\nfunction replaceAnchorSection(content, anchorId, heading, body, options = {}) {\n  const pattern = new RegExp(`<!-- ANCHOR:${anchorId} -->[\\\\s\\\\S]*?<!-- \\\\/ANCHOR:${anchorId} -->`, 'm');\n  const replacement = [\n    `<!-- ANCHOR:${anchorId} -->`,\n    `## ${heading}`,\n    body.trim() ? body.trim() : '[None yet]',\n    '',\n    `<!-- /ANCHOR:${anchorId} -->`,\n  ].join('\\n');\n\n  if (!pattern.test(content)) {\n    if (options.createMissing) {\n      const suffix = content.endsWith('\\n') ? '' : '\\n';\n      return `${content}${suffix}\\n${replacement}\\n`;\n    }\n    throw new Error(\n      `Missing machine-owned anchor \"${anchorId}\" in deep-review strategy file. `\n      + 'Pass createMissing:true (or the reducer CLI flag --create-missing-anchors) to bootstrap.',\n    );\n  }\n  return content.replace(pattern, replacement);\n}\n\nfunction updateStrategyContent(strategyContent, registry, iterationFiles, options = {}, iterationRecords = []) {\n  // Early return when there is no strategy file to update. Empty content\n  // cannot contain the machine-owned anchors and replaceAnchorSection would\n  // correctly fail-close — but for that specific case we intentionally skip\n  // rather than throw so bootstrap flows (no strategy yet) still work.\n  if (!strategyContent) {\n    return strategyContent;\n  }\n\n  const anchorOptions = { createMissing: Boolean(options.createMissingAnchors) };\n  const severity = registry.findingsBySeverity;\n  const runningFindings = [\n    `- P0 (Blockers): ${severity.P0}`,\n    `- P1 (Required): ${severity.P1}`,\n    `- P2 (Suggestions): ${severity.P2}`,\n    `- Resolved: ${registry.resolvedFindingsCount}`,\n  ].join('\\n');\n\n  const completedDimensions = REQUIRED_DIMENSIONS\n    .filter((dimension) => registry.dimensionCoverage[dimension])\n    .map((dimension) => `- [x] ${dimension}`)\n    .join('\\n') || '[None yet]';\n\n  const remainingDimensions = REQUIRED_DIMENSIONS\n    .filter((dimension) => !registry.dimensionCoverage[dimension])\n    .map((dimension) => `- [ ] ${dimension}`)\n    .join('\\n') || '[All dimensions complete]';\n\n  // Default next-focus comes from latest iteration → first uncovered dimension → fallback.\n  let nextFocus = iterationFiles.map((iteration) => iteration.nextFocus).filter(Boolean).at(-1)\n    || REQUIRED_DIMENSIONS.find((dimension) => !registry.dimensionCoverage[dimension])\n    || '[All dimensions covered]';\n\n  // Prefer the latest blocked-stop\n  // recovery only when blocked-stop is genuinely the most recent loop event.\n  // The earlier implementation read timestamps from the markdown iteration\n  // files, but parseIterationFile() never captures timestamps, so\n  // latestIterationTimestamp was always undefined and any historical\n  // blocked-stop permanently pinned next-focus. Fix: source recency from the\n  // JSONL iteration records (which do carry timestamps) instead.\n  const latestBlockedStop = registry.blockedStopHistory?.at(-1);\n  if (latestBlockedStop && latestBlockedStop.timestamp) {\n    const latestIterationTimestamp = iterationRecords\n      .filter((record) => record?.type === 'iteration' && typeof record.timestamp === 'string')\n      .map((record) => record.timestamp)\n      .at(-1);\n    const blockedIsMostRecent = !latestIterationTimestamp\n      || latestBlockedStop.timestamp >= latestIterationTimestamp;\n    if (blockedIsMostRecent) {\n      const blockers = formatBlockedByList(latestBlockedStop.blockedBy);\n      const recovery = latestBlockedStop.recoveryStrategy || '[no recovery strategy provided]';\n      nextFocus = [\n        `BLOCKED on: ${blockers}`,\n        `Recovery: ${recovery}`,\n        'Address the blocking gates before the next iteration.',\n      ].join('\\n');\n    }\n  }\n\n  let updated = strategyContent;\n  updated = replaceAnchorSection(updated, 'review-dimensions', '3. REVIEW DIMENSIONS (remaining)', remainingDimensions, anchorOptions);\n  updated = replaceAnchorSection(updated, 'completed-dimensions', '4. COMPLETED DIMENSIONS', completedDimensions, anchorOptions);\n  updated = replaceAnchorSection(updated, 'running-findings', '5. RUNNING FINDINGS', runningFindings, anchorOptions);\n  updated = replaceAnchorSection(\n    updated,\n    'exhausted-approaches',\n    '9. EXHAUSTED APPROACHES (do not retry)',\n    buildExhaustedApproaches(iterationFiles),\n    anchorOptions,\n  );\n  updated = replaceAnchorSection(updated, 'next-focus', '11. NEXT FOCUS', nextFocus, anchorOptions);\n  return updated;\n}\n\nfunction renderDashboard(config, registry, iterationRecords, iterationFiles) {\n  const latestIteration = iterationRecords.filter((record) => record.type === 'iteration').at(-1);\n  const ratios = iterationRecords\n    .filter((record) => record.type === 'iteration')\n    .map((record) => (typeof record.newFindingsRatio === 'number' ? record.newFindingsRatio : null))\n    .filter((value) => value !== null);\n  const lastThreeRatios = ratios.slice(-3).map((value) => value.toFixed(2)).join(' -> ') || 'N/A';\n  const nextFocus = iterationFiles.map((iteration) => iteration.nextFocus).filter(Boolean).at(-1)\n    || REQUIRED_DIMENSIONS.find((dimension) => !registry.dimensionCoverage[dimension])\n    || '[All dimensions covered]';\n\n  const severity = registry.findingsBySeverity;\n  const hasSearchDebt = Array.isArray(registry.searchDebt) && registry.searchDebt.length > 0;\n  const verdict = severity.P0 > 0\n    ? 'FAIL'\n    : severity.P1 > 0 || hasSearchDebt\n      ? 'CONDITIONAL'\n      : 'PASS';\n  const hasAdvisories = verdict === 'PASS' && severity.P2 > 0;\n\n  const progressRows = iterationRecords\n    .filter((record) => record.type === 'iteration')\n    .map((record) => {\n      const dimensions = Array.isArray(record.dimensions) ? record.dimensions.join('/') : '-';\n      const ratio = typeof record.newFindingsRatio === 'number' ? record.newFindingsRatio.toFixed(2) : '0.00';\n      const summary = record.findingsSummary || {};\n      const findings = `${summary.P0 ?? 0}/${summary.P1 ?? 0}/${summary.P2 ?? 0}`;\n      return `| ${record.run} | ${record.focus || 'unknown'} | ${dimensions} | ${ratio} | ${findings} | ${record.status || 'complete'} |`;\n    })\n    .join('\\n') || '| 0 | none yet | - | 0.00 | 0/0/0 | initialized |';\n\n  const dimensionRows = REQUIRED_DIMENSIONS\n    .map((dimension) => {\n      const covered = registry.dimensionCoverage[dimension];\n      const status = covered ? 'covered' : 'pending';\n      const openInDimension = registry.openFindings.filter((finding) => finding.dimension === dimension).length;\n      return `| ${dimension} | ${status} | ${openInDimension} |`;\n    })\n    .join('\\n');\n\n  return [\n    '---',\n    'title: Deep Review Dashboard',\n    'description: Auto-generated reducer view over the review packet.',\n    '---',\n    '',\n    '# Deep Review Dashboard - Session Overview',\n    '',\n    'Auto-generated from JSONL state log, iteration files, findings registry, and strategy state. Never manually edited.',\n    '',\n    '<!-- ANCHOR:overview -->',\n    '## 1. OVERVIEW',\n    '',\n    'Reducer-generated observability surface for the active review packet.',\n    '',\n    '<!-- /ANCHOR:overview -->',\n    '<!-- ANCHOR:status -->',\n    '## 2. STATUS',\n    `- Review Target: ${config.reviewTarget || '[Unknown target]'} (${config.reviewTargetType || 'unknown'})`,\n    `- Started: ${config.createdAt || '[Unknown start]'}`,\n    `- Status: ${registry.status || String(config.status || 'initialized').toUpperCase()}`,\n    `- Iteration: ${iterationRecords.filter((record) => record.type === 'iteration').length} of ${config.maxIterations || 0}`,\n    `- Provisional Verdict: ${verdict}`,\n    `- hasSearchDebt: ${hasSearchDebt}`,\n    `- hasAdvisories: ${hasAdvisories}`,\n    `- Session ID: ${registry.sessionId || '[Unknown session]'}`,\n    `- Parent Session: ${registry.parentSessionId ?? 'none'}`,\n    `- Lifecycle Mode: ${registry.lineageMode || 'new'}`,\n    `- Generation: ${registry.generation ?? 1}`,\n    `- continuedFromRun: ${registry.continuedFromRun ?? 'none'}`,\n    ...(registry.terminalStop?.stopReason ? [`- stopReason: ${registry.terminalStop.stopReason}`] : []),\n    '',\n    '<!-- /ANCHOR:status -->',\n    '<!-- ANCHOR:findings-summary -->',\n    '## 3. FINDINGS SUMMARY',\n    '',\n    '| Severity | Count |',\n    '|----------|------:|',\n    `| P0 (Blockers) | ${severity.P0} |`,\n    `| P1 (Required) | ${severity.P1} |`,\n    `| P2 (Suggestions) | ${severity.P2} |`,\n    `| Resolved | ${registry.resolvedFindingsCount} |`,\n    '',\n    '<!-- /ANCHOR:findings-summary -->',\n    '<!-- ANCHOR:progress -->',\n    '## 4. PROGRESS',\n    '',\n    '| # | Focus | Dimensions | Ratio | P0/P1/P2 | Status |',\n    '|---|-------|------------|-------|----------|--------|',\n    progressRows,\n    '',\n    '<!-- /ANCHOR:progress -->',\n    '<!-- ANCHOR:dimension-coverage -->',\n    '## 5. DIMENSION COVERAGE',\n    '',\n    '| Dimension | Status | Open findings |',\n    '|-----------|--------|--------------:|',\n    dimensionRows,\n    '',\n    '<!-- /ANCHOR:dimension-coverage -->',\n    '<!-- ANCHOR:blocked-stops -->',\n    '## 6. BLOCKED STOPS',\n    ...(registry.blockedStopHistory && registry.blockedStopHistory.length > 0\n      ? registry.blockedStopHistory.flatMap((entry) => {\n          const blockers = formatBlockedByList(entry.blockedBy);\n          const gateSummary = entry.gateResults && typeof entry.gateResults === 'object'\n            ? Object.entries(entry.gateResults)\n                .map(([gate, result]) => {\n                  const pass = result && typeof result === 'object' && 'pass' in result ? result.pass : '?';\n                  return `${gate}: ${pass}`;\n                })\n                .join(', ')\n            : '[no gate results]';\n          return [\n            `### Iteration ${entry.run} — blocked by [${blockers}]`,\n            `- Recovery: ${entry.recoveryStrategy || '[no recovery strategy recorded]'}`,\n            `- Gate results: ${gateSummary}`,\n            `- Timestamp: ${entry.timestamp || '[no timestamp]'}`,\n            '',\n          ];\n        })\n      : ['No blocked-stop events recorded.', '']),\n    '<!-- /ANCHOR:blocked-stops -->',\n    '<!-- ANCHOR:graph-convergence -->',\n    '## 7. GRAPH CONVERGENCE',\n    `- graphConvergenceScore: ${Number(registry.graphConvergenceScore || 0).toFixed(2)}`,\n    `- graphDecision: ${registry.graphDecision || 'none'}`,\n    ...(Array.isArray(registry.graphBlockers) && registry.graphBlockers.length > 0\n      ? [`- graphBlockers: ${registry.graphBlockers.map((b) => (typeof b === 'string' ? b : JSON.stringify(b))).join(', ')}`]\n      : ['- graphBlockers: none']),\n    '',\n    '<!-- /ANCHOR:graph-convergence -->',\n    '<!-- ANCHOR:trend -->',\n    '## 8. TREND',\n    `- Last 3 ratios: ${lastThreeRatios}`,\n    `- convergenceScore: ${Number(registry.convergenceScore || 0).toFixed(2)}`,\n    `- openFindings: ${registry.openFindingsCount}`,\n    `- persistentSameSeverity: ${(registry.persistentSameSeverity || []).length}`,\n    `- severityChanged: ${(registry.severityChanged || []).length}`,\n    `- repeatedFindings (deprecated combined bucket): ${registry.repeatedFindings.length}`,\n    '',\n    '<!-- /ANCHOR:trend -->',\n    '<!-- ANCHOR:corruption-warnings -->',\n    '## 9. CORRUPTION WARNINGS',\n    ...(Array.isArray(registry.corruptionWarnings) && registry.corruptionWarnings.length > 0\n      ? registry.corruptionWarnings.map((w) => `- Line ${w.line}: ${w.error} (raw: ${w.raw})`)\n      : ['No corrupt JSONL lines detected.']),\n    '',\n    '<!-- /ANCHOR:corruption-warnings -->',\n    '<!-- ANCHOR:search-debt -->',\n    '## 10. SEARCH DEBT',\n    renderSearchDebtSection(registry),\n    '',\n    '<!-- /ANCHOR:search-debt -->',\n    '<!-- ANCHOR:next-focus -->',\n    '## 11. NEXT FOCUS',\n    nextFocus,\n    '',\n    '<!-- /ANCHOR:next-focus -->',\n    '<!-- ANCHOR:active-risks -->',\n    '## 12. ACTIVE RISKS',\n    ...(function buildActiveRisks() {\n      // Surface non-P0 release-readiness debt alongside P0s so the dashboard\n      // cannot hide P1 debt behind a\n      // \"None active\" summary when activeP0 == 0. Gate debt on the latest\n      // `blocked_stop` and `claim_adjudication` events so operators see\n      // claim-adjudication and legal-stop gate failures, not just severity.\n      const lines = [];\n      if (latestIteration?.status === 'error') {\n        lines.push('- Latest iteration reported error status.');\n      }\n      if (severity.P0 > 0) {\n        lines.push(`- ${severity.P0} active P0 finding(s) blocking release.`);\n      }\n      if (severity.P1 > 0) {\n        lines.push(`- ${severity.P1} active P1 finding(s) — required before release; not a P0 but still blocks PASS.`);\n      }\n      const latestClaimAdjudication = [...iterationRecords]\n        .reverse()\n        .find((record) => record\n          && record.type === 'event'\n          && record.event === 'claim_adjudication'\n          && typeof getNestedField(record, 'passed') === 'boolean'\n          && !normalizeText(getNestedField(record, 'findingId') || ''));\n      const activeP0P1 = severity.P0 + severity.P1;\n      const adjudicationActiveCount = isFiniteNumber(getNestedField(latestClaimAdjudication, 'activeP0P1'))\n        ? getNestedField(latestClaimAdjudication, 'activeP0P1')\n        : activeP0P1;\n      if (latestClaimAdjudication && getNestedField(latestClaimAdjudication, 'passed') === false && activeP0P1 > 0 && adjudicationActiveCount > 0) {\n        const missingPackets = getNestedField(latestClaimAdjudication, 'missingPackets');\n        const missing = Array.isArray(missingPackets) && missingPackets.length > 0\n          ? ` (missing packets: ${missingPackets.join(', ')})`\n          : '';\n        lines.push(`- Claim-adjudication gate last failed at run ${latestClaimAdjudication.run ?? '?'}${missing}. STOP is vetoed until every active P0/P1 has a typed claim-adjudication packet.`);\n      }\n      const latestBlockedStop = registry.blockedStopHistory?.at(-1);\n      if (latestBlockedStop && Array.isArray(latestBlockedStop.blockedBy) && latestBlockedStop.blockedBy.length > 0) {\n        lines.push(`- Latest blocked_stop at run ${latestBlockedStop.run ?? '?'}: ${formatBlockedByList(latestBlockedStop.blockedBy)}. Recovery: ${latestBlockedStop.recoveryStrategy || 'see dashboard §BLOCKED STOPS'}.`);\n      }\n      if (hasSearchDebt) {\n        lines.push(`- ${registry.searchDebt.length} search-debt obligation(s) remain deferred or blocked. Verdict is CONDITIONAL until they are covered or ruled out.`);\n      }\n      if (severity.P2 > 0 && lines.length === 0) {\n        lines.push(`- ${severity.P2} active P2 finding(s) — advisory only; release is not blocked by P2 alone, but the debt is tracked here so it does not disappear.`);\n      }\n      if (lines.length === 0) {\n        lines.push('- None active beyond normal review uncertainty.');\n      }\n      return lines;\n    })(),\n    '',\n    '<!-- /ANCHOR:active-risks -->',\n    '',\n  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the review packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard\n */\nfunction reduceReviewState(specFolder, options = {}) {\n  const write = options.write !== false;\n  const lenient = Boolean(options.lenient);\n  const createMissingAnchors = Boolean(options.createMissingAnchors);\n  const emitResourceMapOutput = Boolean(options.emitResourceMap);\n  const resolvedSpecFolder = path.resolve(specFolder);\n  const { artifactDir: reviewDir } = resolveArtifactRoot(resolvedSpecFolder, 'review');\n  const configPath = path.join(reviewDir, 'deep-review-config.json');\n  const stateLogPath = path.join(reviewDir, 'deep-review-state.jsonl');\n  const strategyPath = path.join(reviewDir, 'deep-review-strategy.md');\n  const registryPath = path.join(reviewDir, 'deep-review-findings-registry.json');\n  const dashboardPath = path.join(reviewDir, 'deep-review-dashboard.md');\n  const resourceMapPath = path.join(reviewDir, 'resource-map.md');\n  const iterationDir = path.join(reviewDir, 'iterations');\n  const deltaDir = path.join(reviewDir, 'deltas');\n\n  const config = readJson(configPath);\n  const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(stateLogPath));\n  const terminalStop = buildTerminalStopState(records);\n  const lineage = buildLineageState(config, records, terminalStop);\n  config.sessionId = lineage.sessionId || config.sessionId || '';\n  config.parentSessionId = lineage.parentSessionId;\n  config.lineageMode = lineage.lineageMode;\n  config.generation = lineage.generation;\n  config.continuedFromRun = lineage.continuedFromRun;\n  if (terminalStop?.stopReason) {\n    config.stopReason = terminalStop.stopReason;\n  }\n  const strategyContent = fs.existsSync(strategyPath) ? readUtf8(strategyPath) : '';\n  const strategyDimensions = parseStrategyDimensions(strategyContent);\n  const iterationFiles = fs.existsSync(iterationDir)\n    ? fs.readdirSync(iterationDir)\n        .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n        .sort()\n        .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n    : [];\n\n  // P1-026 fix: load delta payloads up-front so the finding registry can be\n  // built from {type:\"finding\"} delta records (primary source) rather than\n  // relying solely on iteration markdown parsing (legacy/fallback). The\n  // resource-map emit path below reuses these loaded payloads.\n  const deltaPayloads = fs.existsSync(deltaDir) ? loadDeltaPayloads(deltaDir) : [];\n  const flattenedDeltaRecords = deltaPayloads\n    .flat()\n    .filter((record) => record !== null && record !== undefined);\n\n  const registry = buildRegistry(strategyDimensions, iterationFiles, records, config, corruptionWarnings, flattenedDeltaRecords);\n  const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, { createMissingAnchors }, records);\n  const dashboard = renderDashboard(config, registry, records, iterationFiles);\n  let resourceMap = null;\n  let resourceMapSkipped = true;\n  let resourceMapSkipReason = null;\n\n  if (corruptionWarnings.length > 0 && !lenient) {\n    throw createCorruptionError(stateLogPath, corruptionWarnings);\n  }\n\n  if (emitResourceMapOutput) {\n    if (getResourceMapEmitSetting(config) === false) {\n      resourceMapSkipReason = 'config.resource_map.emit=false';\n    } else {\n      // Reuse the deltaPayloads already loaded above (P1-026 fix) — avoids re-reading.\n      if (!deltaPayloads.length) {\n        resourceMapSkipReason = 'no delta files found';\n      } else {\n        resourceMap = emitResourceMap({\n          shape: 'review',\n          deltas: deltaPayloads,\n          packet: {\n            title: config.reviewTarget || path.basename(resolvedSpecFolder),\n            specFolder: resolvedSpecFolder,\n          },\n          scope: `review convergence output for ${path.basename(resolvedSpecFolder)}`,\n          createdAt: new Date().toISOString(),\n        });\n        resourceMapSkipped = false;\n      }\n    }\n  }\n\n  if (write) {\n    writeUtf8(registryPath, `${JSON.stringify(registry, null, 2)}\\n`);\n    if (strategyContent) {\n      writeUtf8(strategyPath, strategy.endsWith('\\n') ? strategy : `${strategy}\\n`);\n    }\n    writeUtf8(dashboardPath, dashboard);\n    if (emitResourceMapOutput && resourceMap) {\n      writeUtf8(resourceMapPath, resourceMap);\n    }\n  }\n\n  return {\n    configPath,\n    stateLogPath,\n    strategyPath,\n    registryPath,\n    dashboardPath,\n    resourceMapPath,\n    registry,\n    strategy,\n    dashboard,\n    resourceMap,\n    resourceMapSkipped,\n    resourceMapSkipReason,\n    corruptionWarnings,\n    hasCorruption: corruptionWarnings.length > 0,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. CLI ENTRY POINT\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const lenient = args.includes('--lenient');\n  const createMissingAnchors = args.includes('--create-missing-anchors');\n  const emitResourceMapOutput = args.includes('--emit-resource-map');\n  const positional = args.filter((arg) => !arg.startsWith('--'));\n  const specFolder = positional[0];\n\n  if (!specFolder) {\n    process.stderr.write(\n      'Usage: node .opencode/skills/deep-review/scripts/reduce-state.cjs <spec-folder> [--lenient] [--create-missing-anchors] [--emit-resource-map]\\n',\n    );\n    process.exit(1);\n  }\n\n  try {\n    const result = reduceReviewState(specFolder, {\n      write: true,\n      lenient,\n      createMissingAnchors,\n      emitResourceMap: emitResourceMapOutput,\n    });\n    process.stdout.write(\n      `${JSON.stringify(\n        {\n          registryPath: result.registryPath,\n          dashboardPath: result.dashboardPath,\n          strategyPath: result.strategyPath,\n          openFindingsCount: result.registry.openFindingsCount,\n          resolvedFindingsCount: result.registry.resolvedFindingsCount,\n          convergenceScore: result.registry.convergenceScore,\n          graphConvergenceScore: result.registry.graphConvergenceScore,\n          searchDebtCount: Array.isArray(result.registry.searchDebt) ? result.registry.searchDebt.length : 0,\n          corruptionCount: result.corruptionWarnings.length,\n          resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n          resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n          resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n        },\n        null,\n        2,\n      )}\\n`,\n    );\n  } catch (error) {\n    if (error && error.code === 'STATE_CORRUPTION') {\n      process.stderr.write(`${error.message}\\n`);\n      process.exit(2);\n    }\n    process.stderr.write(`[deep-review] reducer failed: ${error instanceof Error ? error.message : String(error)}\\n`);\n    process.exit(3);\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 7. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  REQUIRED_DIMENSIONS,\n  SEVERITY_KEYS,\n  SEVERITY_WEIGHTS,\n  buildGraphConvergenceRollup,\n  parseIterationFile,\n  parseJsonl,\n  parseJsonlDetailed,\n  parseFindingLine,\n  replaceAnchorSection,\n  reduceReviewState,\n  deltaRecordToFinding,\n  deriveDashboardStatus,\n  collapseFindingsByDedupKey,\n  findingDedupKey,\n  buildTraceabilityRollup,\n  validateReviewRecordFields,\n};","lineStart":1201,"lineEnd":1853,"totalLines":1853,"truncated":false}},"title":".opencode/skills/deep-review/scripts/reduce-state.cjs","time":{"start":1781150554426,"end":1781150554430}},"metadata":{"openai":{"itemId":"fc_00fe2b296b4191a6016a2a3359bfc88191860ffbb9cea0c5d6"}},"id":"prt_eb4d896a1001grxsppnni1yRJa","sessionID":"ses_14b28450fffeXtSj4IYMHTa90z","messageID":"msg_eb4d888040010dhY7H3WzM4m0N"}}
