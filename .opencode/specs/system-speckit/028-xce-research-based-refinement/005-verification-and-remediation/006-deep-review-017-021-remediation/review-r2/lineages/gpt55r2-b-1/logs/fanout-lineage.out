{"type":"tool_use","timestamp":1781761460451,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_NyfOwAWcEgLJB594Fc6sC7hF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Save Handler\n3: // ───────────────────────────────────────────────────────────────\n4: /* --- 1. DEPENDENCIES --- */\n5: \n6: // Node built-ins\n7: import { createHash, randomUUID } from 'node:crypto';\n8: import * as fs from 'node:fs';\n9: import path from 'path';\n10: \n11: // Shared packages\n12: import { validateFilePath } from '@spec-kit/shared/utils/path-security';\n13: import {\n14:   evaluateMemorySufficiency,\n15:   MEMORY_SUFFICIENCY_REJECTION_CODE,\n16:   type MemorySufficiencyResult,\n17: } from '@spec-kit/shared/parsing/memory-sufficiency';\n18: import {\n19:   validateMemoryTemplateContract,\n20:   type MemoryTemplateContractResult,\n21: } from '@spec-kit/shared/parsing/memory-template-contract';\n22: import {\n23:   evaluateSpecDocHealth,\n24:   type SpecDocHealthResult,\n25: } from '@spec-kit/shared/parsing/spec-doc-health';\n26: \n27: // Internal modules\n28: import { ALLOWED_BASE_PATHS, checkDatabaseUpdated } from '../core/index.js';\n29: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n30: import { scrubSecretsDetailed } from '../lib/parsing/secret-scrubber.js';\n31: import { createFilePathValidator } from '../utils/validators.js';\n32: import * as memoryParser from '../lib/parsing/memory-parser.js';\n33: import * as transactionManager from '../lib/storage/transaction-manager.js';\n34: import * as checkpoints from '../lib/storage/checkpoints.js';\n35: import * as preflight from '../lib/validation/preflight.js';\n36: import { requireDb } from '../utils/index.js';\n37: import type { MCPResponse } from './types.js';\n38: import { createAppendOnlyMemoryRecord, recordLineageVersion, retirePredecessorForActiveReindex } from '../lib/storage/lineage-state.js';\n39: import { determineAction } from '../lib/storage/reconsolidation.js';\n40: import * as causalEdges from '../lib/storage/causal-edges.js';\n41: \n42: import { runQualityGate, isQualityGateEnabled } from '../lib/validation/save-quality-gate.js';\n43: import {\n44:   isPostInsertEnrichmentEnabled,\n45:   isPostInsertEnrichmentAsync,\n46:   isSaveQualityGateEnabled,\n47:   isSaveReconsolidationEnabled,\n48:   resolveSavePlannerMode,\n49: } from '../lib/search/search-flags.js';\n50: \n51: import { getCanonicalPathKey, resolveCanonicalPath } from '../lib/utils/canonical-path.js';\n52: import { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../lib/utils/index-scope.js';\n53: import { findSimilarMemories } from './pe-gating.js';\n54: import { runPostMutationHooks } from './mutation-hooks.js';\n55: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n56: import { indexChunkedMemoryFile, shouldUseChunkedIndexing } from './chunking-orchestrator.js';\n57: import { applyPostInsertMetadata } from './save/db-helpers.js';\n58: import {\n59:   createMemoryRecord,\n60:   findSamePathExistingMemory,\n61:   type CreateRecordIdentityHints,\n62:   type MemoryScopeMatch,\n63: } from './save/create-record.js';\n64: import {\n65:   buildGovernanceLogicalKey,\n66:   buildGovernancePostInsertFields,\n67:   ensureGovernanceRuntime,\n68:   recordGovernanceAudit,\n69:   recordTierDowngradeAudit,\n70:   validateGovernedIngest,\n71:   type GovernanceDecision,\n72: } from '../lib/governance/scope-governance.js';\n73: import { delete_memory_from_database } from '../lib/search/vector-index-mutations.js';\n74: import {\n75:   runQualityLoop,\n76: } from './quality-loop.js';\n77: import type {\n78:   QualityLoopResult,\n79: } from './quality-loop.js';\n80: \n81: // O2-5/O2-12: V-rule validation (previously only in workflow path)\n82: import {\n83:   validateMemoryQualityContent,\n84:   determineValidationDisposition,\n85: } from './v-rule-bridge.js';\n86: \n87: // Save pipeline modules\n88: import type {\n89:   IndexResult,\n90:   RouteCategory,\n91:   MergeModeHint,\n92:   SaveArgs,\n93:   AtomicSaveParams,\n94:   AtomicSaveOptions,\n95:   AtomicSaveResult,\n96:   PlannerAdvisory,\n97:   PlannerBlocker,\n98:   PlannerFollowUpAction,\n99:   PlannerRouteTarget,\n100: } from './save/index.js';\n101: import { checkExistingRow, checkContentHashDedup } from './save/dedup.js';\n102: import { generateOrCacheEmbedding, persistPendingEmbeddingCacheWrite } from './save/embedding-pipeline.js';\n103: import { evaluateAndApplyPeDecision } from './save/pe-orchestration.js';\n104: import {\n105:   findScopeFilteredCandidates,\n106:   getRequestedScope,\n107:   runReconsolidationIfEnabled,\n108: } from './save/reconsolidation-bridge.js';\n109: import {\n110:   runPostInsertEnrichmentIfEnabled,\n111:   runPostInsertEnrichment,\n112:   shouldRunPostInsertEnrichment,\n113:   buildDeferredEnrichmentResult,\n114: } from './save/post-insert.js';\n115: import type { PostInsertEnrichmentResult } from './save/post-insert.js';\n116: import {\n117:   markEnrichmentPending,\n118:   needsEnrichmentRepair,\n119:   POST_INSERT_ENRICHMENT_VERSION,\n120:   recordEnrichmentResult,\n121:   repairEnrichmentOnReplay,\n122: } from './save/enrichment-state.js';\n123: import {\n124:   buildIndexResult,\n125:   buildPlannerResponse,\n126:   buildSaveResponse,\n127:   classifySaveErrorCode,\n128:   extractSaveErrorDetails,\n129:   serializePlannerAdvisory,\n130:   serializePlannerBlocker,\n131:   serializePlannerFollowUpAction,\n132:   serializePlannerProposedEdit,\n133:   serializePlannerRouteTarget,\n134: } from './save/response-builder.js';\n135: import type {\n136:   IndexingOrigin,\n137:   ReconsolidationFailureReason,\n138:   ReconsolidationOperationState,\n139: } from './save/types.js';\n140: import { atomicIndexMemory } from './save/atomic-index-memory.js';\n141: import { createMCPErrorResponse } from '../lib/response/envelope.js';\n142: import {\n143:   buildTier3Prompt,\n144:   createContentRouter,\n145:   getTier3Contract,\n146:   isTier3RoutingEnabled,\n147:   InMemoryRouterCache,\n148:   TIER2_FALLBACK_PENALTY,\n149:   TIER3_THRESHOLD,\n150:   type RoutingDecision,\n151:   type Tier3ClassifierInput,\n152:   type Tier3RawResponse,\n153: } from '../lib/routing/content-router.js';\n154: import { anchorMergeOperation } from '../lib/merge/anchor-merge-operation.js';\n155: import {\n156:   readThinContinuityRecord,\n157:   upsertThinContinuityInMarkdown,\n158:   type ThinContinuityRecord,\n159: } from '../lib/continuity/thin-continuity-record.js';\n160: import {\n161:   runSpecDocStructureRule,\n162:   type ContaminationPlan,\n163:   type MergePlan,\n164:   type PostSavePlan,\n165: } from '../lib/validation/spec-doc-structure.js';\n166: import { detectSpecLevelFromParsed } from './handler-utils.js';\n167: import { createStatediffAction } from '../lib/storage/statediff.js';\n168: import {\n169:   applyWriteProvenance,\n170:   persistSourceKind,\n171:   type SourceKind,\n172:   type WriteProvenanceContext,\n173: } from '../lib/storage/write-provenance.js';\n174: import {\n175:   deleteIdempotencyReceiptByKey,\n176:   extractMemoryIdFromResponse,\n177:   isMemoryIdempotencyEnabled,\n178:   lookupIdempotencyReceipt,\n179:   lookupIdempotencyReceiptByKey,\n180:   markResponseWithReceiptStoreConflict,\n181:   shouldStoreMemorySaveReceipt,\n182:   storeIdempotencyReceipt,\n183:   type IdempotencyReceiptKey,\n184: } from '../lib/storage/idempotency-receipts.js';\n185: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n186: \n187: // Extracted sub-modules\n188: import { withSpecFolderLock } from './save/spec-folder-mutex.js';\n189: import { buildParsedMemoryEvidenceSnapshot } from './save/markdown-evidence-builder.js';\n190: import {\n191:   applyInsufficiencyMetadata,\n192:   buildInsufficiencyRejectionResult,\n193:   buildTemplateContractRejectionResult,\n194:   buildDryRunSummary,\n195:   buildPlannerAdvisory,\n196:   buildPlannerBlocker,\n197: } from './save/validation-responses.js';\n198: \n199: import { markMemorySuperseded } from './pe-gating.js';\n200: import { resolveMemoryReference } from './causal-links-processor.js';\n201: import { refreshAutoEntitiesForMemory } from '../lib/extraction/entity-extractor.js';\n202: \n203: // Feature catalog: Memory indexing (memory_save)\n204: // Feature catalog: Verify-fix-verify memory quality loop\n205: // Feature catalog: Dry-run preflight for memory_save\n206: // Feature catalog: Prediction-error save arbitration\n207: \n208: \n209: // Create local path validator\n210: const validateFilePathLocal = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\n211: const MANUAL_FALLBACK_SOURCE_CLASSIFICATION = 'manual-fallback' as const;\n212: export const MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE = 'E_MEMORY_INDEX_SCOPE_EXCLUDED';\n213: const ROUTED_CONTINUITY_ANCHOR_ID = '_memory.continuity';\n214: const tier3RoutingCache = new InMemoryRouterCache();\n215: \n216: function emitPostInsertEnrichmentSubscribers(memoryId: number, sourceOperation: string): void {\n217:   try {\n218:     runPostMutationHooks(sourceOperation, {\n219:       memoryId,\n220:       statediffActions: [createStatediffAction('upsert', {\n221:         target: 'graph_edge',\n222:         key: String(memoryId),\n223:         sourceOperation,\n224:       })],\n225:     });\n226:   } catch (err: unknown) {\n227:     const message = err instanceof Error ? err.message : String(err);\n228:     console.warn(`[memory-save] Post-insert enrichment subscriber dispatch failed: ${message}`);\n229:   }\n230: }\n231: \n232: async function repairReplayEnrichmentIfNeeded(\n233:   database: Parameters<typeof needsEnrichmentRepair>[0],\n234:   memoryId: number | undefined,\n235:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n236: ): Promise<void> {\n237:   if (memoryId == null || !needsEnrichmentRepair(database, memoryId)) {\n238:     return;\n239:   }\n240: \n241:   await repairEnrichmentOnReplay({\n242:     database,\n243:     parsed,\n244:     plannerMode: 'full-auto',\n245:   }, memoryId);\n246: }\n247: \n248: interface PreparedParsedMemory {\n249:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n250:   validation: ReturnType<typeof memoryParser.validateParsedMemory>;\n251:   qualityLoopResult: QualityLoopResult;\n252:   sufficiencyResult: MemorySufficiencyResult;\n253:   templateContract: MemoryTemplateContractResult;\n254:   specDocHealth: SpecDocHealthResult | null;\n255:   finalizedFileContent: string | null;\n256:   sourceClassification: 'template-generated' | typeof MANUAL_FALLBACK_SOURCE_CLASSIFICATION;\n257: }\n258: \n259: function createIndexScopeExcludedResponse(\n260:   requestId: string,\n261:   canonicalPath: string,\n262:   originalPath: string,\n263: ): MCPResponse {\n264:   return createMCPErrorResponse({\n265:     tool: 'memory_save',\n266:     error: `Memory indexing excluded for path: ${canonicalPath}`,\n267:     code: MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE,\n268:     details: {\n269:       requestId,\n270:       canonicalPath,\n271:       filePath: originalPath,\n272:     },\n273:     recovery: {\n274:       hint: 'Move the file into an indexable spec folder or constitutional rule path before retrying.',\n275:       actions: ['Verify the path is not under z_future/ or external/'],\n276:       severity: 'warning',\n277:     },\n278:   });\n279: }\n280: \n281: type ParsedMemoryWithIndexHints = ReturnType<typeof memoryParser.parseMemoryFile> & {\n282:   _skipIndex?: boolean;\n283:   _vRuleIndexBlockIds?: string[];\n284: };\n285: \n286: interface RoutedSaveOptions extends CreateRecordIdentityHints {\n287:   routeAs?: RouteCategory;\n288:   mergeModeHint?: MergeModeHint;\n289: }\n290: \n291: interface RoutedRecordIdentity {\n292:   targetDocPath: string;\n293:   canonicalFilePath: string;\n294:   targetAnchorId: string | null;\n295:   routeAs: RouteCategory | null;\n296:   continuitySourceKey: string | null;\n297: }\n298: \n299: type CanonicalPacketLevel = 'L1' | 'L2' | 'L3' | 'L3+';\n300: type CanonicalPacketKind = 'feature' | 'phase' | 'remediation' | 'research' | 'unknown';\n301: \n302: interface CanonicalAtomicValidatorPlan {\n303:   folder: string;\n304:   level: string;\n305:   mergePlan: MergePlan | null;\n306:   contaminationPlan: ContaminationPlan | null;\n307:   postSavePlan: PostSavePlan | null;\n308: }\n309: \n310: interface CanonicalAtomicPrepared {\n311:   preparedMemory: PreparedParsedMemory;\n312:   routing: RoutedSaveOptions;\n313:   validatorPlan: CanonicalAtomicValidatorPlan | null;\n314: }\n315: \n316: const STANDARD_MEMORY_TEMPLATE_MARKERS = [\n317:   '## continue session',\n318:   '## recovery hints',\n319:   '<!-- memory metadata -->',\n320: ];\n321: const CANONICAL_SPEC_DOCUMENT_TYPES = new Set([\n322:   'spec',\n323:   'plan',\n324:   'tasks',\n325:   'checklist',\n326:   'decision_record',\n327:   'implementation_summary',\n328:   'research',\n329:   'handover',\n330:   'resource_map',\n331: ]);\n332: const ROUTE_CATEGORIES = new Set<RouteCategory>([\n333:   'narrative_progress',\n334:   'narrative_delivery',\n335:   'decision',\n336:   'handover_state',\n337:   'research_finding',\n338:   'task_update',\n339:   'metadata_only',\n340:   'drop',\n341: ]);\n342: \n343: class VRuleUnavailableError extends Error {\n344:   constructor(message: string) {\n345:     super(message);\n346:     this.name = 'VRuleUnavailableError';\n347:   }\n348: }\n349: \n350: function isVRuleUnavailableResult(value: unknown): value is {\n351:   passed: false;\n352:   status: 'error' | 'warning';\n353:   message: string;\n354:   _unavailable: true;\n355: } {\n356:   return typeof value === 'object'\n357:     && value !== null\n358:     && 'passed' in value\n359:     && (value as { passed?: unknown }).passed === false\n360:     && 'status' in value\n\n(Showing lines 1-360 of 4082. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Save Handler\n// ───────────────────────────────────────────────────────────────\n/* --- 1. DEPENDENCIES --- */\n\n// Node built-ins\nimport { createHash, randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport path from 'path';\n\n// Shared packages\nimport { validateFilePath } from '@spec-kit/shared/utils/path-security';\nimport {\n  evaluateMemorySufficiency,\n  MEMORY_SUFFICIENCY_REJECTION_CODE,\n  type MemorySufficiencyResult,\n} from '@spec-kit/shared/parsing/memory-sufficiency';\nimport {\n  validateMemoryTemplateContract,\n  type MemoryTemplateContractResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Save Handler\n// ───────────────────────────────────────────────────────────────\n/* --- 1. DEPENDENCIES --- */\n\n// Node built-ins\nimport { createHash, randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport path from 'path';\n\n// Shared packages\nimport { validateFilePath } from '@spec-kit/shared/utils/path-security';\nimport {\n  evaluateMemorySufficiency,\n  MEMORY_SUFFICIENCY_REJECTION_CODE,\n  type MemorySufficiencyResult,\n} from '@spec-kit/shared/parsing/memory-sufficiency';\nimport {\n  validateMemoryTemplateContract,\n  type MemoryTemplateContractResult,\n} from '@spec-kit/shared/parsing/memory-template-contract';\nimport {\n  evaluateSpecDocHealth,\n  type SpecDocHealthResult,\n} from '@spec-kit/shared/parsing/spec-doc-health';\n\n// Internal modules\nimport { ALLOWED_BASE_PATHS, checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { scrubSecretsDetailed } from '../lib/parsing/secret-scrubber.js';\nimport { createFilePathValidator } from '../utils/validators.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as transactionManager from '../lib/storage/transaction-manager.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as preflight from '../lib/validation/preflight.js';\nimport { requireDb } from '../utils/index.js';\nimport type { MCPResponse } from './types.js';\nimport { createAppendOnlyMemoryRecord, recordLineageVersion, retirePredecessorForActiveReindex } from '../lib/storage/lineage-state.js';\nimport { determineAction } from '../lib/storage/reconsolidation.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\n\nimport { runQualityGate, isQualityGateEnabled } from '../lib/validation/save-quality-gate.js';\nimport {\n  isPostInsertEnrichmentEnabled,\n  isPostInsertEnrichmentAsync,\n  isSaveQualityGateEnabled,\n  isSaveReconsolidationEnabled,\n  resolveSavePlannerMode,\n} from '../lib/search/search-flags.js';\n\nimport { getCanonicalPathKey, resolveCanonicalPath } from '../lib/utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../lib/utils/index-scope.js';\nimport { findSimilarMemories } from './pe-gating.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { indexChunkedMemoryFile, shouldUseChunkedIndexing } from './chunking-orchestrator.js';\nimport { applyPostInsertMetadata } from './save/db-helpers.js';\nimport {\n  createMemoryRecord,\n  findSamePathExistingMemory,\n  type CreateRecordIdentityHints,\n  type MemoryScopeMatch,\n} from './save/create-record.js';\nimport {\n  buildGovernanceLogicalKey,\n  buildGovernancePostInsertFields,\n  ensureGovernanceRuntime,\n  recordGovernanceAudit,\n  recordTierDowngradeAudit,\n  validateGovernedIngest,\n  type GovernanceDecision,\n} from '../lib/governance/scope-governance.js';\nimport { delete_memory_from_database } from '../lib/search/vector-index-mutations.js';\nimport {\n  runQualityLoop,\n} from './quality-loop.js';\nimport type {\n  QualityLoopResult,\n} from './quality-loop.js';\n\n// O2-5/O2-12: V-rule validation (previously only in workflow path)\nimport {\n  validateMemoryQualityContent,\n  determineValidationDisposition,\n} from './v-rule-bridge.js';\n\n// Save pipeline modules\nimport type {\n  IndexResult,\n  RouteCategory,\n  MergeModeHint,\n  SaveArgs,\n  AtomicSaveParams,\n  AtomicSaveOptions,\n  AtomicSaveResult,\n  PlannerAdvisory,\n  PlannerBlocker,\n  PlannerFollowUpAction,\n  PlannerRouteTarget,\n} from './save/index.js';\nimport { checkExistingRow, checkContentHashDedup } from './save/dedup.js';\nimport { generateOrCacheEmbedding, persistPendingEmbeddingCacheWrite } from './save/embedding-pipeline.js';\nimport { evaluateAndApplyPeDecision } from './save/pe-orchestration.js';\nimport {\n  findScopeFilteredCandidates,\n  getRequestedScope,\n  runReconsolidationIfEnabled,\n} from './save/reconsolidation-bridge.js';\nimport {\n  runPostInsertEnrichmentIfEnabled,\n  runPostInsertEnrichment,\n  shouldRunPostInsertEnrichment,\n  buildDeferredEnrichmentResult,\n} from './save/post-insert.js';\nimport type { PostInsertEnrichmentResult } from './save/post-insert.js';\nimport {\n  markEnrichmentPending,\n  needsEnrichmentRepair,\n  POST_INSERT_ENRICHMENT_VERSION,\n  recordEnrichmentResult,\n  repairEnrichmentOnReplay,\n} from './save/enrichment-state.js';\nimport {\n  buildIndexResult,\n  buildPlannerResponse,\n  buildSaveResponse,\n  classifySaveErrorCode,\n  extractSaveErrorDetails,\n  serializePlannerAdvisory,\n  serializePlannerBlocker,\n  serializePlannerFollowUpAction,\n  serializePlannerProposedEdit,\n  serializePlannerRouteTarget,\n} from './save/response-builder.js';\nimport type {\n  IndexingOrigin,\n  ReconsolidationFailureReason,\n  ReconsolidationOperationState,\n} from './save/types.js';\nimport { atomicIndexMemory } from './save/atomic-index-memory.js';\nimport { createMCPErrorResponse } from '../lib/response/envelope.js';\nimport {\n  buildTier3Prompt,\n  createContentRouter,\n  getTier3Contract,\n  isTier3RoutingEnabled,\n  InMemoryRouterCache,\n  TIER2_FALLBACK_PENALTY,\n  TIER3_THRESHOLD,\n  type RoutingDecision,\n  type Tier3ClassifierInput,\n  type Tier3RawResponse,\n} from '../lib/routing/content-router.js';\nimport { anchorMergeOperation } from '../lib/merge/anchor-merge-operation.js';\nimport {\n  readThinContinuityRecord,\n  upsertThinContinuityInMarkdown,\n  type ThinContinuityRecord,\n} from '../lib/continuity/thin-continuity-record.js';\nimport {\n  runSpecDocStructureRule,\n  type ContaminationPlan,\n  type MergePlan,\n  type PostSavePlan,\n} from '../lib/validation/spec-doc-structure.js';\nimport { detectSpecLevelFromParsed } from './handler-utils.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport {\n  applyWriteProvenance,\n  persistSourceKind,\n  type SourceKind,\n  type WriteProvenanceContext,\n} from '../lib/storage/write-provenance.js';\nimport {\n  deleteIdempotencyReceiptByKey,\n  extractMemoryIdFromResponse,\n  isMemoryIdempotencyEnabled,\n  lookupIdempotencyReceipt,\n  lookupIdempotencyReceiptByKey,\n  markResponseWithReceiptStoreConflict,\n  shouldStoreMemorySaveReceipt,\n  storeIdempotencyReceipt,\n  type IdempotencyReceiptKey,\n} from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n\n// Extracted sub-modules\nimport { withSpecFolderLock } from './save/spec-folder-mutex.js';\nimport { buildParsedMemoryEvidenceSnapshot } from './save/markdown-evidence-builder.js';\nimport {\n  applyInsufficiencyMetadata,\n  buildInsufficiencyRejectionResult,\n  buildTemplateContractRejectionResult,\n  buildDryRunSummary,\n  buildPlannerAdvisory,\n  buildPlannerBlocker,\n} from './save/validation-responses.js';\n\nimport { markMemorySuperseded } from './pe-gating.js';\nimport { resolveMemoryReference } from './causal-links-processor.js';\nimport { refreshAutoEntitiesForMemory } from '../lib/extraction/entity-extractor.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Verify-fix-verify memory quality loop\n// Feature catalog: Dry-run preflight for memory_save\n// Feature catalog: Prediction-error save arbitration\n\n\n// Create local path validator\nconst validateFilePathLocal = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\nconst MANUAL_FALLBACK_SOURCE_CLASSIFICATION = 'manual-fallback' as const;\nexport const MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE = 'E_MEMORY_INDEX_SCOPE_EXCLUDED';\nconst ROUTED_CONTINUITY_ANCHOR_ID = '_memory.continuity';\nconst tier3RoutingCache = new InMemoryRouterCache();\n\nfunction emitPostInsertEnrichmentSubscribers(memoryId: number, sourceOperation: string): void {\n  try {\n    runPostMutationHooks(sourceOperation, {\n      memoryId,\n      statediffActions: [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: String(memoryId),\n        sourceOperation,\n      })],\n    });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[memory-save] Post-insert enrichment subscriber dispatch failed: ${message}`);\n  }\n}\n\nasync function repairReplayEnrichmentIfNeeded(\n  database: Parameters<typeof needsEnrichmentRepair>[0],\n  memoryId: number | undefined,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n): Promise<void> {\n  if (memoryId == null || !needsEnrichmentRepair(database, memoryId)) {\n    return;\n  }\n\n  await repairEnrichmentOnReplay({\n    database,\n    parsed,\n    plannerMode: 'full-auto',\n  }, memoryId);\n}\n\ninterface PreparedParsedMemory {\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n  validation: ReturnType<typeof memoryParser.validateParsedMemory>;\n  qualityLoopResult: QualityLoopResult;\n  sufficiencyResult: MemorySufficiencyResult;\n  templateContract: MemoryTemplateContractResult;\n  specDocHealth: SpecDocHealthResult | null;\n  finalizedFileContent: string | null;\n  sourceClassification: 'template-generated' | typeof MANUAL_FALLBACK_SOURCE_CLASSIFICATION;\n}\n\nfunction createIndexScopeExcludedResponse(\n  requestId: string,\n  canonicalPath: string,\n  originalPath: string,\n): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_save',\n    error: `Memory indexing excluded for path: ${canonicalPath}`,\n    code: MEMORY_INDEX_SCOPE_EXCLUDED_ERROR_CODE,\n    details: {\n      requestId,\n      canonicalPath,\n      filePath: originalPath,\n    },\n    recovery: {\n      hint: 'Move the file into an indexable spec folder or constitutional rule path before retrying.',\n      actions: ['Verify the path is not under z_future/ or external/'],\n      severity: 'warning',\n    },\n  });\n}\n\ntype ParsedMemoryWithIndexHints = ReturnType<typeof memoryParser.parseMemoryFile> & {\n  _skipIndex?: boolean;\n  _vRuleIndexBlockIds?: string[];\n};\n\ninterface RoutedSaveOptions extends CreateRecordIdentityHints {\n  routeAs?: RouteCategory;\n  mergeModeHint?: MergeModeHint;\n}\n\ninterface RoutedRecordIdentity {\n  targetDocPath: string;\n  canonicalFilePath: string;\n  targetAnchorId: string | null;\n  routeAs: RouteCategory | null;\n  continuitySourceKey: string | null;\n}\n\ntype CanonicalPacketLevel = 'L1' | 'L2' | 'L3' | 'L3+';\ntype CanonicalPacketKind = 'feature' | 'phase' | 'remediation' | 'research' | 'unknown';\n\ninterface CanonicalAtomicValidatorPlan {\n  folder: string;\n  level: string;\n  mergePlan: MergePlan | null;\n  contaminationPlan: ContaminationPlan | null;\n  postSavePlan: PostSavePlan | null;\n}\n\ninterface CanonicalAtomicPrepared {\n  preparedMemory: PreparedParsedMemory;\n  routing: RoutedSaveOptions;\n  validatorPlan: CanonicalAtomicValidatorPlan | null;\n}\n\nconst STANDARD_MEMORY_TEMPLATE_MARKERS = [\n  '## continue session',\n  '## recovery hints',\n  '<!-- memory metadata -->',\n];\nconst CANONICAL_SPEC_DOCUMENT_TYPES = new Set([\n  'spec',\n  'plan',\n  'tasks',\n  'checklist',\n  'decision_record',\n  'implementation_summary',\n  'research',\n  'handover',\n  'resource_map',\n]);\nconst ROUTE_CATEGORIES = new Set<RouteCategory>([\n  'narrative_progress',\n  'narrative_delivery',\n  'decision',\n  'handover_state',\n  'research_finding',\n  'task_update',\n  'metadata_only',\n  'drop',\n]);\n\nclass VRuleUnavailableError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'VRuleUnavailableError';\n  }\n}\n\nfunction isVRuleUnavailableResult(value: unknown): value is {\n  passed: false;\n  status: 'error' | 'warning';\n  message: string;\n  _unavailable: true;\n} {\n  return typeof value === 'object'\n    && value !== null\n    && 'passed' in value\n    && (value as { passed?: unknown }).passed === false\n    && 'status' in value","lineStart":1,"lineEnd":360,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781761460420,"end":1781761460450}},"metadata":{"openai":{"itemId":"fc_0f33689ed4629db5016a3385b45a44819195e6072f3d94717f"}},"id":"prt_ed9424895001o1ggExJbSsLIDf","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94220fc001yUh9MgDz6zye8x"}}
{"type":"tool_use","timestamp":1781761460453,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_BnjkftQhNPEVZjTfvDZreey5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Mutation Ledger\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Append-only audit trail for all memory mutations\n6: // SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\n7: import { createHash } from 'crypto';\n8: import type Database from 'better-sqlite3';\n9: import { runInTransaction } from './transaction-manager.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. TYPES\n13: ----------------------------------------------------------------*/\n14: \n15: type MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n16: \n17: interface MutationLedgerEntry {\n18:   id: number;\n19:   timestamp: string;\n20:   mutation_type: MutationType;\n21:   reason: string;\n22:   prior_hash: string | null;\n23:   new_hash: string;\n24:   linked_memory_ids: string; // JSON array\n25:   decision_meta: string;     // JSON object\n26:   actor: string;\n27:   session_id: string | null;\n28: }\n29: \n30: interface AppendEntryInput {\n31:   mutation_type: MutationType;\n32:   reason: string;\n33:   prior_hash: string | null;\n34:   new_hash: string;\n35:   linked_memory_ids: number[];\n36:   decision_meta: Record<string, unknown>;\n37:   actor: string;\n38:   session_id?: string | null;\n39: }\n40: \n41: interface GetEntriesOptions {\n42:   mutation_type?: MutationType;\n43:   actor?: string;\n44:   session_id?: string;\n45:   since?: string;    // ISO timestamp\n46:   until?: string;    // ISO timestamp\n47:   limit?: number;\n48:   offset?: number;\n49: }\n50: \n51: interface DivergenceReconcilePolicy {\n52:   normalizedPath: string;\n53:   attemptsSoFar: number;\n54:   nextAttempt: number;\n55:   maxRetries: number;\n56:   shouldRetry: boolean;\n57:   exhausted: boolean;\n58: }\n59: \n60: interface DivergenceEscalationPayload {\n61:   code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n62:   normalizedPath: string;\n63:   attempts: number;\n64:   maxRetries: number;\n65:   recommendation: 'manual_triage_required';\n66:   reason: string;\n67:   variants: string[];\n68: }\n69: \n70: interface RecordDivergenceReconcileInput {\n71:   normalizedPath: string;\n72:   variants?: string[];\n73:   actor?: string;\n74:   session_id?: string | null;\n75:   maxRetries?: number;\n76: }\n77: \n78: interface RecordDivergenceReconcileResult {\n79:   policy: DivergenceReconcilePolicy;\n80:   retryEntryId: number | null;\n81:   escalationEntryId: number | null;\n82:   escalation: DivergenceEscalationPayload | null;\n83: }\n84: \n85: interface AutomatedMutationAuditInput {\n86:   mutation_type?: MutationType;\n87:   actor: string;\n88:   source_kind: 'agent' | 'system' | 'import' | 'feedback';\n89:   reason: string;\n90:   linked_memory_ids?: number[];\n91:   session_id?: string | null;\n92:   decision_meta?: Record<string, unknown>;\n93: }\n94: \n95: interface AutomatedMutationAuditResult {\n96:   appended: boolean;\n97:   eventKey: string;\n98:   entry: MutationLedgerEntry | null;\n99: }\n100: \n101: /* ───────────────────────────────────────────────────────────────\n102:    2. SCHEMA SQL\n103: ----------------------------------------------------------------*/\n104: \n105: const LEDGER_SCHEMA_SQL = `\n106:   CREATE TABLE IF NOT EXISTS mutation_ledger (\n107:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n108:     timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n109:     mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n110:     reason TEXT NOT NULL,\n111:     prior_hash TEXT,\n112:     new_hash TEXT NOT NULL,\n113:     linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n114:     decision_meta TEXT NOT NULL DEFAULT '{}',\n115:     actor TEXT NOT NULL,\n116:     session_id TEXT\n117:   )\n118: `;\n119: \n120: const LEDGER_INDEX_SQL = `\n121:   CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n122:   CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n123:   CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n124:   CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n125:   CREATE INDEX IF NOT EXISTS idx_ledger_new_hash ON mutation_ledger(new_hash);\n126:   CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n127:     CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n128:     mutation_type,\n129:     timestamp\n130:   )\n131: `;\n132: \n133: const LEDGER_TRIGGER_SQL = `\n134:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n135:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n136:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n137:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n138: `;\n139: \n140: /* ───────────────────────────────────────────────────────────────\n141:    3. INITIALIZATION\n142: ----------------------------------------------------------------*/\n143: \n144: function initLedger(db: Database.Database): void {\n145:   db.exec(LEDGER_SCHEMA_SQL);\n146:   db.exec(LEDGER_INDEX_SQL);\n147:   db.exec(LEDGER_TRIGGER_SQL);\n148: }\n149: \n150: /* ───────────────────────────────────────────────────────────────\n151:    4. HASH COMPUTATION\n152: ----------------------------------------------------------------*/\n153: \n154: function computeHash(content: string): string {\n155:   return createHash('sha256').update(content, 'utf8').digest('hex');\n156: }\n157: \n158: /* ───────────────────────────────────────────────────────────────\n159:    5. APPEND ENTRY\n160: ----------------------------------------------------------------*/\n161: \n162: function appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n163:   const linkedJson = JSON.stringify(entry.linked_memory_ids);\n164:   const metaJson = JSON.stringify(entry.decision_meta);\n165: \n166:   const stmt = db.prepare(`\n167:     INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n168:     VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n169:   `);\n170: \n171:   const result = stmt.run(\n172:     entry.mutation_type,\n173:     entry.reason,\n174:     entry.prior_hash,\n175:     entry.new_hash,\n176:     linkedJson,\n177:     metaJson,\n178:     entry.actor,\n179:     entry.session_id ?? null\n180:   );\n181: \n182:   const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n183: \n184:   const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n185:   return row;\n186: }\n187: \n188: function buildAutomatedMutationEventKey(input: AutomatedMutationAuditInput): string {\n189:   const linkedMemoryIds = (input.linked_memory_ids ?? [])\n190:     .filter((id) => Number.isInteger(id) && id > 0)\n191:     .slice()\n192:     .sort((left, right) => left - right);\n193:   return computeHash(JSON.stringify({\n194:     actor: input.actor,\n195:     source_kind: input.source_kind,\n196:     reason: input.reason,\n197:     linked_memory_ids: linkedMemoryIds,\n198:   }));\n199: }\n200: \n201: function getAutomatedMutationAuditEntry(db: Database.Database, eventKey: string): MutationLedgerEntry | null {\n202:   const row = db.prepare(`\n203:     SELECT *\n204:     FROM mutation_ledger\n205:     WHERE new_hash = ?\n206:     ORDER BY id ASC\n207:     LIMIT 1\n208:   `).get(eventKey) as MutationLedgerEntry | undefined;\n209:   return row ?? null;\n210: }\n211: \n212: function appendAutomatedMutationAudit(\n213:   db: Database.Database,\n214:   input: AutomatedMutationAuditInput,\n215: ): AutomatedMutationAuditResult {\n216:   initLedger(db);\n217:   const eventKey = buildAutomatedMutationEventKey(input);\n218:   const existing = getAutomatedMutationAuditEntry(db, eventKey);\n219:   if (existing) {\n220:     return { appended: false, eventKey, entry: existing };\n221:   }\n222: \n223:   const entry = appendEntry(db, {\n224:     mutation_type: input.mutation_type ?? 'update',\n225:     reason: input.reason,\n226:     prior_hash: null,\n227:     new_hash: eventKey,\n228:     linked_memory_ids: input.linked_memory_ids ?? [],\n229:     decision_meta: {\n230:       ...(input.decision_meta ?? {}),\n231:       eventKey,\n232:       sourceKind: input.source_kind,\n233:       automated: true,\n234:     },\n235:     actor: input.actor,\n236:     session_id: input.session_id ?? null,\n237:   });\n238: \n239:   return { appended: true, eventKey, entry };\n240: }\n241: \n242: /* ───────────────────────────────────────────────────────────────\n243:    6. QUERY ENTRIES\n244: ----------------------------------------------------------------*/\n245: \n246: function getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n247:   const conditions: string[] = [];\n248:   const params: Array<string | number> = [];\n249: \n250:   if (opts.mutation_type) {\n251:     conditions.push('mutation_type = ?');\n252:     params.push(opts.mutation_type);\n253:   }\n254:   if (opts.actor) {\n255:     conditions.push('actor = ?');\n256:     params.push(opts.actor);\n257:   }\n258:   if (opts.session_id) {\n259:     conditions.push('session_id = ?');\n260:     params.push(opts.session_id);\n261:   }\n262:   if (opts.since) {\n263:     conditions.push('timestamp >= ?');\n264:     params.push(opts.since);\n265:   }\n266:   if (opts.until) {\n267:     conditions.push('timestamp <= ?');\n268:     params.push(opts.until);\n269:   }\n270: \n271:   const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n272:   // String interpolation in LIMIT/OFFSET is safe here because both values\n273:   // Are coerced to non-negative integers via Math.floor + Math.max before use —\n274:   // Math.floor guarantees no decimal component, Math.max(1,…)/Math.max(0,…)\n275:   // Guarantees no negative value. No user-supplied string reaches the SQL directly.\n276:   const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n277:   // OFFSET without LIMIT is invalid SQLite syntax.\n278:   // When offset is set but limit is not, emit LIMIT -1 (all rows) before OFFSET.\n279:   const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n280:   const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n281: \n282:   // String interpolation constructs IN(?,?,?) placeholder list only —\n283:   // All user values are parameterized. Accepted exception per audit H-08.\n284:   const sql = `SELECT * FROM mutation_ledger ${where} ORDER BY id ASC ${effectiveLimit} ${offset}`;\n285:   return db.prepare(sql).all(...params) as MutationLedgerEntry[];\n286: }\n287: \n288: function getEntryCount(db: Database.Database): number {\n289:   const row = db.prepare('SELECT COUNT(*) as count FROM mutation_ledger').get() as { count: number };\n290:   return row.count;\n291: }\n292: \n293: /* ───────────────────────────────────────────────────────────────\n294:    7. LINKED ENTRIES LOOKUP\n295: ----------------------------------------------------------------*/\n296: \n297: function getLinkedEntries(db: Database.Database, memoryId: number): MutationLedgerEntry[] {\n298:   // SQLite json_each can expand JSON arrays for matching\n299:   const sql = `\n300:     SELECT ml.* FROM mutation_ledger ml, json_each(ml.linked_memory_ids) je\n301:     WHERE je.value = ?\n302:     ORDER BY ml.id ASC\n303:   `;\n304:   return db.prepare(sql).all(memoryId) as MutationLedgerEntry[];\n305: }\n306: \n307: /* ───────────────────────────────────────────────────────────────\n308:    8. APPEND-ONLY VERIFICATION\n309: ----------------------------------------------------------------*/\n310: \n311: /**\n312:  * Verify that append-only triggers exist on the mutation_ledger table.\n313:  * Returns true if both UPDATE and DELETE triggers are present.\n314:  */\n315: function verifyAppendOnly(db: Database.Database): boolean {\n316:   const triggers = db.prepare(\n317:     \"SELECT name FROM sqlite_master WHERE type = 'trigger' AND tbl_name = 'mutation_ledger'\"\n318:   ).all() as Array<{ name: string }>;\n319: \n320:   const names = triggers.map(t => t.name);\n\n(Showing lines 1-320 of 555. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: string; // JSON array\n  decision_meta: string;     // JSON object\n  actor: string;\n  session_id: string | null;\n}\n\ninterface AppendEntryInput {\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: number[];\n  decision_meta: Record<string, unknown>;\n  actor: string;\n  session_id?: string | null;\n}\n\ninterface GetEntriesOptions {\n  mutation_type?: MutationType;\n  actor?: string;\n  session_id?: string;\n  since?: string;    // ISO timestamp\n  until?: string;    // ISO timestamp\n  limit?: number;\n  offset?: number;\n}\n\ninterface DivergenceReconcilePolicy {\n  normalizedPath: string;\n  attemptsSoFar: number;\n  nextAttempt: number;\n  maxRetries: number;\n  shouldRetry: boolean;\n  exhausted: boolean;\n}\n\ninterface DivergenceEscalationPayload {\n  code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n  normalizedPath: string;\n  attempts: number;\n  maxRetries: number;\n  recommendation: 'manual_triage_required';\n  reason: string;\n  variants: string[];\n}\n\ninterface RecordDivergenceReconcileInput {\n  normalizedPath: string;\n  variants?: string[];\n  actor?: string;\n  session_id?: string | null;\n  maxRetries?: number;\n}\n\ninterface RecordDivergenceReconcileResult {\n  policy: DivergenceReconcilePolicy;\n  retryEntryId: number | null;\n  escalationEntryId: number | null;\n  escalation: DivergenceEscalationPayload | null;\n}\n\ninterface AutomatedMutationAuditInput {\n  mutation_type?: MutationType;\n  actor: string;\n  source_kind: 'agent' | 'system' | 'import' | 'feedback';\n  reason: string;\n  linked_memory_ids?: number[];\n  session_id?: string | null;\n  decision_meta?: Record<string, unknown>;\n}\n\ninterface AutomatedMutationAuditResult {\n  appended: boolean;\n  eventKey: string;\n  entry: MutationLedgerEntry | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. SCHEMA SQL\n----------------------------------------------------------------*/\n\nconst LEDGER_SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS mutation_ledger (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n    mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n    reason TEXT NOT NULL,\n    prior_hash TEXT,\n    new_hash TEXT NOT NULL,\n    linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n    decision_meta TEXT NOT NULL DEFAULT '{}',\n    actor TEXT NOT NULL,\n    session_id TEXT\n  )\n`;\n\nconst LEDGER_INDEX_SQL = `\n  CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n  CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n  CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n  CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n  CREATE INDEX IF NOT EXISTS idx_ledger_new_hash ON mutation_ledger(new_hash);\n  CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n    CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n    mutation_type,\n    timestamp\n  )\n`;\n\nconst LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   3. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction initLedger(db: Database.Database): void {\n  db.exec(LEDGER_SCHEMA_SQL);\n  db.exec(LEDGER_INDEX_SQL);\n  db.exec(LEDGER_TRIGGER_SQL);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HASH COMPUTATION\n----------------------------------------------------------------*/\n\nfunction computeHash(content: string): string {\n  return createHash('sha256').update(content, 'utf8').digest('hex');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. APPEND ENTRY\n----------------------------------------------------------------*/\n\nfunction appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n  const linkedJson = JSON.stringify(entry.linked_memory_ids);\n  const metaJson = JSON.stringify(entry.decision_meta);\n\n  const stmt = db.prepare(`\n    INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const result = stmt.run(\n    entry.mutation_type,\n    entry.reason,\n    entry.prior_hash,\n    entry.new_hash,\n    linkedJson,\n    metaJson,\n    entry.actor,\n    entry.session_id ?? null\n  );\n\n  const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n\n  const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n  return row;\n}\n\nfunction buildAutomatedMutationEventKey(input: AutomatedMutationAuditInput): string {\n  const linkedMemoryIds = (input.linked_memory_ids ?? [])\n    .filter((id) => Number.isInteger(id) && id > 0)\n    .slice()\n    .sort((left, right) => left - right);\n  return computeHash(JSON.stringify({\n    actor: input.actor,\n    source_kind: input.source_kind,\n    reason: input.reason,\n    linked_memory_ids: linkedMemoryIds,\n  }));\n}\n\nfunction getAutomatedMutationAuditEntry(db: Database.Database, eventKey: string): MutationLedgerEntry | null {\n  const row = db.prepare(`\n    SELECT *\n    FROM mutation_ledger\n    WHERE new_hash = ?\n    ORDER BY id ASC\n    LIMIT 1\n  `).get(eventKey) as MutationLedgerEntry | undefined;\n  return row ?? null;\n}\n\nfunction appendAutomatedMutationAudit(\n  db: Database.Database,\n  input: AutomatedMutationAuditInput,\n): AutomatedMutationAuditResult {\n  initLedger(db);\n  const eventKey = buildAutomatedMutationEventKey(input);\n  const existing = getAutomatedMutationAuditEntry(db, eventKey);\n  if (existing) {\n    return { appended: false, eventKey, entry: existing };\n  }\n\n  const entry = appendEntry(db, {\n    mutation_type: input.mutation_type ?? 'update',\n    reason: input.reason,\n    prior_hash: null,\n    new_hash: eventKey,\n    linked_memory_ids: input.linked_memory_ids ?? [],\n    decision_meta: {\n      ...(input.decision_meta ?? {}),\n      eventKey,\n      sourceKind: input.source_kind,\n      automated: true,\n    },\n    actor: input.actor,\n    session_id: input.session_id ?? null,\n  });\n\n  return { appended: true, eventKey, entry };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. QUERY ENTRIES\n----------------------------------------------------------------*/\n\nfunction getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n  const conditions: string[] = [];\n  const params: Array<string | number> = [];\n\n  if (opts.mutation_type) {\n    conditions.push('mutation_type = ?');\n    params.push(opts.mutation_type);\n  }\n  if (opts.actor) {\n    conditions.push('actor = ?');\n    params.push(opts.actor);\n  }\n  if (opts.session_id) {\n    conditions.push('session_id = ?');\n    params.push(opts.session_id);\n  }\n  if (opts.since) {\n    conditions.push('timestamp >= ?');\n    params.push(opts.since);\n  }\n  if (opts.until) {\n    conditions.push('timestamp <= ?');\n    params.push(opts.until);\n  }\n\n  const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n  // String interpolation in LIMIT/OFFSET is safe here because both values\n  // Are coerced to non-negative integers via Math.floor + Math.max before use —\n  // Math.floor guarantees no decimal component, Math.max(1,…)/Math.max(0,…)\n  // Guarantees no negative value. No user-supplied string reaches the SQL directly.\n  const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n  // OFFSET without LIMIT is invalid SQLite syntax.\n  // When offset is set but limit is not, emit LIMIT -1 (all rows) before OFFSET.\n  const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n  const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n\n  // String interpolation constructs IN(?,?,?) placeholder list only —\n  // All user values are parameterized. Accepted exception per audit H-08.\n  const sql = `SELECT * FROM mutation_ledger ${where} ORDER BY id ASC ${effectiveLimit} ${offset}`;\n  return db.prepare(sql).all(...params) as MutationLedgerEntry[];\n}\n\nfunction getEntryCount(db: Database.Database): number {\n  const row = db.prepare('SELECT COUNT(*) as count FROM mutation_ledger').get() as { count: number };\n  return row.count;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LINKED ENTRIES LOOKUP\n----------------------------------------------------------------*/\n\nfunction getLinkedEntries(db: Database.Database, memoryId: number): MutationLedgerEntry[] {\n  // SQLite json_each can expand JSON arrays for matching\n  const sql = `\n    SELECT ml.* FROM mutation_ledger ml, json_each(ml.linked_memory_ids) je\n    WHERE je.value = ?\n    ORDER BY ml.id ASC\n  `;\n  return db.prepare(sql).all(memoryId) as MutationLedgerEntry[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. APPEND-ONLY VERIFICATION\n----------------------------------------------------------------*/\n\n/**\n * Verify that append-only triggers exist on the mutation_ledger table.\n * Returns true if both UPDATE and DELETE triggers are present.\n */\nfunction verifyAppendOnly(db: Database.Database): boolean {\n  const triggers = db.prepare(\n    \"SELECT name FROM sqlite_master WHERE type = 'trigger' AND tbl_name = 'mutation_ledger'\"\n  ).all() as Array<{ name: string }>;\n\n  const names = triggers.map(t => t.name);","lineStart":1,"lineEnd":320,"totalLines":555,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","time":{"start":1781761460431,"end":1781761460452}},"metadata":{"openai":{"itemId":"fc_0f33689ed4629db5016a3385b45a708191bcff7c4d9246c1dc"}},"id":"prt_ed94248cd001qq83TrauZ2dPcH","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94220fc001yUh9MgDz6zye8x"}}
