mpatibility details for logging and rollout gates.\n1799:  */\n1800: export function validate_backward_compatibility(database: Database.Database): SchemaCompatibilityReport {\n1801:   try {\n1802:     const missingTables = REQUIRED_TABLES.filter((tableName) => !hasTable(database, tableName));\n1803:     const missingColumns: Record<string, string[]> = {};\n1804:     const missingIndexes: string[] = [];\n1805:     const constraintMismatches: string[] = [];\n1806:     const warnings: string[] = [];\n1807: \n1808:     if (hasTable(database, 'memory_index')) {\n1809:       const existingColumns = new Set(getTableColumns(database, 'memory_index'));\n1810:       const absentColumns = REQUIRED_MEMORY_INDEX_COLUMNS.filter((columnName) => !existingColumns.has(columnName));\n1811:       if (absentColumns.length > 0) {\n1812:         missingColumns.memory_index = absentColumns;\n1813:       }\n1814:       if (!hasConstitutionalTierConstraint(database)) {\n1815:         constraintMismatches.push('memory_index.importance_tier CHECK constraint is missing constitutional support');\n1816:       }\n1817:     } else {\n1818:       missingColumns.memory_index = [...REQUIRED_MEMORY_INDEX_COLUMNS];\n1819:     }\n1820: \n1821:     if (hasTable(database, 'memory_conflicts')) {\n1822:       const existingColumns = new Set(getTableColumns(database, 'memory_conflicts'));\n1823:       const absentColumns = REQUIRED_MEMORY_CONFLICT_COLUMNS.filter((columnName) => !existingColumns.has(columnName));\n1824:       if (absentColumns.length > 0) {\n1825:         missingColumns.memory_conflicts = absentColumns;\n1826:       }\n1827:     }\n1828: \n1829:     for (const [tableName, requiredIndexes] of Object.entries(REQUIRED_INDEXES_BY_TABLE)) {\n1830:       if (!hasTable(database, tableName)) {\n1831:         continue;\n1832:       }\n1833:       for (const indexName of requiredIndexes) {\n1834:         if (!hasIndex(database, indexName)) {\n1835:           missingIndexes.push(indexName);\n1836:         }\n1837:       }\n1838:     }\n1839: \n1840:     if (!hasTable(database, 'memory_history')) {\n1841:       warnings.push('memory_history table missing; historical replay functionality may be degraded.');\n1842:     }\n1843:     if (!hasTable(database, 'checkpoints')) {\n1844:       warnings.push('checkpoints table missing; migration checkpoint tooling may be unavailable.');\n1845:     }\n1846:     if (!hasTable(database, 'memory_conflicts')) {\n1847:       warnings.push('memory_conflicts table missing; conflict audit trail may be incomplete.');\n1848:     }\n1849: \n\n(Showing lines 1760-1849 of 2784. Use offset=1850 to continue.)\n</content>","metadata":{"preview":"  dropDeprecatedSharedSpaceColumn(database);\n\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS governance_audit (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      action TEXT NOT NULL,\n      decision TEXT NOT NULL,\n      memory_id INTEGER,\n      logical_key TEXT,\n      tenant_id TEXT,\n      user_id TEXT,\n      agent_id TEXT,\n      session_id TEXT,\n      reason TEXT,\n      metadata TEXT,\n      created_at TEXT DEFAULT CURRENT_TIMESTAMP\n    )\n  `);\n\n  database.exec(`","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","text":"  dropDeprecatedSharedSpaceColumn(database);\n\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS governance_audit (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      action TEXT NOT NULL,\n      decision TEXT NOT NULL,\n      memory_id INTEGER,\n      logical_key TEXT,\n      tenant_id TEXT,\n      user_id TEXT,\n      agent_id TEXT,\n      session_id TEXT,\n      reason TEXT,\n      metadata TEXT,\n      created_at TEXT DEFAULT CURRENT_TIMESTAMP\n    )\n  `);\n\n  database.exec(`\n    CREATE INDEX IF NOT EXISTS idx_governance_audit_action\n      ON governance_audit(action, decision, created_at DESC);\n    CREATE INDEX IF NOT EXISTS idx_governance_audit_scope\n      ON governance_audit(tenant_id, user_id, agent_id, session_id);\n  `);\n\n  if (hasTable(database, 'memory_index')) {\n    database.exec(`\n      CREATE INDEX IF NOT EXISTS idx_memory_scope_hierarchy\n        ON memory_index(tenant_id, user_id, agent_id, session_id);\n      CREATE INDEX IF NOT EXISTS idx_memory_retention_delete_after\n        ON memory_index(delete_after);\n    `);\n  }\n}\n\n/**\n * Validates backward compatibility expectations for the current schema.\n * Never throws; returns compatibility details for logging and rollout gates.\n */\nexport function validate_backward_compatibility(database: Database.Database): SchemaCompatibilityReport {\n  try {\n    const missingTables = REQUIRED_TABLES.filter((tableName) => !hasTable(database, tableName));\n    const missingColumns: Record<string, string[]> = {};\n    const missingIndexes: string[] = [];\n    const constraintMismatches: string[] = [];\n    const warnings: string[] = [];\n\n    if (hasTable(database, 'memory_index')) {\n      const existingColumns = new Set(getTableColumns(database, 'memory_index'));\n      const absentColumns = REQUIRED_MEMORY_INDEX_COLUMNS.filter((columnName) => !existingColumns.has(columnName));\n      if (absentColumns.length > 0) {\n        missingColumns.memory_index = absentColumns;\n      }\n      if (!hasConstitutionalTierConstraint(database)) {\n        constraintMismatches.push('memory_index.importance_tier CHECK constraint is missing constitutional support');\n      }\n    } else {\n      missingColumns.memory_index = [...REQUIRED_MEMORY_INDEX_COLUMNS];\n    }\n\n    if (hasTable(database, 'memory_conflicts')) {\n      const existingColumns = new Set(getTableColumns(database, 'memory_conflicts'));\n      const absentColumns = REQUIRED_MEMORY_CONFLICT_COLUMNS.filter((columnName) => !existingColumns.has(columnName));\n      if (absentColumns.length > 0) {\n        missingColumns.memory_conflicts = absentColumns;\n      }\n    }\n\n    for (const [tableName, requiredIndexes] of Object.entries(REQUIRED_INDEXES_BY_TABLE)) {\n      if (!hasTable(database, tableName)) {\n        continue;\n      }\n      for (const indexName of requiredIndexes) {\n        if (!hasIndex(database, indexName)) {\n          missingIndexes.push(indexName);\n        }\n      }\n    }\n\n    if (!hasTable(database, 'memory_history')) {\n      warnings.push('memory_history table missing; historical replay functionality may be degraded.');\n    }\n    if (!hasTable(database, 'checkpoints')) {\n      warnings.push('checkpoints table missing; migration checkpoint tooling may be unavailable.');\n    }\n    if (!hasTable(database, 'memory_conflicts')) {\n      warnings.push('memory_conflicts table missing; conflict audit trail may be incomplete.');\n    }\n","lineStart":1760,"lineEnd":1849,"totalLines":2784,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","time":{"start":1780738265448,"end":1780738265456}},"metadata":{"openai":{"itemId":"fc_0b189349cc923f4d016a23e8d95d2c81918e16ec6def6afb98"}},"id":"prt_e9c45915c001lEJiAPvgUsYps0","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c456e1d001TBAIMzmDoEXsC5"}}
{"type":"tool_use","timestamp":1780738265553,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_s45jPJFSgJpaSX5MvUcVhuHC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","offset":240,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts</path>\n<type>file</type>\n<content>\n240:   try {\n241:     database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n242:     database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n243:     ensureTemporalColumns(database);\n244:   } catch (_e: unknown) {\n245:     // Best-effort: table may not exist yet during early startup sequencing\n246:   }\n247: }\n248: \n249: /* ───────────────────────────────────────────────────────────────\n250:    5. EDGE OPERATIONS\n251: ----------------------------------------------------------------*/\n252: \n253: function insertEdge(\n254:   sourceId: string,\n255:   targetId: string,\n256:   relation: RelationType,\n257:   strength: number = 1.0,\n258:   evidence: string | null = null,\n259:   shouldInvalidateCache: boolean = true,\n260:   createdBy: string = 'manual',\n261:   anchors: { sourceAnchor?: string | null; targetAnchor?: string | null } = {},\n262: ): number | null {\n263:   if (!db) {\n264:     console.warn('[causal-edges] Database not initialized. Server may still be starting up.');\n265:     return null;\n266:   }\n267:   const database = db;\n268: \n269:   // NFR-R01: Auto edges capped at MAX_AUTO_STRENGTH\n270:   const effectiveStrength = createdBy === 'auto'\n271:     ? Math.min(strength, MAX_AUTO_STRENGTH)\n272:     : strength;\n273: \n274:   // Prevent self-loops\n275:   if (sourceId === targetId) {\n276:     return null;\n277:   }\n278: \n279:   // FK check deferred — test environments use synthetic IDs not in memory_index.\n280:   // Implementing FK validation would require seeding memory_index in 20+ causal edge tests.\n281: \n282:   // NFR-R01: Edge bounds — reject if node already has MAX_EDGES_PER_NODE auto edges\n283:   if (createdBy === 'auto') {\n284:     const edgeCount = countEdgesForNode(sourceId);\n285:     if (edgeCount >= MAX_EDGES_PER_NODE) {\n286:       console.warn(`[causal-edges] Edge bounds: node ${sourceId} has ${edgeCount} edges (max ${MAX_EDGES_PER_NODE}), rejecting auto edge`);\n287:       return null;\n288:     }\n289:   }\n290: \n291:   try {\n292:     const clampedStrength = clampStrength(effectiveStrength);\n293:     if (clampedStrength === null) {\n294:       console.warn('[causal-edges] insertEdge rejected non-finite strength');\n295:       return null;\n296:     }\n297: \n298:     // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n299:     const rowId = database.transaction(() => {\n300:       if (isTemporalEdgesEnabled()) {\n301:         detectContradictions(\n302:           database,\n303:           Number.parseInt(sourceId, 10),\n304:           Number.parseInt(targetId, 10),\n305:           relation,\n306:         );\n307:       }\n308: \n309:       // Check if edge exists (for weight_history logging on conflict update).\n310:       // This SELECT is intentional: we need the old strength to decide whether\n311:       // To write a weight_history row after the upsert. The subsequent INSERT\n312:       // Uses last_insert_rowid() to avoid a second post-upsert SELECT.\n313:       const existing = (database.prepare(`\n314:         SELECT id, strength FROM causal_edges\n315:         WHERE source_id = ? AND target_id = ? AND relation = ?\n316:           AND COALESCE(source_anchor, '') = COALESCE(?, '')\n317:           AND COALESCE(target_anchor, '') = COALESCE(?, '')\n318:       `) as Database.Statement).get(\n319:         sourceId,\n320:         targetId,\n321:         relation,\n322:         anchors.sourceAnchor ?? null,\n323:         anchors.targetAnchor ?? null,\n324:       ) as { id: number; strength: number } | undefined;\n325: \n326:       if (existing) {\n327:         (database.prepare(`\n328:           UPDATE causal_edges\n329:           SET strength = ?,\n330:               evidence = COALESCE(?, evidence),\n331:               created_by = ?\n332:           WHERE id = ?\n333:         `) as Database.Statement).run(\n334:           clampedStrength,\n335:           evidence,\n336:           createdBy,\n337:           existing.id,\n338:         );\n339:       } else {\n340:         if (!enforceRelationWindowCap(relation, database)) {\n341:           return 0;\n342:         }\n343: \n344:         (database.prepare(`\n345:           INSERT INTO causal_edges (\n346:             source_id,\n347:             target_id,\n348:             source_anchor,\n349:             target_anchor,\n350:             relation,\n351:             strength,\n352:             evidence,\n353:             created_by\n354:           )\n355:           VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n356:         `) as Database.Statement).run(\n357:           sourceId,\n358:           targetId,\n359:           anchors.sourceAnchor ?? null,\n\n(Showing lines 240-359 of 1099. Use offset=360 to continue.)\n</content>","metadata":{"preview":"  try {\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n    ensureTemporalColumns(database);\n  } catch (_e: unknown) {\n    // Best-effort: table may not exist yet during early startup sequencing\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EDGE OPERATIONS\n----------------------------------------------------------------*/\n\nfunction insertEdge(\n  sourceId: string,\n  targetId: string,\n  relation: RelationType,\n  strength: number = 1.0,\n  evidence: string | null = null,\n  shouldInvalidateCache: boolean = true,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","text":"  try {\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n    ensureTemporalColumns(database);\n  } catch (_e: unknown) {\n    // Best-effort: table may not exist yet during early startup sequencing\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EDGE OPERATIONS\n----------------------------------------------------------------*/\n\nfunction insertEdge(\n  sourceId: string,\n  targetId: string,\n  relation: RelationType,\n  strength: number = 1.0,\n  evidence: string | null = null,\n  shouldInvalidateCache: boolean = true,\n  createdBy: string = 'manual',\n  anchors: { sourceAnchor?: string | null; targetAnchor?: string | null } = {},\n): number | null {\n  if (!db) {\n    console.warn('[causal-edges] Database not initialized. Server may still be starting up.');\n    return null;\n  }\n  const database = db;\n\n  // NFR-R01: Auto edges capped at MAX_AUTO_STRENGTH\n  const effectiveStrength = createdBy === 'auto'\n    ? Math.min(strength, MAX_AUTO_STRENGTH)\n    : strength;\n\n  // Prevent self-loops\n  if (sourceId === targetId) {\n    return null;\n  }\n\n  // FK check deferred — test environments use synthetic IDs not in memory_index.\n  // Implementing FK validation would require seeding memory_index in 20+ causal edge tests.\n\n  // NFR-R01: Edge bounds — reject if node already has MAX_EDGES_PER_NODE auto edges\n  if (createdBy === 'auto') {\n    const edgeCount = countEdgesForNode(sourceId);\n    if (edgeCount >= MAX_EDGES_PER_NODE) {\n      console.warn(`[causal-edges] Edge bounds: node ${sourceId} has ${edgeCount} edges (max ${MAX_EDGES_PER_NODE}), rejecting auto edge`);\n      return null;\n    }\n  }\n\n  try {\n    const clampedStrength = clampStrength(effectiveStrength);\n    if (clampedStrength === null) {\n      console.warn('[causal-edges] insertEdge rejected non-finite strength');\n      return null;\n    }\n\n    // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n    const rowId = database.transaction(() => {\n      if (isTemporalEdgesEnabled()) {\n        detectContradictions(\n          database,\n          Number.parseInt(sourceId, 10),\n          Number.parseInt(targetId, 10),\n          relation,\n        );\n      }\n\n      // Check if edge exists (for weight_history logging on conflict update).\n      // This SELECT is intentional: we need the old strength to decide whether\n      // To write a weight_history row after the upsert. The subsequent INSERT\n      // Uses last_insert_rowid() to avoid a second post-upsert SELECT.\n      const existing = (database.prepare(`\n        SELECT id, strength FROM causal_edges\n        WHERE source_id = ? AND target_id = ? AND relation = ?\n          AND COALESCE(source_anchor, '') = COALESCE(?, '')\n          AND COALESCE(target_anchor, '') = COALESCE(?, '')\n      `) as Database.Statement).get(\n        sourceId,\n        targetId,\n        relation,\n        anchors.sourceAnchor ?? null,\n        anchors.targetAnchor ?? null,\n      ) as { id: number; strength: number } | undefined;\n\n      if (existing) {\n        (database.prepare(`\n          UPDATE causal_edges\n          SET strength = ?,\n              evidence = COALESCE(?, evidence),\n              created_by = ?\n          WHERE id = ?\n        `) as Database.Statement).run(\n          clampedStrength,\n          evidence,\n          createdBy,\n          existing.id,\n        );\n      } else {\n        if (!enforceRelationWindowCap(relation, database)) {\n          return 0;\n        }\n\n        (database.prepare(`\n          INSERT INTO causal_edges (\n            source_id,\n            target_id,\n            source_anchor,\n            target_anchor,\n            relation,\n            strength,\n            evidence,\n            created_by\n          )\n          VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n        `) as Database.Statement).run(\n          sourceId,\n          targetId,\n          anchors.sourceAnchor ?? null,","lineStart":240,"lineEnd":359,"totalLines":1099,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","time":{"start":1780738265545,"end":1780738265550}},"metadata":{"openai":{"itemId":"fc_0b189349cc923f4d016a23e8d95d5881918bece54a107d80ea"}},"id":"prt_e9c4591c8001Bb4sirTKPIcZon","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c456e1d001TBAIMzmDoEXsC5"}}
{"type":"tool_use","timestamp":1780738265553,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_o9osmrIaD4sLe9S1MjDV38Vo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { recordGovernanceAudit } from './scope-governance.js';\n9: \n10: import type Database from 'better-sqlite3';\n11: \n12: /** Options for a governed memory retention sweep. */\n13: export interface MemoryRetentionSweepArgs {\n14:   dryRun?: boolean;\n15: }\n16: \n17: /** Expired memory_index row selected for retention deletion. */\n18: export interface RetentionExpiredRow {\n19:   id: number;\n20:   specFolder: string | null;\n21:   filePath: string | null;\n22:   contentHash: string | null;\n23:   tenantId: string | null;\n24:   userId: string | null;\n25:   agentId: string | null;\n26:   sessionId: string | null;\n27:   deleteAfter: string;\n28: }\n29: \n30: /** Aggregate sweep counts returned to callers and audit logs. */\n31: export interface MemoryRetentionSweepSummary {\n32:   swept: number;\n33:   retained: number;\n34:   dryRun: boolean;\n35:   durationMs: number;\n36: }\n37: \n38: /** Full sweep result including candidates, deletions, and ledger state. */\n39: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n40:   candidates: RetentionExpiredRow[];\n41:   deletedIds: number[];\n42:   ledgerRecorded: boolean | null;\n43: }\n44: \n45: function hasTable(database: Database.Database, tableName: string): boolean {\n46:   const row = database.prepare(\n47:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n48:   ).get(tableName) as { present?: number } | undefined;\n49:   return row?.present === 1;\n50: }\n51: \n52: function selectExpiredRows(database: Database.Database): RetentionExpiredRow[] {\n53:   return database.prepare(`\n54:     SELECT\n55:       id,\n56:       spec_folder AS specFolder,\n57:       file_path AS filePath,\n58:       content_hash AS contentHash,\n59:       tenant_id AS tenantId,\n60:       user_id AS userId,\n61:       agent_id AS agentId,\n62:       session_id AS sessionId,\n63:       delete_after AS deleteAfter\n64:     FROM memory_index\n65:     WHERE delete_after IS NOT NULL\n66:       AND datetime(delete_after) < datetime('now')\n67:     ORDER BY datetime(delete_after) ASC, id ASC\n68:   `).all() as RetentionExpiredRow[];\n69: }\n70: \n71: // Re-validate inside the delete transaction: a concurrent writer can raise or\n72: // clear delete_after between candidate selection and deletion, so a row that is\n73: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n74: function isStillExpired(database: Database.Database, id: number): boolean {\n75:   const row = database.prepare(`\n76:     SELECT 1 AS expired\n77:     FROM memory_index\n78:     WHERE id = ?\n79:       AND delete_after IS NOT NULL\n80:       AND datetime(delete_after) < datetime('now')\n81:     LIMIT 1\n82:   `).get(id) as { expired?: number } | undefined;\n83:   return row?.expired === 1;\n84: }\n85: \n86: /** Test-only surface for the retention TOCTOU guard. */\n87: export const __retentionSweepTestables = { isStillExpired };\n88: \n89: function countRows(database: Database.Database): number {\n90:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n91:   return row.count;\n92: }\n93: \n94: function appendRetentionLedger(\n95:   database: Database.Database,\n96:   deletedIds: number[],\n97:   candidates: RetentionExpiredRow[],\n98: ): boolean {\n99:   try {\n100:     mutationLedger.initLedger(database);\n101:     mutationLedger.appendEntry(database, {\n102:       mutation_type: 'delete',\n103:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n104:       prior_hash: null,\n105:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n106:       linked_memory_ids: deletedIds.slice(0, 50),\n107:       decision_meta: {\n108:         tool: 'memory_retention_sweep',\n109:         reason: 'retention_expired',\n110:         totalDeleted: deletedIds.length,\n111:         originalDeleteAfter: candidates\n112:           .filter((candidate) => deletedIds.includes(candidate.id))\n113:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n114:       },\n115:       actor: 'mcp:memory_retention_sweep',\n116:     });\n117:     return true;\n118:   } catch (error: unknown) {\n119:     const message = error instanceof Error ? error.message : String(error);\n120:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n121:     return false;\n122:   }\n123: }\n124: \n125: function runPostDeleteMaintenance(database: Database.Database): void {\n126:   try {\n127:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n128:   } catch (error: unknown) {\n129:     const message = error instanceof Error ? error.message : String(error);\n130:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n131:   }\n132: \n133:   let shouldRunIncrementalVacuum = false;\n134:   try {\n135:     const autoVacuumMode = database.pragma('auto_vacuum', { simple: true });\n136:     shouldRunIncrementalVacuum = Number(autoVacuumMode) === 2;\n137:   } catch (error: unknown) {\n138:     const message = error instanceof Error ? error.message : String(error);\n139:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n140:   }\n141: \n142:   if (shouldRunIncrementalVacuum) {\n143:     try {\n144:       database.pragma('incremental_vacuum');\n145:     } catch (error: unknown) {\n146:       const message = error instanceof Error ? error.message : String(error);\n147:       console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n148:     }\n149:   }\n150: \n151:   try {\n152:     database.pragma('wal_checkpoint(TRUNCATE)');\n153:   } catch (error: unknown) {\n154:     const message = error instanceof Error ? error.message : String(error);\n155:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n156:   }\n157: }\n158: \n159: /**\n160:  * Sweep expired governed memory rows.\n161:  *\n162:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n163:  * to enforce the ISO timestamps persisted by governed ingest.\n164:  */\n165: export function runMemoryRetentionSweep(\n166:   database: Database.Database,\n167:   args: MemoryRetentionSweepArgs = {},\n168: ): MemoryRetentionSweepResult {\n169:   const startTime = Date.now();\n170:   const dryRun = args.dryRun === true;\n171: \n172:   if (!hasTable(database, 'memory_index')) {\n173:     return {\n174:       swept: 0,\n175:       retained: 0,\n176:       dryRun,\n177:       durationMs: Date.now() - startTime,\n178:       candidates: [],\n179:       deletedIds: [],\n180:       ledgerRecorded: null,\n181:     };\n182:   }\n183: \n184:   const candidates = selectExpiredRows(database);\n185: \n186:   if (dryRun || candidates.length === 0) {\n187:     const totalRows = countRows(database);\n188:     return {\n189:       swept: 0,\n190:       retained: totalRows,\n191:       dryRun,\n192:       durationMs: Date.now() - startTime,\n193:       candidates,\n194:       deletedIds: [],\n195:       ledgerRecorded: null,\n196:     };\n197:   }\n198: \n199:   initHistory(database);\n200: \n201:   const deletedIds: number[] = [];\n202:   let ledgerRecorded: boolean | null = null;\n203: \n204:   const sweepTx = database.transaction(() => {\n205:     for (const candidate of candidates) {\n206:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n207:       if (!isStillExpired(database, candidate.id)) {\n208:         continue;\n209:       }\n210:       const deleted = vectorIndex.deleteMemory(candidate.id, database);\n211:       if (!deleted) {\n212:         continue;\n213:       }\n214: \n215:       deletedIds.push(candidate.id);\n216: \n217:       recordHistory(\n218:         candidate.id,\n219:         'DELETE',\n220:         {\n221:           reason: 'retention_expired',\n222:           deleteAfter: candidate.deleteAfter,\n223:           filePath: candidate.filePath,\n224:         },\n225:         null,\n226:         'mcp:memory_retention_sweep',\n227:         candidate.specFolder,\n228:       );\n229: \n230:       recordGovernanceAudit(database, {\n231:         action: 'retention_sweep',\n232:         decision: 'delete',\n233:         memoryId: candidate.id,\n234:         logicalKey: candidate.filePath,\n235:         tenantId: candidate.tenantId ?? undefined,\n236:         userId: candidate.userId ?? undefined,\n237:         agentId: candidate.agentId ?? undefined,\n238:         sessionId: candidate.sessionId ?? undefined,\n239:         reason: 'retention_expired',\n240:         metadata: {\n241:           originalDeleteAfter: candidate.deleteAfter,\n242:           delete_after: candidate.deleteAfter,\n243:           specFolder: candidate.specFolder,\n244:           filePath: candidate.filePath,\n245:         },\n246:       });\n247:     }\n248: \n249:     if (deletedIds.length > 0) {\n250:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n251:     }\n252:   });\n253: \n254:   sweepTx();\n255:   if (deletedIds.length > 0) {\n256:     runPostDeleteMaintenance(database);\n257:   }\n258: \n259:   return {\n260:     swept: deletedIds.length,\n\n(Showing lines 1-260 of 268. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n}\n\n/** Expired memory_index row selected for retention deletion. */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n}\n\n/** Expired memory_index row selected for retention deletion. */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  ledgerRecorded: boolean | null;\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction selectExpiredRows(database: Database.Database): RetentionExpiredRow[] {\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter\n    FROM memory_index\n    WHERE delete_after IS NOT NULL\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction isStillExpired(database: Database.Database, id: number): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS expired\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as { expired?: number } | undefined;\n  return row?.expired === 1;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  let shouldRunIncrementalVacuum = false;\n  try {\n    const autoVacuumMode = database.pragma('auto_vacuum', { simple: true });\n    shouldRunIncrementalVacuum = Number(autoVacuumMode) === 2;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  }\n\n  if (shouldRunIncrementalVacuum) {\n    try {\n      database.pragma('incremental_vacuum');\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n    }\n  }\n\n  try {\n    database.pragma('wal_checkpoint(TRUNCATE)');\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      ledgerRecorded: null,\n    };\n  }\n\n  const candidates = selectExpiredRows(database);\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    return {\n      swept: 0,\n      retained: totalRows,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      ledgerRecorded: null,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      if (!isStillExpired(database, candidate.id)) {\n        continue;\n      }\n      const deleted = vectorIndex.deleteMemory(candidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(candidate.id);\n\n      recordHistory(\n        candidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: candidate.deleteAfter,\n          filePath: candidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        candidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: candidate.id,\n        logicalKey: candidate.filePath,\n        tenantId: candidate.tenantId ?? undefined,\n        userId: candidate.userId ?? undefined,\n        agentId: candidate.agentId ?? undefined,\n        sessionId: candidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: candidate.deleteAfter,\n          delete_after: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n\n  return {\n    swept: deletedIds.length,","lineStart":1,"lineEnd":260,"totalLines":268,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1780738265547,"end":1780738265551}},"metadata":{"openai":{"itemId":"fc_0b189349cc923f4d016a23e8d95d688191bfed8200c4315612"}},"id":"prt_e9c4591ca001BtDTRmokN13GGT","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c456e1d001TBAIMzmDoEXsC5"}}
{"type":"tool_use","timestamp":1780738265553,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_RE0H9OFKGaCtgGhoDzh5JCGP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Mutation Ledger\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Append-only audit trail for all memory mutations\n6: // SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\n7: import { createHash } from 'crypto';\n8: import type Database from 'better-sqlite3';\n9: import { runInTransaction } from './transaction-manager.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. TYPES\n13: ----------------------------------------------------------------*/\n14: \n15: type MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n16: \n17: interface MutationLedgerEntry {\n18:   id: number;\n19:   timestamp: string;\n20:   mutation_type: MutationType;\n21:   reason: string;\n22:   prior_hash: string | null;\n23:   new_hash: string;\n24:   linked_memory_ids: string; // JSON array\n25:   decision_meta: string;     // JSON object\n26:   actor: string;\n27:   session_id: string | null;\n28: }\n29: \n30: interface AppendEntryInput {\n31:   mutation_type: MutationType;\n32:   reason: string;\n33:   prior_hash: string | null;\n34:   new_hash: string;\n35:   linked_memory_ids: number[];\n36:   decision_meta: Record<string, unknown>;\n37:   actor: string;\n38:   session_id?: string | null;\n39: }\n40: \n41: interface GetEntriesOptions {\n42:   mutation_type?: MutationType;\n43:   actor?: string;\n44:   session_id?: string;\n45:   since?: string;    // ISO timestamp\n46:   until?: string;    // ISO timestamp\n47:   limit?: number;\n48:   offset?: number;\n49: }\n50: \n51: interface DivergenceReconcilePolicy {\n52:   normalizedPath: string;\n53:   attemptsSoFar: number;\n54:   nextAttempt: number;\n55:   maxRetries: number;\n56:   shouldRetry: boolean;\n57:   exhausted: boolean;\n58: }\n59: \n60: interface DivergenceEscalationPayload {\n61:   code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n62:   normalizedPath: string;\n63:   attempts: number;\n64:   maxRetries: number;\n65:   recommendation: 'manual_triage_required';\n66:   reason: string;\n67:   variants: string[];\n68: }\n69: \n70: interface RecordDivergenceReconcileInput {\n71:   normalizedPath: string;\n72:   variants?: string[];\n73:   actor?: string;\n74:   session_id?: string | null;\n75:   maxRetries?: number;\n76: }\n77: \n78: interface RecordDivergenceReconcileResult {\n79:   policy: DivergenceReconcilePolicy;\n80:   retryEntryId: number | null;\n81:   escalationEntryId: number | null;\n82:   escalation: DivergenceEscalationPayload | null;\n83: }\n84: \n85: /* ───────────────────────────────────────────────────────────────\n86:    2. SCHEMA SQL\n87: ----------------------------------------------------------------*/\n88: \n89: const LEDGER_SCHEMA_SQL = `\n90:   CREATE TABLE IF NOT EXISTS mutation_ledger (\n91:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n92:     timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n93:     mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n94:     reason TEXT NOT NULL,\n95:     prior_hash TEXT,\n96:     new_hash TEXT NOT NULL,\n97:     linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n98:     decision_meta TEXT NOT NULL DEFAULT '{}',\n99:     actor TEXT NOT NULL,\n100:     session_id TEXT\n101:   )\n102: `;\n103: \n104: const LEDGER_INDEX_SQL = `\n105:   CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n106:   CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n107:   CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n108:   CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n109:   CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n110:     CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n111:     mutation_type,\n112:     timestamp\n113:   )\n114: `;\n115: \n116: const LEDGER_TRIGGER_SQL = `\n117:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n118:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n119:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n120:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n121: `;\n122: \n123: /* ───────────────────────────────────────────────────────────────\n124:    3. INITIALIZATION\n125: ----------------------------------------------------------------*/\n126: \n127: function initLedger(db: Database.Database): void {\n128:   db.exec(LEDGER_SCHEMA_SQL);\n129:   db.exec(LEDGER_INDEX_SQL);\n130:   db.exec(LEDGER_TRIGGER_SQL);\n131: }\n132: \n133: /* ───────────────────────────────────────────────────────────────\n134:    4. HASH COMPUTATION\n135: ----------------------------------------------------------------*/\n136: \n137: function computeHash(content: string): string {\n138:   return createHash('sha256').update(content, 'utf8').digest('hex');\n139: }\n140: \n141: /* ───────────────────────────────────────────────────────────────\n142:    5. APPEND ENTRY\n143: ----------------------------------------------------------------*/\n144: \n145: function appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n146:   const linkedJson = JSON.stringify(entry.linked_memory_ids);\n147:   const metaJson = JSON.stringify(entry.decision_meta);\n148: \n149:   const stmt = db.prepare(`\n150:     INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n151:     VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n152:   `);\n153: \n154:   const result = stmt.run(\n155:     entry.mutation_type,\n156:     entry.reason,\n157:     entry.prior_hash,\n158:     entry.new_hash,\n159:     linkedJson,\n160:     metaJson,\n161:     entry.actor,\n162:     entry.session_id ?? null\n163:   );\n164: \n165:   const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n166: \n167:   const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n168:   return row;\n169: }\n170: \n171: /* ───────────────────────────────────────────────────────────────\n172:    6. QUERY ENTRIES\n173: ----------------------------------------------------------------*/\n174: \n175: function getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n176:   const conditions: string[] = [];\n177:   const params: Array<string | number> = [];\n178: \n179:   if (opts.mutation_type) {\n180:     conditions.push('mutation_type = ?');\n181:     params.push(opts.mutation_type);\n182:   }\n183:   if (opts.actor) {\n184:     conditions.push('actor = ?');\n185:     params.push(opts.actor);\n186:   }\n187:   if (opts.session_id) {\n188:     conditions.push('session_id = ?');\n189:     params.push(opts.session_id);\n190:   }\n191:   if (opts.since) {\n192:     conditions.push('timestamp >= ?');\n193:     params.push(opts.since);\n194:   }\n195:   if (opts.until) {\n196:     conditions.push('timestamp <= ?');\n197:     params.push(opts.until);\n198:   }\n199: \n200:   const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n201:   // String interpolation in LIMIT/OFFSET is safe here because both values\n202:   // Are coerced to non-negative integers via Math.floor + Math.max before use —\n203:   // Math.floor guarantees no decimal component, Math.max(1,…)/Math.max(0,…)\n204:   // Guarantees no negative value. No user-supplied string reaches the SQL directly.\n205:   const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n206:   // OFFSET without LIMIT is invalid SQLite syntax.\n207:   // When offset is set but limit is not, emit LIMIT -1 (all rows) before OFFSET.\n208:   const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n209:   const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n210: \n211:   // String interpolation constructs IN(?,?,?) placeholder list only —\n212:   // All user values are parameterized. Accepted exception per audit H-08.\n213:   const sql = `SELECT * FROM mutation_ledger ${where} ORDER BY id ASC ${effectiveLimit} ${offset}`;\n214:   return db.prepare(sql).all(...params) as MutationLedgerEntry[];\n215: }\n216: \n217: function getEntryCount(db: Database.Database): number {\n218:   const row = db.prepare('SELECT COUNT(*) as count FROM mutation_ledger').get() as { count: number };\n219:   return row.count;\n220: }\n\n(Showing lines 1-220 of 480. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: string; // JSON array\n  decision_meta: string;     // JSON object\n  actor: string;\n  session_id: string | null;\n}\n\ninterface AppendEntryInput {\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: number[];\n  decision_meta: Record<string, unknown>;\n  actor: string;\n  session_id?: string | null;\n}\n\ninterface GetEntriesOptions {\n  mutation_type?: MutationType;\n  actor?: string;\n  session_id?: string;\n  since?: string;    // ISO timestamp\n  until?: string;    // ISO timestamp\n  limit?: number;\n  offset?: number;\n}\n\ninterface DivergenceReconcilePolicy {\n  normalizedPath: string;\n  attemptsSoFar: number;\n  nextAttempt: number;\n  maxRetries: number;\n  shouldRetry: boolean;\n  exhausted: boolean;\n}\n\ninterface DivergenceEscalationPayload {\n  code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n  normalizedPath: string;\n  attempts: number;\n  maxRetries: number;\n  recommendation: 'manual_triage_required';\n  reason: string;\n  variants: string[];\n}\n\ninterface RecordDivergenceReconcileInput {\n  normalizedPath: string;\n  variants?: string[];\n  actor?: string;\n  session_id?: string | null;\n  maxRetries?: number;\n}\n\ninterface RecordDivergenceReconcileResult {\n  policy: DivergenceReconcilePolicy;\n  retryEntryId: number | null;\n  escalationEntryId: number | null;\n  escalation: DivergenceEscalationPayload | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. SCHEMA SQL\n----------------------------------------------------------------*/\n\nconst LEDGER_SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS mutation_ledger (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n    mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n    reason TEXT NOT NULL,\n    prior_hash TEXT,\n    new_hash TEXT NOT NULL,\n    linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n    decision_meta TEXT NOT NULL DEFAULT '{}',\n    actor TEXT NOT NULL,\n    session_id TEXT\n  )\n`;\n\nconst LEDGER_INDEX_SQL = `\n  CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n  CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n  CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n  CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n  CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n    CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n    mutation_type,\n    timestamp\n  )\n`;\n\nconst LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   3. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction initLedger(db: Database.Database): void {\n  db.exec(LEDGER_SCHEMA_SQL);\n  db.exec(LEDGER_INDEX_SQL);\n  db.exec(LEDGER_TRIGGER_SQL);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HASH COMPUTATION\n----------------------------------------------------------------*/\n\nfunction computeHash(content: string): string {\n  return createHash('sha256').update(content, 'utf8').digest('hex');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. APPEND ENTRY\n----------------------------------------------------------------*/\n\nfunction appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n  const linkedJson = JSON.stringify(entry.linked_memory_ids);\n  const metaJson = JSON.stringify(entry.decision_meta);\n\n  const stmt = db.prepare(`\n    INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const result = stmt.run(\n    entry.mutation_type,\n    entry.reason,\n    entry.prior_hash,\n    entry.new_hash,\n    linkedJson,\n    metaJson,\n    entry.actor,\n    entry.session_id ?? null\n  );\n\n  const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n\n  const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n  return row;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. QUERY ENTRIES\n----------------------------------------------------------------*/\n\nfunction getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n  const conditions: string[] = [];\n  const params: Array<string | number> = [];\n\n  if (opts.mutation_type) {\n    conditions.push('mutation_type = ?');\n    params.push(opts.mutation_type);\n  }\n  if (opts.actor) {\n    conditions.push('actor = ?');\n    params.push(opts.actor);\n  }\n  if (opts.session_id) {\n    conditions.push('session_id = ?');\n    params.push(opts.session_id);\n  }\n  if (opts.since) {\n    conditions.push('timestamp >= ?');\n    params.push(opts.since);\n  }\n  if (opts.until) {\n    conditions.push('timestamp <= ?');\n    params.push(opts.until);\n  }\n\n  const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n  // String interpolation in LIMIT/OFFSET is safe here because both values\n  // Are coerced to non-negative integers via Math.floor + Math.max before use —\n  // Math.floor guarantees no decimal component, Math.max(1,…)/Math.max(0,…)\n  // Guarantees no negative value. No user-supplied string reaches the SQL directly.\n  const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n  // OFFSET without LIMIT is invalid SQLite syntax.\n  // When offset is set but limit is not, emit LIMIT -1 (all rows) before OFFSET.\n  const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n  const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n\n  // String interpolation constructs IN(?,?,?) placeholder list only —\n  // All user values are parameterized. Accepted exception per audit H-08.\n  const sql = `SELECT * FROM mutation_ledger ${where} ORDER BY id ASC ${effectiveLimit} ${offset}`;\n  return db.prepare(sql).all(...params) as MutationLedgerEntry[];\n}\n\nfunction getEntryCount(db: Database.Database): number {\n  const row = db.prepare('SELECT COUNT(*) as count FROM mutation_ledger').get() as { count: number };\n  return row.count;\n}","lineStart":1,"lineEnd":220,"totalLines":480,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","time":{"start":1780738265543,"end":1780738265552}},"metadata":{"openai":{"itemId":"fc_0b189349cc923f4d016a23e8d95d4c819190f967286607b041"}},"id":"prt_e9c459184001TST4qA2dzVWame","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c456e1d001TBAIMzmDoEXsC5"}}
