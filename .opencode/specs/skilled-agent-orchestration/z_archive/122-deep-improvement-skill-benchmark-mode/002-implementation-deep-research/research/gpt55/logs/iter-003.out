    11	// hand-maintained copy.
    12	const { DEFAULT_PROFILES_DIR, fixturePathFor } = require('../lib/profile-resolve.cjs');
    13	
    14	function parseArgs(argv) {
    15	  const args = {};
    16	  for (let index = 0; index < argv.length; index += 1) {
    17	    const entry = argv[index];
    18	    if (!entry.startsWith('--')) continue;
    19	    const [key, ...rest] = entry.slice(2).split('=');
    20	    if (rest.length > 0) args[key] = rest.join('=');
    21	    else if (argv[index + 1] && !argv[index + 1].startsWith('--')) args[key] = argv[++index];
    22	    else args[key] = true;
    23	  }
    24	  return args;
    25	}
    26	
    27	function readJson(filePath) {
    28	  return JSON.parse(fs.readFileSync(filePath, 'utf8'));
    29	}
    30	
    31	function resolveInput(value, baseDir) {
    32	  if (path.isAbsolute(value)) return value;
    33	  const fromCwd = path.resolve(process.cwd(), value);
    34	  return fs.existsSync(fromCwd) ? fromCwd : path.resolve(baseDir, value);
    35	}
    36	
    37	// F017-P1-01 (017 review): the materializer is the FIRST writer in the wired
    38	// plan (loop-host runs materialize before run-benchmark) and writes
    39	// path.join(outputsDir, `${fixture.id}.md`) below. An unsanitized id like
    40	// '../escaped' or 'a/b' escapes outputsDir at materialization time. Apply the
    41	// SAME guard run-benchmark.cjs uses (SAFE_FIXTURE_ID + assertSafeFixtureId):
    42	// restrict ids to a basename charset and reject path separators / parent-dir
    43	// traversal before any path.join.
    44	const SAFE_FIXTURE_ID = /^[A-Za-z0-9._-]+$/;
    45	
    46	function assertSafeFixtureId(id) {
    47	  if (typeof id !== 'string' || id.length === 0 || !SAFE_FIXTURE_ID.test(id) || id === '.' || id === '..') {
    48	    throw new Error(`materialize: unsafe fixture id '${id}' (must match ${SAFE_FIXTURE_ID} and not be '.'/'..' or contain path separators)`);
    49	  }
    50	  return id;
    51	}
    52	
    53	function renderFixture(fixture) {
    54	  if (typeof fixture.markdown === 'string') {
    55	    return fixture.markdown.endsWith('\n') ? fixture.markdown : `${fixture.markdown}\n`;
    56	  }
    57	
    58	  const lines = [
    59	    `# ${fixture.title || fixture.id}`,
    60	    '',
    61	    fixture.description || '',
    62	    '',
    63	    '## Candidate',
    64	    '',
    65	    `candidateId: ${fixture.id}`,
    66	    '',
    67	    '## Evidence',
    68	    '',
    69	    ...(fixture.content || []),
    70	  ];
    71	  if ((fixture.requiredHeadings || []).some((heading) => /legal stop/i.test(heading))) {
    72	    lines.push('', '## Legal Stop', '', 'details.gateResults: present');
    73	  }
    74	  return `${lines.join('\n').replace(/\n{3,}/g, '\n\n')}\n`;
    75	}
