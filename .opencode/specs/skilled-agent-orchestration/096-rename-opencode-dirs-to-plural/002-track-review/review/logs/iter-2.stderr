./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:151:        ".opencode/skills/sk-deep-review/scripts/reduce-state.cjs:1128",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:152:        ".opencode/skills/sk-deep-research/references/state_format.md:15",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:153:        ".opencode/skills/sk-deep-review/references/loop_protocol.md:150",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:154:        ".opencode/skills/sk-deep-research/manual_testing_playbook/04--convergence-and-recovery/033-graph-aware-stop-gate.md:28",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:169:        ".opencode/skills/sk-deep-research/scripts/reduce-state.cjs:855",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:170:        ".opencode/skills/sk-deep-review/scripts/reduce-state.cjs:1128",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:171:        ".opencode/skills/sk-deep-research/references/state_format.md:15",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:172:        ".opencode/skills/sk-deep-review/references/loop_protocol.md:150",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:173:        ".opencode/skills/sk-deep-research/manual_testing_playbook/04--convergence-and-recovery/033-graph-aware-stop-gate.md:28",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:180:      "text": "Child-phase safety depends on never re-running `resolveArtifactRoot()` inside the convergence emitter. The shared helper allocates the next `{phaseSlug}-pt-{NN}` subfolder by counting existing packet directories each time it resolves a child phase, and both reducers currently call that helper internally. A convergence-time emitter that resolves again could therefore drift into a sibling packet on repeat runs. The safe contract is: resolve `{artifact_dir}` once in YAML init, carry that resolved path through `state_paths`, and have the emitter and extractor consume the fixed path directly. [SOURCE: .opencode/skills/system-spec-kit/shared/review-research-paths.cjs:18] [SOURCE: .opencode/skills/system-spec-kit/shared/review-research-paths.cjs:41] [SOURCE: .opencode/skills/system-spec-kit/shared/review-research-paths.cjs:77] [SOURCE: .opencode/skills/system-spec-kit/shared/review-research-paths.cjs:117] [SOURCE: .opencode/commands/spec_kit/assets/spec_kit_deep-research_auto.yaml:98] [SOURCE: .opencode/commands/spec_kit/assets/spec_kit_deep-review_auto.yaml:89] [SOURCE: .opencode/skills/sk-deep-research/scripts/reduce-state.cjs:823] [SOURCE: .opencode/skills/sk-deep-review/scripts/reduce-state.cjs:1141]",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:199:        ".opencode/skills/sk-deep-research/SKILL.md:287",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:200:        ".opencode/skills/sk-deep-review/SKILL.md:295",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:201:        ".opencode/skills/sk-deep-research/references/state_format.md:17",
