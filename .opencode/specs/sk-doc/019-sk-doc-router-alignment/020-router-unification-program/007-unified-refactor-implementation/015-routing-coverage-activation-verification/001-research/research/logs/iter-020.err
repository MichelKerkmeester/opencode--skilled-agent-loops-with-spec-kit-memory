   364	async function loadCanonicalRenderer() {
   365	  canonicalRendererPromise ??= import(new URL('../dist/mcp-server/compat/index.js', import.meta.url))
   366	    .then((compat) => (typeof compat.renderAdvisorBrief === 'function' ? compat.renderAdvisorBrief : renderAdvisorBrief))
   367	    .catch(() => renderAdvisorBrief);
   368	  return canonicalRendererPromise;
   369	}
   370	
   371	async function callAdvisorTool(name, args, workspaceRoot) {
   372	  const transport = new StdioClientTransport({
   373	    command: process.execPath,
   374	    args: [ADVISOR_LAUNCHER_PATH],
   375	    cwd: workspaceRoot,
   376	      env: createChildEnv(),
   377	    stderr: 'pipe',
   378	  });
   379	  transport.stderr?.on('data', () => {});
   380	  const client = new Client({ name: 'mk-skill-advisor-bridge', version: '0.1.0' });
   381	  try {
   382	    await withTimeout(client.connect(transport), ADVISOR_MCP_TIMEOUT_MS, 'mk_skill_advisor initialize');
   383	    return await withTimeout(
   384	      client.callTool({ name, arguments: args }),
   385	      ADVISOR_MCP_TIMEOUT_MS,
   386	      `mk_skill_advisor.${name}`,
   387	    );
   388	  } finally {
   389	    try {
   390	      await client.close();
   391	    } catch {
   392	      // Best-effort process cleanup; bridge callers still get fail-open output.
   393	    }
   394	  }
   395	}
   396	
   397	function parseAdvisorToolData(toolResponse) {
   398	  const first = Array.isArray(toolResponse?.content) ? toolResponse.content[0] : null;
   399	  if (typeof first?.text !== 'string') {
   400	    throw Object.assign(new Error('Advisor MCP response missing text content'), { code: 'ADVISOR_MCP_BAD_RESPONSE' });
   401	  }
   402	  const parsed = JSON.parse(first.text);
   403	  return parsed?.data ?? parsed;
   404	}
   405	
   406	// The dead `renderNativeBrief()` alternate renderer was removed
   407	// here. It was unreferenced (verified via grep across mcp_server) and could
   408	// drift from the shared `renderAdvisorBrief()` formatter. Bridge output now
   409	// flows exclusively through `renderAdvisorBrief()` loaded via
   410	// `loadNativeAdvisorModules()`. Helpers `formatScore` and `sanitizeLabel`
   411	// stay because they are still used by `buildNativeBrief` and `buildLegacyBrief`.
   412	
   413	async function loadNativeAdvisorModules() {
   414	  // Primary native path: import the compiled compat module in-process. This is the
   415	  // canonical native surface (status handler, recommend handler, daemon probe, brief)
   416	  // and its return shapes already match this bridge's consumers — readAdvisorStatus
   417	  // returns the status DATA object (probeNativeAdvisor reads .freshness/.generation),
   418	  // handleAdvisorRecommend returns the MCP `{content:[{text}]}` envelope
   419	  // (buildNativeBrief parses content[0].text), and probeAdvisorDaemon returns the
   420	  // probe result directly. Importing compat avoids the launcher/MCP stdio handshake,
   421	  // which fails open to the python route when a stale launcher lease has no IPC socket
   422	  // (LEASE_HELD_BY... no-bridge-socket). The launcher subprocess remains a fallback for
   423	  // callers without a colocated dist build.
   424	  try {
   425	    const compat = await import(new URL('../dist/mcp-server/compat/index.js', import.meta.url));
   426	    if (
   427	      typeof compat.readAdvisorStatus === 'function'
   428	      && typeof compat.handleAdvisorRecommend === 'function'
   429	    ) {
   430	      return {
   431	        readAdvisorStatus: (args) => compat.readAdvisorStatus(args),
   432	        handleAdvisorRecommend: (args) => compat.handleAdvisorRecommend(args),
   433	        probeAdvisorDaemon: typeof compat.probeAdvisorDaemon === 'function'
   434	          ? (args) => compat.probeAdvisorDaemon(args)
   435	          : null,
   436	        buildSkillAdvisorBrief: typeof compat.buildSkillAdvisorBrief === 'function'
   437	          ? compat.buildSkillAdvisorBrief
   438	          : null,
   439	        renderAdvisorBrief: typeof compat.renderAdvisorBrief === 'function'
   440	          ? compat.renderAdvisorBrief
   441	          : renderAdvisorBrief,
   442	      };
   443	    }
   444	  } catch {
   445	    // Compat import unavailable (e.g. dist not built for a non-colocated caller).
   446	    // Fall through to the launcher/MCP-subprocess fallback below.
   447	  }
   448	  return {
   449	    readAdvisorStatus: async (args) => parseAdvisorToolData(await callAdvisorTool('advisor_status', args, args.workspaceRoot)),
   450	    handleAdvisorRecommend: (args) => callAdvisorTool('advisor_recommend', args, args.workspaceRoot),
   451	    probeAdvisorDaemon: null,
   452	    buildSkillAdvisorBrief: null,
   453	    renderAdvisorBrief,
   454	  };
   455	}
   744	async function buildCliBrief(input, dependencies = {}) {
   745	  const env = dependencies.env ?? process.env;
   746	  const timeoutMs = resolveCliTimeoutMs(env);
   747	  const probe = await probeCliWarmDaemon(env, timeoutMs);
   748	  if (!probe.available) {
   749	    return cliFallbackResponse(input, `CLI_RETRYABLE_UNAVAILABLE:${probe.reason ?? 'warm-daemon-unavailable'}`, false);
   750	  }
   751	
   752	  const cli = await runCliRecommend(input, env, timeoutMs);
   753	  if (cli.timedOut) {
   754	    return cliFallbackResponse(input, 'CLI_RETRYABLE_UNAVAILABLE:timeout', true);
   755	  }
   756	  if (cli.error) {
   757	    return cliFallbackResponse(input, `CLI_RETRYABLE_UNAVAILABLE:${cli.error}`, true);
   758	  }
   759	  if (cli.exitCode !== 0 || cli.signal !== null) {
   760	    const staleDist = classifyCliStaleDist(cli.exitCode, cli.stderr ?? '');
   761	    if (staleDist) {
   762	      return cliFallbackResponse(input, 'DIST_STALE_REBUILD_REQUIRED', true, staleDist);
   763	    }
   764	    return cliFallbackResponse(
   765	      input,
   766	      cli.exitCode === ADVISOR_CLI_RETRYABLE_EXIT ? 'CLI_RETRYABLE_EXIT_75' : `CLI_EXIT_${cli.exitCode ?? 'SIGNAL'}`,
   767	      true,
   768	    );
   769	  }
   770	
   771	  let parsed;
   772	  try {
   773	    parsed = JSON.parse(cli.stdout || '{}');
   774	  } catch {
   775	    return cliFallbackResponse(input, 'CLI_RETRYABLE_UNAVAILABLE:bad-json', true);
   776	  }
   777	  const data = parsed?.data && typeof parsed.data === 'object' ? parsed.data : null;
   778	  if (!data) {
   779	    return cliFallbackResponse(input, 'CLI_RETRYABLE_UNAVAILABLE:bad-response', true);
   780	  }
   781	
   782	  const maxTokens = positiveInt(input.maxTokens, 80);
   783	  const effectiveThresholds = {
   784	    confidenceThreshold: threshold(input.thresholdConfidence),
   785	    uncertaintyThreshold: DEFAULT_UNCERTAINTY_THRESHOLD,
   786	    confidenceOnly: false,
   787	  };
   788	  const recommendations = cliRecommendations(data, effectiveThresholds);
   789	  const top = recommendations[0] ?? null;
   790	  const renderedTokenCap = data.ambiguous === true ? 120 : maxTokens;
   791	  const freshness = data.freshness === 'live' || data.freshness === 'stale'
   792	    ? data.freshness
   793	    : 'unavailable';
   794	  if (freshness === 'unavailable') {
   795	    return cliFallbackResponse(input, 'CLI_RETRYABLE_UNAVAILABLE:freshness', true);
   796	  }
   797	  const renderBrief = await loadCanonicalRenderer();
   798	  const rendered = renderBrief({
   799	    status: recommendations.length > 0 ? 'ok' : 'skipped',
   800	    freshness,
   801	    recommendations,
   802	    ambiguous: data.ambiguous === true,
   803	    metrics: { tokenCap: renderedTokenCap },
   804	    sharedPayload: {
   805	      metadata: {
   806	        skillLabel: top?.skill ?? null,
   807	      },
   808	    },
   809	  }, {
   810	    tokenCap: renderedTokenCap,
   811	    thresholdConfig: effectiveThresholds,
   812	  });
   813	
   814	  const safeStatus = sanitizeLabel(top?.status);
   815	  const redirectTo = sanitizeLabel(top?.redirectTo);
   816	  const redirectFrom = Array.isArray(top?.redirectFrom)
   817	    ? top.redirectFrom.map(sanitizeLabel).filter(Boolean)
   818	    : [];
   819	  return response({
   820	    brief: rendered,
   821	    status: rendered ? 'ok' : 'skipped',
   822	    metadata: {
   823	      route: 'cli',
   824	      workspaceRoot: input.workspaceRoot,
   825	      effectiveThresholds,
   826	      freshness,
   827	      cacheHit: Boolean(data.cache?.hit),
   828	      recommendationCount: recommendations.length,
   829	      tokenCap: renderedTokenCap,
   830	      skillLabel: top?.skill ?? null,
   831	      status: safeStatus,
   832	      redirectTo,
   833	      redirectFrom,
   834	      retryable: false,
   835	      exitCode: 0,
   836	      subprocessInvoked: true,
   837	    },
   838	  });
   839	}
   840	

