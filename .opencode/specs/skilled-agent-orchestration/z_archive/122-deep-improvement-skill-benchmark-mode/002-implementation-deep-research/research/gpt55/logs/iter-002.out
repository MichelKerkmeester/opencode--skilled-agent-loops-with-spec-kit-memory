   497	      const topRec = ranked.find((recommendation) => recommendation.passes_threshold) ?? null;
   498	      if (topRec && (topRec.skill === 'sk-code' || topRec.skill === 'system-skill-advisor')) {
   499	        const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;
   500	        const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;
