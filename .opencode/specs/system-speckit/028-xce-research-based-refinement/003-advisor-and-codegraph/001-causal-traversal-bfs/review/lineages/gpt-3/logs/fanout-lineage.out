{"type":"tool_use","timestamp":1781150579290,"sessionID":"ses_14b284513ffeIITXJTJTMH97Er","part":{"type":"tool","tool":"read","callID":"call_FLsNPIu4hkpEVuW5eNqenkDh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts</path>\n<type>file</type>\n<content>\n1: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n2: // MODULE: BFS Traversal\n3: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n4: \n5: import type Database from 'better-sqlite3';\n6: \n7: type TraversalNode = number | string;\n8: \n9: const SQLITE_BINDING_CHUNK_SIZE = 900;\n10: \n11: /** Edge returned by a weighted graph reader. */\n12: export interface WeightedTraversalEdge<TNode extends TraversalNode> {\n13:   readonly from: TNode;\n14:   readonly to: TNode;\n15:   readonly weight: number;\n16:   readonly strength?: number;\n17: }\n18: \n19: /** Aggregated weighted walk output for one reached node. */\n20: export interface WeightedWalkResult<TNode extends TraversalNode> {\n21:   readonly nodeId: TNode;\n22:   readonly minHop: number;\n23:   readonly maxWalkScore: number;\n24: }\n25: \n26: /** Options for hop-capped weighted graph traversal. */\n27: export interface WeightedWalkOptions<TNode extends TraversalNode> {\n28:   readonly seeds: readonly TNode[];\n29:   readonly maxHops: number;\n30:   readonly readEdges: (nodeIds: readonly TNode[]) => readonly WeightedTraversalEdge<TNode>[];\n31: }\n32: \n33: /** Edge returned by a directed graph reader. */\n34: export interface DirectedTraversalEdge<TNode extends TraversalNode> {\n35:   readonly from: TNode;\n36:   readonly to: TNode;\n37: }\n38: \n39: /** Options for directed reachability traversal. */\n40: export interface DirectedReachabilityOptions<TNode extends TraversalNode> {\n41:   readonly roots: readonly TNode[];\n42:   readonly readEdges: (nodeIds: readonly TNode[]) => readonly DirectedTraversalEdge<TNode>[];\n43: }\n44: \n45: interface WeightedWalkState<TNode extends TraversalNode> {\n46:   readonly origin: TNode;\n47:   readonly nodeId: TNode;\n48:   readonly hop: number;\n49:   readonly walkScore: number;\n50: }\n51: \n52: interface CausalEdgeRow {\n53:   readonly source_id: string;\n54:   readonly target_id: string;\n55:   readonly relation: string;\n56:   readonly strength: number | null;\n57: }\n58: \n59: interface DependencyEdgeRow {\n60:   readonly parent_path: string;\n61:   readonly child_path: string;\n62: }\n63: \n64: function uniqueNodes<TNode extends TraversalNode>(nodeIds: readonly TNode[]): TNode[] {\n65:   return Array.from(new Set(nodeIds));\n66: }\n67: \n68: function sameNode<TNode extends TraversalNode>(left: TNode, right: TNode): boolean {\n69:   return left === right;\n70: }\n71: \n72: function stateKey<TNode extends TraversalNode>(state: WeightedWalkState<TNode>): string {\n73:   return `${String(state.origin)}\\u0000${String(state.nodeId)}\\u0000${state.hop}\\u0000${state.walkScore}`;\n74: }\n75: \n76: function groupWeightedEdges<TNode extends TraversalNode>(\n77:   edges: readonly WeightedTraversalEdge<TNode>[],\n78: ): Map<TNode, WeightedTraversalEdge<TNode>[]> {\n79:   const grouped = new Map<TNode, WeightedTraversalEdge<TNode>[]>();\n80:   for (const edge of edges) {\n81:     const group = grouped.get(edge.from) ?? [];\n82:     group.push(edge);\n83:     grouped.set(edge.from, group);\n84:   }\n85:   return grouped;\n86: }\n87: \n88: function placeholders(count: number): string {\n89:   return Array.from({ length: count }, () => '?').join(', ');\n90: }\n91: \n92: function chunks<T>(items: readonly T[], size: number): T[][] {\n93:   const result: T[][] = [];\n94:   for (let index = 0; index < items.length; index += size) {\n95:     result.push(items.slice(index, index + size));\n96:   }\n97:   return result;\n98: }\n99: \n100: function relationWeight(relation: string, relationWeights: Readonly<Record<string, number>>): number {\n101:   const multiplier = relationWeights[relation] ?? 1.0;\n102:   return Number.isFinite(multiplier) ? multiplier : 1.0;\n103: }\n104: \n105: function edgeStrength(value: number | null): number {\n106:   return typeof value === 'number' && Number.isFinite(value) ? value : 1.0;\n107: }\n108: \n109: function nextWalkScore<TNode extends TraversalNode>(\n110:   state: WeightedWalkState<TNode>,\n111:   edge: WeightedTraversalEdge<TNode>,\n112: ): number {\n113:   const weighted = state.walkScore * edge.weight;\n114:   return edge.strength === undefined ? weighted : weighted * edge.strength;\n115: }\n116: \n117: /**\n118:  * Run a hop-capped weighted walk and aggregate by reached node.\n119:  * The aggregation intentionally keeps min hop and max score independent.\n120:  */\n121: export function collectWeightedWalk<TNode extends TraversalNode>(\n122:   options: WeightedWalkOptions<TNode>,\n123: ): Map<TNode, WeightedWalkResult<TNode>> {\n124:   const maxHops = Math.max(0, Math.trunc(options.maxHops));\n125:   const seeds = uniqueNodes(options.seeds);\n126:   const seedSet = new Set(seeds);\n127:   const results = new Map<TNode, WeightedWalkResult<TNode>>();\n128:   if (seeds.length === 0 || maxHops === 0) {\n129:     return results;\n130:   }\n131: \n132:   let frontier: WeightedWalkState<TNode>[] = seeds.map((seed) => ({\n133:     origin: seed,\n134:     nodeId: seed,\n135:     hop: 0,\n136:     walkScore: 1.0,\n137:   }));\n138:   const seenStates = new Set<string>();\n139: \n140:   while (frontier.length > 0) {\n141:     const expandable = frontier.filter((state) => state.hop < maxHops);\n142:     if (expandable.length === 0) break;\n143: \n144:     const nodeIds = uniqueNodes(expandable.map((state) => state.nodeId));\n145:     const edgesByFrom = groupWeightedEdges(options.readEdges(nodeIds));\n146:     const nextFrontier: WeightedWalkState<TNode>[] = [];\n147: \n148:     for (const state of expandable) {\n149:       const edges = edgesByFrom.get(state.nodeId) ?? [];\n150:       for (const edge of edges) {\n151:         if (state.hop > 0 && sameNode(edge.to, state.origin)) {\n152:           continue;\n153:         }\n154: \n155:         const nextState: WeightedWalkState<TNode> = {\n156:           origin: state.origin,\n157:           nodeId: edge.to,\n158:           hop: state.hop + 1,\n159:           walkScore: nextWalkScore(state, edge),\n160:         };\n161:         const key = stateKey(nextState);\n162:         if (seenStates.has(key)) {\n163:           continue;\n164:         }\n165:         seenStates.add(key);\n166:         nextFrontier.push(nextState);\n167: \n168:         if (seedSet.has(nextState.nodeId)) {\n169:           continue;\n170:         }\n171: \n172:         const current = results.get(nextState.nodeId);\n173:         if (!current) {\n174:           results.set(nextState.nodeId, {\n175:             nodeId: nextState.nodeId,\n176:             minHop: nextState.hop,\n177:             maxWalkScore: nextState.walkScore,\n178:           });\n179:         } else {\n180:           results.set(nextState.nodeId, {\n181:             nodeId: nextState.nodeId,\n182:             minHop: Math.min(current.minHop, nextState.hop),\n183:             maxWalkScore: Math.max(current.maxWalkScore, nextState.walkScore),\n184:           });\n185:         }\n186:       }\n187:     }\n188: \n189:     frontier = nextFrontier;\n190:   }\n191: \n192:   return results;\n193: }\n194: \n195: /** Collect all nodes reachable from the given roots through directed edges. */\n196: export function collectDirectedReachability<TNode extends TraversalNode>(\n197:   options: DirectedReachabilityOptions<TNode>,\n198: ): TNode[] {\n199:   const roots = uniqueNodes(options.roots);\n200:   if (roots.length === 0) {\n201:     return [];\n202:   }\n203: \n204:   const rootSet = new Set(roots);\n205:   const visited = new Set<TNode>();\n206:   const reached: TNode[] = [];\n207:   let frontier = roots;\n208: \n209:   while (frontier.length > 0) {\n210:     const nextFrontier: TNode[] = [];\n211:     const edges = options.readEdges(frontier);\n212: \n213:     for (const edge of edges) {\n214:       if (visited.has(edge.to)) {\n215:         continue;\n216:       }\n217:       visited.add(edge.to);\n218:       if (!rootSet.has(edge.to)) {\n219:         reached.push(edge.to);\n220:       }\n221:       nextFrontier.push(edge.to);\n222:     }\n223: \n224:     frontier = uniqueNodes(nextFrontier);\n225:   }\n226: \n227:   return reached;\n228: }\n229: \n230: /** Read causal edges as an undirected, weighted adjacency view without OR joins. */\n231: export function readCausalNeighborEdges(\n232:   database: Database.Database,\n233:   nodeIds: readonly number[],\n234:   relationWeights: Readonly<Record<string, number>>,\n235: ): WeightedTraversalEdge<number>[] {\n236:   const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n237:   const edges: WeightedTraversalEdge<number>[] = [];\n238:   if (nodes.length === 0) {\n239:     return edges;\n240:   }\n241: \n242:   for (const nodeChunk of chunks(nodes.map((nodeId) => String(nodeId)), SQLITE_BINDING_CHUNK_SIZE)) {\n243:     const chunkPlaceholders = placeholders(nodeChunk.length);\n244:     const outgoingRows = database.prepare(`\n245:       SELECT source_id, target_id, relation, strength\n246:       FROM causal_edges\n247:       WHERE source_id IN (${chunkPlaceholders})\n248:     `).all(...nodeChunk) as CausalEdgeRow[];\n249:     const incomingRows = database.prepare(`\n250:       SELECT source_id, target_id, relation, strength\n251:       FROM causal_edges\n252:       WHERE target_id IN (${chunkPlaceholders})\n253:     `).all(...nodeChunk) as CausalEdgeRow[];\n254: \n255:     for (const row of outgoingRows) {\n256:       const from = Number.parseInt(row.source_id, 10);\n257:       const to = Number.parseInt(row.target_id, 10);\n258:       if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n259:       edges.push({\n260:         from,\n261:         to,\n262:         weight: relationWeight(row.relation, relationWeights),\n263:         strength: edgeStrength(row.strength),\n264:       });\n265:     }\n266:     for (const row of incomingRows) {\n267:       const from = Number.parseInt(row.target_id, 10);\n268:       const to = Number.parseInt(row.source_id, 10);\n269:       if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n270:       edges.push({\n271:         from,\n272:         to,\n273:         weight: relationWeight(row.relation, relationWeights),\n274:         strength: edgeStrength(row.strength),\n275:       });\n276:     }\n277:   }\n278: \n279:   return edges;\n280: }\n281: \n282: /** Traverse causal edges with the production weighted-walk reader. */\n283: export function collectCausalWeightedNeighbors(\n284:   database: Database.Database,\n285:   seeds: readonly number[],\n286:   maxHops: number,\n287:   relationWeights: Readonly<Record<string, number>>,\n288: ): Map<number, WeightedWalkResult<number>> {\n289:   return collectWeightedWalk({\n290:     seeds,\n291:     maxHops,\n292:     readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n293:   });\n294: }\n295: \n296: /** Read memo dependency edges in parent-to-child direction. */\n297: export function readDependencyChildren(\n298:   database: Database.Database,\n299:   parentPaths: readonly string[],\n300: ): DirectedTraversalEdge<string>[] {\n301:   const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n302:   const edges: DirectedTraversalEdge<string>[] = [];\n303:   if (parents.length === 0) {\n304:     return edges;\n305:   }\n306: \n307:   for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n308:     const chunkPlaceholders = placeholders(parentChunk.length);\n309:     const rows = database.prepare(`\n310:       SELECT parent_path, child_path\n311:       FROM dependency_edges\n312:       WHERE parent_path IN (${chunkPlaceholders})\n313:     `).all(...parentChunk) as DependencyEdgeRow[];\n314: \n315:     for (const row of rows) {\n316:       edges.push({ from: row.parent_path, to: row.child_path });\n317:     }\n318:   }\n319: \n320:   return edges;\n321: }\n322: \n323: /** Traverse memo dependency edges from parent paths to all transitive children. */\n324: export function collectDependencyReachability(\n325:   database: Database.Database,\n326:   roots: readonly string[],\n327: ): string[] {\n328:   return collectDirectedReachability({\n329:     roots,\n330:     readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n331:   });\n332: }\n\n(End of file - total 332 lines)\n</content>","metadata":{"preview":"// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// MODULE: BFS Traversal\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\nimport type Database from 'better-sqlite3';\n\ntype TraversalNode = number | string;\n\nconst SQLITE_BINDING_CHUNK_SIZE = 900;\n\n/** Edge returned by a weighted graph reader. */\nexport interface WeightedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n  readonly weight: number;\n  readonly strength?: number;\n}\n\n/** Aggregated weighted walk output for one reached node. */\nexport interface WeightedWalkResult<TNode extends TraversalNode> {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","text":"// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// MODULE: BFS Traversal\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\nimport type Database from 'better-sqlite3';\n\ntype TraversalNode = number | string;\n\nconst SQLITE_BINDING_CHUNK_SIZE = 900;\n\n/** Edge returned by a weighted graph reader. */\nexport interface WeightedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n  readonly weight: number;\n  readonly strength?: number;\n}\n\n/** Aggregated weighted walk output for one reached node. */\nexport interface WeightedWalkResult<TNode extends TraversalNode> {\n  readonly nodeId: TNode;\n  readonly minHop: number;\n  readonly maxWalkScore: number;\n}\n\n/** Options for hop-capped weighted graph traversal. */\nexport interface WeightedWalkOptions<TNode extends TraversalNode> {\n  readonly seeds: readonly TNode[];\n  readonly maxHops: number;\n  readonly readEdges: (nodeIds: readonly TNode[]) => readonly WeightedTraversalEdge<TNode>[];\n}\n\n/** Edge returned by a directed graph reader. */\nexport interface DirectedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n}\n\n/** Options for directed reachability traversal. */\nexport interface DirectedReachabilityOptions<TNode extends TraversalNode> {\n  readonly roots: readonly TNode[];\n  readonly readEdges: (nodeIds: readonly TNode[]) => readonly DirectedTraversalEdge<TNode>[];\n}\n\ninterface WeightedWalkState<TNode extends TraversalNode> {\n  readonly origin: TNode;\n  readonly nodeId: TNode;\n  readonly hop: number;\n  readonly walkScore: number;\n}\n\ninterface CausalEdgeRow {\n  readonly source_id: string;\n  readonly target_id: string;\n  readonly relation: string;\n  readonly strength: number | null;\n}\n\ninterface DependencyEdgeRow {\n  readonly parent_path: string;\n  readonly child_path: string;\n}\n\nfunction uniqueNodes<TNode extends TraversalNode>(nodeIds: readonly TNode[]): TNode[] {\n  return Array.from(new Set(nodeIds));\n}\n\nfunction sameNode<TNode extends TraversalNode>(left: TNode, right: TNode): boolean {\n  return left === right;\n}\n\nfunction stateKey<TNode extends TraversalNode>(state: WeightedWalkState<TNode>): string {\n  return `${String(state.origin)}\\u0000${String(state.nodeId)}\\u0000${state.hop}\\u0000${state.walkScore}`;\n}\n\nfunction groupWeightedEdges<TNode extends TraversalNode>(\n  edges: readonly WeightedTraversalEdge<TNode>[],\n): Map<TNode, WeightedTraversalEdge<TNode>[]> {\n  const grouped = new Map<TNode, WeightedTraversalEdge<TNode>[]>();\n  for (const edge of edges) {\n    const group = grouped.get(edge.from) ?? [];\n    group.push(edge);\n    grouped.set(edge.from, group);\n  }\n  return grouped;\n}\n\nfunction placeholders(count: number): string {\n  return Array.from({ length: count }, () => '?').join(', ');\n}\n\nfunction chunks<T>(items: readonly T[], size: number): T[][] {\n  const result: T[][] = [];\n  for (let index = 0; index < items.length; index += size) {\n    result.push(items.slice(index, index + size));\n  }\n  return result;\n}\n\nfunction relationWeight(relation: string, relationWeights: Readonly<Record<string, number>>): number {\n  const multiplier = relationWeights[relation] ?? 1.0;\n  return Number.isFinite(multiplier) ? multiplier : 1.0;\n}\n\nfunction edgeStrength(value: number | null): number {\n  return typeof value === 'number' && Number.isFinite(value) ? value : 1.0;\n}\n\nfunction nextWalkScore<TNode extends TraversalNode>(\n  state: WeightedWalkState<TNode>,\n  edge: WeightedTraversalEdge<TNode>,\n): number {\n  const weighted = state.walkScore * edge.weight;\n  return edge.strength === undefined ? weighted : weighted * edge.strength;\n}\n\n/**\n * Run a hop-capped weighted walk and aggregate by reached node.\n * The aggregation intentionally keeps min hop and max score independent.\n */\nexport function collectWeightedWalk<TNode extends TraversalNode>(\n  options: WeightedWalkOptions<TNode>,\n): Map<TNode, WeightedWalkResult<TNode>> {\n  const maxHops = Math.max(0, Math.trunc(options.maxHops));\n  const seeds = uniqueNodes(options.seeds);\n  const seedSet = new Set(seeds);\n  const results = new Map<TNode, WeightedWalkResult<TNode>>();\n  if (seeds.length === 0 || maxHops === 0) {\n    return results;\n  }\n\n  let frontier: WeightedWalkState<TNode>[] = seeds.map((seed) => ({\n    origin: seed,\n    nodeId: seed,\n    hop: 0,\n    walkScore: 1.0,\n  }));\n  const seenStates = new Set<string>();\n\n  while (frontier.length > 0) {\n    const expandable = frontier.filter((state) => state.hop < maxHops);\n    if (expandable.length === 0) break;\n\n    const nodeIds = uniqueNodes(expandable.map((state) => state.nodeId));\n    const edgesByFrom = groupWeightedEdges(options.readEdges(nodeIds));\n    const nextFrontier: WeightedWalkState<TNode>[] = [];\n\n    for (const state of expandable) {\n      const edges = edgesByFrom.get(state.nodeId) ?? [];\n      for (const edge of edges) {\n        if (state.hop > 0 && sameNode(edge.to, state.origin)) {\n          continue;\n        }\n\n        const nextState: WeightedWalkState<TNode> = {\n          origin: state.origin,\n          nodeId: edge.to,\n          hop: state.hop + 1,\n          walkScore: nextWalkScore(state, edge),\n        };\n        const key = stateKey(nextState);\n        if (seenStates.has(key)) {\n          continue;\n        }\n        seenStates.add(key);\n        nextFrontier.push(nextState);\n\n        if (seedSet.has(nextState.nodeId)) {\n          continue;\n        }\n\n        const current = results.get(nextState.nodeId);\n        if (!current) {\n          results.set(nextState.nodeId, {\n            nodeId: nextState.nodeId,\n            minHop: nextState.hop,\n            maxWalkScore: nextState.walkScore,\n          });\n        } else {\n          results.set(nextState.nodeId, {\n            nodeId: nextState.nodeId,\n            minHop: Math.min(current.minHop, nextState.hop),\n            maxWalkScore: Math.max(current.maxWalkScore, nextState.walkScore),\n          });\n        }\n      }\n    }\n\n    frontier = nextFrontier;\n  }\n\n  return results;\n}\n\n/** Collect all nodes reachable from the given roots through directed edges. */\nexport function collectDirectedReachability<TNode extends TraversalNode>(\n  options: DirectedReachabilityOptions<TNode>,\n): TNode[] {\n  const roots = uniqueNodes(options.roots);\n  if (roots.length === 0) {\n    return [];\n  }\n\n  const rootSet = new Set(roots);\n  const visited = new Set<TNode>();\n  const reached: TNode[] = [];\n  let frontier = roots;\n\n  while (frontier.length > 0) {\n    const nextFrontier: TNode[] = [];\n    const edges = options.readEdges(frontier);\n\n    for (const edge of edges) {\n      if (visited.has(edge.to)) {\n        continue;\n      }\n      visited.add(edge.to);\n      if (!rootSet.has(edge.to)) {\n        reached.push(edge.to);\n      }\n      nextFrontier.push(edge.to);\n    }\n\n    frontier = uniqueNodes(nextFrontier);\n  }\n\n  return reached;\n}\n\n/** Read causal edges as an undirected, weighted adjacency view without OR joins. */\nexport function readCausalNeighborEdges(\n  database: Database.Database,\n  nodeIds: readonly number[],\n  relationWeights: Readonly<Record<string, number>>,\n): WeightedTraversalEdge<number>[] {\n  const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n  const edges: WeightedTraversalEdge<number>[] = [];\n  if (nodes.length === 0) {\n    return edges;\n  }\n\n  for (const nodeChunk of chunks(nodes.map((nodeId) => String(nodeId)), SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(nodeChunk.length);\n    const outgoingRows = database.prepare(`\n      SELECT source_id, target_id, relation, strength\n      FROM causal_edges\n      WHERE source_id IN (${chunkPlaceholders})\n    `).all(...nodeChunk) as CausalEdgeRow[];\n    const incomingRows = database.prepare(`\n      SELECT source_id, target_id, relation, strength\n      FROM causal_edges\n      WHERE target_id IN (${chunkPlaceholders})\n    `).all(...nodeChunk) as CausalEdgeRow[];\n\n    for (const row of outgoingRows) {\n      const from = Number.parseInt(row.source_id, 10);\n      const to = Number.parseInt(row.target_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n    for (const row of incomingRows) {\n      const from = Number.parseInt(row.target_id, 10);\n      const to = Number.parseInt(row.source_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse causal edges with the production weighted-walk reader. */\nexport function collectCausalWeightedNeighbors(\n  database: Database.Database,\n  seeds: readonly number[],\n  maxHops: number,\n  relationWeights: Readonly<Record<string, number>>,\n): Map<number, WeightedWalkResult<number>> {\n  return collectWeightedWalk({\n    seeds,\n    maxHops,\n    readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n  });\n}\n\n/** Read memo dependency edges in parent-to-child direction. */\nexport function readDependencyChildren(\n  database: Database.Database,\n  parentPaths: readonly string[],\n): DirectedTraversalEdge<string>[] {\n  const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n  const edges: DirectedTraversalEdge<string>[] = [];\n  if (parents.length === 0) {\n    return edges;\n  }\n\n  for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(parentChunk.length);\n    const rows = database.prepare(`\n      SELECT parent_path, child_path\n      FROM dependency_edges\n      WHERE parent_path IN (${chunkPlaceholders})\n    `).all(...parentChunk) as DependencyEdgeRow[];\n\n    for (const row of rows) {\n      edges.push({ from: row.parent_path, to: row.child_path });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse memo dependency edges from parent paths to all transitive children. */\nexport function collectDependencyReachability(\n  database: Database.Database,\n  roots: readonly string[],\n): string[] {\n  return collectDirectedReachability({\n    roots,\n    readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n  });\n}","lineStart":1,"lineEnd":332,"totalLines":332,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","time":{"start":1781150579282,"end":1781150579288}},"metadata":{"openai":{"itemId":"fc_01d1432db783fd34016a2a33732cd88191bd1c8d8d91cd6eda"}},"id":"prt_eb4d8fa2b001kYM44uuymKqC7o","sessionID":"ses_14b284513ffeIITXJTJTMH97Er","messageID":"msg_eb4d8d1a0001NRTHdPmMSVF0HR"}}
{"type":"tool_use","timestamp":1781150579310,"sessionID":"ses_14b284513ffeIITXJTJTMH97Er","part":{"type":"tool","tool":"read","callID":"call_SGjXXq2VfDOV1Tq3w5f0RMyR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts</path>\n<type>file</type>\n<content>\n1: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n2: // MODULE: Causal Boost\n3: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n4: // Feature catalog: Causal neighbor boost and injection\n5: // Graph-traversal score boosting via causal edge relationships.\n6: // Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n7: // For results related to top seed results via weighted CTE.\n8: //\n9: // Sparse-First + Intent-Aware Traversal:\n10: // - Sparse-first policy ŌĆö density < 0.5 disables community\n11: //   detection and constrains traversal to typed 1-hop expansion only.\n12: // - Intent-aware edge traversal ŌĆö maps classified query intents\n13: //   to edge-type priority orderings; computes traversal score as:\n14: //   score = seedScore * edgePrior * hopDecay * freshness\n15: // Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\n16: import { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\n17: import { routeQueryConcepts } from './entity-linker.js';\n18: import { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n19: \n20: import type Database from 'better-sqlite3';\n21: \n22: /** Maximum graph traversal depth. Beyond 2 hops, signal degrades and queries become expensive. */\n23: const MAX_HOPS = 2;\n24: /** Per-hop boost cap. 0.05 keeps causal nudge subtle relative to semantic scores (~0.5ŌĆō1.0). */\n25: const MAX_BOOST_PER_HOP = 0.05;\n26: /** Combined causal + session boost ceiling to prevent runaway amplification. */\n27: const MAX_COMBINED_BOOST = 0.20;\n28: /** Top fraction of result set used as graph walk seed nodes. */\n29: const SEED_FRACTION = 0.25;\n30: /** Absolute cap on seed nodes regardless of result set size. */\n31: const MAX_SEED_RESULTS = 5;\n32: \n33: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n34: // SPARSE-FIRST POLICY CONSTANTS\n35: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n36: /** Graph density threshold below which community detection is disabled\n37:  * and traversal is constrained to typed 1-hop expansion only.\n38:  * Density = edgeCount / totalMemories (see edge-density.ts). */\n39: const SPARSE_DENSITY_THRESHOLD = 0.5;\n40: \n41: /** Traversal depth used in sparse mode (1-hop typed expansion). */\n42: const SPARSE_MAX_HOPS = 1;\n43: \n44: /** Default traversal depth for typed traversal helper policies. */\n45: const DEFAULT_TYPED_TRAVERSAL_DEPTH = SPARSE_MAX_HOPS;\n46: \n47: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n48: // INTENT-AWARE EDGE TRAVERSAL\n49: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n50: /** Per-hop decay factor applied to traversal score. 1-hop = 1.0, 2-hop = 0.5. */\n51: const HOP_DECAY_BASE = 1.0;\n52: \n53: /**\n54:  * Intent-to-edge-type priority ordering.\n55:  * Maps each query intent to an ordered list of edge relation types.\n56:  * Earlier entries in the list receive higher edge prior scores.\n57:  *\n58:  * Scores are normalized: first-listed relation = 1.0, second = 0.75, remaining = 0.5.\n59:  */\n60: const INTENT_EDGE_PRIORITY: Record<string, string[]> = {\n61:   fix_bug:        ['CORRECTION', 'DEPENDS_ON', 'supersedes', 'caused'],\n62:   add_feature:    ['EXTENDS', 'DEPENDS_ON', 'enabled', 'derived_from'],\n63:   find_decision:  ['PREFERENCE', 'CORRECTION', 'supersedes', 'contradicts'],\n64:   // Defaults for other intents ŌĆö use existing relation-weight ordering\n65:   understand:     ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n66:   find_spec:      ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n67:   refactor:       ['caused', 'derived_from', 'enabled', 'supports', 'supersedes', 'contradicts'],\n68:   security_audit: ['caused', 'contradicts', 'supersedes', 'enabled', 'supports', 'derived_from'],\n69: };\n70: \n71: /** Fallback priority list when intent is unrecognized. */\n72: const DEFAULT_EDGE_PRIORITY = ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'];\n73: \n74: /** Edge prior score tiers: 1st priority = 1.0, 2nd = 0.75, remaining = 0.5. */\n75: const EDGE_PRIOR_TIERS = [1.0, 0.75, 0.5];\n76: const DEFAULT_EDGE_PRIOR = 1.0;\n77: const FRESHNESS_DECAY_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;\n78: \n79: /**\n80:  * Relation-type weight multipliers for causal edge traversal.\n81:  * Applied during CTE accumulation so stronger relation types (supersedes)\n82:  * amplify the boost while weaker ones (contradicts) attenuate it.\n83:  *\n84:  * These multipliers serve a DIFFERENT purpose from RELATION_WEIGHTS in\n85:  * causal-edges.ts. causal-edges weights are applied during chain traversal\n86:  * scoring (getCausalChain), while these are applied during the causal-boost\n87:  * CTE walk (getNeighborBoosts) for search result amplification. The value\n88:  * ranges overlap but are tuned independently for their respective contexts:\n89:  *   - causal-edges: traversal strength propagation (range 0.8ŌĆō1.5)\n90:  *   - causal-boost: search result boost amplitude (range 0.8ŌĆō1.5)\n91:  */\n92: const RELATION_WEIGHT_MULTIPLIERS: Record<string, number> = {\n93:   supersedes: 1.5,\n94:   contradicts: 0.8,\n95:   caused: 1.0,\n96:   enabled: 1.0,\n97:   derived_from: 1.0,\n98:   supports: 1.0,\n99: };\n100: \n101: interface RankedSearchResult extends Record<string, unknown> {\n102:   id: number;\n103:   score?: number;\n104:   rrfScore?: number;\n105:   intentAdjustedScore?: number;\n106:   attentionScore?: number;\n107:   similarity?: number;\n108:   sessionBoost?: number;\n109:   baseScore?: number;\n110:   causalBoost?: number;\n111:   injectedByCausalBoost?: boolean;\n112: }\n113: \n114: interface CausalBoostMetadata {\n115:   enabled: boolean;\n116:   applied: boolean;\n117:   boostedCount: number;\n118:   injectedCount: number;\n119:   maxBoostApplied: number;\n120:   traversalDepth: number;\n121:   /** True when sparse-first policy was active (density < threshold) */\n122:   sparseModeActive?: boolean;\n123:   /** Intent used for edge traversal scoring (if typed traversal enabled) */\n124:   intentUsed?: string;\n125: }\n126: \n127: /** Options for applyCausalBoost ŌĆö extended with sparse-first parameters. */\n128: interface CausalBoostOptions {\n129:   /** Graph density (edgeCount / totalMemories). Used for sparse-first gate. */\n130:   graphDensity?: number;\n131:   /** Classified query intent. Used for intent-aware edge priority mapping. */\n132:   intent?: string;\n133:   /** Freshness factor [0,1] applied to traversal scoring. Defaults to 1.0. */\n134:   freshness?: number;\n135: }\n136: \n137: interface NeighborBoost {\n138:   boost: number;\n139:   hopCount: number;\n140: }\n141: \n142: let db: Database.Database | null = null;\n143: let graphTraversal: GraphTraversal | null = null;\n144: \n145: /**\n146:  * Check whether the causal boost feature flag is enabled.\n147:  * Default: ON (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n148:  * When enabled, causal graph traversal amplifies scores for results\n149:  * connected to top-ranked results via causal edges.\n150:  *\n151:  * Delegates to the canonical flag check in search-flags.ts.\n152:  */\n153: function isEnabled(): boolean {\n154:   return isCausalBoostEnabled();\n155: }\n156: \n157: /**\n158:  * Check whether the typed traversal feature flag is enabled.\n159:  * Default: ON (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n160:  * Activates sparse-first + intent-aware traversal.\n161:  */\n162: function isTypedTraversalEnabled(): boolean {\n163:   return _isTypedTraversalEnabled();\n164: }\n165: \n166: /** Store the database reference used by causal edge traversal queries. */\n167: function init(database: Database.Database): void {\n168:   db = database;\n169:   graphTraversal = new BetterSqliteGraphTraversal(database);\n170: }\n171: \n172: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n173: // SPARSE-FIRST POLICY\n174: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n175: \n176: /**\n177:  * Determine whether sparse mode should be active for this traversal pass.\n178:  * Sparse mode is active when:\n179:  *   - SPECKIT_TYPED_TRAVERSAL is enabled, AND\n180:  *   - graphDensity is a finite number below SPARSE_DENSITY_THRESHOLD (0.5)\n181:  *\n182:  * When sparse mode is active:\n183:  *   - Community detection is suppressed (caller must respect this)\n184:  *   - Traversal is constrained to SPARSE_MAX_HOPS (1)\n185:  */\n186: function isSparseMode(graphDensity: number | undefined): boolean {\n187:   if (!isTypedTraversalEnabled()) return false;\n188:   if (typeof graphDensity !== 'number' || !Number.isFinite(graphDensity)) return false;\n189:   return graphDensity < SPARSE_DENSITY_THRESHOLD;\n190: }\n191: \n192: interface SparseFirstTraversalPolicy {\n193:   sparseModeActive: boolean;\n194:   communityDetectionEnabled: boolean;\n195: }\n196: \n197: /**\n198:  * Resolve the sparse-first policy gate for callers that need a simple\n199:  * community-detection decision without running the full boost pipeline.\n200:  */\n201: function resolveSparseFirstTraversalPolicy(graphDensity: number | undefined): SparseFirstTraversalPolicy {\n202:   const sparseModeActive = isSparseMode(graphDensity);\n203:   return {\n204:     sparseModeActive,\n205:     communityDetectionEnabled: !sparseModeActive,\n206:   };\n207: }\n208: \n209: /**\n210:  * Resolve traversal depth for typed traversal helper callers.\n211:  * Typed traversal defaults to 1-hop and stays within the supported range.\n212:  * When the flag is off, preserve the legacy MAX_HOPS behavior.\n213:  */\n214: function resolveTraversalDepth(depth: number = DEFAULT_TYPED_TRAVERSAL_DEPTH): number {\n215:   if (!isTypedTraversalEnabled()) {\n216:     return MAX_HOPS;\n217:   }\n218: \n219:   if (!Number.isFinite(depth)) {\n220:     return DEFAULT_TYPED_TRAVERSAL_DEPTH;\n221:   }\n222: \n223:   return Math.max(DEFAULT_TYPED_TRAVERSAL_DEPTH, Math.min(MAX_HOPS, Math.trunc(depth)));\n224: }\n225: \n226: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n227: // INTENT-AWARE EDGE TRAVERSAL HELPERS\n228: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n229: \n230: /**\n231:  * Compute the edge prior score for a given relation type and intent.\n232:  * Returns a normalized score in [0.5, 1.0] based on priority position.\n233:  *\n234:  * Canonical relation names from causal-boost are lower-cased (e.g. 'supersedes').\n235:  * Intent priority lists may include upper-case semantic labels (e.g. 'CORRECTION').\n236:  * Matching is case-insensitive against both the label and any alias.\n237:  *\n238:  * Alias map: CORRECTION ŌåÆ supersedes | contradicts\n239:  *            DEPENDS_ON ŌåÆ caused | enabled | derived_from\n240:  *            EXTENDS    ŌåÆ enabled | derived_from\n241:  *            PREFERENCE ŌåÆ supports\n242:  */\n243: const EDGE_LABEL_ALIASES: Record<string, string[]> = {\n244:   CORRECTION:  ['supersedes', 'contradicts'],\n245:   DEPENDS_ON:  ['caused', 'enabled', 'derived_from'],\n246:   EXTENDS:     ['enabled', 'derived_from'],\n247:   PREFERENCE:  ['supports'],\n248: };\n249: \n250: function resolveEdgePrior(relation: string, intent: string): number {\n251:   if (!isTypedTraversalEnabled()) return 1.0;\n252: \n253:   const priority = INTENT_EDGE_PRIORITY[intent] ?? DEFAULT_EDGE_PRIORITY;\n254:   const relLower = relation.toLowerCase();\n255: \n256:   for (let i = 0; i < priority.length; i++) {\n257:     const entry = priority[i];\n258:     if (!entry) continue;\n259:     // Exact match (case-insensitive)\n260:     if (entry.toLowerCase() === relLower) {\n261:       return EDGE_PRIOR_TIERS[Math.min(i, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n262:     }\n263:     // Alias expansion: check if this priority label maps to the relation\n264:     const aliases = EDGE_LABEL_ALIASES[entry.toUpperCase()];\n265:     if (aliases && aliases.includes(relLower)) {\n266:       return EDGE_PRIOR_TIERS[Math.min(i, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n267:     }\n268:   }\n269: \n270:   // Relation not found in priority list ŌĆö assign minimum tier\n271:   return EDGE_PRIOR_TIERS[EDGE_PRIOR_TIERS.length - 1] ?? 0.5;\n272: }\n273: \n274: /**\n275:  * Compute hop decay factor. Formula: HOP_DECAY_BASE / hopDistance.\n276:  * 1-hop ŌåÆ 1.0, 2-hop ŌåÆ 0.5, etc. Capped at 1.0.\n277:  */\n278: function computeHopDecay(hopDistance: number): number {\n279:   if (!Number.isFinite(hopDistance) || hopDistance <= 0) return 0;\n280:   return Math.min(1.0, HOP_DECAY_BASE / hopDistance);\n281: }\n282: \n283: /**\n284:  * Compute the intent-aware traversal score.\n285:  * Formula: seedScore * edgePrior * hopDecay * freshness\n286:  *\n287:  * @param seedScore  - Base score of the seed node (0ŌĆō1)\n288:  * @param relation   - Edge relation type (e.g. 'supersedes', 'caused')\n289:  * @param hopDistance - Hop distance from seed (1 = direct neighbor)\n290:  * @param freshness  - Recency factor (0ŌĆō1, default 1.0)\n291:  * @param intent     - Classified query intent (default 'understand')\n292:  */\n293: function computeIntentTraversalScore(\n294:   seedScore: number,\n295:   relation: string,\n296:   hopDistance: number,\n297:   freshness: number,\n298:   intent: string\n299: ): number {\n300:   const edgePrior = resolveEdgePrior(relation, intent);\n301:   const hopDecay = computeHopDecay(hopDistance);\n302:   return seedScore * edgePrior * hopDecay * freshness;\n303: }\n304: \n305: function getIntentEdgePriorities(intent: string): string[] {\n306:   return (INTENT_EDGE_PRIORITY[intent] ?? []).slice(0, 2);\n307: }\n308: \n309: function computeIntentEdgePrior(intent: string, edgeType: string): number {\n310:   const priorities = getIntentEdgePriorities(intent);\n311:   if (priorities.length === 0) {\n312:     return DEFAULT_EDGE_PRIOR;\n313:   }\n314: \n315:   const normalizedEdgeType = edgeType.toUpperCase();\n316:   const directMatchIndex = priorities.findIndex(\n317:     (priority) => priority.toUpperCase() === normalizedEdgeType,\n318:   );\n319:   if (directMatchIndex >= 0) {\n320:     return EDGE_PRIOR_TIERS[Math.min(directMatchIndex, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n321:   }\n322: \n323:   return resolveEdgePrior(edgeType, intent);\n324: }\n325: \n326: function computeTraversalHopDecay(hopDistance: number): number {\n327:   return computeHopDecay(hopDistance);\n328: }\n329: \n330: function computeTraversalFreshnessFactor(\n331:   updatedAt: Date | string,\n332:   now: Date | string = new Date(),\n333: ): number {\n334:   const updatedAtMs = new Date(updatedAt).getTime();\n335:   const nowMs = new Date(now).getTime();\n336:   if (!Number.isFinite(updatedAtMs) || !Number.isFinite(nowMs) || nowMs <= updatedAtMs) {\n337:     return 1;\n338:   }\n339: \n340:   const ageMs = nowMs - updatedAtMs;\n341:   return Math.exp(-(ageMs / FRESHNESS_DECAY_WINDOW_MS));\n342: }\n343: \n344: function computeIntentAwareTraversalScore(params: {\n345:   seedScore: number;\n346:   intent: string;\n347:   edgeType: string;\n348:   hopDistance: number;\n349:   updatedAt: Date | string;\n350:   now?: Date | string;\n351: }): number {\n352:   return params.seedScore *\n353:     computeIntentEdgePrior(params.intent, params.edgeType) *\n354:     computeTraversalHopDecay(params.hopDistance) *\n355:     computeTraversalFreshnessFactor(params.updatedAt, params.now);\n356: }\n357: \n358: /**\n359:  * Resolve the primary numeric score from a result, checking score, rrfScore,\n360:  * and similarity (normalized to 0ŌĆō1) in precedence order. Returns 0 if none present.\n361:  */\n362: function resolveBaseScore(result: RankedSearchResult): number {\n363:   if (typeof result.score === 'number' && Number.isFinite(result.score)) return result.score;\n364:   if (typeof result.rrfScore === 'number' && Number.isFinite(result.rrfScore)) return result.rrfScore;\n365:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) return result.similarity / 100;\n366:   return 0;\n367: }\n368: \n369: function buildPipelineRow(\n370:   row: RankedSearchResult,\n371:   baseScore: number,\n372:   causalBoost: number\n373: ): RankedSearchResult {\n374:   const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST));\n375:   const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n376:   return {\n377:     ...row,\n378:     score,\n379:     rrfScore: score,\n380:     intentAdjustedScore: score,\n381:     attentionScore: score,\n382:     causalBoost: allowedBoost,\n383:     baseScore,\n384:     injectedByCausalBoost: true,\n385:   };\n386: }\n387: \n388: /**\n389:  * Deduplicate and validate a list of numeric IDs, truncating to integers\n390:  * and dropping non-finite values to guard against DB query injection.\n391:  */\n392: function normalizeIds(inputIds: number[]): number[] {\n393:   const ids = new Set<number>();\n394:   for (const candidate of inputIds) {\n395:     if (typeof candidate === 'number' && Number.isFinite(candidate)) {\n396:       ids.add(Math.trunc(candidate));\n397:     }\n398:   }\n399:   return Array.from(ids);\n400: }\n401: \n402: /**\n403:  * Compute the hop-distance decay boost: MAX_BOOST_PER_HOP / hopDistance,\n404:  * capped at MAX_BOOST_PER_HOP so closer neighbors get the full signal.\n405:  */\n406: function computeBoostByHop(hopDistance: number): number {\n407:   if (!Number.isFinite(hopDistance) || hopDistance <= 0) return 0;\n408:   const rawBoost = MAX_BOOST_PER_HOP / hopDistance;\n409:   return Math.min(MAX_BOOST_PER_HOP, rawBoost);\n410: }\n411: \n412: /**\n413:  * Walk causal edges up to maxHops from the given seed memory IDs,\n414:  * returning a map of neighbor ID to boost score.\n415:  *\n416:    * Accepts an optional maxHops override. When sparse mode is active\n417:  * (density < 0.5 and SPECKIT_TYPED_TRAVERSAL enabled), the caller passes\n418:  * SPARSE_MAX_HOPS (1) to constrain traversal depth.\n419:  */\n420: function getNeighborBoosts(memoryIds: number[], maxHops: number = MAX_HOPS): Map<number, NeighborBoost> {\n421:   const neighborBoosts = new Map<number, NeighborBoost>();\n422:   if (!db || !graphTraversal) return neighborBoosts;\n423: \n424:   const ids = normalizeIds(memoryIds);\n425:   if (ids.length === 0) return neighborBoosts;\n426: \n427:   try {\n428:     const rows = graphTraversal.collectCausalWeightedNeighbors(ids, maxHops, RELATION_WEIGHT_MULTIPLIERS);\n429: \n430:     for (const [neighborId, row] of rows) {\n431:       const hopBoost = computeBoostByHop(row.minHop);\n432:       const walkMultiplier = typeof row.maxWalkScore === 'number' && Number.isFinite(row.maxWalkScore)\n433:         ? Math.max(0.1, Math.min(2.0, row.maxWalkScore))\n434:         : 1.0;\n435:       const boost = hopBoost * walkMultiplier;\n436:       if (boost <= 0) continue;\n437:       const current = neighborBoosts.get(neighborId);\n438:       if (!current || boost > current.boost) {\n439:         neighborBoosts.set(neighborId, {\n440:           boost,\n441:           hopCount: Math.max(1, Math.min(maxHops, row.minHop)),\n442:         });\n443:       }\n444:     }\n445:   } catch (error: unknown) {\n446:     const message = error instanceof Error ? error.message : String(error);\n447:     console.warn(`[causal-boost] Traversal failed: ${message}`);\n448:   }\n449: \n450:   return neighborBoosts;\n451: }\n452: \n453: function fetchNeighborRows(memoryIds: number[]): RankedSearchResult[] {\n454:   if (!db || memoryIds.length === 0) return [];\n455: \n456:   const placeholders = memoryIds.map(() => '?').join(', ');\n457:   const rows = (db.prepare(`\n458:     SELECT id, spec_folder, file_path, title, importance_tier, trigger_phrases, created_at\n459:     FROM memory_index\n460:     WHERE id IN (${placeholders})\n461:   `) as Database.Statement).all(...memoryIds) as RankedSearchResult[];\n462: \n463:   return rows;\n464: }\n465: \n466: /**\n467:  * Apply causal graph boost to ranked search results, injecting\n468:  * graph-discovered neighbors and amplifying scores for connected nodes.\n469:  *\n470:    * Sparse-first and intent-aware traversal extensions:\n471:    * - When SPECKIT_TYPED_TRAVERSAL is enabled and graphDensity < 0.5,\n472:  *   activates sparse mode: traversal depth = 1, community detection suppressed.\n473:    * - When SPECKIT_TYPED_TRAVERSAL is enabled and intent is provided,\n474:  *   applies intent-aware edge traversal scoring using the formula:\n475:  *   score = seedScore * edgePrior * hopDecay * freshness\n476:  *\n477:  * @param results - Ranked search results from prior pipeline stages\n478:    * @param options - Optional traversal parameters (graphDensity, intent, freshness)\n479:  */\n480: function applyCausalBoost(\n481:   results: RankedSearchResult[],\n482:   options: CausalBoostOptions = {}\n483: ): { results: RankedSearchResult[]; metadata: CausalBoostMetadata } {\n484:   const { graphDensity, intent = 'understand', freshness = 1.0 } = options;\n485: \n486:   // Determine sparse mode and effective hop depth.\n487:   const sparseMode = isSparseMode(graphDensity);\n488:   const effectiveMaxHops = sparseMode ? SPARSE_MAX_HOPS : MAX_HOPS;\n489: \n490:   const metadata: CausalBoostMetadata = {\n491:     enabled: isEnabled(),\n492:     applied: false,\n493:     boostedCount: 0,\n494:     injectedCount: 0,\n495:     maxBoostApplied: 0,\n496:     traversalDepth: effectiveMaxHops,\n497:     sparseModeActive: sparseMode,\n498:     intentUsed: isTypedTraversalEnabled() ? intent : undefined,\n499:   };\n500: \n501:   if (!metadata.enabled || !Array.isArray(results) || results.length === 0 || !db) {\n502:     return { results, metadata };\n503:   }\n504: \n505:   const seedLimit = Math.max(1, Math.min(MAX_SEED_RESULTS, Math.ceil(results.length * SEED_FRACTION)));\n506:   const seedResults = results.slice(0, seedLimit);\n507:   const seedIds = seedResults.map((item) => item.id);\n508:   // Pass effectiveMaxHops to constrain traversal in sparse mode.\n509:   const neighborBoosts = getNeighborBoosts(seedIds, effectiveMaxHops);\n510:   if (neighborBoosts.size === 0) {\n511:     return { results, metadata };\n512:   }\n513: \n514:   // When SPECKIT_TYPED_TRAVERSAL is enabled, re-score neighbor boosts\n515:   // using the intent-aware traversal formula: seedScore * edgePrior * hopDecay * freshness.\n516:   // We use the average seed score as the seedScore proxy and the actual hop distance\n517:   // returned by getNeighborBoosts(). This preserves backward compatibility: when flag\n518:   // is OFF, the original boost values from getNeighborBoosts() are used unchanged.\n519:   const intentBoosts: Map<number, number> = new Map();\n520:   if (isTypedTraversalEnabled()) {\n521:     const avgSeedScore = seedResults.length > 0\n522:       ? seedResults.map((s) => resolveBaseScore(s)).reduce((a, b) => a + b, 0) / seedResults.length\n523:       : 1.0;\n524:     const clampedFreshness = Math.max(0, Math.min(1, Number.isFinite(freshness) ? freshness : 1.0));\n525: \n526:     for (const [neighborId, neighborBoost] of neighborBoosts) {\n527:       // We don't have the per-edge relation type at this aggregation level,\n528:       // so we use the seed's dominant relation by querying the first-hop edge from the DB.\n529:       // Fall back to 'caused' (neutral default) if unavailable.\n530:       let dominantRelation = 'caused';\n531:       if (db) {\n532:         try {\n533:           const edgeRow = (db.prepare(`\n534:             SELECT relation FROM causal_edges\n535:             WHERE source_id IN (${seedIds.map(() => '?').join(',')})\n536:               AND target_id = ?\n537:             LIMIT 1\n538:           `) as Database.Statement).get(...seedIds.map(String), String(neighborId)) as\n539:             { relation: string } | undefined;\n540:           if (edgeRow?.relation) dominantRelation = edgeRow.relation;\n541:         } catch (_err: unknown) {\n542:           // Fall back to default relation on query failure\n543:         }\n544:       }\n545: \n546:       const intentScore = computeIntentTraversalScore(\n547:         avgSeedScore,\n548:         dominantRelation,\n549:         neighborBoost.hopCount,\n550:         clampedFreshness,\n551:         intent\n552:       );\n553:       intentBoosts.set(neighborId, intentScore);\n554:     }\n555:   }\n556: \n557:   // Select the active boost map: intent-aware when the flag is on, classic otherwise.\n558:   const classicBoosts = new Map<number, number>();\n559:   for (const [neighborId, neighborBoost] of neighborBoosts) {\n560:     classicBoosts.set(neighborId, neighborBoost.boost);\n561:   }\n562:   const activeBoosts = isTypedTraversalEnabled() ? intentBoosts : classicBoosts;\n563: \n564:   const existingIds = new Set(results.map((item) => item.id));\n565:   // Reduce avoids stack overflow on arrays >100K elements (spread pushes all onto call stack)\n566:   const lowestScore = Math.max(0.0001, results.map((item) => resolveBaseScore(item)).reduce((a, b) => Math.min(a, b), Infinity));\n567: \n568:   const boosted = results.map((item) => {\n569:     const causalBoost = activeBoosts.get(item.id) ?? 0;\n570:     if (causalBoost <= 0) {\n571:       return item;\n572:     }\n573: \n574:     const sessionBoost = typeof item.sessionBoost === 'number' ? Math.max(0, item.sessionBoost) : 0;\n575:     const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST - sessionBoost));\n576:     if (allowedBoost <= 0) {\n577:       return item;\n578:     }\n579: \n580:     const baseScore = resolveBaseScore(item);\n581:     const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n582:     metadata.boostedCount += 1;\n583:     metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, allowedBoost);\n584:     return {\n585:       ...item,\n586:       score,\n587:       rrfScore: score,\n588:       intentAdjustedScore: score,\n589:       attentionScore: score,\n590:       causalBoost: allowedBoost,\n591:       baseScore,\n592:     };\n593:   });\n594: \n595:   const injectIds: number[] = [];\n596:   for (const [neighborId] of activeBoosts) {\n597:     if (!existingIds.has(neighborId)) {\n598:       injectIds.push(neighborId);\n599:     }\n600:   }\n601: \n602:   const injectedRows = fetchNeighborRows(injectIds).map((row) => {\n603:     const causalBoost = Math.max(0, Math.min(activeBoosts.get(row.id) ?? 0, MAX_COMBINED_BOOST));\n604:     metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, causalBoost);\n605:     const baseScore = lowestScore * 0.5;\n606:     return buildPipelineRow(row, baseScore, causalBoost);\n607:   });\n608: \n609:   metadata.injectedCount = injectedRows.length;\n610:   metadata.applied = metadata.boostedCount > 0 || metadata.injectedCount > 0;\n611: \n612:   const merged = [...boosted, ...injectedRows].sort((left, right) => {\n613:     const leftScore = resolveBaseScore(left);\n614:     const rightScore = resolveBaseScore(right);\n615:     if (rightScore === leftScore) {\n616:       return left.id - right.id;\n617:     }\n618:     return rightScore - leftScore;\n619:   });\n620: \n621:   return { results: merged, metadata };\n622: }\n623: \n624: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n625: // ALWAYS-ON GRAPH CONTEXT INJECTION\n626: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n627: \n628: /**\n629:  * Graph context metadata returned by injectGraphContext.\n630:  * Contains related memory IDs and edge types discovered from the graph\n631:  * even when the causal boost has no seed results.\n632:  */\n633: interface GraphContextResult {\n634:   /** Whether graph context injection was active and produced results. */\n635:   activated: boolean;\n636:   /** Canonical concept names matched from the query. */\n637:   matchedConcepts: string[];\n638:   /** Memory IDs of graph neighbors related to matched concepts. */\n639:   relatedMemoryIds: number[];\n640:   /** Edge relation types connecting seeds to neighbors. */\n641:   edgeTypes: string[];\n642: }\n643: \n644: /**\n645:  * Always-on graph context injection.\n646:  *\n647:  * Runs concept routing on the query and finds graph neighbors for matched\n648:  * concepts, returning graph context metadata (related memory IDs, edge types).\n649:  * Unlike applyCausalBoost, this runs even when there are no seed results,\n650:  * enabling proactive graph-guided context discovery.\n651:  *\n652:  * Feature-gated by SPECKIT_GRAPH_CONTEXT_INJECTION (default ON).\n653:  * Fail-open: returns empty result on any error.\n654:  *\n655:  * @param query - The search query string.\n656:  * @param database - SQLite database instance for graph lookups.\n657:  * @returns GraphContextResult with related memory IDs and edge types.\n658:  */\n659: function injectGraphContext(\n660:   query: string,\n661:   database: Database.Database,\n662: ): GraphContextResult {\n663:   const empty: GraphContextResult = {\n664:     activated: false,\n665:     matchedConcepts: [],\n666:     relatedMemoryIds: [],\n667:     edgeTypes: [],\n668:   };\n669: \n670:   if (!isGraphContextInjectionEnabled()) return empty;\n671: \n672:   try {\n673:     const routing = routeQueryConcepts(query, database);\n674:     if (!routing.graphActivated || routing.concepts.length === 0) return empty;\n675: \n676:     // Find seed memory IDs whose titles contain matched concept keywords\n677:     const likeClauses = routing.concepts.map(() => 'LOWER(title) LIKE ?').join(' OR ');\n678:     const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n679: \n680:     const seedRows = (database.prepare(`\n681:       SELECT id FROM memory_index WHERE (${likeClauses}) LIMIT 10\n682:     `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n683: \n684:     if (seedRows.length === 0) {\n685:       return { ...empty, activated: true, matchedConcepts: routing.concepts };\n686:     }\n687: \n688:     const seedIds = seedRows.map((r) => String(r.id));\n689:     const seedPlaceholders = seedIds.map(() => '?').join(', ');\n690: \n691:     // Walk 1-hop causal edges to find neighbor nodes and edge types\n692:     const neighborRows = (database.prepare(`\n693:       SELECT DISTINCT\n694:         CASE\n695:           WHEN ce.source_id IN (${seedPlaceholders}) THEN CAST(ce.target_id AS INTEGER)\n696:           ELSE CAST(ce.source_id AS INTEGER)\n697:         END AS neighbor_id,\n698:         ce.relation\n699:       FROM causal_edges ce\n700:       WHERE ce.source_id IN (${seedPlaceholders}) OR ce.target_id IN (${seedPlaceholders})\n701:       LIMIT 20\n702:     `) as Database.Statement).all(\n703:       ...seedIds,\n704:       ...seedIds,\n705:       ...seedIds,\n706:     ) as Array<{ neighbor_id: number; relation: string }>;\n707: \n708:     const relatedMemoryIds: number[] = [];\n709:     const edgeTypes = new Set<string>();\n710:     const seedIdSet = new Set(seedRows.map((r) => r.id));\n711: \n712:     for (const row of neighborRows) {\n713:       if (!seedIdSet.has(row.neighbor_id) && Number.isFinite(row.neighbor_id)) {\n714:         relatedMemoryIds.push(row.neighbor_id);\n715:       }\n716:       if (row.relation) {\n717:         edgeTypes.add(row.relation);\n718:       }\n719:     }\n720: \n721:     return {\n722:       activated: true,\n723:       matchedConcepts: routing.concepts,\n724:       relatedMemoryIds: [...new Set(relatedMemoryIds)].slice(0, 10),\n725:       edgeTypes: Array.from(edgeTypes),\n726:     };\n727:   } catch (error: unknown) {\n728:     const message = error instanceof Error ? error.message : String(error);\n729:     console.warn(`[causal-boost] injectGraphContext failed (fail-open): ${message}`);\n730:     return empty;\n731:   }\n732: }\n733: \n734: export {\n735:   MAX_HOPS,\n736:   MAX_BOOST_PER_HOP,\n737:   RELATION_WEIGHT_MULTIPLIERS,\n738:   // D3 Phase A exports\n739:   SPARSE_DENSITY_THRESHOLD,\n740:   SPARSE_MAX_HOPS,\n741:   DEFAULT_TYPED_TRAVERSAL_DEPTH,\n742:   INTENT_EDGE_PRIORITY,\n743:   DEFAULT_EDGE_PRIORITY,\n744:   DEFAULT_EDGE_PRIOR,\n745:   EDGE_PRIOR_TIERS,\n746:   EDGE_LABEL_ALIASES,\n747:   init,\n748:   isEnabled,\n749:   isTypedTraversalEnabled,\n750:   isSparseMode,\n751:   resolveSparseFirstTraversalPolicy,\n752:   resolveTraversalDepth,\n753:   resolveEdgePrior,\n754:   computeHopDecay,\n755:   computeIntentTraversalScore,\n756:   getIntentEdgePriorities,\n757:   computeIntentEdgePrior,\n758:   computeTraversalHopDecay,\n759:   computeTraversalFreshnessFactor,\n760:   computeIntentAwareTraversalScore,\n761:   getNeighborBoosts,\n762:   applyCausalBoost,\n763:   // Always-on graph context injection\n764:   injectGraphContext,\n765: };\n766: \n767: export type {\n768:   RankedSearchResult,\n769:   CausalBoostMetadata,\n770:   CausalBoostOptions,\n771:   SparseFirstTraversalPolicy,\n772:   GraphContextResult,\n773: };\n\n(End of file - total 773 lines)\n</content>","metadata":{"preview":"// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// MODULE: Causal Boost\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// Feature catalog: Causal neighbor boost and injection\n// Graph-traversal score boosting via causal edge relationships.\n// Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n// For results related to top seed results via weighted CTE.\n//\n// Sparse-First + Intent-Aware Traversal:\n// - Sparse-first policy ŌĆö density < 0.5 disables community\n//   detection and constrains traversal to typed 1-hop expansion only.\n// - Intent-aware edge traversal ŌĆö maps classified query intents\n//   to edge-type priority orderings; computes traversal score as:\n//   score = seedScore * edgePrior * hopDecay * freshness\n// Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\nimport { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n\nimport type Database from 'better-sqlite3';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","text":"// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// MODULE: Causal Boost\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// Feature catalog: Causal neighbor boost and injection\n// Graph-traversal score boosting via causal edge relationships.\n// Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n// For results related to top seed results via weighted CTE.\n//\n// Sparse-First + Intent-Aware Traversal:\n// - Sparse-first policy ŌĆö density < 0.5 disables community\n//   detection and constrains traversal to typed 1-hop expansion only.\n// - Intent-aware edge traversal ŌĆö maps classified query intents\n//   to edge-type priority orderings; computes traversal score as:\n//   score = seedScore * edgePrior * hopDecay * freshness\n// Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\nimport { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Maximum graph traversal depth. Beyond 2 hops, signal degrades and queries become expensive. */\nconst MAX_HOPS = 2;\n/** Per-hop boost cap. 0.05 keeps causal nudge subtle relative to semantic scores (~0.5ŌĆō1.0). */\nconst MAX_BOOST_PER_HOP = 0.05;\n/** Combined causal + session boost ceiling to prevent runaway amplification. */\nconst MAX_COMBINED_BOOST = 0.20;\n/** Top fraction of result set used as graph walk seed nodes. */\nconst SEED_FRACTION = 0.25;\n/** Absolute cap on seed nodes regardless of result set size. */\nconst MAX_SEED_RESULTS = 5;\n\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// SPARSE-FIRST POLICY CONSTANTS\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n/** Graph density threshold below which community detection is disabled\n * and traversal is constrained to typed 1-hop expansion only.\n * Density = edgeCount / totalMemories (see edge-density.ts). */\nconst SPARSE_DENSITY_THRESHOLD = 0.5;\n\n/** Traversal depth used in sparse mode (1-hop typed expansion). */\nconst SPARSE_MAX_HOPS = 1;\n\n/** Default traversal depth for typed traversal helper policies. */\nconst DEFAULT_TYPED_TRAVERSAL_DEPTH = SPARSE_MAX_HOPS;\n\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// INTENT-AWARE EDGE TRAVERSAL\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n/** Per-hop decay factor applied to traversal score. 1-hop = 1.0, 2-hop = 0.5. */\nconst HOP_DECAY_BASE = 1.0;\n\n/**\n * Intent-to-edge-type priority ordering.\n * Maps each query intent to an ordered list of edge relation types.\n * Earlier entries in the list receive higher edge prior scores.\n *\n * Scores are normalized: first-listed relation = 1.0, second = 0.75, remaining = 0.5.\n */\nconst INTENT_EDGE_PRIORITY: Record<string, string[]> = {\n  fix_bug:        ['CORRECTION', 'DEPENDS_ON', 'supersedes', 'caused'],\n  add_feature:    ['EXTENDS', 'DEPENDS_ON', 'enabled', 'derived_from'],\n  find_decision:  ['PREFERENCE', 'CORRECTION', 'supersedes', 'contradicts'],\n  // Defaults for other intents ŌĆö use existing relation-weight ordering\n  understand:     ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n  find_spec:      ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n  refactor:       ['caused', 'derived_from', 'enabled', 'supports', 'supersedes', 'contradicts'],\n  security_audit: ['caused', 'contradicts', 'supersedes', 'enabled', 'supports', 'derived_from'],\n};\n\n/** Fallback priority list when intent is unrecognized. */\nconst DEFAULT_EDGE_PRIORITY = ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'];\n\n/** Edge prior score tiers: 1st priority = 1.0, 2nd = 0.75, remaining = 0.5. */\nconst EDGE_PRIOR_TIERS = [1.0, 0.75, 0.5];\nconst DEFAULT_EDGE_PRIOR = 1.0;\nconst FRESHNESS_DECAY_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;\n\n/**\n * Relation-type weight multipliers for causal edge traversal.\n * Applied during CTE accumulation so stronger relation types (supersedes)\n * amplify the boost while weaker ones (contradicts) attenuate it.\n *\n * These multipliers serve a DIFFERENT purpose from RELATION_WEIGHTS in\n * causal-edges.ts. causal-edges weights are applied during chain traversal\n * scoring (getCausalChain), while these are applied during the causal-boost\n * CTE walk (getNeighborBoosts) for search result amplification. The value\n * ranges overlap but are tuned independently for their respective contexts:\n *   - causal-edges: traversal strength propagation (range 0.8ŌĆō1.5)\n *   - causal-boost: search result boost amplitude (range 0.8ŌĆō1.5)\n */\nconst RELATION_WEIGHT_MULTIPLIERS: Record<string, number> = {\n  supersedes: 1.5,\n  contradicts: 0.8,\n  caused: 1.0,\n  enabled: 1.0,\n  derived_from: 1.0,\n  supports: 1.0,\n};\n\ninterface RankedSearchResult extends Record<string, unknown> {\n  id: number;\n  score?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  attentionScore?: number;\n  similarity?: number;\n  sessionBoost?: number;\n  baseScore?: number;\n  causalBoost?: number;\n  injectedByCausalBoost?: boolean;\n}\n\ninterface CausalBoostMetadata {\n  enabled: boolean;\n  applied: boolean;\n  boostedCount: number;\n  injectedCount: number;\n  maxBoostApplied: number;\n  traversalDepth: number;\n  /** True when sparse-first policy was active (density < threshold) */\n  sparseModeActive?: boolean;\n  /** Intent used for edge traversal scoring (if typed traversal enabled) */\n  intentUsed?: string;\n}\n\n/** Options for applyCausalBoost ŌĆö extended with sparse-first parameters. */\ninterface CausalBoostOptions {\n  /** Graph density (edgeCount / totalMemories). Used for sparse-first gate. */\n  graphDensity?: number;\n  /** Classified query intent. Used for intent-aware edge priority mapping. */\n  intent?: string;\n  /** Freshness factor [0,1] applied to traversal scoring. Defaults to 1.0. */\n  freshness?: number;\n}\n\ninterface NeighborBoost {\n  boost: number;\n  hopCount: number;\n}\n\nlet db: Database.Database | null = null;\nlet graphTraversal: GraphTraversal | null = null;\n\n/**\n * Check whether the causal boost feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n * When enabled, causal graph traversal amplifies scores for results\n * connected to top-ranked results via causal edges.\n *\n * Delegates to the canonical flag check in search-flags.ts.\n */\nfunction isEnabled(): boolean {\n  return isCausalBoostEnabled();\n}\n\n/**\n * Check whether the typed traversal feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n * Activates sparse-first + intent-aware traversal.\n */\nfunction isTypedTraversalEnabled(): boolean {\n  return _isTypedTraversalEnabled();\n}\n\n/** Store the database reference used by causal edge traversal queries. */\nfunction init(database: Database.Database): void {\n  db = database;\n  graphTraversal = new BetterSqliteGraphTraversal(database);\n}\n\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// SPARSE-FIRST POLICY\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\n/**\n * Determine whether sparse mode should be active for this traversal pass.\n * Sparse mode is active when:\n *   - SPECKIT_TYPED_TRAVERSAL is enabled, AND\n *   - graphDensity is a finite number below SPARSE_DENSITY_THRESHOLD (0.5)\n *\n * When sparse mode is active:\n *   - Community detection is suppressed (caller must respect this)\n *   - Traversal is constrained to SPARSE_MAX_HOPS (1)\n */\nfunction isSparseMode(graphDensity: number | undefined): boolean {\n  if (!isTypedTraversalEnabled()) return false;\n  if (typeof graphDensity !== 'number' || !Number.isFinite(graphDensity)) return false;\n  return graphDensity < SPARSE_DENSITY_THRESHOLD;\n}\n\ninterface SparseFirstTraversalPolicy {\n  sparseModeActive: boolean;\n  communityDetectionEnabled: boolean;\n}\n\n/**\n * Resolve the sparse-first policy gate for callers that need a simple\n * community-detection decision without running the full boost pipeline.\n */\nfunction resolveSparseFirstTraversalPolicy(graphDensity: number | undefined): SparseFirstTraversalPolicy {\n  const sparseModeActive = isSparseMode(graphDensity);\n  return {\n    sparseModeActive,\n    communityDetectionEnabled: !sparseModeActive,\n  };\n}\n\n/**\n * Resolve traversal depth for typed traversal helper callers.\n * Typed traversal defaults to 1-hop and stays within the supported range.\n * When the flag is off, preserve the legacy MAX_HOPS behavior.\n */\nfunction resolveTraversalDepth(depth: number = DEFAULT_TYPED_TRAVERSAL_DEPTH): number {\n  if (!isTypedTraversalEnabled()) {\n    return MAX_HOPS;\n  }\n\n  if (!Number.isFinite(depth)) {\n    return DEFAULT_TYPED_TRAVERSAL_DEPTH;\n  }\n\n  return Math.max(DEFAULT_TYPED_TRAVERSAL_DEPTH, Math.min(MAX_HOPS, Math.trunc(depth)));\n}\n\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// INTENT-AWARE EDGE TRAVERSAL HELPERS\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\n/**\n * Compute the edge prior score for a given relation type and intent.\n * Returns a normalized score in [0.5, 1.0] based on priority position.\n *\n * Canonical relation names from causal-boost are lower-cased (e.g. 'supersedes').\n * Intent priority lists may include upper-case semantic labels (e.g. 'CORRECTION').\n * Matching is case-insensitive against both the label and any alias.\n *\n * Alias map: CORRECTION ŌåÆ supersedes | contradicts\n *            DEPENDS_ON ŌåÆ caused | enabled | derived_from\n *            EXTENDS    ŌåÆ enabled | derived_from\n *            PREFERENCE ŌåÆ supports\n */\nconst EDGE_LABEL_ALIASES: Record<string, string[]> = {\n  CORRECTION:  ['supersedes', 'contradicts'],\n  DEPENDS_ON:  ['caused', 'enabled', 'derived_from'],\n  EXTENDS:     ['enabled', 'derived_from'],\n  PREFERENCE:  ['supports'],\n};\n\nfunction resolveEdgePrior(relation: string, intent: string): number {\n  if (!isTypedTraversalEnabled()) return 1.0;\n\n  const priority = INTENT_EDGE_PRIORITY[intent] ?? DEFAULT_EDGE_PRIORITY;\n  const relLower = relation.toLowerCase();\n\n  for (let i = 0; i < priority.length; i++) {\n    const entry = priority[i];\n    if (!entry) continue;\n    // Exact match (case-insensitive)\n    if (entry.toLowerCase() === relLower) {\n      return EDGE_PRIOR_TIERS[Math.min(i, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n    }\n    // Alias expansion: check if this priority label maps to the relation\n    const aliases = EDGE_LABEL_ALIASES[entry.toUpperCase()];\n    if (aliases && aliases.includes(relLower)) {\n      return EDGE_PRIOR_TIERS[Math.min(i, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n    }\n  }\n\n  // Relation not found in priority list ŌĆö assign minimum tier\n  return EDGE_PRIOR_TIERS[EDGE_PRIOR_TIERS.length - 1] ?? 0.5;\n}\n\n/**\n * Compute hop decay factor. Formula: HOP_DECAY_BASE / hopDistance.\n * 1-hop ŌåÆ 1.0, 2-hop ŌåÆ 0.5, etc. Capped at 1.0.\n */\nfunction computeHopDecay(hopDistance: number): number {\n  if (!Number.isFinite(hopDistance) || hopDistance <= 0) return 0;\n  return Math.min(1.0, HOP_DECAY_BASE / hopDistance);\n}\n\n/**\n * Compute the intent-aware traversal score.\n * Formula: seedScore * edgePrior * hopDecay * freshness\n *\n * @param seedScore  - Base score of the seed node (0ŌĆō1)\n * @param relation   - Edge relation type (e.g. 'supersedes', 'caused')\n * @param hopDistance - Hop distance from seed (1 = direct neighbor)\n * @param freshness  - Recency factor (0ŌĆō1, default 1.0)\n * @param intent     - Classified query intent (default 'understand')\n */\nfunction computeIntentTraversalScore(\n  seedScore: number,\n  relation: string,\n  hopDistance: number,\n  freshness: number,\n  intent: string\n): number {\n  const edgePrior = resolveEdgePrior(relation, intent);\n  const hopDecay = computeHopDecay(hopDistance);\n  return seedScore * edgePrior * hopDecay * freshness;\n}\n\nfunction getIntentEdgePriorities(intent: string): string[] {\n  return (INTENT_EDGE_PRIORITY[intent] ?? []).slice(0, 2);\n}\n\nfunction computeIntentEdgePrior(intent: string, edgeType: string): number {\n  const priorities = getIntentEdgePriorities(intent);\n  if (priorities.length === 0) {\n    return DEFAULT_EDGE_PRIOR;\n  }\n\n  const normalizedEdgeType = edgeType.toUpperCase();\n  const directMatchIndex = priorities.findIndex(\n    (priority) => priority.toUpperCase() === normalizedEdgeType,\n  );\n  if (directMatchIndex >= 0) {\n    return EDGE_PRIOR_TIERS[Math.min(directMatchIndex, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n  }\n\n  return resolveEdgePrior(edgeType, intent);\n}\n\nfunction computeTraversalHopDecay(hopDistance: number): number {\n  return computeHopDecay(hopDistance);\n}\n\nfunction computeTraversalFreshnessFactor(\n  updatedAt: Date | string,\n  now: Date | string = new Date(),\n): number {\n  const updatedAtMs = new Date(updatedAt).getTime();\n  const nowMs = new Date(now).getTime();\n  if (!Number.isFinite(updatedAtMs) || !Number.isFinite(nowMs) || nowMs <= updatedAtMs) {\n    return 1;\n  }\n\n  const ageMs = nowMs - updatedAtMs;\n  return Math.exp(-(ageMs / FRESHNESS_DECAY_WINDOW_MS));\n}\n\nfunction computeIntentAwareTraversalScore(params: {\n  seedScore: number;\n  intent: string;\n  edgeType: string;\n  hopDistance: number;\n  updatedAt: Date | string;\n  now?: Date | string;\n}): number {\n  return params.seedScore *\n    computeIntentEdgePrior(params.intent, params.edgeType) *\n    computeTraversalHopDecay(params.hopDistance) *\n    computeTraversalFreshnessFactor(params.updatedAt, params.now);\n}\n\n/**\n * Resolve the primary numeric score from a result, checking score, rrfScore,\n * and similarity (normalized to 0ŌĆō1) in precedence order. Returns 0 if none present.\n */\nfunction resolveBaseScore(result: RankedSearchResult): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) return result.score;\n  if (typeof result.rrfScore === 'number' && Number.isFinite(result.rrfScore)) return result.rrfScore;\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) return result.similarity / 100;\n  return 0;\n}\n\nfunction buildPipelineRow(\n  row: RankedSearchResult,\n  baseScore: number,\n  causalBoost: number\n): RankedSearchResult {\n  const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST));\n  const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n  return {\n    ...row,\n    score,\n    rrfScore: score,\n    intentAdjustedScore: score,\n    attentionScore: score,\n    causalBoost: allowedBoost,\n    baseScore,\n    injectedByCausalBoost: true,\n  };\n}\n\n/**\n * Deduplicate and validate a list of numeric IDs, truncating to integers\n * and dropping non-finite values to guard against DB query injection.\n */\nfunction normalizeIds(inputIds: number[]): number[] {\n  const ids = new Set<number>();\n  for (const candidate of inputIds) {\n    if (typeof candidate === 'number' && Number.isFinite(candidate)) {\n      ids.add(Math.trunc(candidate));\n    }\n  }\n  return Array.from(ids);\n}\n\n/**\n * Compute the hop-distance decay boost: MAX_BOOST_PER_HOP / hopDistance,\n * capped at MAX_BOOST_PER_HOP so closer neighbors get the full signal.\n */\nfunction computeBoostByHop(hopDistance: number): number {\n  if (!Number.isFinite(hopDistance) || hopDistance <= 0) return 0;\n  const rawBoost = MAX_BOOST_PER_HOP / hopDistance;\n  return Math.min(MAX_BOOST_PER_HOP, rawBoost);\n}\n\n/**\n * Walk causal edges up to maxHops from the given seed memory IDs,\n * returning a map of neighbor ID to boost score.\n *\n   * Accepts an optional maxHops override. When sparse mode is active\n * (density < 0.5 and SPECKIT_TYPED_TRAVERSAL enabled), the caller passes\n * SPARSE_MAX_HOPS (1) to constrain traversal depth.\n */\nfunction getNeighborBoosts(memoryIds: number[], maxHops: number = MAX_HOPS): Map<number, NeighborBoost> {\n  const neighborBoosts = new Map<number, NeighborBoost>();\n  if (!db || !graphTraversal) return neighborBoosts;\n\n  const ids = normalizeIds(memoryIds);\n  if (ids.length === 0) return neighborBoosts;\n\n  try {\n    const rows = graphTraversal.collectCausalWeightedNeighbors(ids, maxHops, RELATION_WEIGHT_MULTIPLIERS);\n\n    for (const [neighborId, row] of rows) {\n      const hopBoost = computeBoostByHop(row.minHop);\n      const walkMultiplier = typeof row.maxWalkScore === 'number' && Number.isFinite(row.maxWalkScore)\n        ? Math.max(0.1, Math.min(2.0, row.maxWalkScore))\n        : 1.0;\n      const boost = hopBoost * walkMultiplier;\n      if (boost <= 0) continue;\n      const current = neighborBoosts.get(neighborId);\n      if (!current || boost > current.boost) {\n        neighborBoosts.set(neighborId, {\n          boost,\n          hopCount: Math.max(1, Math.min(maxHops, row.minHop)),\n        });\n      }\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-boost] Traversal failed: ${message}`);\n  }\n\n  return neighborBoosts;\n}\n\nfunction fetchNeighborRows(memoryIds: number[]): RankedSearchResult[] {\n  if (!db || memoryIds.length === 0) return [];\n\n  const placeholders = memoryIds.map(() => '?').join(', ');\n  const rows = (db.prepare(`\n    SELECT id, spec_folder, file_path, title, importance_tier, trigger_phrases, created_at\n    FROM memory_index\n    WHERE id IN (${placeholders})\n  `) as Database.Statement).all(...memoryIds) as RankedSearchResult[];\n\n  return rows;\n}\n\n/**\n * Apply causal graph boost to ranked search results, injecting\n * graph-discovered neighbors and amplifying scores for connected nodes.\n *\n   * Sparse-first and intent-aware traversal extensions:\n   * - When SPECKIT_TYPED_TRAVERSAL is enabled and graphDensity < 0.5,\n *   activates sparse mode: traversal depth = 1, community detection suppressed.\n   * - When SPECKIT_TYPED_TRAVERSAL is enabled and intent is provided,\n *   applies intent-aware edge traversal scoring using the formula:\n *   score = seedScore * edgePrior * hopDecay * freshness\n *\n * @param results - Ranked search results from prior pipeline stages\n   * @param options - Optional traversal parameters (graphDensity, intent, freshness)\n */\nfunction applyCausalBoost(\n  results: RankedSearchResult[],\n  options: CausalBoostOptions = {}\n): { results: RankedSearchResult[]; metadata: CausalBoostMetadata } {\n  const { graphDensity, intent = 'understand', freshness = 1.0 } = options;\n\n  // Determine sparse mode and effective hop depth.\n  const sparseMode = isSparseMode(graphDensity);\n  const effectiveMaxHops = sparseMode ? SPARSE_MAX_HOPS : MAX_HOPS;\n\n  const metadata: CausalBoostMetadata = {\n    enabled: isEnabled(),\n    applied: false,\n    boostedCount: 0,\n    injectedCount: 0,\n    maxBoostApplied: 0,\n    traversalDepth: effectiveMaxHops,\n    sparseModeActive: sparseMode,\n    intentUsed: isTypedTraversalEnabled() ? intent : undefined,\n  };\n\n  if (!metadata.enabled || !Array.isArray(results) || results.length === 0 || !db) {\n    return { results, metadata };\n  }\n\n  const seedLimit = Math.max(1, Math.min(MAX_SEED_RESULTS, Math.ceil(results.length * SEED_FRACTION)));\n  const seedResults = results.slice(0, seedLimit);\n  const seedIds = seedResults.map((item) => item.id);\n  // Pass effectiveMaxHops to constrain traversal in sparse mode.\n  const neighborBoosts = getNeighborBoosts(seedIds, effectiveMaxHops);\n  if (neighborBoosts.size === 0) {\n    return { results, metadata };\n  }\n\n  // When SPECKIT_TYPED_TRAVERSAL is enabled, re-score neighbor boosts\n  // using the intent-aware traversal formula: seedScore * edgePrior * hopDecay * freshness.\n  // We use the average seed score as the seedScore proxy and the actual hop distance\n  // returned by getNeighborBoosts(). This preserves backward compatibility: when flag\n  // is OFF, the original boost values from getNeighborBoosts() are used unchanged.\n  const intentBoosts: Map<number, number> = new Map();\n  if (isTypedTraversalEnabled()) {\n    const avgSeedScore = seedResults.length > 0\n      ? seedResults.map((s) => resolveBaseScore(s)).reduce((a, b) => a + b, 0) / seedResults.length\n      : 1.0;\n    const clampedFreshness = Math.max(0, Math.min(1, Number.isFinite(freshness) ? freshness : 1.0));\n\n    for (const [neighborId, neighborBoost] of neighborBoosts) {\n      // We don't have the per-edge relation type at this aggregation level,\n      // so we use the seed's dominant relation by querying the first-hop edge from the DB.\n      // Fall back to 'caused' (neutral default) if unavailable.\n      let dominantRelation = 'caused';\n      if (db) {\n        try {\n          const edgeRow = (db.prepare(`\n            SELECT relation FROM causal_edges\n            WHERE source_id IN (${seedIds.map(() => '?').join(',')})\n              AND target_id = ?\n            LIMIT 1\n          `) as Database.Statement).get(...seedIds.map(String), String(neighborId)) as\n            { relation: string } | undefined;\n          if (edgeRow?.relation) dominantRelation = edgeRow.relation;\n        } catch (_err: unknown) {\n          // Fall back to default relation on query failure\n        }\n      }\n\n      const intentScore = computeIntentTraversalScore(\n        avgSeedScore,\n        dominantRelation,\n        neighborBoost.hopCount,\n        clampedFreshness,\n        intent\n      );\n      intentBoosts.set(neighborId, intentScore);\n    }\n  }\n\n  // Select the active boost map: intent-aware when the flag is on, classic otherwise.\n  const classicBoosts = new Map<number, number>();\n  for (const [neighborId, neighborBoost] of neighborBoosts) {\n    classicBoosts.set(neighborId, neighborBoost.boost);\n  }\n  const activeBoosts = isTypedTraversalEnabled() ? intentBoosts : classicBoosts;\n\n  const existingIds = new Set(results.map((item) => item.id));\n  // Reduce avoids stack overflow on arrays >100K elements (spread pushes all onto call stack)\n  const lowestScore = Math.max(0.0001, results.map((item) => resolveBaseScore(item)).reduce((a, b) => Math.min(a, b), Infinity));\n\n  const boosted = results.map((item) => {\n    const causalBoost = activeBoosts.get(item.id) ?? 0;\n    if (causalBoost <= 0) {\n      return item;\n    }\n\n    const sessionBoost = typeof item.sessionBoost === 'number' ? Math.max(0, item.sessionBoost) : 0;\n    const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST - sessionBoost));\n    if (allowedBoost <= 0) {\n      return item;\n    }\n\n    const baseScore = resolveBaseScore(item);\n    const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n    metadata.boostedCount += 1;\n    metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, allowedBoost);\n    return {\n      ...item,\n      score,\n      rrfScore: score,\n      intentAdjustedScore: score,\n      attentionScore: score,\n      causalBoost: allowedBoost,\n      baseScore,\n    };\n  });\n\n  const injectIds: number[] = [];\n  for (const [neighborId] of activeBoosts) {\n    if (!existingIds.has(neighborId)) {\n      injectIds.push(neighborId);\n    }\n  }\n\n  const injectedRows = fetchNeighborRows(injectIds).map((row) => {\n    const causalBoost = Math.max(0, Math.min(activeBoosts.get(row.id) ?? 0, MAX_COMBINED_BOOST));\n    metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, causalBoost);\n    const baseScore = lowestScore * 0.5;\n    return buildPipelineRow(row, baseScore, causalBoost);\n  });\n\n  metadata.injectedCount = injectedRows.length;\n  metadata.applied = metadata.boostedCount > 0 || metadata.injectedCount > 0;\n\n  const merged = [...boosted, ...injectedRows].sort((left, right) => {\n    const leftScore = resolveBaseScore(left);\n    const rightScore = resolveBaseScore(right);\n    if (rightScore === leftScore) {\n      return left.id - right.id;\n    }\n    return rightScore - leftScore;\n  });\n\n  return { results: merged, metadata };\n}\n\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// ALWAYS-ON GRAPH CONTEXT INJECTION\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\n/**\n * Graph context metadata returned by injectGraphContext.\n * Contains related memory IDs and edge types discovered from the graph\n * even when the causal boost has no seed results.\n */\ninterface GraphContextResult {\n  /** Whether graph context injection was active and produced results. */\n  activated: boolean;\n  /** Canonical concept names matched from the query. */\n  matchedConcepts: string[];\n  /** Memory IDs of graph neighbors related to matched concepts. */\n  relatedMemoryIds: number[];\n  /** Edge relation types connecting seeds to neighbors. */\n  edgeTypes: string[];\n}\n\n/**\n * Always-on graph context injection.\n *\n * Runs concept routing on the query and finds graph neighbors for matched\n * concepts, returning graph context metadata (related memory IDs, edge types).\n * Unlike applyCausalBoost, this runs even when there are no seed results,\n * enabling proactive graph-guided context discovery.\n *\n * Feature-gated by SPECKIT_GRAPH_CONTEXT_INJECTION (default ON).\n * Fail-open: returns empty result on any error.\n *\n * @param query - The search query string.\n * @param database - SQLite database instance for graph lookups.\n * @returns GraphContextResult with related memory IDs and edge types.\n */\nfunction injectGraphContext(\n  query: string,\n  database: Database.Database,\n): GraphContextResult {\n  const empty: GraphContextResult = {\n    activated: false,\n    matchedConcepts: [],\n    relatedMemoryIds: [],\n    edgeTypes: [],\n  };\n\n  if (!isGraphContextInjectionEnabled()) return empty;\n\n  try {\n    const routing = routeQueryConcepts(query, database);\n    if (!routing.graphActivated || routing.concepts.length === 0) return empty;\n\n    // Find seed memory IDs whose titles contain matched concept keywords\n    const likeClauses = routing.concepts.map(() => 'LOWER(title) LIKE ?').join(' OR ');\n    const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n\n    const seedRows = (database.prepare(`\n      SELECT id FROM memory_index WHERE (${likeClauses}) LIMIT 10\n    `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n\n    if (seedRows.length === 0) {\n      return { ...empty, activated: true, matchedConcepts: routing.concepts };\n    }\n\n    const seedIds = seedRows.map((r) => String(r.id));\n    const seedPlaceholders = seedIds.map(() => '?').join(', ');\n\n    // Walk 1-hop causal edges to find neighbor nodes and edge types\n    const neighborRows = (database.prepare(`\n      SELECT DISTINCT\n        CASE\n          WHEN ce.source_id IN (${seedPlaceholders}) THEN CAST(ce.target_id AS INTEGER)\n          ELSE CAST(ce.source_id AS INTEGER)\n        END AS neighbor_id,\n        ce.relation\n      FROM causal_edges ce\n      WHERE ce.source_id IN (${seedPlaceholders}) OR ce.target_id IN (${seedPlaceholders})\n      LIMIT 20\n    `) as Database.Statement).all(\n      ...seedIds,\n      ...seedIds,\n      ...seedIds,\n    ) as Array<{ neighbor_id: number; relation: string }>;\n\n    const relatedMemoryIds: number[] = [];\n    const edgeTypes = new Set<string>();\n    const seedIdSet = new Set(seedRows.map((r) => r.id));\n\n    for (const row of neighborRows) {\n      if (!seedIdSet.has(row.neighbor_id) && Number.isFinite(row.neighbor_id)) {\n        relatedMemoryIds.push(row.neighbor_id);\n      }\n      if (row.relation) {\n        edgeTypes.add(row.relation);\n      }\n    }\n\n    return {\n      activated: true,\n      matchedConcepts: routing.concepts,\n      relatedMemoryIds: [...new Set(relatedMemoryIds)].slice(0, 10),\n      edgeTypes: Array.from(edgeTypes),\n    };\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-boost] injectGraphContext failed (fail-open): ${message}`);\n    return empty;\n  }\n}\n\nexport {\n  MAX_HOPS,\n  MAX_BOOST_PER_HOP,\n  RELATION_WEIGHT_MULTIPLIERS,\n  // D3 Phase A exports\n  SPARSE_DENSITY_THRESHOLD,\n  SPARSE_MAX_HOPS,\n  DEFAULT_TYPED_TRAVERSAL_DEPTH,\n  INTENT_EDGE_PRIORITY,\n  DEFAULT_EDGE_PRIORITY,\n  DEFAULT_EDGE_PRIOR,\n  EDGE_PRIOR_TIERS,\n  EDGE_LABEL_ALIASES,\n  init,\n  isEnabled,\n  isTypedTraversalEnabled,\n  isSparseMode,\n  resolveSparseFirstTraversalPolicy,\n  resolveTraversalDepth,\n  resolveEdgePrior,\n  computeHopDecay,\n  computeIntentTraversalScore,\n  getIntentEdgePriorities,\n  computeIntentEdgePrior,\n  computeTraversalHopDecay,\n  computeTraversalFreshnessFactor,\n  computeIntentAwareTraversalScore,\n  getNeighborBoosts,\n  applyCausalBoost,\n  // Always-on graph context injection\n  injectGraphContext,\n};\n\nexport type {\n  RankedSearchResult,\n  CausalBoostMetadata,\n  CausalBoostOptions,\n  SparseFirstTraversalPolicy,\n  GraphContextResult,\n};","lineStart":1,"lineEnd":773,"totalLines":773,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","time":{"start":1781150579301,"end":1781150579308}},"metadata":{"openai":{"itemId":"fc_01d1432db783fd34016a2a33732f8c8191bdaa6d59411ef165"}},"id":"prt_eb4d8fa63001rsqBL78da16Syc","sessionID":"ses_14b284513ffeIITXJTJTMH97Er","messageID":"msg_eb4d8d1a0001NRTHdPmMSVF0HR"}}
{"type":"tool_use","timestamp":1781150579318,"sessionID":"ses_14b284513ffeIITXJTJTMH97Er","part":{"type":"tool","tool":"read","callID":"call_bVpviNVXz96FFXQd219dVmdr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts</path>\n<type>file</type>\n<content>\n1: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n2: // MODULE: Memo Storage\n3: // ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n4: \n5: import type Database from 'better-sqlite3';\n6: import { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n7: \n8: export interface MemoRecordInput {\n9:   componentPath: string;\n10:   inputFingerprint: string;\n11:   codeHash: string;\n12:   outputBlob: string;\n13:   computedAt?: string;\n14: }\n15: \n16: export interface MemoRecord extends MemoRecordInput {\n17:   computedAt: string;\n18: }\n19: \n20: export interface DependencyEdgeInput {\n21:   parentPath: string;\n22:   childPath: string;\n23:   kind: string;\n24: }\n25: \n26: export interface DependencyEdge extends DependencyEdgeInput {\n27:   createdAt: string;\n28: }\n29: \n30: export interface InvalidationResult {\n31:   invalidatedPaths: string[];\n32:   deletedMemoRecords: number;\n33: }\n34: \n35: function assertPath(value: string, label: string): void {\n36:   if (typeof value !== 'string' || value.trim().length === 0) {\n37:     throw new Error(`${label} must be a non-empty string`);\n38:   }\n39: }\n40: \n41: export function ensureMemoStorageSchema(database: Database.Database): void {\n42:   database.exec(`\n43:     CREATE TABLE IF NOT EXISTS memoization_records (\n44:       component_path TEXT NOT NULL,\n45:       input_fingerprint TEXT NOT NULL,\n46:       code_hash TEXT NOT NULL,\n47:       output_blob TEXT NOT NULL,\n48:       computed_at TEXT NOT NULL DEFAULT (datetime('now')),\n49:       PRIMARY KEY (component_path, input_fingerprint, code_hash)\n50:     );\n51: \n52:     CREATE TABLE IF NOT EXISTS dependency_edges (\n53:       parent_path TEXT NOT NULL,\n54:       child_path TEXT NOT NULL,\n55:       kind TEXT NOT NULL,\n56:       created_at TEXT NOT NULL DEFAULT (datetime('now')),\n57:       PRIMARY KEY (parent_path, child_path, kind),\n58:       CHECK(parent_path != child_path)\n59:     );\n60: \n61:     CREATE INDEX IF NOT EXISTS idx_memoization_records_component\n62:       ON memoization_records(component_path);\n63:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_parent\n64:       ON dependency_edges(parent_path);\n65:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_child\n66:       ON dependency_edges(child_path);\n67:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_kind\n68:       ON dependency_edges(kind);\n69:   `);\n70: }\n71: \n72: function mapMemoRow(row: {\n73:   component_path: string;\n74:   input_fingerprint: string;\n75:   code_hash: string;\n76:   output_blob: string;\n77:   computed_at: string;\n78: }): MemoRecord {\n79:   return {\n80:     componentPath: row.component_path,\n81:     inputFingerprint: row.input_fingerprint,\n82:     codeHash: row.code_hash,\n83:     outputBlob: row.output_blob,\n84:     computedAt: row.computed_at,\n85:   };\n86: }\n87: \n88: function mapEdgeRow(row: {\n89:   parent_path: string;\n90:   child_path: string;\n91:   kind: string;\n92:   created_at: string;\n93: }): DependencyEdge {\n94:   return {\n95:     parentPath: row.parent_path,\n96:     childPath: row.child_path,\n97:     kind: row.kind,\n98:     createdAt: row.created_at,\n99:   };\n100: }\n101: \n102: export class MemoStore {\n103:   private dependencyEdgeCount: number;\n104:   private readonly graphTraversal: GraphTraversal;\n105: \n106:   constructor(\n107:     private readonly database: Database.Database,\n108:     graphTraversal: GraphTraversal = new BetterSqliteGraphTraversal(database),\n109:   ) {\n110:     ensureMemoStorageSchema(database);\n111:     this.graphTraversal = graphTraversal;\n112:     this.dependencyEdgeCount = this.countDependencyEdges();\n113:   }\n114: \n115:   private countDependencyEdges(): number {\n116:     const row = this.database.prepare(`\n117:       SELECT COUNT(*) AS edge_count\n118:       FROM dependency_edges\n119:     `).get() as { edge_count: number } | undefined;\n120:     return row?.edge_count ?? 0;\n121:   }\n122: \n123:   private insertDependencyEdge(edge: DependencyEdgeInput): void {\n124:     const result = this.database.prepare(`\n125:       INSERT OR IGNORE INTO dependency_edges (parent_path, child_path, kind)\n126:       VALUES (?, ?, ?)\n127:     `).run(edge.parentPath, edge.childPath, edge.kind) as { changes: number };\n128:     if (result.changes > 0) {\n129:       this.dependencyEdgeCount += result.changes;\n130:     }\n131:   }\n132: \n133:   getMemoRecord(componentPath: string, inputFingerprint: string, codeHash: string): MemoRecord | null {\n134:     const row = this.database.prepare(`\n135:       SELECT component_path, input_fingerprint, code_hash, output_blob, computed_at\n136:       FROM memoization_records\n137:       WHERE component_path = ?\n138:         AND input_fingerprint = ?\n139:         AND code_hash = ?\n140:       LIMIT 1\n141:     `).get(componentPath, inputFingerprint, codeHash) as Parameters<typeof mapMemoRow>[0] | undefined;\n142: \n143:     return row ? mapMemoRow(row) : null;\n144:   }\n145: \n146:   upsertMemoRecord(record: MemoRecordInput): void {\n147:     assertPath(record.componentPath, 'componentPath');\n148:     assertPath(record.inputFingerprint, 'inputFingerprint');\n149:     assertPath(record.codeHash, 'codeHash');\n150:     this.database.prepare(`\n151:       INSERT INTO memoization_records (\n152:         component_path,\n153:         input_fingerprint,\n154:         code_hash,\n155:         output_blob,\n156:         computed_at\n157:       ) VALUES (?, ?, ?, ?, COALESCE(?, datetime('now')))\n158:       ON CONFLICT(component_path, input_fingerprint, code_hash) DO UPDATE SET\n159:         output_blob = excluded.output_blob,\n160:         computed_at = excluded.computed_at\n161:     `).run(\n162:       record.componentPath,\n163:       record.inputFingerprint,\n164:       record.codeHash,\n165:       record.outputBlob,\n166:       record.computedAt ?? null,\n167:     );\n168:   }\n169: \n170:   deleteMemoRecords(componentPaths: readonly string[]): number {\n171:     const paths = Array.from(new Set(componentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n172:     if (paths.length === 0) {\n173:       return 0;\n174:     }\n175: \n176:     const placeholders = paths.map(() => '?').join(', ');\n177:     const result = this.database.prepare(`\n178:       DELETE FROM memoization_records\n179:       WHERE component_path IN (${placeholders})\n180:     `).run(...paths) as { changes: number };\n181:     return result.changes;\n182:   }\n183: \n184:   listDependencyEdges(parentPath?: string): DependencyEdge[] {\n185:     const rows = parentPath\n186:       ? this.database.prepare(`\n187:           SELECT parent_path, child_path, kind, created_at\n188:           FROM dependency_edges\n189:           WHERE parent_path = ?\n190:           ORDER BY parent_path, child_path, kind\n191:         `).all(parentPath) as Parameters<typeof mapEdgeRow>[0][]\n192:       : this.database.prepare(`\n193:           SELECT parent_path, child_path, kind, created_at\n194:           FROM dependency_edges\n195:           ORDER BY parent_path, child_path, kind\n196:         `).all() as Parameters<typeof mapEdgeRow>[0][];\n197: \n198:     return rows.map(mapEdgeRow);\n199:   }\n200: \n201:   addDependencyEdge(edge: DependencyEdgeInput): void {\n202:     assertPath(edge.parentPath, 'parentPath');\n203:     assertPath(edge.childPath, 'childPath');\n204:     assertPath(edge.kind, 'kind');\n205:     if (edge.parentPath === edge.childPath) {\n206:       throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n207:     }\n208:     if (this.dependencyEdgeCount > 0 && this.wouldCreateCycle(edge.parentPath, edge.childPath)) {\n209:       throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n210:     }\n211: \n212:     this.insertDependencyEdge(edge);\n213:   }\n214: \n215:   collectDependents(parentPaths: readonly string[]): string[] {\n216:     const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n217:     if (roots.length === 0 || this.dependencyEdgeCount === 0) {\n218:       return [];\n219:     }\n220: \n221:     return this.graphTraversal.collectDependencyReachability(roots).sort();\n222:   }\n223: \n224:   invalidateDependents(parentPaths: readonly string[], includeSources = false): InvalidationResult {\n225:     const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n226:     const invalidatedPaths = this.collectDependents(roots);\n227:     const deleteTargets = includeSources ? Array.from(new Set([...roots, ...invalidatedPaths])) : invalidatedPaths;\n228:     const deletedMemoRecords = this.deleteMemoRecords(deleteTargets);\n229:     return { invalidatedPaths, deletedMemoRecords };\n230:   }\n231: \n232:   private wouldCreateCycle(parentPath: string, childPath: string): boolean {\n233:     if (parentPath === childPath) {\n234:       return true;\n235:     }\n236: \n237:     return this.collectDependents([childPath]).includes(parentPath);\n238:   }\n239: }\n240: \n241: export function createMemoStore(\n242:   database: Database.Database,\n243:   graphTraversal?: GraphTraversal,\n244: ): MemoStore {\n245:   return new MemoStore(database, graphTraversal);\n246: }\n\n(End of file - total 246 lines)\n</content>","metadata":{"preview":"// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// MODULE: Memo Storage\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\nimport type Database from 'better-sqlite3';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n\nexport interface MemoRecordInput {\n  componentPath: string;\n  inputFingerprint: string;\n  codeHash: string;\n  outputBlob: string;\n  computedAt?: string;\n}\n\nexport interface MemoRecord extends MemoRecordInput {\n  computedAt: string;\n}\n\nexport interface DependencyEdgeInput {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","text":"// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n// MODULE: Memo Storage\n// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n\nimport type Database from 'better-sqlite3';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n\nexport interface MemoRecordInput {\n  componentPath: string;\n  inputFingerprint: string;\n  codeHash: string;\n  outputBlob: string;\n  computedAt?: string;\n}\n\nexport interface MemoRecord extends MemoRecordInput {\n  computedAt: string;\n}\n\nexport interface DependencyEdgeInput {\n  parentPath: string;\n  childPath: string;\n  kind: string;\n}\n\nexport interface DependencyEdge extends DependencyEdgeInput {\n  createdAt: string;\n}\n\nexport interface InvalidationResult {\n  invalidatedPaths: string[];\n  deletedMemoRecords: number;\n}\n\nfunction assertPath(value: string, label: string): void {\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    throw new Error(`${label} must be a non-empty string`);\n  }\n}\n\nexport function ensureMemoStorageSchema(database: Database.Database): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS memoization_records (\n      component_path TEXT NOT NULL,\n      input_fingerprint TEXT NOT NULL,\n      code_hash TEXT NOT NULL,\n      output_blob TEXT NOT NULL,\n      computed_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (component_path, input_fingerprint, code_hash)\n    );\n\n    CREATE TABLE IF NOT EXISTS dependency_edges (\n      parent_path TEXT NOT NULL,\n      child_path TEXT NOT NULL,\n      kind TEXT NOT NULL,\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (parent_path, child_path, kind),\n      CHECK(parent_path != child_path)\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_memoization_records_component\n      ON memoization_records(component_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_parent\n      ON dependency_edges(parent_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_child\n      ON dependency_edges(child_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_kind\n      ON dependency_edges(kind);\n  `);\n}\n\nfunction mapMemoRow(row: {\n  component_path: string;\n  input_fingerprint: string;\n  code_hash: string;\n  output_blob: string;\n  computed_at: string;\n}): MemoRecord {\n  return {\n    componentPath: row.component_path,\n    inputFingerprint: row.input_fingerprint,\n    codeHash: row.code_hash,\n    outputBlob: row.output_blob,\n    computedAt: row.computed_at,\n  };\n}\n\nfunction mapEdgeRow(row: {\n  parent_path: string;\n  child_path: string;\n  kind: string;\n  created_at: string;\n}): DependencyEdge {\n  return {\n    parentPath: row.parent_path,\n    childPath: row.child_path,\n    kind: row.kind,\n    createdAt: row.created_at,\n  };\n}\n\nexport class MemoStore {\n  private dependencyEdgeCount: number;\n  private readonly graphTraversal: GraphTraversal;\n\n  constructor(\n    private readonly database: Database.Database,\n    graphTraversal: GraphTraversal = new BetterSqliteGraphTraversal(database),\n  ) {\n    ensureMemoStorageSchema(database);\n    this.graphTraversal = graphTraversal;\n    this.dependencyEdgeCount = this.countDependencyEdges();\n  }\n\n  private countDependencyEdges(): number {\n    const row = this.database.prepare(`\n      SELECT COUNT(*) AS edge_count\n      FROM dependency_edges\n    `).get() as { edge_count: number } | undefined;\n    return row?.edge_count ?? 0;\n  }\n\n  private insertDependencyEdge(edge: DependencyEdgeInput): void {\n    const result = this.database.prepare(`\n      INSERT OR IGNORE INTO dependency_edges (parent_path, child_path, kind)\n      VALUES (?, ?, ?)\n    `).run(edge.parentPath, edge.childPath, edge.kind) as { changes: number };\n    if (result.changes > 0) {\n      this.dependencyEdgeCount += result.changes;\n    }\n  }\n\n  getMemoRecord(componentPath: string, inputFingerprint: string, codeHash: string): MemoRecord | null {\n    const row = this.database.prepare(`\n      SELECT component_path, input_fingerprint, code_hash, output_blob, computed_at\n      FROM memoization_records\n      WHERE component_path = ?\n        AND input_fingerprint = ?\n        AND code_hash = ?\n      LIMIT 1\n    `).get(componentPath, inputFingerprint, codeHash) as Parameters<typeof mapMemoRow>[0] | undefined;\n\n    return row ? mapMemoRow(row) : null;\n  }\n\n  upsertMemoRecord(record: MemoRecordInput): void {\n    assertPath(record.componentPath, 'componentPath');\n    assertPath(record.inputFingerprint, 'inputFingerprint');\n    assertPath(record.codeHash, 'codeHash');\n    this.database.prepare(`\n      INSERT INTO memoization_records (\n        component_path,\n        input_fingerprint,\n        code_hash,\n        output_blob,\n        computed_at\n      ) VALUES (?, ?, ?, ?, COALESCE(?, datetime('now')))\n      ON CONFLICT(component_path, input_fingerprint, code_hash) DO UPDATE SET\n        output_blob = excluded.output_blob,\n        computed_at = excluded.computed_at\n    `).run(\n      record.componentPath,\n      record.inputFingerprint,\n      record.codeHash,\n      record.outputBlob,\n      record.computedAt ?? null,\n    );\n  }\n\n  deleteMemoRecords(componentPaths: readonly string[]): number {\n    const paths = Array.from(new Set(componentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    if (paths.length === 0) {\n      return 0;\n    }\n\n    const placeholders = paths.map(() => '?').join(', ');\n    const result = this.database.prepare(`\n      DELETE FROM memoization_records\n      WHERE component_path IN (${placeholders})\n    `).run(...paths) as { changes: number };\n    return result.changes;\n  }\n\n  listDependencyEdges(parentPath?: string): DependencyEdge[] {\n    const rows = parentPath\n      ? this.database.prepare(`\n          SELECT parent_path, child_path, kind, created_at\n          FROM dependency_edges\n          WHERE parent_path = ?\n          ORDER BY parent_path, child_path, kind\n        `).all(parentPath) as Parameters<typeof mapEdgeRow>[0][]\n      : this.database.prepare(`\n          SELECT parent_path, child_path, kind, created_at\n          FROM dependency_edges\n          ORDER BY parent_path, child_path, kind\n        `).all() as Parameters<typeof mapEdgeRow>[0][];\n\n    return rows.map(mapEdgeRow);\n  }\n\n  addDependencyEdge(edge: DependencyEdgeInput): void {\n    assertPath(edge.parentPath, 'parentPath');\n    assertPath(edge.childPath, 'childPath');\n    assertPath(edge.kind, 'kind');\n    if (edge.parentPath === edge.childPath) {\n      throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n    }\n    if (this.dependencyEdgeCount > 0 && this.wouldCreateCycle(edge.parentPath, edge.childPath)) {\n      throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n    }\n\n    this.insertDependencyEdge(edge);\n  }\n\n  collectDependents(parentPaths: readonly string[]): string[] {\n    const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    if (roots.length === 0 || this.dependencyEdgeCount === 0) {\n      return [];\n    }\n\n    return this.graphTraversal.collectDependencyReachability(roots).sort();\n  }\n\n  invalidateDependents(parentPaths: readonly string[], includeSources = false): InvalidationResult {\n    const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    const invalidatedPaths = this.collectDependents(roots);\n    const deleteTargets = includeSources ? Array.from(new Set([...roots, ...invalidatedPaths])) : invalidatedPaths;\n    const deletedMemoRecords = this.deleteMemoRecords(deleteTargets);\n    return { invalidatedPaths, deletedMemoRecords };\n  }\n\n  private wouldCreateCycle(parentPath: string, childPath: string): boolean {\n    if (parentPath === childPath) {\n      return true;\n    }\n\n    return this.collectDependents([childPath]).includes(parentPath);\n  }\n}\n\nexport function createMemoStore(\n  database: Database.Database,\n  graphTraversal?: GraphTraversal,\n): MemoStore {\n  return new MemoStore(database, graphTraversal);\n}","lineStart":1,"lineEnd":246,"totalLines":246,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","time":{"start":1781150579306,"end":1781150579317}},"metadata":{"openai":{"itemId":"fc_01d1432db783fd34016a2a33732f9881919329440a3c3dd161"}},"id":"prt_eb4d8fa69001JGA2oBpcT9a1xR","sessionID":"ses_14b284513ffeIITXJTJTMH97Er","messageID":"msg_eb4d8d1a0001NRTHdPmMSVF0HR"}}
{"type":"tool_use","timestamp":1781150579320,"sessionID":"ses_14b284513ffeIITXJTJTMH97Er","part":{"type":"tool","tool":"read","callID":"call_0ReTJz5W54YcggFXGUZuDiB0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts</path>\n<type>file</type>\n<content>\n1: // TEST: CAUSAL TRAVERSAL BFS EQUIVALENCE\n2: import { describe, expect, it, vi } from 'vitest';\n3: import Database from 'better-sqlite3';\n4: \n5: import {\n6:   collectCausalWeightedNeighbors,\n7:   collectDependencyReachability,\n8: } from '../lib/graph/bfs-traversal';\n9: import { RELATION_WEIGHT_MULTIPLIERS, getNeighborBoosts, init as initCausalBoost } from '../lib/search/causal-boost';\n10: import { createMemoStore } from '../lib/storage/memo';\n11: \n12: interface CausalSnapshotRow {\n13:   readonly node_id: string;\n14:   readonly min_hop: number;\n15:   readonly max_walk_score: number;\n16: }\n17: \n18: interface DependencySnapshotRow {\n19:   readonly child_path: string;\n20: }\n21: \n22: function createCausalDb(): Database.Database {\n23:   const db = new Database(':memory:');\n24:   db.exec(`\n25:     CREATE TABLE causal_edges (\n26:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n27:       source_id TEXT NOT NULL,\n28:       target_id TEXT NOT NULL,\n29:       relation TEXT NOT NULL,\n30:       strength REAL DEFAULT 1.0\n31:     );\n32:     CREATE INDEX idx_causal_edges_source ON causal_edges(source_id);\n33:     CREATE INDEX idx_causal_edges_target ON causal_edges(target_id);\n34:   `);\n35:   return db;\n36: }\n37: \n38: function createMemoDb(): Database.Database {\n39:   return new Database(':memory:');\n40: }\n41: \n42: function insertFixtureEdges(db: Database.Database): void {\n43:   const relations = ['caused', 'supports', 'supersedes', 'contradicts', 'enabled', 'derived_from'];\n44:   const insert = db.prepare(`\n45:     INSERT INTO causal_edges (source_id, target_id, relation, strength)\n46:     VALUES (?, ?, ?, ?)\n47:   `);\n48:   const insertMany = db.transaction(() => {\n49:     for (let nodeId = 1; nodeId <= 1024; nodeId++) {\n50:       for (let offset = 1; offset <= 10; offset++) {\n51:         const targetId = ((nodeId + offset - 1) % 1024) + 1;\n52:         const relation = relations[(nodeId + offset) % relations.length] ?? 'caused';\n53:         const strength = 0.5 + ((nodeId + offset) % 4) * 0.25;\n54:         insert.run(String(nodeId), String(targetId), relation, strength);\n55:       }\n56:     }\n57:   });\n58:   insertMany();\n59: }\n60: \n61: function cteCausalWalk(db: Database.Database, seeds: readonly number[], maxHops: number): Map<number, { minHop: number; maxWalkScore: number }> {\n62:   const originIds = seeds.map((value) => String(value));\n63:   const placeholders = originIds.map(() => '?').join(', ');\n64:   const rows = db.prepare(`\n65:     WITH RECURSIVE causal_walk(origin_id, node_id, hop_distance, walk_score) AS (\n66:       SELECT ce.source_id, ce.target_id, 1,\n67:              (CASE WHEN ce.relation = 'supersedes' THEN 1.5\n68:                    WHEN ce.relation = 'contradicts' THEN 0.8\n69:                    ELSE 1.0 END * COALESCE(ce.strength, 1.0))\n70:       FROM causal_edges ce\n71:       WHERE ce.source_id IN (${placeholders})\n72: \n73:       UNION\n74: \n75:       SELECT ce.target_id, ce.source_id, 1,\n76:              (CASE WHEN ce.relation = 'supersedes' THEN 1.5\n77:                    WHEN ce.relation = 'contradicts' THEN 0.8\n78:                    ELSE 1.0 END * COALESCE(ce.strength, 1.0))\n79:       FROM causal_edges ce\n80:       WHERE ce.target_id IN (${placeholders})\n81: \n82:       UNION\n83: \n84:       SELECT cw.origin_id,\n85:              CASE\n86:                WHEN ce.source_id = cw.node_id THEN ce.target_id\n87:                ELSE ce.source_id\n88:              END,\n89:              cw.hop_distance + 1,\n90:              (cw.walk_score * CASE WHEN ce.relation = 'supersedes' THEN 1.5\n91:                                    WHEN ce.relation = 'contradicts' THEN 0.8\n92:                                    ELSE 1.0 END * COALESCE(ce.strength, 1.0))\n93:       FROM causal_walk cw\n94:       JOIN causal_edges ce\n95:         ON ce.source_id = cw.node_id OR ce.target_id = cw.node_id\n96:       WHERE cw.hop_distance < ?\n97:         AND (CASE WHEN ce.source_id = cw.node_id THEN ce.target_id ELSE ce.source_id END) != cw.origin_id\n98:     )\n99:     SELECT node_id, MIN(hop_distance) AS min_hop, MAX(walk_score) AS max_walk_score\n100:     FROM causal_walk\n101:     WHERE node_id NOT IN (${placeholders})\n102:     GROUP BY node_id\n103:     ORDER BY CAST(node_id AS INTEGER)\n104:   `).all(\n105:     ...originIds,\n106:     ...originIds,\n107:     maxHops,\n108:     ...originIds,\n109:   ) as CausalSnapshotRow[];\n110: \n111:   return new Map(rows.map((row) => [\n112:     Number.parseInt(row.node_id, 10),\n113:     { minHop: row.min_hop, maxWalkScore: row.max_walk_score },\n114:   ]));\n115: }\n116: \n117: function cteDependents(db: Database.Database, roots: readonly string[]): string[] {\n118:   const placeholders = roots.map(() => '?').join(', ');\n119:   const rows = db.prepare(`\n120:     WITH RECURSIVE dependents(child_path) AS (\n121:       SELECT child_path\n122:       FROM dependency_edges\n123:       WHERE parent_path IN (${placeholders})\n124:       UNION\n125:       SELECT edge.child_path\n126:       FROM dependency_edges edge\n127:       JOIN dependents dep ON edge.parent_path = dep.child_path\n128:     )\n129:     SELECT DISTINCT child_path\n130:     FROM dependents\n131:     ORDER BY child_path\n132:   `).all(...roots) as DependencySnapshotRow[];\n133:   return rows.map((row) => row.child_path);\n134: }\n135: \n136: function causalSnapshot(map: Map<number, { minHop: number; maxWalkScore: number }>): Array<[number, number, number]> {\n137:   return Array.from(map.entries())\n138:     .map(([nodeId, row]) => [nodeId, row.minHop, row.maxWalkScore] as [number, number, number])\n139:     .sort((left, right) => left[0] - right[0]);\n140: }\n141: \n142: function measureMs(callback: () => unknown, iterations: number): number {\n143:   const started = performance.now();\n144:   for (let index = 0; index < iterations; index++) {\n145:     callback();\n146:   }\n147:   return Number(((performance.now() - started) / iterations).toFixed(3));\n148: }\n149: \n150: describe('causal traversal BFS equivalence', () => {\n151:   it('matches recursive CTE weighted-walk output exactly on live-shaped fixtures', () => {\n152:     const db = createCausalDb();\n153:     try {\n154:       insertFixtureEdges(db);\n155:       const seeds = [1, 8, 33, 144, 377];\n156:       const expected = cteCausalWalk(db, seeds, 2);\n157:       const actual = collectCausalWeightedNeighbors(db, seeds, 2, RELATION_WEIGHT_MULTIPLIERS);\n158: \n159:       expect(causalSnapshot(actual)).toEqual(causalSnapshot(expected));\n160:       expect(causalSnapshot(actual).some(([, , score]) => score !== 1)).toBe(true);\n161:       for (const seed of seeds) {\n162:         expect(actual.has(seed)).toBe(false);\n163:       }\n164:     } finally {\n165:       db.close();\n166:     }\n167:   });\n168: \n169:   it('keeps getNeighborBoosts behavior equivalent to the weighted-walk snapshot', () => {\n170:     const db = createCausalDb();\n171:     try {\n172:       db.prepare(`\n173:         INSERT INTO causal_edges (source_id, target_id, relation, strength)\n174:         VALUES ('1', '2', 'supersedes', 1.0), ('2', '3', 'contradicts', 1.0), ('3', '4', 'caused', 0.5)\n175:       `).run();\n176:       initCausalBoost(db);\n177: \n178:       const cteRows = cteCausalWalk(db, [1], 2);\n179:       const boosts = getNeighborBoosts([1], 2);\n180: \n181:       for (const [nodeId, row] of cteRows) {\n182:         const walkMultiplier = Math.max(0.1, Math.min(2.0, row.maxWalkScore));\n183:         const expectedBoost = Math.min(0.05, 0.05 / row.minHop) * walkMultiplier;\n184:         expect(boosts.get(nodeId)?.boost).toBe(expectedBoost);\n185:         expect(boosts.get(nodeId)?.hopCount).toBe(row.minHop);\n186:       }\n187:     } finally {\n188:       db.close();\n189:     }\n190:   });\n191: \n192:   it('matches recursive CTE directed reachability and skips cycle checks for an empty edge table', () => {\n193:     const db = createMemoDb();\n194:     try {\n195:       const store = createMemoStore(db);\n196:       const prepareSpy = vi.spyOn(db, 'prepare');\n197: \n198:       store.addDependencyEdge({ parentPath: 'root', childPath: 'child-a', kind: 'derived' });\n199: \n200:       const selectAfterConstruction = prepareSpy.mock.calls\n201:         .map(([source]) => String(source))\n202:         .filter((source) => /^\\s*SELECT/i.test(source));\n203:       expect(selectAfterConstruction).toHaveLength(0);\n204: \n205:       store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n206:       store.addDependencyEdge({ parentPath: 'root', childPath: 'child-c', kind: 'derived' });\n207: \n208:       const expected = cteDependents(db, ['root']);\n209:       const actual = collectDependencyReachability(db, ['root']).sort();\n210:       expect(actual).toEqual(expected);\n211:       expect(store.collectDependents(['root'])).toEqual(expected);\n212:       expect(() => store.addDependencyEdge({ parentPath: 'child-b', childPath: 'root', kind: 'derived' }))\n213:         .toThrow(/cycle/);\n214:     } finally {\n215:       db.close();\n216:     }\n217:   });\n218: \n219:   it('records BFS latency at or below the recursive CTE on the live-shaped fixture', () => {\n220:     const db = createCausalDb();\n221:     try {\n222:       insertFixtureEdges(db);\n223:       const seeds = [1, 8, 33, 144, 377];\n224:       const iterations = 25;\n225: \n226:       const cteMs = measureMs(() => cteCausalWalk(db, seeds, 2), iterations);\n227:       const bfsMs = measureMs(\n228:         () => collectCausalWeightedNeighbors(db, seeds, 2, RELATION_WEIGHT_MULTIPLIERS),\n229:         iterations,\n230:       );\n231: \n232:       console.info(`BFS traversal benchmark: fixture_edges=10240 max_degree=20 seeds=5 hops=2 cte_ms=${cteMs} bfs_ms=${bfsMs}`);\n233:       expect(bfsMs).toBeLessThanOrEqual(cteMs);\n234:     } finally {\n235:       db.close();\n236:     }\n237:   });\n238: });\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"// TEST: CAUSAL TRAVERSAL BFS EQUIVALENCE\nimport { describe, expect, it, vi } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n} from '../lib/graph/bfs-traversal';\nimport { RELATION_WEIGHT_MULTIPLIERS, getNeighborBoosts, init as initCausalBoost } from '../lib/search/causal-boost';\nimport { createMemoStore } from '../lib/storage/memo';\n\ninterface CausalSnapshotRow {\n  readonly node_id: string;\n  readonly min_hop: number;\n  readonly max_walk_score: number;\n}\n\ninterface DependencySnapshotRow {\n  readonly child_path: string;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts","text":"// TEST: CAUSAL TRAVERSAL BFS EQUIVALENCE\nimport { describe, expect, it, vi } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n} from '../lib/graph/bfs-traversal';\nimport { RELATION_WEIGHT_MULTIPLIERS, getNeighborBoosts, init as initCausalBoost } from '../lib/search/causal-boost';\nimport { createMemoStore } from '../lib/storage/memo';\n\ninterface CausalSnapshotRow {\n  readonly node_id: string;\n  readonly min_hop: number;\n  readonly max_walk_score: number;\n}\n\ninterface DependencySnapshotRow {\n  readonly child_path: string;\n}\n\nfunction createCausalDb(): Database.Database {\n  const db = new Database(':memory:');\n  db.exec(`\n    CREATE TABLE causal_edges (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      source_id TEXT NOT NULL,\n      target_id TEXT NOT NULL,\n      relation TEXT NOT NULL,\n      strength REAL DEFAULT 1.0\n    );\n    CREATE INDEX idx_causal_edges_source ON causal_edges(source_id);\n    CREATE INDEX idx_causal_edges_target ON causal_edges(target_id);\n  `);\n  return db;\n}\n\nfunction createMemoDb(): Database.Database {\n  return new Database(':memory:');\n}\n\nfunction insertFixtureEdges(db: Database.Database): void {\n  const relations = ['caused', 'supports', 'supersedes', 'contradicts', 'enabled', 'derived_from'];\n  const insert = db.prepare(`\n    INSERT INTO causal_edges (source_id, target_id, relation, strength)\n    VALUES (?, ?, ?, ?)\n  `);\n  const insertMany = db.transaction(() => {\n    for (let nodeId = 1; nodeId <= 1024; nodeId++) {\n      for (let offset = 1; offset <= 10; offset++) {\n        const targetId = ((nodeId + offset - 1) % 1024) + 1;\n        const relation = relations[(nodeId + offset) % relations.length] ?? 'caused';\n        const strength = 0.5 + ((nodeId + offset) % 4) * 0.25;\n        insert.run(String(nodeId), String(targetId), relation, strength);\n      }\n    }\n  });\n  insertMany();\n}\n\nfunction cteCausalWalk(db: Database.Database, seeds: readonly number[], maxHops: number): Map<number, { minHop: number; maxWalkScore: number }> {\n  const originIds = seeds.map((value) => String(value));\n  const placeholders = originIds.map(() => '?').join(', ');\n  const rows = db.prepare(`\n    WITH RECURSIVE causal_walk(origin_id, node_id, hop_distance, walk_score) AS (\n      SELECT ce.source_id, ce.target_id, 1,\n             (CASE WHEN ce.relation = 'supersedes' THEN 1.5\n                   WHEN ce.relation = 'contradicts' THEN 0.8\n                   ELSE 1.0 END * COALESCE(ce.strength, 1.0))\n      FROM causal_edges ce\n      WHERE ce.source_id IN (${placeholders})\n\n      UNION\n\n      SELECT ce.target_id, ce.source_id, 1,\n             (CASE WHEN ce.relation = 'supersedes' THEN 1.5\n                   WHEN ce.relation = 'contradicts' THEN 0.8\n                   ELSE 1.0 END * COALESCE(ce.strength, 1.0))\n      FROM causal_edges ce\n      WHERE ce.target_id IN (${placeholders})\n\n      UNION\n\n      SELECT cw.origin_id,\n             CASE\n               WHEN ce.source_id = cw.node_id THEN ce.target_id\n               ELSE ce.source_id\n             END,\n             cw.hop_distance + 1,\n             (cw.walk_score * CASE WHEN ce.relation = 'supersedes' THEN 1.5\n                                   WHEN ce.relation = 'contradicts' THEN 0.8\n                                   ELSE 1.0 END * COALESCE(ce.strength, 1.0))\n      FROM causal_walk cw\n      JOIN causal_edges ce\n        ON ce.source_id = cw.node_id OR ce.target_id = cw.node_id\n      WHERE cw.hop_distance < ?\n        AND (CASE WHEN ce.source_id = cw.node_id THEN ce.target_id ELSE ce.source_id END) != cw.origin_id\n    )\n    SELECT node_id, MIN(hop_distance) AS min_hop, MAX(walk_score) AS max_walk_score\n    FROM causal_walk\n    WHERE node_id NOT IN (${placeholders})\n    GROUP BY node_id\n    ORDER BY CAST(node_id AS INTEGER)\n  `).all(\n    ...originIds,\n    ...originIds,\n    maxHops,\n    ...originIds,\n  ) as CausalSnapshotRow[];\n\n  return new Map(rows.map((row) => [\n    Number.parseInt(row.node_id, 10),\n    { minHop: row.min_hop, maxWalkScore: row.max_walk_score },\n  ]));\n}\n\nfunction cteDependents(db: Database.Database, roots: readonly string[]): string[] {\n  const placeholders = roots.map(() => '?').join(', ');\n  const rows = db.prepare(`\n    WITH RECURSIVE dependents(child_path) AS (\n      SELECT child_path\n      FROM dependency_edges\n      WHERE parent_path IN (${placeholders})\n      UNION\n      SELECT edge.child_path\n      FROM dependency_edges edge\n      JOIN dependents dep ON edge.parent_path = dep.child_path\n    )\n    SELECT DISTINCT child_path\n    FROM dependents\n    ORDER BY child_path\n  `).all(...roots) as DependencySnapshotRow[];\n  return rows.map((row) => row.child_path);\n}\n\nfunction causalSnapshot(map: Map<number, { minHop: number; maxWalkScore: number }>): Array<[number, number, number]> {\n  return Array.from(map.entries())\n    .map(([nodeId, row]) => [nodeId, row.minHop, row.maxWalkScore] as [number, number, number])\n    .sort((left, right) => left[0] - right[0]);\n}\n\nfunction measureMs(callback: () => unknown, iterations: number): number {\n  const started = performance.now();\n  for (let index = 0; index < iterations; index++) {\n    callback();\n  }\n  return Number(((performance.now() - started) / iterations).toFixed(3));\n}\n\ndescribe('causal traversal BFS equivalence', () => {\n  it('matches recursive CTE weighted-walk output exactly on live-shaped fixtures', () => {\n    const db = createCausalDb();\n    try {\n      insertFixtureEdges(db);\n      const seeds = [1, 8, 33, 144, 377];\n      const expected = cteCausalWalk(db, seeds, 2);\n      const actual = collectCausalWeightedNeighbors(db, seeds, 2, RELATION_WEIGHT_MULTIPLIERS);\n\n      expect(causalSnapshot(actual)).toEqual(causalSnapshot(expected));\n      expect(causalSnapshot(actual).some(([, , score]) => score !== 1)).toBe(true);\n      for (const seed of seeds) {\n        expect(actual.has(seed)).toBe(false);\n      }\n    } finally {\n      db.close();\n    }\n  });\n\n  it('keeps getNeighborBoosts behavior equivalent to the weighted-walk snapshot', () => {\n    const db = createCausalDb();\n    try {\n      db.prepare(`\n        INSERT INTO causal_edges (source_id, target_id, relation, strength)\n        VALUES ('1', '2', 'supersedes', 1.0), ('2', '3', 'contradicts', 1.0), ('3', '4', 'caused', 0.5)\n      `).run();\n      initCausalBoost(db);\n\n      const cteRows = cteCausalWalk(db, [1], 2);\n      const boosts = getNeighborBoosts([1], 2);\n\n      for (const [nodeId, row] of cteRows) {\n        const walkMultiplier = Math.max(0.1, Math.min(2.0, row.maxWalkScore));\n        const expectedBoost = Math.min(0.05, 0.05 / row.minHop) * walkMultiplier;\n        expect(boosts.get(nodeId)?.boost).toBe(expectedBoost);\n        expect(boosts.get(nodeId)?.hopCount).toBe(row.minHop);\n      }\n    } finally {\n      db.close();\n    }\n  });\n\n  it('matches recursive CTE directed reachability and skips cycle checks for an empty edge table', () => {\n    const db = createMemoDb();\n    try {\n      const store = createMemoStore(db);\n      const prepareSpy = vi.spyOn(db, 'prepare');\n\n      store.addDependencyEdge({ parentPath: 'root', childPath: 'child-a', kind: 'derived' });\n\n      const selectAfterConstruction = prepareSpy.mock.calls\n        .map(([source]) => String(source))\n        .filter((source) => /^\\s*SELECT/i.test(source));\n      expect(selectAfterConstruction).toHaveLength(0);\n\n      store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n      store.addDependencyEdge({ parentPath: 'root', childPath: 'child-c', kind: 'derived' });\n\n      const expected = cteDependents(db, ['root']);\n      const actual = collectDependencyReachability(db, ['root']).sort();\n      expect(actual).toEqual(expected);\n      expect(store.collectDependents(['root'])).toEqual(expected);\n      expect(() => store.addDependencyEdge({ parentPath: 'child-b', childPath: 'root', kind: 'derived' }))\n        .toThrow(/cycle/);\n    } finally {\n      db.close();\n    }\n  });\n\n  it('records BFS latency at or below the recursive CTE on the live-shaped fixture', () => {\n    const db = createCausalDb();\n    try {\n      insertFixtureEdges(db);\n      const seeds = [1, 8, 33, 144, 377];\n      const iterations = 25;\n\n      const cteMs = measureMs(() => cteCausalWalk(db, seeds, 2), iterations);\n      const bfsMs = measureMs(\n        () => collectCausalWeightedNeighbors(db, seeds, 2, RELATION_WEIGHT_MULTIPLIERS),\n        iterations,\n      );\n\n      console.info(`BFS traversal benchmark: fixture_edges=10240 max_degree=20 seeds=5 hops=2 cte_ms=${cteMs} bfs_ms=${bfsMs}`);\n      expect(bfsMs).toBeLessThanOrEqual(cteMs);\n    } finally {\n      db.close();\n    }\n  });\n});","lineStart":1,"lineEnd":238,"totalLines":238,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts","time":{"start":1781150579311,"end":1781150579319}},"metadata":{"openai":{"itemId":"fc_01d1432db783fd34016a2a33732fa08191b7f43a1b1b881404"}},"id":"prt_eb4d8fa6b001xB3T7By7EG212X","sessionID":"ses_14b284513ffeIITXJTJTMH97Er","messageID":"msg_eb4d8d1a0001NRTHdPmMSVF0HR"}}
