{"type":"tool_use","timestamp":1780929146917,"sessionID":"ses_1585c7ef3ffeE8bQgxmNtEsbEj","part":{"type":"tool","tool":"read","callID":"call_TVFgmFhvcH1VzYV3Z3mSLxz3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/types.ts","offset":80,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/types.ts</path>\n<type>file</type>\n<content>\n80: // --- Phase 2: Provenance + Audit ---\n81: \n82: export type ProvenanceSourceType =\n83:   | \"learn\" | \"git-backfill\" | \"evaluate-session\" | \"import-bundle\"\n84:   | \"user-promotion\" | \"janitor-rollup\" | \"legacy\";\n85: \n86: export type AuditOp =\n87:   | \"insert\" | \"update\" | \"forget\" | \"deprecate\" | \"supersede\" | \"redact\" | \"restore\" | \"archive\";\n88: \n89: export interface ProvenanceRow {\n90:   id: number;\n91:   memory_id: number;\n92:   source_type: ProvenanceSourceType;\n93:   source_ref: string | null;\n94:   actor: string | null;\n95:   created_at: string;\n96:   metadata: string | null;\n97: }\n98: \n99: export interface ProvenanceInput {\n100:   memory_id: number;\n101:   source_type: ProvenanceSourceType;\n102:   source_ref?: string | null;\n103:   actor?: string | null;\n104:   metadata?: string | null;\n105: }\n106: \n107: export interface AuditRow {\n108:   id: number;\n109:   memory_id: number;\n110:   op: AuditOp;\n111:   actor: string;\n112:   session_id: string | null;\n113:   before_json: string | null;\n114:   after_json: string | null;\n115:   created_at: string;\n116: }\n117: \n118: export interface AuditInput {\n119:   memory_id: number;\n120:   op: AuditOp;\n121:   actor: string;\n122:   session_id?: string | null;\n123:   before_json?: string | null;\n124:   after_json?: string | null;\n125: }\n126: \n127: /**\n128:  * JSON-safe memory snapshot — excludes embedding blob. Used for audit before/after captures.\n129:  * Same shape as MemorySlim but with category/status widened to string (SQLite returns raw strings).\n130:  */\n131: export type MemorySnapshot = Omit<MemorySlim, \"category\" | \"status\"> & {\n132:   category: string;\n133:   status: string;\n134: };\n135: \n136: /** A superseded-memory conflict row returned by getRecentConflicts(). */\n137: export interface ConflictRow {\n138:   olderId: number;\n139:   olderContent: string;\n140:   newerId: number;\n141:   newerContent: string;\n142: }\n\n(End of file - total 142 lines)\n</content>","metadata":{"preview":"// --- Phase 2: Provenance + Audit ---\n\nexport type ProvenanceSourceType =\n  | \"learn\" | \"git-backfill\" | \"evaluate-session\" | \"import-bundle\"\n  | \"user-promotion\" | \"janitor-rollup\" | \"legacy\";\n\nexport type AuditOp =\n  | \"insert\" | \"update\" | \"forget\" | \"deprecate\" | \"supersede\" | \"redact\" | \"restore\" | \"archive\";\n\nexport interface ProvenanceRow {\n  id: number;\n  memory_id: number;\n  source_type: ProvenanceSourceType;\n  source_ref: string | null;\n  actor: string | null;\n  created_at: string;\n  metadata: string | null;\n}\n\nexport interface ProvenanceInput {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/types.ts","text":"// --- Phase 2: Provenance + Audit ---\n\nexport type ProvenanceSourceType =\n  | \"learn\" | \"git-backfill\" | \"evaluate-session\" | \"import-bundle\"\n  | \"user-promotion\" | \"janitor-rollup\" | \"legacy\";\n\nexport type AuditOp =\n  | \"insert\" | \"update\" | \"forget\" | \"deprecate\" | \"supersede\" | \"redact\" | \"restore\" | \"archive\";\n\nexport interface ProvenanceRow {\n  id: number;\n  memory_id: number;\n  source_type: ProvenanceSourceType;\n  source_ref: string | null;\n  actor: string | null;\n  created_at: string;\n  metadata: string | null;\n}\n\nexport interface ProvenanceInput {\n  memory_id: number;\n  source_type: ProvenanceSourceType;\n  source_ref?: string | null;\n  actor?: string | null;\n  metadata?: string | null;\n}\n\nexport interface AuditRow {\n  id: number;\n  memory_id: number;\n  op: AuditOp;\n  actor: string;\n  session_id: string | null;\n  before_json: string | null;\n  after_json: string | null;\n  created_at: string;\n}\n\nexport interface AuditInput {\n  memory_id: number;\n  op: AuditOp;\n  actor: string;\n  session_id?: string | null;\n  before_json?: string | null;\n  after_json?: string | null;\n}\n\n/**\n * JSON-safe memory snapshot — excludes embedding blob. Used for audit before/after captures.\n * Same shape as MemorySlim but with category/status widened to string (SQLite returns raw strings).\n */\nexport type MemorySnapshot = Omit<MemorySlim, \"category\" | \"status\"> & {\n  category: string;\n  status: string;\n};\n\n/** A superseded-memory conflict row returned by getRecentConflicts(). */\nexport interface ConflictRow {\n  olderId: number;\n  olderContent: string;\n  newerId: number;\n  newerContent: string;\n}","lineStart":80,"lineEnd":142,"totalLines":142,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/types.ts","time":{"start":1780929146901,"end":1780929146914}},"metadata":{"openai":{"itemId":"fc_0b77effdf1aec047016a26d27714b481919b692acaf5e22ebd"}},"id":"prt_ea7a6213b00134LdM1dWDM6TN2","sessionID":"ses_1585c7ef3ffeE8bQgxmNtEsbEj","messageID":"msg_ea7a6131c001k5Je2UK5LbeOiE"}}
