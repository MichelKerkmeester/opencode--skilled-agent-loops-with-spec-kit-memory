n    const importers = importedBy.get(edge.importedFilePath) ?? [];\n    if (!importers.some((existing) => existing.importerFilePath === edge.importerFilePath)) {\n      importers.push(edge);\n    }\n    importedBy.set(edge.importedFilePath, importers);\n  }\n\n  const affectedByFile = new Map<string, { depth: number; why_included?: BlastRadiusWhyIncluded }>();\n  const normalizedSources = [...new Set(sourceFiles)];\n  let depthTruncated = false;\n  let overflowed = false;\n\n  const buildWhyIncluded = (\n    depth: number,\n    path: ReadonlyArray<GraphBfsPathStep<string, BlastRadiusDependency>>,\n    truncationReason: BlastRadiusWhyIncluded['truncationReason'],\n  ): BlastRadiusWhyIncluded => {\n    const edgeChain = path.map((step) => ({\n      fromFile: step.payload.importedFilePath,\n      toFile: step.payload.importerFilePath,\n      edgeType: 'IMPORTS' as const,\n      confidence: step.payload.confidence,\n    }));\n    const confidence = edgeChain.reduce(\n      (minimum, step) => Math.min(minimum, step.confidence),\n      edgeChain.length > 0 ? 1 : 1,\n    );\n    return {\n      depth,\n      edgeChain,\n      confidence,\n      ambiguous: ambiguityCandidates.length > 0,\n      truncationReason,\n    };\n  };\n\n  for (const sourceFile of normalizedSources) {\n    const traversal = traverseGraphBfs<string, BlastRadiusDependency, BlastRadiusAffectedFile>({\n      startIds: [sourceFile],\n      maxDepth,\n      preVisitedIds: [sourceFile],\n      visitTiming: 'enqueue',\n      inspectDepthBoundary: true,\n      getNeighbors: (item) => [...(importedBy.get(item.id) ?? [])]\n        .sort((left, right) => left.importerFilePath.localeCompare(right.importerFilePath))\n        .map((edge) => ({\n          id: edge.importerFilePath,\n          payload: edge,\n        })),\n      mapResult: (visit) => normalizedSources.includes(visit.id)\n        ? null\n        : {\n          filePath: visit.id,\n          depth: visit.depth,\n          ...(includeTrace\n            ? { why_included: buildWhyIncluded(visit.depth, visit.path, null) }\n            : {}),\n        },\n    });\n\n    depthTruncated ||= traversal.depthTruncated;\n    const maxDepthTruncatedFrom = new Set(traversal.truncated.map((entry) => entry.fromId));\n    for (const affectedFile of traversal.results.map((entry) => entry.value)) {\n      if (includeTrace && affectedFile.why_included && maxDepthTruncatedFrom.has(affectedFile.filePath)) {\n        affectedFile.why_included = {\n          ...affectedFile.why_included,\n          truncationReason: 'max_depth',\n        };\n      }\n      const previous = affectedByFile.get(affectedFile.filePath);\n      if (previous === undefined || affectedFile.depth < previous.depth) {\n        affectedByFile.set(affectedFile.filePath, {\n          depth: affectedFile.depth,\n          ...(affectedFile.why_included ? { why_included: affectedFile.why_included } : {}),\n        });\n      }\n    }\n  }\n\n  // Detect true overflow by comparing the full traversal size against `limit`\n  // BEFORE slicing. Previously `affectedFiles.length >= limit`\n  // false-positived whenever the reachable set happened to equal `limit`\n  // exactly. We over-collect (`limit + 1` semantically — here the whole\n  // BFS frontier is already in `affectedByFile`) and slice down only after\n  // recording overflow.\n  const totalAffectedBeforeSlice = affectedByFile.size;\n  let affectedFiles = [...affectedByFile.entries()]\n    .map(([filePath, entry]) => ({\n      filePath,\n      depth: entry.depth,\n      ...(entry.why_included ? { why_included: entry.why_included } : {}),\n    }))\n    .sort((left, right) => left.depth - right.depth || left.filePath.localeCompare(right.filePath))\n    .slice(0, limit);\n  overflowed = totalAffectedBeforeSlice > limit;\n  if (includeTrace && overflowed && affectedFiles.length > 0) {\n    const lastIncluded = affectedFiles[affectedFiles.length - 1];\n    if (lastIncluded.why_included && lastIncluded.why_included.truncationReason == null) {\n      lastIncluded.why_included = {\n        ...lastIncluded.why_included,\n        truncationReason: 'result_limit',\n      };\n    }\n  }\n  const breadcrumbByFile = new Map(\n    buildHotFileBreadcrumbs([\n      ...normalizedSources,\n      ...affectedFiles.map((entry) => entry.filePath),\n    ]).map((entry) => [entry.filePath, entry.hotFileBreadcrumb]),\n  );\n  affectedFiles = affectedFiles.map((entry) => ({\n    ...entry,\n    ...(breadcrumbByFile.get(entry.filePath) ? { hotFileBreadcrumb: breadcrumbByFile.get(entry.filePath) } : {}),\n  }));\n\n  const seedNodes = normalizedSources.map((filePath) => ({\n    filePath,\n    depth: 0,\n    isSeed: true,\n    ...(includeTrace\n      ? {\n        why_included: buildWhyIncluded(0, [], null),\n      }\n      : {}),\n    ...(breadcrumbByFile.get(filePath) ? { hotFileBreadcrumb: breadcrumbByFile.get(filePath) } : {}),\n  }));\n  const depthGroups = buildDepthGroups(affectedFiles, maxDepth);\n\n  return {\n    sourceFiles: normalizedSources,\n    nodes: [\n      ...seedNodes,\n      ...affectedFiles,\n    ],\n    affectedFiles,\n    depthGroups,\n    riskLevel: classifyBlastRadiusRisk(depthGroups, ambiguityCandidates),\n    minConfidence,\n    ambiguityCandidates,\n    hotFileBreadcrumbs: [...breadcrumbByFile.entries()].map(([filePath, hotFileBreadcrumb]) => ({\n      filePath,\n      hotFileBreadcrumb,\n    })),\n    // Omitted when the traversal reached the full depth horizon, mirroring the","lineStart":1080,"lineEnd":1259,"totalLines":1766,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781128831959,"end":1781128831965}},"metadata":{"openai":{"itemId":"fc_02508314844ac467016a29de7fea448191b686768d3b3a6aeb"}},"id":"prt_eb38d23d0001QBInvmNLEePZrG","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38cec4d0010WXvLEynEAUnvm"}}
{"type":"tool_use","timestamp":1781128832015,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_Vzve8z3hjE6RHZCopa5fe1yn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/graph/bfs-traversal.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/graph/bfs-traversal.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Code Graph BFS Traversal\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: export type GraphBfsVisitTiming = 'dequeue' | 'enqueue';\n6: \n7: export interface GraphBfsPathStep<TNodeId, TTracePayload> {\n8:   readonly fromId: TNodeId;\n9:   readonly toId: TNodeId;\n10:   readonly depth: number;\n11:   readonly payload: TTracePayload;\n12: }\n13: \n14: export interface GraphBfsQueueItem<TNodeId, TTracePayload = unknown> {\n15:   readonly id: TNodeId;\n16:   readonly depth: number;\n17:   readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n18: }\n19: \n20: export interface GraphBfsNeighbor<TNodeId, TPayload, TTracePayload = TPayload> {\n21:   readonly id: TNodeId;\n22:   readonly payload: TPayload;\n23:   readonly danglingId?: TNodeId;\n24:   readonly tracePayload?: TTracePayload;\n25: }\n26: \n27: export interface GraphBfsVisit<TNodeId, TPayload, TTracePayload = TPayload> {\n28:   readonly id: TNodeId;\n29:   readonly depth: number;\n30:   readonly payload: TPayload;\n31:   readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n32: }\n33: \n34: export interface GraphBfsResult<TNodeId, TResult, TTracePayload = unknown> {\n35:   readonly id: TNodeId;\n36:   readonly depth: number;\n37:   readonly value: TResult;\n38:   readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n39: }\n40: \n41: export interface GraphBfsDangling<TNodeId, TPayload> {\n42:   readonly id: TNodeId;\n43:   readonly depth: number;\n44:   readonly payload: TPayload;\n45: }\n46: \n47: export interface GraphBfsTruncated<TNodeId, TTracePayload> {\n48:   readonly id: TNodeId;\n49:   readonly fromId: TNodeId;\n50:   readonly depth: number;\n51:   readonly reason: 'max_depth';\n52:   readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n53: }\n54: \n55: export interface GraphBfsTraversalOptions<TNodeId, TPayload, TResult, TTracePayload = TPayload> {\n56:   readonly startIds: readonly TNodeId[];\n57:   readonly maxDepth: number;\n58:   readonly resultLimit?: number;\n59:   readonly preVisitedIds?: readonly TNodeId[];\n60:   readonly visitTiming?: GraphBfsVisitTiming;\n61:   readonly inspectDepthBoundary?: boolean;\n62:   readonly stopEnqueueWhenResultLimitReached?: boolean;\n63:   readonly getNeighbors: (item: GraphBfsQueueItem<TNodeId, TTracePayload>) => Iterable<GraphBfsNeighbor<TNodeId, TPayload, TTracePayload>>;\n64:   readonly mapResult?: (visit: GraphBfsVisit<TNodeId, TPayload, TTracePayload>) => TResult | null | undefined;\n65:   readonly shouldEnqueue?: (visit: GraphBfsVisit<TNodeId, TPayload, TTracePayload>) => boolean;\n66: }\n67: \n68: export interface GraphBfsTraversalResult<TNodeId, TPayload, TResult, TTracePayload = TPayload> {\n69:   readonly results: Array<GraphBfsResult<TNodeId, TResult, TTracePayload>>;\n70:   readonly dangling: Array<GraphBfsDangling<TNodeId, TPayload>>;\n71:   readonly truncated: Array<GraphBfsTruncated<TNodeId, TTracePayload>>;\n72:   readonly depthTruncated: boolean;\n73: }\n74: \n75: /** Traverse a graph breadth-first with shared depth, cap, dangling, and truncation handling. */\n76: export function traverseGraphBfs<TNodeId, TPayload, TResult, TTracePayload = TPayload>(\n77:   options: GraphBfsTraversalOptions<TNodeId, TPayload, TResult, TTracePayload>,\n78: ): GraphBfsTraversalResult<TNodeId, TPayload, TResult, TTracePayload> {\n79:   const maxDepth = Math.max(0, options.maxDepth);\n80:   const resultLimit = options.resultLimit ?? Number.POSITIVE_INFINITY;\n81:   const visitTiming = options.visitTiming ?? 'dequeue';\n82:   const visited = new Set<TNodeId>(options.preVisitedIds ?? []);\n83:   const expanded = new Set<TNodeId>();\n84:   const queue: Array<GraphBfsQueueItem<TNodeId, TTracePayload>> = options.startIds.map((id) => ({\n85:     id,\n86:     depth: 0,\n87:     path: [],\n88:   }));\n89:   const results: Array<GraphBfsResult<TNodeId, TResult, TTracePayload>> = [];\n90:   const dangling: Array<GraphBfsDangling<TNodeId, TPayload>> = [];\n91:   const truncated: Array<GraphBfsTruncated<TNodeId, TTracePayload>> = [];\n92:   let depthTruncated = false;\n93: \n94:   if (resultLimit <= 0) {\n95:     return { results, dangling, truncated, depthTruncated };\n96:   }\n97: \n98:   while (queue.length > 0 && results.length < resultLimit) {\n99:     const current = queue.shift();\n100:     if (!current || expanded.has(current.id)) {\n101:       continue;\n102:     }\n103: \n104:     if (visitTiming === 'dequeue') {\n105:       if (visited.has(current.id)) {\n106:         continue;\n107:       }\n108:       visited.add(current.id);\n109:     }\n110:     expanded.add(current.id);\n111: \n112:     if (current.depth >= maxDepth && !options.inspectDepthBoundary) {\n113:       continue;\n114:     }\n115: \n116:     for (const neighbor of options.getNeighbors(current)) {\n117:       const nextDepth = current.depth + 1;\n118:       const path = [\n119:         ...current.path,\n120:         {\n121:           fromId: current.id,\n122:           toId: neighbor.id,\n123:           depth: nextDepth,\n124:           payload: (neighbor.tracePayload ?? neighbor.payload) as TTracePayload,\n125:         },\n126:       ];\n127:       if (neighbor.danglingId !== undefined) {\n128:         dangling.push({ id: neighbor.danglingId, depth: nextDepth, payload: neighbor.payload });\n129:         continue;\n130:       }\n131: \n132:       if (visited.has(neighbor.id)) {\n133:         continue;\n134:       }\n135: \n136:       if (nextDepth > maxDepth) {\n137:         depthTruncated = true;\n138:         truncated.push({\n139:           id: neighbor.id,\n140:           fromId: current.id,\n141:           depth: nextDepth,\n142:           reason: 'max_depth',\n143:           path,\n144:         });\n145:         continue;\n146:       }\n147: \n148:       const visit: GraphBfsVisit<TNodeId, TPayload, TTracePayload> = {\n149:         id: neighbor.id,\n150:         depth: nextDepth,\n151:         payload: neighbor.payload,\n152:         path,\n153:       };\n154:       const mappedResult = options.mapResult?.(visit);\n155:       const hasResult = mappedResult !== undefined && mappedResult !== null;\n156: \n157:       if (visitTiming === 'enqueue') {\n158:         visited.add(neighbor.id);\n159:       }\n160: \n161:       if (hasResult) {\n162:         results.push({ id: neighbor.id, depth: nextDepth, value: mappedResult, path });\n163:       }\n164: \n165:       if (\n166:         hasResult\n167:         && options.stopEnqueueWhenResultLimitReached\n168:         && results.length >= resultLimit\n169:       ) {\n170:         break;\n171:       }\n172: \n173:       if (options.shouldEnqueue?.(visit) ?? true) {\n174:         queue.push({ id: neighbor.id, depth: nextDepth, path });\n175:       }\n176: \n177:       if (results.length >= resultLimit) {\n178:         break;\n179:       }\n180:     }\n181:   }\n182: \n183:   return { results, dangling, truncated, depthTruncated };\n184: }\n\n(End of file - total 184 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph BFS Traversal\n// ───────────────────────────────────────────────────────────────\n\nexport type GraphBfsVisitTiming = 'dequeue' | 'enqueue';\n\nexport interface GraphBfsPathStep<TNodeId, TTracePayload> {\n  readonly fromId: TNodeId;\n  readonly toId: TNodeId;\n  readonly depth: number;\n  readonly payload: TTracePayload;\n}\n\nexport interface GraphBfsQueueItem<TNodeId, TTracePayload = unknown> {\n  readonly id: TNodeId;\n  readonly depth: number;\n  readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n}\n\nexport interface GraphBfsNeighbor<TNodeId, TPayload, TTracePayload = TPayload> {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/graph/bfs-traversal.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph BFS Traversal\n// ───────────────────────────────────────────────────────────────\n\nexport type GraphBfsVisitTiming = 'dequeue' | 'enqueue';\n\nexport interface GraphBfsPathStep<TNodeId, TTracePayload> {\n  readonly fromId: TNodeId;\n  readonly toId: TNodeId;\n  readonly depth: number;\n  readonly payload: TTracePayload;\n}\n\nexport interface GraphBfsQueueItem<TNodeId, TTracePayload = unknown> {\n  readonly id: TNodeId;\n  readonly depth: number;\n  readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n}\n\nexport interface GraphBfsNeighbor<TNodeId, TPayload, TTracePayload = TPayload> {\n  readonly id: TNodeId;\n  readonly payload: TPayload;\n  readonly danglingId?: TNodeId;\n  readonly tracePayload?: TTracePayload;\n}\n\nexport interface GraphBfsVisit<TNodeId, TPayload, TTracePayload = TPayload> {\n  readonly id: TNodeId;\n  readonly depth: number;\n  readonly payload: TPayload;\n  readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n}\n\nexport interface GraphBfsResult<TNodeId, TResult, TTracePayload = unknown> {\n  readonly id: TNodeId;\n  readonly depth: number;\n  readonly value: TResult;\n  readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n}\n\nexport interface GraphBfsDangling<TNodeId, TPayload> {\n  readonly id: TNodeId;\n  readonly depth: number;\n  readonly payload: TPayload;\n}\n\nexport interface GraphBfsTruncated<TNodeId, TTracePayload> {\n  readonly id: TNodeId;\n  readonly fromId: TNodeId;\n  readonly depth: number;\n  readonly reason: 'max_depth';\n  readonly path: ReadonlyArray<GraphBfsPathStep<TNodeId, TTracePayload>>;\n}\n\nexport interface GraphBfsTraversalOptions<TNodeId, TPayload, TResult, TTracePayload = TPayload> {\n  readonly startIds: readonly TNodeId[];\n  readonly maxDepth: number;\n  readonly resultLimit?: number;\n  readonly preVisitedIds?: readonly TNodeId[];\n  readonly visitTiming?: GraphBfsVisitTiming;\n  readonly inspectDepthBoundary?: boolean;\n  readonly stopEnqueueWhenResultLimitReached?: boolean;\n  readonly getNeighbors: (item: GraphBfsQueueItem<TNodeId, TTracePayload>) => Iterable<GraphBfsNeighbor<TNodeId, TPayload, TTracePayload>>;\n  readonly mapResult?: (visit: GraphBfsVisit<TNodeId, TPayload, TTracePayload>) => TResult | null | undefined;\n  readonly shouldEnqueue?: (visit: GraphBfsVisit<TNodeId, TPayload, TTracePayload>) => boolean;\n}\n\nexport interface GraphBfsTraversalResult<TNodeId, TPayload, TResult, TTracePayload = TPayload> {\n  readonly results: Array<GraphBfsResult<TNodeId, TResult, TTracePayload>>;\n  readonly dangling: Array<GraphBfsDangling<TNodeId, TPayload>>;\n  readonly truncated: Array<GraphBfsTruncated<TNodeId, TTracePayload>>;\n  readonly depthTruncated: boolean;\n}\n\n/** Traverse a graph breadth-first with shared depth, cap, dangling, and truncation handling. */\nexport function traverseGraphBfs<TNodeId, TPayload, TResult, TTracePayload = TPayload>(\n  options: GraphBfsTraversalOptions<TNodeId, TPayload, TResult, TTracePayload>,\n): GraphBfsTraversalResult<TNodeId, TPayload, TResult, TTracePayload> {\n  const maxDepth = Math.max(0, options.maxDepth);\n  const resultLimit = options.resultLimit ?? Number.POSITIVE_INFINITY;\n  const visitTiming = options.visitTiming ?? 'dequeue';\n  const visited = new Set<TNodeId>(options.preVisitedIds ?? []);\n  const expanded = new Set<TNodeId>();\n  const queue: Array<GraphBfsQueueItem<TNodeId, TTracePayload>> = options.startIds.map((id) => ({\n    id,\n    depth: 0,\n    path: [],\n  }));\n  const results: Array<GraphBfsResult<TNodeId, TResult, TTracePayload>> = [];\n  const dangling: Array<GraphBfsDangling<TNodeId, TPayload>> = [];\n  const truncated: Array<GraphBfsTruncated<TNodeId, TTracePayload>> = [];\n  let depthTruncated = false;\n\n  if (resultLimit <= 0) {\n    return { results, dangling, truncated, depthTruncated };\n  }\n\n  while (queue.length > 0 && results.length < resultLimit) {\n    const current = queue.shift();\n    if (!current || expanded.has(current.id)) {\n      continue;\n    }\n\n    if (visitTiming === 'dequeue') {\n      if (visited.has(current.id)) {\n        continue;\n      }\n      visited.add(current.id);\n    }\n    expanded.add(current.id);\n\n    if (current.depth >= maxDepth && !options.inspectDepthBoundary) {\n      continue;\n    }\n\n    for (const neighbor of options.getNeighbors(current)) {\n      const nextDepth = current.depth + 1;\n      const path = [\n        ...current.path,\n        {\n          fromId: current.id,\n          toId: neighbor.id,\n          depth: nextDepth,\n          payload: (neighbor.tracePayload ?? neighbor.payload) as TTracePayload,\n        },\n      ];\n      if (neighbor.danglingId !== undefined) {\n        dangling.push({ id: neighbor.danglingId, depth: nextDepth, payload: neighbor.payload });\n        continue;\n      }\n\n      if (visited.has(neighbor.id)) {\n        continue;\n      }\n\n      if (nextDepth > maxDepth) {\n        depthTruncated = true;\n        truncated.push({\n          id: neighbor.id,\n          fromId: current.id,\n          depth: nextDepth,\n          reason: 'max_depth',\n          path,\n        });\n        continue;\n      }\n\n      const visit: GraphBfsVisit<TNodeId, TPayload, TTracePayload> = {\n        id: neighbor.id,\n        depth: nextDepth,\n        payload: neighbor.payload,\n        path,\n      };\n      const mappedResult = options.mapResult?.(visit);\n      const hasResult = mappedResult !== undefined && mappedResult !== null;\n\n      if (visitTiming === 'enqueue') {\n        visited.add(neighbor.id);\n      }\n\n      if (hasResult) {\n        results.push({ id: neighbor.id, depth: nextDepth, value: mappedResult, path });\n      }\n\n      if (\n        hasResult\n        && options.stopEnqueueWhenResultLimitReached\n        && results.length >= resultLimit\n      ) {\n        break;\n      }\n\n      if (options.shouldEnqueue?.(visit) ?? true) {\n        queue.push({ id: neighbor.id, depth: nextDepth, path });\n      }\n\n      if (results.length >= resultLimit) {\n        break;\n      }\n    }\n  }\n\n  return { results, dangling, truncated, depthTruncated };\n}","lineStart":1,"lineEnd":184,"totalLines":184,"truncated":false}},"title":".opencode/skills/system-code-graph/mcp_server/lib/graph/bfs-traversal.ts","time":{"start":1781128832011,"end":1781128832014}},"metadata":{"openai":{"itemId":"fc_02508314844ac467016a29de7fea7081918c80c951be1410e4"}},"id":"prt_eb38d23ff001gk16rzI55s0pSe","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38cec4d0010WXvLEynEAUnvm"}}
{"type":"tool_use","timestamp":1781128832040,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_ehf2urJmO363pa91RGOISUlP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-context.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-context.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Code Graph Context\n3: // ───────────────────────────────────────────────────────────────\n4: // LLM-oriented compact graph neighborhoods from structural seeds.\n5: // Provides the code_graph_context MCP tool implementation.\n6: \n7: import { performance } from 'node:perf_hooks';\n8: import * as graphDb from './code-graph-db.js';\n9: import { resolveSeeds, type AnySeed, type ArtifactRef } from './seed-resolver.js';\n10: import { isSpeckitMetricsEnabled, speckitMetrics } from './shared/metrics-stub.js';\n11: \n12: /** Map internal QueryMode → canonical spec_kit metric `mode` label value. */\n13: function speckitQueryModeLabel(mode: QueryMode): 'outline' | 'blast_radius' | 'relationship' {\n14:   if (mode === 'outline') return 'outline';\n15:   if (mode === 'impact') return 'blast_radius';\n16:   return 'relationship';\n17: }\n18: \n19: export type QueryMode = 'neighborhood' | 'outline' | 'impact';\n20: \n21: export interface ContextArgs {\n22:   input?: string;\n23:   queryMode?: QueryMode;\n24:   subject?: string;\n25:   seeds?: AnySeed[];\n26:   budgetTokens?: number;\n27:   deadlineMs?: number;\n28:   profile?: 'quick' | 'research' | 'debug';\n29:   includeTrace?: boolean;\n30: }\n31: \n32: export interface ContextResult {\n33:   queryMode: QueryMode;\n34:   resolvedAnchors: ArtifactRef[];\n35:   graphContext: GraphContextSection[];\n36:   textBrief: string;\n37:   combinedSummary: string;\n38:   nextActions: string[];\n39:   metadata: {\n40:     totalNodes: number;\n41:     totalEdges: number;\n42:     budgetUsed: number;\n43:     budgetLimit: number;\n44:     deadlineMs: number | null;\n45:     partialOutput: {\n46:       isPartial: boolean;\n47:       reasons: Array<'deadline' | 'budget'>;\n48:       omittedSections: number;\n49:       omittedAnchors: number;\n50:       truncatedText: boolean;\n51:     };\n52:     freshness: { lastScanAt: string | null; staleness: 'fresh' | 'recent' | 'stale' | 'unknown' };\n53:   };\n54: }\n55: \n56: interface GraphContextSection {\n57:   anchor: string;\n58:   nodes: { name: string; kind: string; file: string; line: number }[];\n59:   edges: {\n60:     from: string;\n61:     to: string;\n62:     type: string;\n63:     confidence: number | null;\n64:     detectorProvenance: string | null;\n65:     evidenceClass: string | null;\n66:     reason: string | null;\n67:     step: string | null;\n68:   }[];\n69:   why_included?: ContextWhyIncluded[];\n70:   partial?: {\n71:     reason: 'deadline';\n72:     omittedNodes: number;\n73:     omittedEdges: number;\n74:   };\n75: }\n76: \n77: interface ContextWhyIncludedEdgeChainStep {\n78:   from: string;\n79:   to: string;\n80:   fromFile: string | null;\n81:   toFile: string | null;\n82:   edgeType: string;\n83:   confidence: number | null;\n84:   detectorProvenance: string | null;\n85:   evidenceClass: string | null;\n86:   reason: string | null;\n87:   step: string | null;\n88: }\n89: \n90: interface ContextWhyIncluded {\n91:   filePath: string;\n92:   depth: number;\n93:   edgeChain: ContextWhyIncludedEdgeChainStep[];\n94:   confidence: number | null;\n95:   ambiguous: boolean;\n96:   truncationReason: 'deadline' | 'budget' | 'trace_limit' | null;\n97: }\n98: \n99: const CONTEXT_WHY_INCLUDED_LIMIT = 25;\n100: \n101: interface ExpansionResult {\n102:   section: GraphContextSection;\n103:   deadlineExceeded: boolean;\n104:   omittedNodes: number;\n105:   omittedEdges: number;\n106: }\n107: \n108: interface FormattedTextBrief {\n109:   text: string;\n110:   omittedSections: number;\n111:   truncated: boolean;\n112: }\n113: \n114: function defaultDeadlineMsForProfile(profile: ContextArgs['profile']): number {\n115:   switch (profile) {\n116:     case 'quick':\n117:       return 250;\n118:     case 'debug':\n119:       return 700;\n120:     case 'research':\n121:       return 900;\n122:     default:\n123:       return 400;\n124:   }\n125: }\n126: \n127: /** Build context from resolved anchors using specified query mode */\n128: export function buildContext(args: ContextArgs): ContextResult {\n129:   const queryMode = args.queryMode ?? 'neighborhood';\n130:   const budgetTokens = args.budgetTokens ?? 1200;\n131:   const seeds = args.seeds ?? [];\n132:   const deadlineMs = args.deadlineMs ?? defaultDeadlineMsForProfile(args.profile);\n133:   const speckitQueryStart = isSpeckitMetricsEnabled() ? performance.now() : 0;\n134:   const speckitModeLabel = speckitQueryModeLabel(queryMode);\n135:   const resolvedAnchors = resolveSeeds(seeds);\n136: \n137:   // If no seeds but subject given, create seed from subject\n138:   if (resolvedAnchors.length === 0 && args.subject) {\n139:     const subjectRef = resolveSubjectToRef(args.subject);\n140:     if (subjectRef) resolvedAnchors.push(subjectRef);\n141:   }\n142: \n143:   // Empty seeds + no subject → outline mode fallback\n144:   if (resolvedAnchors.length === 0) {\n145:     if (isSpeckitMetricsEnabled()) {\n146:       speckitMetrics.incrementCounter('spec_kit.graph.query_cache_misses_total', { mode: speckitModeLabel });\n147:     }\n148:     return buildEmptyFallback(queryMode, budgetTokens);\n149:   }\n150:   if (isSpeckitMetricsEnabled()) {\n151:     speckitMetrics.incrementCounter('spec_kit.graph.query_cache_hits_total', { mode: speckitModeLabel });\n152:   }\n153: \n154:   const sections: GraphContextSection[] = [];\n155:   let totalNodes = 0;\n156:   let totalEdges = 0;\n157:   let omittedAnchors = 0;\n158:   let omittedSections = 0;\n159:   const partialReasons = new Set<'deadline' | 'budget'>();\n160: \n161:   // Profile-based limits\n162:   const nodeLimit = args.profile === 'quick' ? 10 : args.profile === 'debug' ? 30 : 20;\n163: \n164:   const contextStart = performance.now();\n165: \n166:   for (const anchor of resolvedAnchors) {\n167:     // Deadline check: stop processing further anchors if over budget\n168:     if (performance.now() - contextStart > deadlineMs) {\n169:       partialReasons.add('deadline');\n170:       omittedAnchors += resolvedAnchors.length - sections.length;\n171:       break;\n172:     }\n173: \n174:     if (!anchor.symbolId) {\n175:       // File anchor — get outline\n176:       const outlineNodes = graphDb.queryOutline(anchor.filePath).slice(0, nodeLimit);\n177:       sections.push({\n178:         anchor: `${anchor.filePath}:${anchor.startLine}`,\n179:         nodes: outlineNodes.map(n => ({ name: n.fqName, kind: n.kind, file: n.filePath, line: n.startLine })),\n180:         edges: [],\n181:         ...(args.includeTrace === true\n182:           ? {\n183:             why_included: [{\n184:               filePath: anchor.filePath,\n185:               depth: 0,\n186:               edgeChain: [],\n187:               confidence: anchor.confidence,\n188:               ambiguous: anchor.resolution !== 'exact',\n189:               truncationReason: null,\n190:             }],\n191:           }\n192:           : {}),\n193:       });\n194:       totalNodes += outlineNodes.length;\n195:       continue;\n196:     }\n197: \n198:     const expansion = expandAnchor(\n199:       anchor,\n200:       queryMode,\n201:       Math.max(0, deadlineMs - (performance.now() - contextStart)),\n202:       args.includeTrace === true,\n203:     );\n204:     sections.push(expansion.section);\n205:     totalNodes += expansion.section.nodes.length;\n206:     totalEdges += expansion.section.edges.length;\n207:     omittedSections += expansion.section.partial ? 1 : 0;\n208:     if (expansion.deadlineExceeded) {\n209:       partialReasons.add('deadline');\n210:       omittedAnchors += resolvedAnchors.length - sections.length;\n211:       break;\n212:     }\n213:   }\n214: \n215:   const formattedTextBrief = formatTextBrief(sections, budgetTokens, resolvedAnchors);\n216:   if (formattedTextBrief.omittedSections > 0 || formattedTextBrief.truncated) {\n217:     partialReasons.add('budget');\n218:     if (args.includeTrace === true) {\n219:       stampContextTraceTruncation(sections, 'budget');\n220:     }\n221:   }\n222:   const combinedSummary = buildCombinedSummary(resolvedAnchors, sections);\n223:   const nextActions = suggestNextActions(resolvedAnchors, sections, queryMode);\n224:   const freshness = computeFreshness();\n225:   if (isSpeckitMetricsEnabled()) {\n226:     const freshnessLabel = freshness.staleness === 'fresh' || freshness.staleness === 'recent' ? 'live' : freshness.staleness === 'stale' ? 'stale' : 'unavailable';\n227:     speckitMetrics.recordHistogram('spec_kit.graph.query_latency_ms', performance.now() - speckitQueryStart, { mode: speckitModeLabel, freshness_state: freshnessLabel });\n228:   }\n229: \n230:   return {\n231:     queryMode,\n232:     resolvedAnchors,\n233:     graphContext: sections,\n234:     textBrief: formattedTextBrief.text,\n235:     combinedSummary,\n236:     nextActions,\n237:     metadata: {\n238:       totalNodes,\n239:       totalEdges,\n240:       budgetUsed: Math.ceil(formattedTextBrief.text.length / 4),\n241:       budgetLimit: budgetTokens,\n242:       deadlineMs,\n243:       partialOutput: {\n244:         isPartial: partialReasons.size > 0,\n245:         reasons: [...partialReasons],\n246:         omittedSections: omittedSections + formattedTextBrief.omittedSections,\n247:         omittedAnchors,\n248:         truncatedText: formattedTextBrief.truncated,\n249:       },\n250:       freshness,\n251:     },\n252:   };\n253: }\n254: \n255: /** Build fallback result when no seeds/subject resolve */\n256: function buildEmptyFallback(queryMode: QueryMode, budgetTokens: number): ContextResult {\n257:   return {\n258:     queryMode,\n259:     resolvedAnchors: [],\n260:     graphContext: [],\n\n(Showing lines 1-260 of 811. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Context\n// ───────────────────────────────────────────────────────────────\n// LLM-oriented compact graph neighborhoods from structural seeds.\n// Provides the code_graph_context MCP tool implementation.\n\nimport { performance } from 'node:perf_hooks';\nimport * as graphDb from './code-graph-db.js';\nimport { resolveSeeds, type AnySeed, type ArtifactRef } from './seed-resolver.js';\nimport { isSpeckitMetricsEnabled, speckitMetrics } from './shared/metrics-stub.js';\n\n/** Map internal QueryMode → canonical spec_kit metric `mode` label value. */\nfunction speckitQueryModeLabel(mode: QueryMode): 'outline' | 'blast_radius' | 'relationship' {\n  if (mode === 'outline') return 'outline';\n  if (mode === 'impact') return 'blast_radius';\n  return 'relationship';\n}\n\nexport type QueryMode = 'neighborhood' | 'outline' | 'impact';\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-context.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Context\n// ───────────────────────────────────────────────────────────────\n// LLM-oriented compact graph neighborhoods from structural seeds.\n// Provides the code_graph_context MCP tool implementation.\n\nimport { performance } from 'node:perf_hooks';\nimport * as graphDb from './code-graph-db.js';\nimport { resolveSeeds, type AnySeed, type ArtifactRef } from './seed-resolver.js';\nimport { isSpeckitMetricsEnabled, speckitMetrics } from './shared/metrics-stub.js';\n\n/** Map internal QueryMode → canonical spec_kit metric `mode` label value. */\nfunction speckitQueryModeLabel(mode: QueryMode): 'outline' | 'blast_radius' | 'relationship' {\n  if (mode === 'outline') return 'outline';\n  if (mode === 'impact') return 'blast_radius';\n  return 'relationship';\n}\n\nexport type QueryMode = 'neighborhood' | 'outline' | 'impact';\n\nexport interface ContextArgs {\n  input?: string;\n  queryMode?: QueryMode;\n  subject?: string;\n  seeds?: AnySeed[];\n  budgetTokens?: number;\n  deadlineMs?: number;\n  profile?: 'quick' | 'research' | 'debug';\n  includeTrace?: boolean;\n}\n\nexport interface ContextResult {\n  queryMode: QueryMode;\n  resolvedAnchors: ArtifactRef[];\n  graphContext: GraphContextSection[];\n  textBrief: string;\n  combinedSummary: string;\n  nextActions: string[];\n  metadata: {\n    totalNodes: number;\n    totalEdges: number;\n    budgetUsed: number;\n    budgetLimit: number;\n    deadlineMs: number | null;\n    partialOutput: {\n      isPartial: boolean;\n      reasons: Array<'deadline' | 'budget'>;\n      omittedSections: number;\n      omittedAnchors: number;\n      truncatedText: boolean;\n    };\n    freshness: { lastScanAt: string | null; staleness: 'fresh' | 'recent' | 'stale' | 'unknown' };\n  };\n}\n\ninterface GraphContextSection {\n  anchor: string;\n  nodes: { name: string; kind: string; file: string; line: number }[];\n  edges: {\n    from: string;\n    to: string;\n    type: string;\n    confidence: number | null;\n    detectorProvenance: string | null;\n    evidenceClass: string | null;\n    reason: string | null;\n    step: string | null;\n  }[];\n  why_included?: ContextWhyIncluded[];\n  partial?: {\n    reason: 'deadline';\n    omittedNodes: number;\n    omittedEdges: number;\n  };\n}\n\ninterface ContextWhyIncludedEdgeChainStep {\n  from: string;\n  to: string;\n  fromFile: string | null;\n  toFile: string | null;\n  edgeType: string;\n  confidence: number | null;\n  detectorProvenance: string | null;\n  evidenceClass: string | null;\n  reason: string | null;\n  step: string | null;\n}\n\ninterface ContextWhyIncluded {\n  filePath: string;\n  depth: number;\n  edgeChain: ContextWhyIncludedEdgeChainStep[];\n  confidence: number | null;\n  ambiguous: boolean;\n  truncationReason: 'deadline' | 'budget' | 'trace_limit' | null;\n}\n\nconst CONTEXT_WHY_INCLUDED_LIMIT = 25;\n\ninterface ExpansionResult {\n  section: GraphContextSection;\n  deadlineExceeded: boolean;\n  omittedNodes: number;\n  omittedEdges: number;\n}\n\ninterface FormattedTextBrief {\n  text: string;\n  omittedSections: number;\n  truncated: boolean;\n}\n\nfunction defaultDeadlineMsForProfile(profile: ContextArgs['profile']): number {\n  switch (profile) {\n    case 'quick':\n      return 250;\n    case 'debug':\n      return 700;\n    case 'research':\n      return 900;\n    default:\n      return 400;\n  }\n}\n\n/** Build context from resolved anchors using specified query mode */\nexport function buildContext(args: ContextArgs): ContextResult {\n  const queryMode = args.queryMode ?? 'neighborhood';\n  const budgetTokens = args.budgetTokens ?? 1200;\n  const seeds = args.seeds ?? [];\n  const deadlineMs = args.deadlineMs ?? defaultDeadlineMsForProfile(args.profile);\n  const speckitQueryStart = isSpeckitMetricsEnabled() ? performance.now() : 0;\n  const speckitModeLabel = speckitQueryModeLabel(queryMode);\n  const resolvedAnchors = resolveSeeds(seeds);\n\n  // If no seeds but subject given, create seed from subject\n  if (resolvedAnchors.length === 0 && args.subject) {\n    const subjectRef = resolveSubjectToRef(args.subject);\n    if (subjectRef) resolvedAnchors.push(subjectRef);\n  }\n\n  // Empty seeds + no subject → outline mode fallback\n  if (resolvedAnchors.length === 0) {\n    if (isSpeckitMetricsEnabled()) {\n      speckitMetrics.incrementCounter('spec_kit.graph.query_cache_misses_total', { mode: speckitModeLabel });\n    }\n    return buildEmptyFallback(queryMode, budgetTokens);\n  }\n  if (isSpeckitMetricsEnabled()) {\n    speckitMetrics.incrementCounter('spec_kit.graph.query_cache_hits_total', { mode: speckitModeLabel });\n  }\n\n  const sections: GraphContextSection[] = [];\n  let totalNodes = 0;\n  let totalEdges = 0;\n  let omittedAnchors = 0;\n  let omittedSections = 0;\n  const partialReasons = new Set<'deadline' | 'budget'>();\n\n  // Profile-based limits\n  const nodeLimit = args.profile === 'quick' ? 10 : args.profile === 'debug' ? 30 : 20;\n\n  const contextStart = performance.now();\n\n  for (const anchor of resolvedAnchors) {\n    // Deadline check: stop processing further anchors if over budget\n    if (performance.now() - contextStart > deadlineMs) {\n      partialReasons.add('deadline');\n      omittedAnchors += resolvedAnchors.length - sections.length;\n      break;\n    }\n\n    if (!anchor.symbolId) {\n      // File anchor — get outline\n      const outlineNodes = graphDb.queryOutline(anchor.filePath).slice(0, nodeLimit);\n      sections.push({\n        anchor: `${anchor.filePath}:${anchor.startLine}`,\n        nodes: outlineNodes.map(n => ({ name: n.fqName, kind: n.kind, file: n.filePath, line: n.startLine })),\n        edges: [],\n        ...(args.includeTrace === true\n          ? {\n            why_included: [{\n              filePath: anchor.filePath,\n              depth: 0,\n              edgeChain: [],\n              confidence: anchor.confidence,\n              ambiguous: anchor.resolution !== 'exact',\n              truncationReason: null,\n            }],\n          }\n          : {}),\n      });\n      totalNodes += outlineNodes.length;\n      continue;\n    }\n\n    const expansion = expandAnchor(\n      anchor,\n      queryMode,\n      Math.max(0, deadlineMs - (performance.now() - contextStart)),\n      args.includeTrace === true,\n    );\n    sections.push(expansion.section);\n    totalNodes += expansion.section.nodes.length;\n    totalEdges += expansion.section.edges.length;\n    omittedSections += expansion.section.partial ? 1 : 0;\n    if (expansion.deadlineExceeded) {\n      partialReasons.add('deadline');\n      omittedAnchors += resolvedAnchors.length - sections.length;\n      break;\n    }\n  }\n\n  const formattedTextBrief = formatTextBrief(sections, budgetTokens, resolvedAnchors);\n  if (formattedTextBrief.omittedSections > 0 || formattedTextBrief.truncated) {\n    partialReasons.add('budget');\n    if (args.includeTrace === true) {\n      stampContextTraceTruncation(sections, 'budget');\n    }\n  }\n  const combinedSummary = buildCombinedSummary(resolvedAnchors, sections);\n  const nextActions = suggestNextActions(resolvedAnchors, sections, queryMode);\n  const freshness = computeFreshness();\n  if (isSpeckitMetricsEnabled()) {\n    const freshnessLabel = freshness.staleness === 'fresh' || freshness.staleness === 'recent' ? 'live' : freshness.staleness === 'stale' ? 'stale' : 'unavailable';\n    speckitMetrics.recordHistogram('spec_kit.graph.query_latency_ms', performance.now() - speckitQueryStart, { mode: speckitModeLabel, freshness_state: freshnessLabel });\n  }\n\n  return {\n    queryMode,\n    resolvedAnchors,\n    graphContext: sections,\n    textBrief: formattedTextBrief.text,\n    combinedSummary,\n    nextActions,\n    metadata: {\n      totalNodes,\n      totalEdges,\n      budgetUsed: Math.ceil(formattedTextBrief.text.length / 4),\n      budgetLimit: budgetTokens,\n      deadlineMs,\n      partialOutput: {\n        isPartial: partialReasons.size > 0,\n        reasons: [...partialReasons],\n        omittedSections: omittedSections + formattedTextBrief.omittedSections,\n        omittedAnchors,\n        truncatedText: formattedTextBrief.truncated,\n      },\n      freshness,\n    },\n  };\n}\n\n/** Build fallback result when no seeds/subject resolve */\nfunction buildEmptyFallback(queryMode: QueryMode, budgetTokens: number): ContextResult {\n  return {\n    queryMode,\n    resolvedAnchors: [],\n    graphContext: [],","lineStart":1,"lineEnd":260,"totalLines":811,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/lib/code-graph-context.ts","time":{"start":1781128832035,"end":1781128832039}},"metadata":{"openai":{"itemId":"fc_02508314844ac467016a29de7fea788191adb5bff957b70f15"}},"id":"prt_eb38d24190017aXlYGB7wCE1x6","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38cec4d0010WXvLEynEAUnvm"}}
{"type":"tool_use","timestamp":1781128832055,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_zZEdhJIYBs3WlBwsXKmric8a","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/symbol-bm25-resolver.ts","offset":1,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/symbol-bm25-resolver.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Code Graph Symbol BM25 Resolver\n3: // ───────────────────────────────────────────────────────────────\n4: // Optional, fallback-only symbol candidate scoring over indexed symbol fields.\n5: \n6: export const CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV = 'SPECKIT_CODE_GRAPH_BM25_SYMBOL_RESOLVER';\n7: \n8: const BM25_K1 = 1.2;\n9: const BM25_B = 0.75;\n10: const DEFAULT_LIMIT = 5;\n11: const ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n12: \n13: const SYMBOL_BM25_FIELD_NAMES = [\n14:   'name',\n15:   'fqName',\n16:   'signature',\n17:   'docstring',\n18:   'filePath',\n19: ] as const;\n20: \n21: export type SymbolBm25FieldName = typeof SYMBOL_BM25_FIELD_NAMES[number];\n22: export type SymbolBm25FieldWeights = Record<SymbolBm25FieldName, number>;\n23: \n24: export const SYMBOL_BM25_FIELD_WEIGHTS: SymbolBm25FieldWeights = {\n25:   name: 4.0,\n26:   fqName: 3.2,\n27:   signature: 2.0,\n28:   filePath: 1.2,\n29:   docstring: 0.7,\n30: };\n31: \n32: export interface SymbolBm25Document {\n33:   readonly symbolId: string;\n34:   readonly fqName: string | null;\n35:   readonly name: string | null;\n36:   readonly kind: string | null;\n37:   readonly filePath: string | null;\n38:   readonly startLine: number | null;\n39:   readonly signature: string | null;\n40:   readonly docstring: string | null;\n41: }\n42: \n43: export interface SymbolBm25SearchOptions {\n44:   readonly fieldWeights?: Partial<SymbolBm25FieldWeights>;\n45:   readonly limit?: number;\n46: }\n47: \n48: export interface SymbolBm25Candidate {\n49:   readonly symbolId: string;\n50:   readonly fqName: string | null;\n51:   readonly name: string | null;\n52:   readonly kind: string | null;\n53:   readonly filePath: string | null;\n54:   readonly startLine: number | null;\n55:   readonly score: number;\n56:   readonly rawScore: number;\n57:   readonly evidence: readonly string[];\n58:   readonly disambiguationOnly: true;\n59: }\n60: \n61: export interface SymbolBm25FootprintStats {\n62:   readonly documentCount: number;\n63:   readonly termCount: number;\n64:   readonly postingCount: number;\n65:   readonly typedArrayBytes: number;\n66:   readonly mutablePostingCount: number;\n67: }\n68: \n69: interface FieldTermFrequency {\n70:   total: number;\n71:   fields: Record<SymbolBm25FieldName, number>;\n72: }\n73: \n74: interface PackedSymbolDocument extends SymbolBm25Document {\n75:   numericId: number;\n76:   length: number;\n77: }\n78: \n79: interface PackedPostingMutable {\n80:   docIds: number[];\n81:   nameTfs: number[];\n82:   fqNameTfs: number[];\n83:   signatureTfs: number[];\n84:   docstringTfs: number[];\n85:   filePathTfs: number[];\n86: }\n87: \n88: interface PackedPostingList {\n89:   docIds: Uint32Array;\n90:   nameTfs: Uint32Array;\n91:   fqNameTfs: Uint32Array;\n92:   signatureTfs: Uint32Array;\n93:   docstringTfs: Uint32Array;\n94:   filePathTfs: Uint32Array;\n95: }\n96: \n97: function emptyFieldFrequency(): FieldTermFrequency {\n98:   return {\n99:     total: 0,\n100:     fields: {\n101:       name: 0,\n102:       fqName: 0,\n103:       signature: 0,\n104:       docstring: 0,\n105:       filePath: 0,\n106:     },\n107:   };\n108: }\n109: \n110: function resolveFieldWeights(overrides: Partial<SymbolBm25FieldWeights> = {}): SymbolBm25FieldWeights {\n111:   return {\n112:     name: overrides.name ?? SYMBOL_BM25_FIELD_WEIGHTS.name,\n113:     fqName: overrides.fqName ?? SYMBOL_BM25_FIELD_WEIGHTS.fqName,\n114:     signature: overrides.signature ?? SYMBOL_BM25_FIELD_WEIGHTS.signature,\n115:     docstring: overrides.docstring ?? SYMBOL_BM25_FIELD_WEIGHTS.docstring,\n116:     filePath: overrides.filePath ?? SYMBOL_BM25_FIELD_WEIGHTS.filePath,\n117:   };\n118: }\n119: \n120: export function isCodeGraphBm25SymbolResolverEnabled(env: NodeJS.ProcessEnv = process.env): boolean {\n121:   const value = env[CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV]?.trim().toLowerCase();\n122:   return value ? ENABLED_VALUES.has(value) : false;\n123: }\n124: \n125: function splitIdentifier(value: string): string[] {\n126:   return value\n127:     .replace(/([a-z0-9])([A-Z])/g, '$1 $2')\n128:     .replace(/([A-Z]+)([A-Z][a-z])/g, '$1 $2')\n129:     .toLowerCase()\n130:     .split(/[^a-z0-9]+/)\n131:     .filter((token) => token.length >= 2);\n132: }\n133: \n134: function trigrams(token: string): string[] {\n135:   if (token.length < 4) return [];\n136:   const grams: string[] = [];\n137:   for (let index = 0; index <= token.length - 3; index += 1) {\n138:     grams.push(`tri:${token.slice(index, index + 3)}`);\n139:   }\n140:   return grams;\n141: }\n142: \n143: function tokenize(value: string | null | undefined): string[] {\n144:   if (!value) return [];\n145:   const baseTokens = splitIdentifier(value);\n146:   return baseTokens.flatMap((token) => [token, ...trigrams(token)]);\n147: }\n148: \n149: function documentFields(document: SymbolBm25Document): Record<SymbolBm25FieldName, readonly string[]> {\n150:   return {\n151:     name: [document.name ?? ''],\n152:     fqName: [document.fqName ?? ''],\n153:     signature: [document.signature ?? ''],\n154:     docstring: [document.docstring ?? ''],\n155:     filePath: [document.filePath ?? ''],\n156:   };\n157: }\n158: \n159: function fieldTermFrequencies(document: SymbolBm25Document): Map<string, FieldTermFrequency> {\n160:   const frequencies = new Map<string, FieldTermFrequency>();\n161:   for (const fieldName of SYMBOL_BM25_FIELD_NAMES) {\n162:     for (const value of documentFields(document)[fieldName]) {\n163:       for (const token of tokenize(value)) {\n164:         let frequency = frequencies.get(token);\n165:         if (!frequency) {\n166:           frequency = emptyFieldFrequency();\n167:           frequencies.set(token, frequency);\n168:         }\n169:         frequency.total += 1;\n170:         frequency.fields[fieldName] += 1;\n171:       }\n172:     }\n173:   }\n174:   return frequencies;\n175: }\n176: \n177: function weightedFrequency(\n178:   postings: PackedPostingList,\n179:   index: number,\n180:   weights: SymbolBm25FieldWeights,\n181: ): number {\n182:   return postings.nameTfs[index] * weights.name\n183:     + postings.fqNameTfs[index] * weights.fqName\n184:     + postings.signatureTfs[index] * weights.signature\n185:     + postings.docstringTfs[index] * weights.docstring\n186:     + postings.filePathTfs[index] * weights.filePath;\n187: }\n188: \n189: function topWeightedFields(\n190:   postings: PackedPostingList,\n191:   index: number,\n192:   weights: SymbolBm25FieldWeights,\n193: ): SymbolBm25FieldName[] {\n194:   return [\n195:     { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n196:     { field: 'fqName' as const, value: postings.fqNameTfs[index] * weights.fqName },\n197:     { field: 'signature' as const, value: postings.signatureTfs[index] * weights.signature },\n198:     { field: 'filePath' as const, value: postings.filePathTfs[index] * weights.filePath },\n199:     { field: 'docstring' as const, value: postings.docstringTfs[index] * weights.docstring },\n200:   ]\n201:     .filter((entry) => entry.value > 0)\n202:     .sort((left, right) => right.value - left.value)\n203:     .map((entry) => entry.field)\n204:     .slice(0, 3);\n205: }\n206: \n207: export class SymbolPackedBm25Index {\n208:   private readonly symbolIds: string[] = [];\n209:   private readonly symbolNumbersById = new Map<string, number>();\n210:   private readonly documents = new Map<string, PackedSymbolDocument>();\n211:   private readonly documentFreq = new Map<string, number>();\n212:   private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n213:   private readonly packedPostings = new Map<string, PackedPostingList>();\n214:   private totalDocumentLength = 0;\n215: \n216:   constructor(documents: readonly SymbolBm25Document[] = []) {\n217:     for (const document of documents) {\n218:       this.addDocument(document);\n219:     }\n220:     this.finalize();\n221:   }\n222: \n223:   addDocument(document: SymbolBm25Document): void {\n224:     const frequencies = fieldTermFrequencies(document);\n225:     const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n226:     if (length === 0) return;\n227: \n228:     const numericId = this.nextNumericId(document.symbolId);\n229:     this.documents.set(document.symbolId, { ...document, numericId, length });\n230:     this.totalDocumentLength += length;\n231: \n232:     for (const term of [...frequencies.keys()].sort()) {\n233:       const frequency = frequencies.get(term);\n234:       if (!frequency) continue;\n235:       this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n236:       const postings = this.ensureMutablePostings(term);\n237:       postings.docIds.push(numericId);\n238:       postings.nameTfs.push(frequency.fields.name);\n239:       postings.fqNameTfs.push(frequency.fields.fqName);\n240:       postings.signatureTfs.push(frequency.fields.signature);\n241:       postings.docstringTfs.push(frequency.fields.docstring);\n242:       postings.filePathTfs.push(frequency.fields.filePath);\n243:     }\n244:   }\n245: \n246:   finalize(): void {\n247:     for (const [term, postings] of this.mutablePostings.entries()) {\n248:       const order = postings.docIds.map((docId, index) => ({ docId, index }))\n249:         .sort((left, right) => left.docId - right.docId);\n250:       this.packedPostings.set(term, {\n251:         docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n252:         nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n253:         fqNameTfs: Uint32Array.from(order.map((entry) => postings.fqNameTfs[entry.index])),\n254:         signatureTfs: Uint32Array.from(order.map((entry) => postings.signatureTfs[entry.index])),\n255:         docstringTfs: Uint32Array.from(order.map((entry) => postings.docstringTfs[entry.index])),\n256:         filePathTfs: Uint32Array.from(order.map((entry) => postings.filePathTfs[entry.index])),\n257:       });\n258:     }\n259:     this.mutablePostings.clear();\n260:   }\n261: \n262:   search(query: string, options: SymbolBm25SearchOptions = {}): SymbolBm25Candidate[] {\n263:     const queryTerms = [...new Set(tokenize(query))];\n264:     if (queryTerms.length === 0 || this.documents.size === 0) return [];\n265: \n266:     const weights = resolveFieldWeights(options.fieldWeights);\n267:     const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n268:     const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n269: \n270:     for (const term of queryTerms) {\n271:       const postings = this.packedPostings.get(term);\n272:       if (!postings) continue;\n273:       const idf = this.idf(term);\n274:       for (let index = 0; index < postings.docIds.length; index += 1) {\n275:         const numericId = postings.docIds[index];\n276:         const symbolId = this.symbolIds[numericId];\n277:         const document = symbolId ? this.documents.get(symbolId) : undefined;\n278:         if (!document) continue;\n279:         const weightedTf = weightedFrequency(postings, index, weights);\n280:         if (weightedTf <= 0) continue;\n281: \n282:         const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n283:           / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (document.length / averageLength))));\n284:         const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n285:         existing.rawScore += termScore;\n286:         if (existing.evidence.length < 6) {\n287:           existing.evidence.push(`bm25:${term}`);\n288:           for (const field of topWeightedFields(postings, index, weights)) {\n289:             if (existing.evidence.length >= 6) break;\n290:             existing.evidence.push(`field:${field}`);\n291:           }\n292:         }\n293:         scores.set(numericId, existing);\n294:       }\n295:     }\n296: \n297:     const matches = [...scores.entries()]\n298:       .flatMap(([numericId, result]) => {\n299:         const symbolId = this.symbolIds[numericId];\n300:         const document = symbolId ? this.documents.get(symbolId) : undefined;\n301:         if (!document) return [];\n302:         return [{\n303:           symbolId: document.symbolId,\n304:           fqName: document.fqName,\n305:           name: document.name,\n306:           kind: document.kind,\n307:           filePath: document.filePath,\n308:           startLine: document.startLine,\n309:           rawScore: Number(result.rawScore.toFixed(6)),\n310:           score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n311:           evidence: result.evidence,\n312:           disambiguationOnly: true,\n313:         } satisfies SymbolBm25Candidate];\n314:       })\n315:       .filter((match) => match.score > 0);\n316: \n317:     return matches\n318:       .sort((left, right) => right.score - left.score\n319:         || (left.filePath ?? '').localeCompare(right.filePath ?? '')\n320:         || (left.startLine ?? Number.MAX_SAFE_INTEGER) - (right.startLine ?? Number.MAX_SAFE_INTEGER)\n321:         || left.symbolId.localeCompare(right.symbolId))\n322:       .slice(0, options.limit ?? DEFAULT_LIMIT);\n323:   }\n324: \n325:   getFootprintStats(): SymbolBm25FootprintStats {\n326:     let postingCount = 0;\n327:     let typedArrayBytes = 0;\n328:     for (const postings of this.packedPostings.values()) {\n329:       postingCount += postings.docIds.length;\n330:       typedArrayBytes += postings.docIds.byteLength\n331:         + postings.nameTfs.byteLength\n332:         + postings.fqNameTfs.byteLength\n333:         + postings.signatureTfs.byteLength\n334:         + postings.docstringTfs.byteLength\n335:         + postings.filePathTfs.byteLength;\n336:     }\n337:     return {\n338:       documentCount: this.documents.size,\n339:       termCount: this.packedPostings.size,\n340:       postingCount,\n\n(Showing lines 1-340 of 382. Use offset=341 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Symbol BM25 Resolver\n// ───────────────────────────────────────────────────────────────\n// Optional, fallback-only symbol candidate scoring over indexed symbol fields.\n\nexport const CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV = 'SPECKIT_CODE_GRAPH_BM25_SYMBOL_RESOLVER';\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 5;\nconst ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n\nconst SYMBOL_BM25_FIELD_NAMES = [\n  'name',\n  'fqName',\n  'signature',\n  'docstring',\n  'filePath',\n] as const;\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/symbol-bm25-resolver.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Symbol BM25 Resolver\n// ───────────────────────────────────────────────────────────────\n// Optional, fallback-only symbol candidate scoring over indexed symbol fields.\n\nexport const CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV = 'SPECKIT_CODE_GRAPH_BM25_SYMBOL_RESOLVER';\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 5;\nconst ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n\nconst SYMBOL_BM25_FIELD_NAMES = [\n  'name',\n  'fqName',\n  'signature',\n  'docstring',\n  'filePath',\n] as const;\n\nexport type SymbolBm25FieldName = typeof SYMBOL_BM25_FIELD_NAMES[number];\nexport type SymbolBm25FieldWeights = Record<SymbolBm25FieldName, number>;\n\nexport const SYMBOL_BM25_FIELD_WEIGHTS: SymbolBm25FieldWeights = {\n  name: 4.0,\n  fqName: 3.2,\n  signature: 2.0,\n  filePath: 1.2,\n  docstring: 0.7,\n};\n\nexport interface SymbolBm25Document {\n  readonly symbolId: string;\n  readonly fqName: string | null;\n  readonly name: string | null;\n  readonly kind: string | null;\n  readonly filePath: string | null;\n  readonly startLine: number | null;\n  readonly signature: string | null;\n  readonly docstring: string | null;\n}\n\nexport interface SymbolBm25SearchOptions {\n  readonly fieldWeights?: Partial<SymbolBm25FieldWeights>;\n  readonly limit?: number;\n}\n\nexport interface SymbolBm25Candidate {\n  readonly symbolId: string;\n  readonly fqName: string | null;\n  readonly name: string | null;\n  readonly kind: string | null;\n  readonly filePath: string | null;\n  readonly startLine: number | null;\n  readonly score: number;\n  readonly rawScore: number;\n  readonly evidence: readonly string[];\n  readonly disambiguationOnly: true;\n}\n\nexport interface SymbolBm25FootprintStats {\n  readonly documentCount: number;\n  readonly termCount: number;\n  readonly postingCount: number;\n  readonly typedArrayBytes: number;\n  readonly mutablePostingCount: number;\n}\n\ninterface FieldTermFrequency {\n  total: number;\n  fields: Record<SymbolBm25FieldName, number>;\n}\n\ninterface PackedSymbolDocument extends SymbolBm25Document {\n  numericId: number;\n  length: number;\n}\n\ninterface PackedPostingMutable {\n  docIds: number[];\n  nameTfs: number[];\n  fqNameTfs: number[];\n  signatureTfs: number[];\n  docstringTfs: number[];\n  filePathTfs: number[];\n}\n\ninterface PackedPostingList {\n  docIds: Uint32Array;\n  nameTfs: Uint32Array;\n  fqNameTfs: Uint32Array;\n  signatureTfs: Uint32Array;\n  docstringTfs: Uint32Array;\n  filePathTfs: Uint32Array;\n}\n\nfunction emptyFieldFrequency(): FieldTermFrequency {\n  return {\n    total: 0,\n    fields: {\n      name: 0,\n      fqName: 0,\n      signature: 0,\n      docstring: 0,\n      filePath: 0,\n    },\n  };\n}\n\nfunction resolveFieldWeights(overrides: Partial<SymbolBm25FieldWeights> = {}): SymbolBm25FieldWeights {\n  return {\n    name: overrides.name ?? SYMBOL_BM25_FIELD_WEIGHTS.name,\n    fqName: overrides.fqName ?? SYMBOL_BM25_FIELD_WEIGHTS.fqName,\n    signature: overrides.signature ?? SYMBOL_BM25_FIELD_WEIGHTS.signature,\n    docstring: overrides.docstring ?? SYMBOL_BM25_FIELD_WEIGHTS.docstring,\n    filePath: overrides.filePath ?? SYMBOL_BM25_FIELD_WEIGHTS.filePath,\n  };\n}\n\nexport function isCodeGraphBm25SymbolResolverEnabled(env: NodeJS.ProcessEnv = process.env): boolean {\n  const value = env[CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV]?.trim().toLowerCase();\n  return value ? ENABLED_VALUES.has(value) : false;\n}\n\nfunction splitIdentifier(value: string): string[] {\n  return value\n    .replace(/([a-z0-9])([A-Z])/g, '$1 $2')\n    .replace(/([A-Z]+)([A-Z][a-z])/g, '$1 $2')\n    .toLowerCase()\n    .split(/[^a-z0-9]+/)\n    .filter((token) => token.length >= 2);\n}\n\nfunction trigrams(token: string): string[] {\n  if (token.length < 4) return [];\n  const grams: string[] = [];\n  for (let index = 0; index <= token.length - 3; index += 1) {\n    grams.push(`tri:${token.slice(index, index + 3)}`);\n  }\n  return grams;\n}\n\nfunction tokenize(value: string | null | undefined): string[] {\n  if (!value) return [];\n  const baseTokens = splitIdentifier(value);\n  return baseTokens.flatMap((token) => [token, ...trigrams(token)]);\n}\n\nfunction documentFields(document: SymbolBm25Document): Record<SymbolBm25FieldName, readonly string[]> {\n  return {\n    name: [document.name ?? ''],\n    fqName: [document.fqName ?? ''],\n    signature: [document.signature ?? ''],\n    docstring: [document.docstring ?? ''],\n    filePath: [document.filePath ?? ''],\n  };\n}\n\nfunction fieldTermFrequencies(document: SymbolBm25Document): Map<string, FieldTermFrequency> {\n  const frequencies = new Map<string, FieldTermFrequency>();\n  for (const fieldName of SYMBOL_BM25_FIELD_NAMES) {\n    for (const value of documentFields(document)[fieldName]) {\n      for (const token of tokenize(value)) {\n        let frequency = frequencies.get(token);\n        if (!frequency) {\n          frequency = emptyFieldFrequency();\n          frequencies.set(token, frequency);\n        }\n        frequency.total += 1;\n        frequency.fields[fieldName] += 1;\n      }\n    }\n  }\n  return frequencies;\n}\n\nfunction weightedFrequency(\n  postings: PackedPostingList,\n  index: number,\n  weights: SymbolBm25FieldWeights,\n): number {\n  return postings.nameTfs[index] * weights.name\n    + postings.fqNameTfs[index] * weights.fqName\n    + postings.signatureTfs[index] * weights.signature\n    + postings.docstringTfs[index] * weights.docstring\n    + postings.filePathTfs[index] * weights.filePath;\n}\n\nfunction topWeightedFields(\n  postings: PackedPostingList,\n  index: number,\n  weights: SymbolBm25FieldWeights,\n): SymbolBm25FieldName[] {\n  return [\n    { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n    { field: 'fqName' as const, value: postings.fqNameTfs[index] * weights.fqName },\n    { field: 'signature' as const, value: postings.signatureTfs[index] * weights.signature },\n    { field: 'filePath' as const, value: postings.filePathTfs[index] * weights.filePath },\n    { field: 'docstring' as const, value: postings.docstringTfs[index] * weights.docstring },\n  ]\n    .filter((entry) => entry.value > 0)\n    .sort((left, right) => right.value - left.value)\n    .map((entry) => entry.field)\n    .slice(0, 3);\n}\n\nexport class SymbolPackedBm25Index {\n  private readonly symbolIds: string[] = [];\n  private readonly symbolNumbersById = new Map<string, number>();\n  private readonly documents = new Map<string, PackedSymbolDocument>();\n  private readonly documentFreq = new Map<string, number>();\n  private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n  private readonly packedPostings = new Map<string, PackedPostingList>();\n  private totalDocumentLength = 0;\n\n  constructor(documents: readonly SymbolBm25Document[] = []) {\n    for (const document of documents) {\n      this.addDocument(document);\n    }\n    this.finalize();\n  }\n\n  addDocument(document: SymbolBm25Document): void {\n    const frequencies = fieldTermFrequencies(document);\n    const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n    if (length === 0) return;\n\n    const numericId = this.nextNumericId(document.symbolId);\n    this.documents.set(document.symbolId, { ...document, numericId, length });\n    this.totalDocumentLength += length;\n\n    for (const term of [...frequencies.keys()].sort()) {\n      const frequency = frequencies.get(term);\n      if (!frequency) continue;\n      this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n      const postings = this.ensureMutablePostings(term);\n      postings.docIds.push(numericId);\n      postings.nameTfs.push(frequency.fields.name);\n      postings.fqNameTfs.push(frequency.fields.fqName);\n      postings.signatureTfs.push(frequency.fields.signature);\n      postings.docstringTfs.push(frequency.fields.docstring);\n      postings.filePathTfs.push(frequency.fields.filePath);\n    }\n  }\n\n  finalize(): void {\n    for (const [term, postings] of this.mutablePostings.entries()) {\n      const order = postings.docIds.map((docId, index) => ({ docId, index }))\n        .sort((left, right) => left.docId - right.docId);\n      this.packedPostings.set(term, {\n        docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n        nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n        fqNameTfs: Uint32Array.from(order.map((entry) => postings.fqNameTfs[entry.index])),\n        signatureTfs: Uint32Array.from(order.map((entry) => postings.signatureTfs[entry.index])),\n        docstringTfs: Uint32Array.from(order.map((entry) => postings.docstringTfs[entry.index])),\n        filePathTfs: Uint32Array.from(order.map((entry) => postings.filePathTfs[entry.index])),\n      });\n    }\n    this.mutablePostings.clear();\n  }\n\n  search(query: string, options: SymbolBm25SearchOptions = {}): SymbolBm25Candidate[] {\n    const queryTerms = [...new Set(tokenize(query))];\n    if (queryTerms.length === 0 || this.documents.size === 0) return [];\n\n    const weights = resolveFieldWeights(options.fieldWeights);\n    const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n    const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n\n    for (const term of queryTerms) {\n      const postings = this.packedPostings.get(term);\n      if (!postings) continue;\n      const idf = this.idf(term);\n      for (let index = 0; index < postings.docIds.length; index += 1) {\n        const numericId = postings.docIds[index];\n        const symbolId = this.symbolIds[numericId];\n        const document = symbolId ? this.documents.get(symbolId) : undefined;\n        if (!document) continue;\n        const weightedTf = weightedFrequency(postings, index, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n          / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (document.length / averageLength))));\n        const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n        existing.rawScore += termScore;\n        if (existing.evidence.length < 6) {\n          existing.evidence.push(`bm25:${term}`);\n          for (const field of topWeightedFields(postings, index, weights)) {\n            if (existing.evidence.length >= 6) break;\n            existing.evidence.push(`field:${field}`);\n          }\n        }\n        scores.set(numericId, existing);\n      }\n    }\n\n    const matches = [...scores.entries()]\n      .flatMap(([numericId, result]) => {\n        const symbolId = this.symbolIds[numericId];\n        const document = symbolId ? this.documents.get(symbolId) : undefined;\n        if (!document) return [];\n        return [{\n          symbolId: document.symbolId,\n          fqName: document.fqName,\n          name: document.name,\n          kind: document.kind,\n          filePath: document.filePath,\n          startLine: document.startLine,\n          rawScore: Number(result.rawScore.toFixed(6)),\n          score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n          evidence: result.evidence,\n          disambiguationOnly: true,\n        } satisfies SymbolBm25Candidate];\n      })\n      .filter((match) => match.score > 0);\n\n    return matches\n      .sort((left, right) => right.score - left.score\n        || (left.filePath ?? '').localeCompare(right.filePath ?? '')\n        || (left.startLine ?? Number.MAX_SAFE_INTEGER) - (right.startLine ?? Number.MAX_SAFE_INTEGER)\n        || left.symbolId.localeCompare(right.symbolId))\n      .slice(0, options.limit ?? DEFAULT_LIMIT);\n  }\n\n  getFootprintStats(): SymbolBm25FootprintStats {\n    let postingCount = 0;\n    let typedArrayBytes = 0;\n    for (const postings of this.packedPostings.values()) {\n      postingCount += postings.docIds.length;\n      typedArrayBytes += postings.docIds.byteLength\n        + postings.nameTfs.byteLength\n        + postings.fqNameTfs.byteLength\n        + postings.signatureTfs.byteLength\n        + postings.docstringTfs.byteLength\n        + postings.filePathTfs.byteLength;\n    }\n    return {\n      documentCount: this.documents.size,\n      termCount: this.packedPostings.size,\n      postingCount,","lineStart":1,"lineEnd":340,"totalLines":382,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/lib/symbol-bm25-resolver.ts","time":{"start":1781128832043,"end":1781128832052}},"metadata":{"openai":{"itemId":"fc_02508314844ac467016a29de7fea848191a701a5909a1015e2"}},"id":"prt_eb38d2424001zFWObIDxj0mJw2","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38cec4d0010WXvLEynEAUnvm"}}
{"type":"tool_use","timestamp":1781128832055,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_tAiy01Q5n8YVfkWFfEAlP527","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts","offset":200,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts</path>\n<type>file</type>\n<content>\n200:       rawScore: lane.rawScore,\n201:       weightedScore: lane.weightedScore,\n202:       weight: lane.weight,\n203:       shadowOnly: lane.shadowOnly,\n204:       evidenceTypes: Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))),\n205:       evidenceCount: lane.evidence.length,\n206:     })),\n207:     matchedSkillFeatures,\n208:   };\n209: }\n210: \n211: function publicRecommendation(recommendation: ScoredRecommendation, includeAttribution: boolean) {\n212:   const skillId = sanitizeSkillLabel(recommendation.skill);\n213:   if (!skillId) return null;\n214:   const redirectFrom = safeMany(recommendation.redirectFrom);\n215:   const redirectTo = sanitizeSkillLabel(recommendation.redirectTo ?? '');\n216:   const sanitizedStatus = sanitizeSkillLabel(recommendation.lifecycleStatus);\n217:   const status: PublicRecommendationStatus | undefined = sanitizedStatus === 'active'\n218:     || sanitizedStatus === 'deprecated'\n219:     || sanitizedStatus === 'archived'\n220:     || sanitizedStatus === 'future'\n221:     ? sanitizedStatus as PublicRecommendationStatus\n222:     : undefined;\n223:   return {\n224:     skillId,\n225:     score: recommendation.score,\n226:     confidence: recommendation.confidence,\n227:     uncertainty: recommendation.uncertainty,\n228:     dominantLane: recommendation.dominantLane,\n229:     ...(includeAttribution ? {\n230:       laneBreakdown: recommendation.laneContributions.map((lane) => ({\n231:         lane: lane.lane,\n232:         rawScore: lane.rawScore,\n233:         weightedScore: lane.weightedScore,\n234:         weight: lane.weight,\n235:         shadowOnly: lane.shadowOnly,\n236:       })),\n237:       why_recommended: publicWhyRecommended(recommendation),\n238:     } : {}),\n239:     ...(redirectFrom.length > 0 ? { redirectFrom } : {}),\n240:     ...(redirectTo ? { redirectTo } : {}),\n241:     ...(status ? { status } : {}),\n242:   };\n243: }\n244: \n245: function publicShadowRecommendations(recommendations: readonly ScoredRecommendation[], topK: number): ShadowRecommendation[] {\n246:   const shadowRecommendations: ShadowRecommendation[] = [];\n247:   for (const recommendation of recommendations) {\n248:     const skillId = sanitizeSkillLabel(recommendation.skill);\n249:     if (!skillId) continue;\n250:     const shadowContributions = recommendation.laneContributions.map((lane) => ({\n251:       lane: lane.lane,\n252:       weightedScore: lane.rawScore * DEFAULT_SHADOW_SCORER_LANE_WEIGHTS[lane.lane],\n253:     }));\n254:     const shadowScore = roundScore(shadowContributions.reduce((total, lane) => total + lane.weightedScore, 0));\n255:     const dominant = shadowContributions\n256:       .filter((lane) => lane.weightedScore > 0)\n257:       .sort((left, right) => right.weightedScore - left.weightedScore)[0]?.lane ?? null;\n258:     shadowRecommendations.push({\n259:         skillId,\n260:         liveScore: recommendation.score,\n261:         shadowScore,\n262:         delta: roundScore(shadowScore - recommendation.score),\n263:         dominantShadowLane: dominant,\n264:     });\n265:   }\n266:   return shadowRecommendations\n267:     .sort((left, right) => right.shadowScore - left.shadowScore || left.skillId.localeCompare(right.skillId))\n268:     .slice(0, topK);\n269: }\n270: \n271: function roundScore(value: number): number {\n272:   return Math.round(value * 1_000_000) / 1_000_000;\n273: }\n274: \n275: async function computeRecommendationOutput(input: AdvisorRecommendInput): Promise<AdvisorRecommendOutput> {\n276:   // Canonicalize via realpath after the schema allowlist check.\n277:   const workspaceRoot = input.workspaceRoot\n278:     ? canonicalizeWorkspaceRoot(input.workspaceRoot)\n279:     : findWorkspaceRoot();\n280:   const effectiveThresholds = publicThresholds({\n281:     confidenceThreshold: input.options?.confidenceThreshold,\n282:     uncertaintyThreshold: input.options?.uncertaintyThreshold,\n283:   });\n284:   const status = readAdvisorStatus({ workspaceRoot });\n285:   if (status.freshness === 'unavailable') {\n286:     return unavailableOutput(status, workspaceRoot, effectiveThresholds);\n287:   }\n288:   if (status.freshness === 'absent') {\n289:     return absentOutput(status, workspaceRoot, effectiveThresholds);\n290:   }\n291:   const sourceSignature = cacheSourceSignature(status);\n292:   advisorPromptCache.invalidateSourceSignatureChange(sourceSignature);\n293:   const key = advisorPromptCache.makeKey({\n294:     canonicalPrompt: input.prompt.trim(),\n295:     sourceSignature,\n296:     workspaceRoot,\n297:     runtime: 'mcp',\n298:     maxTokens: input.options?.topK,\n299:     thresholdConfig: {\n300:       confidenceThreshold: input.options?.confidenceThreshold,\n301:       uncertaintyThreshold: input.options?.uncertaintyThreshold,\n302:       includeAttribution: input.options?.includeAttribution,\n303:       includeAbstainReasons: input.options?.includeAbstainReasons,\n304:     },\n305:   });\n306:   const cached = advisorPromptCache.get(key);\n307:   if (cached) {\n308:     const cachedOutput = cached.value as AdvisorRecommendOutput;\n309:     return AdvisorRecommendOutputSchema.parse({\n310:       ...cachedOutput,\n311:       workspaceRoot,\n312:       effectiveThresholds,\n313:       cache: {\n314:         ...cachedOutput.cache,\n315:         hit: true,\n316:       },\n317:     });\n318:   }\n319: \n320:   const topK = input.options?.topK ?? 3;\n321:   const result = await withSemanticShadowPromptEmbedding(input.prompt, () => scoreAdvisorPrompt(input.prompt, {\n322:     workspaceRoot,\n323:     confidenceThreshold: input.options?.confidenceThreshold,\n324:     uncertaintyThreshold: input.options?.uncertaintyThreshold,\n325:   }));\n326:   const recommendations = result.recommendations\n327:     .map((recommendation) => publicRecommendation(recommendation, Boolean(input.options?.includeAttribution)))\n328:     .filter((recommendation): recommendation is NonNullable<typeof recommendation> => Boolean(recommendation))\n329:     .slice(0, topK);\n330:   const output: AdvisorRecommendOutput = {\n331:     workspaceRoot,\n332:     effectiveThresholds,\n333:     recommendations,\n334:     ambiguous: result.ambiguous,\n335:     freshness: status.freshness,\n336:     trustState: status.trustState,\n337:     generatedAt: new Date().toISOString(),\n338:     cache: {\n339:       hit: false,\n340:       sourceSignaturePresent: status.generation > 0 || status.lastGenerationBump !== null,\n341:     },\n342:     _shadow: {\n343:       model: 'advisor-shadow-learned-weights-v1',\n344:       liveWeightsFrozen: true,\n345:       recommendations: publicShadowRecommendations(result.recommendations, topK),\n346:     },\n347:     ...(status.freshness === 'stale' ? { warnings: [status.trustState.reason ?? 'STALE_ADVISOR_FRESHNESS'] } : {}),\n348:     ...(input.options?.includeAbstainReasons && result.unknown\n349:       ? { abstainReasons: ['No recommendation passed confidence and uncertainty thresholds.'] }\n350:       : {}),\n351:   };\n352:   const parsed = AdvisorRecommendOutputSchema.parse(output);\n353:   for (const shadow of parsed._shadow?.recommendations ?? []) {\n354:     recordShadowDelta({\n355:       prompt: input.prompt,\n356:       recommendation: shadow.skillId,\n357:       liveScore: shadow.liveScore,\n358:       shadowScore: shadow.shadowScore,\n359:       delta: shadow.delta,\n\n(Showing lines 200-359 of 394. Use offset=360 to continue.)\n</content>","metadata":{"preview":"      rawScore: lane.rawScore,\n      weightedScore: lane.weightedScore,\n      weight: lane.weight,\n      shadowOnly: lane.shadowOnly,\n      evidenceTypes: Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))),\n      evidenceCount: lane.evidence.length,\n    })),\n    matchedSkillFeatures,\n  };\n}\n\nfunction publicRecommendation(recommendation: ScoredRecommendation, includeAttribution: boolean) {\n  const skillId = sanitizeSkillLabel(recommendation.skill);\n  if (!skillId) return null;\n  const redirectFrom = safeMany(recommendation.redirectFrom);\n  const redirectTo = sanitizeSkillLabel(recommendation.redirectTo ?? '');\n  const sanitizedStatus = sanitizeSkillLabel(recommendation.lifecycleStatus);\n  const status: PublicRecommendationStatus | undefined = sanitizedStatus === 'active'\n    || sanitizedStatus === 'deprecated'\n    || sanitizedStatus === 'archived'","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts","text":"      rawScore: lane.rawScore,\n      weightedScore: lane.weightedScore,\n      weight: lane.weight,\n      shadowOnly: lane.shadowOnly,\n      evidenceTypes: Array.from(new Set(lane.evidence.map((entry) => evidenceFeature(entry)))),\n      evidenceCount: lane.evidence.length,\n    })),\n    matchedSkillFeatures,\n  };\n}\n\nfunction publicRecommendation(recommendation: ScoredRecommendation, includeAttribution: boolean) {\n  const skillId = sanitizeSkillLabel(recommendation.skill);\n  if (!skillId) return null;\n  const redirectFrom = safeMany(recommendation.redirectFrom);\n  const redirectTo = sanitizeSkillLabel(recommendation.redirectTo ?? '');\n  const sanitizedStatus = sanitizeSkillLabel(recommendation.lifecycleStatus);\n  const status: PublicRecommendationStatus | undefined = sanitizedStatus === 'active'\n    || sanitizedStatus === 'deprecated'\n    || sanitizedStatus === 'archived'\n    || sanitizedStatus === 'future'\n    ? sanitizedStatus as PublicRecommendationStatus\n    : undefined;\n  return {\n    skillId,\n    score: recommendation.score,\n    confidence: recommendation.confidence,\n    uncertainty: recommendation.uncertainty,\n    dominantLane: recommendation.dominantLane,\n    ...(includeAttribution ? {\n      laneBreakdown: recommendation.laneContributions.map((lane) => ({\n        lane: lane.lane,\n        rawScore: lane.rawScore,\n        weightedScore: lane.weightedScore,\n        weight: lane.weight,\n        shadowOnly: lane.shadowOnly,\n      })),\n      why_recommended: publicWhyRecommended(recommendation),\n    } : {}),\n    ...(redirectFrom.length > 0 ? { redirectFrom } : {}),\n    ...(redirectTo ? { redirectTo } : {}),\n    ...(status ? { status } : {}),\n  };\n}\n\nfunction publicShadowRecommendations(recommendations: readonly ScoredRecommendation[], topK: number): ShadowRecommendation[] {\n  const shadowRecommendations: ShadowRecommendation[] = [];\n  for (const recommendation of recommendations) {\n    const skillId = sanitizeSkillLabel(recommendation.skill);\n    if (!skillId) continue;\n    const shadowContributions = recommendation.laneContributions.map((lane) => ({\n      lane: lane.lane,\n      weightedScore: lane.rawScore * DEFAULT_SHADOW_SCORER_LANE_WEIGHTS[lane.lane],\n    }));\n    const shadowScore = roundScore(shadowContributions.reduce((total, lane) => total + lane.weightedScore, 0));\n    const dominant = shadowContributions\n      .filter((lane) => lane.weightedScore > 0)\n      .sort((left, right) => right.weightedScore - left.weightedScore)[0]?.lane ?? null;\n    shadowRecommendations.push({\n        skillId,\n        liveScore: recommendation.score,\n        shadowScore,\n        delta: roundScore(shadowScore - recommendation.score),\n        dominantShadowLane: dominant,\n    });\n  }\n  return shadowRecommendations\n    .sort((left, right) => right.shadowScore - left.shadowScore || left.skillId.localeCompare(right.skillId))\n    .slice(0, topK);\n}\n\nfunction roundScore(value: number): number {\n  return Math.round(value * 1_000_000) / 1_000_000;\n}\n\nasync function computeRecommendationOutput(input: AdvisorRecommendInput): Promise<AdvisorRecommendOutput> {\n  // Canonicalize via realpath after the schema allowlist check.\n  const workspaceRoot = input.workspaceRoot\n    ? canonicalizeWorkspaceRoot(input.workspaceRoot)\n    : findWorkspaceRoot();\n  const effectiveThresholds = publicThresholds({\n    confidenceThreshold: input.options?.confidenceThreshold,\n    uncertaintyThreshold: input.options?.uncertaintyThreshold,\n  });\n  const status = readAdvisorStatus({ workspaceRoot });\n  if (status.freshness === 'unavailable') {\n    return unavailableOutput(status, workspaceRoot, effectiveThresholds);\n  }\n  if (status.freshness === 'absent') {\n    return absentOutput(status, workspaceRoot, effectiveThresholds);\n  }\n  const sourceSignature = cacheSourceSignature(status);\n  advisorPromptCache.invalidateSourceSignatureChange(sourceSignature);\n  const key = advisorPromptCache.makeKey({\n    canonicalPrompt: input.prompt.trim(),\n    sourceSignature,\n    workspaceRoot,\n    runtime: 'mcp',\n    maxTokens: input.options?.topK,\n    thresholdConfig: {\n      confidenceThreshold: input.options?.confidenceThreshold,\n      uncertaintyThreshold: input.options?.uncertaintyThreshold,\n      includeAttribution: input.options?.includeAttribution,\n      includeAbstainReasons: input.options?.includeAbstainReasons,\n    },\n  });\n  const cached = advisorPromptCache.get(key);\n  if (cached) {\n    const cachedOutput = cached.value as AdvisorRecommendOutput;\n    return AdvisorRecommendOutputSchema.parse({\n      ...cachedOutput,\n      workspaceRoot,\n      effectiveThresholds,\n      cache: {\n        ...cachedOutput.cache,\n        hit: true,\n      },\n    });\n  }\n\n  const topK = input.options?.topK ?? 3;\n  const result = await withSemanticShadowPromptEmbedding(input.prompt, () => scoreAdvisorPrompt(input.prompt, {\n    workspaceRoot,\n    confidenceThreshold: input.options?.confidenceThreshold,\n    uncertaintyThreshold: input.options?.uncertaintyThreshold,\n  }));\n  const recommendations = result.recommendations\n    .map((recommendation) => publicRecommendation(recommendation, Boolean(input.options?.includeAttribution)))\n    .filter((recommendation): recommendation is NonNullable<typeof recommendation> => Boolean(recommendation))\n    .slice(0, topK);\n  const output: AdvisorRecommendOutput = {\n    workspaceRoot,\n    effectiveThresholds,\n    recommendations,\n    ambiguous: result.ambiguous,\n    freshness: status.freshness,\n    trustState: status.trustState,\n    generatedAt: new Date().toISOString(),\n    cache: {\n      hit: false,\n      sourceSignaturePresent: status.generation > 0 || status.lastGenerationBump !== null,\n    },\n    _shadow: {\n      model: 'advisor-shadow-learned-weights-v1',\n      liveWeightsFrozen: true,\n      recommendations: publicShadowRecommendations(result.recommendations, topK),\n    },\n    ...(status.freshness === 'stale' ? { warnings: [status.trustState.reason ?? 'STALE_ADVISOR_FRESHNESS'] } : {}),\n    ...(input.options?.includeAbstainReasons && result.unknown\n      ? { abstainReasons: ['No recommendation passed confidence and uncertainty thresholds.'] }\n      : {}),\n  };\n  const parsed = AdvisorRecommendOutputSchema.parse(output);\n  for (const shadow of parsed._shadow?.recommendations ?? []) {\n    recordShadowDelta({\n      prompt: input.prompt,\n      recommendation: shadow.skillId,\n      liveScore: shadow.liveScore,\n      shadowScore: shadow.shadowScore,\n      delta: shadow.delta,","lineStart":200,"lineEnd":359,"totalLines":394,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/handlers/advisor-recommend.ts","time":{"start":1781