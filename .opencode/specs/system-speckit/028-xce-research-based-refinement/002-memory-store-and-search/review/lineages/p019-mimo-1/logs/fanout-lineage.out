{"type":"tool_use","timestamp":1781719628415,"sessionID":"ses_1293d8f52ffeq7LR48U3s4YG7N","part":{"type":"tool","tool":"read","callID":"call_b2ade048c2eb45d6bd641d7c","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance-Active Marker\n3: // ───────────────────────────────────────────────────────────────\n4: // Signals the launcher that this daemon is busy-by-design (a background index\n5: // scan or a background-embedding burst) so a competing launcher adopts it\n6: // instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n7: // and refuses to reap a live daemon that holds a fresh marker (see the\n8: // shouldAdoptDespiteProbe guard in the launcher supervision lib).\n9: //\n10: // Reference-counted: the scan and the embedding queue can overlap (the scan\n11: // defers embeddings the queue then drains), so the marker stays present while\n12: // ANY maintenance source is active and is removed only when the last one ends.\n13: // A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n14: // becomes reapable again.\n15: \n16: import { rmSync } from 'node:fs';\n17: import path from 'node:path';\n18: \n19: import { DATABASE_DIR } from '../../core/config.js';\n20: import { atomicWriteFile } from './transaction-manager.js';\n21: \n22: const MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n23: // The TTL must exceed the longest single synchronous phase that cannot fire the\n24: // refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\n25: const MAINTENANCE_MARKER_TTL_MS = 180_000;\n26: const MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n27: \n28: export interface MaintenanceMarkerHandle {\n29:   // Refresh at a known progress point too: a non-yielding phase cannot fire the\n30:   // interval timer, so it only gets the refresh its caller makes explicitly.\n31:   refresh(): void;\n32:   // Idempotent. Decrements the active count and removes the marker at zero.\n33:   end(): void;\n34: }\n35: \n36: let activeCount = 0;\n37: let refreshTimer: ReturnType<typeof setInterval> | null = null;\n38: let activeLabels: string[] = [];\n39: \n40: function markerPath(): string {\n41:   return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n42: }\n43: \n44: function writeMarker(): void {\n45:   atomicWriteFile(markerPath(), `${JSON.stringify({\n46:     childPid: process.pid,\n47:     activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n48:     labels: activeLabels,\n49:     refreshedAtIso: new Date().toISOString(),\n50:   }, null, 2)}\\n`);\n51: }\n52: \n53: /**\n54:  * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n55:  * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n56:  * overlap with other maintenance sources.\n57:  */\n58: export function beginMaintenance(label: string): MaintenanceMarkerHandle {\n59:   activeCount += 1;\n60:   activeLabels.push(label);\n61:   writeMarker();\n62:   if (!refreshTimer) {\n63:     refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n64:     refreshTimer.unref?.();\n65:   }\n66: \n67:   let ended = false;\n68:   return {\n69:     refresh(): void {\n70:       if (!ended && activeCount > 0) writeMarker();\n71:     },\n72:     end(): void {\n73:       if (ended) return;\n74:       ended = true;\n75:       activeCount = Math.max(0, activeCount - 1);\n76:       const idx = activeLabels.indexOf(label);\n77:       if (idx >= 0) activeLabels.splice(idx, 1);\n78:       if (activeCount === 0) {\n79:         if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n80:         try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n81:       }\n82:     },\n83:   };\n84: }\n85: \n86: // Test-only: reset module state between cases.\n87: export function __resetMaintenanceMarkerForTest(): void {\n88:   if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n89:   activeCount = 0;\n90:   activeLabels = [];\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance-Active Marker\n// ───────────────────────────────────────────────────────────────\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance-Active Marker\n// ───────────────────────────────────────────────────────────────\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';\n\nconst MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n// The TTL must exceed the longest single synchronous phase that cannot fire the\n// refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\nconst MAINTENANCE_MARKER_TTL_MS = 180_000;\nconst MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n\nexport interface MaintenanceMarkerHandle {\n  // Refresh at a known progress point too: a non-yielding phase cannot fire the\n  // interval timer, so it only gets the refresh its caller makes explicitly.\n  refresh(): void;\n  // Idempotent. Decrements the active count and removes the marker at zero.\n  end(): void;\n}\n\nlet activeCount = 0;\nlet refreshTimer: ReturnType<typeof setInterval> | null = null;\nlet activeLabels: string[] = [];\n\nfunction markerPath(): string {\n  return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n}\n\nfunction writeMarker(): void {\n  atomicWriteFile(markerPath(), `${JSON.stringify({\n    childPid: process.pid,\n    activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n    labels: activeLabels,\n    refreshedAtIso: new Date().toISOString(),\n  }, null, 2)}\\n`);\n}\n\n/**\n * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n * overlap with other maintenance sources.\n */\nexport function beginMaintenance(label: string): MaintenanceMarkerHandle {\n  activeCount += 1;\n  activeLabels.push(label);\n  writeMarker();\n  if (!refreshTimer) {\n    refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n    refreshTimer.unref?.();\n  }\n\n  let ended = false;\n  return {\n    refresh(): void {\n      if (!ended && activeCount > 0) writeMarker();\n    },\n    end(): void {\n      if (ended) return;\n      ended = true;\n      activeCount = Math.max(0, activeCount - 1);\n      const idx = activeLabels.indexOf(label);\n      if (idx >= 0) activeLabels.splice(idx, 1);\n      if (activeCount === 0) {\n        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n        try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n      }\n    },\n  };\n}\n\n// Test-only: reset module state between cases.\nexport function __resetMaintenanceMarkerForTest(): void {\n  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n  activeCount = 0;\n  activeLabels = [];\n}","lineStart":1,"lineEnd":91,"totalLines":91,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","time":{"start":1781719628413,"end":1781719628414}},"id":"prt_ed6c3fa7c001V41LvSlZXROYVD","sessionID":"ses_1293d8f52ffeq7LR48U3s4YG7N","messageID":"msg_ed6c3dd18001SPOshrgSR7Sh3W"}}
{"type":"tool_use","timestamp":1781719628779,"sessionID":"ses_1293d8f52ffeq7LR48U3s4YG7N","part":{"type":"tool","tool":"read","callID":"call_c76ed1cf16344e92baf9af77","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { createRequire } from 'node:module';\n2: \n3: import { describe, expect, it } from 'vitest';\n4: \n5: type MaintenanceMarker = {\n6:   childPid: number;\n7:   activeUntilMs: number;\n8:   jobId?: string;\n9:   refreshedAtIso?: string;\n10: };\n11: \n12: const require = createRequire(import.meta.url);\n13: const launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n14:   readMaintenanceMarker: (\n15:     dbDir: string,\n16:     options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n17:   ) => MaintenanceMarker | null;\n18:   shouldAdoptDespiteProbe: (options?: {\n19:     marker?: MaintenanceMarker | null;\n20:     childPid?: number;\n21:     childLiveness?: string;\n22:     nowMs?: number | (() => number);\n23:   }) => boolean;\n24: };\n25: \n26: describe('launcher maintenance-active adopt guard', () => {\n27:   const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n28:   const freshMarker = (childPid: number): MaintenanceMarker => ({\n29:     childPid,\n30:     activeUntilMs: NOW + 30_000,\n31:     jobId: 'index-scan-1',\n32:     refreshedAtIso: '2026-06-09T00:00:00.000Z',\n33:   });\n34: \n35:   it('adopts a fresh marker that names this exact live child (a)', () => {\n36:     // Busy-by-design: the marker is unexpired, names the probed child, and the\n37:     // child is alive — the only case where adoption beats reaping.\n38:     expect(\n39:       launcher.shouldAdoptDespiteProbe({\n40:         marker: freshMarker(4242),\n41:         childPid: 4242,\n42:         childLiveness: 'alive',\n43:         nowMs: NOW,\n44:       }),\n45:     ).toBe(true);\n46:   });\n47: \n48:   it('reaps once the marker has expired (b)', () => {\n49:     // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n50:     // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n51:     expect(\n52:       launcher.shouldAdoptDespiteProbe({\n53:         marker: { ...freshMarker(4242), activeUntilMs: NOW },\n54:         childPid: 4242,\n55:         childLiveness: 'alive',\n56:         nowMs: NOW,\n57:       }),\n58:     ).toBe(false);\n59:   });\n60: \n61:   it('reaps when the marker names a different child (c)', () => {\n62:     // A marker left over from a prior daemon child must never pin the current\n63:     // one; a childPid mismatch falls through to the reap path.\n64:     expect(\n65:       launcher.shouldAdoptDespiteProbe({\n66:         marker: freshMarker(4242),\n67:         childPid: 9999,\n68:         childLiveness: 'alive',\n69:         nowMs: NOW,\n70:       }),\n71:     ).toBe(false);\n72:   });\n73: \n74:   it('reaps when the probed child is dead (d)', () => {\n75:     expect(\n76:       launcher.shouldAdoptDespiteProbe({\n77:         marker: freshMarker(4242),\n78:         childPid: 4242,\n79:         childLiveness: 'dead',\n80:         nowMs: NOW,\n81:       }),\n82:     ).toBe(false);\n83:   });\n84: \n85:   it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n86:     // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n87:     // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n88:     expect(\n89:       launcher.shouldAdoptDespiteProbe({\n90:         marker: freshMarker(4242),\n91:         childPid: 4242,\n92:         childLiveness: 'unknown-eperm',\n93:         nowMs: NOW,\n94:       }),\n95:     ).toBe(false);\n96:   });\n97: \n98:   it('reaps when there is no marker at all (f)', () => {\n99:     expect(\n100:       launcher.shouldAdoptDespiteProbe({\n101:         marker: null,\n102:         childPid: 4242,\n103:         childLiveness: 'alive',\n104:         nowMs: NOW,\n105:       }),\n106:     ).toBe(false);\n107:   });\n108: \n109:   it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n110:     for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n111:       expect(\n112:         launcher.shouldAdoptDespiteProbe({\n113:           marker: freshMarker(4242),\n114:           childPid,\n115:           childLiveness: 'alive',\n116:           nowMs: NOW,\n117:         }),\n118:       ).toBe(false);\n119:     }\n120:   });\n121: });\n122: \n123: describe('launcher maintenance marker reader (injected fs)', () => {\n124:   const injectFs = (readFileSync: (path: string) => string) =>\n125:     ({ fs: { readFileSync } });\n126: \n127:   it('returns the parsed object for a valid marker (a)', () => {\n128:     const marker = {\n129:       childPid: 4242,\n130:       activeUntilMs: 1_700_000_000_000,\n131:       jobId: 'index-scan-1',\n132:       refreshedAtIso: '2026-06-09T00:00:00.000Z',\n133:     };\n134:     expect(\n135:       launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n136:     ).toEqual(marker);\n137:   });\n138: \n139:   it('returns null when the marker file is missing (ENOENT) (b)', () => {\n140:     expect(\n141:       launcher.readMaintenanceMarker('/db', injectFs(() => {\n142:         throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n143:       })),\n144:     ).toBeNull();\n145:   });\n146: \n147:   it('returns null for corrupt JSON (c)', () => {\n148:     expect(\n149:       launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n150:     ).toBeNull();\n151:   });\n152: \n153:   it('returns null when childPid is missing (d)', () => {\n154:     expect(\n155:       launcher.readMaintenanceMarker(\n156:         '/db',\n157:         injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n158:       ),\n159:     ).toBeNull();\n160:   });\n161: \n162:   it('returns null when activeUntilMs is non-finite (e)', () => {\n163:     expect(\n164:       launcher.readMaintenanceMarker(\n165:         '/db',\n166:         // JSON.stringify turns Infinity into null, which is non-finite by the\n167:         // reader's Number.isFinite gate — the canonical corrupt-time shape.\n168:         injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n169:       ),\n170:     ).toBeNull();\n171:   });\n172: });\n\n(End of file - total 172 lines)\n</content>","metadata":{"preview":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","text":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;\n    childLiveness?: string;\n    nowMs?: number | (() => number);\n  }) => boolean;\n};\n\ndescribe('launcher maintenance-active adopt guard', () => {\n  const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n  const freshMarker = (childPid: number): MaintenanceMarker => ({\n    childPid,\n    activeUntilMs: NOW + 30_000,\n    jobId: 'index-scan-1',\n    refreshedAtIso: '2026-06-09T00:00:00.000Z',\n  });\n\n  it('adopts a fresh marker that names this exact live child (a)', () => {\n    // Busy-by-design: the marker is unexpired, names the probed child, and the\n    // child is alive — the only case where adoption beats reaping.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(true);\n  });\n\n  it('reaps once the marker has expired (b)', () => {\n    // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n    // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: { ...freshMarker(4242), activeUntilMs: NOW },\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the marker names a different child (c)', () => {\n    // A marker left over from a prior daemon child must never pin the current\n    // one; a childPid mismatch falls through to the reap path.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 9999,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the probed child is dead (d)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'dead',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n    // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n    // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'unknown-eperm',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when there is no marker at all (f)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: null,\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n    for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n      expect(\n        launcher.shouldAdoptDespiteProbe({\n          marker: freshMarker(4242),\n          childPid,\n          childLiveness: 'alive',\n          nowMs: NOW,\n        }),\n      ).toBe(false);\n    }\n  });\n});\n\ndescribe('launcher maintenance marker reader (injected fs)', () => {\n  const injectFs = (readFileSync: (path: string) => string) =>\n    ({ fs: { readFileSync } });\n\n  it('returns the parsed object for a valid marker (a)', () => {\n    const marker = {\n      childPid: 4242,\n      activeUntilMs: 1_700_000_000_000,\n      jobId: 'index-scan-1',\n      refreshedAtIso: '2026-06-09T00:00:00.000Z',\n    };\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n    ).toEqual(marker);\n  });\n\n  it('returns null when the marker file is missing (ENOENT) (b)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => {\n        throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n      })),\n    ).toBeNull();\n  });\n\n  it('returns null for corrupt JSON (c)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n    ).toBeNull();\n  });\n\n  it('returns null when childPid is missing (d)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n      ),\n    ).toBeNull();\n  });\n\n  it('returns null when activeUntilMs is non-finite (e)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        // JSON.stringify turns Infinity into null, which is non-finite by the\n        // reader's Number.isFinite gate — the canonical corrupt-time shape.\n        injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n      ),\n    ).toBeNull();\n  });\n});","lineStart":1,"lineEnd":172,"totalLines":172,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","time":{"start":1781719628768,"end":1781719628777}},"id":"prt_ed6c3fbdb0010Hv9ME76rrGkPY","sessionID":"ses_1293d8f52ffeq7LR48U3s4YG7N","messageID":"msg_ed6c3dd18001SPOshrgSR7Sh3W"}}
{"type":"tool_use","timestamp":1781719629370,"sessionID":"ses_1293d8f52ffeq7LR48U3s4YG7N","part":{"type":"tool","tool":"read","callID":"call_1ab0960b95a44e5a9c89019d","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // The sibling release-integration test proves the OS-level release-vs-kill\n6: // DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n7: // feature actually promises: with the flag ON, when an OWNER session disposes the\n8: // shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n9: // flag OFF the daemon DIES with its owner and the secondary loses transport.\n10: //\n11: // It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n12: // isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n13: // SIGTERM (what a host does on session end), and observes the shared daemon's pid\n14: // and the secondary's next call.\n15: //\n16: // SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n17: // launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n18: // the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n19: // guard resolves to the fake root, never the production tree); node_modules and\n20: // scripts are symlinked; the IPC socket lives in a short isolated dir. No\n21: // production lease, DB, or socket is read or written. Only processes this test\n22: // starts are signalled, tracked by pid, and force-reaped in teardown.\n23: \n24: import { spawn, spawnSync, type ChildProcess } from 'node:child_process';\n25: import { cpSync, copyFileSync, existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync, writeFileSync } from 'node:fs';\n26: import { tmpdir } from 'node:os';\n27: import { dirname, join, resolve } from 'node:path';\n28: import { fileURLToPath } from 'node:url';\n29: \n30: import { afterEach, describe, expect, it } from 'vitest';\n31: \n32: // stress_test/durability/<file> -> repo root is six levels up.\n33: const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\n34: const realBin = join(repoRoot, '.opencode/bin');\n35: const realKit = join(repoRoot, '.opencode/skills/system-spec-kit');\n36: const realMcp = join(realKit, 'mcp_server');\n37: \n38: const trackedPids = new Set<number>();\n39: const tempDirs = new Set<string>();\n40: \n41: function track(pid: number | undefined): void {\n42:   if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n43: }\n44: function isAlive(pid: number): boolean {\n45:   try { process.kill(pid, 0); return true; }\n46:   catch (e) { return (e as NodeJS.ErrnoException).code === 'EPERM'; }\n47: }\n48: function delay(ms: number): Promise<void> { return new Promise((r) => setTimeout(r, ms)); }\n49: \n50: // spawnSync (no shell) so the temp-dir argument is never interpreted by a shell. pgrep exits\n51: // non-zero with empty stdout when nothing matches, which yields an empty list.\n52: function pgrepContains(needle: string): number[] {\n53:   const res = spawnSync('pgrep', ['-f', needle], { encoding: 'utf8' });\n54:   const out = (res.stdout || '').trim();\n55:   return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n56: }\n57: \n58: // Distinct pids holding any *.sqlite* file open under dbDir. One = single writer. spawnSync (no\n59: // shell) plus JS parsing, so dbDir is never interpolated into a shell command. We parse stdout\n60: // regardless of exit status because `lsof +D` often exits non-zero on benign warnings while still\n61: // listing the open files.\n62: function sqliteOpenerPids(dbDir: string): number[] {\n63:   const res = spawnSync('lsof', ['+D', dbDir], { encoding: 'utf8' });\n64:   const out = res.stdout || '';\n65:   const pids = new Set<number>();\n66:   for (const line of out.split('\\n').slice(1)) {\n67:     const cols = line.split(/\\s+/);\n68:     const name = cols[8] || '';\n69:     if (/\\.(db|sqlite|sqlite3)/.test(name)) {\n70:       const pid = Number(cols[1]);\n71:       if (Number.isInteger(pid) && pid > 0) pids.add(pid);\n72:     }\n73:   }\n74:   return [...pids];\n75: }\n76: \n77: // Build an isolated fake-root: real-copied launcher + daemon dist, symlinked deps,\n78: // fresh lease/db dir. Returns the paths the two sessions share.\n79: function buildFakeRoot(): { base: string; sockDir: string; dbDir: string; launcher: string } {\n80:   const base = mkdtempSync(join(tmpdir(), 'rladopt.'));\n81:   tempDirs.add(base);\n82:   const fbin = join(base, '.opencode/bin');\n83:   const fkit = join(base, '.opencode/skills/system-spec-kit');\n84:   const fmcp = join(fkit, 'mcp_server');\n85:   mkdirSync(fbin, { recursive: true });\n86:   mkdirSync(fmcp, { recursive: true });\n87:   copyFileSync(join(realBin, 'mk-spec-memory-launcher.cjs'), join(fbin, 'mk-spec-memory-launcher.cjs'));\n88:   symlinkSync(join(realBin, 'lib'), join(fbin, 'lib'));\n89:   cpSync(join(realMcp, 'dist'), join(fmcp, 'dist'), { recursive: true });\n90:   symlinkSync(join(realMcp, 'node_modules'), join(fmcp, 'node_modules'));\n91:   if (existsSync(join(realKit, 'node_modules'))) symlinkSync(join(realKit, 'node_modules'), join(fkit, 'node_modules'));\n92:   symlinkSync(join(realMcp, 'package.json'), join(fmcp, 'package.json'));\n93:   symlinkSync(join(realKit, 'scripts'), join(fkit, 'scripts'));\n94:   const dbDir = join(fmcp, 'database');\n95:   mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n96:   const sockDir = mkdtempSync(join(tmpdir(), 'rladsk.'));\n97:   tempDirs.add(sockDir);\n98:   return { base, sockDir, dbDir, launcher: join(fbin, 'mk-spec-memory-launcher.cjs') };\n99: }\n100: \n101: type RpcResponse = { result?: unknown; error?: unknown; id?: number | null };\n102: \n103: // A minimal newline-delimited MCP JSON-RPC client over a launcher's stdio.\n104: function makeClient(child: ChildProcess) {\n105:   let buf = '';\n106:   const pending = new Map<number, (m: RpcResponse) => void>();\n107:   child.stdout!.setEncoding('utf8');\n108:   child.stdout!.on('data', (chunk: string) => {\n109:     buf += chunk;\n110:     let nl: number;\n111:     while ((nl = buf.indexOf('\\n')) >= 0) {\n112:       const line = buf.slice(0, nl).trim();\n113:       buf = buf.slice(nl + 1);\n114:       if (!line) continue;\n115:       let msg: RpcResponse;\n116:       try { msg = JSON.parse(line); } catch { continue; }\n117:       if (msg.id != null && pending.has(msg.id)) { pending.get(msg.id)!(msg); pending.delete(msg.id); }\n118:     }\n119:   });\n120:   child.stderr!.setEncoding('utf8');\n121:   child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n122:   let nextId = 1;\n123:   function request(method: string, params: unknown, timeoutMs = 30_000): Promise<RpcResponse> {\n124:     const id = nextId++;\n125:     return new Promise((resolveReq, rejectReq) => {\n126:       const timer = setTimeout(() => { pending.delete(id); rejectReq(new Error(`${method} timed out`)); }, timeoutMs);\n127:       pending.set(id, (m) => { clearTimeout(timer); resolveReq(m); });\n128:       try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', id, method, params }) + '\\n'); }\n129:       catch (e) { clearTimeout(timer); pending.delete(id); rejectReq(e as Error); }\n130:     });\n131:   }\n132:   function notify(method: string, params: unknown): void {\n133:     try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n134:   }\n135:   return { request, notify };\n136: }\n137: \n138: async function startSession(\n139:   paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n140:   enabled: boolean,\n141:   extraEnv: Record<string, string> = {},\n142: ): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n143:   const child = spawn(process.execPath, [paths.launcher], {\n144:     cwd: paths.base,\n145:     env: {\n146:       ...process.env,\n147:       SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n148:       SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n149:       SPEC_KIT_DB_DIR: paths.dbDir,\n150:       SPECKIT_LAUNCHER_LOG: '1',\n151:       AI_SESSION_CHILD: '1',\n152:       ...extraEnv,\n153:     },\n154:     stdio: ['pipe', 'pipe', 'pipe'],\n155:   });\n156:   track(child.pid);\n157:   const client = makeClient(child);\n158:   const init = await client.request('initialize', {\n159:     protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n160:   }, 30_000);\n161:   if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n162:   client.notify('notifications/initialized', {});\n163:   return { child, client };\n164: }\n165: \n166: // Spawn a competing launcher and send it an initialize WITHOUT requiring a completed MCP handshake.\n167: // When the marked daemon is busy-but-healthy, the launcher's contract is to refuse the respawn and\n168: // report lease-held on stdout, then exit 0 — it does NOT bridge the contending session into a live\n169: // transport (that session is told to back off, not adopted). So this helper observes the launcher's\n170: // decision (its stdout report + exit) rather than driving real MCP calls through it.\n171: async function spawnCompetingLauncher(\n172:   paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n173:   extraEnv: Record<string, string> = {},\n174: ): Promise<{ child: ChildProcess; settled: () => { exited: boolean; code: number | null; stdout: string } }> {\n175:   const child = spawn(process.execPath, [paths.launcher], {\n176:     cwd: paths.base,\n177:     env: {\n178:       ...process.env,\n179:       SPECKIT_DAEMON_REELECTION: '1',\n180:       SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n181:       SPEC_KIT_DB_DIR: paths.dbDir,\n182:       SPECKIT_LAUNCHER_LOG: '1',\n183:       AI_SESSION_CHILD: '1',\n184:       ...extraEnv,\n185:     },\n186:     stdio: ['pipe', 'pipe', 'pipe'],\n187:   });\n188:   track(child.pid);\n189:   let stdout = '';\n190:   let exited = false;\n191:   let code: number | null = null;\n192:   child.stdout!.setEncoding('utf8');\n193:   child.stdout!.on('data', (c: string) => { stdout += c; });\n194:   child.stderr!.setEncoding('utf8');\n195:   child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n196:   child.on('exit', (c) => { exited = true; code = c; });\n197:   // A bare initialize so a launcher that DID hand us a transport would answer; under refusal it\n198:   // instead emits its lease-held report and exits.\n199:   try {\n200:     child.stdin!.write(JSON.stringify({\n201:       jsonrpc: '2.0', id: 1, method: 'initialize',\n202:       params: { protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-compete', version: '1.0' } },\n203:     }) + '\\n');\n204:   } catch { /* launcher may already be exiting */ }\n205:   return { child, settled: () => ({ exited, code, stdout }) };\n206: }\n207: \n208: function leaseDaemonPid(base: string): number | null {\n209:   const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n210:   try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n211: }\n212: async function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n213:   try {\n214:     const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n215:     return !r.error;\n216:   } catch { return false; }\n217: }\n218: async function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n219:   const deadline = Date.now() + timeoutMs;\n220:   while (isAlive(pid) && Date.now() < deadline) await delay(50);\n221: }\n222: \n223: afterEach(async () => {\n224:   for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n225:   await delay(150);\n226:   // Sweep any detached daemon / embed sidecar that reparented to init.\n227:   for (const dir of tempDirs) {\n228:     for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n229:   }\n230:   await delay(150);\n231:   trackedPids.clear();\n232:   for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n233:   tempDirs.clear();\n234: });\n235: \n236: describe('daemon re-election: live two-session adoption', () => {\n237:   it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n238:     const paths = buildFakeRoot();\n239: \n240:     const owner = await startSession(paths, true);\n241:     expect(await statsOk(owner.client)).toBe(true);\n242:     const daemonPid = leaseDaemonPid(paths.base);\n243:     expect(daemonPid).toBeTypeOf('number');\n244:     track(daemonPid!);\n245:     expect(isAlive(daemonPid!)).toBe(true);\n246: \n247:     // Secondary joins while the owner holds the lease and the socket is live.\n248:     const secondary = await startSession(paths, true);\n249:     expect(await statsOk(secondary.client)).toBe(true);\n250:     // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n251:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n252: \n253:     // Dispose the owner.\n254:     owner.child.kill('SIGTERM');\n255:     await waitForExit(owner.child.pid!, 8_000);\n256:     expect(isAlive(owner.child.pid!)).toBe(false);\n257:     await delay(1_200);\n258: \n259:     // The released daemon outlives its owner and the secondary keeps transport.\n260:     expect(isAlive(daemonPid!)).toBe(true);\n261:     expect(await statsOk(secondary.client)).toBe(true);\n262:   });\n263: \n264:   it('flag ON: a FRESH session after owner disposal ADOPTS the released daemon (single writer)', async () => {\n265:     const paths = buildFakeRoot();\n266: \n267:     const owner = await startSession(paths, true);\n268:     expect(await statsOk(owner.client)).toBe(true);\n269:     const orphanPid = leaseDaemonPid(paths.base);\n270:     expect(orphanPid).toBeTypeOf('number');\n271:     track(orphanPid!);\n272: \n273:     // Dispose the owner: the daemon is RELEASED (survives), not killed.\n274:     owner.child.kill('SIGTERM');\n275:     await waitForExit(owner.child.pid!, 8_000);\n276:     await delay(1_200);\n277:     expect(isAlive(orphanPid!)).toBe(true);\n278: \n279:     // A brand-new session starts AFTER disposal. With true adoption it bridges to the still-live\n280:     // released daemon instead of reaping and respawning, so the warm daemon is reused and there is\n281:     // never a second writer.\n282:     const fresh = await startSession(paths, true);\n283:     expect(await statsOk(fresh.client)).toBe(true);\n284:     const newPid = leaseDaemonPid(paths.base);\n285:     expect(newPid).toBeTypeOf('number');\n286:     track(newPid!);\n287:     await delay(800);\n288: \n289:     // Adoption invariant: the released daemon is reused (same pid, still alive), not respawned.\n290:     expect(isAlive(orphanPid!)).toBe(true);\n291:     expect(newPid).toBe(orphanPid);\n292: \n293:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n294:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n295:     expect(dbWriters.length).toBe(1);\n296:   });\n297: \n298:   it('flag ON: a FRESH session does NOT adopt a WEDGED released daemon; it reaps and respawns (single writer)', async () => {\n299:     const paths = buildFakeRoot();\n300: \n301:     const owner = await startSession(paths, true);\n302:     expect(await statsOk(owner.client)).toBe(true);\n303:     const orphanPid = leaseDaemonPid(paths.base);\n304:     expect(orphanPid).toBeTypeOf('number');\n305:     track(orphanPid!);\n306: \n307:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n308:     owner.child.kill('SIGTERM');\n309:     await waitForExit(owner.child.pid!, 8_000);\n310:     await delay(1_200);\n311:     expect(isAlive(orphanPid!)).toBe(true);\n312: \n313:     // WEDGE the released daemon. SIGSTOP freezes its event loop, so it stays 'alive' to kill(pid,0)\n314:     // and still owns its listening socket, but it never services a JSON-RPC request — the exact\n315:     // observable state of a busy-loop / deadlock. A pre-fix launcher adopts on socket-existence alone\n316:     // and bridges the fresh session into a dead end; the fix must deep-probe, fail, and reap+respawn.\n317:     process.kill(orphanPid!, 'SIGSTOP');\n318: \n319:     // Fresh session with a short probe so the not-alive verdict is fast and deterministic. The reap\n320:     // grace (SIGTERM is ignored by a stopped process, then SIGKILL) is a fixed 7s, so allow generous\n321:     // startup time before the launcher answers initialize.\n322:     const fresh = await startSession(paths, true, {\n323:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n324:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n325:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n326:     });\n327:     expect(await statsOk(fresh.client, 20_000)).toBe(true);\n328:     const newPid = leaseDaemonPid(paths.base);\n329:     expect(newPid).toBeTypeOf('number');\n330:     track(newPid!);\n331: \n332:     // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n333:     expect(newPid).not.toBe(orphanPid);\n334:     await waitForExit(orphanPid!, 10_000);\n335:     expect(isAlive(orphanPid!)).toBe(false);\n336:     await delay(800);\n337: \n338:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n339:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n340:     expect(dbWriters.length).toBe(1);\n341:   }, 60_000);\n342: \n343:   it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n344:     const paths = buildFakeRoot();\n345: \n346:     const owner = await startSession(paths, true);\n347:     expect(await statsOk(owner.client)).toBe(true);\n348:     const orphanPid = leaseDaemonPid(paths.base);\n349:     expect(orphanPid).toBeTypeOf('number');\n350:     track(orphanPid!);\n351: \n352:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n353:     owner.child.kill('SIGTERM');\n354:     await waitForExit(owner.child.pid!, 8_000);\n355:     await delay(1_200);\n356:     expect(isAlive(orphanPid!)).toBe(true);\n357: \n358:     // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n359:     // intentionally too busy to service the probe. The launcher resolves the marker dir from\n360:     // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n361:     writeFileSync(\n362:       join(paths.dbDir, '.maintenance-active.json'),\n363:       JSON.stringify({\n364:         childPid: orphanPid,\n365:         activeUntilMs: Date.now() + 60_000,\n366:         jobId: 'test',\n367:         refreshedAtIso: new Date().toISOString(),\n368:       }),\n369:     );\n370: \n371:     // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n372:     // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n373:     // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n374:     // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n375:     process.kill(orphanPid!, 'SIGSTOP');\n376: \n377:     // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n378:     // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n379:     // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n380:     // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n381:     const compete = await spawnCompetingLauncher(paths, {\n382:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n383:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n384:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n385:     });\n386:     await waitForExit(compete.child.pid!, 20_000);\n387:     const settled = compete.settled();\n388:     // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n389:     expect(settled.exited).toBe(true);\n390:     expect(settled.code).toBe(0);\n391:     expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n392:     expect(settled.stdout).toMatch(/maintenance-active/);\n393: \n394:     // Let the marked daemon run again so teardown and the writer checks see a normal process.\n395:     process.kill(orphanPid!, 'SIGCONT');\n396:     await delay(800);\n397: \n398:     // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n399:     // never reaped and respawned, despite the probe failing while it was stopped.\n400:     expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n401:     expect(isAlive(orphanPid!)).toBe(true);\n402: \n403:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n404:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n405:     expect(dbWriters.length).toBe(1);\n406:   }, 60_000);\n407: \n408:   it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n409:     const paths = buildFakeRoot();\n410: \n411:     const owner = await startSession(paths, true);\n412:     expect(await statsOk(owner.client)).toBe(true);\n413:     const orphanPid = leaseDaemonPid(paths.base);\n414:     expect(orphanPid).toBeTypeOf('number');\n415:     track(orphanPid!);\n416: \n417:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n418:     owner.child.kill('SIGTERM');\n419:     await waitForExit(owner.child.pid!, 8_000);\n420:     await delay(1_200);\n421:     expect(isAlive(orphanPid!)).toBe(true);\n422: \n423:     // Publish a STALE maintenance marker (already expired): it names the live child but its\n424:     // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n425:     writeFileSync(\n426:       join(paths.dbDir, '.maintenance-active.json'),\n427:       JSON.stringify({\n428:         childPid: orphanPid,\n429:         activeUntilMs: Date.now() - 1_000,\n430:         jobId: 'test',\n431:         refreshedAtIso: new Date().toISOString(),\n432:       }),\n433:     );\n434: \n435:     // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n436:     process.kill(orphanPid!, 'SIGSTOP');\n437: \n438:     // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n439:     const fresh = await startSession(paths, true, {\n440:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n441:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n442:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n443:     });\n444:     expect(await statsOk(fresh.client, 20_000)).toBe(true);\n445:     const newPid = leaseDaemonPid(paths.base);\n446:     expect(newPid).toBeTypeOf('number');\n447:     track(newPid!);\n448: \n449:     // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n450:     // and a fresh daemon replaced it.\n451:     expect(newPid).not.toBe(orphanPid);\n452:     // The reap SIGKILLs the stopped orphan, so it may already be gone — SIGCONT only to be sure a\n453:     // surviving stopped process is resumable for teardown; tolerate ESRCH when it is already reaped.\n454:     try { process.kill(orphanPid!, 'SIGCONT'); } catch { /* already reaped */ }\n455:     await waitForExit(orphanPid!, 10_000);\n456:     expect(isAlive(orphanPid!)).toBe(false);\n457:     await delay(800);\n458: \n459:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n460:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n461:     expect(dbWriters.length).toBe(1);\n462:   }, 60_000);\n463: \n464:   it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n465:     const paths = buildFakeRoot();\n466: \n467:     const owner = await startSession(paths, false);\n468:     expect(await statsOk(owner.client)).toBe(true);\n469:     const daemonPid = leaseDaemonPid(paths.base);\n470:     expect(daemonPid).toBeTypeOf('number');\n471:     track(daemonPid!);\n472:     expect(isAlive(daemonPid!)).toBe(true);\n473: \n474:     const secondary = await startSession(paths, false);\n475:     expect(await statsOk(secondary.client)).toBe(true);\n476:     expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n477: \n478:     owner.child.kill('SIGTERM');\n479:     await waitForExit(owner.child.pid!, 8_000);\n480:     expect(isAlive(owner.child.pid!)).toBe(false);\n481:     await delay(1_200);\n482: \n483:     // With the flag off, the daemon dies with its owner and the secondary's next\n484:     // call fails (no surviving daemon to serve it) within a short window.\n485:     expect(isAlive(daemonPid!)).toBe(false);\n486:     expect(await statsOk(secondary.client, 6_000)).toBe(false);\n487:   });\n488: });\n\n(End of file - total 488 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n// ───────────────────────────────────────────────────────────────\n//\n// The sibling release-integration test proves the OS-level release-vs-kill\n// DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n// feature actually promises: with the flag ON, when an OWNER session disposes the\n// shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n// flag OFF the daemon DIES with its owner and the secondary loses transport.\n//\n// It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n// isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n// SIGTERM (what a host does on session end), and observes the shared daemon's pid\n// and the secondary's next call.\n//\n// SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n// launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n// the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n// guard resolves to the fake root, never the production tree); node_modules and\n// scripts are symlinked; the IPC socket lives in a short isolated dir. No","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// DURABILITY: daemon re-election LIVE two-session ADOPTION (real launchers)\n// ───────────────────────────────────────────────────────────────\n//\n// The sibling release-integration test proves the OS-level release-vs-kill\n// DECISION with a sleeper stand-in. This test proves the END-TO-END behavior the\n// feature actually promises: with the flag ON, when an OWNER session disposes the\n// shared daemon SURVIVES and a SECONDARY session keeps its MCP transport; with the\n// flag OFF the daemon DIES with its owner and the secondary loses transport.\n//\n// It runs TWO real mk-spec-memory launchers as MCP stdio servers against ONE\n// isolated fake-root, speaks real MCP JSON-RPC to each, disposes the owner with\n// SIGTERM (what a host does on session end), and observes the shared daemon's pid\n// and the secondary's next call.\n//\n// SAFETY: everything runs in a throwaway fake-root under the OS temp dir. The\n// launcher is REAL-COPIED (so its __dirname-derived lease/db dir is isolated) and\n// the daemon's dist is REAL-COPIED (so the daemon's workspace-root/DB boundary\n// guard resolves to the fake root, never the production tree); node_modules and\n// scripts are symlinked; the IPC socket lives in a short isolated dir. No\n// production lease, DB, or socket is read or written. Only processes this test\n// starts are signalled, tracked by pid, and force-reaped in teardown.\n\nimport { spawn, spawnSync, type ChildProcess } from 'node:child_process';\nimport { cpSync, copyFileSync, existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { afterEach, describe, expect, it } from 'vitest';\n\n// stress_test/durability/<file> -> repo root is six levels up.\nconst repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../../../..');\nconst realBin = join(repoRoot, '.opencode/bin');\nconst realKit = join(repoRoot, '.opencode/skills/system-spec-kit');\nconst realMcp = join(realKit, 'mcp_server');\n\nconst trackedPids = new Set<number>();\nconst tempDirs = new Set<string>();\n\nfunction track(pid: number | undefined): void {\n  if (typeof pid === 'number' && pid > 0) trackedPids.add(pid);\n}\nfunction isAlive(pid: number): boolean {\n  try { process.kill(pid, 0); return true; }\n  catch (e) { return (e as NodeJS.ErrnoException).code === 'EPERM'; }\n}\nfunction delay(ms: number): Promise<void> { return new Promise((r) => setTimeout(r, ms)); }\n\n// spawnSync (no shell) so the temp-dir argument is never interpreted by a shell. pgrep exits\n// non-zero with empty stdout when nothing matches, which yields an empty list.\nfunction pgrepContains(needle: string): number[] {\n  const res = spawnSync('pgrep', ['-f', needle], { encoding: 'utf8' });\n  const out = (res.stdout || '').trim();\n  return out ? out.split('\\n').map(Number).filter(Boolean) : [];\n}\n\n// Distinct pids holding any *.sqlite* file open under dbDir. One = single writer. spawnSync (no\n// shell) plus JS parsing, so dbDir is never interpolated into a shell command. We parse stdout\n// regardless of exit status because `lsof +D` often exits non-zero on benign warnings while still\n// listing the open files.\nfunction sqliteOpenerPids(dbDir: string): number[] {\n  const res = spawnSync('lsof', ['+D', dbDir], { encoding: 'utf8' });\n  const out = res.stdout || '';\n  const pids = new Set<number>();\n  for (const line of out.split('\\n').slice(1)) {\n    const cols = line.split(/\\s+/);\n    const name = cols[8] || '';\n    if (/\\.(db|sqlite|sqlite3)/.test(name)) {\n      const pid = Number(cols[1]);\n      if (Number.isInteger(pid) && pid > 0) pids.add(pid);\n    }\n  }\n  return [...pids];\n}\n\n// Build an isolated fake-root: real-copied launcher + daemon dist, symlinked deps,\n// fresh lease/db dir. Returns the paths the two sessions share.\nfunction buildFakeRoot(): { base: string; sockDir: string; dbDir: string; launcher: string } {\n  const base = mkdtempSync(join(tmpdir(), 'rladopt.'));\n  tempDirs.add(base);\n  const fbin = join(base, '.opencode/bin');\n  const fkit = join(base, '.opencode/skills/system-spec-kit');\n  const fmcp = join(fkit, 'mcp_server');\n  mkdirSync(fbin, { recursive: true });\n  mkdirSync(fmcp, { recursive: true });\n  copyFileSync(join(realBin, 'mk-spec-memory-launcher.cjs'), join(fbin, 'mk-spec-memory-launcher.cjs'));\n  symlinkSync(join(realBin, 'lib'), join(fbin, 'lib'));\n  cpSync(join(realMcp, 'dist'), join(fmcp, 'dist'), { recursive: true });\n  symlinkSync(join(realMcp, 'node_modules'), join(fmcp, 'node_modules'));\n  if (existsSync(join(realKit, 'node_modules'))) symlinkSync(join(realKit, 'node_modules'), join(fkit, 'node_modules'));\n  symlinkSync(join(realMcp, 'package.json'), join(fmcp, 'package.json'));\n  symlinkSync(join(realKit, 'scripts'), join(fkit, 'scripts'));\n  const dbDir = join(fmcp, 'database');\n  mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  const sockDir = mkdtempSync(join(tmpdir(), 'rladsk.'));\n  tempDirs.add(sockDir);\n  return { base, sockDir, dbDir, launcher: join(fbin, 'mk-spec-memory-launcher.cjs') };\n}\n\ntype RpcResponse = { result?: unknown; error?: unknown; id?: number | null };\n\n// A minimal newline-delimited MCP JSON-RPC client over a launcher's stdio.\nfunction makeClient(child: ChildProcess) {\n  let buf = '';\n  const pending = new Map<number, (m: RpcResponse) => void>();\n  child.stdout!.setEncoding('utf8');\n  child.stdout!.on('data', (chunk: string) => {\n    buf += chunk;\n    let nl: number;\n    while ((nl = buf.indexOf('\\n')) >= 0) {\n      const line = buf.slice(0, nl).trim();\n      buf = buf.slice(nl + 1);\n      if (!line) continue;\n      let msg: RpcResponse;\n      try { msg = JSON.parse(line); } catch { continue; }\n      if (msg.id != null && pending.has(msg.id)) { pending.get(msg.id)!(msg); pending.delete(msg.id); }\n    }\n  });\n  child.stderr!.setEncoding('utf8');\n  child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n  let nextId = 1;\n  function request(method: string, params: unknown, timeoutMs = 30_000): Promise<RpcResponse> {\n    const id = nextId++;\n    return new Promise((resolveReq, rejectReq) => {\n      const timer = setTimeout(() => { pending.delete(id); rejectReq(new Error(`${method} timed out`)); }, timeoutMs);\n      pending.set(id, (m) => { clearTimeout(timer); resolveReq(m); });\n      try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', id, method, params }) + '\\n'); }\n      catch (e) { clearTimeout(timer); pending.delete(id); rejectReq(e as Error); }\n    });\n  }\n  function notify(method: string, params: unknown): void {\n    try { child.stdin!.write(JSON.stringify({ jsonrpc: '2.0', method, params }) + '\\n'); } catch { /* gone */ }\n  }\n  return { request, notify };\n}\n\nasync function startSession(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  enabled: boolean,\n  extraEnv: Record<string, string> = {},\n): Promise<{ child: ChildProcess; client: ReturnType<typeof makeClient> }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: enabled ? '1' : '0',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',\n      AI_SESSION_CHILD: '1',\n      ...extraEnv,\n    },\n    stdio: ['pipe', 'pipe', 'pipe'],\n  });\n  track(child.pid);\n  const client = makeClient(child);\n  const init = await client.request('initialize', {\n    protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-adopt', version: '1.0' },\n  }, 30_000);\n  if (!init.result) throw new Error(`initialize failed: ${JSON.stringify(init.error)}`);\n  client.notify('notifications/initialized', {});\n  return { child, client };\n}\n\n// Spawn a competing launcher and send it an initialize WITHOUT requiring a completed MCP handshake.\n// When the marked daemon is busy-but-healthy, the launcher's contract is to refuse the respawn and\n// report lease-held on stdout, then exit 0 — it does NOT bridge the contending session into a live\n// transport (that session is told to back off, not adopted). So this helper observes the launcher's\n// decision (its stdout report + exit) rather than driving real MCP calls through it.\nasync function spawnCompetingLauncher(\n  paths: { base: string; sockDir: string; dbDir: string; launcher: string },\n  extraEnv: Record<string, string> = {},\n): Promise<{ child: ChildProcess; settled: () => { exited: boolean; code: number | null; stdout: string } }> {\n  const child = spawn(process.execPath, [paths.launcher], {\n    cwd: paths.base,\n    env: {\n      ...process.env,\n      SPECKIT_DAEMON_REELECTION: '1',\n      SPECKIT_IPC_SOCKET_DIR: paths.sockDir,\n      SPEC_KIT_DB_DIR: paths.dbDir,\n      SPECKIT_LAUNCHER_LOG: '1',\n      AI_SESSION_CHILD: '1',\n      ...extraEnv,\n    },\n    stdio: ['pipe', 'pipe', 'pipe'],\n  });\n  track(child.pid);\n  let stdout = '';\n  let exited = false;\n  let code: number | null = null;\n  child.stdout!.setEncoding('utf8');\n  child.stdout!.on('data', (c: string) => { stdout += c; });\n  child.stderr!.setEncoding('utf8');\n  child.stderr!.on('data', () => { /* swallow launcher stderr */ });\n  child.on('exit', (c) => { exited = true; code = c; });\n  // A bare initialize so a launcher that DID hand us a transport would answer; under refusal it\n  // instead emits its lease-held report and exits.\n  try {\n    child.stdin!.write(JSON.stringify({\n      jsonrpc: '2.0', id: 1, method: 'initialize',\n      params: { protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'reelect-compete', version: '1.0' } },\n    }) + '\\n');\n  } catch { /* launcher may already be exiting */ }\n  return { child, settled: () => ({ exited, code, stdout }) };\n}\n\nfunction leaseDaemonPid(base: string): number | null {\n  const f = join(base, '.opencode/skills/system-spec-kit/mcp_server/database/.mk-spec-memory-launcher.json');\n  try { return (JSON.parse(readFileSync(f, 'utf8')).childPid as number) ?? null; } catch { return null; }\n}\nasync function statsOk(client: ReturnType<typeof makeClient>, timeoutMs = 15_000): Promise<boolean> {\n  try {\n    const r = await client.request('tools/call', { name: 'memory_stats', arguments: {} }, timeoutMs);\n    return !r.error;\n  } catch { return false; }\n}\nasync function waitForExit(pid: number, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  while (isAlive(pid) && Date.now() < deadline) await delay(50);\n}\n\nafterEach(async () => {\n  for (const pid of trackedPids) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  await delay(150);\n  // Sweep any detached daemon / embed sidecar that reparented to init.\n  for (const dir of tempDirs) {\n    for (const pid of pgrepContains(dir)) { try { process.kill(pid, 'SIGKILL'); } catch { /* gone */ } }\n  }\n  await delay(150);\n  trackedPids.clear();\n  for (const dir of tempDirs) { try { rmSync(dir, { recursive: true, force: true }); } catch { /* best effort */ } }\n  tempDirs.clear();\n});\n\ndescribe('daemon re-election: live two-session adoption', () => {\n  it('flag ON: owner disposal RELEASES the shared daemon; secondary keeps transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    // Secondary joins while the owner holds the lease and the socket is live.\n    const secondary = await startSession(paths, true);\n    expect(await statsOk(secondary.client)).toBe(true);\n    // The secondary must BRIDGE to the owner's daemon, not spawn its own.\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    // Dispose the owner.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // The released daemon outlives its owner and the secondary keeps transport.\n    expect(isAlive(daemonPid!)).toBe(true);\n    expect(await statsOk(secondary.client)).toBe(true);\n  });\n\n  it('flag ON: a FRESH session after owner disposal ADOPTS the released daemon (single writer)', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // A brand-new session starts AFTER disposal. With true adoption it bridges to the still-live\n    // released daemon instead of reaping and respawning, so the warm daemon is reused and there is\n    // never a second writer.\n    const fresh = await startSession(paths, true);\n    expect(await statsOk(fresh.client)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n    await delay(800);\n\n    // Adoption invariant: the released daemon is reused (same pid, still alive), not respawned.\n    expect(isAlive(orphanPid!)).toBe(true);\n    expect(newPid).toBe(orphanPid);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  });\n\n  it('flag ON: a FRESH session does NOT adopt a WEDGED released daemon; it reaps and respawns (single writer)', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // WEDGE the released daemon. SIGSTOP freezes its event loop, so it stays 'alive' to kill(pid,0)\n    // and still owns its listening socket, but it never services a JSON-RPC request — the exact\n    // observable state of a busy-loop / deadlock. A pre-fix launcher adopts on socket-existence alone\n    // and bridges the fresh session into a dead end; the fix must deep-probe, fail, and reap+respawn.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // Fresh session with a short probe so the not-alive verdict is fast and deterministic. The reap\n    // grace (SIGTERM is ignored by a stopped process, then SIGKILL) is a fixed 7s, so allow generous\n    // startup time before the launcher answers initialize.\n    const fresh = await startSession(paths, true, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    expect(await statsOk(fresh.client, 20_000)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n\n    // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n    // intentionally too busy to service the probe. The launcher resolves the marker dir from\n    // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() + 60_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n    // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n    // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n    // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n    // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n    // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n    // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n    const compete = await spawnCompetingLauncher(paths, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    await waitForExit(compete.child.pid!, 20_000);\n    const settled = compete.settled();\n    // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n    expect(settled.exited).toBe(true);\n    expect(settled.code).toBe(0);\n    expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n    expect(settled.stdout).toMatch(/maintenance-active/);\n\n    // Let the marked daemon run again so teardown and the writer checks see a normal process.\n    process.kill(orphanPid!, 'SIGCONT');\n    await delay(800);\n\n    // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n    // never reaped and respawned, despite the probe failing while it was stopped.\n    expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a STALE maintenance marker (already expired): it names the live child but its\n    // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() - 1_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n    const fresh = await startSession(paths, true, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    expect(await statsOk(fresh.client, 20_000)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n\n    // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n    // and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    // The reap SIGKILLs the stopped orphan, so it may already be gone — SIGCONT only to be sure a\n    // surviving stopped process is resumable for teardown; tolerate ESRCH when it is already reaped.\n    try { process.kill(orphanPid!, 'SIGCONT'); } catch { /* already reaped */ }\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('flag OFF: owner disposal KILLS the shared daemon; secondary loses transport', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, false);\n    expect(await statsOk(owner.client)).toBe(true);\n    const daemonPid = leaseDaemonPid(paths.base);\n    expect(daemonPid).toBeTypeOf('number');\n    track(daemonPid!);\n    expect(isAlive(daemonPid!)).toBe(true);\n\n    const secondary = await startSession(paths, false);\n    expect(await statsOk(secondary.client)).toBe(true);\n    expect(leaseDaemonPid(paths.base)).toBe(daemonPid);\n\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    expect(isAlive(owner.child.pid!)).toBe(false);\n    await delay(1_200);\n\n    // With the flag off, the daemon dies with its owner and the secondary's next\n    // call fails (no surviving daemon to serve it) within a short window.\n    expect(isAlive(daemonPid!)).toBe(false);\n    expect(await statsOk(secondary.client, 6_000)).toBe(false);\n  });\n});","lineStart":1,"lineEnd":488,"totalLines":488,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","time":{"start":1781719629355,"end":1781719629367}},"id":"prt_ed6c3fe260018rmOnDeKz1NJJn","sessionID":"ses_1293d8f52ffeq7LR48U3s4YG7N","messageID":"msg_ed6c3dd18001SPOshrgSR7Sh3W"}}
