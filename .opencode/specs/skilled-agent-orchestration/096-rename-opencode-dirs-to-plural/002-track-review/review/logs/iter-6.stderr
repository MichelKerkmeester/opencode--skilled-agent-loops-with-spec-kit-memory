    21	function isEnabledEnvValue(value) {
    22	    return value?.trim().toLowerCase() === 'true';
    23	}
    24	function isIndexScopePolicySource(value) {
    25	    return value === 'default' || value === 'env' || value === 'scan-argument';
    26	}
    27	function hasPerCallScopeOverride(input) {
    28	    return input.includeSkills !== undefined
    29	        || input.includeAgents !== undefined
    30	        || input.includeCommands !== undefined
    31	        || input.includeSpecs !== undefined
    32	        || input.includePlugins !== undefined
    33	        || input.includeGlobs !== undefined
