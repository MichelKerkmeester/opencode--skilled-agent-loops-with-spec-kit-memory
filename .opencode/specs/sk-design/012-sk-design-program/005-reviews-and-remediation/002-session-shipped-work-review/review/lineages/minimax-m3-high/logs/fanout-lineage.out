"run_id\":null,\"label\":\"deepseek-v4-pro-high\",\"loop_type\":null,\"spec_folder\":null},\"event\":\"started\",\"status\":\"running\",\"observed_at_iso\":\"2026-07-21T03:57:47.081Z\",\"payload\":{\"event\":\"started\",\"label\":\"deepseek-v4-pro-high\",\"index\":0,\"attempt\":1,\"at\":\"2026-07-21T03:57:47.080Z\",\"gauges\":{\"lag\":2,\"pending\":1,\"failed\":0,\"oldest_pending_lag_ms\":1}}}\n{\"schema_version\":\"1.0\",\"event_id\":\"d30f62f7-72ae-4e81-aae5-7b1d92f3892c\",\"producer\":\"fanout-run\",\"stream\":\"orchestration-status\",\"subject\":{\"run_id\":null,\"label\":\"minimax-m3-high\",\"loop_type\":null,\"spec_folder\":null},\"event\":\"started\",\"status\":\"running\",\"observed_at_iso\":\"2026-07-21T03:57:47.084Z\",\"payload\":{\"event\":\"started\",\"label\":\"minimax-m3-high\",\"index\":1,\"attempt\":1,\"at\":\"2026-07-21T03:57:47.084Z\",\"gauges\":{\"lag\":2,\"pending\":0,\"failed\":0}}}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/specs/sk-design/016-session-shipped-work-review/review/observability-events.jsonl","text":"{\"schema_version\":\"1.0\",\"event_id\":\"669a7695-da18-4746-948b-52d3add4a815\",\"producer\":\"fanout-run\",\"stream\":\"orchestration-status\",\"subject\":{\"run_id\":null,\"label\":\"deepseek-v4-pro-high\",\"loop_type\":null,\"spec_folder\":null},\"event\":\"started\",\"status\":\"running\",\"observed_at_iso\":\"2026-07-21T03:57:47.081Z\",\"payload\":{\"event\":\"started\",\"label\":\"deepseek-v4-pro-high\",\"index\":0,\"attempt\":1,\"at\":\"2026-07-21T03:57:47.080Z\",\"gauges\":{\"lag\":2,\"pending\":1,\"failed\":0,\"oldest_pending_lag_ms\":1}}}\n{\"schema_version\":\"1.0\",\"event_id\":\"d30f62f7-72ae-4e81-aae5-7b1d92f3892c\",\"producer\":\"fanout-run\",\"stream\":\"orchestration-status\",\"subject\":{\"run_id\":null,\"label\":\"minimax-m3-high\",\"loop_type\":null,\"spec_folder\":null}