e without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n119:   'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n120:   'cms collection': [['mcp-code-mode', 1.4]],\n121:   'structural search': [['system-code-graph', 1.5]],\n122:   'code graph search': [['system-code-graph', 1.5]],\n123:   'find code that': [['system-code-graph', 1.4]],\n124:   'code that handles': [['system-code-graph', 1.4]],\n125:   '5d scoring': [['deep-loop-workflows', 1.5]],\n126:   '5-dimension agent scoring': [['deep-loop-workflows', 1.6]],\n127:   'integration scan': [['deep-loop-workflows', 1.5]],\n128:   'dynamic profile': [['deep-loop-workflows', 1.5]],\n129:   // Lane B (model-benchmark) command anchors. These benchmark or optimize a\n130:   // model / prompt framework against fixtures, routed by the\n131:   // /deep:start-model-benchmark-loop command (canonical deep-model-benchmark).\n132:   // Lane B runs as a MODE of the agent-improvement skill, now folded into\n133:   // deep-loop-workflows. The projection exposes that merged node, so the\n134:   // disambiguation penalty must target deep-loop-workflows to actually lower the\n135:   // ranked Lane A candidate; an alias-shaped target is not a projection node and\n136:   // its penalty would be inert. The bounded penalty keeps benchmark phrasing\n137:   // from out-ranking deep-model-benchmark.\n138:   'benchmark a model': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n139:   'benchmark a prompt framework': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.6]],\n140:   'benchmark a prompt': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n141:   'optimize a model': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n142:   'optimize a prompt framework': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.6]],\n143:   'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-loop-workflows', -0.4]],\n144:   'model benchmark': [['deep-model-benchmark', 1.4], ['deep-loop-workflows', -0.4]],\n145:   'benchmark fixtures': [['deep-model-benchmark', 1.3]],\n146:   'prompt framework benchmark': [['deep-model-benchmark', 1.5], ['deep-loop-workflows', -0.4]],\n147:   'chrome devtools': [['mcp-chrome-devtools', 1]],\n148:   'staging url': [['mcp-chrome-devtools', 0.65]],\n149:   'staging site': [['mcp-chrome-devtools', 0.65]],\n150:   'staging website': [['mcp-chrome-devtools', 0.65]],\n151:   'live site': [['mcp-chrome-devtools', 0.65]],\n152:   'live website': [['mcp-chrome-devtools', 0.65]],\n153:   'live url': [['mcp-chrome-devtools', 0.65]],\n154:   'production site': [['mcp-chrome-devtools', 0.65]],\n155:   'production website': [['mcp-chrome-devtools', 0.65]],\n156:   'production url': [['mcp-chrome-devtools', 0.65]],\n157:   'browser console': [['mcp-chrome-devtools', 0.75]],\n158:   'cleaner prompt': [['sk-prompt', 1]],\n159:   'code review': [['sk-code', 1]],\n160:   'review the routing': [['sk-code', 0.6]],\n161:   'review the taxonomy': [['sk-code', 0.6]],\n162:   'review the routing taxonomy': [['sk-code', 1.1], ['sk-doc', -0.4]],\n163:   'review the packet docs': [['sk-code', 1.2]],\n164:   'audit packet docs': [['sk-code', 1.2]],\n165:   'audit whether': [['sk-code', 1.2]],\n166:   'audit the': [['sk-code', 1.0]],\n167:   'documented consistently': [['sk-code', 1]],\n168:   'scoped correctly': [['sk-code', 1]],\n169:   'iteration is scoped': [['sk-code', 1]],\n170:   'classifier vocabulary': [['sk-code', 0.9]],\n171:   'commonjs helper': [['sk-code', 1]],\n172:   'create a prompt': [['sk-prompt', 0.95]],\n173:   'deep research': [['deep-loop-workflows', 1]],\n174:   'deep review': [['deep-loop-workflows', 1]],\n175:   'deep ai council': [['deep-loop-workflows', 1.6]],\n176:   'deep-ai-council': [['deep-loop-workflows', 1.6]],\n177:   'deep-research': [['deep-loop-workflows', 1.3]],\n178:   'deep-review': [['deep-loop-workflows', 1.3]],\n179:   'ai council': [['deep-loop-workflows', 1.4]],\n180:   'planning council': [['deep-loop-workflows', 1.2]],\n181:   'council deliberation': [['deep-loop-workflows', 1.4]],\n182:   'persist council artifacts': [['deep-loop-workflows', 1.2]],\n183:   'ai-council artifacts': [['deep-loop-workflows', 1.2]],\n184:   'multi-ai-council': [['deep-loop-workflows', 1.2]],\n185:   'gate 3': [['system-spec-kit', 0.35], ['sk-code', 0.25]],\n186:   'gate-3-classifier': [['sk-code', 1]],\n187:   'generate implementation-summary': [['system-spec-kit', 1]],\n188:   'implementation-summary.md': [['system-spec-kit', 0.8]],\n189:   'continuation prompts': [['system-spec-kit', 0.9]],\n190:   'first-100 predictions': [['system-spec-kit', 0.8]],\n191:   'improve my prompt': [['sk-prompt', 1]],\n192:   'manual testing playbook': [['sk-doc', 1]],\n193:   'negative-trigger whitelist': [['sk-code', 0.9]],\n194:   'list any mismatches': [['sk-code', 0.8]],\n195:   'pull request': [['sk-code', 0.45], ['sk-git', 0.45]],\n196:   'resume deep research': [['deep-loop-workflows', 1]],\n197:   'resume deep review': [['deep-loop-workflows', 1]],\n198:   'resume the phase folder': [['system-spec-kit', 1]],\n199:   'phase folder': [['system-spec-kit', 0.75]],\n200:   'routing dashboard': [['sk-code', 0.35]],\n201:   'routing study config': [['system-spec-kit', 0.85]],\n202:   'css layout': [['sk-code', 0.85]],\n203:   'viewport height': [['sk-code', 0.55]],\n204:   'mobile browser': [['sk-code', 0.6]],\n205:   'browser verification': [['sk-code', 0.7]],\n206:   'create a new agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n207:   'create a test playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n208:   'create a testing playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n209:   'create new agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n210:   'create test playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n211:   'create testing playbook': [['create:manual-testing-playbook', 1.8], ['command-create-manual-testing-playbook', 1.2], ['sk-doc', 0.2]],\n212:   'save context': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n213:   'save memory': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n214:   'semantic code search': [['system-code-graph', 0.8]],\n215:   'source-type mix': [['system-spec-kit', 0.35]],\n216:   'system prompt': [['sk-prompt', 0.8]],\n217:   'prompt variant': [['sk-prompt', 1]],\n218:   'user prompt': [['sk-prompt', 0.9]],\n219:   'cleaner user prompt': [['sk-prompt', 1]],\n220:   'vector-search': [['system-code-graph', 0.6]],\n221:   // sk-code phrases: frontend and system-code surfaces.\n222:   'motion v12': [['sk-code', 0.6]],\n223:   'opencode skill': [['sk-code', 0.95]],\n224:   'opencode agent': [['sk-code', 0.85]],\n225:   'opencode command': [['sk-code', 0.85]],\n226:   'opencode plugin': [['sk-code', 0.85]],\n227:   'smart router': [['sk-code', 0.65]],\n228:   'language standards': [['sk-code', 0.6]],\n229:   'typescript helper': [['sk-code', 0.75]],\n230:   'python script': [['sk-code', 0.75]],\n231:   'shell script': [['sk-code', 0.7]],\n232:   'frontend hero animation timing': [['sk-code', 0.95]],\n233:   'parallel routes': [['sk-code', 0.85]],\n234:   'route handler': [['sk-code', 0.7]],\n235:   'metadata api': [['sk-code', 0.65]],\n236: };\n237: \n238: const WRITE_VERBS = /\\b(add|build|change|configure|create|edit|fix|generate|implement|modify|patch|refactor|rename|replace|run|update|write)\\b/;\n239: const MEMORY_PRESERVATION_SESSION_INTENT = /\\b(preserve|remember|capture|keep|store)\\b.*\\b(next|future|later)\\s+session\\b|\\b(next|future|later)\\s+session\\b.*\\b(lose|lost|preserve|remember|capture|keep|store)\\b/;\n240: \n241: function push(\n242:   scores: Map<string, ExplicitScoreEntry>,\n243:   skillId: string,\n244:   amount: number,\n245:   evidence: string,\n246:   producerSkillId?: string,\n247: ): void {\n248:   const current = scores.get(skillId) ?? { score: 0, evidence: [], producerSkillIds: new Set<string>() };\n249:   current.score += amount;\n250:   current.evidence.push(evidence);\n251:   if (producerSkillId) {\n252:     current.producerSkillIds.add(producerSkillId);\n253:   }\n254:   scores.set(skillId, current);\n255: }\n256: \n257: export function scoreExplicitLane(\n258:   prompt: string,\n259:   projection: AdvisorProjection,\n260:   options: ExplicitLaneOptions = {},\n261: ): LaneMatch[] {\n262:   const lower = prompt.toLowerCase();\n263:   const tokens = tokenize(prompt, true);\n264:   const scores = new Map<string, ExplicitScoreEntry>();\n265: \n266:   for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {\n267:     if (!lower.includes(phrase)) continue;\n268:     for (const [skillId, amount] of boosts) {\n269:       push(scores, skillId, amount, `phrase:${phrase}`);\n270:     }\n271:   }\n272: \n273:   for (const token of tokens) {\n274:     for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {\n275:       push(scores, skillId, amount, `token:${token}`);\n276:     }\n277:   }\n278: \n279:   if (WRITE_VERBS.test(lower) && /\\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\\b/.test(lower)) {\n280:     push(scores, 'sk-doc', 0.7, 'write-doc-surface');\n281:   }\n282:   if (WRITE_VERBS.test(lower) && /\\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\\.py|mcp\\.json|commonjs)\\b/.test(lower)) {\n283:     push(scores, 'sk-code', 0.7, 'write-system-code-surface');\n284:   }\n285:   if (WRITE_VERBS.test(lower) && /\\b(error classes|trigger gap|reporter|mismatches?|bucket|gate 3)\\b/.test(lower)) {\n286:     push(scores, 'sk-code', 0.6, 'write-routing-tool-surface');\n287:   }\n288:   if (MEMORY_PRESERVATION_SESSION_INTENT.test(lower)) {\n289:     push(scores, 'memory:save', 1.2, 'memory-preservation-session-intent');\n290:     push(scores, 'command-memory-save', 0.8, 'memory-preservation-session-intent');\n291:     push(scores, 'system-spec-kit', 0.3, 'memory-preservation-session-intent');\n292:   }\n293:   if (lower.includes('/speckit:resume')) {\n294:     push(scores, 'system-spec-kit', 0.4, 'speckit-resume-skill-disambiguation');\n295:     push(scores, 'command-spec-kit', -1.0, 'speckit-resume-skill-disambiguation');\n296:   }\n297:   // Review-plus-write intent. When the prompt contains the word `review`\n298:   // AND an explicit write/edit verb (`update|edit|fix|modify`), the request\n299:   // is implementation work; anchor the explicit lane firmly on `sk-code` so\n300:   // the code hub wins the skill selection (its router then selects the\n301:   // implement mode rather than the code-review mode). The lane's emit clamps\n302:   // with `Math.min(value.score, 1)`, so the wide magnitude only guarantees\n303:   // the anchor; it cannot overshoot.\n304:   if (/\\breview\\b/.test(lower) && /\\b(update|edit|fix|modify)\\b/.test(lower)) {\n305:     push(scores, 'sk-code', 3.0, 'review-plus-write-disambiguation');\n306:   }\n307:   if (/\\b(continue|resume|launch|kick off|overnight|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\bresearch\\b/.test(lower)) {\n308:     push(scores, 'deep-loop-workflows', 0.85, 'research-loop');\n309:   }\n310:   if (/\\b(continue|resume|launch|start|convergence|iteration|iterative|multi-pass|loop)\\b/.test(lower) && /\\breview\\b/.test(lower)) {\n311:     push(scores, 'deep-loop-workflows', 0.85, 'review-loop');\n312:     if (/\\b(audit|spec folder|packet|convergence)\\b/.test(lower)) {\n313:       push(scores, 'sk-code', -0.6, 'iterative-review-vs-pr-disambiguation');\n314:     }\n315:   }\n316:   if (/\\b(figure out|find|diagnose|debug)\\b.{0,40}\\b(wrong|broken|failing|bug|issue)\\b.{0,40}\\bcode\\b|\\b(wrong|broken|failing)\\b.{0,30}\\bcode\\b/.test(lower)) {\n317:     push(scores, 'sk-code', 0.9, 'ambiguous-code-problem');\n318:     push(scores, 'deep-loop-workflows', 0.45, 'ambiguous-code-problem');\n319:   }\n320: \n321:   for (const skill of projection.skills) {\n322:     for (const variant of skillNameVariants(skill.id)) {\n323:       if (matchesPhraseBoundary(lower, variant)) {\n324:         push(scores, skill.id, 1, `explicit:${variant}`);\n325:       }\n326:     }\n327:     for (const phrase of [...skill.intentSignals, ...skill.keywords]) {\n328:       if (matchesPhraseBoundary(lower, phrase)) {\n329:         push(\n330:           scores,\n331:           skill.id,\n332:           phraseSpecificity(phrase),\n333:           `author:${phrase}`,\n334:           options.includeProducerIdentity ? skill.id : undefined,\n335:         );\n336:       }\n337:     }\n338:   }\n339: \n340:   return [...scores.entries()].map(([skillId, value]) => {\n\n(Showing lines 1-340 of 350. Use offset=341 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, skillNameVariants, tokenize } from '../text.js';\n\ninterface ExplicitLaneOptions {\n  readonly includeProducerIdentity?: boolean;\n}\n\ninterface ExplicitScoreEntry {\n  score: number;\n  readonly evidence: string[];\n  readonly producerSkillIds: Set<string>;\n}\n\nconst TOKEN_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  audit: [['sk-code', 0.75]],\n  branch: [['sk-git', 0.45]],","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───