    34	/**
    35	 * Fail-closed provenance guard. Scoped to the gated typed-pair taxonomy only:
    36	 * a plain report (no excluded rows, no row carrying an errorClass) never
    37	 * enters this check, so it can never trip for any pre-existing report shape.
    38	 * Once a report DOES carry gated rows, it must be able to say which skill
    39	 * root and manifest digest they were scored against, and every gated/excluded
    40	 * row must be individually identifiable — otherwise the report is rendered
    41	 * without knowing what it is claiming, which is worse than not rendering it.
    42	 *
    43	 * @param {Object} report - Candidate report object.
    44	 * @returns {string[]} Provenance problems; empty when the report is clean or ungated.
    45	 */
    46	function validateProvenance(report) {
    47	  const problems = [];
    48	  const excluded = Array.isArray(report && report.excludedRows) ? report.excludedRows : [];
    49	  const rows = Array.isArray(report && report.scenarioRows) ? report.scenarioRows : [];
    50	  const gatedRows = rows.filter((row) => row && row.errorClass != null);
    51	  if (excluded.length === 0 && gatedRows.length === 0) return problems;
    52	
    53	  if (!report || !report.targetSkill || !report.targetSkill.root) {
    54	    problems.push('missing provenance: targetSkill.root (skill root)');
    55	  }
    56	  if (!report.topologyDigest) {
    57	    problems.push('missing provenance: topologyDigest (manifest digest)');
    58	  }
    59	  for (const row of [...excluded, ...gatedRows]) {
    60	    if (!row.scenarioId) problems.push('missing provenance: a gated/excluded row has no scenarioId');
    61	  }
    62	  return problems;
    63	}
    64	
    65	// ─────────────────────────────────────────────────────────────────────────────
    66	// 3. CORE LOGIC
    67	// ─────────────────────────────────────────────────────────────────────────────
    68	
    69	/**
    70	 * Render the human-readable report.md from a machine report object.
    71	 * @param {Object} report - Parsed report.json object (scores, funnel, scenarios, etc.).
    72	 * @returns {string} Markdown document rendered deterministically from the report.
    73	 */
    74	function renderReport(report) {
    75	  const provenanceProblems = validateProvenance(report);
    76	  if (provenanceProblems.length) {
    77	    throw new Error(`build-report: fail-closed on missing provenance — ${provenanceProblems.join('; ')}`);
    78	  }
    79	  const r = report;
    80	  const lines = [];
    81	  lines.push(`# Skill Benchmark Report — ${r.targetSkill ? r.targetSkill.id : 'unknown'}`);
    82	  lines.push('');
    83	  lines.push(`> Rendered from report.json (do not hand-edit). Scoring: \`${r.scoringMethod}\` · trace mode: \`${r.traceMode}\`.`);
    84	  lines.push('');
    85	  lines.push(`**Verdict: ${r.verdict}**${r.aggregateScore != null ? ` · aggregate ${r.aggregateScore}/100` : ''}`);
    86	  if (r.gate && r.gate.gateFailed) lines.push(`\n⚠ **${r.gate.reason}** — verdict capped regardless of weighted score.`);
