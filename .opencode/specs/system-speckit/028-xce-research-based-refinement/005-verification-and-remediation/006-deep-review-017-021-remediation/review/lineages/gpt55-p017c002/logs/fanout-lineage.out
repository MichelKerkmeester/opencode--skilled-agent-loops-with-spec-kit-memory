{"type":"step_start","timestamp":1781757284932,"sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","part":{"id":"prt_ed9029243001iSLVzWHP6Q14Ni","messageID":"msg_ed9028bae001qh2ogOAQdtC8ZE","sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","snapshot":"c1b9335929560f5998bea356a6b889076eb7ae63","type":"step-start"}}
{"type":"text","timestamp":1781757295569,"sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","part":{"id":"prt_ed902a153001qaSqLntP3W1HJz","messageID":"msg_ed9028bae001qh2ogOAQdtC8ZE","sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","type":"text","text":"The implementation matches the intended high-level shape. I’m checking the calibration helpers and score normalization path now, because the review-critical risk is whether the new thresholds are applied on the actual 0-1 signal the code receives.","time":{"start":1781757288787,"end":1781757295565},"metadata":{"openai":{"itemId":"msg_067a45d1db0982a8016a337568bfe8819187c20e7b096a16a9","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781757295614,"sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","part":{"type":"tool","tool":"read","callID":"call_emcPpPRYKYpUn02EpCRPXzG8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Types\n3: // ───────────────────────────────────────────────────────────────\n4: // Stage interfaces with the Stage 4 immutability invariant\n5: import type { RetrievalTrace } from '@spec-kit/shared/contracts/retrieval-trace';\n6: import type { QueryPlan } from '../../query/query-plan.js';\n7: \n8: // Feature catalog: 4-stage pipeline architecture\n9: \n10: \n11: /**\n12:  * Memory search row — the canonical internal result type flowing through the pipeline.\n13:  * Extends Record<string, unknown> for backward compatibility with existing code.\n14:  */\n15: export interface PipelineRow extends Record<string, unknown> {\n16:   id: number;\n17:   similarity?: number;\n18:   score?: number;\n19:   importance_tier?: string;\n20:   contextType?: string;\n21:   context_type?: string;\n22:   attentionScore?: number;\n23:   retrievability?: number;\n24:   stability?: number;\n25:   last_review?: string | null;\n26:   created_at?: string;\n27:   last_accessed?: number;\n28:   content?: string;\n29:   memoryState?: string;\n30:   file_path?: string;\n31:   parent_id?: number | null;\n32:   chunk_index?: number | null;\n33:   chunk_label?: string | null;\n34:   isChunk?: boolean;\n35:   parentId?: number | null;\n36:   chunkIndex?: number | null;\n37:   chunkLabel?: string | null;\n38:   chunkCount?: number | null;\n39:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n40:   precomputedContent?: string;\n41:   quality_score?: number;\n42:   quality_flags?: string | string[] | null;\n43:   qualityFlags?: string | string[] | null;\n44:   importance_weight?: number;\n45:   rrfScore?: number;\n46:   intentAdjustedScore?: number;\n47:   /** Stage 2 composite score preserved for auditability when Stage 3 overwrites score */\n48:   stage2Score?: number;\n49:   /** Graph evidence provenance — edges and communities that contributed to graph-based boosts. */\n50:   graphEvidence?: {\n51:     edges: Array<{ sourceId: number; targetId: number; relation: string; strength: number }>;\n52:     communities: Array<{ communityId: number; summary?: string }>;\n53:     boostFactors: Array<{ type: string; delta: number }>;\n54:   };\n55: }\n56: \n57: /**\n58:  * Shared score resolution function — canonical fallback chain for deriving the\n59:  * \"best available score\" from a PipelineRow. Used by Stage 2, Stage 3, and any\n60:  * code needing a consistent effective score.\n61:  *\n62:  * Previously Stage 2 and Stage 3 had\n63:  * separate implementations with different fallback orders and clamping. This shared\n64:  * function uses the correct chain: intentAdjustedScore → rrfScore → score → similarity/100,\n65:  * all clamped to [0,1] with isFinite guards.\n66:  */\n67: export function resolveEffectiveScore(row: PipelineRow): number {\n68:   if (typeof row.intentAdjustedScore === 'number' && Number.isFinite(row.intentAdjustedScore))\n69:     return Math.max(0, Math.min(1, row.intentAdjustedScore));\n70:   if (typeof row.rrfScore === 'number' && Number.isFinite(row.rrfScore))\n71:     return Math.max(0, Math.min(1, row.rrfScore));\n72:   if (typeof row.score === 'number' && Number.isFinite(row.score))\n73:     return Math.max(0, Math.min(1, row.score));\n74:   if (typeof row.similarity === 'number' && Number.isFinite(row.similarity))\n75:     return Math.max(0, Math.min(1, row.similarity / 100));\n76:   return 0;\n77: }\n78: \n79: /**\n80:  * Absolute 0–1 relevance for confidence calibration and result-set digests —\n81:  * NOT for ordering. Prefers cosine similarity (an absolute relevance signal)\n82:  * over the RRF fusion score, whose magnitude (~0.01–0.05) is only meaningful as\n83:  * relative rank and badly understates relevance when read as an absolute 0–1\n84:  * quality. Feeding RRF magnitudes into 0.7/0.4-scaled thresholds makes \"good\"\n85:  * unreachable, so every hybrid query degrades to \"weak\"/\"gap\". Vector hits carry\n86:  * a real cosine; lexical-only hits (no similarity) fall back to the effective\n87:  * score, preserving their current behavior.\n88:  */\n89: export function resolveAbsoluteRelevance(row: PipelineRow): number {\n90:   if (typeof row.similarity === 'number' && Number.isFinite(row.similarity)) {\n91:     // sqlite-vec emits cosine on a 0–100 scale; normalize. Already-0–1 inputs pass through.\n92:     const normalized = row.similarity > 1 ? row.similarity / 100 : row.similarity;\n93:     return Math.max(0, Math.min(1, normalized));\n94:   }\n95:   return resolveEffectiveScore(row);\n96: }\n97: \n98: /**\n99:  * Stage 4 read-only row — compile-time enforcement that Stage 4 cannot modify scores.\n100:  * OQ-S5-001 CLOSED: Primary enforcement via TypeScript read-only type guards.\n101:  * All score-related fields are Readonly to prevent mutation in Stage 4.\n102:  */\n103: export interface Stage4ReadonlyRow extends Readonly<Pick<PipelineRow,\n104:   'similarity' | 'score' | 'importance_weight' | 'rrfScore' | 'intentAdjustedScore' | 'attentionScore'\n105: >> {\n106:   readonly id: number;\n107:   // Non-score fields remain mutable for annotation purposes\n108:   importance_tier?: string;\n109:   contextType?: string;\n110:   context_type?: string;\n111:   retrievability?: number;\n112:   stability?: number;\n113:   last_review?: string | null;\n114:   created_at?: string;\n115:   last_accessed?: number;\n116:   content?: string;\n117:   memoryState?: string;\n118:   file_path?: string;\n119:   parent_id?: number | null;\n120:   chunk_index?: number | null;\n121:   chunk_label?: string | null;\n122:   isChunk?: boolean;\n123:   parentId?: number | null;\n124:   chunkIndex?: number | null;\n125:   chunkLabel?: string | null;\n126:   chunkCount?: number | null;\n127:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n128:   precomputedContent?: string;\n129:   quality_score?: number;\n130:   // Annotation fields (Stage 4 may add these)\n131:   channelAttribution?: string[];\n132:   evidenceGap?: { gapDetected: boolean; warning?: string };\n133: }\n134: \n135: // -- Pipeline Configuration --\n136: \n137: /**\n138:  * Normalized configuration consumed by the four-stage retrieval pipeline.\n139:  */\n140: export interface PipelineConfig {\n141:   query: string;\n142:   queryEmbedding?: Float32Array;\n143:   concepts?: string[];\n144:   searchType: 'hybrid' | 'vector' | 'multi-concept';\n145:   mode?: string;\n146: \n147:   // Limits and filtering\n148:   limit: number;\n149:   specFolder?: string;\n150:   tenantId?: string;\n151:   userId?: string;\n152:   agentId?: string;\n153:   tier?: string;\n154:   contextType?: string;\n155:   includeArchived: boolean;\n156:   includeConstitutional: boolean;\n157:   includeContent: boolean;\n158:   anchors?: string[];\n159:   qualityThreshold?: number;\n160: \n161:   // Scoring configuration\n162:   minState: string;\n163:   applyStateLimits: boolean;\n164:   useDecay: boolean;\n165:   rerank: boolean;\n166:   applyLengthPenalty: boolean;\n167: \n168:   // Session and boost\n169:   sessionId?: string;\n170:   enableDedup: boolean;\n171:   enableSessionBoost: boolean;\n172:   enableCausalBoost: boolean;\n173:   trackAccess: boolean;\n174: \n175:   // Intent\n176:   detectedIntent: string | null;\n177:   adaptiveFusionIntent?: string | null;\n178:   intentConfidence: number;\n179:   intentWeights: IntentWeightsConfig | null;\n180: \n181:   // Routing\n182:   artifactRouting?: ArtifactRoutingConfig;\n183:   queryPlan?: QueryPlan;\n184: \n185:   // Trace\n186:   trace?: RetrievalTrace;\n187: }\n188: \n189: /**\n190:  * Intent-aware weighting factors applied during fusion.\n191:  */\n192: export interface IntentWeightsConfig {\n193:   similarity: number;\n194:   importance: number;\n195:   recency: number;\n196: }\n197: \n198: /**\n199:  * Artifact-class routing decision passed into the pipeline.\n200:  */\n201: export interface ArtifactRoutingConfig {\n202:   detectedClass: string;\n203:   confidence: number;\n204:   strategy: {\n205:     maxResults: number;\n206:     [key: string]: unknown;\n207:   };\n208: }\n209: \n210: // -- Stage Interfaces --\n211: \n212: /**\n213:  * Stage 1: Candidate Generation\n214:  * Executes search channels (FTS5, semantic, trigger, graph, co-activation)\n215:  * and collects raw results. No scoring modifications.\n216:  */\n217: export interface Stage1Input {\n218:   config: PipelineConfig;\n219: }\n220: \n221: /**\n222:  * Stage 1 output containing candidate rows and generation metadata.\n223:  */\n224: export interface Stage1Output {\n225:   candidates: PipelineRow[];\n226:   metadata: {\n227:     searchType: string;\n228:     channelCount: number;\n229:     /** Actual retrieval channels active (vector=1, hybrid=2). Unlike channelCount which tracks query variants. */\n230:     activeChannels?: number;\n231:     candidateCount: number;\n232:     constitutionalInjected: number;\n233:     durationMs: number;\n234:   };\n235: }\n236: \n237: /**\n238:  * Tri-state for signal application metadata.\n239:  * Replaces boolean flags so callers can distinguish \"feature disabled\n240:  * by config\" ('off') from \"feature crashed\" ('failed') from \"feature applied\n241:  * successfully\" ('applied').\n242:  */\n243: export type SignalStatus = 'off' | 'applied' | 'enabled' | 'failed';\n244: \n245: /**\n246:  * Stage 2: Fusion + Signal Integration\n247:  * Single point for ALL scoring signals: RRF/RSF, causal boost, co-activation,\n248:  * composite, intent weights (applied ONCE — prevents G2 recurrence).\n249:  * Score changes: YES\n250:  */\n251: export interface Stage2Input {\n252:   candidates: PipelineRow[];\n253:   config: PipelineConfig;\n254:   stage1Metadata: Stage1Output['metadata'];\n255: }\n256: \n257: /**\n258:  * Stage 2 output containing scored rows and fusion metadata.\n259:  */\n260: export interface Stage2Output {\n261:   scored: PipelineRow[];\n262:   metadata: {\n263:     sessionBoostApplied: SignalStatus;\n264:     causalBoostApplied: SignalStatus;\n265:     intentWeightsApplied: SignalStatus;\n266:     artifactRoutingApplied: SignalStatus;\n267:     feedbackSignalsApplied: SignalStatus;\n268:     graphContribution?: {\n269:       killSwitchActive: boolean;\n270:       causalBoosted: number;\n271:       coActivationBoosted: number;\n272:       communityInjected: number;\n273:       graphSignalsBoosted: number;\n274:       totalGraphInjected: number;\n275:       rolloutState?: 'off' | 'trace_only' | 'bounded_runtime';\n276:     };\n277:     qualityFiltered: number;\n278:     durationMs: number;\n279:   };\n280: }\n281: \n282: /**\n283:  * Stage 3: Rerank + Aggregate\n284:  * Cross-encoder reranking, MMR diversity enforcement, MPAB chunk-to-memory aggregation.\n285:  * Score changes: YES\n286:  */\n287: export interface Stage3Input {\n288:   scored: PipelineRow[];\n289:   config: PipelineConfig;\n290: }\n291: \n292: /**\n293:  * Stage 3 output containing reranked rows and reranking metadata.\n294:  */\n295: export interface Stage3Output {\n296:   reranked: PipelineRow[];\n297:   metadata: {\n298:     rerankApplied: boolean;\n299:     rerankProvider?: string;\n300:     chunkReassemblyStats: {\n301:       collapsedChunkHits: number;\n302:       chunkParents: number;\n303:       reassembled: number;\n304:       fallback: number;\n305:     };\n306:     durationMs: number;\n307:   };\n308: }\n309: \n310: /**\n311:  * Stage 4: Filter + Annotate\n312:  * State filtering, session dedup, constitutional injection, channel attribution.\n313:  * Score changes: **NO** — Architectural invariant.\n314:  *\n315:  * Runtime assertion: scores at entry must equal scores at exit.\n316:  * Compile-time enforcement: input type uses Stage4ReadonlyRow with readonly score fields.\n317:  */\n318: export interface Stage4Input {\n319:   /** Results with read-only score fields — Stage 4 cannot modify scores */\n320:   results: Stage4ReadonlyRow[];\n321:   config: PipelineConfig;\n322:   /** Stage 1 metadata passed through for constitutional count */\n323:   stage1Metadata?: { constitutionalInjected?: number };\n324: }\n325: \n326: /**\n327:  * Stage 4 output containing final rows, filter metadata, and annotations.\n328:  */\n329: export interface Stage4Output {\n330:   final: Stage4ReadonlyRow[];\n331:   metadata: {\n332:     stateFiltered: number;\n333:     constitutionalInjected: number;\n334:     evidenceGapDetected: boolean;\n335:     durationMs: number;\n336:   };\n337:   annotations: {\n338:     evidenceGapWarning?: string;\n339:     stateStats: Record<string, unknown>;\n340:     featureFlags: Record<string, boolean>;\n341:   };\n342: }\n343: \n344: // -- Pipeline Result --\n345: \n346: /**\n347:  * Final pipeline response returned to retrieval callers.\n348:  */\n349: export interface PipelineResult {\n350:   results: Stage4ReadonlyRow[];\n351:   metadata: {\n352:     stage1: Stage1Output['metadata'];\n353:     stage2: Stage2Output['metadata'];\n354:     stage3: Stage3Output['metadata'];\n355:     stage4: Stage4Output['metadata'];\n356:     /** Per-stage and total timing in milliseconds for latency observability. */\n357:     timing?: Record<string, number>;\n358:     /** True when one or more stages fell back to degraded output. */\n359:     degraded?: boolean;\n360:   };\n361:   annotations: Stage4Output['annotations'];\n362:   trace?: RetrievalTrace;\n363: }\n364: \n365: // -- Stage Function Types --\n366: \n367: /**\n368:  * Executor signature for Stage 1 candidate generation.\n369:  */\n370: export type Stage1Fn = (input: Stage1Input) => Promise<Stage1Output>;\n371: /**\n372:  * Executor signature for Stage 2 fusion and signal integration.\n373:  */\n374: export type Stage2Fn = (input: Stage2Input) => Promise<Stage2Output>;\n375: /**\n376:  * Executor signature for Stage 3 reranking and aggregation.\n377:  */\n378: export type Stage3Fn = (input: Stage3Input) => Promise<Stage3Output>;\n379: /**\n380:  * Executor signature for Stage 4 filtering and annotation.\n381:  */\n382: export type Stage4Fn = (input: Stage4Input) => Promise<Stage4Output>;\n383: \n384: // -- Score Snapshot Utility (Runtime assertion for Stage 4 invariant) --\n385: \n386: /**\n387:  * Captures score values from results for invariant checking.\n388:  * Used to verify Stage 4 does not modify any scores.\n389:  */\n390: export interface ScoreSnapshot {\n391:   id: number;\n392:   similarity?: number;\n393:   score?: number;\n394:   importance_weight?: number;\n395:   rrfScore?: number;\n396:   intentAdjustedScore?: number;\n397:   attentionScore?: number;\n398: }\n399: \n400: /**\n401:  * Take a snapshot of score fields for later invariant verification.\n402:  */\n403: export function captureScoreSnapshot(results: Stage4ReadonlyRow[]): ScoreSnapshot[] {\n404:   return results.map(r => ({\n405:     id: r.id,\n406:     similarity: r.similarity,\n407:     score: r.score,\n408:     importance_weight: r.importance_weight,\n409:     rrfScore: r.rrfScore,\n410:     intentAdjustedScore: r.intentAdjustedScore,\n411:     attentionScore: r.attentionScore,\n412:   }));\n413: }\n414: \n415: /**\n416:  * Verify Stage 4 invariant: no score fields were modified.\n417:  * Throws if any score differs between before and after snapshots.\n418:  */\n419: export function verifyScoreInvariant(\n420:   before: ScoreSnapshot[],\n421:   after: Stage4ReadonlyRow[]\n422: ): void {\n423:   if (before.length !== after.length) {\n424:     // Length changes are allowed (filtering removes items), but we verify retained items\n425:   }\n426: \n427:   const afterMap = new Map(after.map(r => [r.id, r]));\n428: \n429:   for (const snap of before) {\n430:     const row = afterMap.get(snap.id);\n431:     if (!row) continue; // Filtered out — OK\n432: \n433:     if (row.similarity !== snap.similarity) {\n434:       throw new Error(\n435:         `[Stage4Invariant] Score mutation detected: id=${snap.id} similarity changed from ${snap.similarity} to ${row.similarity}`\n436:       );\n437:     }\n438:     if (row.score !== snap.score) {\n439:       throw new Error(\n440:         `[Stage4Invariant] Score mutation detected: id=${snap.id} score changed from ${snap.score} to ${row.score}`\n441:       );\n442:     }\n443:     if (row.rrfScore !== snap.rrfScore) {\n444:       throw new Error(\n445:         `[Stage4Invariant] Score mutation detected: id=${snap.id} rrfScore changed from ${snap.rrfScore} to ${row.rrfScore}`\n446:       );\n447:     }\n448:     if (row.intentAdjustedScore !== snap.intentAdjustedScore) {\n449:       throw new Error(\n450:         `[Stage4Invariant] Score mutation detected: id=${snap.id} intentAdjustedScore changed from ${snap.intentAdjustedScore} to ${row.intentAdjustedScore}`\n451:       );\n452:     }\n453:     if (row.importance_weight !== snap.importance_weight) {\n454:       throw new Error(\n455:         `[Stage4Invariant] Score mutation detected: id=${snap.id} importance_weight changed from ${snap.importance_weight} to ${row.importance_weight}`\n456:       );\n457:     }\n458:     if (row.attentionScore !== snap.attentionScore) {\n459:       throw new Error(\n460:         `[Stage4Invariant] Score mutation detected: id=${snap.id} attentionScore changed from ${snap.attentionScore} to ${row.attentionScore}`\n461:       );\n462:     }\n463:   }\n464: }\n\n(End of file - total 464 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Types\n// ───────────────────────────────────────────────────────────────\n// Stage interfaces with the Stage 4 immutability invariant\nimport type { RetrievalTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport type { QueryPlan } from '../../query/query-plan.js';\n\n// Feature catalog: 4-stage pipeline architecture\n\n\n/**\n * Memory search row — the canonical internal result type flowing through the pipeline.\n * Extends Record<string, unknown> for backward compatibility with existing code.\n */\nexport interface PipelineRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  score?: number;\n  importance_tier?: string;\n  contextType?: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Types\n// ───────────────────────────────────────────────────────────────\n// Stage interfaces with the Stage 4 immutability invariant\nimport type { RetrievalTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport type { QueryPlan } from '../../query/query-plan.js';\n\n// Feature catalog: 4-stage pipeline architecture\n\n\n/**\n * Memory search row — the canonical internal result type flowing through the pipeline.\n * Extends Record<string, unknown> for backward compatibility with existing code.\n */\nexport interface PipelineRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  score?: number;\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  attentionScore?: number;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n  quality_score?: number;\n  quality_flags?: string | string[] | null;\n  qualityFlags?: string | string[] | null;\n  importance_weight?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  /** Stage 2 composite score preserved for auditability when Stage 3 overwrites score */\n  stage2Score?: number;\n  /** Graph evidence provenance — edges and communities that contributed to graph-based boosts. */\n  graphEvidence?: {\n    edges: Array<{ sourceId: number; targetId: number; relation: string; strength: number }>;\n    communities: Array<{ communityId: number; summary?: string }>;\n    boostFactors: Array<{ type: string; delta: number }>;\n  };\n}\n\n/**\n * Shared score resolution function — canonical fallback chain for deriving the\n * \"best available score\" from a PipelineRow. Used by Stage 2, Stage 3, and any\n * code needing a consistent effective score.\n *\n * Previously Stage 2 and Stage 3 had\n * separate implementations with different fallback orders and clamping. This shared\n * function uses the correct chain: intentAdjustedScore → rrfScore → score → similarity/100,\n * all clamped to [0,1] with isFinite guards.\n */\nexport function resolveEffectiveScore(row: PipelineRow): number {\n  if (typeof row.intentAdjustedScore === 'number' && Number.isFinite(row.intentAdjustedScore))\n    return Math.max(0, Math.min(1, row.intentAdjustedScore));\n  if (typeof row.rrfScore === 'number' && Number.isFinite(row.rrfScore))\n    return Math.max(0, Math.min(1, row.rrfScore));\n  if (typeof row.score === 'number' && Number.isFinite(row.score))\n    return Math.max(0, Math.min(1, row.score));\n  if (typeof row.similarity === 'number' && Number.isFinite(row.similarity))\n    return Math.max(0, Math.min(1, row.similarity / 100));\n  return 0;\n}\n\n/**\n * Absolute 0–1 relevance for confidence calibration and result-set digests —\n * NOT for ordering. Prefers cosine similarity (an absolute relevance signal)\n * over the RRF fusion score, whose magnitude (~0.01–0.05) is only meaningful as\n * relative rank and badly understates relevance when read as an absolute 0–1\n * quality. Feeding RRF magnitudes into 0.7/0.4-scaled thresholds makes \"good\"\n * unreachable, so every hybrid query degrades to \"weak\"/\"gap\". Vector hits carry\n * a real cosine; lexical-only hits (no similarity) fall back to the effective\n * score, preserving their current behavior.\n */\nexport function resolveAbsoluteRelevance(row: PipelineRow): number {\n  if (typeof row.similarity === 'number' && Number.isFinite(row.similarity)) {\n    // sqlite-vec emits cosine on a 0–100 scale; normalize. Already-0–1 inputs pass through.\n    const normalized = row.similarity > 1 ? row.similarity / 100 : row.similarity;\n    return Math.max(0, Math.min(1, normalized));\n  }\n  return resolveEffectiveScore(row);\n}\n\n/**\n * Stage 4 read-only row — compile-time enforcement that Stage 4 cannot modify scores.\n * OQ-S5-001 CLOSED: Primary enforcement via TypeScript read-only type guards.\n * All score-related fields are Readonly to prevent mutation in Stage 4.\n */\nexport interface Stage4ReadonlyRow extends Readonly<Pick<PipelineRow,\n  'similarity' | 'score' | 'importance_weight' | 'rrfScore' | 'intentAdjustedScore' | 'attentionScore'\n>> {\n  readonly id: number;\n  // Non-score fields remain mutable for annotation purposes\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n  quality_score?: number;\n  // Annotation fields (Stage 4 may add these)\n  channelAttribution?: string[];\n  evidenceGap?: { gapDetected: boolean; warning?: string };\n}\n\n// -- Pipeline Configuration --\n\n/**\n * Normalized configuration consumed by the four-stage retrieval pipeline.\n */\nexport interface PipelineConfig {\n  query: string;\n  queryEmbedding?: Float32Array;\n  concepts?: string[];\n  searchType: 'hybrid' | 'vector' | 'multi-concept';\n  mode?: string;\n\n  // Limits and filtering\n  limit: number;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  tier?: string;\n  contextType?: string;\n  includeArchived: boolean;\n  includeConstitutional: boolean;\n  includeContent: boolean;\n  anchors?: string[];\n  qualityThreshold?: number;\n\n  // Scoring configuration\n  minState: string;\n  applyStateLimits: boolean;\n  useDecay: boolean;\n  rerank: boolean;\n  applyLengthPenalty: boolean;\n\n  // Session and boost\n  sessionId?: string;\n  enableDedup: boolean;\n  enableSessionBoost: boolean;\n  enableCausalBoost: boolean;\n  trackAccess: boolean;\n\n  // Intent\n  detectedIntent: string | null;\n  adaptiveFusionIntent?: string | null;\n  intentConfidence: number;\n  intentWeights: IntentWeightsConfig | null;\n\n  // Routing\n  artifactRouting?: ArtifactRoutingConfig;\n  queryPlan?: QueryPlan;\n\n  // Trace\n  trace?: RetrievalTrace;\n}\n\n/**\n * Intent-aware weighting factors applied during fusion.\n */\nexport interface IntentWeightsConfig {\n  similarity: number;\n  importance: number;\n  recency: number;\n}\n\n/**\n * Artifact-class routing decision passed into the pipeline.\n */\nexport interface ArtifactRoutingConfig {\n  detectedClass: string;\n  confidence: number;\n  strategy: {\n    maxResults: number;\n    [key: string]: unknown;\n  };\n}\n\n// -- Stage Interfaces --\n\n/**\n * Stage 1: Candidate Generation\n * Executes search channels (FTS5, semantic, trigger, graph, co-activation)\n * and collects raw results. No scoring modifications.\n */\nexport interface Stage1Input {\n  config: PipelineConfig;\n}\n\n/**\n * Stage 1 output containing candidate rows and generation metadata.\n */\nexport interface Stage1Output {\n  candidates: PipelineRow[];\n  metadata: {\n    searchType: string;\n    channelCount: number;\n    /** Actual retrieval channels active (vector=1, hybrid=2). Unlike channelCount which tracks query variants. */\n    activeChannels?: number;\n    candidateCount: number;\n    constitutionalInjected: number;\n    durationMs: number;\n  };\n}\n\n/**\n * Tri-state for signal application metadata.\n * Replaces boolean flags so callers can distinguish \"feature disabled\n * by config\" ('off') from \"feature crashed\" ('failed') from \"feature applied\n * successfully\" ('applied').\n */\nexport type SignalStatus = 'off' | 'applied' | 'enabled' | 'failed';\n\n/**\n * Stage 2: Fusion + Signal Integration\n * Single point for ALL scoring signals: RRF/RSF, causal boost, co-activation,\n * composite, intent weights (applied ONCE — prevents G2 recurrence).\n * Score changes: YES\n */\nexport interface Stage2Input {\n  candidates: PipelineRow[];\n  config: PipelineConfig;\n  stage1Metadata: Stage1Output['metadata'];\n}\n\n/**\n * Stage 2 output containing scored rows and fusion metadata.\n */\nexport interface Stage2Output {\n  scored: PipelineRow[];\n  metadata: {\n    sessionBoostApplied: SignalStatus;\n    causalBoostApplied: SignalStatus;\n    intentWeightsApplied: SignalStatus;\n    artifactRoutingApplied: SignalStatus;\n    feedbackSignalsApplied: SignalStatus;\n    graphContribution?: {\n      killSwitchActive: boolean;\n      causalBoosted: number;\n      coActivationBoosted: number;\n      communityInjected: number;\n      graphSignalsBoosted: number;\n      totalGraphInjected: number;\n      rolloutState?: 'off' | 'trace_only' | 'bounded_runtime';\n    };\n    qualityFiltered: number;\n    durationMs: number;\n  };\n}\n\n/**\n * Stage 3: Rerank + Aggregate\n * Cross-encoder reranking, MMR diversity enforcement, MPAB chunk-to-memory aggregation.\n * Score changes: YES\n */\nexport interface Stage3Input {\n  scored: PipelineRow[];\n  config: PipelineConfig;\n}\n\n/**\n * Stage 3 output containing reranked rows and reranking metadata.\n */\nexport interface Stage3Output {\n  reranked: PipelineRow[];\n  metadata: {\n    rerankApplied: boolean;\n    rerankProvider?: string;\n    chunkReassemblyStats: {\n      collapsedChunkHits: number;\n      chunkParents: number;\n      reassembled: number;\n      fallback: number;\n    };\n    durationMs: number;\n  };\n}\n\n/**\n * Stage 4: Filter + Annotate\n * State filtering, session dedup, constitutional injection, channel attribution.\n * Score changes: **NO** — Architectural invariant.\n *\n * Runtime assertion: scores at entry must equal scores at exit.\n * Compile-time enforcement: input type uses Stage4ReadonlyRow with readonly score fields.\n */\nexport interface Stage4Input {\n  /** Results with read-only score fields — Stage 4 cannot modify scores */\n  results: Stage4ReadonlyRow[];\n  config: PipelineConfig;\n  /** Stage 1 metadata passed through for constitutional count */\n  stage1Metadata?: { constitutionalInjected?: number };\n}\n\n/**\n * Stage 4 output containing final rows, filter metadata, and annotations.\n */\nexport interface Stage4Output {\n  final: Stage4ReadonlyRow[];\n  metadata: {\n    stateFiltered: number;\n    constitutionalInjected: number;\n    evidenceGapDetected: boolean;\n    durationMs: number;\n  };\n  annotations: {\n    evidenceGapWarning?: string;\n    stateStats: Record<string, unknown>;\n    featureFlags: Record<string, boolean>;\n  };\n}\n\n// -- Pipeline Result --\n\n/**\n * Final pipeline response returned to retrieval callers.\n */\nexport interface PipelineResult {\n  results: Stage4ReadonlyRow[];\n  metadata: {\n    stage1: Stage1Output['metadata'];\n    stage2: Stage2Output['metadata'];\n    stage3: Stage3Output['metadata'];\n    stage4: Stage4Output['metadata'];\n    /** Per-stage and total timing in milliseconds for latency observability. */\n    timing?: Record<string, number>;\n    /** True when one or more stages fell back to degraded output. */\n    degraded?: boolean;\n  };\n  annotations: Stage4Output['annotations'];\n  trace?: RetrievalTrace;\n}\n\n// -- Stage Function Types --\n\n/**\n * Executor signature for Stage 1 candidate generation.\n */\nexport type Stage1Fn = (input: Stage1Input) => Promise<Stage1Output>;\n/**\n * Executor signature for Stage 2 fusion and signal integration.\n */\nexport type Stage2Fn = (input: Stage2Input) => Promise<Stage2Output>;\n/**\n * Executor signature for Stage 3 reranking and aggregation.\n */\nexport type Stage3Fn = (input: Stage3Input) => Promise<Stage3Output>;\n/**\n * Executor signature for Stage 4 filtering and annotation.\n */\nexport type Stage4Fn = (input: Stage4Input) => Promise<Stage4Output>;\n\n// -- Score Snapshot Utility (Runtime assertion for Stage 4 invariant) --\n\n/**\n * Captures score values from results for invariant checking.\n * Used to verify Stage 4 does not modify any scores.\n */\nexport interface ScoreSnapshot {\n  id: number;\n  similarity?: number;\n  score?: number;\n  importance_weight?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  attentionScore?: number;\n}\n\n/**\n * Take a snapshot of score fields for later invariant verification.\n */\nexport function captureScoreSnapshot(results: Stage4ReadonlyRow[]): ScoreSnapshot[] {\n  return results.map(r => ({\n    id: r.id,\n    similarity: r.similarity,\n    score: r.score,\n    importance_weight: r.importance_weight,\n    rrfScore: r.rrfScore,\n    intentAdjustedScore: r.intentAdjustedScore,\n    attentionScore: r.attentionScore,\n  }));\n}\n\n/**\n * Verify Stage 4 invariant: no score fields were modified.\n * Throws if any score differs between before and after snapshots.\n */\nexport function verifyScoreInvariant(\n  before: ScoreSnapshot[],\n  after: Stage4ReadonlyRow[]\n): void {\n  if (before.length !== after.length) {\n    // Length changes are allowed (filtering removes items), but we verify retained items\n  }\n\n  const afterMap = new Map(after.map(r => [r.id, r]));\n\n  for (const snap of before) {\n    const row = afterMap.get(snap.id);\n    if (!row) continue; // Filtered out — OK\n\n    if (row.similarity !== snap.similarity) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} similarity changed from ${snap.similarity} to ${row.similarity}`\n      );\n    }\n    if (row.score !== snap.score) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} score changed from ${snap.score} to ${row.score}`\n      );\n    }\n    if (row.rrfScore !== snap.rrfScore) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} rrfScore changed from ${snap.rrfScore} to ${row.rrfScore}`\n      );\n    }\n    if (row.intentAdjustedScore !== snap.intentAdjustedScore) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} intentAdjustedScore changed from ${snap.intentAdjustedScore} to ${row.intentAdjustedScore}`\n      );\n    }\n    if (row.importance_weight !== snap.importance_weight) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} importance_weight changed from ${snap.importance_weight} to ${row.importance_weight}`\n      );\n    }\n    if (row.attentionScore !== snap.attentionScore) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} attentionScore changed from ${snap.attentionScore} to ${row.attentionScore}`\n      );\n    }\n  }\n}","lineStart":1,"lineEnd":464,"totalLines":464,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","time":{"start":1781757295603,"end":1781757295612}},"metadata":{"openai":{"itemId":"fc_067a45d1db0982a8016a33756f84288191b1da0d91e4055742"}},"id":"prt_ed902bbd0001fAyCd0d9f0KRYJ","sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","messageID":"msg_ed9028bae001qh2ogOAQdtC8ZE"}}
{"type":"tool_use","timestamp":1781757295621,"sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","part":{"type":"tool","tool":"read","callID":"call_guR0cp95bsyRGb7VWjKXKb3j","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Search Flags\n3: // ───────────────────────────────────────────────────────────────\n4: // Default-on runtime gates for search pipeline controls\n5: //\n6: // Production-ready flags graduated to default-ON.\n7: // Set SPECKIT_<FLAG>=false to disable any graduated feature.\n8: \n9: /* ───────────────────────────────────────────────────────────────\n10:    1. IMPORTS\n11: ──────────────────────────────────────────────────────────────── */\n12: \n13: import { isFeatureEnabled } from '../cognitive/rollout-policy.js';\n14: \n15: // Feature catalog: Quality-aware 3-tier search fallback\n16: // Feature catalog: Verify-fix-verify memory quality loop\n17: // Feature catalog: Negative feedback confidence signal\n18: \n19: export type SavePlannerMode = 'plan-only' | 'full-auto' | 'hybrid';\n20: \n21: const TRUTHY_OPT_IN = new Set(['true', '1', 'yes', 'on', 'enabled']);\n22: \n23: /**\n24:  * Returns true for explicit opt-in values: true, 1, yes, on, enabled.\n25:  * Undefined, empty, unrecognized, and explicit false-like values are treated as false.\n26:  */\n27: function isOptInEnabled(variableName: string): boolean {\n28:   const value = process.env[variableName]?.toLowerCase().trim();\n29:   return value !== undefined && TRUTHY_OPT_IN.has(value);\n30: }\n31: \n32: /* ───────────────────────────────────────────────────────────────\n33:    2. BOOST FLAGS (Graduated default-ON)\n34: ──────────────────────────────────────────────────────────────── */\n35: \n36: /**\n37:  * Session attention boost for search result re-ranking.\n38:  * Default: TRUE (graduated). Set SPECKIT_SESSION_BOOST=false to disable.\n39:  */\n40: export function isSessionBoostEnabled(): boolean {\n41:   return isFeatureEnabled('SPECKIT_SESSION_BOOST');\n42: }\n43: \n44: /**\n45:  * Causal graph traversal boost for search result amplification.\n46:  * Default: TRUE (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n47:  */\n48: export function isCausalBoostEnabled(): boolean {\n49:   return isFeatureEnabled('SPECKIT_CAUSAL_BOOST');\n50: }\n51: \n52: /* ───────────────────────────────────────────────────────────────\n53:    3. CORE FLAGS\n54: ──────────────────────────────────────────────────────────────── */\n55: \n56: /**\n57:  * Dynamic startup instruction injection for the MCP server.\n58:  * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_INIT=false to disable.\n59:  */\n60: export function isDynamicInitEnabled(): boolean {\n61:   return isFeatureEnabled('SPECKIT_DYNAMIC_INIT');\n62: }\n63: \n64: /**\n65:  * Token-pressure policy for memory_context.\n66:  * Default: TRUE (graduated). Set SPECKIT_PRESSURE_POLICY=false to disable.\n67:  */\n68: export function isPressurePolicyEnabled(identity?: string): boolean {\n69:   return isFeatureEnabled('SPECKIT_PRESSURE_POLICY', identity);\n70: }\n71: \n72: /**\n73:  * Automatic session resume context injection for memory_context.\n74:  * Default: TRUE (graduated). Set SPECKIT_AUTO_RESUME=false to disable.\n75:  */\n76: export function isAutoResumeEnabled(identity?: string): boolean {\n77:   return isFeatureEnabled('SPECKIT_AUTO_RESUME', identity);\n78: }\n79: \n80: /**\n81:  * Graph-guided MMR diversity reranking.\n82:  * Default: TRUE (enabled). Set SPECKIT_MMR=false to disable.\n83:  */\n84: export function isMMREnabled(): boolean {\n85:   return isFeatureEnabled('SPECKIT_MMR');\n86: }\n87: \n88: /**\n89:  * Transparent Reasoning Module (evidence-gap detection).\n90:  * Default: TRUE (enabled). Set SPECKIT_TRM=false to disable.\n91:  */\n92: export function isTRMEnabled(): boolean {\n93:   return isFeatureEnabled('SPECKIT_TRM');\n94: }\n95: \n96: /**\n97:  * Multi-query expansion for deep-mode retrieval.\n98:  * Default: TRUE (enabled). Set SPECKIT_MULTI_QUERY=false to disable.\n99:  */\n100: export function isMultiQueryEnabled(): boolean {\n101:   return isFeatureEnabled('SPECKIT_MULTI_QUERY');\n102: }\n103: \n104: /**\n105:  * PI-A2: Quality-aware 3-tier search fallback chain.\n106:  * Default: TRUE (graduated). Set SPECKIT_SEARCH_FALLBACK=false to disable.\n107:  */\n108: export function isSearchFallbackEnabled(): boolean {\n109:   return isFeatureEnabled('SPECKIT_SEARCH_FALLBACK');\n110: }\n111: \n112: /**\n113:  * Automatic spec folder discovery via description cache.\n114:  * Default: TRUE (graduated). Set SPECKIT_FOLDER_DISCOVERY=false to disable.\n115:  */\n116: export function isFolderDiscoveryEnabled(): boolean {\n117:   return isFeatureEnabled('SPECKIT_FOLDER_DISCOVERY');\n118: }\n119: \n120: /**\n121:  * Planner-first save mode selection for canonical save flows.\n122:  * Default: 'plan-only'. Set SPECKIT_SAVE_PLANNER_MODE=full-auto to restore\n123:  * the legacy mutation-first behavior. `hybrid` is reserved for future mixed\n124:  * flows and currently behaves the same as `plan-only`.\n125:  */\n126: export function resolveSavePlannerMode(): SavePlannerMode {\n127:   const raw = process.env.SPECKIT_SAVE_PLANNER_MODE?.trim().toLowerCase();\n128:   if (raw === 'full-auto' || raw === 'full_auto') {\n129:     return 'full-auto';\n130:   }\n131:   if (raw === 'hybrid') {\n132:     return 'hybrid';\n133:   }\n134:   return 'plan-only';\n135: }\n136: \n137: /**\n138:  * Save-time reconsolidation gate. Opt-in (default OFF): it enables the destructive\n139:  * reconsolidate() path that can merge near-duplicate rows and deprecate older ones — itself\n140:  * further gated on a per-spec-folder \"pre-reconsolidation\" checkpoint. Kept opt-in so a\n141:  * destructive merge never happens without explicit intent. Set SPECKIT_RECONSOLIDATION_ENABLED=true to enable.\n142:  */\n143: export function isSaveReconsolidationEnabled(): boolean {\n144:   return isOptInEnabled('SPECKIT_RECONSOLIDATION_ENABLED');\n145: }\n146: \n147: /**\n148:  * Save-time post-insert enrichment bundle gate (causal links, entity extraction,\n149:  * summaries, entity linking, graph lifecycle — populates the causal/entity graph).\n150:  * Default: TRUE (graduated). Set SPECKIT_POST_INSERT_ENRICHMENT_ENABLED=false to disable.\n151:  */\n152: export function isPostInsertEnrichmentEnabled(): boolean {\n153:   return isFeatureEnabled('SPECKIT_POST_INSERT_ENRICHMENT_ENABLED');\n154: }\n155: \n156: /**\n157:  * Whether the post-insert enrichment bundle runs in the background (non-blocking save).\n158:  * Default: TRUE (async). Set SPECKIT_POST_INSERT_ENRICHMENT_SYNC=true to run it synchronously\n159:  * when a caller needs the causal/entity graph fresh within the same save response.\n160:  */\n161: export function isPostInsertEnrichmentAsync(): boolean {\n162:   return !isOptInEnabled('SPECKIT_POST_INSERT_ENRICHMENT_SYNC');\n163: }\n164: \n165: /**\n166:  * Save-time quality auto-fix retries gate (regenerates trigger phrases, trims oversized\n167:  * content to the char budget, normalizes anchors on save).\n168:  * Default: TRUE (graduated). Set SPECKIT_QUALITY_AUTO_FIX=false to disable.\n169:  */\n170: export function isQualityAutoFixEnabled(): boolean {\n171:   return isFeatureEnabled('SPECKIT_QUALITY_AUTO_FIX');\n172: }\n173: \n174: // -- Hybrid RAG Fusion Refinement flags --\n175: \n176: /**\n177:  * MPAB: Document-level chunk-to-memory score aggregation.\n178:  * Default: TRUE (graduated). Set SPECKIT_DOCSCORE_AGGREGATION=false to disable.\n179:  */\n180: export function isDocscoreAggregationEnabled(): boolean {\n181:   return isFeatureEnabled('SPECKIT_DOCSCORE_AGGREGATION');\n182: }\n183: \n184: /**\n185:  * Pre-storage quality gate for memory saves.\n186:  * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE=false to disable.\n187:  */\n188: export function isSaveQualityGateEnabled(): boolean {\n189:   return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE');\n190: }\n191: \n192: /**\n193:  * Dynamic token budget allocation by query complexity.\n194:  * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_TOKEN_BUDGET=false to disable.\n195:  */\n196: export function isDynamicTokenBudgetEnabled(): boolean {\n197:   return isFeatureEnabled('SPECKIT_DYNAMIC_TOKEN_BUDGET');\n198: }\n199: \n200: /**\n201:  * Confidence-gap truncation for low-confidence tails.\n202:  * Default: TRUE (graduated). Set SPECKIT_CONFIDENCE_TRUNCATION=false to disable.\n203:  */\n204: export function isConfidenceTruncationEnabled(): boolean {\n205:   return isFeatureEnabled('SPECKIT_CONFIDENCE_TRUNCATION');\n206: }\n207: \n208: /**\n209:  * Channel minimum-representation promotion after fusion.\n210:  * Default: TRUE (graduated). Set SPECKIT_CHANNEL_MIN_REP=false to disable.\n211:  */\n212: export function isChannelMinRepEnabled(): boolean {\n213:   return isFeatureEnabled('SPECKIT_CHANNEL_MIN_REP');\n214: }\n215: \n216: /**\n217:  * Reconsolidation-on-save for memory deduplication.\n218:  * Default: TRUE (graduated). Set SPECKIT_RECONSOLIDATION=false to disable.\n219:  */\n220: export function isReconsolidationEnabled(): boolean {\n221:   return isFeatureEnabled('SPECKIT_RECONSOLIDATION');\n222: }\n223: \n224: /**\n225:  * Negative-feedback confidence demotion in ranking.\n226:  * Default: TRUE (graduated). Set SPECKIT_NEGATIVE_FEEDBACK=false to disable.\n227:  */\n228: export function isNegativeFeedbackEnabled(): boolean {\n229:   return isFeatureEnabled('SPECKIT_NEGATIVE_FEEDBACK');\n230: }\n231: \n232: // -- Pipeline Refactor flags --\n233: \n234: /**\n235:  * Query expansion for embedding-based retrieval.\n236:  * Suppressed when classification = \"simple\" (mutual exclusion).\n237:  * Default: TRUE (graduated). Set SPECKIT_EMBEDDING_EXPANSION=false to disable.\n238:  */\n239: export function isEmbeddingExpansionEnabled(): boolean {\n240:   return isFeatureEnabled('SPECKIT_EMBEDDING_EXPANSION');\n241: }\n242: \n243: // -- Indexing and Graph flags --\n244: \n245: /**\n246:  * N3-lite: Consolidation engine — contradiction scan, Hebbian strengthening,\n247:  * staleness detection, edge bounds enforcement.\n248:  * Default: TRUE (graduated). Set SPECKIT_CONSOLIDATION=false to disable.\n249:  */\n250: export function isConsolidationEnabled(): boolean {\n251:   return isFeatureEnabled('SPECKIT_CONSOLIDATION');\n252: }\n253: \n254: /**\n255:  * Encoding-intent capture at index time.\n256:  * Records intent metadata (document, code, structured_data) alongside embeddings.\n257:  * Default: TRUE (graduated). Set SPECKIT_ENCODING_INTENT=false to disable.\n258:  */\n259: export function isEncodingIntentEnabled(): boolean {\n260:   return isFeatureEnabled('SPECKIT_ENCODING_INTENT');\n261: }\n262: \n263: /* ───────────────────────────────────────────────────────────────\n264:    3. GRAPH FLAGS\n265: ──────────────────────────────────────────────────────────────── */\n266: \n267: /**\n268:  * N2a+N2b: Graph momentum scoring and causal depth signals.\n269:  * Default: TRUE (enabled). Set SPECKIT_GRAPH_SIGNALS=false to disable.\n270:  */\n271: // Supported SPECKIT_GRAPH_WALK_ROLLOUT states: off, trace_only, bounded_runtime.\n272: export type GraphWalkRolloutState = 'off' | 'trace_only' | 'bounded_runtime';\n273: \n274: export function resolveGraphWalkRolloutState(): GraphWalkRolloutState {\n275:   const rollout = process.env.SPECKIT_GRAPH_WALK_ROLLOUT?.trim().toLowerCase();\n276:   if (rollout === 'off' || rollout === 'false' || rollout === '0') {\n277:     return 'off';\n278:   }\n279:   if (rollout === 'trace_only' || rollout === 'trace-only') {\n280:     return 'trace_only';\n281:   }\n282:   if (rollout === 'bounded_runtime' || rollout === 'bounded-runtime' || rollout === 'true' || rollout === '1') {\n283:     return 'bounded_runtime';\n284:   }\n285: \n286:   return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS') ? 'bounded_runtime' : 'off';\n287: }\n288: \n289: export function isGraphSignalsEnabled(): boolean {\n290:   return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS');\n291: }\n292: \n293: /**\n294:  * N2c: Community detection (BFS connected components + Louvain escalation).\n295:  * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_DETECTION=false to disable.\n296:  */\n297: export function isCommunityDetectionEnabled(): boolean {\n298:   return isFeatureEnabled('SPECKIT_COMMUNITY_DETECTION');\n299: }\n300: \n301: /**\n302:  * Community summary generation and search channel.\n303:  * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_SUMMARIES=false to disable.\n304:  */\n305: export function isCommunitySummariesEnabled(): boolean {\n306:   return isFeatureEnabled('SPECKIT_COMMUNITY_SUMMARIES');\n307: }\n308: \n309: /**\n310:  * Memory summary generation (TF-IDF extractive summaries as search channel).\n311:  * Default: TRUE (enabled). Set SPECKIT_MEMORY_SUMMARIES=false to disable.\n312:  */\n313: export function isMemorySummariesEnabled(): boolean {\n314:   return isFeatureEnabled('SPECKIT_MEMORY_SUMMARIES');\n315: }\n316: \n317: /**\n318:  * Temporal contiguity boost on raw Stage 1 vector results.\n319:  * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_CONTIGUITY=false to disable.\n320:  */\n321: export function isTemporalContiguityEnabled(): boolean {\n322:   return isFeatureEnabled('SPECKIT_TEMPORAL_CONTIGUITY');\n323: }\n324: \n325: /**\n326:  * Auto entity extraction (rule-based noun-phrase extraction at save time).\n327:  * Default: TRUE (enabled). Set SPECKIT_AUTO_ENTITIES=false to disable.\n328:  */\n329: export function isAutoEntitiesEnabled(): boolean {\n330:   return isFeatureEnabled('SPECKIT_AUTO_ENTITIES');\n331: }\n332: \n333: /**\n334:  * Cross-document entity linking (entity-based cross-doc edges).\n335:  * Requires auto entities to also be enabled.\n336:  * Default: TRUE (enabled). Set SPECKIT_ENTITY_LINKING=false to disable.\n337:  */\n338: export function isEntityLinkingEnabled(): boolean {\n339:   return isFeatureEnabled('SPECKIT_ENTITY_LINKING');\n340: }\n341: \n342: /** Whether causal-edge degree-based re-ranking is enabled (SPECKIT_DEGREE_BOOST). */\n343: export function isDegreeBoostEnabled(): boolean {\n344:   return isFeatureEnabled('SPECKIT_DEGREE_BOOST');\n345: }\n346: \n347: /* ───────────────────────────────────────────────────────────────\n348:    FLAGS\n349: ──────────────────────────────────────────────────────────────── */\n350: \n351: /**\n352:  * Contextual tree headers for Stage 4 result enrichment.\n353:  * Default: TRUE. Set SPECKIT_CONTEXT_HEADERS=false to disable.\n354:  */\n355: export function isContextHeadersEnabled(): boolean {\n356:   return isFeatureEnabled('SPECKIT_CONTEXT_HEADERS');\n357: }\n358: \n359: /**\n360:  * Real-time file watcher for markdown reindexing.\n361:  * Default: FALSE. Set SPECKIT_FILE_WATCHER=true to enable.\n362:  * Honors SPECKIT_ROLLOUT_PERCENT global rollout policy.\n363:  */\n364: export function isFileWatcherEnabled(): boolean {\n365:   if (process.env.SPECKIT_FILE_WATCHER?.toLowerCase().trim() !== 'true') return false;\n366:   return isFeatureEnabled('SPECKIT_FILE_WATCHER');\n367: }\n368: \n369: /**\n370:  * Verify-fix-verify memory quality loop.\n371:  * Default: TRUE (graduated). Set SPECKIT_QUALITY_LOOP=false to disable.\n372:  */\n373: export function isQualityLoopEnabled(): boolean {\n374:   return isFeatureEnabled('SPECKIT_QUALITY_LOOP');\n375: }\n376: \n377: /* ───────────────────────────────────────────────────────────────\n378:    5. QUERY INTELLIGENCE FLAGS\n379: ──────────────────────────────────────────────────────────────── */\n380: \n381: /**\n382:  * Query decomposition — bounded facet detection.\n383:  * Deep-mode only: multi-faceted queries split into up to 3 sub-queries.\n384:  * Default: TRUE (graduated). Set SPECKIT_QUERY_DECOMPOSITION=false to disable.\n385:  */\n386: export function isQueryDecompositionEnabled(): boolean {\n387:   return isFeatureEnabled('SPECKIT_QUERY_DECOMPOSITION');\n388: }\n389: \n390: /**\n391:  * Graph concept routing — query-time alias matching.\n392:  * Extracts noun phrases from the query and matches against concept alias table,\n393:  * activating the graph channel for matched concepts.\n394:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONCEPT_ROUTING=false to disable.\n395:  */\n396: export function isGraphConceptRoutingEnabled(): boolean {\n397:   return isFeatureEnabled('SPECKIT_GRAPH_CONCEPT_ROUTING');\n398: }\n399: \n400: /**\n401:  * Index-time surrogates for recall improvement.\n402:  * Generates surrogate metadata (aliases, headings, summary, questions)\n403:  * at index time; matched at query time with no LLM calls.\n404:  * Default: TRUE (graduated). Set SPECKIT_QUERY_SURROGATES=false to disable.\n405:  */\n406: export function isQuerySurrogatesEnabled(): boolean {\n407:   return isFeatureEnabled('SPECKIT_QUERY_SURROGATES');\n408: }\n409: \n410: /* ───────────────────────────────────────────────────────────────\n411:    6. FEEDBACK & QUALITY LEARNING FLAGS\n412: ──────────────────────────────────────────────────────────────── */\n413: \n414: /**\n415:  * Implicit feedback event ledger.\n416:  * Shadow-only — no ranking side effects.\n417:  * Default: TRUE (graduated). Set SPECKIT_IMPLICIT_FEEDBACK_LOG=false to disable.\n418:  */\n419: export function isImplicitFeedbackLogEnabled(): boolean {\n420:   return isFeatureEnabled('SPECKIT_IMPLICIT_FEEDBACK_LOG');\n421: }\n422: \n423: /**\n424:  * Hybrid decay policy — type-aware no-decay for permanent artifacts.\n425:  * Default: TRUE (graduated). Set SPECKIT_HYBRID_DECAY_POLICY=false to disable.\n426:  * When enabled: decision/constitutional/critical context types receive Infinity\n427:  * stability (no decay). All other types follow the standard FSRS schedule.\n428:  */\n429: export function isHybridDecayPolicyEnabled(): boolean {\n430:   return isFeatureEnabled('SPECKIT_HYBRID_DECAY_POLICY');\n431: }\n432: \n433: /**\n434:  * Short-critical quality gate exception.\n435:  * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS=false to disable.\n436:  * When enabled: decision context_type documents with >= 2 structural signals\n437:  * bypass the 50-character minimum content length check.\n438:  */\n439: export function isSaveQualityGateExceptionsEnabled(): boolean {\n440:   return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS');\n441: }\n442: \n443: /* ───────────────────────────────────────────────────────────────\n444:    7. LLM QUERY INTELLIGENCE FLAGS\n445: ──────────────────────────────────────────────────────────────── */\n446: \n447: /**\n448:  * Corpus-grounded LLM query reformulation.\n449:  * Step-back abstraction + corpus seed grounding. Deep-mode only.\n450:  * Default: TRUE (graduated). Set SPECKIT_LLM_REFORMULATION=false to disable.\n451:  * Requires an OpenAI-compatible LLM endpoint (LLM_REFORMULATION_ENDPOINT).\n452:  */\n453: export function isLlmReformulationEnabled(): boolean {\n454:   return isFeatureEnabled('SPECKIT_LLM_REFORMULATION');\n455: }\n456: \n457: /**\n458:  * HyDE (Hypothetical Document Embeddings).\n459:  * Generates a pseudo-document for low-confidence deep queries.\n460:  * Default: TRUE (graduated). Set SPECKIT_HYDE=false to disable.\n461:  */\n462: export function isHyDEEnabled(): boolean {\n463:   return isFeatureEnabled('SPECKIT_HYDE');\n464: }\n465: \n466: /* ───────────────────────────────────────────────────────────────\n467:    8. GRAPH LIFECYCLE FLAGS\n468: ──────────────────────────────────────────────────────────────── */\n469: \n470: /**\n471:  * Graph refresh mode.\n472:  * Controls when dirty-node recomputation runs after write operations.\n473:  * Default: 'write_local' (graduated). Set SPECKIT_GRAPH_REFRESH_MODE=off to disable.\n474:  * Values: off | write_local | scheduled.\n475:  */\n476: export function getGraphRefreshMode(): string {\n477:   return process.env.SPECKIT_GRAPH_REFRESH_MODE?.trim().toLowerCase() ?? 'write_local';\n478: }\n479: \n480: export function isGraphRefreshDisabled(): boolean {\n481:   return getGraphRefreshMode() === 'off';\n482: }\n483: \n484: /**\n485:  * Async LLM graph backfill for high-value documents.\n486:  * Runs after deterministic extraction; adds probabilistic edges via LLM.\n487:  * Default: TRUE (graduated). Set SPECKIT_LLM_GRAPH_BACKFILL=false to disable.\n488:  */\n489: export function isLlmGraphBackfillEnabled(): boolean {\n490:   return isFeatureEnabled('SPECKIT_LLM_GRAPH_BACKFILL');\n491: }\n492: \n493: /* ───────────────────────────────────────────────────────────────\n494:    9. GRAPH CALIBRATION & COMMUNITIES FLAGS\n495: ──────────────────────────────────────────────────────────────── */\n496: \n497: /**\n498:  * Graph calibration profiles and community thresholds.\n499:  * Enables calibration profile enforcement, Louvain activation gates, and\n500:  * community score capping (secondary-only).\n501:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CALIBRATION_PROFILE=false to disable.\n502:  */\n503: export function isGraphCalibrationProfileEnabled(): boolean {\n504:   return isFeatureEnabled('SPECKIT_GRAPH_CALIBRATION_PROFILE');\n505: }\n506: \n507: /* ───────────────────────────────────────────────────────────────\n508:    10. LEARNED RANKING FLAGS\n509: ──────────────────────────────────────────────────────────────── */\n510: \n511: /**\n512:  * Learned Stage 2 weight combiner (shadow mode).\n513:  * Runs the learned linear ranker in parallel with manual weights.\n514:  * Scores are computed but NOT used for ranking (shadow-only).\n515:  * Default: TRUE (graduated). Set SPECKIT_LEARNED_STAGE2_COMBINER=false to disable.\n516:  */\n517: export function isLearnedStage2CombinerEnabled(): boolean {\n518:   return isFeatureEnabled('SPECKIT_LEARNED_STAGE2_COMBINER');\n519: }\n520: \n521: /* ───────────────────────────────────────────────────────────────\n522:    11. SHADOW EVALUATION FLAGS\n523: ──────────────────────────────────────────────────────────────── */\n524: \n525: /**\n526:  * Shadow scoring with holdout evaluation.\n527:  * Compares would-have-changed rankings vs live rankings on a holdout\n528:  * slice of queries. Shadow-only — no ranking side effects.\n529:  * Default: TRUE (graduated). Set SPECKIT_SHADOW_FEEDBACK=false to disable.\n530:  */\n531: export function isShadowFeedbackEnabled(): boolean {\n532:   return isFeatureEnabled('SPECKIT_SHADOW_FEEDBACK');\n533: }\n534: \n535: /* ───────────────────────────────────────────────────────────────\n536:    12. PROGRESSIVE DISCLOSURE & SESSION STATE FLAGS\n537: ──────────────────────────────────────────────────────────────── */\n538: \n539: /**\n540:  * Progressive disclosure for search results.\n541:  * Replaces hard tail-truncation with summary layer + snippet + cursor pagination.\n542:  * Default: TRUE (graduated). Set SPECKIT_PROGRESSIVE_DISCLOSURE_V1=false to disable.\n543:  */\n544: export function isProgressiveDisclosureEnabled(): boolean {\n545:   return isFeatureEnabled('SPECKIT_PROGRESSIVE_DISCLOSURE_V1');\n546: }\n547: \n548: /**\n549:  * Retrieval session state for cross-turn context.\n550:  * Enables cross-turn dedup and goal-aware refinement of search results.\n551:  * Default: TRUE (graduated). Set SPECKIT_SESSION_RETRIEVAL_STATE_V1=false to disable.\n552:  */\n553: export function isSessionRetrievalStateEnabled(): boolean {\n554:   return isFeatureEnabled('SPECKIT_SESSION_RETRIEVAL_STATE_V1');\n555: }\n556: \n557: /* ───────────────────────────────────────────────────────────────\n558:    13. GRADUATED FLAGS\n559: ──────────────────────────────────────────────────────────────── */\n560: \n561: /**\n562:  * Calibrated overlap bonus for multi-channel convergence.\n563:  * Default: TRUE (graduated). Set SPECKIT_CALIBRATED_OVERLAP_BONUS=false to disable.\n564:  */\n565: export function isCalibratedOverlapBonusEnabled(): boolean {\n566:   return isFeatureEnabled('SPECKIT_CALIBRATED_OVERLAP_BONUS');\n567: }\n568: \n569: /**\n570:  * Experimental per-intent RRF K selection.\n571:  * Default: TRUE (graduated). Set SPECKIT_RRF_K_EXPERIMENTAL=false to disable.\n572:  */\n573: export function isRrfKExperimentalEnabled(): boolean {\n574:   return isFeatureEnabled('SPECKIT_RRF_K_EXPERIMENTAL');\n575: }\n576: \n577: /**\n578:  * Sparse-first + intent-aware typed traversal.\n579:  * Default: TRUE (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n580:  */\n581: export function isTypedTraversalEnabled(): boolean {\n582:   return isFeatureEnabled('SPECKIT_TYPED_TRAVERSAL');\n583: }\n584: \n585: /**\n586:  * Empty/weak result recovery UX.\n587:  * Default: TRUE (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n588:  */\n589: export function isEmptyResultRecoveryEnabled(): boolean {\n590:   return isFeatureEnabled('SPECKIT_EMPTY_RESULT_RECOVERY_V1');\n591: }\n592: \n593: /**\n594:  * Per-result calibrated confidence scoring.\n595:  * Default: TRUE (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n596:  */\n597: export function isResultConfidenceEnabled(): boolean {\n598:   return isFeatureEnabled('SPECKIT_RESULT_CONFIDENCE_V1');\n599: }\n600: \n601: /**\n602:  * Calibrate confidence/request-quality and result-set digests on an absolute\n603:  * relevance signal (cosine similarity) instead of the RRF fusion score. RRF\n604:  * magnitudes (~0.01–0.05) understate relevance and make \"good\" unreachable, so\n605:  * every hybrid query degrades to \"weak\"/\"gap\". Ordering is unaffected — this\n606:  * only changes the calibration/display scale.\n607:  * Default: TRUE (graduated). Set SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION=false to disable.\n608:  */\n609: export function isAbsoluteRelevanceCalibrationEnabled(): boolean {\n610:   return isFeatureEnabled('SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION');\n611: }\n612: \n613: /**\n614:  * Map per-result confidence values through a fitted isotonic calibration model\n615:  * so confidence.value approximates P(relevant). Opt-in (default OFF): the only\n616:  * labeled set available today is a corpus-derived PROXY, not human-judged live\n617:  * `memory_search` traffic, so the model is unvalidated and must not silently\n618:  * reshape production confidence. A model is applied only when this flag is ON\n619:  * AND SPECKIT_CONFIDENCE_CALIBRATION_MODEL points at a readable model file.\n620:  * Set SPECKIT_CONFIDENCE_CALIBRATION=true to enable once a validated set exists.\n621:  */\n622: export function isConfidenceCalibrationEnabled(): boolean {\n623:   return isOptInEnabled('SPECKIT_CONFIDENCE_CALIBRATION');\n624: }\n625: \n626: /**\n627:  * Cosine-primary reorder of the result head before truncation.\n628:  *\n629:  * Reorders only the top-N of the final ranked list by absolute cosine relevance\n630:  * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n631:  * ordering baseline; only the head is rebalanced toward the strongest absolute\n632:  * semantic signal, which matters now that downstream consumers treat position 1\n633:  * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n634:  * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n635:  */\n636: export function isCosineTopnReorderEnabled(): boolean {\n637:   return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n638: }\n639: \n640: /** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\n641: export function getConfidenceCalibrationModelPath(): string | undefined {\n642:   const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n643:   return raw && raw.length > 0 ? raw : undefined;\n644: }\n645: \n646: /**\n647:  * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n648:  * instead of hard-excluding them. The FSRS temperature system already ranks\n649:  * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard\n650:  * exclusion is redundant and hides legitimately-cold-but-relevant history (e.g.\n651:  * z_archive specs). Cold rows are included and naturally rank below hot ones.\n652:  * Applies to the query-time channels (lexical FTS/BM25, trigger); the vector lane\n653:  * filters via the active_memory_projection and is included separately when that\n654:  * projection is rebuilt. Constitutional rows stay on their own injected path.\n655:  * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n656:  * the hard exclusion.\n657:  */\n658: export function isArchivedRetrievalIncludedByDefault(): boolean {\n659:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n660: }\n661: \n662: /**\n663:  * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n664:  * The vector lane joins `active_memory_projection`, which holds one active row per\n665:  * logical key, so cold rows are admitted to the projection (option A: only rows\n666:  * whose logical key has no active winner) by a boot-time backfill, and the\n667:  * query-time deprecated filter is relaxed. Graduated to default ON alongside the\n668:  * other cold-tier channels; the backfill is idempotent and preserves the\n669:  * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n670:  * to restore the vector-lane exclusion.\n671:  */\n672: export function isArchivedVectorInclusionEnabled(): boolean {\n673:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n674: }\n675: \n676: /**\n677:  * Weekly batch feedback learning pipeline.\n678:  * Default: TRUE (graduated). Set SPECKIT_BATCH_LEARNED_FEEDBACK=false to disable.\n679:  */\n680: export function isBatchLearnedFeedbackEnabled(): boolean {\n681:   return isFeatureEnabled('SPECKIT_BATCH_LEARNED_FEEDBACK');\n682: }\n683: \n684: /**\n685:  * Assistive reconsolidation for near-duplicate detection.\n686:  * Default: TRUE (graduated). Set SPECKIT_ASSISTIVE_RECONSOLIDATION=false to disable.\n687:  */\n688: export function isAssistiveReconsolidationEnabled(): boolean {\n689:   return isFeatureEnabled('SPECKIT_ASSISTIVE_RECONSOLIDATION');\n690: }\n691: \n692: /**\n693:  * Two-tier result explainability.\n694:  * Default: TRUE (graduated). Set SPECKIT_RESULT_EXPLAIN_V1=false to disable.\n695:  */\n696: export function isResultExplainEnabled(): boolean {\n697:   return isFeatureEnabled('SPECKIT_RESULT_EXPLAIN_V1');\n698: }\n699: \n700: /**\n701:  * Mode-aware response profile formatting.\n702:  * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n703:  */\n704: export function isResponseProfileEnabled(): boolean {\n705:   return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n706: }\n707: \n708: /* ───────────────────────────────────────────────────────────────\n709:    14. PHASE B GRAPH RETRIEVAL FLAGS\n710: ──────────────────────────────────────────────────────────────── */\n711: \n712: /**\n713:  * Query concept expansion for hybrid search.\n714:  * When concept routing matches aliases, expands query with related terms.\n715:  * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n716:  */\n717: export function isQueryConceptExpansionEnabled(): boolean {\n718:   return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n719: }\n720: \n721: /**\n722:  * Graph-expanded fallback on zero/weak results.\n723:  * Queries causal_edges for neighbor titles when recovery triggers.\n724:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_FALLBACK=false to disable.\n725:  */\n726: export function isGraphFallbackEnabled(): boolean {\n727:   return isFeatureEnabled('SPECKIT_GRAPH_FALLBACK');\n728: }\n729: \n730: /**\n731:  * Always-on graph context injection.\n732:  * Runs concept routing + graph neighbor lookup even without seed results.\n733:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONTEXT_INJECTION=false to disable.\n734:  */\n735: export function isGraphContextInjectionEnabled(): boolean {\n736:   return isFeatureEnabled('SPECKIT_GRAPH_CONTEXT_INJECTION');\n737: }\n738: \n739: /**\n740:  * Result provenance — include graph evidence metadata in search results.\n741:  * When enabled, search results include graphEvidence with contributing edges,\n742:  * communities, and boost factors for transparency and debuggability.\n743:  * Default: TRUE (enabled). Set SPECKIT_RESULT_PROVENANCE=false to disable.\n744:  */\n745: export function isResultProvenanceEnabled(): boolean {\n746:   return isFeatureEnabled('SPECKIT_RESULT_PROVENANCE');\n747: }\n748: \n749: /**\n750:  * Temporal validity tracking for causal edges.\n751:  * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_EDGES=false to disable.\n752:  */\n753: export function isTemporalEdgesEnabled(): boolean {\n754:   return isFeatureEnabled('SPECKIT_TEMPORAL_EDGES');\n755: }\n756: \n757: /**\n758:  * Usage-weighted ranking signal.\n759:  * Default: TRUE (graduated). Set SPECKIT_USAGE_RANKING=false to disable.\n760:  */\n761: export function isUsageRankingEnabled(): boolean {\n762:   return isFeatureEnabled('SPECKIT_USAGE_RANKING');\n763: }\n764: \n765: /**\n766:  * Ontology-guided extraction validation hooks.\n767:  * Default: TRUE (graduated). Set SPECKIT_ONTOLOGY_HOOKS=false to disable.\n768:  */\n769: export function isOntologyHooksEnabled(): boolean {\n770:   return isFeatureEnabled('SPECKIT_ONTOLOGY_HOOKS');\n771: }\n772: \n773: /**\n774:  * Community-level search as fallback channel.\n775:  * When primary search returns weak/no results, searches community summaries\n776:  * and injects matching community members as candidates.\n777:  * Default: TRUE (graduated). Set SPECKIT_COMMUNITY_SEARCH_FALLBACK=false to disable.\n778:  */\n779: export function isCommunitySearchFallbackEnabled(): boolean {\n780:   return isFeatureEnabled('SPECKIT_COMMUNITY_SEARCH_FALLBACK');\n781: }\n782: \n783: /**\n784:  * Dual-level retrieval mode.\n785:  * Adds retrievalLevel parameter: 'local' (entity), 'global' (community), 'auto' (local + fallback).\n786:  * Default: TRUE (graduated). Set SPECKIT_DUAL_RETRIEVAL=false to disable.\n787:  */\n788: export function isDualRetrievalEnabled(): boolean {\n789:   return isFeatureEnabled('SPECKIT_DUAL_RETRIEVAL');\n790: }\n791: \n792: /**\n793:  * Phase C: Intent-to-profile auto-routing.\n794:  * When enabled, classifyIntent() results automatically select a response profile\n795:  * (quick, research, resume, debug) when no explicit profile is specified by the caller.\n796:  * Default: TRUE (graduated). Set SPECKIT_INTENT_AUTO_PROFILE=false to disable.\n797:  */\n798: export function isIntentAutoProfileEnabled(): boolean {\n799:   return isFeatureEnabled('SPECKIT_INTENT_AUTO_PROFILE');\n800: }\n\n(End of file - total 800 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Flags\n// ───────────────────────────────────────────────────────────────\n// Default-on runtime gates for search pipeline controls\n//\n// Production-ready flags graduated to default-ON.\n// Set SPECKIT_<FLAG>=false to disable any graduated feature.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { isFeatureEnabled } from '../cognitive/rollout-policy.js';\n\n// Feature catalog: Quality-aware 3-tier search fallback\n// Feature catalog: Verify-fix-verify memory quality loop\n// Feature catalog: Negative feedback confidence signal\n\nexport type SavePlannerMode = 'plan-only' | 'full-auto' | 'hybrid';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Flags\n// ───────────────────────────────────────────────────────────────\n// Default-on runtime gates for search pipeline controls\n//\n// Production-ready flags graduated to default-ON.\n// Set SPECKIT_<FLAG>=false to disable any graduated feature.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { isFeatureEnabled } from '../cognitive/rollout-policy.js';\n\n// Feature catalog: Quality-aware 3-tier search fallback\n// Feature catalog: Verify-fix-verify memory quality loop\n// Feature catalog: Negative feedback confidence signal\n\nexport type SavePlannerMode = 'plan-only' | 'full-auto' | 'hybrid';\n\nconst TRUTHY_OPT_IN = new Set(['true', '1', 'yes', 'on', 'enabled']);\n\n/**\n * Returns true for explicit opt-in values: true, 1, yes, on, enabled.\n * Undefined, empty, unrecognized, and explicit false-like values are treated as false.\n */\nfunction isOptInEnabled(variableName: string): boolean {\n  const value = process.env[variableName]?.toLowerCase().trim();\n  return value !== undefined && TRUTHY_OPT_IN.has(value);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. BOOST FLAGS (Graduated default-ON)\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Session attention boost for search result re-ranking.\n * Default: TRUE (graduated). Set SPECKIT_SESSION_BOOST=false to disable.\n */\nexport function isSessionBoostEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SESSION_BOOST');\n}\n\n/**\n * Causal graph traversal boost for search result amplification.\n * Default: TRUE (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n */\nexport function isCausalBoostEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CAUSAL_BOOST');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CORE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Dynamic startup instruction injection for the MCP server.\n * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_INIT=false to disable.\n */\nexport function isDynamicInitEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DYNAMIC_INIT');\n}\n\n/**\n * Token-pressure policy for memory_context.\n * Default: TRUE (graduated). Set SPECKIT_PRESSURE_POLICY=false to disable.\n */\nexport function isPressurePolicyEnabled(identity?: string): boolean {\n  return isFeatureEnabled('SPECKIT_PRESSURE_POLICY', identity);\n}\n\n/**\n * Automatic session resume context injection for memory_context.\n * Default: TRUE (graduated). Set SPECKIT_AUTO_RESUME=false to disable.\n */\nexport function isAutoResumeEnabled(identity?: string): boolean {\n  return isFeatureEnabled('SPECKIT_AUTO_RESUME', identity);\n}\n\n/**\n * Graph-guided MMR diversity reranking.\n * Default: TRUE (enabled). Set SPECKIT_MMR=false to disable.\n */\nexport function isMMREnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_MMR');\n}\n\n/**\n * Transparent Reasoning Module (evidence-gap detection).\n * Default: TRUE (enabled). Set SPECKIT_TRM=false to disable.\n */\nexport function isTRMEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TRM');\n}\n\n/**\n * Multi-query expansion for deep-mode retrieval.\n * Default: TRUE (enabled). Set SPECKIT_MULTI_QUERY=false to disable.\n */\nexport function isMultiQueryEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_MULTI_QUERY');\n}\n\n/**\n * PI-A2: Quality-aware 3-tier search fallback chain.\n * Default: TRUE (graduated). Set SPECKIT_SEARCH_FALLBACK=false to disable.\n */\nexport function isSearchFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SEARCH_FALLBACK');\n}\n\n/**\n * Automatic spec folder discovery via description cache.\n * Default: TRUE (graduated). Set SPECKIT_FOLDER_DISCOVERY=false to disable.\n */\nexport function isFolderDiscoveryEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_FOLDER_DISCOVERY');\n}\n\n/**\n * Planner-first save mode selection for canonical save flows.\n * Default: 'plan-only'. Set SPECKIT_SAVE_PLANNER_MODE=full-auto to restore\n * the legacy mutation-first behavior. `hybrid` is reserved for future mixed\n * flows and currently behaves the same as `plan-only`.\n */\nexport function resolveSavePlannerMode(): SavePlannerMode {\n  const raw = process.env.SPECKIT_SAVE_PLANNER_MODE?.trim().toLowerCase();\n  if (raw === 'full-auto' || raw === 'full_auto') {\n    return 'full-auto';\n  }\n  if (raw === 'hybrid') {\n    return 'hybrid';\n  }\n  return 'plan-only';\n}\n\n/**\n * Save-time reconsolidation gate. Opt-in (default OFF): it enables the destructive\n * reconsolidate() path that can merge near-duplicate rows and deprecate older ones — itself\n * further gated on a per-spec-folder \"pre-reconsolidation\" checkpoint. Kept opt-in so a\n * destructive merge never happens without explicit intent. Set SPECKIT_RECONSOLIDATION_ENABLED=true to enable.\n */\nexport function isSaveReconsolidationEnabled(): boolean {\n  return isOptInEnabled('SPECKIT_RECONSOLIDATION_ENABLED');\n}\n\n/**\n * Save-time post-insert enrichment bundle gate (causal links, entity extraction,\n * summaries, entity linking, graph lifecycle — populates the causal/entity graph).\n * Default: TRUE (graduated). Set SPECKIT_POST_INSERT_ENRICHMENT_ENABLED=false to disable.\n */\nexport function isPostInsertEnrichmentEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_POST_INSERT_ENRICHMENT_ENABLED');\n}\n\n/**\n * Whether the post-insert enrichment bundle runs in the background (non-blocking save).\n * Default: TRUE (async). Set SPECKIT_POST_INSERT_ENRICHMENT_SYNC=true to run it synchronously\n * when a caller needs the causal/entity graph fresh within the same save response.\n */\nexport function isPostInsertEnrichmentAsync(): boolean {\n  return !isOptInEnabled('SPECKIT_POST_INSERT_ENRICHMENT_SYNC');\n}\n\n/**\n * Save-time quality auto-fix retries gate (regenerates trigger phrases, trims oversized\n * content to the char budget, normalizes anchors on save).\n * Default: TRUE (graduated). Set SPECKIT_QUALITY_AUTO_FIX=false to disable.\n */\nexport function isQualityAutoFixEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUALITY_AUTO_FIX');\n}\n\n// -- Hybrid RAG Fusion Refinement flags --\n\n/**\n * MPAB: Document-level chunk-to-memory score aggregation.\n * Default: TRUE (graduated). Set SPECKIT_DOCSCORE_AGGREGATION=false to disable.\n */\nexport function isDocscoreAggregationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DOCSCORE_AGGREGATION');\n}\n\n/**\n * Pre-storage quality gate for memory saves.\n * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE=false to disable.\n */\nexport function isSaveQualityGateEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE');\n}\n\n/**\n * Dynamic token budget allocation by query complexity.\n * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_TOKEN_BUDGET=false to disable.\n */\nexport function isDynamicTokenBudgetEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DYNAMIC_TOKEN_BUDGET');\n}\n\n/**\n * Confidence-gap truncation for low-confidence tails.\n * Default: TRUE (graduated). Set SPECKIT_CONFIDENCE_TRUNCATION=false to disable.\n */\nexport function isConfidenceTruncationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CONFIDENCE_TRUNCATION');\n}\n\n/**\n * Channel minimum-representation promotion after fusion.\n * Default: TRUE (graduated). Set SPECKIT_CHANNEL_MIN_REP=false to disable.\n */\nexport function isChannelMinRepEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CHANNEL_MIN_REP');\n}\n\n/**\n * Reconsolidation-on-save for memory deduplication.\n * Default: TRUE (graduated). Set SPECKIT_RECONSOLIDATION=false to disable.\n */\nexport function isReconsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RECONSOLIDATION');\n}\n\n/**\n * Negative-feedback confidence demotion in ranking.\n * Default: TRUE (graduated). Set SPECKIT_NEGATIVE_FEEDBACK=false to disable.\n */\nexport function isNegativeFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_NEGATIVE_FEEDBACK');\n}\n\n// -- Pipeline Refactor flags --\n\n/**\n * Query expansion for embedding-based retrieval.\n * Suppressed when classification = \"simple\" (mutual exclusion).\n * Default: TRUE (graduated). Set SPECKIT_EMBEDDING_EXPANSION=false to disable.\n */\nexport function isEmbeddingExpansionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_EMBEDDING_EXPANSION');\n}\n\n// -- Indexing and Graph flags --\n\n/**\n * N3-lite: Consolidation engine — contradiction scan, Hebbian strengthening,\n * staleness detection, edge bounds enforcement.\n * Default: TRUE (graduated). Set SPECKIT_CONSOLIDATION=false to disable.\n */\nexport function isConsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CONSOLIDATION');\n}\n\n/**\n * Encoding-intent capture at index time.\n * Records intent metadata (document, code, structured_data) alongside embeddings.\n * Default: TRUE (graduated). Set SPECKIT_ENCODING_INTENT=false to disable.\n */\nexport function isEncodingIntentEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ENCODING_INTENT');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. GRAPH FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * N2a+N2b: Graph momentum scoring and causal depth signals.\n * Default: TRUE (enabled). Set SPECKIT_GRAPH_SIGNALS=false to disable.\n */\n// Supported SPECKIT_GRAPH_WALK_ROLLOUT states: off, trace_only, bounded_runtime.\nexport type GraphWalkRolloutState = 'off' | 'trace_only' | 'bounded_runtime';\n\nexport function resolveGraphWalkRolloutState(): GraphWalkRolloutState {\n  const rollout = process.env.SPECKIT_GRAPH_WALK_ROLLOUT?.trim().toLowerCase();\n  if (rollout === 'off' || rollout === 'false' || rollout === '0') {\n    return 'off';\n  }\n  if (rollout === 'trace_only' || rollout === 'trace-only') {\n    return 'trace_only';\n  }\n  if (rollout === 'bounded_runtime' || rollout === 'bounded-runtime' || rollout === 'true' || rollout === '1') {\n    return 'bounded_runtime';\n  }\n\n  return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS') ? 'bounded_runtime' : 'off';\n}\n\nexport function isGraphSignalsEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS');\n}\n\n/**\n * N2c: Community detection (BFS connected components + Louvain escalation).\n * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_DETECTION=false to disable.\n */\nexport function isCommunityDetectionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_DETECTION');\n}\n\n/**\n * Community summary generation and search channel.\n * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_SUMMARIES=false to disable.\n */\nexport function isCommunitySummariesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_SUMMARIES');\n}\n\n/**\n * Memory summary generation (TF-IDF extractive summaries as search channel).\n * Default: TRUE (enabled). Set SPECKIT_MEMORY_SUMMARIES=false to disable.\n */\nexport function isMemorySummariesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_MEMORY_SUMMARIES');\n}\n\n/**\n * Temporal contiguity boost on raw Stage 1 vector results.\n * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_CONTIGUITY=false to disable.\n */\nexport function isTemporalContiguityEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TEMPORAL_CONTIGUITY');\n}\n\n/**\n * Auto entity extraction (rule-based noun-phrase extraction at save time).\n * Default: TRUE (enabled). Set SPECKIT_AUTO_ENTITIES=false to disable.\n */\nexport function isAutoEntitiesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_AUTO_ENTITIES');\n}\n\n/**\n * Cross-document entity linking (entity-based cross-doc edges).\n * Requires auto entities to also be enabled.\n * Default: TRUE (enabled). Set SPECKIT_ENTITY_LINKING=false to disable.\n */\nexport function isEntityLinkingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ENTITY_LINKING');\n}\n\n/** Whether causal-edge degree-based re-ranking is enabled (SPECKIT_DEGREE_BOOST). */\nexport function isDegreeBoostEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DEGREE_BOOST');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Contextual tree headers for Stage 4 result enrichment.\n * Default: TRUE. Set SPECKIT_CONTEXT_HEADERS=false to disable.\n */\nexport function isContextHeadersEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CONTEXT_HEADERS');\n}\n\n/**\n * Real-time file watcher for markdown reindexing.\n * Default: FALSE. Set SPECKIT_FILE_WATCHER=true to enable.\n * Honors SPECKIT_ROLLOUT_PERCENT global rollout policy.\n */\nexport function isFileWatcherEnabled(): boolean {\n  if (process.env.SPECKIT_FILE_WATCHER?.toLowerCase().trim() !== 'true') return false;\n  return isFeatureEnabled('SPECKIT_FILE_WATCHER');\n}\n\n/**\n * Verify-fix-verify memory quality loop.\n * Default: TRUE (graduated). Set SPECKIT_QUALITY_LOOP=false to disable.\n */\nexport function isQualityLoopEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUALITY_LOOP');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. QUERY INTELLIGENCE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Query decomposition — bounded facet detection.\n * Deep-mode only: multi-faceted queries split into up to 3 sub-queries.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_DECOMPOSITION=false to disable.\n */\nexport function isQueryDecompositionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_DECOMPOSITION');\n}\n\n/**\n * Graph concept routing — query-time alias matching.\n * Extracts noun phrases from the query and matches against concept alias table,\n * activating the graph channel for matched concepts.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONCEPT_ROUTING=false to disable.\n */\nexport function isGraphConceptRoutingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CONCEPT_ROUTING');\n}\n\n/**\n * Index-time surrogates for recall improvement.\n * Generates surrogate metadata (aliases, headings, summary, questions)\n * at index time; matched at query time with no LLM calls.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_SURROGATES=false to disable.\n */\nexport function isQuerySurrogatesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_SURROGATES');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. FEEDBACK & QUALITY LEARNING FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Implicit feedback event ledger.\n * Shadow-only — no ranking side effects.\n * Default: TRUE (graduated). Set SPECKIT_IMPLICIT_FEEDBACK_LOG=false to disable.\n */\nexport function isImplicitFeedbackLogEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_IMPLICIT_FEEDBACK_LOG');\n}\n\n/**\n * Hybrid decay policy — type-aware no-decay for permanent artifacts.\n * Default: TRUE (graduated). Set SPECKIT_HYBRID_DECAY_POLICY=false to disable.\n * When enabled: decision/constitutional/critical context types receive Infinity\n * stability (no decay). All other types follow the standard FSRS schedule.\n */\nexport function isHybridDecayPolicyEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_HYBRID_DECAY_POLICY');\n}\n\n/**\n * Short-critical quality gate exception.\n * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS=false to disable.\n * When enabled: decision context_type documents with >= 2 structural signals\n * bypass the 50-character minimum content length check.\n */\nexport function isSaveQualityGateExceptionsEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LLM QUERY INTELLIGENCE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Corpus-grounded LLM query reformulation.\n * Step-back abstraction + corpus seed grounding. Deep-mode only.\n * Default: TRUE (graduated). Set SPECKIT_LLM_REFORMULATION=false to disable.\n * Requires an OpenAI-compatible LLM endpoint (LLM_REFORMULATION_ENDPOINT).\n */\nexport function isLlmReformulationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_LLM_REFORMULATION');\n}\n\n/**\n * HyDE (Hypothetical Document Embeddings).\n * Generates a pseudo-document for low-confidence deep queries.\n * Default: TRUE (graduated). Set SPECKIT_HYDE=false to disable.\n */\nexport function isHyDEEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_HYDE');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. GRAPH LIFECYCLE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Graph refresh mode.\n * Controls when dirty-node recomputation runs after write operations.\n * Default: 'write_local' (graduated). Set SPECKIT_GRAPH_REFRESH_MODE=off to disable.\n * Values: off | write_local | scheduled.\n */\nexport function getGraphRefreshMode(): string {\n  return process.env.SPECKIT_GRAPH_REFRESH_MODE?.trim().toLowerCase() ?? 'write_local';\n}\n\nexport function isGraphRefreshDisabled(): boolean {\n  return getGraphRefreshMode() === 'off';\n}\n\n/**\n * Async LLM graph backfill for high-value documents.\n * Runs after deterministic extraction; adds probabilistic edges via LLM.\n * Default: TRUE (graduated). Set SPECKIT_LLM_GRAPH_BACKFILL=false to disable.\n */\nexport function isLlmGraphBackfillEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_LLM_GRAPH_BACKFILL');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. GRAPH CALIBRATION & COMMUNITIES FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Graph calibration profiles and community thresholds.\n * Enables calibration profile enforcement, Louvain activation gates, and\n * community score capping (secondary-only).\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CALIBRATION_PROFILE=false to disable.\n */\nexport function isGraphCalibrationProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CALIBRATION_PROFILE');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   10. LEARNED RANKING FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Learned Stage 2 weight combiner (shadow mode).\n * Runs the learned linear ranker in parallel with manual weights.\n * Scores are computed but NOT used for ranking (shadow-only).\n * Default: TRUE (graduated). Set SPECKIT_LEARNED_STAGE2_COMBINER=false to disable.\n */\nexport function isLearnedStage2CombinerEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_LEARNED_STAGE2_COMBINER');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   11. SHADOW EVALUATION FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Shadow scoring with holdout evaluation.\n * Compares would-have-changed rankings vs live rankings on a holdout\n * slice of queries. Shadow-only — no ranking side effects.\n * Default: TRUE (graduated). Set SPECKIT_SHADOW_FEEDBACK=false to disable.\n */\nexport function isShadowFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SHADOW_FEEDBACK');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   12. PROGRESSIVE DISCLOSURE & SESSION STATE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Progressive disclosure for search results.\n * Replaces hard tail-truncation with summary layer + snippet + cursor pagination.\n * Default: TRUE (graduated). Set SPECKIT_PROGRESSIVE_DISCLOSURE_V1=false to disable.\n */\nexport function isProgressiveDisclosureEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_PROGRESSIVE_DISCLOSURE_V1');\n}\n\n/**\n * Retrieval session state for cross-turn context.\n * Enables cross-turn dedup and goal-aware refinement of search results.\n * Default: TRUE (graduated). Set SPECKIT_SESSION_RETRIEVAL_STATE_V1=false to disable.\n */\nexport function isSessionRetrievalStateEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SESSION_RETRIEVAL_STATE_V1');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   13. GRADUATED FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Calibrated overlap bonus for multi-channel convergence.\n * Default: TRUE (graduated). Set SPECKIT_CALIBRATED_OVERLAP_BONUS=false to disable.\n */\nexport function isCalibratedOverlapBonusEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CALIBRATED_OVERLAP_BONUS');\n}\n\n/**\n * Experimental per-intent RRF K selection.\n * Default: TRUE (graduated). Set SPECKIT_RRF_K_EXPERIMENTAL=false to disable.\n */\nexport function isRrfKExperimentalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RRF_K_EXPERIMENTAL');\n}\n\n/**\n * Sparse-first + intent-aware typed traversal.\n * Default: TRUE (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n */\nexport function isTypedTraversalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TYPED_TRAVERSAL');\n}\n\n/**\n * Empty/weak result recovery UX.\n * Default: TRUE (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n */\nexport function isEmptyResultRecoveryEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_EMPTY_RESULT_RECOVERY_V1');\n}\n\n/**\n * Per-result calibrated confidence scoring.\n * Default: TRUE (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n */\nexport function isResultConfidenceEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_CONFIDENCE_V1');\n}\n\n/**\n * Calibrate confidence/request-quality and result-set digests on an absolute\n * relevance signal (cosine similarity) instead of the RRF fusion score. RRF\n * magnitudes (~0.01–0.05) understate relevance and make \"good\" unreachable, so\n * every hybrid query degrades to \"weak\"/\"gap\". Ordering is unaffected — this\n * only changes the calibration/display scale.\n * Default: TRUE (graduated). Set SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION=false to disable.\n */\nexport function isAbsoluteRelevanceCalibrationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION');\n}\n\n/**\n * Map per-result confidence values through a fitted isotonic calibration model\n * so confidence.value approximates P(relevant). Opt-in (default OFF): the only\n * labeled set available today is a corpus-derived PROXY, not human-judged live\n * `memory_search` traffic, so the model is unvalidated and must not silently\n * reshape production confidence. A model is applied only when this flag is ON\n * AND SPECKIT_CONFIDENCE_CALIBRATION_MODEL points at a readable model file.\n * Set SPECKIT_CONFIDENCE_CALIBRATION=true to enable once a validated set exists.\n */\nexport function isConfidenceCalibrationEnabled(): boolean {\n  return isOptInEnabled('SPECKIT_CONFIDENCE_CALIBRATION');\n}\n\n/**\n * Cosine-primary reorder of the result head before truncation.\n *\n * Reorders only the top-N of the final ranked list by absolute cosine relevance\n * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n * ordering baseline; only the head is rebalanced toward the strongest absolute\n * semantic signal, which matters now that downstream consumers treat position 1\n * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n */\nexport function isCosineTopnReorderEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n}\n\n/** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\nexport function getConfidenceCalibrationModelPath(): string | undefined {\n  const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n  return raw && raw.length > 0 ? raw : undefined;\n}\n\n/**\n * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n * instead of hard-excluding them. The FSRS temperature system already ranks\n * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard\n * exclusion is redundant and hides legitimately-cold-but-relevant history (e.g.\n * z_archive specs). Cold rows are included and naturally rank below hot ones.\n * Applies to the query-time channels (lexical FTS/BM25, trigger); the vector lane\n * filters via the active_memory_projection and is included separately when that\n * projection is rebuilt. Constitutional rows stay on their own injected path.\n * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n * the hard exclusion.\n */\nexport function isArchivedRetrievalIncludedByDefault(): boolean {\n  return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n}\n\n/**\n * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n * The vector lane joins `active_memory_projection`, which holds one active row per\n * logical key, so cold rows are admitted to the projection (option A: only rows\n * whose logical key has no active winner) by a boot-time backfill, and the\n * query-time deprecated filter is relaxed. Graduated to default ON alongside the\n * other cold-tier channels; the backfill is idempotent and preserves the\n * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n * to restore the vector-lane exclusion.\n */\nexport function isArchivedVectorInclusionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n}\n\n/**\n * Weekly batch feedback learning pipeline.\n * Default: TRUE (graduated). Set SPECKIT_BATCH_LEARNED_FEEDBACK=false to disable.\n */\nexport function isBatchLearnedFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_BATCH_LEARNED_FEEDBACK');\n}\n\n/**\n * Assistive reconsolidation for near-duplicate detection.\n * Default: TRUE (graduated). Set SPECKIT_ASSISTIVE_RECONSOLIDATION=false to disable.\n */\nexport function isAssistiveReconsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ASSISTIVE_RECONSOLIDATION');\n}\n\n/**\n * Two-tier result explainability.\n * Default: TRUE (graduated). Set SPECKIT_RESULT_EXPLAIN_V1=false to disable.\n */\nexport function isResultExplainEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_EXPLAIN_V1');\n}\n\n/**\n * Mode-aware response profile formatting.\n * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n */\nexport function isResponseProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   14. PHASE B GRAPH RETRIEVAL FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Query concept expansion for hybrid search.\n * When concept routing matches aliases, expands query with related terms.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n */\nexport function isQueryConceptExpansionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n}\n\n/**\n * Graph-expanded fallback on zero/weak results.\n * Queries causal_edges for neighbor titles when recovery triggers.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_FALLBACK=false to disable.\n */\nexport function isGraphFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_FALLBACK');\n}\n\n/**\n * Always-on graph context injection.\n * Runs concept routing + graph neighbor lookup even without seed results.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONTEXT_INJECTION=false to disable.\n */\nexport function isGraphContextInjectionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CONTEXT_INJECTION');\n}\n\n/**\n * Result provenance — include graph evidence metadata in search results.\n * When enabled, search results include graphEvidence with contributing edges,\n * communities, and boost factors for transparency and debuggability.\n * Default: TRUE (enabled). Set SPECKIT_RESULT_PROVENANCE=false to disable.\n */\nexport function isResultProvenanceEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_PROVENANCE');\n}\n\n/**\n * Temporal validity tracking for causal edges.\n * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_EDGES=false to disable.\n */\nexport function isTemporalEdgesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TEMPORAL_EDGES');\n}\n\n/**\n * Usage-weighted ranking signal.\n * Default: TRUE (graduated). Set SPECKIT_USAGE_RANKING=false to disable.\n */\nexport function isUsageRankingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_USAGE_RANKING');\n}\n\n/**\n * Ontology-guided extraction validation hooks.\n * Default: TRUE (graduated). Set SPECKIT_ONTOLOGY_HOOKS=false to disable.\n */\nexport function isOntologyHooksEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ONTOLOGY_HOOKS');\n}\n\n/**\n * Community-level search as fallback channel.\n * When primary search returns weak/no results, searches community summaries\n * and injects matching community members as candidates.\n * Default: TRUE (graduated). Set SPECKIT_COMMUNITY_SEARCH_FALLBACK=false to disable.\n */\nexport function isCommunitySearchFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_SEARCH_FALLBACK');\n}\n\n/**\n * Dual-level retrieval mode.\n * Adds retrievalLevel parameter: 'local' (entity), 'global' (community), 'auto' (local + fallback).\n * Default: TRUE (graduated). Set SPECKIT_DUAL_RETRIEVAL=false to disable.\n */\nexport function isDualRetrievalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DUAL_RETRIEVAL');\n}\n\n/**\n * Phase C: Intent-to-profile auto-routing.\n * When enabled, classifyIntent() results automatically select a response profile\n * (quick, research, resume, debug) when no explicit profile is specified by the caller.\n * Default: TRUE (graduated). Set SPECKIT_INTENT_AUTO_PROFILE=false to disable.\n */\nexport function isIntentAutoProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_INTENT_AUTO_PROFILE');\n}","lineStart":1,"lineEnd":800,"totalLines":800,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","time":{"start":1781757295616,"end":1781757295620}},"metadata":{"openai":{"itemId":"fc_067a45d1db0982a8016a33756f84388191802d30073dc464a9"}},"id":"prt_ed902bbff001Vd5Ti25wRtLo0v","sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","messageID":"msg_ed9028bae001qh2ogOAQdtC8ZE"}}
