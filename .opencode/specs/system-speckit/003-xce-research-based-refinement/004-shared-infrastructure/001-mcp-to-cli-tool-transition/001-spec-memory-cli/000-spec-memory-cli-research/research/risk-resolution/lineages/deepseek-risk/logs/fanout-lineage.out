{"type":"tool_use","timestamp":1780741893511,"sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","part":{"type":"tool","tool":"read","callID":"call_00_iI8lgG3hPqtDN4W0jmRF4549","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   releaseRespawnLockFile,\n37:   sampleProcessTreeRssMb,\n38:   shouldSkipLaunch,\n39:   signalProcess,\n40:   superviseChildExit,\n41:   waitForPidExit,\n42: } = mss;\n43: \n44: const root = path.resolve(__dirname, '..', '..');\n45: const opencodeDir = path.join(root, '.opencode');\n46: \n47: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n48: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n49: // Minimal parser — no external dependency.\n50: function loadEnvFile(filePath) {\n51:   if (!fs.existsSync(filePath)) return 0;\n52:   let count = 0;\n53:   const raw = fs.readFileSync(filePath, 'utf8');\n54:   for (const line of raw.split('\\n')) {\n55:     const trimmed = line.trim();\n56:     if (!trimmed || trimmed.startsWith('#')) continue;\n57:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n58:     if (!m) continue;\n59:     const key = m[1];\n60:     let val = m[2];\n61:     // Strip matching outer quotes (single or double)\n62:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n63:       val = val.slice(1, -1);\n64:     }\n65:     if (!(key in process.env)) {\n66:       process.env[key] = val;\n67:       count++;\n68:     }\n69:   }\n70:   return count;\n71: }\n72: \n73: function isStrictModeDisabled(value) {\n74:   if (value === undefined || value === null) return false;\n75:   const v = String(value).trim().toLowerCase();\n76:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n77: }\n78: \n79: let skillsDir = path.join(opencodeDir, 'skills');\n80: let legacySkillDir = path.join(opencodeDir, 'skill');\n81: let kitDir = path.join(skillsDir, 'system-spec-kit');\n82: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n83: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n84: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n85: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n86: let stateFile = path.join(dbDir, PID_FILE_NAME);\n87: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n88: \n89: const rel = (p) => path.relative(root, p) || '.';\n90: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n91: const now = () => new Date().toISOString();\n92: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n93: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n94: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n95: let childProcess = null;\n96: let ownerLeasePid = null;\n97: let leaseStartedAt = null;\n98: let launcherShutdownInProgress = false;\n99: let rssBreachSelfExitInProgress = false;\n100: let rssWatchdogTimer = null;\n\n(Showing lines 1-100 of 1470. Use offset=101 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;","lineStart":1,"lineEnd":100,"totalLines":1470,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780741893503,"end":1780741893509}},"id":"prt_e9c7ceacf001SkwCyUmcebnxHQ","sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","messageID":"msg_e9c7cdf6f001r26Dzvh6rdRdW4"}}
{"type":"tool_use","timestamp":1780741894179,"sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","part":{"type":"tool","tool":"read","callID":"call_01_oNpqeTSAznGVD1pTcFrw1176","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const fs = require('fs');\n4: const net = require('net');\n5: const path = require('path');\n6: const { StringDecoder } = require('string_decoder');\n7: \n8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n9: const DEFAULT_PROBE_TIMEOUT_MS = 5000;\n10: const MAX_PROBE_TIMEOUT_MS = 6999;\n11: const DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\n12: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n13: const MODEL_SERVER_HEALTH_PATH = '/api/health';\n14: let nextProbeId = 1;\n15: \n16: function parsePositiveInteger(value, fallback) {\n17:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n18:   const parsed = Number.parseInt(String(value).trim(), 10);\n19:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n20: }\n21: \n22: function clampProbeTimeoutMs(value) {\n23:   return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n24: }\n25: \n26: function resolveProbeTimeoutMs(options = {}) {\n27:   if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n28:     return clampProbeTimeoutMs(options.timeoutMs);\n29:   }\n30:   return clampProbeTimeoutMs(parsePositiveInteger(\n31:     (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n32:     DEFAULT_PROBE_TIMEOUT_MS,\n33:   ));\n34: }\n35: \n36: function repoRoot() {\n37:   return path.resolve(__dirname, '..', '..', '..');\n38: }\n39: \n40: function defaultDbDirForService(serviceName) {\n41:   const root = repoRoot();\n42:   if (serviceName === 'mk-spec-memory') {\n43:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n44:   }\n45:   if (serviceName === 'mk-code-index') {\n46:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n47:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n48:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n49:   }\n50:   if (serviceName === 'mk-skill-advisor') {\n51:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n52:     return advisorOverride\n53:       ? path.resolve(advisorOverride)\n54:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n55:   }\n56:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n57: }\n58: \n59: function getIpcSocketPath(serviceName, options = {}) {\n60:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n61:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n62:   }\n63:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n64:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n65:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n66:   return path.join(socketDir, SOCKET_FILE_NAME);\n67: }\n68: \n69: function toConnectionOptions(socketPath) {\n70:   if (!socketPath.startsWith('tcp://')) {\n71:     return socketPath;\n72:   }\n73:   const url = new URL(socketPath);\n74:   return {\n75:     host: url.hostname,\n76:     port: Number.parseInt(url.port, 10),\n77:   };\n78: }\n79: \n80: function bridgeStdioToSocket(socketPath, options = {}) {\n81:   const input = options.stdin ?? process.stdin;\n82:   const output = options.stdout ?? process.stdout;\n83:   const exit = options.exit ?? ((code) => process.exit(code));\n84:   const socket = net.createConnection(toConnectionOptions(socketPath));\n85:   let closed = false;\n86: \n87:   const closeOnce = (code = 0) => {\n88:     if (closed) return;\n89:     closed = true;\n90:     input.unpipe(socket);\n91:     socket.unpipe(output);\n92:     socket.destroy();\n93:     exit(code);\n94:   };\n95: \n96:   socket.once('connect', () => {\n97:     options.onConnect?.(socket);\n98:     input.pipe(socket);\n99:     socket.pipe(output);\n100:   });\n\n(Showing lines 1-100 of 389. Use offset=101 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });","lineStart":1,"lineEnd":100,"totalLines":389,"truncated":true}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1780741894172,"end":1780741894177}},"id":"prt_e9c7cedc5001klenfheVf2pVPp","sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","messageID":"msg_e9c7cdf6f001r26Dzvh6rdRdW4"}}
{"type":"tool_use","timestamp":1780741894953,"sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","part":{"type":"tool","tool":"read","callID":"call_02_iJtbWNIvIT4S42OP3S1f4274","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","limit":50},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // All MCP tool definitions (names, descriptions, input schemas).\n5: // Extracted from context-server.ts for maintainability.\n6: import {\n7:   MAX_INGEST_PATHS,\n8:   MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n9: } from './schemas/tool-input-schemas.js';\n10: \n11: /**\n12:  * Re-export schema validation helpers used by the MCP tool entry points.\n13:  */\n14: export {\n15:   ToolSchemaValidationError,\n16:   formatZodError,\n17:   getToolSchema,\n18:   validateToolArgs,\n19:   getSchema,\n20: } from './schemas/tool-input-schemas.js';\n21: \n22: // ───────────────────────────────────────────────────────────────\n23: // 1. TYPES\n24: \n25: // ───────────────────────────────────────────────────────────────\n26: /**\n27:  * Normalized definition for a single MCP tool and its JSON schema.\n28:  */\n29: export interface ToolDefinition {\n30:   name: string;\n31:   description: string;\n32:   inputSchema: Record<string, unknown>;\n33:   outputSchema?: Record<string, unknown>;\n34: }\n35: \n36: // ───────────────────────────────────────────────────────────────\n37: // 2. TOOL DEFINITIONS\n38: \n39: // ───────────────────────────────────────────────────────────────\n40: // L1 Orchestration - Unified entry point (Token Budget: 3500)\n41: const memoryContext: ToolDefinition = {\n42:   name: 'memory_context',\n43:   description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n44:   inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n45: };\n46: \n47: // L2: Core - Primary operations (Token Budget: 3500)\n48: const memorySearch: ToolDefinition = {\n49:   name: 'memory_search',\n50:   description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n\n(Showing lines 1-50 of 756. Use offset=51 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Normalized definition for a single MCP tool and its JSON schema.\n */\nexport interface ToolDefinition {\n  name: string;\n  description: string;\n  inputSchema: Record<string, unknown>;\n  outputSchema?: Record<string, unknown>;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. TOOL DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n// L1 Orchestration - Unified entry point (Token Budget: 3500)\nconst memoryContext: ToolDefinition = {\n  name: 'memory_context',\n  description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n};\n\n// L2: Core - Primary operations (Token Budget: 3500)\nconst memorySearch: ToolDefinition = {\n  name: 'memory_search',\n  description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',","lineStart":1,"lineEnd":50,"totalLines":756,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1780741894945,"end":1780741894952}},"id":"prt_e9c7cf04e001i3dN12ftOXKmtS","sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","messageID":"msg_e9c7cdf6f001r26Dzvh6rdRdW4"}}
{"type":"tool_use","timestamp":1780741895586,"sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","part":{"type":"tool","tool":"read","callID":"call_03_nJX5yOPmg2KEfzqcJCwR5372","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/types.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/types.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Types\n3: // ───────────────────────────────────────────────────────────────\n4: // Shared types for tool dispatch modules.\n5: // Re-export canonical MCPResponse from shared\n6: export type { MCPResponse } from '@spec-kit/shared/types';\n7: \n8: /** Narrow pre-validated MCP tool args to a specific handler arg type.\n9:  *  Centralises the single protocol-boundary cast so call sites stay clean. */\n10: export function parseArgs<T>(args: Record<string, unknown>): T {\n11:   // Guard against null/undefined/non-object\n12:   // At the protocol boundary before casting.\n13:   if (args == null || typeof args !== 'object') {\n14:     return {} as T;\n15:   }\n16:   return args as unknown as T;\n17: }\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    Handler Arg Types\n21: ──────────────────────────────────────────────────────────────── */\n22: \n23: /** Arguments for memory context requests. */\n24: export interface ContextArgs {\n25:   input: string;\n26:   mode?: string;\n27:   intent?: string;\n28:   specFolder?: string;\n29:   tenantId?: string;\n30:   userId?: string;\n31:   agentId?: string;\n32:   limit?: number;\n33:   sessionId?: string;\n34:   enableDedup?: boolean;\n35:   includeContent?: boolean;\n36:   includeTrace?: boolean;\n37:   tokenUsage?: number;\n38:   anchors?: string[];\n39:   profile?: 'quick' | 'research' | 'resume' | 'debug';\n40: }\n41: \n42: /** Arguments for memory search requests. */\n43: export interface SearchArgs {\n44:   cursor?: string;\n45:   query?: string;\n46:   concepts?: string[];\n47:   specFolder?: string;\n48:   tenantId?: string;\n49:   userId?: string;\n50:   agentId?: string;\n51:   limit?: number;\n52:   tier?: string;\n53:   contextType?: string;\n54:   useDecay?: boolean;\n55:   includeContiguity?: boolean;\n56:   includeConstitutional?: boolean;\n57:   includeContent?: boolean;\n58:   anchors?: string[];\n59:   bypassCache?: boolean;\n60:   sessionId?: string;\n61:   enableDedup?: boolean;\n62:   intent?: string;\n63:   autoDetectIntent?: boolean;\n64:   enableSessionBoost?: boolean;\n65:   enableCausalBoost?: boolean;\n66:   minQualityScore?: number;\n67:   min_quality_score?: number;\n68:   rerank?: boolean;\n69:   applyLengthPenalty?: boolean;\n70:   applyStateLimits?: boolean;\n71:   minState?: 'HOT' | 'WARM' | 'COLD' | 'DORMANT' | 'ARCHIVED';\n72:   trackAccess?: boolean;\n73:   includeArchived?: boolean;\n74:   mode?: 'auto' | 'deep';\n75:   includeTrace?: boolean;\n76: }\n77: \n78: /** Arguments for trigger matching requests. */\n79: export interface TriggerArgs {\n80:   prompt: string;\n81:   limit?: number;\n82:   session_id?: string;\n83:   turnNumber?: number;\n84:   include_cognitive?: boolean;\n85: }\n86: \n87: /** Arguments for memory deletion requests. */\n88: export interface DeleteArgs {\n89:   id?: number | string;\n90:   specFolder?: string;\n91:   confirm?: boolean;\n92: }\n93: \n94: /** Arguments for memory update requests. */\n95: export interface UpdateArgs {\n96:   id: number;\n97:   title?: string;\n98:   triggerPhrases?: string[];\n99:   importanceWeight?: number;\n100:   importanceTier?: string;\n101:   allowPartialUpdate?: boolean;\n102: }\n103: \n104: /** Arguments for memory listing requests. */\n105: export interface ListArgs {\n106:   limit?: number;\n107:   offset?: number;\n108:   specFolder?: string;\n109:   sortBy?: string;\n110:   includeChunks?: boolean;\n111: }\n112: \n113: /** Arguments for memory statistics requests. */\n114: export interface StatsArgs {\n115:   folderRanking?: string;\n116:   excludePatterns?: string[];\n117:   includeScores?: boolean;\n118:   includeArchived?: boolean;\n119:   limit?: number;\n120: }\n121: \n122: /** Arguments for memory health checks.\n123:  * Intentionally declared inline to preserve the public interface contract\n124:  * asserted by context-server.vitest.ts. */\n125: export interface HealthArgs {\n126:   reportMode?: 'full' | 'divergent_aliases';\n127:   limit?: number;\n128:   specFolder?: string;\n129:   autoRepair?: boolean;\n130:   confirmed?: boolean;\n131: }\n132: \n133: /** Arguments for memory validation feedback requests. */\n134: export interface MemoryValidateArgs {\n135:   id: number | string;\n136:   wasUseful: boolean;\n137:   queryId?: string;\n138:   queryTerms?: string[];\n139:   resultRank?: number;\n140:   totalResultsShown?: number;\n141:   searchMode?: string;\n142:   intent?: string;\n143:   sessionId?: string;\n144:   notes?: string;\n145: }\n146: \n147: /** Arguments for manual memory retention sweep requests. */\n148: export interface RetentionSweepArgs {\n149:   dryRun?: boolean;\n150: }\n151: \n152: /** Arguments for memory_embedding_reconcile maintenance requests. */\n153: export interface ReconcileArgs {\n154:   mode?: 'dry-run' | 'apply';\n155:   activeOnly?: boolean;\n156:   resetMissing?: boolean;\n157:   missingFailureScope?: 'retry-retention';\n158:   maskedFailedPolicy?: 'reconcile';\n159:   providerFailurePolicy?: 'report-only';\n160:   requireActiveShard?: boolean;\n161:   repairSuccessCoverage?: boolean;\n162: }\n163: \n164: /** Arguments for selecting the active embedder target. */\n165: export interface EmbedderSetArgs {\n166:   name: string;\n167: }\n168: \n169: /** Arguments for embedder re-index status polling. */\n170: export interface EmbedderStatusArgs {\n171:   jobId?: string;\n172: }\n173: \n174: /** Arguments for memory save requests. */\n175: export interface SaveArgs {\n176:   filePath: string;\n177:   force?: boolean;\n178:   dryRun?: boolean;\n179:   skipPreflight?: boolean;\n180:   asyncEmbedding?: boolean; // When true, embedding generation is deferred (non-blocking)\n181:   routeAs?:\n182:     | 'narrative_progress'\n183:     | 'narrative_delivery'\n184:     | 'decision'\n185:     | 'handover_state'\n186:     | 'research_finding'\n187:     | 'task_update'\n188:     | 'metadata_only'\n189:     | 'drop';\n190:   mergeModeHint?:\n191:     | 'append-as-paragraph'\n192:     | 'insert-new-adr'\n193:     | 'append-table-row'\n194:     | 'update-in-place'\n195:     | 'append-section';\n196:   tenantId?: string;\n197:   userId?: string;\n198:   agentId?: string;\n199:   sessionId?: string;\n200:   provenanceSource?: string;\n201:   provenanceActor?: string;\n202:   governedAt?: string;\n203:   retentionPolicy?: 'keep' | 'ephemeral';\n204:   deleteAfter?: string;\n205: }\n206: \n207: /** Arguments for memory index scan requests. */\n208: export interface ScanArgs {\n209:   specFolder?: string | null;\n210:   force?: boolean;\n211:   includeConstitutional?: boolean;\n212:   includeSpecDocs?: boolean;\n213:   incremental?: boolean;\n214:   // Governed-ingest metadata, validated and threaded onto each indexed row so a\n215:   // governed scan does not silently downgrade rows to ungoverned. Optional;\n216:   // omitted for the default local single-user scan.\n217:   tenantId?: string;\n218:   userId?: string;\n219:   agentId?: string;\n220:   sessionId?: string;\n221:   provenanceSource?: string;\n222:   provenanceActor?: string;\n223:   governedAt?: string;\n224:   retentionPolicy?: 'keep' | 'ephemeral';\n225:   deleteAfter?: string;\n226: }\n227: \n228: /** Arguments for session resume requests. */\n229: export interface SessionResumeArgs {\n230:   specFolder?: string;\n231:   minimal?: boolean;\n232: }\n233: \n234: /** Arguments for session bootstrap requests. */\n235: export interface SessionBootstrapArgs {\n236:   specFolder?: string;\n237: }\n238: \n239: /** Arguments for checkpoint creation requests. */\n240: export interface CheckpointCreateArgs {\n241:   name: string;\n242:   specFolder?: string;\n243:   tenantId?: string;\n244:   userId?: string;\n245:   agentId?: string;\n246:   metadata?: Record<string, unknown>;\n247: }\n248: \n249: /** Arguments for checkpoint listing requests. */\n250: export interface CheckpointListArgs {\n251:   specFolder?: string;\n252:   tenantId?: string;\n253:   userId?: string;\n254:   agentId?: string;\n255:   limit?: number;\n256: }\n257: \n258: /** Arguments for checkpoint restore requests. */\n259: export interface CheckpointRestoreArgs {\n260:   name: string;\n261:   tenantId?: string;\n262:   userId?: string;\n263:   agentId?: string;\n264:   clearExisting?: boolean;\n265: }\n266: \n267: /** Arguments for checkpoint deletion requests. */\n268: export interface CheckpointDeleteArgs {\n269:   name: string;\n270:   tenantId?: string;\n271:   userId?: string;\n272:   agentId?: string;\n273:   confirmName: string;\n274: }\n275: \n276: /** Arguments for task preflight requests. */\n277: export interface PreflightArgs {\n278:   specFolder: string;\n279:   taskId: string;\n280:   knowledgeScore: number;\n281:   uncertaintyScore: number;\n282:   contextScore: number;\n283:   knowledgeGaps?: string[];\n284:   sessionId?: string | null;\n285: }\n286: \n287: /** Arguments for task postflight requests. */\n288: export interface PostflightArgs {\n289:   specFolder: string;\n290:   taskId: string;\n291:   knowledgeScore: number;\n292:   uncertaintyScore: number;\n293:   contextScore: number;\n294:   gapsClosed?: string[];\n295:   newGapsDiscovered?: string[];\n296:   sessionId?: string | null;\n297: }\n298: \n299: /** Arguments for learning history requests. */\n300: export interface LearningHistoryArgs {\n301:   specFolder: string;\n302:   sessionId?: string;\n303:   limit?: number;\n304:   onlyComplete?: boolean;\n305:   includeSummary?: boolean;\n306: }\n307: \n308: /** Arguments for causal drift trace requests. */\n309: export interface DriftWhyArgs {\n310:   memoryId: string | number;\n311:   maxDepth?: number;\n312:   direction?: string;\n313:   relations?: string[] | null;\n314:   includeMemoryDetails?: boolean;\n315: }\n316: \n317: /** Arguments for causal link creation requests. */\n318: export interface CausalLinkArgs {\n319:   sourceId: string | number;\n320:   targetId: string | number;\n321:   relation: string;\n322:   strength?: number;\n323:   evidence?: string | null;\n324: }\n325: \n326: /** Arguments for causal statistics requests. */\n327: export interface CausalStatsArgs {\n328:   // Optional bounded relation-inference backfill; dryRun-default so reads stay side-effect-free.\n329:   // similarity/contradicts are OPT-IN collectors (default false); similarityThreshold gates similarity.\n330:   backfill?: {\n331:     dryRun?: boolean;\n332:     limit?: number;\n333:     actor?: string;\n334:     similarity?: boolean;\n335:     contradicts?: boolean;\n336:     similarityThreshold?: number;\n337:   };\n338: }\n339: \n340: /** Arguments for causal link removal requests. */\n341: export interface CausalUnlinkArgs {\n342:   edgeId: number;\n343: }\n344: \n345: /** Arguments for bulk memory deletion requests. */\n346: export interface BulkDeleteArgs {\n347:   tier: string;\n348:   specFolder?: string;\n349:   confirm: boolean;\n350:   olderThanDays?: number;\n351:   skipCheckpoint?: boolean;\n352: }\n353: \n354: /** Arguments for evaluation ablation runs. */\n355: export interface EvalRunAblationArgs {\n356:   mode?: 'ablation' | 'k_sensitivity';\n357:   channels?: Array<'vector' | 'bm25' | 'fts5' | 'graph' | 'trigger'>;\n358:   queries?: string[];\n359:   groundTruthQueryIds?: number[];\n360:   recallK?: number;\n361:   storeResults?: boolean;\n362:   includeFormattedReport?: boolean;\n363: }\n364: \n365: /** Arguments for evaluation dashboard requests. */\n366: export interface EvalReportingDashboardArgs {\n367:   sprintFilter?: string[];\n368:   channelFilter?: string[];\n369:   metricFilter?: string[];\n370:   limit?: number;\n371:   format?: 'text' | 'json';\n372: }\n373: \n374: /** Arguments for ingestion job start requests. */\n375: export interface IngestStartArgs {\n376:   paths: string[];\n377:   specFolder?: string;\n378: }\n379: \n380: /** Arguments for ingestion job status requests. */\n381: export interface IngestStatusArgs {\n382:   jobId: string;\n383: }\n384: \n385: /** Arguments for ingestion job cancellation requests. */\n386: export interface IngestCancelArgs {\n387:   jobId: string;\n388: }\n\n(End of file - total 388 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Types\n// ───────────────────────────────────────────────────────────────\n// Shared types for tool dispatch modules.\n// Re-export canonical MCPResponse from shared\nexport type { MCPResponse } from '@spec-kit/shared/types';\n\n/** Narrow pre-validated MCP tool args to a specific handler arg type.\n *  Centralises the single protocol-boundary cast so call sites stay clean. */\nexport function parseArgs<T>(args: Record<string, unknown>): T {\n  // Guard against null/undefined/non-object\n  // At the protocol boundary before casting.\n  if (args == null || typeof args !== 'object') {\n    return {} as T;\n  }\n  return args as unknown as T;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   Handler Arg Types","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/types.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Types\n// ───────────────────────────────────────────────────────────────\n// Shared types for tool dispatch modules.\n// Re-export canonical MCPResponse from shared\nexport type { MCPResponse } from '@spec-kit/shared/types';\n\n/** Narrow pre-validated MCP tool args to a specific handler arg type.\n *  Centralises the single protocol-boundary cast so call sites stay clean. */\nexport function parseArgs<T>(args: Record<string, unknown>): T {\n  // Guard against null/undefined/non-object\n  // At the protocol boundary before casting.\n  if (args == null || typeof args !== 'object') {\n    return {} as T;\n  }\n  return args as unknown as T;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   Handler Arg Types\n──────────────────────────────────────────────────────────────── */\n\n/** Arguments for memory context requests. */\nexport interface ContextArgs {\n  input: string;\n  mode?: string;\n  intent?: string;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n  sessionId?: string;\n  enableDedup?: boolean;\n  includeContent?: boolean;\n  includeTrace?: boolean;\n  tokenUsage?: number;\n  anchors?: string[];\n  profile?: 'quick' | 'research' | 'resume' | 'debug';\n}\n\n/** Arguments for memory search requests. */\nexport interface SearchArgs {\n  cursor?: string;\n  query?: string;\n  concepts?: string[];\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n  tier?: string;\n  contextType?: string;\n  useDecay?: boolean;\n  includeContiguity?: boolean;\n  includeConstitutional?: boolean;\n  includeContent?: boolean;\n  anchors?: string[];\n  bypassCache?: boolean;\n  sessionId?: string;\n  enableDedup?: boolean;\n  intent?: string;\n  autoDetectIntent?: boolean;\n  enableSessionBoost?: boolean;\n  enableCausalBoost?: boolean;\n  minQualityScore?: number;\n  min_quality_score?: number;\n  rerank?: boolean;\n  applyLengthPenalty?: boolean;\n  applyStateLimits?: boolean;\n  minState?: 'HOT' | 'WARM' | 'COLD' | 'DORMANT' | 'ARCHIVED';\n  trackAccess?: boolean;\n  includeArchived?: boolean;\n  mode?: 'auto' | 'deep';\n  includeTrace?: boolean;\n}\n\n/** Arguments for trigger matching requests. */\nexport interface TriggerArgs {\n  prompt: string;\n  limit?: number;\n  session_id?: string;\n  turnNumber?: number;\n  include_cognitive?: boolean;\n}\n\n/** Arguments for memory deletion requests. */\nexport interface DeleteArgs {\n  id?: number | string;\n  specFolder?: string;\n  confirm?: boolean;\n}\n\n/** Arguments for memory update requests. */\nexport interface UpdateArgs {\n  id: number;\n  title?: string;\n  triggerPhrases?: string[];\n  importanceWeight?: number;\n  importanceTier?: string;\n  allowPartialUpdate?: boolean;\n}\n\n/** Arguments for memory listing requests. */\nexport interface ListArgs {\n  limit?: number;\n  offset?: number;\n  specFolder?: string;\n  sortBy?: string;\n  includeChunks?: boolean;\n}\n\n/** Arguments for memory statistics requests. */\nexport interface StatsArgs {\n  folderRanking?: string;\n  excludePatterns?: string[];\n  includeScores?: boolean;\n  includeArchived?: boolean;\n  limit?: number;\n}\n\n/** Arguments for memory health checks.\n * Intentionally declared inline to preserve the public interface contract\n * asserted by context-server.vitest.ts. */\nexport interface HealthArgs {\n  reportMode?: 'full' | 'divergent_aliases';\n  limit?: number;\n  specFolder?: string;\n  autoRepair?: boolean;\n  confirmed?: boolean;\n}\n\n/** Arguments for memory validation feedback requests. */\nexport interface MemoryValidateArgs {\n  id: number | string;\n  wasUseful: boolean;\n  queryId?: string;\n  queryTerms?: string[];\n  resultRank?: number;\n  totalResultsShown?: number;\n  searchMode?: string;\n  intent?: string;\n  sessionId?: string;\n  notes?: string;\n}\n\n/** Arguments for manual memory retention sweep requests. */\nexport interface RetentionSweepArgs {\n  dryRun?: boolean;\n}\n\n/** Arguments for memory_embedding_reconcile maintenance requests. */\nexport interface ReconcileArgs {\n  mode?: 'dry-run' | 'apply';\n  activeOnly?: boolean;\n  resetMissing?: boolean;\n  missingFailureScope?: 'retry-retention';\n  maskedFailedPolicy?: 'reconcile';\n  providerFailurePolicy?: 'report-only';\n  requireActiveShard?: boolean;\n  repairSuccessCoverage?: boolean;\n}\n\n/** Arguments for selecting the active embedder target. */\nexport interface EmbedderSetArgs {\n  name: string;\n}\n\n/** Arguments for embedder re-index status polling. */\nexport interface EmbedderStatusArgs {\n  jobId?: string;\n}\n\n/** Arguments for memory save requests. */\nexport interface SaveArgs {\n  filePath: string;\n  force?: boolean;\n  dryRun?: boolean;\n  skipPreflight?: boolean;\n  asyncEmbedding?: boolean; // When true, embedding generation is deferred (non-blocking)\n  routeAs?:\n    | 'narrative_progress'\n    | 'narrative_delivery'\n    | 'decision'\n    | 'handover_state'\n    | 'research_finding'\n    | 'task_update'\n    | 'metadata_only'\n    | 'drop';\n  mergeModeHint?:\n    | 'append-as-paragraph'\n    | 'insert-new-adr'\n    | 'append-table-row'\n    | 'update-in-place'\n    | 'append-section';\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/** Arguments for memory index scan requests. */\nexport interface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Governed-ingest metadata, validated and threaded onto each indexed row so a\n  // governed scan does not silently downgrade rows to ungoverned. Optional;\n  // omitted for the default local single-user scan.\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/** Arguments for session resume requests. */\nexport interface SessionResumeArgs {\n  specFolder?: string;\n  minimal?: boolean;\n}\n\n/** Arguments for session bootstrap requests. */\nexport interface SessionBootstrapArgs {\n  specFolder?: string;\n}\n\n/** Arguments for checkpoint creation requests. */\nexport interface CheckpointCreateArgs {\n  name: string;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  metadata?: Record<string, unknown>;\n}\n\n/** Arguments for checkpoint listing requests. */\nexport interface CheckpointListArgs {\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n}\n\n/** Arguments for checkpoint restore requests. */\nexport interface CheckpointRestoreArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  clearExisting?: boolean;\n}\n\n/** Arguments for checkpoint deletion requests. */\nexport interface CheckpointDeleteArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  confirmName: string;\n}\n\n/** Arguments for task preflight requests. */\nexport interface PreflightArgs {\n  specFolder: string;\n  taskId: string;\n  knowledgeScore: number;\n  uncertaintyScore: number;\n  contextScore: number;\n  knowledgeGaps?: string[];\n  sessionId?: string | null;\n}\n\n/** Arguments for task postflight requests. */\nexport interface PostflightArgs {\n  specFolder: string;\n  taskId: string;\n  knowledgeScore: number;\n  uncertaintyScore: number;\n  contextScore: number;\n  gapsClosed?: string[];\n  newGapsDiscovered?: string[];\n  sessionId?: string | null;\n}\n\n/** Arguments for learning history requests. */\nexport interface LearningHistoryArgs {\n  specFolder: string;\n  sessionId?: string;\n  limit?: number;\n  onlyComplete?: boolean;\n  includeSummary?: boolean;\n}\n\n/** Arguments for causal drift trace requests. */\nexport interface DriftWhyArgs {\n  memoryId: string | number;\n  maxDepth?: number;\n  direction?: string;\n  relations?: string[] | null;\n  includeMemoryDetails?: boolean;\n}\n\n/** Arguments for causal link creation requests. */\nexport interface CausalLinkArgs {\n  sourceId: string | number;\n  targetId: string | number;\n  relation: string;\n  strength?: number;\n  evidence?: string | null;\n}\n\n/** Arguments for causal statistics requests. */\nexport interface CausalStatsArgs {\n  // Optional bounded relation-inference backfill; dryRun-default so reads stay side-effect-free.\n  // similarity/contradicts are OPT-IN collectors (default false); similarityThreshold gates similarity.\n  backfill?: {\n    dryRun?: boolean;\n    limit?: number;\n    actor?: string;\n    similarity?: boolean;\n    contradicts?: boolean;\n    similarityThreshold?: number;\n  };\n}\n\n/** Arguments for causal link removal requests. */\nexport interface CausalUnlinkArgs {\n  edgeId: number;\n}\n\n/** Arguments for bulk memory deletion requests. */\nexport interface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\n/** Arguments for evaluation ablation runs. */\nexport interface EvalRunAblationArgs {\n  mode?: 'ablation' | 'k_sensitivity';\n  channels?: Array<'vector' | 'bm25' | 'fts5' | 'graph' | 'trigger'>;\n  queries?: string[];\n  groundTruthQueryIds?: number[];\n  recallK?: number;\n  storeResults?: boolean;\n  includeFormattedReport?: boolean;\n}\n\n/** Arguments for evaluation dashboard requests. */\nexport interface EvalReportingDashboardArgs {\n  sprintFilter?: string[];\n  channelFilter?: string[];\n  metricFilter?: string[];\n  limit?: number;\n  format?: 'text' | 'json';\n}\n\n/** Arguments for ingestion job start requests. */\nexport interface IngestStartArgs {\n  paths: string[];\n  specFolder?: string;\n}\n\n/** Arguments for ingestion job status requests. */\nexport interface IngestStatusArgs {\n  jobId: string;\n}\n\n/** Arguments for ingestion job cancellation requests. */\nexport interface IngestCancelArgs {\n  jobId: string;\n}","lineStart":1,"lineEnd":388,"totalLines":388,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tools/types.ts","time":{"start":1780741895575,"end":1780741895583}},"id":"prt_e9c7cf395001lBc4zF33zRw4uF","sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","messageID":"msg_e9c7cdf6f001r26Dzvh6rdRdW4"}}
