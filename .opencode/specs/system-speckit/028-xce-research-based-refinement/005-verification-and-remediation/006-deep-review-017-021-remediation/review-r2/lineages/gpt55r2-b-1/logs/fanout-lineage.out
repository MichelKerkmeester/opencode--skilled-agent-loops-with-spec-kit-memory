{"type":"text","timestamp":1781761460373,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"id":"prt_ed94232d8001yaNEzG1nh56Qhk","messageID":"msg_ed94220fc001yUh9MgDz6zye8x","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","type":"text","text":"Index-scan lease and cancellation handling appear intentionally guarded and idempotent on the paths I checked. I’m shifting to memory save/write lifecycle and idempotency receipt handling for one-iteration coverage.","time":{"start":1781761454808,"end":1781761460371},"metadata":{"openai":{"itemId":"msg_0f33689ed4629db5016a3385aece208191aa2587c29a788b38","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781761460441,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_XAlpWJ9C7D0ehEvW535d4ZeC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Atomic Index Memory\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import { randomUUID } from 'node:crypto';\n8: \n9: import * as transactionManager from '../../lib/storage/transaction-manager.js';\n10: \n11: import type {\n12:   AtomicSaveOptions,\n13:   AtomicSaveParams,\n14:   AtomicSaveResult,\n15:   IndexResult,\n16: } from './types.js';\n17: import { withSpecFolderLock } from './spec-folder-mutex.js';\n18: \n19: // Feature catalog: Memory indexing (memory_save)\n20: // Feature catalog: Atomic-save parity and partial-indexing hints\n21: \n22: interface AtomicIndexOriginalState {\n23:   existed: boolean;\n24:   content: string | null;\n25: }\n26: \n27: interface AtomicIndexPendingCleanupResult {\n28:   cleaned: boolean;\n29:   existed: boolean;\n30:   error?: string;\n31: }\n32: \n33: interface AtomicIndexRestoreResult {\n34:   restored: boolean;\n35:   error?: string;\n36: }\n37: \n38: export interface AtomicIndexReady<TPrepared = unknown> {\n39:   status: 'ready';\n40:   prepared: TPrepared;\n41:   specFolder: string;\n42:   persistedContent?: string;\n43:   persistedFilePath?: string;\n44: }\n45: \n46: export interface AtomicIndexTerminal {\n47:   status: 'abort' | 'rejected';\n48:   result: AtomicSaveResult;\n49: }\n50: \n51: export type AtomicIndexPreparation<TPrepared = unknown> =\n52:   | AtomicIndexReady<TPrepared>\n53:   | AtomicIndexTerminal;\n54: \n55: export interface AtomicIndexAttemptContext {\n56:   attempt: number;\n57:   force: boolean;\n58: }\n59: \n60: export interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n61:   params: AtomicSaveParams;\n62:   ready: AtomicIndexReady<TPrepared>;\n63:   specFolderLockAlreadyHeld: true;\n64: }\n65: \n66: export interface AtomicIndexDependencies<TPrepared = unknown> {\n67:   prepare: (\n68:     params: AtomicSaveParams,\n69:     context: AtomicIndexAttemptContext,\n70:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n71:   prepareLocked?: (\n72:     context: AtomicIndexLockedContext<TPrepared>,\n73:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n74:   indexPrepared: (\n75:     context: AtomicIndexLockedContext<TPrepared>,\n76:   ) => Promise<IndexResult> | IndexResult;\n77:   mapSuccessResult?: (\n78:     indexResult: IndexResult,\n79:     context: AtomicIndexLockedContext<TPrepared>,\n80:   ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n81:   maxIndexAttempts?: number;\n82:   getPendingPath?: (filePath: string) => string;\n83:   withSpecFolderLock?: typeof withSpecFolderLock;\n84:   captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n85:   restoreOriginalState?: (\n86:     filePath: string,\n87:     originalState: AtomicIndexOriginalState,\n88:   ) => AtomicIndexRestoreResult;\n89:   cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n90:   writePendingFile?: (pendingPath: string, content: string) => void;\n91:   promotePendingFile?: (pendingPath: string, filePath: string) => void;\n92: }\n93: \n94: function toErrorMessage(error: unknown): string {\n95:   return error instanceof Error ? error.message : String(error);\n96: }\n97: \n98: function deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n99:   const existed = fs.existsSync(filePath);\n100:   if (!existed) {\n101:     return { deleted: false, existed: false };\n102:   }\n103: \n104:   try {\n105:     fs.unlinkSync(filePath);\n106:     return { deleted: true, existed: true };\n107:   } catch (error: unknown) {\n108:     return {\n109:       deleted: false,\n110:       existed: true,\n111:       error: toErrorMessage(error),\n112:     };\n113:   }\n114: }\n115: \n116: function captureOriginalState(filePath: string): AtomicIndexOriginalState {\n117:   if (!fs.existsSync(filePath)) {\n118:     return { existed: false, content: null };\n119:   }\n120: \n121:   return {\n122:     existed: true,\n123:     content: fs.readFileSync(filePath, 'utf-8'),\n124:   };\n125: }\n126: \n127: function restoreOriginalState(\n128:   filePath: string,\n129:   originalState: AtomicIndexOriginalState,\n130: ): AtomicIndexRestoreResult {\n131:   try {\n132:     if (!originalState.existed) {\n133:       const deleteResult = deleteFileIfPresent(filePath);\n134:       if (!deleteResult.existed || deleteResult.deleted) {\n135:         return { restored: true };\n136:       }\n137:       return {\n138:         restored: false,\n139:         error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n140:       };\n141:     }\n142: \n143:     if (typeof originalState.content !== 'string') {\n144:       return { restored: false, error: 'Original file content is unavailable for rollback' };\n145:     }\n146: \n147:     fs.mkdirSync(path.dirname(filePath), { recursive: true });\n148:     fs.writeFileSync(filePath, originalState.content, 'utf-8');\n149:     return { restored: true };\n150:   } catch (error: unknown) {\n151:     return {\n152:       restored: false,\n153:       error: toErrorMessage(error),\n154:     };\n155:   }\n156: }\n157: \n158: function cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n159:   const deleteResult = deleteFileIfPresent(pendingPath);\n160:   if (!deleteResult.existed || deleteResult.deleted) {\n161:     return {\n162:       cleaned: true,\n163:       existed: deleteResult.existed,\n164:     };\n165:   }\n166:   return {\n167:     cleaned: false,\n168:     existed: deleteResult.existed,\n169:     error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n170:   };\n171: }\n172: \n173: function writePendingFile(pendingPath: string, content: string): void {\n174:   fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n175:   fs.writeFileSync(pendingPath, content, 'utf-8');\n176: }\n177: \n178: function promotePendingFile(pendingPath: string, filePath: string): void {\n179:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n180:   fs.renameSync(pendingPath, filePath);\n181: }\n182: \n183: function defaultPendingPath(filePath: string): string {\n184:   const basePendingPath = transactionManager.getPendingPath(filePath);\n185:   return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n186: }\n187: \n188: function buildRejectedResult(\n189:   filePath: string,\n190:   indexResult: IndexResult,\n191:   rollbackSucceeded: boolean,\n192:   errorMetadata: Record<string, string> | null,\n193: ): AtomicSaveResult {\n194:   return {\n195:     success: false,\n196:     filePath,\n197:     status: 'rejected',\n198:     id: indexResult.id,\n199:     specFolder: indexResult.specFolder,\n200:     title: indexResult.title,\n201:     summary: rollbackSucceeded\n202:       ? 'Atomic index rejected before file promotion'\n203:       : 'Atomic index rejected but pending file cleanup failed',\n204:     message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n205:     embeddingStatus: indexResult.embeddingStatus,\n206:     hints: [\n207:       rollbackSucceeded\n208:         ? 'Pending file was removed because the save was rejected before promotion'\n209:         : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n210:     ],\n211:     ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n212:     ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n213:   };\n214: }\n215: \n216: function buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n217:   const message = indexResult.message ?? (\n218:     indexResult.status === 'duplicate'\n219:       ? 'Memory skipped (duplicate content)'\n220:       : `Memory ${indexResult.status} successfully`\n221:   );\n222: \n223:   const hints: string[] = [];\n224:   if (indexResult.embeddingStatus === 'pending') {\n225:     hints.push('Memory will be fully indexed when embedding provider becomes available');\n226:   }\n227:   if (indexResult.embeddingStatus === 'partial') {\n228:     hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n229:   }\n230: \n231:   const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n232: \n233:   return {\n234:     success: true,\n235:     filePath,\n236:     status: indexResult.status,\n237:     id: indexResult.id,\n238:     specFolder: indexResult.specFolder,\n239:     title: indexResult.title,\n240:     summary: message,\n241:     message,\n242:     embeddingStatus: indexResult.embeddingStatus,\n243:     ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n244:       ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n245:       : {}),\n246:     ...(hints.length > 0 ? { hints } : {}),\n247:   };\n248: }\n249: \n250: function buildRetryFailureResult(\n251:   filePath: string,\n252:   indexError: Error | null,\n253:   rollbackSucceeded: boolean,\n254:   errorMetadata: Record<string, string> | null,\n255: ): AtomicSaveResult {\n256:   const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n257:   const finalErrorMetadata = errorMetadata ?? {};\n258: \n259:   return {\n260:     success: false,\n261:     filePath,\n262:     status: 'error',\n263:     summary: rollbackSucceeded\n264:       ? 'Atomic index failed after retry and restored original file state'\n265:       : 'Atomic index failed after retry and rollback was incomplete',\n266:     message: indexError?.message ?? 'Indexing failed after retry',\n267:     hints: [\n268:       rollbackSucceeded\n269:         ? 'Original file content was preserved or restored because indexing failed before completion'\n270:         : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n271:       'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n272:     ],\n273:     error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n274:     ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n275:   };\n276: }\n277: \n278: export async function atomicIndexMemory<TPrepared = unknown>(\n279:   params: AtomicSaveParams,\n280:   options: AtomicSaveOptions = {},\n281:   dependencies: AtomicIndexDependencies<TPrepared>,\n282: ): Promise<AtomicSaveResult> {\n283:   const { file_path, content } = params;\n284:   const { force = false } = options;\n285: \n286:   const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n287: \n288:   let indexResult: IndexResult | null = null;\n289:   let indexError: Error | null = null;\n290:   let restoredOriginalAfterFailure = false;\n291:   let anyPromotionAttempted = false;\n292:   let errorMetadata: Record<string, string> | null = null;\n293:   let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n294:   let lastEffectiveFilePath = file_path;\n295:   let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n296: \n297:   const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n298:     if (!entry) {\n299:       return;\n300:     }\n301:     errorMetadata = {\n302:       ...(errorMetadata ?? {}),\n303:       ...entry,\n304:     };\n305:   };\n306: \n307:   for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n308:     let promotedToFinalPath = false;\n309:     let handledFailureWhileLocked = false;\n310:     let rollbackSucceededAfterRejectedSave = false;\n311:     let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n312: \n313:     try {\n314:       const prepared = await dependencies.prepare(params, { attempt, force });\n315:       if (prepared.status !== 'ready') {\n316:         return prepared.result;\n317:       }\n318: \n319:       const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n320:       const lockedResult = await runWithLock(prepared.specFolder, async () => {\n321:         let effectiveFilePath = lastEffectiveFilePath;\n322:         let pendingPath = lastPendingPath;\n323:         let originalState: AtomicIndexOriginalState | null = null;\n324:         try {\n325:           let ready = prepared;\n326:           lockedContext = {\n327:             attempt,\n328:             force,\n329:             params,\n330:             ready,\n331:             specFolderLockAlreadyHeld: true,\n332:           };\n333: \n334:           if (dependencies.prepareLocked) {\n335:             const preparedLocked = await dependencies.prepareLocked(lockedContext);\n336:             if (preparedLocked.status !== 'ready') {\n337:               return {\n338:                 kind: 'terminal',\n339:                 result: preparedLocked.result,\n340:               } as const;\n341:             }\n342: \n343:             ready = preparedLocked;\n344:             lockedContext = {\n345:               attempt,\n346:               force,\n347:               params,\n348:               ready,\n349:               specFolderLockAlreadyHeld: true,\n350:             };\n351:           }\n352: \n353:           effectiveFilePath = ready.persistedFilePath ?? file_path;\n354:           const persistedContent = ready.persistedContent ?? content;\n355:           pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n356:           originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n357:           lastEffectiveFilePath = effectiveFilePath;\n358:           lastPendingPath = pendingPath;\n359: \n360:           (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n\n(Showing lines 1-360 of 462. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Atomic Index Memory\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\ninterface AtomicIndexOriginalState {\n  existed: boolean;\n  content: string | null;\n}\n\ninterface AtomicIndexPendingCleanupResult {\n  cleaned: boolean;\n  existed: boolean;\n  error?: string;\n}\n\ninterface AtomicIndexRestoreResult {\n  restored: boolean;\n  error?: string;\n}\n\nexport interface AtomicIndexReady<TPrepared = unknown> {\n  status: 'ready';\n  prepared: TPrepared;\n  specFolder: string;\n  persistedContent?: string;\n  persistedFilePath?: string;\n}\n\nexport interface AtomicIndexTerminal {\n  status: 'abort' | 'rejected';\n  result: AtomicSaveResult;\n}\n\nexport type AtomicIndexPreparation<TPrepared = unknown> =\n  | AtomicIndexReady<TPrepared>\n  | AtomicIndexTerminal;\n\nexport interface AtomicIndexAttemptContext {\n  attempt: number;\n  force: boolean;\n}\n\nexport interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n  params: AtomicSaveParams;\n  ready: AtomicIndexReady<TPrepared>;\n  specFolderLockAlreadyHeld: true;\n}\n\nexport interface AtomicIndexDependencies<TPrepared = unknown> {\n  prepare: (\n    params: AtomicSaveParams,\n    context: AtomicIndexAttemptContext,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  prepareLocked?: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  indexPrepared: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<IndexResult> | IndexResult;\n  mapSuccessResult?: (\n    indexResult: IndexResult,\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n  maxIndexAttempts?: number;\n  getPendingPath?: (filePath: string) => string;\n  withSpecFolderLock?: typeof withSpecFolderLock;\n  captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n  restoreOriginalState?: (\n    filePath: string,\n    originalState: AtomicIndexOriginalState,\n  ) => AtomicIndexRestoreResult;\n  cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n  writePendingFile?: (pendingPath: string, content: string) => void;\n  promotePendingFile?: (pendingPath: string, filePath: string) => void;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n  const existed = fs.existsSync(filePath);\n  if (!existed) {\n    return { deleted: false, existed: false };\n  }\n\n  try {\n    fs.unlinkSync(filePath);\n    return { deleted: true, existed: true };\n  } catch (error: unknown) {\n    return {\n      deleted: false,\n      existed: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction captureOriginalState(filePath: string): AtomicIndexOriginalState {\n  if (!fs.existsSync(filePath)) {\n    return { existed: false, content: null };\n  }\n\n  return {\n    existed: true,\n    content: fs.readFileSync(filePath, 'utf-8'),\n  };\n}\n\nfunction restoreOriginalState(\n  filePath: string,\n  originalState: AtomicIndexOriginalState,\n): AtomicIndexRestoreResult {\n  try {\n    if (!originalState.existed) {\n      const deleteResult = deleteFileIfPresent(filePath);\n      if (!deleteResult.existed || deleteResult.deleted) {\n        return { restored: true };\n      }\n      return {\n        restored: false,\n        error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n      };\n    }\n\n    if (typeof originalState.content !== 'string') {\n      return { restored: false, error: 'Original file content is unavailable for rollback' };\n    }\n\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, originalState.content, 'utf-8');\n    return { restored: true };\n  } catch (error: unknown) {\n    return {\n      restored: false,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n  const deleteResult = deleteFileIfPresent(pendingPath);\n  if (!deleteResult.existed || deleteResult.deleted) {\n    return {\n      cleaned: true,\n      existed: deleteResult.existed,\n    };\n  }\n  return {\n    cleaned: false,\n    existed: deleteResult.existed,\n    error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n  };\n}\n\nfunction writePendingFile(pendingPath: string, content: string): void {\n  fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n  fs.writeFileSync(pendingPath, content, 'utf-8');\n}\n\nfunction promotePendingFile(pendingPath: string, filePath: string): void {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.renameSync(pendingPath, filePath);\n}\n\nfunction defaultPendingPath(filePath: string): string {\n  const basePendingPath = transactionManager.getPendingPath(filePath);\n  return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n}\n\nfunction buildRejectedResult(\n  filePath: string,\n  indexResult: IndexResult,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  return {\n    success: false,\n    filePath,\n    status: 'rejected',\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: rollbackSucceeded\n      ? 'Atomic index rejected before file promotion'\n      : 'Atomic index rejected but pending file cleanup failed',\n    message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n    embeddingStatus: indexResult.embeddingStatus,\n    hints: [\n      rollbackSucceeded\n        ? 'Pending file was removed because the save was rejected before promotion'\n        : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n    ],\n    ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n    ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n  };\n}\n\nfunction buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n  const message = indexResult.message ?? (\n    indexResult.status === 'duplicate'\n      ? 'Memory skipped (duplicate content)'\n      : `Memory ${indexResult.status} successfully`\n  );\n\n  const hints: string[] = [];\n  if (indexResult.embeddingStatus === 'pending') {\n    hints.push('Memory will be fully indexed when embedding provider becomes available');\n  }\n  if (indexResult.embeddingStatus === 'partial') {\n    hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n  }\n\n  const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n\n  return {\n    success: true,\n    filePath,\n    status: indexResult.status,\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: message,\n    message,\n    embeddingStatus: indexResult.embeddingStatus,\n    ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n      ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n      : {}),\n    ...(hints.length > 0 ? { hints } : {}),\n  };\n}\n\nfunction buildRetryFailureResult(\n  filePath: string,\n  indexError: Error | null,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n  const finalErrorMetadata = errorMetadata ?? {};\n\n  return {\n    success: false,\n    filePath,\n    status: 'error',\n    summary: rollbackSucceeded\n      ? 'Atomic index failed after retry and restored original file state'\n      : 'Atomic index failed after retry and rollback was incomplete',\n    message: indexError?.message ?? 'Indexing failed after retry',\n    hints: [\n      rollbackSucceeded\n        ? 'Original file content was preserved or restored because indexing failed before completion'\n        : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n      'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n    ],\n    error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n    ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n  };\n}\n\nexport async function atomicIndexMemory<TPrepared = unknown>(\n  params: AtomicSaveParams,\n  options: AtomicSaveOptions = {},\n  dependencies: AtomicIndexDependencies<TPrepared>,\n): Promise<AtomicSaveResult> {\n  const { file_path, content } = params;\n  const { force = false } = options;\n\n  const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n\n  let indexResult: IndexResult | null = null;\n  let indexError: Error | null = null;\n  let restoredOriginalAfterFailure = false;\n  let anyPromotionAttempted = false;\n  let errorMetadata: Record<string, string> | null = null;\n  let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n  let lastEffectiveFilePath = file_path;\n  let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n\n  const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n    if (!entry) {\n      return;\n    }\n    errorMetadata = {\n      ...(errorMetadata ?? {}),\n      ...entry,\n    };\n  };\n\n  for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n    let promotedToFinalPath = false;\n    let handledFailureWhileLocked = false;\n    let rollbackSucceededAfterRejectedSave = false;\n    let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n\n    try {\n      const prepared = await dependencies.prepare(params, { attempt, force });\n      if (prepared.status !== 'ready') {\n        return prepared.result;\n      }\n\n      const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n      const lockedResult = await runWithLock(prepared.specFolder, async () => {\n        let effectiveFilePath = lastEffectiveFilePath;\n        let pendingPath = lastPendingPath;\n        let originalState: AtomicIndexOriginalState | null = null;\n        try {\n          let ready = prepared;\n          lockedContext = {\n            attempt,\n            force,\n            params,\n            ready,\n            specFolderLockAlreadyHeld: true,\n          };\n\n          if (dependencies.prepareLocked) {\n            const preparedLocked = await dependencies.prepareLocked(lockedContext);\n            if (preparedLocked.status !== 'ready') {\n              return {\n                kind: 'terminal',\n                result: preparedLocked.result,\n              } as const;\n            }\n\n            ready = preparedLocked;\n            lockedContext = {\n              attempt,\n              force,\n              params,\n              ready,\n              specFolderLockAlreadyHeld: true,\n            };\n          }\n\n          effectiveFilePath = ready.persistedFilePath ?? file_path;\n          const persistedContent = ready.persistedContent ?? content;\n          pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n          originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n          lastEffectiveFilePath = effectiveFilePath;\n          lastPendingPath = pendingPath;\n\n          (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);","lineStart":1,"lineEnd":360,"totalLines":462,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","time":{"start":1781761460426,"end":1781761460436}},"metadata":{"openai":{"itemId":"fc_0f33689ed4629db5016a3385b45a5c8191a3a871c4fc5593d4"}},"id":"prt_ed94248c6001ovv7ia6eLNjN6s","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94220fc001yUh9MgDz6zye8x"}}
{"type":"tool_use","timestamp":1781761460441,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_vBoVsC3tWtto5WrfpFYIY1Hl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Idempotency Receipts\n3: // ───────────────────────────────────────────────────────────────\n4: import { createHash } from 'node:crypto';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import type { MCPResponse } from '../../handlers/types.js';\n8: \n9: export type IdempotencyOperation = 'memory_save' | 'memory_update';\n10: \n11: export interface IdempotencyReceiptInput {\n12:   operation: IdempotencyOperation;\n13:   contentHash: string | null;\n14:   requestFingerprint: Record<string, unknown>;\n15:   payload: Record<string, unknown>;\n16: }\n17: \n18: export interface IdempotencyReceiptKey {\n19:   operation: IdempotencyOperation;\n20:   receiptKey: string;\n21:   contentHash: string | null;\n22:   requestFingerprintHash: string;\n23:   payloadHash: string;\n24: }\n25: \n26: export type IdempotencyLookupResult =\n27:   | { status: 'miss'; key: IdempotencyReceiptKey }\n28:   | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n29:   | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n30: \n31: interface ReceiptRow {\n32:   payload_hash: string;\n33:   response_payload: string;\n34: }\n35: \n36: interface MemorySaveReceiptCandidate {\n37:   id?: unknown;\n38:   status?: unknown;\n39: }\n40: \n41: const RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n42: \n43: const CLIENT_TOKEN_KEYS = new Set([\n44:   'idempotencykey',\n45:   'idempotency_key',\n46:   'idempotencytoken',\n47:   'idempotency_token',\n48:   'clientidempotencykey',\n49:   'client_idempotency_key',\n50:   'clientidempotencytoken',\n51:   'client_idempotency_token',\n52: ]);\n53: \n54: export function isMemoryIdempotencyEnabled(): boolean {\n55:   const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n56:   return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n57: }\n58: \n59: function normalizeForHash(value: unknown): unknown {\n60:   if (Array.isArray(value)) {\n61:     return value.map(normalizeForHash);\n62:   }\n63:   if (!value || typeof value !== 'object') {\n64:     return value;\n65:   }\n66: \n67:   const record = value as Record<string, unknown>;\n68:   const normalized: Record<string, unknown> = {};\n69:   for (const key of Object.keys(record).sort()) {\n70:     if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n71:       continue;\n72:     }\n73:     const normalizedValue = normalizeForHash(record[key]);\n74:     if (normalizedValue !== undefined) {\n75:       normalized[key] = normalizedValue;\n76:     }\n77:   }\n78:   return normalized;\n79: }\n80: \n81: function hashJson(value: unknown): string {\n82:   return createHash('sha256')\n83:     .update(JSON.stringify(normalizeForHash(value)))\n84:     .digest('hex');\n85: }\n86: \n87: export function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n88:   const requestFingerprintHash = hashJson(input.requestFingerprint);\n89:   const payloadHash = hashJson(input.payload);\n90:   const material = {\n91:     operation: input.operation,\n92:     contentHash: input.contentHash ?? null,\n93:     requestFingerprintHash,\n94:   };\n95:   return {\n96:     operation: input.operation,\n97:     receiptKey: hashJson(material),\n98:     contentHash: input.contentHash ?? null,\n99:     requestFingerprintHash,\n100:     payloadHash,\n101:   };\n102: }\n103: \n104: export function shouldStoreMemorySaveReceipt(\n105:   result: MemorySaveReceiptCandidate,\n106:   response: MCPResponse,\n107: ): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n108:   return response.isError !== true\n109:     && typeof result.id === 'number'\n110:     && Number.isInteger(result.id)\n111:     && result.id > 0\n112:     && typeof result.status === 'string'\n113:     && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n114: }\n115: \n116: export function lookupIdempotencyReceipt(\n117:   database: BetterSqlite3.Database,\n118:   input: IdempotencyReceiptInput,\n119: ): IdempotencyLookupResult {\n120:   return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n121: }\n122: \n123: export function lookupIdempotencyReceiptByKey(\n124:   database: BetterSqlite3.Database,\n125:   key: IdempotencyReceiptKey,\n126: ): IdempotencyLookupResult {\n127:   const row = database.prepare(`\n128:     SELECT payload_hash, response_payload\n129:     FROM memory_idempotency_receipts\n130:     WHERE receipt_key = ?\n131:   `).get(key.receiptKey) as ReceiptRow | undefined;\n132: \n133:   if (!row) {\n134:     return { status: 'miss', key };\n135:   }\n136:   if (row.payload_hash !== key.payloadHash) {\n137:     return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n138:   }\n139:   return {\n140:     status: 'replay',\n141:     key,\n142:     response: JSON.parse(row.response_payload) as MCPResponse,\n143:   };\n144: }\n145: \n146: /**\n147:  * Drops the receipt for a key so a follow-up store writes fresh.\n148:  *\n149:  * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n150:  * not a durable record. When a replay is rejected because the live index no\n151:  * longer matches the receipt's content_hash (the logical path moved on and\n152:  * came back, so the cached response now carries a superseded memory id), the\n153:  * cache entry is stale: leaving it lets the post-write store lose the\n154:  * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n155:  * it first lets the re-indexed write store its current response and keeps the\n156:  * cache consistent with the active row. Best-effort: a delete failure must\n157:  * never block serving the live write.\n158:  */\n159: export function deleteIdempotencyReceiptByKey(\n160:   database: BetterSqlite3.Database,\n161:   key: IdempotencyReceiptKey,\n162: ): void {\n163:   try {\n164:     database.prepare(`\n165:       DELETE FROM memory_idempotency_receipts\n166:       WHERE receipt_key = ?\n167:     `).run(key.receiptKey);\n168:   } catch {\n169:     // Best-effort cache eviction; serving the live write takes priority.\n170:   }\n171: }\n172: \n173: export function storeIdempotencyReceipt(\n174:   database: BetterSqlite3.Database,\n175:   key: IdempotencyReceiptKey,\n176:   response: MCPResponse,\n177:   memoryId?: number | null,\n178: ): boolean {\n179:   const info = database.prepare(`\n180:     INSERT INTO memory_idempotency_receipts (\n181:       receipt_key,\n182:       operation,\n183:       content_hash,\n184:       request_fingerprint,\n185:       payload_hash,\n186:       response_payload,\n187:       memory_id,\n188:       updated_at\n189:     ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n190:     ON CONFLICT(receipt_key) DO NOTHING\n191:   `).run(\n192:     key.receiptKey,\n193:     key.operation,\n194:     key.contentHash,\n195:     key.requestFingerprintHash,\n196:     key.payloadHash,\n197:     JSON.stringify(response),\n198:     memoryId ?? null,\n199:   );\n200:   // changes === 0 means a concurrent caller already stored the canonical receipt\n201:   // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n202:   return info.changes > 0;\n203: }\n204: \n205: /**\n206:  * Marks a mutated loser's response with an explicit store-race conflict.\n207:  *\n208:  * When a writer loses the first-store race to a concurrent SAME-KEY,\n209:  * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n210:  * already landed (so an error response would lie), and the winner's stored\n211:  * response answers a different payload (so replaying it would lie too).\n212:  * Rolling the landed mutation back from this late window is the dangerous\n213:  * non-option. What remains is the loser's own response carrying a visible\n214:  * conflict block, so callers know the canonical receipt for this key\n215:  * belongs to a different concurrent request and a later retry may replay\n216:  * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n217:  * original response is returned unmodified.\n218:  */\n219: export function markResponseWithReceiptStoreConflict(\n220:   response: MCPResponse,\n221:   key: IdempotencyReceiptKey,\n222:   storedPayloadHash: string | undefined,\n223: ): MCPResponse {\n224:   const first = response.content?.[0];\n225:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n226:     return response;\n227:   }\n228:   try {\n229:     const envelope = JSON.parse(first.text) as Record<string, unknown>;\n230:     const data = (envelope.data && typeof envelope.data === 'object')\n231:       ? envelope.data as Record<string, unknown>\n232:       : {};\n233:     data.idempotencyStoreConflict = {\n234:       receiptKey: key.receiptKey,\n235:       payloadHash: key.payloadHash,\n236:       storedPayloadHash: storedPayloadHash ?? null,\n237:     };\n238:     envelope.data = data;\n239:     const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n240:     hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n241:     envelope.hints = hints;\n242:     return {\n243:       ...response,\n244:       content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n245:     };\n246:   } catch {\n247:     return response;\n248:   }\n249: }\n250: \n251: /**\n252:  * Deletes receipts older than the retention window. Receipts are replay\n253:  * caches, not durable records: unbounded growth plus indefinite stale\n254:  * replays (including against deleted memories) is the failure mode this\n255:  * sweep bounds. Best-effort by contract — callers must never let a sweep\n256:  * failure block serving.\n257:  */\n258: export function pruneExpiredIdempotencyReceipts(\n259:   database: BetterSqlite3.Database,\n260:   ttlDays?: number,\n261: ): number {\n262:   const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n263:   const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n264:   try {\n265:     // Prune on created_at: it is indexed and, since receipts are insert-only\n266:     // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at —\n267:     // so this is behaviorally identical but avoids a full table scan.\n268:     const info = database.prepare(`\n269:       DELETE FROM memory_idempotency_receipts\n270:       WHERE created_at < datetime('now', ?)\n271:     `).run(`-${days} days`);\n272:     return info.changes;\n273:   } catch {\n274:     return 0;\n275:   }\n276: }\n277: \n278: export function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n279:   const first = response.content?.[0];\n280:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n281:     return null;\n282:   }\n283:   try {\n284:     const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n285:     const id = envelope.data?.id ?? envelope.data?.updated;\n286:     return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n287:   } catch {\n288:     return null;\n289:   }\n290: }\n\n(End of file - total 290 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Idempotency Receipts\n// ───────────────────────────────────────────────────────────────\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Idempotency Receipts\n// ───────────────────────────────────────────────────────────────\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;\n  contentHash: string | null;\n  requestFingerprintHash: string;\n  payloadHash: string;\n}\n\nexport type IdempotencyLookupResult =\n  | { status: 'miss'; key: IdempotencyReceiptKey }\n  | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n  | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n\ninterface ReceiptRow {\n  payload_hash: string;\n  response_payload: string;\n}\n\ninterface MemorySaveReceiptCandidate {\n  id?: unknown;\n  status?: unknown;\n}\n\nconst RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n\nconst CLIENT_TOKEN_KEYS = new Set([\n  'idempotencykey',\n  'idempotency_key',\n  'idempotencytoken',\n  'idempotency_token',\n  'clientidempotencykey',\n  'client_idempotency_key',\n  'clientidempotencytoken',\n  'client_idempotency_token',\n]);\n\nexport function isMemoryIdempotencyEnabled(): boolean {\n  const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n  return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n}\n\nfunction normalizeForHash(value: unknown): unknown {\n  if (Array.isArray(value)) {\n    return value.map(normalizeForHash);\n  }\n  if (!value || typeof value !== 'object') {\n    return value;\n  }\n\n  const record = value as Record<string, unknown>;\n  const normalized: Record<string, unknown> = {};\n  for (const key of Object.keys(record).sort()) {\n    if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n      continue;\n    }\n    const normalizedValue = normalizeForHash(record[key]);\n    if (normalizedValue !== undefined) {\n      normalized[key] = normalizedValue;\n    }\n  }\n  return normalized;\n}\n\nfunction hashJson(value: unknown): string {\n  return createHash('sha256')\n    .update(JSON.stringify(normalizeForHash(value)))\n    .digest('hex');\n}\n\nexport function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n  const requestFingerprintHash = hashJson(input.requestFingerprint);\n  const payloadHash = hashJson(input.payload);\n  const material = {\n    operation: input.operation,\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n  };\n  return {\n    operation: input.operation,\n    receiptKey: hashJson(material),\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n    payloadHash,\n  };\n}\n\nexport function shouldStoreMemorySaveReceipt(\n  result: MemorySaveReceiptCandidate,\n  response: MCPResponse,\n): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n  return response.isError !== true\n    && typeof result.id === 'number'\n    && Number.isInteger(result.id)\n    && result.id > 0\n    && typeof result.status === 'string'\n    && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n}\n\nexport function lookupIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  input: IdempotencyReceiptInput,\n): IdempotencyLookupResult {\n  return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n}\n\nexport function lookupIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): IdempotencyLookupResult {\n  const row = database.prepare(`\n    SELECT payload_hash, response_payload\n    FROM memory_idempotency_receipts\n    WHERE receipt_key = ?\n  `).get(key.receiptKey) as ReceiptRow | undefined;\n\n  if (!row) {\n    return { status: 'miss', key };\n  }\n  if (row.payload_hash !== key.payloadHash) {\n    return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n  }\n  return {\n    status: 'replay',\n    key,\n    response: JSON.parse(row.response_payload) as MCPResponse,\n  };\n}\n\n/**\n * Drops the receipt for a key so a follow-up store writes fresh.\n *\n * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n * not a durable record. When a replay is rejected because the live index no\n * longer matches the receipt's content_hash (the logical path moved on and\n * came back, so the cached response now carries a superseded memory id), the\n * cache entry is stale: leaving it lets the post-write store lose the\n * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n * it first lets the re-indexed write store its current response and keeps the\n * cache consistent with the active row. Best-effort: a delete failure must\n * never block serving the live write.\n */\nexport function deleteIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): void {\n  try {\n    database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE receipt_key = ?\n    `).run(key.receiptKey);\n  } catch {\n    // Best-effort cache eviction; serving the live write takes priority.\n  }\n}\n\nexport function storeIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n  response: MCPResponse,\n  memoryId?: number | null,\n): boolean {\n  const info = database.prepare(`\n    INSERT INTO memory_idempotency_receipts (\n      receipt_key,\n      operation,\n      content_hash,\n      request_fingerprint,\n      payload_hash,\n      response_payload,\n      memory_id,\n      updated_at\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n    ON CONFLICT(receipt_key) DO NOTHING\n  `).run(\n    key.receiptKey,\n    key.operation,\n    key.contentHash,\n    key.requestFingerprintHash,\n    key.payloadHash,\n    JSON.stringify(response),\n    memoryId ?? null,\n  );\n  // changes === 0 means a concurrent caller already stored the canonical receipt\n  // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n  return info.changes > 0;\n}\n\n/**\n * Marks a mutated loser's response with an explicit store-race conflict.\n *\n * When a writer loses the first-store race to a concurrent SAME-KEY,\n * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n * already landed (so an error response would lie), and the winner's stored\n * response answers a different payload (so replaying it would lie too).\n * Rolling the landed mutation back from this late window is the dangerous\n * non-option. What remains is the loser's own response carrying a visible\n * conflict block, so callers know the canonical receipt for this key\n * belongs to a different concurrent request and a later retry may replay\n * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n * original response is returned unmodified.\n */\nexport function markResponseWithReceiptStoreConflict(\n  response: MCPResponse,\n  key: IdempotencyReceiptKey,\n  storedPayloadHash: string | undefined,\n): MCPResponse {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return response;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as Record<string, unknown>;\n    const data = (envelope.data && typeof envelope.data === 'object')\n      ? envelope.data as Record<string, unknown>\n      : {};\n    data.idempotencyStoreConflict = {\n      receiptKey: key.receiptKey,\n      payloadHash: key.payloadHash,\n      storedPayloadHash: storedPayloadHash ?? null,\n    };\n    envelope.data = data;\n    const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n    hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n    envelope.hints = hints;\n    return {\n      ...response,\n      content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n    };\n  } catch {\n    return response;\n  }\n}\n\n/**\n * Deletes receipts older than the retention window. Receipts are replay\n * caches, not durable records: unbounded growth plus indefinite stale\n * replays (including against deleted memories) is the failure mode this\n * sweep bounds. Best-effort by contract — callers must never let a sweep\n * failure block serving.\n */\nexport function pruneExpiredIdempotencyReceipts(\n  database: BetterSqlite3.Database,\n  ttlDays?: number,\n): number {\n  const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n  const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n  try {\n    // Prune on created_at: it is indexed and, since receipts are insert-only\n    // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at —\n    // so this is behaviorally identical but avoids a full table scan.\n    const info = database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE created_at < datetime('now', ?)\n    `).run(`-${days} days`);\n    return info.changes;\n  } catch {\n    return 0;\n  }\n}\n\nexport function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return null;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n    const id = envelope.data?.id ?? envelope.data?.updated;\n    return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n  } catch {\n    return null;\n  }\n}","lineStart":1,"lineEnd":290,"totalLines":290,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","time":{"start":1781761460428,"end":1781761460440}},"metadata":{"openai":{"itemId":"fc_0f33689ed4629db5016a3385b45a688191baa626ba6433b5c6"}},"id":"prt_ed94248cb001QzBlPpaD8I1Uer","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94220fc001yUh9MgDz6zye8x"}}
