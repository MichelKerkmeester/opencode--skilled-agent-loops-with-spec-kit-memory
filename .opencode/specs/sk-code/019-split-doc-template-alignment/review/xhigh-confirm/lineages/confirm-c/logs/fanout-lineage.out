    \"file\": null,\n102:       \"line\": null,\n103:       \"description\": \"security\",\n104:       \"findingClass\": \"summary-only\",\n105:       \"deltaStatus\": \"active\",\n106:       \"scopeProof\": null,\n107:       \"affectedSurfaceHints\": [],\n108:       \"contentHash\": null,\n109:       \"dimension\": \"security\",\n110:       \"firstSeen\": 2,\n111:       \"lastSeen\": 2,\n112:       \"status\": \"active\",\n113:       \"transitions\": [\n114:         {\n115:           \"iteration\": 2,\n116:           \"from\": null,\n117:           \"to\": \"P2\",\n118:           \"reason\": \"Initial discovery (iteration summary)\"\n119:         }\n120:       ],\n121:       \"dimensions\": [\n122:         \"security\"\n123:       ],\n124:       \"mergedFindingIds\": []\n125:     }\n126:   ],\n127:   \"resolvedFindings\": [],\n128:   \"blockedStopHistory\": [],\n129:   \"persistentSameSeverity\": [],\n130:   \"severityChanged\": [],\n131:   \"repeatedFindings\": [],\n132:   \"dimensionCoverage\": {\n133:     \"correctness\": true,\n134:     \"security\": true,\n135:     \"traceability\": false,\n136:     \"maintainability\": false\n137:   },\n138:   \"findingsBySeverity\": {\n139:     \"P0\": 0,\n140:     \"P1\": 2,\n141:     \"P2\": 2\n142:   },\n143:   \"openFindingsCount\": 4,\n144:   \"resolvedFindingsCount\": 0,\n145:   \"convergenceScore\": 1,\n146:   \"graphConvergenceScore\": 0,\n147:   \"graphDecision\": \"CONTINUE\",\n148:   \"graphBlockers\": [],\n149:   \"graphSignals\": {},\n150:   \"candidateCoverage\": {\n151:     \"covered\": [],\n152:     \"ruledOut\": [],\n153:     \"deferred\": [],\n154:     \"blocked\": [],\n155:     \"byBugClass\": {}\n156:   },\n157:   \"searchDebt\": [],\n158:   \"ruledOutCandidates\": [],\n159:   \"cleanSearchProof\": [],\n160:   \"searchCoverage\": {\n161:     \"requiredBugClasses\": [],\n162:     \"covered\": [],\n163:     \"ruledOut\": [],\n164:     \"deferred\": [],\n165:     \"blocked\": [],\n166:     \"graphCoverageMode\": null\n167:   },\n168:   \"traceability\": {\n169:     \"summary\": {\n170:       \"required\": 2,\n171:       \"executed\": 2,\n172:       \"pass\": 0,\n173:       \"partial\": 0,\n174:       \"fail\": 2,\n175:       \"blocked\": 0,\n176:       \"notApplicable\": 0,\n177:       \"gatingFailures\": 2\n178:     },\n179:     \"results\": [\n180:       {\n181:         \"protocolId\": \"spec_code\",\n182:         \"status\": \"fail\",\n183:         \"gateClass\": \"hard\",\n184:         \"applicable\": true,\n185:         \"counts\": {\n186:           \"pass\": 0,\n187:           \"partial\": 0,\n188:           \"fail\": 1,\n189:           \"skipped\": 0\n190:         },\n191:         \"evidence\": [\n192:           \".opencode/specs/sk-code/019-split-doc-template-alignment/spec.md:67-72\",\n193:           \".opencode/skills/sk-code/code-webflow/references/shared/enforcement.md:15-30\"\n194:         ],\n195:         \"findingRefs\": [\n196:           \"C1-P1-001\"\n197:         ],\n198:         \"summary\": \"Provisional R3 contradiction.\"\n199:       },\n200:       {\n201:         \"protocolId\": \"checklist_evidence\",\n202:         \"status\": \"fail\",\n203:         \"gateClass\": \"hard\",\n204:         \"applicable\": true,\n205:         \"counts\": {\n206:           \"pass\": 0,\n207:           \"partial\": 0,\n208:           \"fail\": 1,\n209:           \"skipped\": 0\n210:         },\n211:         \"evidence\": [\n212:           \".opencode/specs/sk-code/019-split-doc-template-alignment/checklist.md:49-52\",\n213:           \".opencode/skills/sk-code/code-webflow/references/shared/enforcement.md:15-30\"\n214:         ],\n215:         \"findingRefs\": [\n216:           \"C1-P1-001\"\n217:         ],\n218:         \"summary\": \"Validator evidence does not prove the ordering invariant.\"\n219:       }\n220:     ]\n221:   },\n222:   \"divergence\": {\n223:     \"started\": [],\n224:     \"completed\": [],\n225:     \"failed\": [],\n226:     \"overrides\": [],