{"type":"tool_use","timestamp":1781718553277,"sessionID":"ses_1294dfb52ffe72Cbk6zciVlr5K","part":{"type":"tool","tool":"read","callID":"tool_Hk2M6z0rqxmKMMzsoaSlf4Jp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","limit":500,"offset":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1200:       } catch (error: unknown) {\n1201:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1202:       }\n1203:     }\n1204:   }\n1205: \n1206:   if (ctx.isCancelled?.()) {\n1207:     return cancelledScanEnvelope(scanKey);\n1208:   }\n1209:   ctx.onPhase?.('post-processing');\n1210: \n1211:   if (filesToDelete.length > 0) {\n1212:     if (results.failed === 0) {\n1213:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1214:       results.staleDeleted = staleDeleteResult.deleted;\n1215:       results.staleDeleteFailed = staleDeleteResult.failed;\n1216:       scanAppliedActions.push(...staleDeleteResult.actions);\n1217:     } else {\n1218:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1219:     }\n1220:   }\n1221: \n1222:   // Time each un-yielded tail phase: because these phases do not yield, their\n1223:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n1224:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n1225:   // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n1226:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n1227:     ctx.onPhase?.(phase);\n1228:     if (!instrument) {\n1229:       return await fn();\n1230:     }\n1231:     const startedAt = Date.now();\n1232:     try {\n1233:       return await fn();\n1234:     } finally {\n1235:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n1236:     }\n1237:   };\n1238: \n1239:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1240:   results.orphanSwept = orphanSweepResult.swept;\n1241:   results.orphanSweepFailed = orphanSweepResult.failed;\n1242:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1243:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1244:   scanAppliedActions.push(...orphanSweepResult.actions);\n1245: \n1246:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1247:   if (results.postInsertEnrichmentRepaired > 0) {\n1248:     scanAppliedActions.push(createStatediffAction('upsert', {\n1249:       target: 'graph_edge',\n1250:       key: 'post-insert-enrichment-repair',\n1251:       sourceOperation: 'scan',\n1252:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1253:     }));\n1254:   }\n1255: \n1256:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1257:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1258:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1259:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1260:   }\n1261:   await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1262: \n1263:   // Create causal chains between spec folder documents.\n1264:   // Includes deferred indexing outcomes and incremental single-file updates.\n1265:   if (include_spec_docs) {\n1266:     try {\n1267:       // Determine which spec folders had spec document changes in this scan.\n1268:       // We use parsed document type (not basename) to avoid false positives\n1269:       // From memory/plan.md or similar filenames.\n1270:       const affectedSpecFolders = new Set<string>();\n1271:       for (const fileResult of results.files) {\n1272:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1273:           continue;\n1274:         }\n1275: \n1276:         if (!fileResult.filePath) {\n1277:           continue;\n1278:         }\n1279: \n1280:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1281:         if (\n1282:           docType !== 'memory' &&\n1283:           docType !== 'constitutional'\n1284:         ) {\n1285:           affectedSpecFolders.add(fileResult.specFolder);\n1286:         }\n1287:       }\n1288: \n1289:       if (affectedSpecFolders.size > 0) {\n1290:         const database = requireDb();\n1291:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1292:         initCausalEdges(database);\n1293: \n1294:         // Build full per-folder document map from DB (not just this scan's files).\n1295:         const selectDocIds = database.prepare(`\n1296:           SELECT document_type, MAX(id) AS id\n1297:           FROM memory_index\n1298:           WHERE spec_folder = ?\n1299:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1300:           GROUP BY document_type\n1301:         `);\n1302: \n1303:         let chainsCreated = 0;\n1304:         let foldersProcessed = 0;\n1305:         let chainYieldCount = 0;\n1306: \n1307:         for (const folder of affectedSpecFolders) {\n1308:           // Per-folder synchronous DB work; yield + cancel-check between folders so a\n1309:           // large affected set cannot block the event loop (same rationale as the\n1310:           // metadata-edge sweep above).\n1311:           if (++chainYieldCount % 50 === 0) {\n1312:             if (ctx.isCancelled?.()) {\n1313:               return cancelledScanEnvelope(scanKey);\n1314:             }\n1315:             await new Promise<void>((resolve) => setImmediate(resolve));\n1316:           }\n1317:           const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n1318:           const docIds: Record<string, number> = {};\n1319: \n1320:           for (const row of rows) {\n1321:             if (row.document_type && typeof row.id === 'number') {\n1322:               docIds[row.document_type] = row.id;\n1323:             }\n1324:           }\n1325: \n1326:           if (Object.keys(docIds).length >= 2) {\n1327:             const chainResult = createSpecDocumentChain(docIds);\n1328:             chainsCreated += chainResult.inserted;\n1329:             foldersProcessed++;\n1330:           }\n1331:         }\n1332: \n1333:         if (chainsCreated > 0) {\n1334:           console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n1335:         }\n1336:       }\n1337:     } catch (err: unknown) {\n1338:       const message = toErrorMessage(err);\n1339:       console.warn('[memory-index-scan] Causal chain creation failed:', message);\n1340:     }\n1341:   }\n1342: \n1343:   if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1344:     runScanInvalidationHooks({\n1345:       indexed: results.indexed,\n1346:       updated: results.updated,\n1347:       staleDeleted: results.staleDeleted,\n1348:       staleDeleteFailed: results.staleDeleteFailed,\n1349:       ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n1350:         ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n1351:         : {}),\n1352:       ...(results.postInsertEnrichmentRepaired > 0\n1353:         ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n1354:         : {}),\n1355:       ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n1356:         ? {\n1357:             orphanSwept: results.orphanSwept,\n1358:             orphanSweepFailed: results.orphanSweepFailed,\n1359:           }\n1360:         : {}),\n1361:     }, scanAppliedActions);\n1362:   }\n1363: \n1364:   runScanHygieneSubscribers(scanAppliedActions);\n1365: \n1366:   const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n1367: \n1368:   const hints: string[] = [];\n1369:   if (results.failed > 0) {\n1370:     hints.push(`${results.failed} files failed to index - check file format`);\n1371:   }\n1372:   if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n1373:     hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n1374:   }\n1375:   if (results.staleDeleted > 0) {\n1376:     hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n1377:   }\n1378:   if (results.staleDeleteFailed > 0) {\n1379:     hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n1380:   }\n1381:   if (results.orphanSwept > 0) {\n1382:     hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n1383:   }\n1384:   if (results.postInsertEnrichmentRepaired > 0) {\n1385:     hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n1386:   }\n1387:   if (results.triggerEmbeddingBackfill?.readyRows) {\n1388:     hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n1389:   }\n1390:   if (results.triggerEmbeddingBackfill?.failedRows) {\n1391:     hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n1392:   }\n1393:   if (results.orphanSweepFailed > 0) {\n1394:     hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n1395:   }\n1396:   if (results.dedup.duplicatesSkipped > 0) {\n1397:     hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n1398:   }\n1399:   if (results.aliasConflicts.groups > 0) {\n1400:     hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n1401:   }\n1402:   if (results.aliasConflicts.divergentHashGroups > 0) {\n1403:     hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n1404:   }\n1405:   if (results.divergenceReconcile.retriesScheduled > 0) {\n1406:     hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n1407:   }\n1408:   if (results.divergenceReconcile.escalated > 0) {\n1409:     hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n1410:   }\n1411:   if (results.divergenceReconcile.errors.length > 0) {\n1412:     hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n1413:   }\n1414:   if (results.checkpointRepair.cleared) {\n1415:     hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n1416:   }\n1417:   if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n1418:     hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n1419:   }\n1420:   if (results.checkpointRepair.error) {\n1421:     hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n1422:   }\n1423:   if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n1424:     hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n1425:   }\n1426:   if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n1427:     hints.push('All files already up-to-date. Use force: true to re-index');\n1428:   }\n1429: \n1430:   await releaseScanLease();\n1431: \n1432:   recordMaintenanceRun('memory_index_scan', {\n1433:     status: 'success',\n1434:     counts: {\n1435:       scanned: results.scanned,\n1436:       indexed: results.indexed,\n1437:       updated: results.updated,\n1438:       unchanged: results.unchanged,\n1439:       failed: results.failed,\n1440:       staleDeleted: results.staleDeleted,\n1441:       staleDeleteFailed: results.staleDeleteFailed,\n1442:       orphanSwept: results.orphanSwept,\n1443:     },\n1444:     staleCandidates: filesToDelete.length,\n1445:   });\n1446: \n1447:   return createMCPSuccessResponse({\n1448:     tool: 'memory_index_scan',\n1449:     summary,\n1450:     data: {\n1451:       status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n1452:       ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n1453:       scanKey,\n1454:       batchSize: scanBatchSize,\n1455:       ...results,\n1456:       ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n1457:         ? {\n1458:             _debug_fileCounts: {\n1459:               constitutionalFiles: constitutionalFiles.length,\n1460:               specDocFiles: specDocFiles.length,\n1461:               totalFiles: files.length,\n1462:               mergedFiles: mergedFiles.length,\n1463:               dedupSkipped: dedupDuplicatesSkipped,\n1464:               includeSpecDocs: include_spec_docs,\n1465:               workspacePath,\n1466:             },\n1467:           }\n1468:         : {})\n1469:     },\n1470:     hints\n1471:   });\n1472:   } finally {\n1473:     if (leaseHeartbeat) {\n1474:       clearInterval(leaseHeartbeat);\n1475:       leaseHeartbeat = null;\n1476:     }\n1477:     if (loopLagTimer) {\n1478:       clearInterval(loopLagTimer);\n1479:       loopLagTimer = null;\n1480:       console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n1481:     }\n1482:     await releaseScanLease();\n1483:   }\n1484: }\n1485: \n1486: /** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n1487:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1488: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1489:   if (!args.background) {\n1490:     return runIndexScan(args, {});\n1491:   }\n1492: \n1493:   const jobId = createJobId();\n1494:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1495: \n1496:   setImmediate(() => {\n1497:     void (async () => {\n1498:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1499:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1500:       // background-embedding queue draining this scan's deferred embeddings can\n1501:       // keep it held past the scan itself.\n1502:       const maintenance = beginMaintenance('index_scan');\n1503:       try {\n1504:         await setJobState(jobId, 'running');\n1505:         const response = await runIndexScan(args, {\n1506:           isCancelled: () => isCancelRequestedFast(jobId),\n1507:           onPhase: (phase) => {\n1508:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1509:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1510:             maintenance.refresh();\n1511:             void setJobPhase(jobId, phase).catch(() => {});\n1512:           },\n1513:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1514:         });\n1515:         const scanData = extractEnvelopeData(response);\n1516:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1517:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1518:         if (wasCancelled) {\n1519:           // The run itself short-circuited on cancellation. A cancel that arrives\n1520:           // after the scan already finished does not retroactively cancel it.\n1521:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1522:         } else if (response.isError === true) {\n1523:           // An error envelope (not a thrown error) still means the scan failed.\n1524:           await appendJobError(jobId, '__scan__', scanData);\n1525:           await setJobState(jobId, 'failed');\n1526:         } else {\n1527:           await completeJob(jobId, { state: 'complete', result: scanData });\n1528:         }\n1529:       } catch (error: unknown) {\n1530:         try {\n1531:           await appendJobError(jobId, '__job__', error);\n1532:           await setJobState(jobId, 'failed');\n1533:         } catch (_secondaryError: unknown) {\n1534:           // Best-effort failure record; never surface a background unhandled rejection.\n1535:         }\n1536:       } finally {\n1537:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1538:         // Release this scan's hold; the marker stays present only while the\n1539:         // background-embedding queue still holds it.\n1540:         maintenance.end();\n1541:       }\n1542:     })();\n1543:   });\n1544: \n1545:   return createMCPSuccessResponse({\n1546:     tool: 'memory_index_scan',\n1547:     summary: `Queued background index scan ${jobId}`,\n1548:     data: { jobId, state: 'queued', background: true },\n1549:     hints: [\n1550:       'Use memory_index_scan_status with jobId to poll progress',\n1551:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1552:     ],\n1553:   });\n1554: }\n1555: \n1556: /* ───────────────────────────────────────────────────────────────\n1557:    9. EXPORTS\n1558: ──────────────────────────────────────────────────────────────── */\n1559: \n1560: export {\n1561:   handleMemoryIndexScan,\n1562:   indexSingleFile,\n1563:   findConstitutionalFiles,\n1564:   findSpecDocuments,\n1565:   detectSpecLevel,\n1566:   summarizeAliasConflicts,\n1567:   runDivergenceReconcileHooks,\n1568: };\n1569: \n1570: // Backward-compatible aliases (snake_case)\n1571: const handle_memory_index_scan = handleMemoryIndexScan;\n1572: const index_single_file = indexSingleFile;\n1573: const find_constitutional_files = findConstitutionalFiles;\n1574: const find_spec_documents = findSpecDocuments;\n1575: const detect_spec_level = detectSpecLevel;\n1576: const summarize_alias_conflicts = summarizeAliasConflicts;\n1577: const run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n1578: \n1579: export {\n1580:   handle_memory_index_scan,\n1581:   index_single_file,\n1582:   find_constitutional_files,\n1583:   find_spec_documents,\n1584:   detect_spec_level,\n1585:   summarize_alias_conflicts,\n1586:   run_divergence_reconcile_hooks,\n1587: };\n\n(End of file - total 1587 lines)\n</content>","metadata":{"preview":"      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {\n          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }\n\n  if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    runScanInvalidationHooks({\n      indexed: results.indexed,\n      updated: results.updated,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n        ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n        : {}),\n      ...(results.postInsertEnrichmentRepaired > 0\n        ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n        : {}),\n      ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n        ? {\n            orphanSwept: results.orphanSwept,\n            orphanSweepFailed: results.orphanSweepFailed,\n          }\n        : {}),\n    }, scanAppliedActions);\n  }\n\n  runScanHygieneSubscribers(scanAppliedActions);\n\n  const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n\n  const hints: string[] = [];\n  if (results.failed > 0) {\n    hints.push(`${results.failed} files failed to index - check file format`);\n  }\n  if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n    hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n  }\n  if (results.staleDeleted > 0) {\n    hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n  }\n  if (results.staleDeleteFailed > 0) {\n    hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n  }\n  if (results.orphanSwept > 0) {\n    hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n  }\n  if (results.postInsertEnrichmentRepaired > 0) {\n    hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.readyRows) {\n    hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.failedRows) {\n    hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n  }\n  if (results.orphanSweepFailed > 0) {\n    hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n  }\n  if (results.dedup.duplicatesSkipped > 0) {\n    hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n  }\n  if (results.aliasConflicts.groups > 0) {\n    hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n  }\n  if (results.aliasConflicts.divergentHashGroups > 0) {\n    hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n  }\n  if (results.divergenceReconcile.retriesScheduled > 0) {\n    hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n  }\n  if (results.divergenceReconcile.escalated > 0) {\n    hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n  }\n  if (results.divergenceReconcile.errors.length > 0) {\n    hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n  }\n  if (results.checkpointRepair.cleared) {\n    hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n  }\n  if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n    hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n  }\n  if (results.checkpointRepair.error) {\n    hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n  }\n  if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n    hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n  }\n  if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n    hints.push('All files already up-to-date. Use force: true to re-index');\n  }\n\n  await releaseScanLease();\n\n  recordMaintenanceRun('memory_index_scan', {\n    status: 'success',\n    counts: {\n      scanned: results.scanned,\n      indexed: results.indexed,\n      updated: results.updated,\n      unchanged: results.unchanged,\n      failed: results.failed,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      orphanSwept: results.orphanSwept,\n    },\n    staleCandidates: filesToDelete.length,\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})\n    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_index_scan = handleMemoryIndexScan;\nconst index_single_file = indexSingleFile;\nconst find_constitutional_files = findConstitutionalFiles;\nconst find_spec_documents = findSpecDocuments;\nconst detect_spec_level = detectSpecLevel;\nconst summarize_alias_conflicts = summarizeAliasConflicts;\nconst run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n\nexport {\n  handle_memory_index_scan,\n  index_single_file,\n  find_constitutional_files,\n  find_spec_documents,\n  detect_spec_level,\n  summarize_alias_conflicts,\n  run_divergence_reconcile_hooks,\n};","lineStart":1200,"lineEnd":1587,"totalLines":1587,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781718553261,"end":1781718553274}},"id":"prt_ed6b38ea7001PGTNg6334oNek7","sessionID":"ses_1294dfb52ffe72Cbk6zciVlr5K","messageID":"msg_ed6b36513001HYl8l44MWBk627"}}
