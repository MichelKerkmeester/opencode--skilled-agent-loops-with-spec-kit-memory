   484	        requiredAggregateScore: aggregateThreshold,
   485	        minimumFixtureScore,
   486	        repeatabilityTolerance: profile.benchmark?.repeatabilityTolerance ?? 0,
   487	        thresholdDelta: Number(profile.thresholdDelta || 0),
   488	      },
   489	      rows: results,
   490	      fixtures: results,
   491	      failureModes: aggregateFailureModes(results),
   492	    };
   493	
   494	    if (integrationReportPath) {
   495	      const integration = scoreIntegration(integrationReportPath);
   496	      report.integrationScore = integration.integrationScore;
   497	      report.integrationDetails = integration.integrationDetails;
   498	    }
   499	
   500	    writeJson(outputPath, report);
   501	
   502	    // F-P1-13 / 014-review traceability-7-2: outputPath is a mutable canonical
   503	    // location overwritten every iteration, so historical state-log rows would all
   504	    // point at the latest report. Also write an immutable, label-stamped snapshot
   505	    // and persist that snapshot path in the ledger so each iteration's report is
   506	    // recoverable. The canonical report.json stays the stable "latest" pointer.
   507	    const historyDir = path.join(path.dirname(outputPath), 'report-history');
   508	    const snapshotName = `report-${sanitizeLabel(label)}-${timestampStamp()}.json`;
   509	    const snapshotPath = path.join(historyDir, snapshotName);
   510	    writeJson(snapshotPath, report);
   511	
   512	    if (stateLogPath) {
   513	      appendJsonl(stateLogPath, {
   514	        type: 'benchmark_run',
   515	        mode: 'model-benchmark',
   516	        scoringMethod: scorer,
   517	        grader: graderKind,
   518	        profileId,
   519	        family: profile.family,
   520	        target: profile.targetPath,
   521	        label,
   522	        outputDir: outputsDir,
   523	        report: outputPath,
   524	        reportSnapshot: snapshotPath,
   525	        provenance,
   526	        aggregateScore,
   527	        totals: report.totals,
   528	        rows: results,
   529	        recommendation,
   530	        failureModes: report.failureModes,
   531	      });
   532	    }
   533	  } catch (error) {
   534	    const failure = {
   535	      status: 'infra_failure',
   536	      // F-P1-7 (014 review): a failed 5dim/mock/llm run must be distinguishable
   537	      // from a pattern/noop failure, so carry scorer + grader provenance here too.
   538	      scoringMethod: scorer,
   539	      grader: graderKind,
   540	      profileId,
   541	      family: null,
   542	      evaluationMode: 'benchmark',
   543	      mode: 'model-benchmark',
   544	      outputsDir,
   545	      provenance: {
   546	        profilePath,
   547	        profileVersion,
   548	        fixtureDir,
   549	        fixtureFiles,
   550	      },
   551	      error: error.message,
   552	      failureModes: ['benchmark-runner-failure'],
   553	    };
   554	    writeJson(outputPath, failure);
   555	    if (stateLogPath) {
   556	      appendJsonl(stateLogPath, {
   557	        type: 'infra_failure',
   558	        mode: 'model-benchmark',
   559	        evaluationMode: 'benchmark',
   560	        scoringMethod: scorer,
   561	        grader: graderKind,
   562	        profileId,
   563	        family: null,
   564	        provenance: {
   565	          profilePath,
   566	          profileVersion,
   567	          fixtureDir,
   568	          fixtureFiles,
   569	        },
   570	        recommendation: 'infra_failure',
   571	        error: error.message,
   572	        failureModes: ['benchmark-runner-failure'],
   573	      });
   574	    }
   575	    process.exit(1);
   576	  }
   577	}
   578	
   579	main().catch((error) => {
   580	  process.stderr.write(`${error && error.stack ? error.stack : error}\n`);
   581	  process.exit(1);
   582	});
