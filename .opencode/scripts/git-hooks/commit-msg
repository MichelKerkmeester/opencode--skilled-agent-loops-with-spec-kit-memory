#!/usr/bin/env bash
# Commit-msg hook - blocking structural validation plus advisory clarity checks.
#
# Bypass: SPECKIT_SKIP_COMMIT_MSG_VALIDATE=1 git commit ...
# Install: bash .opencode/scripts/install-git-hooks.sh
# Uninstall: rm .git/hooks/commit-msg

set -euo pipefail

# Pin a UTF-8 locale so character-length checks below are consistent
# regardless of the caller's environment (bash's ${#var} count is
# locale-dependent — under a non-UTF-8 locale it counts bytes, not
# codepoints, and multi-byte subjects would be measured wrong).
export LC_ALL=C.UTF-8

if [[ "${SPECKIT_SKIP_COMMIT_MSG_VALIDATE:-0}" = "1" ]]; then
  exit 0
fi

MESSAGE_FILE="${1:-}"
if [[ -z "$MESSAGE_FILE" || ! -f "$MESSAGE_FILE" ]]; then
  printf 'BLOCKED: commit-msg hook received no readable message file.\n' >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$REPO_ROOT" ]]; then
  exit 0
fi

CLEAN_MESSAGE="$(git stripspace --strip-comments < "$MESSAGE_FILE")"
if [[ -z "$CLEAN_MESSAGE" ]]; then
  printf 'BLOCKED: commit message is empty.\n' >&2
  printf 'Expected: type(scope): imperative summary\n' >&2
  exit 1
fi

ERRORS=()
WARNINGS=()

SUBJECT="${CLEAN_MESSAGE%%$'\n'*}"

# Preserve subjects generated by Git itself.
case "$SUBJECT" in
  Merge\ *|Revert\ \"*\"|fixup!\ *|squash!\ *|amend!\ *)
    exit 0
    ;;
esac

REST=""
BODY=""
if [[ "$CLEAN_MESSAGE" == *$'\n'* ]]; then
  REST="${CLEAN_MESSAGE#*$'\n'}"
  if [[ -n "$REST" ]]; then
    if [[ "$REST" == $'\n'* ]]; then
      BODY="${REST#$'\n'}"
    else
      BODY="$REST"
      ERRORS+=("Separate the subject from the body with a blank line.")
    fi
  fi
fi

SCOPE=""
BREAKING=""
SUMMARY=""

# Scope is strict lowercase kebab-case: no dots, slashes, leading/trailing/
# repeated hyphens. This deliberately rejects legacy packet-path scopes like
# (028/005) or (sk-code/024) — the contract wants a stable subsystem name,
# not a spec-folder path.
SUBJECT_RE='^(build|chore|ci|docs|feat|fix|merge|perf|refactor|release|revert|style|test)\(([a-z0-9]+(-[a-z0-9]+)*)\)(!)?: (.+)$'

if [[ "$SUBJECT" =~ $SUBJECT_RE ]]; then
  SCOPE="${BASH_REMATCH[2]}"
  BREAKING="${BASH_REMATCH[4]}"
  SUMMARY="${BASH_REMATCH[5]}"

  if [[ "$SCOPE" =~ ^[0-9]+$ ]]; then
    ERRORS+=("Scope '$SCOPE' is numeric-only; use the stable owning subsystem.")
  fi

  if [[ ! "$SUMMARY" =~ ^[a-z] ]]; then
    ERRORS+=("Summary must start with a lowercase imperative verb.")
  fi

  if [[ "$SUMMARY" == *"  "* ]]; then
    ERRORS+=("Summary contains repeated spaces.")
  fi

  TRAILING_PUNCT_RE='[.!?;:,]$'
  if [[ "$SUMMARY" =~ $TRAILING_PUNCT_RE ]]; then
    ERRORS+=("Summary must not end with punctuation.")
  fi

  case "$SUMMARY" in
    "change files"|"changes"|"checkpoint"|"cleanup"|"fix"|"fix bug"|"misc"|"misc changes"|"miscellaneous changes"|"stuff"|"update"|"update files"|"update stuff"|"various changes"|"work in progress"|"wip")
      ERRORS+=("Summary '$SUMMARY' is too vague; name the changed behavior or artifact.")
      ;;
  esac

  PROCESS_LABEL_RE='(Phase[[:space:]][A-Z0-9]|wave[[:space:]][+A-Za-z0-9]|Lane[[:space:]][A-Z]|[0-9]+[[:space:]]tasks?|swarm|tranche|WU[0-9]+)'
  if [[ "$SUMMARY" =~ $PROCESS_LABEL_RE ]]; then
    WARNINGS+=("Subject contains internal process language; move it to Context or Refs when it does not describe behavior.")
  fi
else
  ERRORS+=("Authored subject must match type(scope)[!]: imperative summary using an allowed type.")
fi

SUBJECT_LENGTH="${#SUBJECT}"
if (( SUBJECT_LENGTH > 100 )); then
  ERRORS+=("Subject is ${SUBJECT_LENGTH} characters; maximum is 100.")
elif (( SUBJECT_LENGTH > 80 )); then
  WARNINGS+=("Subject is ${SUBJECT_LENGTH} characters; target 80 or fewer for readable git logs.")
fi

HAS_EXPLANATORY_BODY=0
HAS_BREAKING_FOOTER=0
TRAILER_RE='^((Co-Authored-By|Signed-off-by|Reviewed-by|Tested-by|Refs)(:|[[:space:]])|(Fixes|Closes|Related[[:space:]]to)[[:space:]])'
BREAKING_FOOTER_RE='^BREAKING CHANGE: .+$'
BODY_LINE=3

if [[ -n "$BODY" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    if (( ${#line} > 100 )); then
      WARNINGS+=("Body line $BODY_LINE exceeds 100 characters.")
    fi

    if [[ -n "$line" && ! "$line" =~ $TRAILER_RE ]]; then
      HAS_EXPLANATORY_BODY=1
    fi

    if [[ "$line" =~ $BREAKING_FOOTER_RE ]]; then
      HAS_BREAKING_FOOTER=1
    fi

    BODY_LINE=$((BODY_LINE + 1))
  done <<< "$BODY"
fi

if [[ "$BREAKING" == "!" && "$HAS_BREAKING_FOOTER" -eq 0 ]]; then
  ERRORS+=("A breaking '!' subject requires a 'BREAKING CHANGE: <description>' footer line.")
fi

STAGED_FILE_COUNT=0
if ! STAGED_FILE_COUNT="$(
  git -C "$REPO_ROOT" diff --cached --name-only 2>/dev/null \
    | wc -l \
    | tr -d '[:space:]'
)"; then
  STAGED_FILE_COUNT=0
fi
STAGED_FILE_COUNT="${STAGED_FILE_COUNT:-0}"

if (( STAGED_FILE_COUNT >= 4 && HAS_EXPLANATORY_BODY == 0 )); then
  ERRORS+=("${STAGED_FILE_COUNT} paths are staged; SKILL.md requires a body when four or more paths are staged.")
fi

if (( ${#ERRORS[@]} > 0 )); then
  printf '\nBLOCKED: commit message validation failed:\n' >&2
  for message in "${ERRORS[@]}"; do
    printf '  - %s\n' "$message" >&2
  done

  if (( ${#WARNINGS[@]} > 0 )); then
    printf '\nAdditional clarity warnings:\n' >&2
    for message in "${WARNINGS[@]}"; do
      printf '  - %s\n' "$message" >&2
    done
  fi

  printf '\nExpected: type(scope): imperative summary\n' >&2
  printf 'Example: fix(code-graph): consume invalidation markers after commits\n' >&2
  printf 'Bypass: SPECKIT_SKIP_COMMIT_MSG_VALIDATE=1 git commit ...\n\n' >&2
  exit 1
fi

if (( ${#WARNINGS[@]} > 0 )); then
  printf '\nWARNING: commit message clarity checks found:\n' >&2
  for message in "${WARNINGS[@]}"; do
    printf '  - %s\n' "$message" >&2
  done
  printf 'Commit allowed; consider revising the message.\n\n' >&2
fi

exit 0
