, targets };\n\n  Line 445:     selectionKind: action === 'route'\n\n  Line 446:       ? (decision.selectionKind || selectionKindForTargets(targets))\n\n  Line 453:   for (const field of ['action', 'selectionKind']) {\n\n  Line 506:  * Re-hash the frozen scorer trio against the pinned digests. Returns the drift\n\n  Line 508:  * changed scorer is drift, never silently tolerated.\n\n  Line 513:  * @returns {{ok:boolean, drift:Array<{file:string, expected:string, actual:(string|null), error?:string}>}} Gate result.\n\n  Line 516:   const drift = [];\n\n  Line 522:       if (actual !== expected) drift.push({ file, expected, actual });\n\n  Line 525:       drift.push({ file, expected, actual: null, error: err && err.message });\n\n  Line 528:   return { ok: drift.length === 0, drift, digests };\n\n  Line 570:   // (informational), never scored as drift.\n\n  Line 644:   // false pass and not a drift.\n\n  Line 693:   const firstDifference = firstProjectionDifference(legacyProjection, compiledProjection);\n\n  Line 699:   // not drift; only an outcome DIFFERENCE (one side passes, the other fails)\n\n  Line 700:   // is drift. The old `compiledGoldPass && legacyGoldPass` formula wrongly\n\n  Line 702:   // drift even when compiled tracked legacy exactly.\n\n  Line 705:   // agree on such a non-route decision (firstDifference null), any resource gold\n\n  Line 709:   // empty-by-design decision would misread identical routing as drift. A served\n\n  Line 710:   // `route` still compares gold, so a real compiled resource gap on a route drifts.\n\n  Line 711:   const match = firstDifference === null\n\n  Line 718:       : (firstDifference ? 'routing-projection-mismatch' : 'route-gold-failure'),\n\n  Line 726:     firstDifference,\n\n  Line 732:  * paths outrank drift, which outranks a clean compiled-serving run; a run with\n\n  Line 733:  * no scored parity rows is n/a. Broken and drift both block, but stay distinct\n\n  Line 741:   const counts = { match: 0, drift: 0, vacuous: 0, 'n/a': 0, 'resolver-missing': 0 };\n\n  Line 748:   else if (counts.drift > 0 || counts.vacuous > 0) subVerdict = COMPILED_SUBVERDICT.DRIFTED;\n\n  Line 775:  * @param {boolean} blocking - Whether the compiled roll-up is drift/broken.\n\n  Line 826:   selectionKindForTargets,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/build-report.cjs:\n  Line 3: // ║ build-report.cjs — render report.md from report.json (anti-drift)        ║\n\n  Line 8:  * build-report.cjs — render report.md FROM report.json (anti-drift).\n\n  Line 11:  * human report.md, with the markdown rendered from the JSON so they cannot drift.\n\n  Line 182:     lines.push(`- Scored: **${c.scored || 0}** · match: **${ct.match || 0}** · drift: **${ct.drift || 0}** · vacuous: **${ct.vacuous || 0}** · resolver-missing: **${ct['resolver-missing'] || 0}** · n/a: **${ct['n/a'] || 0}**`);\n\n  Line 183:     lines.push(`- Eligible rows: **${Array.isArray(c.eligibleRows) ? c.eligibleRows.length : 0}** · drift rows: **${Array.isArray(c.driftRows) ? c.driftRows.length : 0}** · breakages: **${Array.isArray(c.breakages) ? c.breakages.length : 0}**`);\n\n  Line 196:         const difference = row.firstDifference\n\n  Line 197:           ? `${row.firstDifference.field}: ${JSON.stringify(row.firstDifference.legacy)} -> ${JSON.stringify(row.firstDifference.compiled)}`\n\n  Line 207:   // the ordinary report and cannot drift an existing shape. It exists so an\n\n  Line 297:     lines.push('## Contamination findings (router mode — drift, not failures)');\n\n  Line 299:     lines.push('_Playbook prompts intentionally carry trigger words; these are reported as drift signals, not scenario failures._');\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs:\n  Line 25:  * finding the scorer should surface as router↔gold drift, not silently drop.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs:\n  Line 203: // executors. Contamination-lint is a drift FINDING in router mode (the playbook\n\n  Line 314:   // write if one drifted from its pinned digest — a scorer changed mid-flight\n\n  Line 321:       const detail = frozenGate.drift\n\n  Line 324:       process.stderr.write(`run-skill-benchmark: frozen_scorer_drift — compiled-parity aborted, no report written: ${detail}\\n`);\n\n  Line 332:   // the committed gold would silently drift apart mid-run. A skill with no\n\n  Line 369:         'run-skill-benchmark: frozen_scorer_drift — scorer bytes changed during the run; no report written\\n',\n\n  Line 382:   // three distinct sub-verdicts (serving / legacy-fallback-drifted /\n\n  Line 383:   // broken-compiled-path), and a drift or broken path raises its own outer\n\n  Line 406:       driftRows: parityRows.filter((row) => row.status === 'drift' || row.status === 'vacuous'),\n\n  Line 422:         statusEnum: ['match', 'drift', 'vacuous', 'n/a', 'resolver-missing'],\n\n  Line 428:     // BLOCKED-BY-* stays, so route-gold and compiled drift remain distinct.\n\n  Line 445:   // compiled-parity gate is the same again: a drifted or broken compiled path\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/README.md:\n  Line 87: +-- build-report.cjs              # Renders report.md FROM report.json (anti-drift)\n\n  Line 110: | `build-report.cjs` | The ONLY writer of `report.md`. Renders the human markdown FROM the `report.json` object (anti-drift); accepts no score arguments. Exports `renderReport`. |\n\n  Line 187: The shared status probe distinguishes a missing manifest (`legacy-by-construction`), stale manifest (`re-mint-required` drift), and fresh-manifest front-door breakage. The benchmark reports these states but never mints, repairs, or edits activation data. Status authority remains the compiled-routing decision contract; Lane C only consumes it.\n\n  Line 189: `report.json` is authoritative. Its `compiledRouting` block records `flagForcedOn`, eligible rows, parity counts, drift rows, breakages, frozen scorer hashes before and after the run, full routing projections, and the first differing field. `report.md` is rendered from that JSON. Drift or breakage raises `BLOCKED-BY-COMPILED-DRIFT` and exit 3 unless a higher-precedence structural, registry, or route-gold block already owns the verdict.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/router-replay.cjs:\n  Line 267:  * manifest is the source of truth for \"the whole toolkit\": a hand list drifts\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/tests/code-opencode-playbook-ids.vitest.ts:\n  Line 11: // parsed scenario count drifts away from the number of on-disk markdown files\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/tests/design-dispatch-boundary-proof.vitest.ts:\n  Line 121:     expect(result.driftDetected).toBe(false);\n\n  Line 125:   it('detects drift and missing files in a declared copy set', () => {\n\n  Line 139:     const drifted = checkDesignDispatchBoundaryParity({ skillRoot: root, copies: ['declared-copy.md'] });\n\n  Line 140:     expect(drifted.verdict).toBe('rejected');\n\n  Line 141:     expect(findingCodes(drifted)).toContain('asset-copy-drift');\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/tests/compiled-routing-cutover-luna.test.cjs:\n  Line 40: // 2. compiled decision differs from legacy -> FAIL (real drift).\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/tests/README.md:\n  Line 3: description: \"The three Vitest suites covering the skill-benchmark (Lane C) lane: orchestrator/router-replay/dual-report, playbook mode, and the sk-code router drift guard.\"\n\n  Line 22: - `skill-benchmark.vitest.ts` and `playbook-mode.vitest.ts` cover the lane's two modes plus scoring; `sk-code-router-sync.vitest.ts` is a drift guard that reads the live `sk-code` skill on disk.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/tests/mcp-figma-router-sync.vitest.ts:\n  Line 12: // drift: same intent keys, same keywords per intent (neither side gains or drops\n\n  Line 85:   it('no keyword drift: INTENT_SIGNALS mirrors every INTENT_MODEL keyword, and adds none', () => {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/tests/surface-slice-sync.vitest.ts:\n  Line 16: // loudly if the slicing prefixes drift out of sync with the packet-folder names.\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"compiled-only|drift|firstDifference|goldPass|selectionKind|surfaceBun