   115	  const original = {
   116	    log: console.log,
   117	    info: console.info,
   118	    debug: console.debug,
   119	    warn: console.warn,
   120	  };
   121	
   122	  console.log = forwarded;
   123	  console.info = forwarded;
   124	  console.debug = forwarded;
   125	  console.warn = forwarded;
   126	
   127	  try {
   128	    return await fn();
   129	  } finally {
   130	    console.log = original.log;
   131	    console.info = original.info;
   132	    console.debug = original.debug;
   133	    console.warn = original.warn;
   134	  }
   135	}
