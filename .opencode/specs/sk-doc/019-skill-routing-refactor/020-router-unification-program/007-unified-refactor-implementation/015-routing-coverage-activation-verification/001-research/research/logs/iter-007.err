   263	  if (!args.report) {
   264	    process.stderr.write('usage: build-report.cjs --report <report.json> [--output <report.md>]\n');
   265	    process.exit(2);
   266	  }
   267	  const report = JSON.parse(fs.readFileSync(args.report, 'utf8'));
   268	  const md = renderReport(report);
   269	  if (args.output) { fs.writeFileSync(args.output, md); process.stdout.write(`wrote ${args.output}\n`); }
   270	  else process.stdout.write(md + '\n');
