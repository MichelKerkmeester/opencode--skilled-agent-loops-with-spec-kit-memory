n1371:     if (resultsData && data && existingResults && existingResults.length > 0) {\n1372:       const { results: dedupedResults } = applySessionDedup(\n1373:         existingResults,\n1374:         sessionId,\n1375:         enableDedup\n1376:       );\n1377: \n1378:       const originalCount = existingResults.length;\n1379:       const dedupedCount = dedupedResults.length;\n1380:       const filteredCount = originalCount - dedupedCount;\n1381: \n1382:       const tokensSaved = filteredCount * 200;\n1383:       const savingsPercent = originalCount > 0\n1384:         ? Math.round((filteredCount / originalCount) * 100)\n1385:         : 0;\n1386: \n1387:       data.results = dedupedResults;\n1388:       data.count = dedupedCount;\n1389: \n1390:       const dedupStats = {\n1391:         enabled: true,\n1392:         sessionId,\n1393:         originalCount: originalCount,\n1394:         returnedCount: dedupedCount,\n1395:         filteredCount: filteredCount,\n1396:         tokensSaved: tokensSaved,\n1397:         savingsPercent: savingsPercent,\n1398:         tokenSavingsEstimate: tokensSaved > 0 ? `~${tokensSaved} tokens` : '0'\n1399:       };\n1400:       resultsData.dedupStats = dedupStats;\n1401: \n1402:       if (resultsData.meta && typeof resultsData.meta === 'object') {\n1403:         (resultsData.meta as Record<string, unknown>).dedupStats = dedupStats;\n1404:       }\n1405: \n1406:       if (filteredCount > 0 && typeof resultsData.summary === 'string') {\n1407:         resultsData.summary += ` (${filteredCount} duplicates filtered, ~${tokensSaved} tokens saved)`;\n1408:       }\n1409: \n1410:       responseToReturn = {\n1411:         ...responseToReturn,\n1412:         content: [{ type: 'text', text: JSON.stringify(resultsData, null, 2) }]\n1413:       } as MCPResponse;\n1414:     }\n1415:   }\n1416: \n1417:   if (sessionId && isSessionRetrievalStateEnabled()) {\n1418:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1419:     const data 