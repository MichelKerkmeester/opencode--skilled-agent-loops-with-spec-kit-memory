const tree = await (await fetch('https://api.github.com/repos/silships/figma-cli/git/trees/main?recursive=1')).json();
const files = tree.tree.map(x=>x.path).filter(p => p === 'package.json' || p === 'README.md' || p === 'REFERENCE.md' || p === 'CLAUDE.md' || p.startsWith('src/') || p.startsWith('plugin/') || p.startsWith('docs/'));
const commandFiles = files.filter(p => p.startsWith('src/commands/') && p.endsWith('.js'));
for (const p of commandFiles) {
  const url = 'https://raw.githubusercontent.com/silships/figma-cli/main/' + p;
  const text = await (await fetch(url)).text();
  const lines = text.split(/\n/);
  console.log('\n## ' + p);
  for (let i=0;i<lines.length;i++) {
    const line = lines[i];
    if (/\.command\(|\.alias\(|\.description\(|\.option\(|\.argument\(|\.requiredOption\(/.test(line)) {
      console.log(String(i+1).padStart(4) + ': ' + line.trim());
    }
  }
}
let mcpHits=[];
for (const p of files) {
  const url = 'https://raw.githubusercontent.com/silships/figma-cli/main/' + p;
  const text = await (await fetch(url)).text();
  const re = /mcp|model context protocol/ig;
  let match; while ((match = re.exec(text))) {
    const before = text.slice(0, match.index);
    const lineNo = before.split(/\n/).length;
    const line = text.split(/\n/)[lineNo-1].trim();
    mcpHits.push(`${p}:${lineNo}: ${line}`);
  }
}
console.log('\n## MCP hits');
console.log(mcpHits.length ? mcpHits.join('\n') : 'NONE');
NODE
