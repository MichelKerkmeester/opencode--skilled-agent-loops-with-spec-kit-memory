\",\n151:         \"path\": \"plan.md\",\n152:         \"source\": \"derived\"\n153:       },\n154:       {\n155:         \"name\": \"a\",\n156:         \"kind\": \"key_phrase\",\n157:         \"path\": \"plan.md\",\n158:         \"source\": \"derived\"\n159:       },\n160:       {\n161:         \"name\": \"the\",\n162:         \"kind\": \"key_phrase\",\n163:         \"path\": \"plan.md\",\n164:         \"source\": \"derived\"\n165:       },\n166:       {\n167:         \"name\": \"no\",\n168:         \"kind\": \"key_phrase\",\n169:         \"path\": \"plan.md\",\n170:         \"source\": \"derived\"\n171:       },\n172:       {\n173:         \"name\": \"1. SUMMARY\",\n174:         \"kind\": \"heading\",\n175:         \"path\": \"plan.md\",\n176:         \"source\": \"derived\"\n177:       },\n178:       {\n179:         \"name\": \"Task Format\",\n180:         \"kind\": \"proper_noun\",\n181:         \"path\": \"tasks.md\",\n182:         \"source\": \"derived\"\n183:       },\n184:       {\n185:         \"name\": \"Task Notation\",\n186:         \"kind\": \"proper_noun\",\n187:         \"path\": \"tasks.md\",\n188:         \"source\": \"derived\"\n189:       },\n190:       {\n191:         \"name\": \"Completion Criteria The\",\n192:         \"kind\": \"proper_noun\",\n193:         \"path\": \"tasks.md\",\n194:         \"source\": \"derived\"\n195:       },\n196:       {\n197:         \"name\": \"Phase 1: Setup\",\n198:         \"kind\": \"heading\",\n199:         \"path\": \"tasks.md\",\n200:         \"source\": \"derived\"\n201:       }\n202:     ],\n203:     \"causal_summary\": \"This phase is the direct follow-on to 019. 019 made a reindex's SCAN survive launcher re-election by writing a maintenance-active marker that the launcher reads to adopt a busy-but-healthy daemon instead of reaping it. But that marker was scoped to the scan job. Because the scan defers embeddings (`asyncEmbedding`), the real vector writes happen AFTER the scan, in the background-embedding queue (`lib/providers/retry-manager.ts` draining `embedding_status='pending'` rows). That queue is busy-but-unprotected: a live run saw a separate re-election recycle the daemon DURING the post-scan embedding burst, interrupting the embeddings. Search stayed up and the gap drained on a later queue pass, but the reindex was not re-election-proof end to end. 019's own limitations section flagged this as the loop-closing follow-on.\",\n204:     \"created_at\": \"2026-06-17T13:56:34.988Z\",\n205:     \"last_save_at\": \"2026-06-17T13:56:34.988Z\",\n206:     \"save_lineage\": \"same_pass\",\n207:     \"last_accessed_at\": null,\n208:     \"source_docs\": [\n209:       \"spec.md\",\n210:       \"plan.md\",\n211:       \"tasks.md\",\n212:       \"implementation-summary.md\"\n213:     ],\n214:     \"last_active_child_id\": null,\n215:     \"last_active_at\": null\n216:   }\n217: }\n\n(End of file - total 217 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/020-maintenance-grace-background-embedding\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/020-maintenance-grace-background-embedding\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"maintenance grace background embedding\",\n      \"maintenance marker reference counted embedding queue\",\n      \"reindex post-scan embedding burst re-election\",\n      \"027 002/020\",\n      \"maintenance grace background embedding plan\",\n      \"reference-counted marker embedding queue plan\",\n      \"027 002/020 plan\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Envi