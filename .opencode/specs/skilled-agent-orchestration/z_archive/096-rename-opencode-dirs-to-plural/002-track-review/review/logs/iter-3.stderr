   685	          command: |
   686	            node --experimental-strip-types --input-type=module <<'EOF'
   687	            import { readFileSync, writeFileSync } from 'node:fs';
   688	            import { spawnSync } from 'node:child_process';
   689	
   690	            import { buildCopilotPromptArg } from './.opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/executor-config.ts';
   691	
   692	            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';
   693	            const prompt = readFileSync(promptPath, 'utf8');
   694	
   695	            // Workflow-resolved spec folder is the only legal write authority.
   696	            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)
   697	            // is the single source of truth for rejecting empty / unresolved
   698	            // template / whitespace-only / string-coerced empty values. The
   699	            // YAML hands the raw `{spec_folder}` directly; on rejection the
   700	            // helper safe-fails to `type:"missing", writeIntent:true` (Gate-3
   701	            // enforcement, --allow-all-tools stripped).
   702	            const specFolderRaw = '{spec_folder}';
   703	            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };
   704	
   705	            const baseArgs = [
   706	              '-p',
   707	              prompt,
   708	              '--model',
   709	              '{config.executor.model}',
   710	              '--allow-all-tools',
   711	              '--no-ask-user',
   712	            ];
   713	
   714	            const built = buildCopilotPromptArg({
   715	              promptPath,
   716	              prompt,
   717	              targetAuthority,
   718	              baseArgv: baseArgs,
   719	            });
   720	
   721	            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`
   722	            // containing `<TARGET AUTHORITY preamble>\n\n---\n\n<original>`.
   723	            // Write it to disk so the file Copilot reads via @path opens with
   724	            // the authority block. Without this, recovered/bootstrap folder
   725	            // mentions inside the file could still anchor the model.
   726	            if (built.promptFileBody !== undefined) {
   727	              writeFileSync(promptPath, built.promptFileBody, 'utf8');
   728	            }
   729	
   730	            const result = spawnSync('copilot', built.argv, {
   731	              cwd: '{repo_root}',
   732	              stdio: 'inherit',
   733	              timeout: Number('{config.executor.timeoutSeconds}') * 1000,
   734	            });
   735	            process.exit(result.status ?? 1);
   736	            EOF
   737	          working_directory: "{repo_root}"
   738	          timeout_seconds: "{config.executor.timeoutSeconds}"
   739	          wait_for_completion: true
   740	          notes:
   741	            - "copilot has no stdin support; prompt is positional"
   742	            - "Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt"
   743	            - "Large-prompt path relies on copilot honoring @path references within its prompt string"
   744	            - "buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)"
   745	            - "If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools"
   746	            - "Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference"
