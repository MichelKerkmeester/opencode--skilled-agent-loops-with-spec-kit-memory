    10	{"type":"finding","id":"F2-F3","summary":"cold_p95 fails because benchmark_subprocess starts skill_advisor.py once per prompt, and skill_advisor.py can in turn probe/call a Node native bridge; the batch path amortizes that process cost and passes throughput by a wide margin.","targetFiles":[".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py"],"evidence":[".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:111",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:114",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:174",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:190",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:328",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:342","/tmp/pc005-runs1.json:10","/tmp/pc005-runs1.json:37","/tmp/pc005-runs1.json:41"]}
    11	{"type":"remediation","id":"F2-R1","summary":"Doc fix: update PC-005 to run skill_advisor_bench.py with --dataset .opencode/skills/system-skill-advisor/mcp_server/scripts/fixtures/skill_advisor_regression_cases.jsonl, optionally --runs 1 for manual smoke and --out for captured JSON.","targetFiles":[".opencode/skills/system-skill-advisor/manual_testing_playbook/10--python-compat/005-bench-runner.md"],"evidence":[".opencode/skills/system-skill-advisor/manual_testing_playbook/10--python-compat/004-regression-suite.md:35",".opencode/skills/system-skill-advisor/manual_testing_playbook/10--python-compat/004-regression-suite.md:37",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:245"]}
    12	{"type":"remediation","id":"F2-R2","summary":"Gate fix: align the Python warm default with the documented 50 ms envelope and stop treating one-shot subprocess cold p95 as a 60 ms native-scorer gate; either make cold_p95 advisory/opt-in or raise it to a workstation-calibrated subprocess budget while keeping throughput_multiplier as the main Python-surface regression gate.","targetFiles":[".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py",".opencode/skills/system-skill-advisor/mcp_server/stress_test/skill-advisor/python-bench-runner-stress.vitest.ts",".opencode/skills/system-skill-advisor/feature_catalog/08--python-compat/03-bench-runner.md"],"evidence":[".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:246",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:247",".opencode/skills/system-skill-advisor/mcp_server/stress_test/skill-advisor/python-bench-runner-stress.vitest.ts:93",".opencode/skills/system-skill-advisor/mcp_server/stress_test/skill-advisor/python-bench-runner-stress.vitest.ts:97",".opencode/skills/system-skill-advisor/feature_catalog/08--python-compat/03-bench-runner.md:21"]}

