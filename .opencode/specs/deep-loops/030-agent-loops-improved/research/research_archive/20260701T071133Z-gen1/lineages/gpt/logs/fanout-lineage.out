{"type":"tool_use","timestamp":1782885117937,"sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","part":{"type":"tool","tool":"read","callID":"call_8vjRzlykHvPC7HrbEmkxIxDT","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/spec/check-template-staleness.sh","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/spec/check-template-staleness.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # ───────────────────────────────────────────────────────────────\n3: # COMPONENT: Template Staleness Checker\n4: # ───────────────────────────────────────────────────────────────\n5: # Compares SPECKIT_TEMPLATE_SOURCE version in each spec folder\n6: # against the current template version. Reports stale folders.\n7: #\n8: # Usage:\n9: #   check-template-staleness.sh [--json] [--auto-upgrade] [--root <path>]\n10: #\n11: # Exit codes:\n12: #   0 - all up to date\n13: #   1 - stale folders found\n14: \n15: set -euo pipefail\n16: \n17: SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n18: # shellcheck source=../lib/template-utils.sh\n19: source \"$SCRIPT_DIR/../lib/template-utils.sh\"\n20: \n21: # ───────────────────────────────────────────────────────────────\n22: # 1. CONFIGURATION\n23: # ───────────────────────────────────────────────────────────────\n24: \n25: JSON_MODE=false\n26: AUTO_UPGRADE=false\n27: ROOT_PATH=\"\"\n28: TEMPLATE_DIR=\"\"\n29: \n30: parse_args() {\n31:     while [[ $# -gt 0 ]]; do\n32:         case \"$1\" in\n33:             --json) JSON_MODE=true; shift ;;\n34:             --auto-upgrade) AUTO_UPGRADE=true; shift ;;\n35:             --root) ROOT_PATH=\"$2\"; shift 2 ;;\n36:             --help|-h) show_help; exit 0 ;;\n37:             *) echo \"ERROR: Unknown option '$1'\" >&2; exit 2 ;;\n38:         esac\n39:     done\n40: }\n41: \n42: show_help() {\n43:     cat <<'EOF'\n44: check-template-staleness.sh — Detect spec folders with outdated template versions\n45: \n46: Usage: check-template-staleness.sh [--json] [--auto-upgrade] [--root <path>]\n47: \n48: Options:\n49:   --json           Machine-readable JSON output\n50:   --auto-upgrade   Apply safe auto-fixes to stale folders (update version comment)\n51:   --root           Repository root (default: git root or cwd)\n52:   --help           Show this help\n53: EOF\n54: }\n55: \n56: # ───────────────────────────────────────────────────────────────\n57: # 2. TEMPLATE VERSION DETECTION\n58: # ───────────────────────────────────────────────────────────────\n59: \n60: get_current_template_version() {\n61:     local manifest_path=\"$TEMPLATE_DIR/manifest/spec-kit-docs.json\"\n62:     if [[ ! -f \"$manifest_path\" ]]; then\n63:         echo \"unknown\"\n64:         return\n65:     fi\n66:     local version\n67:     version=$(node -e '\n68: const fs = require(\"fs\");\n69: const manifest = JSON.parse(fs.readFileSync(process.argv[1], \"utf8\"));\n70: process.stdout.write(manifest.versions?.[\"spec.md.tmpl\"] || \"unknown\");\n71: ' \"$manifest_path\" 2>/dev/null || true)\n72:     echo \"${version:-unknown}\"\n73: }\n74: \n75: get_folder_template_version() {\n76:     local folder=\"$1\"\n77:     local spec_file=\"$folder/spec.md\"\n78:     [[ ! -f \"$spec_file\" ]] && { echo \"missing\"; return; }\n79: \n80:     local version\n81:     version=$(head -n 30 \"$spec_file\" | grep \"SPECKIT_TEMPLATE_SOURCE\" | grep -oE 'v[0-9]+\\.[0-9]+' | head -1 || true)\n82:     echo \"${version:-none}\"\n83: }\n84: \n85: # ───────────────────────────────────────────────────────────────\n86: # 3. SPEC FOLDER DISCOVERY\n87: # ───────────────────────────────────────────────────────────────\n88: \n89: discover_spec_folders() {\n90:     local root=\"$1\"\n91:     find \"$root\" -name \"spec.md\" -type f \\\n92:         -not -path \"*/scratch/*\" \\\n93:         -not -path \"*/memory/*\" \\\n94:         -not -path \"*/node_modules/*\" \\\n95:         -not -path \"*/.git/*\" \\\n96:         -not -path \"*/test-fixtures/*\" \\\n97:         -not -path \"*/templates/*\" \\\n98:         2>/dev/null | while IFS= read -r spec_file; do\n99:         dirname \"$spec_file\"\n100:     done | sort -u\n101: }\n102: \n103: # ───────────────────────────────────────────────────────────────\n104: # 4. MAIN\n105: # ───────────────────────────────────────────────────────────────\n106: \n107: main() {\n108:     parse_args \"$@\"\n109: \n110:     if [[ -z \"$ROOT_PATH\" ]]; then\n111:         ROOT_PATH=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"\n112:     fi\n113: \n114:     TEMPLATE_DIR=\"$ROOT_PATH/.opencode/skills/system-spec-kit/templates\"\n115:     if [[ ! -d \"$TEMPLATE_DIR\" ]]; then\n116:         echo \"ERROR: Templates directory not found at $TEMPLATE_DIR\" >&2\n117:         exit 2\n118:     fi\n119: \n120:     local current_version\n121:     current_version=$(get_current_template_version)\n122: \n123:     # Discover and scan folders\n124:     local folders=()\n125:     while IFS= read -r folder; do\n126:         [[ -n \"$folder\" ]] && folders+=(\"$folder\")\n127:     done < <(discover_spec_folders \"$ROOT_PATH\")\n128: \n129:     local total=${#folders[@]}\n130:     local current_count=0 stale_count=0 none_count=0 missing_count=0\n131:     local stale_folders=()\n132:     # Bash 3.2 compatible version tracking (parallel arrays instead of associative)\n133:     local version_keys=()\n134:     local version_vals=()\n135: \n136:     for folder in \"${folders[@]}\"; do\n137:         local folder_name\n138:         folder_name=$(echo \"$folder\" | sed \"s|$ROOT_PATH/||\")\n139:         local version\n140:         version=$(get_folder_template_version \"$folder\")\n141: \n142:         # Track version distribution (Bash 3.2 compatible)\n143:         local found=false\n144:         local idx=0\n145:         for vk in \"${version_keys[@]+\"${version_keys[@]}\"}\"; do\n146:             if [[ \"$vk\" == \"$version\" ]]; then\n147:                 version_vals[$idx]=$(( ${version_vals[$idx]} + 1 ))\n148:                 found=true\n149:                 break\n150:             fi\n151:             ((idx++))\n152:         done\n153:         if ! $found; then\n154:             version_keys+=(\"$version\")\n155:             version_vals+=(1)\n156:         fi\n157: \n158:         case \"$version\" in\n159:             \"$current_version\") ((current_count++)) || true ;;\n160:             \"none\") ((none_count++)) || true; stale_folders+=(\"$folder_name ($version)\") ;;\n161:             \"missing\") ((missing_count++)) || true ;;\n162:             *) ((stale_count++)) || true; stale_folders+=(\"$folder_name ($version)\")\n163: \n164:                if $AUTO_UPGRADE; then\n165:                    for md_file in \"$folder\"/*.md; do\n166:                        [[ ! -f \"$md_file\" ]] && continue\n167:                        local basename_md\n168:                        basename_md=$(basename \"$md_file\")\n169:                        case \"$basename_md\" in\n170:                            spec.md|plan.md|tasks.md|checklist.md|decision-record.md|implementation-summary.md)\n171:                                if head -n 30 \"$md_file\" | grep -q \"SPECKIT_TEMPLATE_SOURCE:\"; then\n172:                                    # Only bump the version portion (vN.N), preserving the template ID\n173:                                    # e.g., \"plan-core | v2.0\" → \"plan-core | v2.2\"\n174:                                    sed -i '' \"s/\\(SPECKIT_TEMPLATE_SOURCE:.*| \\)v[0-9][0-9]*\\.[0-9][0-9]*/\\1$current_version/\" \"$md_file\" 2>/dev/null || true\n175:                                fi\n176:                                ;;\n177:                        esac\n178:                    done\n179:                fi\n180:                ;;\n\n(Showing lines 1-180 of 244. Use offset=181 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# ───────────────────────────────────────────────────────────────\n# COMPONENT: Template Staleness Checker\n# ───────────────────────────────────────────────────────────────\n# Compares SPECKIT_TEMPLATE_SOURCE version in each spec folder\n# against the current template version. Reports stale folders.\n#\n# Usage:\n#   check-template-staleness.sh [--json] [--auto-upgrade] [--root <path>]\n#\n# Exit codes:\n#   0 - all up to date\n#   1 - stale folders found\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=../lib/template-utils.sh\nsource \"$SCRIPT_DIR/../lib/template-utils.sh\"\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/spec/check-template-staleness.sh","text":"#!/usr/bin/env bash\n# ───────────────────────────────────────────────────────────────\n# COMPONENT: Template Staleness Checker\n# ───────────────────────────────────────────────────────────────\n# Compares SPECKIT_TEMPLATE_SOURCE version in each spec folder\n# against the current template version. Reports stale folders.\n#\n# Usage:\n#   check-template-staleness.sh [--json] [--auto-upgrade] [--root <path>]\n#\n# Exit codes:\n#   0 - all up to date\n#   1 - stale folders found\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n# shellcheck source=../lib/template-utils.sh\nsource \"$SCRIPT_DIR/../lib/template-utils.sh\"\n\n# ───────────────────────────────────────────────────────────────\n# 1. CONFIGURATION\n# ───────────────────────────────────────────────────────────────\n\nJSON_MODE=false\nAUTO_UPGRADE=false\nROOT_PATH=\"\"\nTEMPLATE_DIR=\"\"\n\nparse_args() {\n    while [[ $# -gt 0 ]]; do\n        case \"$1\" in\n            --json) JSON_MODE=true; shift ;;\n            --auto-upgrade) AUTO_UPGRADE=true; shift ;;\n            --root) ROOT_PATH=\"$2\"; shift 2 ;;\n            --help|-h) show_help; exit 0 ;;\n            *) echo \"ERROR: Unknown option '$1'\" >&2; exit 2 ;;\n        esac\n    done\n}\n\nshow_help() {\n    cat <<'EOF'\ncheck-template-staleness.sh — Detect spec folders with outdated template versions\n\nUsage: check-template-staleness.sh [--json] [--auto-upgrade] [--root <path>]\n\nOptions:\n  --json           Machine-readable JSON output\n  --auto-upgrade   Apply safe auto-fixes to stale folders (update version comment)\n  --root           Repository root (default: git root or cwd)\n  --help           Show this help\nEOF\n}\n\n# ───────────────────────────────────────────────────────────────\n# 2. TEMPLATE VERSION DETECTION\n# ───────────────────────────────────────────────────────────────\n\nget_current_template_version() {\n    local manifest_path=\"$TEMPLATE_DIR/manifest/spec-kit-docs.json\"\n    if [[ ! -f \"$manifest_path\" ]]; then\n        echo \"unknown\"\n        return\n    fi\n    local version\n    version=$(node -e '\nconst fs = require(\"fs\");\nconst manifest = JSON.parse(fs.readFileSync(process.argv[1], \"utf8\"));\nprocess.stdout.write(manifest.versions?.[\"spec.md.tmpl\"] || \"unknown\");\n' \"$manifest_path\" 2>/dev/null || true)\n    echo \"${version:-unknown}\"\n}\n\nget_folder_template_version() {\n    local folder=\"$1\"\n    local spec_file=\"$folder/spec.md\"\n    [[ ! -f \"$spec_file\" ]] && { echo \"missing\"; return; }\n\n    local version\n    version=$(head -n 30 \"$spec_file\" | grep \"SPECKIT_TEMPLATE_SOURCE\" | grep -oE 'v[0-9]+\\.[0-9]+' | head -1 || true)\n    echo \"${version:-none}\"\n}\n\n# ───────────────────────────────────────────────────────────────\n# 3. SPEC FOLDER DISCOVERY\n# ───────────────────────────────────────────────────────────────\n\ndiscover_spec_folders() {\n    local root=\"$1\"\n    find \"$root\" -name \"spec.md\" -type f \\\n        -not -path \"*/scratch/*\" \\\n        -not -path \"*/memory/*\" \\\n        -not -path \"*/node_modules/*\" \\\n        -not -path \"*/.git/*\" \\\n        -not -path \"*/test-fixtures/*\" \\\n        -not -path \"*/templates/*\" \\\n        2>/dev/null | while IFS= read -r spec_file; do\n        dirname \"$spec_file\"\n    done | sort -u\n}\n\n# ───────────────────────────────────────────────────────────────\n# 4. MAIN\n# ───────────────────────────────────────────────────────────────\n\nmain() {\n    parse_args \"$@\"\n\n    if [[ -z \"$ROOT_PATH\" ]]; then\n        ROOT_PATH=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"\n    fi\n\n    TEMPLATE_DIR=\"$ROOT_PATH/.opencode/skills/system-spec-kit/templates\"\n    if [[ ! -d \"$TEMPLATE_DIR\" ]]; then\n        echo \"ERROR: Templates directory not found at $TEMPLATE_DIR\" >&2\n        exit 2\n    fi\n\n    local current_version\n    current_version=$(get_current_template_version)\n\n    # Discover and scan folders\n    local folders=()\n    while IFS= read -r folder; do\n        [[ -n \"$folder\" ]] && folders+=(\"$folder\")\n    done < <(discover_spec_folders \"$ROOT_PATH\")\n\n    local total=${#folders[@]}\n    local current_count=0 stale_count=0 none_count=0 missing_count=0\n    local stale_folders=()\n    # Bash 3.2 compatible version tracking (parallel arrays instead of associative)\n    local version_keys=()\n    local version_vals=()\n\n    for folder in \"${folders[@]}\"; do\n        local folder_name\n        folder_name=$(echo \"$folder\" | sed \"s|$ROOT_PATH/||\")\n        local version\n        version=$(get_folder_template_version \"$folder\")\n\n        # Track version distribution (Bash 3.2 compatible)\n        local found=false\n        local idx=0\n        for vk in \"${version_keys[@]+\"${version_keys[@]}\"}\"; do\n            if [[ \"$vk\" == \"$version\" ]]; then\n                version_vals[$idx]=$(( ${version_vals[$idx]} + 1 ))\n                found=true\n                break\n            fi\n            ((idx++))\n        done\n        if ! $found; then\n            version_keys+=(\"$version\")\n            version_vals+=(1)\n        fi\n\n        case \"$version\" in\n            \"$current_version\") ((current_count++)) || true ;;\n            \"none\") ((none_count++)) || true; stale_folders+=(\"$folder_name ($version)\") ;;\n            \"missing\") ((missing_count++)) || true ;;\n            *) ((stale_count++)) || true; stale_folders+=(\"$folder_name ($version)\")\n\n               if $AUTO_UPGRADE; then\n                   for md_file in \"$folder\"/*.md; do\n                       [[ ! -f \"$md_file\" ]] && continue\n                       local basename_md\n                       basename_md=$(basename \"$md_file\")\n                       case \"$basename_md\" in\n                           spec.md|plan.md|tasks.md|checklist.md|decision-record.md|implementation-summary.md)\n                               if head -n 30 \"$md_file\" | grep -q \"SPECKIT_TEMPLATE_SOURCE:\"; then\n                                   # Only bump the version portion (vN.N), preserving the template ID\n                                   # e.g., \"plan-core | v2.0\" → \"plan-core | v2.2\"\n                                   sed -i '' \"s/\\(SPECKIT_TEMPLATE_SOURCE:.*| \\)v[0-9][0-9]*\\.[0-9][0-9]*/\\1$current_version/\" \"$md_file\" 2>/dev/null || true\n                               fi\n                               ;;\n                       esac\n                   done\n               fi\n               ;;","lineStart":1,"lineEnd":180,"totalLines":244,"truncated":true}},"title":".opencode/skills/system-spec-kit/scripts/spec/check-template-staleness.sh","time":{"start":1782885117931,"end":1782885117935}},"metadata":{"openai":{"itemId":"fc_01f47f337d3a96f6016a44aafde1408191a733b307600f395f"}},"id":"prt_f1c3befe8001VBDz8sqqezIwZ5","sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","messageID":"msg_f1c3bc0fc001M0Vpbh0G2h5mqP"}}
