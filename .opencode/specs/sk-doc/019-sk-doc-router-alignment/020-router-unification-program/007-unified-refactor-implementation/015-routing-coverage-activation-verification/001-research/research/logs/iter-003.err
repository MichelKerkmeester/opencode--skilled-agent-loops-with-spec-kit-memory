   150	 * descriptions, stdout/stderr, and prompt text, and emits nothing when the
   151	 * repository-authored skill label looks instruction-shaped after folding.
   152	 */
   153	export function renderAdvisorBrief(
   154	  result: AdvisorBriefRenderableResult,
   155	  options: AdvisorBriefRenderOptions = {},
   156	): string | null {
   157	  if (result.status !== 'ok') {
   158	    return null;
   159	  }
   160	  if (result.freshness !== 'live' && result.freshness !== 'stale') {
   161	    return null;
   162	  }
   163	
   164	  const tokenCap = clampTokenCap(result.metrics?.tokenCap ?? options.tokenCap);
   165	  const thresholdConfig = options.thresholdConfig;
   166	  const recommendations = result.recommendations.filter((recommendation) => (
   167	    recommendation.passes_threshold === true
   168	    || (
   169	      recommendation.confidence >= (thresholdConfig?.confidenceThreshold ?? resolvedConfidenceThreshold())
   170	      && (
   171	        thresholdConfig?.confidenceOnly === true
   172	        || recommendation.uncertainty <= (thresholdConfig?.uncertaintyThreshold ?? resolvedUncertaintyThreshold())
   173	      )
   174	    )
   175	  ));
   176	  const [top, second] = recommendations;
   177	  if (!top) {
   178	    return null;
   179	  }
   180	
   181	  const topLabel = sanitizeSkillLabel(metadataSkillLabel(result) ?? top.skill);
   182	  if (!topLabel) {
   183	    return null;
   184	  }
   185	
   186	  if (tokenCap > DEFAULT_TOKEN_CAP && second && hasAdvisorAmbiguitySignal(recommendations, result.ambiguous === true)) {
   187	    const secondLabel = sanitizeSkillLabel(second.skill);
   188	    if (!secondLabel) {
   189	      return null;
   190	    }
   191	    return capText(
   192	      `Advisor: ${result.freshness}; ambiguous: ${topLabel} ${formatScore(top.confidence)}/${formatScore(top.uncertainty)} vs ${secondLabel} ${formatScore(second.confidence)}/${formatScore(second.uncertainty)} pass.${HYGIENE_DIRECTIVE}`,
   193	      Math.min(tokenCap, AMBIGUOUS_TOKEN_CAP),
   194	    ) + GOVERNOR_DIRECTIVE;
   195	  }
   196	
   197	  return capText(
   198	    `Advisor: ${result.freshness}; use ${topLabel} ${formatScore(top.confidence)}/${formatScore(top.uncertainty)} pass.${HYGIENE_DIRECTIVE}`,
   199	    Math.min(tokenCap, DEFAULT_TOKEN_CAP),
   200	  ) + GOVERNOR_DIRECTIVE;
   201	}
   202	
   203	/** Render the constitutional context retained when no advisor brief is available. */
   204	export function renderAdvisorFallbackDirective(): string {
   205	  return HYGIENE_DIRECTIVE.slice(1) + GOVERNOR_DIRECTIVE;
   206	}
   207	
   208	// Shared timeout-fallback renderer. Previously the OpenCode hook
   209	// emitted a bespoke `Advisor: stale (cold-start timeout)\nFallback marker: ...`
   210	// string inline. Centralizing the format here keeps every runtime that needs
   211	// a cold-start timeout fallback aligned on a single contract — `renderAdvisorBrief`
   212	// itself returns null when there are no recommendations, which is correct for
   213	// the live-result path; this function is the explicit fallback companion.
   214	export function renderAdvisorTimeoutFallback(): string {
   215	  return [
   216	    'Advisor: stale (cold-start timeout)',
   217	    'Fallback marker: {"stale":true,"reason":"timeout-fallback"}',
   218	  ].join('\n');
   219	}
   220	
   221	export { sanitizeSkillLabel };

