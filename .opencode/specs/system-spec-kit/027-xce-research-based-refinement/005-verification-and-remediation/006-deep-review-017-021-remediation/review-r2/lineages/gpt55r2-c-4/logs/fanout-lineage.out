n3615:           saveScope.agentId ?? null, saveScope.agentId ?? null,\n3616:           saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n3617:         ) as { id: number; content_hash: string } | undefined;\n3618: \n3619:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n3620:         if (\n3621:           activeRow\n3622:           && activeRow.content_hash === lookup.key.contentHash\n3623:           && (replayMemoryId == null || activeRow.id === replayMemoryId)\n3624:         ) {\n3625:           return lookup.response;\n3626:         }\n3627:         // Stale receipt for this attempt: drop the cache entry so the\n3628:         // re-indexed write stores its current response (the post-write store\n3629:         // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n3630:         // the stale receipt), then fall through to the normal save/reindex path.\n3631:         deleteIdempotencyReceiptByKey(database, lookup.key);\n3632:       } else if (lookup.status === 'conflict') {\n3633:         // Unreachable from this caller: payload === requestFingerprint (above),\n3634:         // so a key match implies a payload match and lookup never returns\n3635:         // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n3636:         // material and payload ever diverge.\n3637:         return createMCPErrorResponse({\n3638:           tool: 'memory_save',\n3639:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n\n(Showing lines 3280-3639 of 4082. Use offset=3640 to continue.)\n</content>","metadata":{"preview":"    parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n    preflightValidation: {\n      skipped: boolean;\n      errors: preflight.PreflightIssue[];\n      warnings: preflight.PreflightResult['warnings'];\n      details: Record<string, unknown>;\n      wouldPass: boolean;\n    },\n  ) {\n    const templateContractPass = preparedDryRun.templateContract.val