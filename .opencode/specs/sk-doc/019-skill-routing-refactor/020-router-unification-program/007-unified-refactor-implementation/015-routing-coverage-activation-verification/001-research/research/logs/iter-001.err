     1	#!/usr/bin/env node
     2	'use strict';
     3	
     4	// Runtime front door for compiled routing.
     5	//
     6	// A hub whose SKILL.md carries the compiled-routing directive calls this to ask
     7	// whether the compiled router contract is authoritative for a prompt. It stays a
     8	// thin delegate to the single-sourced resolver in the activation spec tree, so
     9	// the compiled contract is never duplicated. Prints the compiled decision when
    10	// the hub is compiled-serving and SPECKIT_COMPILED_ROUTING=1; otherwise a legacy
    11	// sentinel so the caller falls back to the prose smart-router. Never throws into
    12	// a routing path — any failure resolves to the legacy sentinel.
    13	
    14	const path = require('path');
    15	
    16	const RESOLVER = path.resolve(
    17	  __dirname,
    18	  '..',
    19	  'specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program',
    20	  '007-unified-refactor-implementation/011-runtime-engine/lib/resolve.cjs',
    21	);
    22	
    23	function main() {
    24	  const args = process.argv.slice(2);
    25	  const hub = args[args.indexOf('--hub') + 1];
    26	  const promptIdx = args.indexOf('--prompt');
    27	  const prompt = promptIdx >= 0 ? args[promptIdx + 1] : '';
    28	  if (!hub) {
    29	    process.stderr.write('usage: compiled-route.cjs --hub <hubId> --prompt <text>\n');
    30	    process.exit(2);
    31	  }
    32	  let route = null;
    33	  try {
    34	    const { resolveRoute } = require(RESOLVER);
    35	    route = resolveRoute(hub, prompt);
    36	  } catch {
    37	    route = null;
    38	  }
    39	  process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\n`);
    40	}
    41	
    42	main();
   300	    : undefined;
   301	  const workflowMode = workflowModeForRecommendation(recommendation, prompt);
   302	  return {
   303	    skillId,
   304	    score: recommendation.score,
   305	    confidence: recommendation.confidence,
   306	    uncertainty: recommendation.uncertainty,
   307	    dominantLane: recommendation.dominantLane,
   308	    ...(includeAttribution ? {
   309	      laneBreakdown: recommendation.laneContributions.map((lane) => ({
   310	        lane: lane.lane,
   311	        rawScore: lane.rawScore,
   312	        weightedScore: lane.weightedScore,
   313	        weight: lane.weight,
   314	        shadowOnly: lane.shadowOnly,
   315	      })),
   316	      why_recommended: publicWhyRecommended(recommendation),
   317	    } : {}),
   318	    ...(matchedDocs.length > 0 ? { matchedDocs } : {}),
   319	    ...(redirectFrom.length > 0 ? { redirectFrom } : {}),
   320	    ...(redirectTo ? { redirectTo } : {}),
   321	    ...(status ? { status } : {}),
   322	    ...(workflowMode ? { workflowMode } : {}),
   323	  };
   324	}
   325	
   326	function compiledRouteForRecommendation(
   327	  skillId: string,
   328	  prompt: string,
   329	  workspaceRoot: string,
   330	): Record<string, unknown> | undefined {
   331	  if (!COMPILED_ROUTING_HUBS.has(skillId)) return undefined;
   332	  try {
   333	    const output = execFileSync(process.execPath, [
   334	      resolve(workspaceRoot, '.opencode', 'bin', 'compiled-route.cjs'),
   335	      '--hub',
   336	      skillId,
   337	      '--prompt',
   338	      prompt,
   339	    ], {
   340	      cwd: workspaceRoot,
   341	      encoding: 'utf8',
   342	      stdio: ['ignore', 'pipe', 'ignore'],
   343	      timeout: 5_000,
   344	      maxBuffer: 1_048_576,
   345	    });
   346	    const parsed: unknown = JSON.parse(output.trim());
   347	    if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {
   348	      return undefined;
   349	    }
   350	    const compiledRoute = parsed as Record<string, unknown>;
   351	    return compiledRoute.servingAuthority === 'legacy' ? undefined : compiledRoute;
   352	  } catch {
   353	    return undefined;
   354	  }
   355	}
   356	
   357	function enrichCompiledRoutes(
   358	  output: AdvisorRecommendOutput,
   359	  prompt: string,
   360	  workspaceRoot: string,
   361	): AdvisorRecommendOutput {
   362	  if (process.env.SPECKIT_COMPILED_ROUTING !== '1') return output;
   363	  return AdvisorRecommendOutputSchema.parse({
   364	    ...output,
   365	    recommendations: output.recommendations.map((recommendation) => {
   366	      const compiledRoute = compiledRouteForRecommendation(
   367	        recommendation.skillId,
   368	        prompt,
   369	        workspaceRoot,
   370	      );
   371	      return compiledRoute ? { ...recommendation, compiledRoute } : recommendation;
   372	    }),
   373	  });
   374	}
   375	
   376	function publicShadowRecommendations(recommendations: readonly ScoredRecommendation[], topK: number): ShadowRecommendation[] {
   377	  const shadowRecommendations: ShadowRecommendation[] = [];
   378	  for (const recommendation of recommendations) {
   379	    const skillId = sanitizeSkillLabel(recommendation.skill);
   380	    if (!skillId) continue;
   381	    const shadowContributions = recommendation.laneContributions.map((lane) => ({
   382	      lane: lane.lane,
   383	      weightedScore: lane.rawScore * DEFAULT_SHADOW_SCORER_LANE_WEIGHTS[lane.lane],
   384	    }));
   385	    const shadowScore = roundScore(shadowContributions.reduce((total, lane) => total + lane.weightedScore, 0));
   386	    const dominant = shadowContributions
   387	      .filter((lane) => lane.weightedScore > 0)
   388	      .sort((left, right) => right.weightedScore - left.weightedScore)[0]?.lane ?? null;
   389	    shadowRecommendations.push({
   390	        skillId,
   391	        liveScore: recommendation.score,
   392	        shadowScore,
   393	        delta: roundScore(shadowScore - recommendation.score),
   394	        dominantShadowLane: dominant,
   395	    });
   396	  }
   397	  return shadowRecommendations
   398	    .sort((left, right) => right.shadowScore - left.shadowScore || left.skillId.localeCompare(right.skillId))
   399	    .slice(0, topK);
   400	}
   401	
   402	function roundScore(value: number): number {
   403	  return Math.round(value * 1_000_000) / 1_000_000;
   404	}
   405	
   406	function outputWarnings(
   407	  status: AdvisorStatus,
   408	  result: ReturnType<typeof scoreAdvisorPrompt>,
   409	): string[] {
   410	  const degradedLanes = result.metrics.degradedLanes ?? [];

