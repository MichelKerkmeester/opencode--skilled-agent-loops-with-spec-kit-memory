d\": \"CS-001\",\n129:       \"leaks\": [\n130:         \"cdn\",\n131:         \"animation\",\n132:         \"webflow\",\n133:         \"javascript\"\n134:       ]\n135:     },\n136:     {\n137:       \"scenarioId\": \"CS-002\",\n138:       \"leaks\": [\n139:         \"sk-code\",\n140:         \"motion.dev\",\n141:         \"references\",\n142:         \"webflow\",\n143:         \"snippets\"\n144:       ]\n145:     },\n146:     {\n147:       \"scenarioId\": \"CS-003\",\n148:       \"leaks\": [\n149:         \"sk-code\",\n150:         \".ts\",\n151:         \"opencode\",\n152:         \"scripts\"\n153:       ]\n154:     },\n\n(Showing lines 65-154 of 1010. Use offset=155 to continue.)\n</content>","metadata":{"preview":"  \"coverage\": {\n    \"routing\": 15,\n    \"advisor\": 2,\n    \"browser\": 7,\n    \"routedOut\": 7,\n    \"scored\": 17\n  },\n  \"divergence\": [],\n  \"lintFindings\": [\n    {\n      \"scenarioId\": \"SD-001\",\n      \"leaks\": [\n        \"lenis\",\n        \"javascript\"\n      ]\n    },\n    {\n      \"scenarioId\": \"SD-002\",\n      \"leaks\": [\n        \"typescript\",","truncated":true,"loaded":[]},"title":".opencode/skills/sk-code/benchmark/router-final/skill-benchmark-report.json","time":{"start":1780372896881,"end":1780372896903}},"metadata":{"openai":{"itemId":"fc_0b91e6a34f951fa7016a1e55a0c6f881919bda7c63e01f905f"}},"id":"prt_e867e7c6f001Nw5xRXOia39kzr","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867e5478001iXymuwFIE4RAhB"}}
