=> row.event === 'synthesis_complete')) throw new Error('missing synthesis_complete event');\nfor (let i = 1; i <= 5; i += 1) {\n  const delta = fs.readFileSync(path.join(dir, `deltas/iter-${String(i).padStart(3, '0')}.jsonl`), 'utf8').trim().split(/\\n/).map((line) => JSON.parse(line));\n  if (!delta.some((row) => row.type === 'iteration' && row.run === i)) throw new Error(`delta ${i} missing iteration record`);\n}\nif (fs.existsSync(path.join(dir, '.deep-research.lock'))) throw new Error('lock file still exists');\nconsole.log('lineage artifact verification passed');\nEOF","timeout":120000,"workdir":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"lineage artifact verification passed\n","metadata":{"output":"lineage artifact verification passed\n","exit":0,"truncated":false},"title":"node <<'EOF'\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst dir = '.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-9';\nconst required = [\n  'deep-research-config.json',\n  'deep-research-state.jsonl',\n  'deep-research-strategy.md',\n  'deep-research-findings-registry.json',\n  'deep-research-dashboard.md',\n  'research.md',\n  'resource-map.md',\n  'iterations/iteration-001.md',\n  'iterations/iteration-002.md',\n  'iterations/iteration-003.md',\n  'iterations/iteration-004.md',\n  'iterations/iteration-005.md',\n  'deltas/iter-001.jsonl',\n  'deltas/iter-002.jsonl',\n  'deltas/iter-003.jsonl',\n  'deltas/iter-004.jsonl',\n  'deltas/iter-005.jsonl',\n];\nfor (const rel of required) {\n  const file = path.join(dir, rel);\n  if (!fs.existsSync(file)) throw new Error(`missing ${rel}`);\n  if (fs.statSync(file).isFile() && fs.statSync(file).size === 0) throw new Error(`empty ${rel}`);\n}\nconst config = JSON.parse(fs.readFileSync(path.join(dir, 'deep-research-config.json'), 'utf8'));\nif (config.status !== 'complete') throw new Error('config not complete');\nconst re