xplicit\n","exit":0,"description":"Get HEAD version of loop-host.cjs","truncated":false},"title":"Get HEAD version of loop-host.cjs","time":{"start":1780204751890,"end":1780204751893}},"id":"prt_e7c78c86f001OGsiwtxtgYEfCW","sessionID":"ses_18387935effekFkBvij8gBl0qD","messageID":"msg_e7c7891290018cDIBO5Ji4RSrf"}}
