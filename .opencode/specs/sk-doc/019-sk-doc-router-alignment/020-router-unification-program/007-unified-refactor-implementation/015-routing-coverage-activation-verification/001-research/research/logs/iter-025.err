    12	<!-- SPECKIT_LEVEL: 2 -->
    13	<!--
    14	SELF-CHECK:
    15	- Confirm the artifact states the current problem, intended outcome, scope, and verification evidence.
    16	- Remove placeholders, stale status, and claims that are not backed by a check.
