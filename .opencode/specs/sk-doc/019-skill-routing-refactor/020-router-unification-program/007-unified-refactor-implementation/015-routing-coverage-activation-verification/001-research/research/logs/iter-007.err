     1	#!/usr/bin/env node
     2	'use strict';
     3	
     4	// ─────────────────────────────────────────────────────────────────
     5	// check-markdown-links.cjs — markdown-link integrity guard
     6	// ─────────────────────────────────────────────────────────────────
     7	// Complements check-links.sh (which validates wikilinks `[[...]]`): this walks the
     8	// active skills/commands/agents docs and verifies every relative markdown link `](path)`
     9	// (and `[id]: path` ref-def) resolves on disk. It exists because feature removal/migration
    10	// edits have deleted snippet files or moved targets without updating the hand-maintained
    11	// catalog/playbook roots that link to them — breakage that nothing else catches. Whole-repo
    12	// (not changed-files) on purpose: a deleted target breaks UNCHANGED referrers.
    13	//
    14	// Conventions: a relative link is valid if it resolves against EITHER the source file's
    15	// directory OR the repo root. Fenced code blocks, anchors, http(s), and template-variable
    16	// refs are not links. A narrow (file,ref) allowlist below covers the intentional template
    17	// fill-in placeholders + one illustrative example so the guard is green today and only fires
    18	// on NEW breakage — it deliberately does NOT skip whole template directories.
    19	//
    20	// Exit: 0 = clean ("0 broken"); 1 = one or more real broken links (listed).
    21	const fs = require('fs');
    22	const path = require('path');
    23	
    24	const ROOTS = [
    25	  '.opencode/skills', '.opencode/commands', '.opencode/agents',
    26	  '.claude/agents', '.claude/commands', '.opencode/agents', '.opencode/commands',
    27	];
    28	
    29	// Files in these path segments are not link-checked: archives/runtime dumps (broken links
    30	// there are expected), changelogs (links were correct at write-time; history is frozen),
    31	// and test fixtures (some are deliberately broken to exercise validators).
    32	const EXCLUDE_SEGMENTS = [
    33	  'node_modules', 'z_archive', 'z-future', '.worktrees', '_archive', 'review-archive',
    34	  '/research/', '/deltas/', '/prompts/', '/iterations/', '/changelog/', '/tests/fixtures/',
    35	];
    36	
    37	// Intentional broken links: template fill-in placeholders the author replaces when copying
    38	// the template, plus one illustrative example path. Keyed by "<sourceFile>::<rawRef>".
    39	// Adding a genuinely-new broken link still fails — these specific pairs are the only waivers.
    40	const ALLOWLIST = new Set([
    41	  // benchmark report template — sibling artifacts the report author creates
    42	  '.opencode/skills/sk-doc/create-benchmark/assets/shared/benchmark-report-template.md::./SOURCE.md',
    43	  '.opencode/skills/sk-doc/create-benchmark/assets/shared/benchmark-report-template.md::./results.csv',
    44	  '.opencode/skills/sk-doc/create-benchmark/assets/shared/benchmark-report-template.md::./per-probe.jsonl',
    45	  '.opencode/skills/sk-doc/create-benchmark/assets/shared/benchmark-report-template.md::./runtime-measurements.md',
    46	  '.opencode/skills/sk-doc/create-benchmark/assets/shared/benchmark-report-template.md::../README.md',
    47	  // skill_md_template — fill-in names the author replaces per skill
    48	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-md-template.md::./references/workflow-details.md',
    49	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-md-template.md::./references/reference-name.md',
    50	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-md-template.md::./references/workflow-name.md',
    51	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-md-template.md::./assets/template-name.md',
    52	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-md-template.md::./assets/checklist-name.md',
    53	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-md-template.md::INSTALL-GUIDE.md',
    54	  // skill_reference_template — use-site example paths
    55	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-reference-template.md::./scripts/workflow_router.py',
    56	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-reference-template.md::../scripts/',
    57	  '.opencode/skills/sk-doc/create-skill/assets/skill/skill-reference-template.md::../assets/',
    58	  // illustrative client-domain example path
    59	  '.opencode/skills/sk-code/code-webflow/references/performance/webflow-constraints.md::/specs/005-example.com/024-performance-optimization/decision-record.md',
    60	]);
    61	
    62	function excluded(p) { return EXCLUDE_SEGMENTS.some((seg) => p.includes(seg)); }
    63	
    64	function walk(dir, out) {
    65	  let entries;
    66	  try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return; }
    67	  for (const e of entries) {
    68	    const p = path.join(dir, e.name);
    69	    if (excluded(p)) continue;
    70	    if (e.isDirectory()) walk(p, out);
    71	    else if (e.isFile() && p.endsWith('.md')) out.push(p);
    72	  }
    73	}
    74	
    75	// Blank out inline code spans so link/ref syntax DOCUMENTED inside backticks (prose showing
    76	// the bracket-paren link form) is not mistaken for a real link. Mirrors the fenced-block strip:
    77	// per CommonMark, code spans are literal text, not link surface. Guard-safe by construction —
    78	// it strips a span only when an opening backtick run is closed by a run of the SAME length,
    79	// treats a backslash-escaped backtick as literal (never a delimiter), and leaves unmatched runs
    80	// untouched. So the worst case is a documented placeholder staying checkable (a false positive
    81	// the ALLOWLIST handles), never a hidden real link (a false negative — the dangerous direction
    82	// for a guard). Blanks rather than deletes, preserving offsets/newlines so refDefRe's `^\s*`
    83	// cannot promote a stripped line into a phantom reference definition.
    84	function stripInlineCode(content) {
    85	  let out = '';
    86	  for (let i = 0; i < content.length; ) {
    87	    const ch = content[i];
    88	    if (ch === '\\' && i + 1 < content.length) { out += ch + content[i + 1]; i += 2; continue; }
    89	    if (ch !== '`') { out += ch; i++; continue; }
    90	    const open = i;
    91	    while (i < content.length && content[i] === '`') i++;
    92	    const runLen = i - open;
    93	    let close = -1;
    94	    for (let j = i; j < content.length; ) {
    95	      if (content[j] !== '`') { j++; continue; }
    96	      const r = j;
    97	      while (j < content.length && content[j] === '`') j++;
    98	      if (j - r === runLen) { close = r; break; }
    99	    }
   100	    if (close === -1) { out += content.slice(open, i); continue; }     // unmatched run: not a span
   101	    const end = close + runLen;
   102	    out += content.slice(open, end).replace(/[^\n]/g, ' ');            // blank the span, keep newlines
   103	    i = end;
   104	  }
   105	  return out;
   106	}
   107	
   108	function extractRefs(content) {
   109	  const refs = [];
   110	  content = content.replace(/```[\s\S]*?```/g, '\n'); // fenced code is not links
   111	  content = stripInlineCode(content);                 // inline code is not links either
   112	  const linkRe = /\]\(\s*([^)\s]+?)\s*(?:\s+"[^"]*")?\)/g;
   113	  let m;
   114	  while ((m = linkRe.exec(content)) !== null) refs.push(m[1]);
   115	  const refDefRe = /^\s*\[[^\]]+\]:\s+(\S+)\s*$/gm;
   116	  while ((m = refDefRe.exec(content)) !== null) refs.push(m[1]);
   117	  return refs;
   118	}
   119	
   120	function checkable(raw) {
   121	  if (!raw) return false;
   122	  if (/^[a-z]+:/i.test(raw)) return false;                 // http:, mailto:, etc.
   123	  if (raw.startsWith('#')) return false;                    // pure anchor
   124	  if (/[<>{}*$]/.test(raw)) return false;                  // autolink / placeholder / glob / var
   125	  return true;
   126	}
   127	
   128	function resolves(file, raw) {
   129	  let t = raw.split('#')[0].split('?')[0].trim();
   130	  if (!t) return true;                                      // anchor on this file
   131	  try { t = decodeURIComponent(t); } catch { /* malformed % */ }
   132	  t = t.replace(/\/+$/, '');
   133	  if (!t) return true;
   134	  const cands = t.startsWith('/')
   135	    ? [path.join('.', t)]
   136	    : [path.join(path.dirname(file), t), path.join('.', t)];
   137	  return cands.some((c) => { try { return fs.existsSync(c); } catch { return false; } });
   138	}
   139	
   140	// `--self-test`: assert inline-code handling on synthetic inputs (no filesystem walk). A guard's
   141	// dangerous failure is a FALSE NEGATIVE (hiding a real broken link), so the same-line and
   142	// escaped-backtick cases below are the ones that MUST stay caught.
   143	function runSelfTest() {
   144	  const T = 'missing.md';
   145	  const targets = (s) => extractRefs(s).filter(checkable);
   146	  const eq = (a, b) => JSON.stringify(a) === JSON.stringify(b);
   147	  const cases = [
   148	    { name: 'inline-code link ignored',                      input: 'Literal `[bad](missing.md)` syntax.',                  expect: [] },
   149	    { name: 'real link on same line as inline code caught',  input: 'Pre `[x](missing.md)` then [bad](missing.md).',         expect: [T] },
   150	    { name: 'ref-style def inside inline code ignored',       input: '`[bad]: missing.md`',                                   expect: [] },
   151	    { name: 'escaped backticks do NOT hide a real link',     input: '\\`[bad](missing.md)\\`',                               expect: [T] },
   152	    { name: 'variable-length delimiter strips whole span',   input: '``Use `[x](missing.md)` with `tick` inside``',          expect: [] },
   153	    { name: 'plain broken link still caught (control)',      input: 'See [bad](missing.md) here.',                           expect: [T] },
   154	  ];
   155	  let failed = 0;
   156	  for (const c of cases) {
   157	    const got = targets(c.input);
   158	    const ok = eq(got, c.expect);
   159	    if (!ok) failed++;
   160	    console.log(`${ok ? 'PASS' : 'FAIL'}  ${c.name}  → [${got.join(', ')}] (expect [${c.expect.join(', ')}])`);
   161	  }
   162	  console.log(failed ? `\nself-test: ${failed} case(s) FAILED` : '\nself-test: all cases passed');
   163	  process.exit(failed ? 1 : 0);
   164	}
   165	
   166	if (process.argv.includes('--self-test')) runSelfTest();
   167	
   168	const files = [];
   169	for (const root of ROOTS) if (fs.existsSync(root)) walk(root, files);
   170	
   171	const broken = [];
   172	let checked = 0;
   173	for (const file of files) {
   174	  let content;
   175	  try { content = fs.readFileSync(file, 'utf8'); } catch { continue; }
   176	  for (const raw of extractRefs(content)) {
   177	    if (!checkable(raw)) continue;
   178	    checked++;
   179	    if (resolves(file, raw)) continue;
   180	    if (ALLOWLIST.has(file + '::' + raw)) continue;        // intentional placeholder/example
   181	    broken.push({ file, raw });
   182	  }
   183	}
   184	
   185	console.log(`check-markdown-links: ${files.length} files, ${checked} links checked, ${broken.length} broken`);
   186	if (broken.length) {
   187	  console.error('\nBroken markdown links (target resolves under neither the file dir nor repo root):');
   188	  for (const b of broken) console.error(`  ${b.file}  ](${b.raw})`);
   189	  console.error('\nFix the link, or — if it is an intentional placeholder/example — add it to the ALLOWLIST in this script.');
   190	  process.exit(1);
   191	}
   192	console.log('OK — 0 broken markdown links.');
   193	process.exit(0);

