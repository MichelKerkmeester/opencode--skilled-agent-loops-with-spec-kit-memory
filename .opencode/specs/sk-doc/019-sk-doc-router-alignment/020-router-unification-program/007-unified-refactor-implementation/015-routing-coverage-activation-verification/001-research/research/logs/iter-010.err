.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-001.md:27:  {"id":"F-1-1","area":"catalogs","finding":"The sk-design hub catalog needs a dedicated compiled-routing entry because it already owns the hub's manager-shell routing inventory.","evidence":".opencode/skills/sk-design/feature-catalog/feature-catalog.md:15","severity":"P1","actionable":"Add a MANAGER SHELL root entry and a template-authored manager-shell/compiled-routing-and-legacy-fallback.md leaf.","novelty":"new"},
