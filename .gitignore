.opencode/skills/system-spec-kit/mcp_server/lib/**/*.js.map
.opencode/skills/system-spec-kit/mcp_server/lib/**/*.d.ts
.opencode/skills/system-spec-kit/mcp_server/lib/**/*.d.ts.map
