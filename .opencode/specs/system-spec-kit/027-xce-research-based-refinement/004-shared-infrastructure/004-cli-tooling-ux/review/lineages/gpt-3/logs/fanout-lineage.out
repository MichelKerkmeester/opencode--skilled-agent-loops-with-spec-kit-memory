r === true,\n662:   };\n663: }\n664: \n665: function renderPayload(payload: unknown, format: OutputFormat): string {\n666:   if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n667:   if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n668:     const record = payload as Record<string, unknown>;\n669:     if (typeof record.summary === 'string') return record.summary;\n670:     if (typeof record.error === 'string') return record.error;\n671:     if (typeof record.message === 'string') return record.message;\n672:   }\n673:   return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n674: }\n675: \n676: function isProtocolMismatch(error: unknown): boolean {\n677:   if (error instanceof JsonRpcError && error.code === -32002) return true;\n678:   const message = error instanceof Error ? error.message : String(error);\n679:   return /protocol.*(mismatch|changed|version)/i.test(message);\n680: }\n681: \n682: function isRetryableError(error: unknown): boolean {\n683:   if (error instanceof CliRetryableError) return true;\n684:   if (error instanceof JsonRpcError && error.code === -32001) return true;\n685:   const message = error instanceof Error ? error.message : String(error);\n686:   return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n687: }\n688: \n689: function exitCodeForError(error: unknown): number {\n690:   if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n691:   if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n692:   if (isRetryableError(error)) return EXIT_RETRYABLE;\n693:   if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n694:   return EXIT_RUNTIME;\n695: }\n696: \n697: function levenshteinDistance(left: string, right: string): number {\n698:   const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n699:   const current = new Array<number>(right.length + 1);\n700: \n701:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n702:     current[0] = leftIndex;\n703:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n704:       const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n705:       current[rightIndex] = Math.min(\n706:         current[rightIndex - 1] + 1,\n707:         previous[rightIndex] + 1,\n708:         previous[rightIndex - 1] + cost,\n709:       );\n710:     }\n711:     previous.splice(0, previous.length, ...current);\n712:   }\n713: \n714:   return previous[right.length];\n715: }\n716: \n717: function closestCommand(command: string): string | undefined {\n718:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n719:   targets.set('completion', 'completion');\n720:   for (const tool of TOOL_DEFINITIONS) {\n721:     for (const alias of commandAliases(tool.name)) {\n722:       targets.set(alias, tool.name);\n723:     }\n724:   }\n725: \n726:   let best: { readonly command: string; readonly distance: number } | null = null;\n727:   for (const [alias, canonical] of targets) {\n728:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n729:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n730:       best = { command: canonical, distance };\n731:     }\n732:   }\n733: \n734:   if (!best) return undefined;\n735:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n736:   return best.distance <= threshold ? best.command : undefined;\n737: }\n738: \n739: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n740:   const match = message.match(/^Unknown command: (.+)$/);\n741:   if (!match) return null;\n742:   return {\n743:     hint: 'Try `list-tools` to see available commands.',\n744:     suggestion: closestCommand(match[1]),\n745:   };\n746: }\n747: \n748: function socketPathTooLong(socketPath: string): boolean {\n749:   if (socketPath.startsWith('tcp://')) return false;\n750:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n751: }\n752: \n753: function ensureSocketEnvironment(): void {\n754:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n755:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n756:   }\n757:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n758:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n759:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n760:   const stat = statSync(socketDir);\n761:   if ((stat.mode & 0o022) !== 0) {\n762:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n763:   }\n764: }\n765: \n766: function sleep(ms: number): Promise<void> {\n767:   return new Promise((resolve) => setTimeout(resolve, ms));\n768: }\n769: \n770: function spawnLauncher(paths: RepoPaths): void {\n771:   const child = spawn(process.execPath, [paths.launcherPath], {\n772:     cwd: paths.repoRoot,\n773:     env: process.env,\n774:     detached: true,\n775:     stdio: 'ignore',\n776:   });\n777:   child.unref();\n778: }\n779: \n780: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n781:   const deadline = Date.now() + timeoutMs;\n782:   let lastReason = 'not probed';\n783: \n784:   while (Date.now() <= deadline) {\n785:     const remaining = Math.max(1, deadline - Date.now());\n786:     const probe = await bridge.probeDaemon(socketPath, {\n787:       timeoutMs: Math.min(remaining, 5000),\n788:       deepProbe: true,\n789:     });\n790:     if (probe.status === 'alive') return;\n791:     lastReason = probe.reason ?? probe.status;\n792:     await sleep(100);\n793:   }\n794: \n795:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n796: }\n797: \n798: class JsonRpcSocketClient {\n799:   private nextId = 1;\n800:   private readonly decoder = new StringDecoder('utf8');\n801: \n802:   private constructor(\n803:     private readonly socket: net.Socket,\n804:   ) {}\n805: \n806:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n807:     return new Promise((resolve, reject) => {\n808:       let socket: net.Socket;\n809:       let settled = false;\n810:       const finish = (error?: Error): void => {\n811:         if (settled) return;\n812:         settled = true;\n813:         clearTimeout(timer);\n814:         socket.off?.('connect', onConnect);\n815:         socket.off?.('error', onError);\n816:         if (error) {\n817:           socket.destroy?.();\n818:           reject(error);\n819:           return;\n820:         }\n821:         resolve(new JsonRpcSocketClient(socket));\n822:       };\n823:       const onConnect = (): void => finish();\n824:       const onError = (error: Error): void => finish(error);\n825:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n826:       timer.unref?.();\n827: \n828:       try {\n829:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n830:         socket = typeof connectionOptions === 'string'\n831:           ? net.createConnection(connectionOptions)\n832:           : net.createConnection(connectionOptions);\n833:       } catch (error: unknown) {\n834:         clearTimeout(timer);\n835:         reject(error instanceof Error ? error : new Error(String(error)));\n836:         return;\n837:       }\n838:       socket.once('connect', onConnect);\n839:       socket.once('error', onError);\n840:     });\n841:   }\n842: \n843:   notify(method: string, params?: unknown): void {\n844:     const frame = params === undefined\n845:       ? { jsonrpc: '2.0', method }\n846:       : { jsonrpc: '2.0', method, params };\n847:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n848:   }\n849: \n850:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n851:     const id = this.nextId++;\n852:     const request = { jsonrpc: '2.0', id, method, params };\n853:     return new Promise((resolve, reject) => {\n854:       let buffer = '';\n855:       let settled = false;\n856: \n857:       const cleanup = (): void => {\n858:         clearTimeout(timer);\n859:         this.socket.off('data', onData);\n860:         this.socket.off('error', onError);\n861:         this.socket.off('close', onClose);\n862:       };\n863:       const finish = (error: unknown, value?: unknown): void => {\n864:         if (settled) return;\n865:         settled = true;\n866:         cleanup();\n867:         if (error) {\n868:           reject(error);\n869:           return;\n870:         }\n871:         resolve(value);\n872:       };\n873:       const onData = (chunk: Buffer | string): void => {\n874:         buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n875:         let newlineIndex = buffer.indexOf('\\n');\n876:         while (newlineIndex !== -1) {\n877:           const line = buffer.slice(0, newlineIndex).trim();\n878:           buffer = buffer.slice(newlineIndex + 1);\n879:           newlineIndex = buffer.indexOf('\\n');\n880:           if (!line) continue;\n881:           let parsed: JsonRpcResponse;\n882:           try {\n883:             parsed = JSON.parse(line) as JsonRpcResponse;\n884:           } catch {\n885:             continue;\n886:           }\n887:           if (parsed.id !== id) continue;\n888:           if (parsed.error) {\n889:             finish(new JsonRpcError(parsed.error));\n890:             return;\n891:           }\n892:           finish(null, parsed.result);\n893:           return;\n894:         }\n895:       };\n896:       const onError = (error: Error): void => finish(error);\n897:       const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n898:       const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n899:       timer.unref?.();\n900: \n901:       this.socket.on('data', onData);\n902:       this.socket.once('error', onError);\n903:       this.socket.once('close', onClose);\n904:       this.socket.write(`${JSON.stringify(request)}\\n`);\n905:     });\n906:   }\n907: \n908:   close(): void {\n909:     this.socket.end();\n910:     this.socket.destroy();\n911:   }\n912: }\n913: \n914: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n915:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n916:   if (initialProbe.status === 'alive') return;\n917:   if (warmOnly) {\n918:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n919:   }\n920:   spawnLauncher(paths);\n921:   await waitForDaemon(socketPath, bridge, timeoutMs);\n922: }\n923: \n924: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n925:   ensureSocketEnvironment();\n926:   const paths = findRepoPaths();\n927:   const bridge = loadBridge(paths);\n928:   const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n929:   if (socketPathTooLong(socketPath)) {\n930:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n931:   }\n932: \n933:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n934: \n935:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n936:   try {\n937:     const initialize = await client.request('initialize', {\n938:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n939:       capabilities: {},\n940:       clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n941:     }, timeoutMs) as InitializeResult;\n942:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n943:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n944:     }\n945:     client.notify('notifications/initialized');\n946:     return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n947:   } finally {\n948:     client.close();\n949:   }\n950: }\n951: \n952: export async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n953:   try {\n954:     const parsed = parseCliArgs(argv);\n955:     if (parsed.help) {\n956:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n957:       return EXIT_SUCCESS;\n958:     }\n959:     if (parsed.version) {\n960:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n961:       return EXIT_SUCCESS;\n962:     }\n963:     if (parsed.command === 'list-tools') {\n964:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n965:       return EXIT_SUCCESS;\n966:     }\n967:     if (parsed.command === 'completion') {\n968:       if (!parsed.completionShell) {\n969:         throw new CliUsageError('completion requires a shell: bash or zsh');\n970:       }\n971:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n972:       return EXIT_SUCCESS;\n973:     }\n974: \n975:     const validated = validateCommand(parsed);\n976:     if (!validated) {\n977:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n978:     }\n979:     const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n980:     const { payload, isError } = extractToolPayload(validated.tool.name, result);\n981:     await writeLine(io.stdout, renderPayload(payload, parsed.format));\n982:     return isError ? EXIT_RUNTIME : EXIT_SUCCESS;\n983:   } catch (error: unknown) {\n984:     const exitCode = exitCodeForError(error);\n985:     const message = error instanceof Error ? error.message : String(error);\n986:     const unknownCommand = unknownCommandContext(message);\n987:     const payload = {\n988:       status: 'error',\n989:       error: message,\n990:       exitCode,\n991:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n992:       ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n993:     };\n994:     const format = (() => {\n995:       try {\n996:         return parseCliArgs(argv).format;\n997:       } catch {\n998:         return 'text' as OutputFormat;\n999:       }\n1000:     })();\n1001:     if (format === 'json' || format === 'jsonl') {\n1002:       await writeLine(io.stderr, renderJson(payload, format));\n1003:     } else {\n1004:       await writeLine(io.stderr, [\n1005:         `ERROR: ${message}`,\n1006:         unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n1007:         unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n1008:       ].filter((line): line is string => Boolean(line)).join('\\n'));\n1009:     }\n1010:     return exitCode;\n1011:   }\n1012: }\n1013: \n1014: function isCliEntrypoint(): boolean {\n1015:   const invoked = process.argv[1];\n1016:   if (!invoked) return false;\n1017:   return path.resolve(invoked) === path.resolve(currentModulePath());\n1018: }\n1019: \n1020: export const __testing = {\n1021:   DEFAULT_SOCKET_DIR,\n1022:   EXIT_PROTOCOL,\n1023:   EXIT_RETRYABLE,\n1024:   EXIT_USAGE,\n1025:   commandMap,\n1026:   commandAliases,\n1027:   ensureSocketEnvironment,\n1028:   exitCodeForError,\n1029:   findRepoPaths,\n1030:   closestCommand,\n1031:   renderCompletion,\n1032:   renderToolList,\n1033:   resolvePropertyName,\n1034: };\n1035: \n1036: if (isCliEntrypoint()) {\n1037:   // Natural exit via process.exitCode: a hard process.exit() drops any\n1038:   // stdout bytes still queued behind the kernel pipe buffer, truncating\n1039:   // large payloads. Pending pipe writes keep the event loop alive until\n1040:   // they flush; all sockets and timers are closed or unref'd by here.\n1041:   process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n1042: }\n\n(End of file - total 1042 lines)\n</content>","metadata":{"preview":"    return\n  fi\n  case \\${words[2]} in\n    completion) _describe 'shells' shells ;;\n    list-tools) _describe 'flags' list_flags ;;\n    *) _describe 'flags' common_flags ;;\n  esac\n}\n_spec_memory \"$@\"`;\n}\n\nfunction renderCompletion(shell: CompletionShell): string {\n  return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n}\n\nfunction extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n  const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n  const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n  if (firstText) {\n    try {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"    return\n  fi\n  case \\${words[2]} in\n    completion) _describe 'shells' shells ;;\n    list-tools) _describe 'flags' list_flags ;;\n    *) _describe 'flags' common_flags ;;\n  esac\n}\n_spec_memory \"$@\"`;\n}\n\nfunction renderCompletion(shell: CompletionShell): string {\n  return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n}\n\nfunction extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n  const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n  const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n  if (firstText) {\n    try {\n      return {\n        payload: JSON.parse(firstText) as unknown,\n        isError: toolResult?.isError === true,\n      };\n    } catch {\n      return {\n        payload: {\n          status: toolResult?.isError ? 'error' : 'ok',\n          tool: toolName,\n          text: firstText,\n        },\n        isError: toolResult?.isError === true,\n      };\n    }\n  }\n  return {\n    payload: {\n      status: toolResult?.isError ? 'error' : 'ok',\n      tool: toolName,\n      result,\n    },\n    isError: toolResult?.isError === true,\n  };\n}\n\nfunction renderPayload(payload: unknown, format: OutputFormat): string {\n  if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n  if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n    const record = payload as Record<string, unknown>;\n    if (typeof record.summary === 'string') return record.summary;\n    if (typeof record.error === 'string') return record.error;\n    if (typeof record.message === 'string') return record.message;\n  }\n  return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n}\n\nfunction isProtocolMismatch(error: unknown): boolean {\n  if (error instanceof JsonRpcError && error.code === -32002) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /protocol.*(mismatch|changed|version)/i.test(message);\n}\n\nfunction isRetryableError(error: unknown): boolean {\n  if (error instanceof CliRetryableError) return true;\n  if (error instanceof JsonRpcError && error.code === -32001) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n}\n\nfunction exitCodeForError(error: unknown): number {\n  if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n  if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n  if (isRetryableError(error)) return EXIT_RETRYABLE;\n  if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n  return EXIT_RUNTIME;\n}\n\nfunction levenshteinDistance(left: string, right: string): number {\n  const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n  const current = new Array<number>(right.length + 1);\n\n  for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n    current[0] = leftIndex;\n    for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n      const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n      current[rightIndex] = Math.min(\n        current[rightIndex - 1] + 1,\n        previous[rightIndex] + 1,\n        previous[rightIndex - 1] + cost,\n      );\n    }\n    previous.splice(0, previous.length, ...current);\n  }\n\n  return previous[right.length];\n}\n\nfunction closestCommand(command: string): string | undefined {\n  const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n  targets.set('completion', 'completion');\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      targets.set(alias, tool.name);\n    }\n  }\n\n  let best: { readonly command: string; readonly distance: number } | null = null;\n  for (const [alias, canonical] of targets) {\n    const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n    if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n      best = { command: canonical, distance };\n    }\n  }\n\n  if (!best) return undefined;\n  const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n  return best.distance <= threshold ? best.command : undefined;\n}\n\nfunction unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n  const match = message.match(/^Unknown command: (.+)$/);\n  if (!match) return null;\n  return {\n    hint: 'Try `list-tools` to see available commands.',\n    suggestion: closestCommand(match[1]),\n  };\n}\n\nfunction socketPathTooLong(socketPath: string): boolean {\n  if (socketPath.startsWith('tcp://')) return false;\n  return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n}\n\nfunction ensureSocketEnvironment(): void {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (!socketDir || socketDir.startsWith('tcp://')) return;\n  mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  const stat = statSync(socketDir);\n  if ((stat.mode & 0o022) !== 0) {\n    throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n  }\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction spawnLauncher(paths: RepoPaths): void {\n  const child = spawn(process.execPath, [paths.launcherPath], {\n    cwd: paths.repoRoot,\n    env: process.env,\n    detached: true,\n    stdio: 'ignore',\n  });\n  child.unref();\n}\n\nasync function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  let lastReason = 'not probed';\n\n  while (Date.now() <= deadline) {\n    const remaining = Math.max(1, deadline - Date.now());\n    const probe = await bridge.probeDaemon(socketPath, {\n      timeoutMs: Math.min(remaining, 5000),\n      deepProbe: true,\n    });\n    if (probe.status === 'alive') return;\n    lastReason = probe.reason ?? probe.status;\n    await sleep(100);\n  }\n\n  throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n}\n\nclass JsonRpcSocketClient {\n  private nextId = 1;\n  private readonly decoder = new StringDecoder('utf8');\n\n  private constructor(\n    private readonly socket: net.Socket,\n  ) {}\n\n  static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n    return new Promise((resolve, reject) => {\n      let socket: net.Socket;\n      let settled = false;\n      const finish = (error?: Error): void => {\n        if (settled) return;\n        settled = true;\n        clearTimeout(timer);\n        socket.off?.('connect', onConnect);\n        socket.off?.('error', onError);\n        if (error) {\n          socket.destroy?.();\n          reject(error);\n          return;\n        }\n        resolve(new JsonRpcSocketClient(socket));\n      };\n      const onConnect = (): void => finish();\n      const onError = (error: Error): void => finish(error);\n      const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n      timer.unref?.();\n\n      try {\n        const connectionOptions = bridge.toConnectionOptions(socketPath);\n        socket = typeof connectionOptions === 'string'\n          ? net.createConnection(connectionOptions)\n          : net.createConnection(connectionOptions);\n      } catch (error: unknown) {\n        clearTimeout(timer);\n        reject(error instanceof Error ? error : new Error(String(error)));\n        return;\n      }\n      socket.once('connect', onConnect);\n      socket.once('error', onError);\n    });\n  }\n\n  notify(method: string, params?: unknown): void {\n    const frame = params === undefined\n      ? { jsonrpc: '2.0', method }\n      : { jsonrpc: '2.0', method, params };\n    this.socket.write(`${JSON.stringify(frame)}\\n`);\n  }\n\n  request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n    const id = this.nextId++;\n    const request = { jsonrpc: '2.0', id, method, params };\n    return new Promise((resolve, reject) => {\n      let buffer = '';\n      let settled = false;\n\n      const cleanup = (): void => {\n        clearTimeout(timer);\n        this.socket.off('data', onData);\n        this.socket.off('error', onError);\n        this.socket.off('close', onClose);\n      };\n      const finish = (error: unknown, value?: unknown): void => {\n        if (settled) return;\n        settled = true;\n        cleanup();\n        if (error) {\n          reject(error);\n          return;\n        }\n        resolve(value);\n      };\n      const onData = (chunk: Buffer | string): void => {\n        buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n        let newlineIndex = buffer.indexOf('\\n');\n        while (newlineIndex !== -1) {\n          const line = buffer.slice(0, newlineIndex).trim();\n          buffer = buffer.slice(newlineIndex + 1);\n          newlineIndex = buffer.indexOf('\\n');\n          if (!line) continue;\n          let parsed: JsonRpcResponse;\n          try {\n            parsed = JSON.parse(line) as JsonRpcResponse;\n          } catch {\n            continue;\n          }\n          if (parsed.id !== id) continue;\n          if (parsed.error) {\n            finish(new JsonRpcError(parsed.error));\n            return;\n          }\n          finish(null, parsed.result);\n          return;\n        }\n      };\n      const onError = (error: Error): void => finish(error);\n      const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n      const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n      timer.unref?.();\n\n      this.socket.on('data', onData);\n      this.socket.once('error', onError);\n      this.socket.once('close', onClose);\n      this.socket.write(`${JSON.stringify(request)}\\n`);\n    });\n  }\n\n  close(): void {\n    this.socket.end();\n    this.socket.destroy();\n  }\n}\n\nasync function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n  const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n  if (initialProbe.status === 'alive') return;\n  if (warmOnly) {\n    throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n  }\n  spawnLauncher(paths);\n  await waitForDaemon(socketPath, bridge, timeoutMs);\n}\n\nasync function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n  ensureSocketEnvironment();\n  const paths = findRepoPaths();\n  const bridge = loadBridge(paths);\n  const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n  if (socketPathTooLong(socketPath)) {\n    throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n  }\n\n  await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n\n  const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n  try {\n    const initialize = await client.request('initialize', {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n    }, timeoutMs) as InitializeResult;\n    if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n      throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n    }\n    client.notify('notifications/initialized');\n    return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n  } finally {\n    client.close();\n  }\n}\n\nexport async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n  try {\n    const parsed = parseCliArgs(argv);\n    if (parsed.help) {\n      await writeLine(io.stdout, usageText(parsed.command || undefined));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.version) {\n      await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'list-tools') {\n      await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'completion') {\n      if (!parsed.completionShell) {\n        throw new CliUsageError('completion requires a shell: bash or zsh');\n      }\n      await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n      return EXIT_SUCCESS;\n    }\n\n    const validated = validateCommand(parsed);\n    if (!validated) {\n      throw new CliUsageError(`Unknown command: ${parsed.command}`);\n    }\n    const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n    const { payload, isError } = extractToolPayload(validated.tool.name, result);\n    await writeLine(io.stdout, renderPayload(payload, parsed.format));\n    return isError ? EXIT_RUNTIME : EXIT_SUCCESS;\n  } catch (error: unknown) {\n    const exitCode = exitCodeForError(error);\n    const message = error instanceof Error ? error.message : String(error);\n    const unknownCommand = unknownCommandContext(message);\n    const payload = {\n      status: 'error',\n      error: message,\n      exitCode,\n      ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n      ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n    };\n    const format = (() => {\n      try {\n        return parseCliArgs(argv).format;\n      } catch {\n        return 'text' as OutputFormat;\n      }\n    })();\n    if (format === 'json' || format === 'jsonl') {\n      await writeLine(io.stderr, renderJson(payload, format));\n    } else {\n      await writeLine(io.stderr, [\n        `ERROR: ${message}`,\n        unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n        unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n      ].filter((line): line is string => Boolean(line)).join('\\n'));\n    }\n    return exitCode;\n  }\n}\n\nfunction isCliEntrypoint(): boolean {\n  const invoked = process.argv[1];\n  if (!invoked) return false;\n  return path.resolve(invoked) === path.resolve(currentModulePath());\n}\n\nexport const __testing = {\n  DEFAULT_SOCKET_DIR,\n  EXIT_PROTOCOL,\n  EXIT_RETRYABLE,\n  EXIT_USAGE,\n  commandMap,\n  commandAliases,\n  ensureSocketEnvironment,\n  exitCodeForError,\n  findRepoPaths,\n  closestCommand,\n  renderCompletion,\n  renderToolList,\n  resolvePropertyName,\n};\n\nif (isCliEntrypoint()) {\n  // Natural exit via process.exitCode: a hard process.exit() drops any\n  // stdout bytes still queued behind the kernel pipe buffer, truncating\n  // large payloads. Pending pipe writes keep the event loop alive until\n  // they flush; all sockets and timers are closed or unref'd by here.\n  process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n}","lineStart":620,"lineEnd":1042,"totalLines":1042,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781145052926,"end":1781145052931}},"metadata":{"openai":{"itemId":"fc_0972614b57b29f4e016a2a1ddce4dc8191b34514ff4c2c3d45"}},"id":"prt_eb484a6f7001IRJUvQKDNBL8Uo","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb4848e07001hYVTQVDbmxq2r0"}}
