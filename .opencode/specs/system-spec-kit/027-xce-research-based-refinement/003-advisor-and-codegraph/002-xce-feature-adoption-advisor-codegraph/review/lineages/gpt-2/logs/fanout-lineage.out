t}`\n363:     : `${matchResult.count}`;\n364: \n365:   return {\n366:     code: 'ambiguous_subject',\n367:     subject,\n368:     matchField,\n369:     count: matchResult.count,\n370:     candidates: matchResult.candidates,\n371:     selectedCandidate,\n372:     selectionReason,\n373:     message: `Multiple code graph nodes matched subject \"${subject}\" by ${matchField} (${countLabel}). Selected ${selectedCandidate.symbolId} for ${selectedCandidate.selectedForOperation ?? 'query'} using ${selectionReason}. Use a symbolId to disambiguate the query.`,\n374:   };\n375: }\n376: \n377: function querySymbolBm25Suggestions(subject: string): SymbolBm25Candidate[] {\n378:   if (!isCodeGraphBm25SymbolResolverEnabled()) {\n379:     return [];\n380:   }\n381: \n382:   return resolveSymbolBm25Candidates(\n383:     subject,\n384:     graphDb.querySymbolIndexRows(),\n385:     { limit: SYMBOL_BM25_SUGGESTION_LIMIT },\n386:   );\n387: }\n388: \n389: function buildUnresolvedSubjectError(subject: string, suggestions: SymbolBm25Candidate[]) {\n390:   const base = {\n391:     status: 'error' as const,\n392:     error: `Could not resolve subject: ${subject}`,\n393:   };\n394: \n395:   if (suggestions.length === 0) {\n396:     return base;\n397:   }\n398: \n399:   return {\n400:     ...base,\n401:     data: {\n402:       symbolResolution: {\n403:         resolver: 'bm25',\n404:         disambiguationOnly: true,\n405:         message: 'No exact symbol match was found. These are candidate symbols only; use a symbolId, fqName, or exact name to run a structural query.',\n406:         candidates: suggestions,\n407:       },\n408:     },\n409:   };\n410: }\n411: \n412: /** Resolve a subject string to a symbolId */\n413: function resolveSubject(\n414:   subject: string,\n415:   operation: QueryArgs['operation'],\n416:   edgeType: EdgeType | undefined,\n417: ): ResolvedSubject {\n418:   const d = graphDb.getDb();\n419: \n420:   // Try as symbolId first\n421:   const byId = d.prepare(`\n422:     SELECT symbol_id, fq_name, name, kind, file_path, start_line\n423:     FROM code_nodes\n424:     WHERE symbol_id = ?\n425:   `).get(subject) as {\n426:     symbol_id: string;\n427:     fq_name: string | null;\n428:     name: string | null;\n429:     kind: string | null;\n430:     file_path: string | null;\n431:     start_line: number | null;\n432:   } | undefined;\n433:   if (byId) {\n434:     return {\n435:       symbolId: byId.symbol_id,\n436:       selectedCandidate: {\n437:         symbolId: byId.symbol_id,\n438:         fqName: byId.fq_name,\n439:         name: byId.name,\n440:         kind: byId.kind,\n441:         filePath: byId.file_path,\n442:         startLine: byId.start_line,\n443:         selectedForOperation: operation,\n444:       },\n445:     };\n446:   }\n447: \n448:   // Try as fqName\n449:   const byFq = querySubjectMatches('fq_name', subject);\n450:   if (byFq.count > 0) {\n451:     const selection = pickOperationAwareCandidate(byFq.candidates, operation, edgeType);\n452:     return {\n453:       symbolId: selection.selectedCandidate.symbolId,\n454:       selectedCandidate: selection.selectedCandidate,\n455:       ...(byFq.count > 1\n456:         ? {\n457:           warnings: [buildAmbiguousSubjectWarning(subject, 'fq_name', {\n458:             ...byFq,\n459:             candidates: selection.candidates.slice(0, AMBIGUOUS_SUBJECT_WARNING_CANDIDATE_LIMIT),\n460:           }, selection.selectedCandidate, selection.selectionReason)]\n461:         }\n462:         : {}),\n463:     };\n464:   }\n465: \n466:   // Try as name\n467:   const byName = querySubjectMatches('name', subject);\n468:   if (byName.count > 0) {\n469:     const selection = pickOperationAwareCandidate(byName.candidates, operation, edgeType);\n470:     return {\n471:       symbolId: selection.selectedCandidate.symbolId,\n472:       selectedCandidate: selection.selectedCandidate,\n473:       ...(byName.count > 1\n474:         ? {\n475:           warnings: [buildAmbiguousSubjectWarning(subject, 'name', {\n476:             ...byName,\n477:             candidates: selection.candidates.slice(0, AMBIGUOUS_SUBJECT_WARNING_CANDIDATE_LIMIT),\n478:           }, selection.selectedCandidate, selection.selectionReason)]\n479:         }\n\n(Showing lines 330-479 of 1766. Use offset=480 to continue.)\n</content>","metadata":{"preview":"      || callableKindRank(left.kind) - callableKindRank(right.kind)\n      || (left.filePath ?? '').localeCompare(right.filePath ?? '')\n      || (left.startLine ?? Number.MAX_SAFE_INTEGER) - (right.startLine ?? Number.MAX_SAFE_INTEGER)\n      || left.symbolId.localeCompare(right.symbolId)\n    ));\n\n  const selectedCandidate = rankedCandidates[0] ?? candidates[0];\n  const highestEdgeCount = selectedCandidate?.operationEdgeCount ?? 0;\n  const hasEdgeSignal = highestEdgeCount > 0;\n  const selectionReason = hasEdgeSignal\n    ? `${operation} edge count`\n    : callableKindRank(selectedCandidate?.kind ?? null) === 0\n      ? 'callable kind preference'\n      : 'deterministic file ordering';\n\n  return {\n    selectedCandidate,\n    candidates: rankedCandidates,\n    selectionReason,\n  };","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/handlers/query.ts","text":"      || callableKindRank(left.kind) - callableKindRank(right.kind)\n      || (left.filePath ?? '').localeCompare(right.filePath ?? '')\n      || (left.startLine ?? Number.MAX_SAFE_INTEGER) - (right.startLine ?? Number.MAX_SAFE_INTEGER)\n      || left.symbolId.localeCompare(right.symbolId)\n    ));\n\n  const selectedCandidate = rankedCandidates[0] ?? candidates[0];\n  const highestEdgeCount = selectedCandidate?.operationEdgeCount ?? 0;\n  const hasEdgeSignal = highestEdgeCount > 0;\n  const selectionReason = hasEdgeSignal\n    ? `${operation} edge count`\n    : callableKindRank(selectedCandidate?.kind ?? null) === 0\n      ? 'callable kind preference'\n      : 'deterministic file ordering';\n\n  return {\n    selectedCandidate,\n    candidates: rankedCandidates,\n    selectionReason,\n  };\n}\n\nfunction buildAmbiguousSubjectWarning(\n  subject: string,\n  matchField: 'fq_name' | 'name' | 'symbol_id',\n  matchResult: SubjectMatchResult,\n  selectedCandidate: SubjectCandidateMetadata,\n  selectionReason: string,\n): AmbiguousSubjectWarning {\n  const truncated = matchResult.count > matchResult.candidates.length;\n  const shownCount = matchResult.candidates.length;\n  const countLabel = truncated\n    ? `${matchResult.count} total; showing first ${shownCount}`\n    : `${matchResult.count}`;\n\n  return {\n    code: 'ambiguous_subject',\n    subject,\n    matchField,\n    count: matchResult.count,\n    candidates: matchResult.candidates,\n    selectedCandidate,\n    selectionReason,\n    message: `Multiple code graph nodes matched subject \"${subject}\" by ${matchField} (${countLabel}). Selected ${selectedCandidate.symbolId} for ${selectedCandidate.selectedForOperation ?? 'query'} using ${selectionReason}. Use a symbolId to disambiguate the query.`,\n  };\n}\n\nfunction querySymbolBm25Suggestions(subject: string): SymbolBm25Candidate[] {\n  if (!isCodeGraphBm25SymbolResolverEnabled()) {\n    return [];\n  }\n\n  return resolveSymbolBm25Candidates(\n    subject,\n    graphDb.querySymbolIndexRows(),\n    { limit: SYMBOL_BM25_SUGGESTION_LIMIT },\n  );\n}\n\nfunction buildUnresolvedSubjectError(subject: string, suggestions: SymbolBm25Candidate[]) {\n  const base = {\n    status: 'error' as const,\n    error: `Could not resolve subject: ${subject}`,\n  };\n\n  if (suggestions.length === 0) {\n    return base;\n  }\n\n  return {\n    ...base,\n    data: {\n      symbolResolution: {\n        resolver: 'bm25',\n        disambiguationOnly: true,\n        message: 'No exact symbol match was found. These are candidate symbols only; use a symbolId, fqName, or exact name to run a structural query.',\n        candidates: suggestions,\n      },\n    },\n  };\n}\n\n/** Resolve a subject string to a symbolId */\nfunction resolveSubject(\n  subject: string,\n  operation: QueryArgs['operation'],\n  edgeType: EdgeType | undefined,\n): ResolvedSubject {\n  const d = graphDb.getDb();\n\n  // Try as symbolId first\n  const byId = d.prepare(`\n    SELECT symbol_id, fq_name, name, kind, file_path, start_line\n    FROM code_nodes\n    WHERE symbol_id = ?\n  `).get(subject) as {\n    symbol_id: string;\n    fq_name: string | null;\n    name: string | null;\n    kind: string | null;\n    file_path: string | null;\n    start_line: number | null;\n  } | undefined;\n  if (byId) {\n    return {\n      symbolId: byId.symbol_id,\n      selectedCandidate: {\n        symbolId: byId.symbol_id,\n        fqName: byId.fq_name,\n        name: byId.name,\n        kind: byId.kind,\n        filePath: byId.file_path,\n        startLine: byId.start_line,\n        selectedForOperation: operation,\n      },\n    };\n  }\n\n  // Try as fqName\n  const byFq = querySubjectMatches('fq_name', subject);\n  if (byFq.count > 0) {\n    const selection = pickOperationAwareCandidate(byFq.candidates, operation, edgeType);\n    return {\n      symbolId: selection.selectedCandidate.symbolId,\n      selectedCandidate: selection.selectedCandidate,\n      ...(byFq.count > 1\n        ? {\n          warnings: [buildAmbiguousSubjectWarning(subject, 'fq_name', {\n            ...byFq,\n            candidates: selection.candidates.slice(0, AMBIGUOUS_SUBJECT_WARNING_CANDIDATE_LIMIT),\n          }, selection.selectedCandidate, selection.selectionReason)]\n        }\n        : {}),\n    };\n  }\n\n  // Try as name\n  const byName = querySubjectMatches('name', subject);\n  if (byName.count > 0) {\n    const selection = pickOperationAwareCandidate(byName.candidates, operation, edgeType);\n    return {\n      symbolId: selection.selectedCandidate.symbolId,\n      selectedCandidate: selection.selectedCandidate,\n      ...(byName.count > 1\n        ? {\n          warnings: [buildAmbiguousSubjectWarning(subject, 'name', {\n            ...byName,\n            candidates: selection.candidates.slice(0, AMBIGUOUS_SUBJECT_WARNING_CANDIDATE_LIMIT),\n          }, selection.selectedCandidate, selection.selectionReason)]\n        }","lineStart":330,"lineEnd":479,"totalLines":1766,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781128791421,"end":1781128791429}},"metadata":{"openai":{"itemId":"fc_02edcf03c0b9c56d016a29de574c888191bcc8d8335aab6a16"}},"id":"prt_eb38c8533001Asnqx2CUUS4n3C","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38c58ec001EvkU1mZu1DUHyY"}}
{"type":"tool_use","timestamp":1781128791452,"sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","part":{"type":"tool","tool":"read","callID":"call_wj55kAtobxZtwuohSJ9lDISQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Code Graph Database\n3: // ───────────────────────────────────────────────────────────────\n4: // SQLite storage for structural code graph (nodes + edges).\n5: // Uses separate code-graph.sqlite alongside the memory index DB.\n6: \n7: import Database from 'better-sqlite3';\n8: import { join, isAbsolute, resolve as resolvePath } from 'node:path';\n9: import { readFileSync, statSync } from 'node:fs';\n10: import { assertDbHandleClosed } from './close-db-assertion.js';\n11: import { generateContentHash, type CodeNode, type CodeEdge, type DetectorProvenance } from './indexer-types.js';\n12: import {\n13:   CODE_GRAPH_SCOPE_FINGERPRINT_KEY,\n14:   CODE_GRAPH_SCOPE_LABEL_KEY,\n15:   CODE_GRAPH_SCOPE_SOURCE_KEY,\n16:   CODE_GRAPH_SKILL_EXCLUDE_GLOBS,\n17:   parseIndexScopePolicyFromFingerprint,\n18:   type IndexScopePolicy,\n19:   type IndexScopePolicySource,\n20: } from './index-scope-policy.js';\n21: import { DATABASE_DIR } from '../core/config.js';\n22: \n23: let db: Database.Database | null = null;\n24: let dbPath: string | null = null;\n25: \n26: export interface StartupHighlight {\n27:   name: string;\n28:   kind: string;\n29:   filePath: string;\n30:   callCount: number;\n31: }\n32: \n33: export interface FileImportDependent {\n34:   importedFilePath: string;\n35:   importerFilePath: string;\n36: }\n37: \n38: export interface FileDegree {\n39:   filePath: string;\n40:   degree: number;\n41: }\n42: \n43: export interface DetectorProvenanceSummary {\n44:   dominant: DetectorProvenance | 'unknown';\n45:   counts: Partial<Record<DetectorProvenance, number>>;\n46: }\n47: \n48: export type GraphEdgeEvidenceSummaryClass =\n49:   | 'import'\n50:   | 'type_reference'\n51:   | 'test_coverage'\n52:   | 'inferred_heuristic'\n53:   | 'direct_call';\n54: \n55: export interface GraphEdgeEnrichmentSummary {\n56:   edgeEvidenceClass: GraphEdgeEvidenceSummaryClass;\n57:   numericConfidence: number;\n58:   crossFileCallResolution?: {\n59:     resolved: number;\n60:     unresolved: number;\n61:     ambiguousSkipped: number;\n62:   };\n63: }\n64: \n65: export interface StoredCodeGraphScope {\n66:   fingerprint: string | null;\n67:   label: string | null;\n68:   includeSkills: boolean | null;\n69:   includedSkillsList: IndexScopePolicy['includedSkillsList'] | null;\n70:   includeAgents: boolean | null;\n71:   includeCommands: boolean | null;\n72:   includeSpecs: boolean | null;\n73:   includePlugins: boolean | null;\n74:   source: IndexScopePolicySource | null;\n75: }\n76: \n77: export interface ParseDiagnostic {\n78:   readonly filePath: string;\n79:   readonly errorMessage: string;\n80:   readonly errorCount: number;\n81:   readonly lastSeenAt: string;\n82: }\n83: \n84: export interface ParseDiagnosticsSummary {\n85:   readonly affectedFiles: number;\n86:   readonly recentErrors: ParseDiagnostic[];\n87: }\n88: \n89: export interface FailedScanRecord {\n90:   readonly reason: string;\n91:   readonly totalFiles: number;\n92:   readonly totalNodes: number;\n93:   readonly parseErrorCount: number;\n94:   readonly parseErrorRatio: number;\n95:   readonly recordedAt: string;\n96:   readonly previousGitHead?: string | null;\n97:   readonly currentGitHead?: string | null;\n98:   readonly scopeFingerprint?: string | null;\n99:   readonly scopeLabel?: string | null;\n100:   readonly errors?: string[];\n101: }\n102: \n103: export type CodeGraphTombstoneKind = 'file' | 'node' | 'edge';\n104: \n105: export interface CodeGraphTombstoneRecord {\n106:   readonly id: number;\n107:   readonly entityKind: CodeGraphTombstoneKind;\n108:   readonly entityId: string | null;\n109:   readonly sourceId: string | null;\n110:   readonly targetId: string | null;\n111:   readonly edgeType: string | null;\n112:   readonly filePath: string | null;\n113:   readonly reason: string;\n114:   readonly deletedAt: string;\n115: }\n116: \n117: export interface CodeGraphTombstoneSummary {\n118:   readonly enabled: boolean;\n119:   readonly retentionLimit: number;\n120:   readonly retainedRows: number;\n121:   readonly byKind: Record<string, number>;\n122:   readonly byReason: Record<string, number>;\n123:   readonly recent: CodeGraphTombstoneRecord[];\n124: }\n125: \n126: export interface SymbolIndexRow {\n127:   readonly symbolId: string;\n128:   readonly fqName: string | null;\n129:   readonly name: string | null;\n130:   readonly kind: string | null;\n131:   readonly filePath: string | null;\n132:   readonly startLine: number | null;\n133:   readonly signature: string | null;\n134:   readonly docstring: string | null;\n135: }\n136: \n137: export interface DeleteAuditOptions {\n138:   readonly reason?: string;\n139: }\n140: \n141: /** Schema version for migration tracking */\n142: export const SCHEMA_VERSION = 5;\n143: \n144: /** SQL schema for code graph tables */\n145: const SCHEMA_SQL = `\n146:   CREATE TABLE IF NOT EXISTS code_files (\n147:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n148:     file_path TEXT NOT NULL UNIQUE,\n149:     language TEXT NOT NULL,\n150:     content_hash TEXT NOT NULL,\n151:     file_mtime_ms INTEGER NOT NULL DEFAULT 0,\n152:     node_count INTEGER DEFAULT 0,\n153:     edge_count INTEGER DEFAULT 0,\n154:     parse_health TEXT DEFAULT 'clean',\n155:     indexed_at TEXT NOT NULL,\n156:     parse_duration_ms INTEGER DEFAULT 0\n157:   );\n158: \n159:   CREATE TABLE IF NOT EXISTS code_nodes (\n160:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n161:     symbol_id TEXT NOT NULL UNIQUE,\n162:     file_id INTEGER NOT NULL REFERENCES code_files(id) ON DELETE CASCADE,\n163:     file_path TEXT NOT NULL,\n164:     fq_name TEXT NOT NULL,\n165:     kind TEXT NOT NULL,\n166:     name TEXT NOT NULL,\n167:     start_line INTEGER NOT NULL,\n168:     end_line INTEGER NOT NULL,\n169:     start_column INTEGER DEFAULT 0,\n170:     end_column INTEGER DEFAULT 0,\n171:     language TEXT NOT NULL,\n172:     signature TEXT,\n173:     docstring TEXT,\n174:     content_hash TEXT NOT NULL\n175:   );\n176: \n177:   CREATE TABLE IF NOT EXISTS code_edges (\n178:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n179:     source_id TEXT NOT NULL,\n180:     target_id TEXT NOT NULL,\n181:     edge_type TEXT NOT NULL,\n182:     weight REAL DEFAULT 1.0,\n183:     metadata TEXT\n184:   );\n185: \n186:   CREATE TABLE IF NOT EXISTS schema_version (\n187:     version INTEGER NOT NULL\n188:   );\n189: \n190:   CREATE TABLE IF NOT EXISTS code_graph_metadata (\n191:     key TEXT PRIMARY KEY,\n192:     value TEXT NOT NULL,\n193:     updated_at TEXT NOT NULL\n194:   );\n195: \n196:   CREATE TABLE IF NOT EXISTS parse_diagnostics (\n197:     file_path TEXT PRIMARY KEY,\n198:     error_message TEXT NOT NULL,\n199:     error_count INTEGER NOT NULL DEFAULT 1,\n200:     last_seen_at TEXT NOT NULL\n201:   );\n202: \n203:   CREATE TABLE IF NOT EXISTS parser_skip_list (\n204:     file_path     TEXT PRIMARY KEY,\n205:     error_class   TEXT NOT NULL CHECK (error_class IN ('B1', 'B2', 'OTHER')),\n206:     error_message TEXT,\n207:     added_at      TEXT NOT NULL,\n208:     last_seen_at  TEXT NOT NULL,\n209:     attempt_count INTEGER NOT NULL DEFAULT 1,\n210:     source        TEXT NOT NULL CHECK (source IN ('seed', 'runtime'))\n211:   );\n212: \n213:   CREATE INDEX IF NOT EXISTS idx_nodes_file_id ON code_nodes(file_id);\n214:   CREATE INDEX IF NOT EXISTS idx_nodes_symbol_id ON code_nodes(symbol_id);\n215:   CREATE INDEX IF NOT EXISTS idx_nodes_kind ON code_nodes(kind);\n216:   CREATE INDEX IF NOT EXISTS idx_nodes_name ON code_nodes(name);\n217:   CREATE INDEX IF NOT EXISTS idx_file_line ON code_nodes(file_path, start_line);\n218:   CREATE INDEX IF NOT EXISTS idx_edges_source ON code_edges(source_id, edge_type);\n219:   CREATE INDEX IF NOT EXISTS idx_edges_target ON code_edges(target_id, edge_type);\n220:   CREATE INDEX IF NOT EXISTS idx_edges_type ON code_edges(edge_type);\n221:   CREATE INDEX IF NOT EXISTS idx_files_path ON code_files(file_path);\n222:   CREATE INDEX IF NOT EXISTS idx_files_hash ON code_files(content_hash);\n223:   CREATE INDEX IF NOT EXISTS idx_parse_diagnostics_last_seen ON parse_diagnostics(last_seen_at);\n224:   CREATE INDEX IF NOT EXISTS idx_parser_skip_list_class ON parser_skip_list(error_class);\n225: `;\n226: \n227: const CODE_GRAPH_TOMBSTONES_ENV = 'SPECKIT_CODE_GRAPH_TOMBSTONES';\n228: const CODE_GRAPH_TOMBSTONE_LIMIT_ENV = 'SPECKIT_CODE_GRAPH_TOMBSTONE_LIMIT';\n229: const DEFAULT_TOMBSTONE_LIMIT = 100;\n230: const MAX_TOMBSTONE_LIMIT = 10_000;\n231: \n232: function codeGraphTombstonesEnabled(): boolean {\n233:   return process.env[CODE_GRAPH_TOMBSTONES_ENV] === 'true';\n234: }\n235: \n236: function getCodeGraphTombstoneLimit(): number {\n237:   const raw = process.env[CODE_GRAPH_TOMBSTONE_LIMIT_ENV];\n238:   const parsed = raw ? Number.parseInt(raw, 10) : DEFAULT_TOMBSTONE_LIMIT;\n239:   if (!Number.isFinite(parsed) || parsed <= 0) {\n240:     return DEFAULT_TOMBSTONE_LIMIT;\n241:   }\n242:   return Math.min(Math.trunc(parsed), MAX_TOMBSTONE_LIMIT);\n243: }\n244: \n245: function ensureTombstoneSchema(database: Database.Database): void {\n246:   database.exec(`\n247:     CREATE TABLE IF NOT EXISTS code_graph_tombstones (\n248:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n249:       entity_kind TEXT NOT NULL CHECK (entity_kind IN ('file', 'node', 'edge')),\n250:       entity_id TEXT,\n251:       source_id TEXT,\n252:       target_id TEXT,\n253:       edge_type TEXT,\n254:       file_path TEXT,\n255:       reason TEXT NOT NULL,\n256:       deleted_at TEXT NOT NULL\n257:     );\n258:     CREATE INDEX IF NOT EXISTS idx_code_graph_tombstones_deleted_at ON code_graph_tombstones(deleted_at);\n259:     CREATE INDEX IF NOT EXISTS idx_code_graph_tombstones_kind_reason ON code_graph_tombstones(entity_kind, reason);\n260:   `);\n\n(Showing lines 1-260 of 1626. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Database\n// ───────────────────────────────────────────────────────────────\n// SQLite storage for structural code graph (nodes + edges).\n// Uses separate code-graph.sqlite alongside the memory index DB.\n\nimport Database from 'better-sqlite3';\nimport { join, isAbsolute, resolve as resolvePath } from 'node:path';\nimport { readFileSync, statSync } from 'node:fs';\nimport { assertDbHandleClosed } from './close-db-assertion.js';\nimport { generateContentHash, type CodeNode, type CodeEdge, type DetectorProvenance } from './indexer-types.js';\nimport {\n  CODE_GRAPH_SCOPE_FINGERPRINT_KEY,\n  CODE_GRAPH_SCOPE_LABEL_KEY,\n  CODE_GRAPH_SCOPE_SOURCE_KEY,\n  CODE_GRAPH_SKILL_EXCLUDE_GLOBS,\n  parseIndexScopePolicyFromFingerprint,\n  type IndexScopePolicy,\n  type IndexScopePolicySource,\n} from './index-scope-policy.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Database\n// ───────────────────────────────────────────────────────────────\n// SQLite storage for structural code graph (nodes + edges).\n// Uses separate code-graph.sqlite alongside the memory index DB.\n\nimport Database from 'better-sqlite3';\nimport { join, isAbsolute, resolve as resolvePath } from 'node:path';\nimport { readFileSync, statSync } from 'node:fs';\nimport { assertDbHandleClosed } from './close-db-assertion.js';\nimport { generateContentHash, type CodeNode, type CodeEdge, type DetectorProvenance } from './indexer-types.js';\nimport {\n  CODE_GRAPH_SCOPE_FINGERPRINT_KEY,\n  CODE_GRAPH_SCOPE_LABEL_KEY,\n  CODE_GRAPH_SCOPE_SOURCE_KEY,\n  CODE_GRAPH_SKILL_EXCLUDE_GLOBS,\n  parseIndexScopePolicyFromFingerprint,\n  type IndexScopePolicy,\n  type IndexScopePolicySource,\n} from './index-scope-policy.js';\nimport { DATABASE_DIR } from '../core/config.js';\n\nlet db: Database.Database | null = null;\nlet dbPath: string | null = null;\n\nexport interface StartupHighlight {\n  name: string;\n  kind: string;\n  filePath: string;\n  callCount: number;\n}\n\nexport interface FileImportDependent {\n  importedFilePath: string;\n  importerFilePath: string;\n}\n\nexport interface FileDegree {\n  filePath: string;\n  degree: number;\n}\n\nexport interface DetectorProvenanceSummary {\n  dominant: DetectorProvenance | 'unknown';\n  counts: Partial<Record<DetectorProvenance, number>>;\n}\n\nexport type GraphEdgeEvidenceSummaryClass =\n  | 'import'\n  | 'type_reference'\n  | 'test_coverage'\n  | 'inferred_heuristic'\n  | 'direct_call';\n\nexport interface GraphEdgeEnrichmentSummary {\n  edgeEvidenceClass: GraphEdgeEvidenceSummaryClass;\n  numericConfidence: number;\n  crossFileCallResolution?: {\n    resolved: number;\n    unresolved: number;\n    ambiguousSkipped: number;\n  };\n}\n\nexport interface StoredCodeGraphScope {\n  fingerprint: string | null;\n  label: string | null;\n  includeSkills: boolean | null;\n  includedSkillsList: IndexScopePolicy['includedSkillsList'] | null;\n  includeAgents: boolean | null;\n  includeCommands: boolean | null;\n  includeSpecs: boolean | null;\n  includePlugins: boolean | null;\n  source: IndexScopePolicySource | null;\n}\n\nexport interface ParseDiagnostic {\n  readonly filePath: string;\n  readonly errorMessage: string;\n  readonly errorCount: number;\n  readonly lastSeenAt: string;\n}\n\nexport interface ParseDiagnosticsSummary {\n  readonly affectedFiles: number;\n  readonly recentErrors: ParseDiagnostic[];\n}\n\nexport interface FailedScanRecord {\n  readonly reason: string;\n  readonly totalFiles: number;\n  readonly totalNodes: number;\n  readonly parseErrorCount: number;\n  readonly parseErrorRatio: number;\n  readonly recordedAt: string;\n  readonly previousGitHead?: string | null;\n  readonly currentGitHead?: string | null;\n  readonly scopeFingerprint?: string | null;\n  readonly scopeLabel?: string | null;\n  readonly errors?: string[];\n}\n\nexport type CodeGraphTombstoneKind = 'file' | 'node' | 'edge';\n\nexport interface CodeGraphTombstoneRecord {\n  readonly id: number;\n  readonly entityKind: CodeGraphTombstoneKind;\n  readonly entityId: string | null;\n  readonly sourceId: string | null;\n  readonly targetId: string | null;\n  readonly edgeType: string | null;\n  readonly filePath: string | null;\n  readonly reason: string;\n  readonly deletedAt: string;\n}\n\nexport interface CodeGraphTombstoneSummary {\n  readonly enabled: boolean;\n  readonly retentionLimit: number;\n  readonly retainedRows: number;\n  readonly byKind: Record<string, number>;\n  readonly byReason: Record<string, number>;\n  readonly recent: CodeGraphTombstoneRecord[];\n}\n\nexport interface SymbolIndexRow {\n  readonly symbolId: string;\n  readonly fqName: string | null;\n  readonly name: string | null;\n  readonly kind: string | null;\n  readonly filePath: string | null;\n  readonly startLine: number | null;\n  readonly signature: string | null;\n  readonly docstring: string | null;\n}\n\nexport interface DeleteAuditOptions {\n  readonly reason?: string;\n}\n\n/** Schema version for migration tracking */\nexport const SCHEMA_VERSION = 5;\n\n/** SQL schema for code graph tables */\nconst SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS code_files (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    file_path TEXT NOT NULL UNIQUE,\n    language TEXT NOT NULL,\n    content_hash TEXT NOT NULL,\n    file_mtime_ms INTEGER NOT NULL DEFAULT 0,\n    node_count INTEGER DEFAULT 0,\n    edge_count INTEGER DEFAULT 0,\n    parse_health TEXT DEFAULT 'clean',\n    indexed_at TEXT NOT NULL,\n    parse_duration_ms INTEGER DEFAULT 0\n  );\n\n  CREATE TABLE IF NOT EXISTS code_nodes (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    symbol_id TEXT NOT NULL UNIQUE,\n    file_id INTEGER NOT NULL REFERENCES code_files(id) ON DELETE CASCADE,\n    file_path TEXT NOT NULL,\n    fq_name TEXT NOT NULL,\n    kind TEXT NOT NULL,\n    name TEXT NOT NULL,\n    start_line INTEGER NOT NULL,\n    end_line INTEGER NOT NULL,\n    start_column INTEGER DEFAULT 0,\n    end_column INTEGER DEFAULT 0,\n    language TEXT NOT NULL,\n    signature TEXT,\n    docstring TEXT,\n    content_hash TEXT NOT NULL\n  );\n\n  CREATE TABLE IF NOT EXISTS code_edges (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_id TEXT NOT NULL,\n    target_id TEXT NOT NULL,\n    edge_type TEXT NOT NULL,\n    weight REAL DEFAULT 1.0,\n    metadata TEXT\n  );\n\n  CREATE TABLE IF NOT EXISTS schema_version (\n    version INTEGER NOT NULL\n  );\n\n  CREATE TABLE IF NOT EXISTS code_graph_metadata (\n    key TEXT PRIMARY KEY,\n    value TEXT NOT NULL,\n    updated_at TEXT NOT NULL\n  );\n\n  CREATE TABLE IF NOT EXISTS parse_diagnostics (\n    file_path TEXT PRIMARY KEY,\n    error_message TEXT NOT NULL,\n    error_count INTEGER NOT NULL DEFAULT 1,\n    last_seen_at TEXT NOT NULL\n  );\n\n  CREATE TABLE IF NOT EXISTS parser_skip_list (\n    file_path     TEXT PRIMARY KEY,\n    error_class   TEXT NOT NULL CHECK (error_class IN ('B1', 'B2', 'OTHER')),\n    error_message TEXT,\n    added_at      TEXT NOT NULL,\n    last_seen_at  TEXT NOT NULL,\n    attempt_count INTEGER NOT NULL DEFAULT 1,\n    source        TEXT NOT NULL CHECK (source IN ('seed', 'runtime'))\n  );\n\n  CREATE INDEX IF NOT EXISTS idx_nodes_file_id ON code_nodes(file_id);\n  CREATE INDEX IF NOT EXISTS idx_nodes_symbol_id ON code_nodes(symbol_id);\n  CREATE INDEX IF NOT EXISTS idx_nodes_kind ON code_nodes(kind);\n  CREATE INDEX IF NOT EXISTS idx_nodes_name ON code_nodes(name);\n  CREATE INDEX IF NOT EXISTS idx_file_line ON code_nodes(file_path, start_line);\n  CREATE INDEX IF NOT EXISTS idx_edges_source ON code_edges(source_id, edge_type);\n  CREATE INDEX IF NOT EXISTS idx_edges_target ON code_edges(target_id, edge_type);\n  CREATE INDEX IF NOT EXISTS idx_edges_type ON code_edges(edge_type);\n  CREATE INDEX IF NOT EXISTS idx_files_path ON code_files(file_path);\n  CREATE INDEX IF NOT EXISTS idx_files_hash ON code_files(content_hash);\n  CREATE INDEX IF NOT EXISTS idx_parse_diagnostics_last_seen ON parse_diagnostics(last_seen_at);\n  CREATE INDEX IF NOT EXISTS idx_parser_skip_list_class ON parser_skip_list(error_class);\n`;\n\nconst CODE_GRAPH_TOMBSTONES_ENV = 'SPECKIT_CODE_GRAPH_TOMBSTONES';\nconst CODE_GRAPH_TOMBSTONE_LIMIT_ENV = 'SPECKIT_CODE_GRAPH_TOMBSTONE_LIMIT';\nconst DEFAULT_TOMBSTONE_LIMIT = 100;\nconst MAX_TOMBSTONE_LIMIT = 10_000;\n\nfunction codeGraphTombstonesEnabled(): boolean {\n  return process.env[CODE_GRAPH_TOMBSTONES_ENV] === 'true';\n}\n\nfunction getCodeGraphTombstoneLimit(): number {\n  const raw = process.env[CODE_GRAPH_TOMBSTONE_LIMIT_ENV];\n  const parsed = raw ? Number.parseInt(raw, 10) : DEFAULT_TOMBSTONE_LIMIT;\n  if (!Number.isFinite(parsed) || parsed <= 0) {\n    return DEFAULT_TOMBSTONE_LIMIT;\n  }\n  return Math.min(Math.trunc(parsed), MAX_TOMBSTONE_LIMIT);\n}\n\nfunction ensureTombstoneSchema(database: Database.Database): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS code_graph_tombstones (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      entity_kind TEXT NOT NULL CHECK (entity_kind IN ('file', 'node', 'edge')),\n      entity_id TEXT,\n      source_id TEXT,\n      target_id TEXT,\n      edge_type TEXT,\n      file_path TEXT,\n      reason TEXT NOT NULL,\n      deleted_at TEXT NOT NULL\n    );\n    CREATE INDEX IF NOT EXISTS idx_code_graph_tombstones_deleted_at ON code_graph_tombstones(deleted_at);\n    CREATE INDEX IF NOT EXISTS idx_code_graph_tombstones_kind_reason ON code_graph_tombstones(entity_kind, reason);\n  `);","lineStart":1,"lineEnd":260,"totalLines":1626,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts","time":{"start":1781128791448,"end":1781128791451}},"metadata":{"openai":{"itemId":"fc_02edcf03c0b9c56d016a29de574ca48191ad213a368c762027"}},"id":"prt_eb38c858e001fRNp7PAcUldzMh","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38c58ec001EvkU1mZu1DUHyY"}}
{"type":"tool_use","timestamp":1781128791461,"sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","part":{"type":"tool","tool":"read","callID":"call_pBC7rmy3t4aBcO7F1cgxIBV2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Cross-Skill Edges Apply Patch\n3: // ───────────────────────────────────────────────────────────────\n4: // Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n5: \n6: import { readFile, writeFile } from 'node:fs/promises';\n7: import { basename, resolve, sep } from 'node:path';\n8: import type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n9: \n10: // ───────────────────────────────────────────────────────────────\n11: // 1. APPLY EDGE\n12: // ───────────────────────────────────────────────────────────────\n13: \n14: const PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n15: \n16: function deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n17:   return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n18: }\n19: \n20: function readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {\n21:   const value = edge.source_kind;\n22:   if (value === 'automated' || value === 'manual' || value === 'trusted') {\n23:     return value;\n24:   }\n25:   return null;\n26: }\n27: \n28: function buildAutomatedReason(candidate: InboundEnhanceCandidate): string {\n29:   return candidate.rules.map(r => `${r.rule}:${r.contribution.toFixed(2)}`).join(' + ');\n30: }\n31: \n32: /**\n33:  * Validate that the source path is a graph-metadata.json file under the trusted skills root.\n34:  * Prevents path traversal in apply mode.\n35:  */\n36: function isPathWithin(candidatePath: string, trustedRoot: string): boolean {\n37:   const resolvedCandidate = resolve(candidatePath);\n38:   const resolvedRoot = resolve(trustedRoot);\n39:   const rootWithSep = resolvedRoot.endsWith(sep) ? resolvedRoot : resolvedRoot + sep;\n40:   return resolvedCandidate.startsWith(rootWithSep) && basename(resolvedCandidate) === 'graph-metadata.json';\n41: }\n42: \n43: /**\n44:  * Apply an enhance edge to the source skill's graph-metadata.json.\n45:  * Idempotent for automated writes and protects manually maintained provenance.\n46:  *\n47:  * @param candidate - The candidate to apply\n48:  * @param skillsRoot - Optional trusted workspace root. When provided, candidate.sourcePath\n49:  *                    MUST resolve under this root and have basename 'graph-metadata.json'.\n50:  * This guards against path traversal in apply mode.\n51:  */\n52: export async function applyEnhanceEdge(\n53:   candidate: InboundEnhanceCandidate,\n54:   skillsRoot?: string,\n55:   writeIntent: EdgeWriteIntent = 'automated',\n56: ): Promise<{ applied: boolean; reason: string }> {\n57:   if (!candidate.applyable) {\n58:     return { applied: false, reason: `not applyable: ${candidate.blockers.join('; ')}` };\n59:   }\n60: \n61:   if (skillsRoot && !isPathWithin(candidate.sourcePath, skillsRoot)) {\n62:     return {\n63:       applied: false,\n64:       reason: `path-boundary violation: ${candidate.sourcePath} not under ${skillsRoot}`,\n65:     };\n66:   }\n67: \n68:   try {\n69:     const raw = await readFile(candidate.sourcePath, 'utf-8');\n70:     const parsed = JSON.parse(raw);\n71: \n72:     if (!parsed.edges) {\n73:       parsed.edges = {};\n74:     }\n75:     if (!parsed.edges.enhances) {\n76:       parsed.edges.enhances = [];\n77:     }\n78: \n79:     const enhances: Array<Record<string, unknown>> = parsed.edges.enhances;\n80:     const sourceKind = deriveSourceKind(writeIntent);\n81:     const existingEdge = enhances.find(e => e.target === candidate.targetSkillId);\n82: \n83:     if (existingEdge && writeIntent === 'automated') {\n84:       const existingSourceKind = readSourceKind(existingEdge);\n85:       if (existingSourceKind && PROTECTED_SOURCE_KINDS.has(existingSourceKind)) {\n86:         return { applied: false, reason: 'edge already exists: manual provenance protected' };\n87:       }\n88:       return { applied: false, reason: 'edge already exists' };\n89:     }\n90: \n91:     if (existingEdge) {\n92:       existingEdge.weight = candidate.weight;\n93:       existingEdge.context = candidate.context;\n94:       existingEdge.source_kind = sourceKind;\n95:       await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n96:       return { applied: true, reason: 'edge updated by trusted maintainer' };\n97:     }\n98: \n99:     const newEdge = {\n100:       target: candidate.targetSkillId,\n101:       weight: candidate.weight,\n102:       context: candidate.context,\n103:       source_kind: sourceKind,\n104:     };\n105: \n106:     if (writeIntent === 'automated') {\n107:       Object.assign(newEdge, {\n108:         auto_added_at: new Date().toISOString(),\n109:         auto_added_reason: buildAutomatedReason(candidate),\n110:       });\n111:     }\n112: \n113:     enhances.push(newEdge);\n114:     parsed.edges.enhances = enhances;\n115: \n116:     await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n117:     return { applied: true, reason: `edge added with ${sourceKind} provenance` };\n118:   } catch (error) {\n119:     const message = error instanceof Error ? error.message : String(error);\n120:     return { applied: false, reason: `failed to apply edge: ${message}` };\n121:   }\n122: }\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Cross-Skill Edges Apply Patch\n// ───────────────────────────────────────────────────────────────\n// Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n\nimport { readFile, writeFile } from 'node:fs/promises';\nimport { basename, resolve, sep } from 'node:path';\nimport type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. APPLY EDGE\n// ───────────────────────────────────────────────────────────────\n\nconst PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n\nfunction deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n  return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n}\n\nfunction readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Cross-Skill Edges Apply Patch\n// ───────────────────────────────────────────────────────────────\n// Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n\nimport { readFile, writeFile } from 'node:fs/promises';\nimport { basename, resolve, sep } from 'node:path';\nimport type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. APPLY EDGE\n// ───────────────────────────────────────────────────────────────\n\nconst PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n\nfunction deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n  return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n}\n\nfunction readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {\n  const value = edge.source_kind;\n  if (value === 'automated' || value === 'manual' || value === 'trusted') {\n    return value;\n  }\n  return null;\n}\n\nfunction buildAutomatedReason(candidate: InboundEnhanceCandidate): string {\n  return candidate.rules.map(r => `${r.rule}:${r.contribution.toFixed(2)}`).join(' + ');\n}\n\n/**\n * Validate that the source path is a graph-metadata.json file under the trusted skills root.\n * Prevents path traversal in apply mode.\n */\nfunction isPathWithin(candidatePath: string, trustedRoot: string): boolean {\n  const resolvedCandidate = resolve(candidatePath);\n  const resolvedRoot = resolve(trustedRoot);\n  const rootWithSep = resolvedRoot.endsWith(sep) ? resolvedRoot : resolvedRoot + sep;\n  return resolvedCandidate.startsWith(rootWithSep) && basename(resolvedCandidate) === 'graph-metadata.json';\n}\n\n/**\n * Apply an enhance edge to the source skill's graph-metadata.json.\n * Idempotent for automated writes and protects manually maintained provenance.\n *\n * @param candidate - The candidate to apply\n * @param skillsRoot - Optional trusted workspace root. When provided, candidate.sourcePath\n *                    MUST resolve under this root and have basename 'graph-metadata.json'.\n * This guards against path traversal in apply mode.\n */\nexport async function applyEnhanceEdge(\n  candidate: InboundEnhanceCandidate,\n  skillsRoot?: string,\n  writeIntent: EdgeWriteIntent = 'automated',\n): Promise<{ applied: boolean; reason: string }> {\n  if (!candidate.applyable) {\n    return { applied: false, reason: `not applyable: ${candidate.blockers.join('; ')}` };\n  }\n\n  if (skillsRoot && !isPathWithin(candidate.sourcePath, skillsRoot)) {\n    return {\n      applied: false,\n      reason: `path-boundary violation: ${candidate.sourcePath} not under ${skillsRoot}`,\n    };\n  }\n\n  try {\n    const raw = await readFile(candidate.sourcePath, 'utf-8');\n    const parsed = JSON.parse(raw);\n\n    if (!parsed.edges) {\n      parsed.edges = {};\n    }\n    if (!parsed.edges.enhances) {\n      parsed.edges.enhances = [];\n    }\n\n    const enhances: Array<Record<string, unknown>> = parsed.edges.enhances;\n    const sourceKind = deriveSourceKind(writeIntent);\n    const existingEdge = enhances.find(e => e.target === candidate.targetSkillId);\n\n    if (existingEdge && writeIntent === 'automated') {\n      const existingSourceKind = readSourceKind(existingEdge);\n      if (existingSourceKind && PROTECTED_SOURCE_KINDS.has(existingSourceKind)) {\n        return { applied: false, reason: 'edge already exists: manual provenance protected' };\n      }\n      return { applied: false, reason: 'edge already exists' };\n    }\n\n    if (existingEdge) {\n      existingEdge.weight = candidate.weight;\n      existingEdge.context = candidate.context;\n      existingEdge.source_kind = sourceKind;\n      await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n      return { applied: true, reason: 'edge updated by trusted maintainer' };\n    }\n\n    const newEdge = {\n      target: candidate.targetSkillId,\n      weight: candidate.weight,\n      context: candidate.context,\n      source_kind: sourceKind,\n    };\n\n    if (writeIntent === 'automated') {\n      Object.assign(newEdge, {\n        auto_added_at: new Date().toISOString(),\n        auto_added_reason: buildAutomatedReason(candidate),\n      });\n    }\n\n    enhances.push(newEdge);\n    parsed.edges.enhances = enhances;\n\n    await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n    return { applied: true, reason: `edge added with ${sourceKind} provenance` };\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    return { applied: false, reason: `failed to apply edge: ${message}` };\n  }\n}","lineStart":1,"lineEnd":122,"totalLines":122,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","time":{"start":1781128791457,"end":1781128791460}},"metadata":{"openai":{"itemId":"fc_02edcf03c0b9c56d016a29de574ca881919dd5dac3cb34de9b"}},"id":"prt_eb38c8598001gPWF0005a7Dzdl","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38c58ec001EvkU1mZu1DUHyY"}}
{"type":"tool_use","timestamp":1781128791476,"sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","part":{"type":"tool","tool":"read","callID":"call_pEA7PHqJymRqOe3G7zMvOzaJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","offset":130,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts</path>\n<type>file</type>\n<content>\n130:   if (!args.attributed) return 'no_lane_attribution_excluded';\n131:   return 'supported_shadow_candidate';\n132: }\n133: \n134: function laneRecords(\n135:   lane: ScorerLane,\n136:   records: readonly AdvisorHookOutcomeRecord[],\n137:   laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n138: ): AdvisorHookOutcomeRecord[] {\n139:   return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n140: }\n141: \n142: export function isAdvisorFeedbackCalibrationEnabled(\n143:   env: Record<string, string | undefined> = process.env,\n144: ): boolean {\n145:   const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n146:   return raw !== undefined && TRUE_VALUES.has(raw);\n147: }\n148: \n149: export function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {\n150:   return process.env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_PATH\n151:     ?? join(RECORD_ROOT, `${workspaceHash(workspaceRoot)}-feedback-calibration.jsonl`);\n152: }\n153: \n154: export function reduceAdvisorFeedbackCalibration(\n155:   records: readonly AdvisorHookOutcomeRecord[],\n156:   options: AdvisorFeedbackCalibrationOptions,\n157: ): AdvisorFeedbackCalibrationReport {\n158:   const minSamples = options.minSamples ?? DEFAULT_MIN_SAMPLES;\n159:   const maxShare = options.maxSkillShare ?? DEFAULT_MAX_SKILL_SHARE;\n160:   const totals = countOutcomes(records);\n161:   const skillShare = round4(maxSkillShare(records));\n162:   const concentrated = records.length > 0 && skillShare > maxShare;\n163:   const laneAttributionBySkill = options.laneAttributionBySkill ?? {};\n164:   const hasAttribution = Object.keys(laneAttributionBySkill).length > 0;\n165:   const weightDeltas: Partial<Record<ScorerLane, number>> = {};\n166: \n167:   const laneSignals = SCORER_LANES.map((lane): AdvisorFeedbackCalibrationLaneSignal => {\n168:     const attributedRecords = laneRecords(lane, records, laneAttributionBySkill);\n169:     const laneTotals = hasAttribution ? countOutcomes(attributedRecords) : totals;\n170:     const sampleCount = hasAttribution ? attributedRecords.length : records.length;\n171:     const reason = signalReason({ sampleCount, minSamples, concentrated, attributed: hasAttribution });\n172:     const status: AdvisorFeedbackCalibrationLaneStatus = reason === 'supported_shadow_candidate' ? 'candidate' : 'excluded';\n173:     const correctionPressure = sampleCount > 0 ? laneTotals.corrected / sampleCount : 0;\n174:     const acceptancePressure = sampleCount > 0 ? laneTotals.accepted / sampleCount : 0;\n175:     const proposedDelta = status === 'candidate' && isLiveScorerLane(lane)\n176:       ? round4(clamp((acceptancePressure - correctionPressure) * MAX_WEIGHT_DELTA, MAX_WEIGHT_DELTA))\n177:       : 0;\n178:     if (proposedDelta !== 0) weightDeltas[lane] = proposedDelta;\n179:     return {\n180:       lane,\n181:       status,\n182:       sampleCount,\n183:       accepted: laneTotals.accepted,\n184:       corrected: laneTotals.corrected,\n185:       ignored: laneTotals.ignored,\n186:       proposedDelta,\n187:       reason,\n188:     };\n189:   });\n190: \n191:   const correctionRate = records.length > 0 ? totals.corrected / records.length : 0;\n192:   const ignoredRate = records.length > 0 ? totals.ignored / records.length : 0;\n193:   const thresholdSignals = records.length < minSamples || concentrated\n194:     ? {\n195:       confidenceThresholdDelta: 0,\n196:       uncertaintyThresholdDelta: 0,\n197:       reason: records.length < minSamples ? 'low_sample_excluded' : 'sample_concentration_excluded',\n198:     }\n199:     : {\n200:       confidenceThresholdDelta: round4(clamp(correctionRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n201:       uncertaintyThresholdDelta: round4(clamp(-ignoredRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n202:       reason: 'supported_shadow_candidate',\n203:     };\n204: \n205:   return {\n206:     model: 'advisor-feedback-calibration-shadow-v1',\n207:     generatedAt: options.generatedAt ?? new Date().toISOString(),\n208:     scope: {\n209:       kind: options.skillSlug === null || options.skillSlug === undefined ? 'workspace' : 'skill',\n210:       skillSlug: options.skillSlug ?? null,\n211:     },\n212:     sample: {\n213:       total: records.length,\n214:       accepted: totals.accepted,\n215:       corrected: totals.corrected,\n216:       ignored: totals.ignored,\n217:       distinctSkills: distinctSkillCount(records),\n218:       maxSkillShare: skillShare,\n219:     },\n220:     laneSignals,\n221:     thresholdSignals,\n222:     proposal: buildReadOnlyScorerCalibrationProposal({\n223:       proposedWeightDeltas: weightDeltas,\n224:       currentThresholds: options.currentThresholds,\n225:       proposedThresholdDeltas: {\n226:         confidenceThreshold: thresholdSignals.confidenceThresholdDelta,\n227:         uncertaintyThreshold: thresholdSignals.uncertaintyThresholdDelta,\n228:       },\n229:     }),\n230:     guardrails: {\n231:       defaultOff: true,\n232:       shadowOnly: true,\n233:       liveWeightsFrozen: true,\n234:       autoPromotion: false,\n235:       heldOutValidationRequired: true,\n236:       noLaneAttributionFallback: !hasAttribution,\n237:     },\n238:   };\n239: }\n240: \n241: export function persistAdvisorFeedbackCalibrationRecord(\n242:   workspaceRoot: string,\n243:   report: AdvisorFeedbackCalibrationReport,\n244: ): string {\n245:   const path = advisorFeedbackCalibrationRecordsPath(workspaceRoot);\n246:   mkdirSync(dirname(path), { recursive: true });\n247:   const existing = existsSync(path)\n248:     ? readFileSync(path, 'utf8').split('\\n').map((line) => line.trim()).filter(Boolean)\n249:     : [];\n250:   existing.push(JSON.stringify(report));\n251:   writeFileSync(path, `${existing.slice(-MAX_RECORDS).join('\\n')}\\n`, 'utf8');\n252:   return path;\n253: }\n254: \n255: export function recordAdvisorFeedbackCalibrationIfEnabled(input: {\n256:   readonly workspaceRoot: string;\n257:   readonly records: readonly AdvisorHookOutcomeRecord[];\n258:   readonly options: AdvisorFeedbackCalibrationOptions;\n259:   readonly env?: Record<string, string | undefined>;\n\n(Showing lines 130-259 of 265. Use offset=260 to continue.)\n</content>","metadata":{"preview":"  if (!args.attributed) return 'no_lane_attribution_excluded';\n  return 'supported_shadow_candidate';\n}\n\nfunction laneRecords(\n  lane: ScorerLane,\n  records: readonly AdvisorHookOutcomeRecord[],\n  laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n): AdvisorHookOutcomeRecord[] {\n  return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n}\n\nexport function isAdvisorFeedbackCalibrationEnabled(\n  env: Record<string, string | undefined> = process.env,\n): boolean {\n  const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n  return raw !== undefined && TRUE_VALUES.has(raw);\n}\n\nexport function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","text":"  if (!args.attributed) return 'no_lane_attribution_excluded';\n  return 'supported_shadow_candidate';\n}\n\nfunction laneRecords(\n  lane: ScorerLane,\n  records: readonly AdvisorHookOutcomeRecord[],\n  laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n): AdvisorHookOutcomeRecord[] {\n  return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n}\n\nexport function isAdvisorFeedbackCalibrationEnabled(\n  env: Record<string, string | undefined> = process.env,\n): boolean {\n  const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n  return raw !== undefined && TRUE_VALUES.has(raw);\n}\n\nexport function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {\n  return process.env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_PATH\n    ?? join(RECORD_ROOT, `${workspaceHash(workspaceRoot)}-feedback-calibration.jsonl`);\n}\n\nexport function reduceAdvisorFeedbackCalibration(\n  records: readonly AdvisorHookOutcomeRecord[],\n  options: AdvisorFeedbackCalibrationOptions,\n): AdvisorFeedbackCalibrationReport {\n  const minSamples = options.minSamples ?? DEFAULT_MIN_SAMPLES;\n  const maxShare = options.maxSkillShare ?? DEFAULT_MAX_SKILL_SHARE;\n  const totals = countOutcomes(records);\n  const skillShare = round4(maxSkillShare(records));\n  const concentrated = records.length > 0 && skillShare > maxShare;\n  const laneAttributionBySkill = options.laneAttributionBySkill ?? {};\n  const hasAttribution = Object.keys(laneAttributionBySkill).length > 0;\n  const weightDeltas: Partial<Record<ScorerLane, number>> = {};\n\n  const laneSignals = SCORER_LANES.map((lane): AdvisorFeedbackCalibrationLaneSignal => {\n    const attributedRecords = laneRecords(lane, records, laneAttributionBySkill);\n    const laneTotals = hasAttribution ? countOutcomes(attributedRecords) : totals;\n    const sampleCount = hasAttribution ? attributedRecords.length : records.length;\n    const reason = signalReason({ sampleCount, minSamples, concentrated, attributed: hasAttribution });\n    const status: AdvisorFeedbackCalibrationLaneStatus = reason === 'supported_shadow_candidate' ? 'candidate' : 'excluded';\n    const correctionPressure = sampleCount > 0 ? laneTotals.corrected / sampleCount : 0;\n    const acceptancePressure = sampleCount > 0 ? laneTotals.accepted / sampleCount : 0;\n    const proposedDelta = status === 'candidate' && isLiveScorerLane(lane)\n      ? round4(clamp((acceptancePressure - correctionPressure) * MAX_WEIGHT_DELTA, MAX_WEIGHT_DELTA))\n      : 0;\n    if (proposedDelta !== 0) weightDeltas[lane] = proposedDelta;\n    return {\n      lane,\n      status,\n      sampleCount,\n      accepted: laneTotals.accepted,\n      corrected: laneTotals.corrected,\n      ignored: laneTotals.ignored,\n      proposedDelta,\n      reason,\n    };\n  });\n\n  const correctionRate = records.length > 0 ? totals.corrected / records.length : 0;\n  const ignoredRate = records.length > 0 ? totals.ignored / records.length : 0;\n  const thresholdSignals = records.length < minSamples || concentrated\n    ? {\n      confidenceThresholdDelta: 0,\n      uncertaintyThresholdDelta: 0,\n      reason: records.length < minSamples ? 'low_sample_excluded' : 'sample_concentration_excluded',\n    }\n    : {\n      confidenceThresholdDelta: round4(clamp(correctionRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n      uncertaintyThresholdDelta: round4(clamp(-ignoredRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n      reason: 'supported_shadow_candidate',\n    };\n\n  return {\n    model: 'advisor-feedback-calibration-shadow-v1',\n    generatedAt: options.generatedAt ?? new Date().toISOString(),\n    scope: {\n      kind: options.skillSlug === null || options.skillSlug === undefined ? 'workspace' : 'skill',\n      skillSlug: options.skillSlug ?? null,\n    },\n    sample: {\n      total: records.length,\n      accepted: totals.accepted,\n      corrected: totals.corrected,\n      ignored: totals.ignored,\n      distinctSkills: distinctSkillCount(records),\n      maxSkillShare: skillShare,\n    },\n    laneSignals,\n    thresholdSignals,\n    proposal: buildReadOnlyScorerCalibrationProposal({\n      proposedWeightDeltas: weightDeltas,\n      currentThresholds: options.currentThresholds,\n      proposedThresholdDeltas: {\n        confidenceThreshold: thresholdSignals.confidenceThresholdDelta,\n        uncertaintyThreshold: thresholdSignals.uncertaintyThresholdDelta,\n      },\n    }),\n    guardrails: {\n      defaultOff: true,\n      shadowOnly: true,\n      liveWeightsFrozen: true,\n      autoPromotion: false,\n      heldOutValidationRequired: true,\n      noLaneAttributionFallback: !hasAttribution,\n    },\n  };\n}\n\nexport function persistAdvisorFeedbackCalibrationRecord(\n  workspaceRoot: string,\n  report: AdvisorFeedbackCalibrationReport,\n): string {\n  const path = advisorFeedbackCalibrationRecordsPath(workspaceRoot);\n  mkdirSync(dirname(path), { recursive: true });\n  const existing = existsSync(path)\n    ? readFileSync(path, 'utf8').split('\\n').map((line) => line.trim()).filter(Boolean)\n    : [];\n  existing.push(JSON.stringify(report));\n  writeFileSync(path, `${existing.slice(-MAX_RECORDS).join('\\n')}\\n`, 'utf8');\n  return path;\n}\n\nexport function recordAdvisorFeedbackCalibrationIfEnabled(input: {\n  readonly workspaceRoot: string;\n  readonly records: readonly AdvisorHookOutcomeRecord[];\n  readonly options: AdvisorFeedbackCalibrationOptions;\n  readonly env?: Record<string, string | undefined>;","lineStart":130,"lineEnd":259,"totalLines":265,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","time":{"start":1781128791473,"end":1781128791475}},"metadata":{"openai":{"itemId":"fc_02edcf03c0b9c56d016a29de574cb48191a9991c80a076523e"}},"id":"prt_eb38c85a3001hGJu56PvuskPrQ","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38c58ec001EvkU1mZu1DUHyY"}}
