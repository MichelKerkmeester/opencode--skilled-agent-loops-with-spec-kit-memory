   631	def _load_source_conflict_declarations() -> Dict[str, Set[str]]:
   632	    """Read per-skill `graph-metadata.json` to recover directional conflict edges.
   633	
   634	    T-SAP-04 (R46-002): defense-in-depth for the runtime conflict penalty. The
   635	    compiled graph's `conflicts` is flattened into undirected pairs, so the
   636	    runtime cannot detect unilateral-declaration asymmetry from that payload
   637	    alone. The compiler's T-SGC-03 symmetry check gates against unilateral
   638	    declarations at build time, but if a compiled graph is shipped that
   639	    bypassed validation (e.g. a legacy JSON artifact), the runtime must
   640	    refuse to penalize a non-declaring skill. This helper replays the
   641	    per-skill `conflicts_with` arrays so the runtime can cross-check.
   642	    """
   643	    _SOURCE_METADATA_DIAGNOSTICS["conflict_declarations"] = []
   644	    declarations: Dict[str, Set[str]] = {}
   645	
   646	    try:
   647	        skill_entries = sorted(os.scandir(SKILLS_DIR), key=lambda entry: entry.name)
   648	    except OSError as exc:
   649	        _record_source_metadata_issue("conflict_declarations", SKILLS_DIR, f"scan_failed:{exc.__class__.__name__}")
   650	        return declarations
   651	
   652	    for entry in skill_entries:
   653	        if not entry.is_dir():
   654	            continue
   655	
   656	        graph_metadata_path = os.path.join(entry.path, "graph-metadata.json")
   657	        if not os.path.exists(graph_metadata_path):
   658	            continue
   659	
   660	        try:
   661	            with open(graph_metadata_path, "r", encoding="utf-8") as handle:
   662	                graph_metadata = json.load(handle)
   663	        except (OSError, ValueError, json.JSONDecodeError) as exc:
   664	            _record_source_metadata_issue("conflict_declarations", graph_metadata_path, f"parse_failed:{exc.__class__.__name__}")
   665	            continue
   666	
   667	        if not isinstance(graph_metadata, dict):
   668	            _record_source_metadata_issue("conflict_declarations", graph_metadata_path, "invalid_shape")
   669	            continue
   670	
   671	        skill_id = str(graph_metadata.get("skill_id") or entry.name)
   672	        edges = graph_metadata.get("edges")
   673	        if not isinstance(edges, dict):
   674	            continue
   675	
   676	        conflicts = edges.get("conflicts_with")
   677	        if not isinstance(conflicts, list):
   678	            continue
   679	
   680	        for edge in conflicts:
   681	            if not isinstance(edge, dict):
   682	                continue
   683	            target = edge.get("target")
   684	            if isinstance(target, str) and target:
   685	                declarations.setdefault(skill_id, set()).add(target)
   686	
   687	    return declarations
   688	
