,html} 2>/dev/null","truncated":true,"loaded":[]},"title":".opencode/skills/sk-code/references/stack_detection.md","time":{"start":1780372964410,"end":1780372964425}},"metadata":{"openai":{"itemId":"fc_09c6db30740bc1d9016a1e55e4536c819194557af6da581283"}},"id":"prt_e867f8438001ZpuzFIv07Pk1fD","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867f6518001oRgjymi2TpCWzu"}}
