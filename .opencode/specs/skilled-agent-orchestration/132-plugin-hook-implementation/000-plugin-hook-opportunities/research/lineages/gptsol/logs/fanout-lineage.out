r = path.resolve(specFolder);\n2696:   const { artifactDir: researchDir } = resolveArtifactRoot(resolvedSpecFolder, 'research');\n2697:   const configPath = path.join(researchDir, 'deep-research-config.json');\n2698:   const stateLogPath = path.join(researchDir, 'deep-research-state.jsonl');\n2699:   const strategyPath = path.join(researchDir, 'deep-research-strategy.md');\n2700:   const registryPath = path.join(researchDir, 'findings-registry.json');\n2701:   const documentedRegistryPath = path.join(researchDir, 'deep-research-findings-registry.json');\n2702:   const dashboardPath = path.join(researchDir, 'deep-research-dashboard.md');\n2703:   const resourceMapPath = path.join(researchDir, 'resource-map.md');\n2704:   const inboxPath = path.join(researchDir, INBOX_FILE_NAME);\n2705:   const iterationDir = path.join(researchDir, 'iterations');\n2706:   const deltaDir = path.join(researchDir, 'deltas');\n2707: \n2708:   const config = readJson(configPath);\n2709:   const { records: parsedRecords, corruptionWarnings } = readStateLogForReduction(stateLogPath, requireExistingState);\n2710:   // Allowlist: only iteration + event types bear completion semantics. Progress\n2711:   // records (type:'progress') are additive liveness signals — they reset the\n2712:   // no-progress watchdog but MUST NOT count as iterations or completion events.\n2713:   const completionBearingRecords = filterCompletionBearingRecords(parsedRecords);\n2714:   const records = completionBearingRecords.filter((record) => record.type === 'iteration');\n2715:   const mainEvents = completionBearingRecords.filter((record) => record.type === 'event');\n2716:   const pivotEvents = loadPivotEventRecords(researchDir);\n2717:   const events = mainEvents.concat(pivotEvents);\n2718:   const strategyContent = readUtf8(strategyPath);\n2719:   const strategyQuestions = parseStrategyQuestions(strategyContent);\n2720:   const inbox = readInboxQuestions(inboxPath);\n2721:   const priorRegistry = readPriorQuestionRegistry(registryPath, documentedRegistryPath);\n2722:   const questionResolution = resolveQuestionConflicts({\n2723:     strategyQuestions,\n2724:     inboxQuestions: inbox.questions,\n2725:     priorRegistry,\n2726:   });\n2727:   const questionInputs = questionResolution.questions;\n2728:   if (write) {\n2729:     warnLegacyImportQuestions(questionInputs);\n2730:   }\n2731:   for (const warning of inbox.warnings) {\n2732:     console.warn(`[deep-research] skipped inbox record: ${warning}`);\n2733:   }\n2734:   const iterationFiles = fs.existsSync(iterationDir)\n2735:     ? fs.readdirSync(iterationDir)\n2736:         .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n2737:         .sort((a, b) => {\n2738:           // Numeric sort on trailing iter number; default .sort() puts iteration-10.md between iteration-1.md and iteration-2.md.\n2739:           const numA = parseInt(a.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n2740:           const numB = parseInt(b.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n2741:           return numA - numB;\n2742:         })\n2743:         .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n2744:     : [];\n2745: \n2746:   const terminalStop = buildTerminalStopState(completionBearingRecords);\n2747:   const lineage = buildLineageState(config, events);\n2748:   config.lineage = {\n2749:     ...(config.lineage && typeof config.lineage === 'object' ? config.lineage : {}),\n2750:     sessionId: lineage.sessionId,\n2751:     parentSessionId: lineage.parentSessionId,\n2752:     lineageMode: lineage.lineageMode,\n2753:     generation: lineage.generation,\n2754:     continuedFromRun: lineage.continuedFromRun,\n2755:   };\n2756:   const status = deriveDashboardStatus(config, records, events, terminalStop);\n2757:   const registry = buildRegistry(questionInputs, iterationFiles, records, events, {\n2758:     lineage,\n2759:     terminalStop,\n2760:     status,\n2761:     questionConflicts: questionResolution.questionConflicts,\n2762:     rejectedPatternFuzzyThreshold: resolveRejectedPatternFuzzyThreshold(config),\n2763:     minIdeaObservations: resolveMinIdeaObservations(config),\n2764:   });\n2765:   // Expose corruptionWarnings as a top-level registry field for parity with\n2766:   // deep-review.\n2767:   registry.corruptionWarnings = corruptionWarnings;\n2768:   registry.inboxPath = inboxPath;\n2769:   registry.inboxWarnings = inbox.warnings;\n2770:   registry.status = status;\n2771:   if (write) {\n2772:     for (const warning of registry.rejectedPatternWarnings) {\n2773:       console.warn(warning);\n2774:     }\n2775:   }\n2776:   const evidenceRecords = records.filter((record) => record.status !== 'thought');\n2777:   const ratioHistory = evidenceRecords\n2778:     .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n2779:     .filter((value) => value !== null);\n2780:   const scoreHistory = evidenceRecords\n2781:     .map(readIterationScore)\n2782:     .filter(isFiniteNumber);\n2783:   registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n2784:     newInfoRatio: ratioHistory,\n2785:     score: scoreHistory,\n2786:   }, evidenceRecords.at(-1));\n2787:   const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n2788:   const dashboard = renderDashboard(config, registry, records, iterationFiles);\n2789:   let resourceMap = null;\n\n(Showing lines 2670-2789 of 2940. Use offset=2790 to continue.)\n</content>","metadata":{"preview":"    `- graphConvergenceScore: ${Number.isFinite(registry.graphConvergenceScore) ? registry.graphConvergenceScore.toFixed(2) : '[Not recorded]'}`,\n    `- graphDecision: ${registry.graphDecision || '[Not recorded]'}`,\n    ...(registry.graphBlockers.length\n      ? registry.graphBlockers.map((blocker) => `- Blocker: ${formatGraphBlocker(blocker)}`)\n      : ['- graphBlockers: none recorded']),\n    '',\n    '<!-- /ANCHOR:graph-convergence -->',\n    '',\n  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the research packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard\n */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","text":"    `- graphConvergenceScore: ${Number.isFinite(registry.graphConvergenceScore) ? registry.graphConvergenceScore.toFixed(2) : '[Not recorded]'}`,\n    `- graphDecision: ${registry.graphDecision || '[Not recorded]'}`,\n    ...(registry.graphBlockers.length\n      ? registry.graphBlockers.map((blocker) => `- Blocker: ${formatGraphBlocker(blocker)}`)\n      : ['- graphBlockers: none recorded']),\n    '',\n    '<!-- /ANCHOR:graph-convergence -->',\n    '',\n  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the research packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard\n */\nfunction reduceResearchState(specFolder, options = {}) {\n  const write = options.write !== false;\n  const lenient = Boolean(options.lenient);\n  const emitResourceMapOutput = Boolean(options.emitResourceMap);\n  const requireExistingState = Boolean(options.requireExistingState);\n  const resolvedSpecFolder = path.resolve(specFolder);\n  const { artifactDir: researchDir } = resolveArtifactRoot(resolvedSpecFolder, 'research');\n  const configPath = path.join(researchDir, 'deep-research-config.json');\n  const stateLogPath = path.join(researchDir, 'deep-research-state.jsonl');\n  const strategyPath = path.join(researchDir, 'deep-research-strategy.md');\n  const registryPath = path.join(researchDir, 'findings-registry.json');\n  const documentedRegistryPath = path.join(researchDir, 'deep-research-findings-registry.json');\n  const dashboardPath = path.join(researchDir, 'deep-research-dashboard.md');\n  const resourceMapPath = path.join(researchDir, 'resource-map.md');\n  const inboxPath = path.join(researchDir, INBOX_FILE_NAME);\n  const iterationDir = path.join(researchDir, 'iterations');\n  const deltaDir = path.join(researchDir, 'deltas');\n\n  const config = readJson(configPath);\n  const { records: parsedRecords, corruptionWarnings } = readStateLogForReduction(stateLogPath, requireExistingState);\n  // Allowlist: only iteration + event types bear completion semantics. Progress\n  // records (type:'progress') are additive liveness signals — they reset the\n  // no-progress watchdog but MUST NOT count as iterations or completion events.\n  const completionBearingRecords = filterCompletionBearingRecords(parsedRecords);\n  const records = completionBearingRecords.filter((record) => record.type === 'iteration');\n  const mainEvents = completionBearingRecords.filter((record) => record.type === 'event');\n  const pivotEvents = loadPivotEventRecords(researchDir);\n  const events = mainEvents.concat(pivotEvents);\n  const strategyContent = readUtf8(strategyPath);\n  const strategyQuestions = parseStrategyQuestions(strategyContent);\n  const inbox = readInboxQuestions(inboxPath);\n  const priorRegistry = readPriorQuestionRegistry(registryPath, documentedRegistryPath);\n  const questionResolution = resolveQuestionConflicts({\n    strategyQuestions,\n    inboxQuestions: inbox.questions,\n    priorRegistry,\n  });\n  const questionInputs = questionResolution.questions;\n  if (write) {\n    warnLegacyImportQuestions(questionInputs);\n  }\n  for (const warning of inbox.warnings) {\n    console.warn(`[deep-research] skipped inbox record: ${warning}`);\n  }\n  const iterationFiles = fs.existsSync(iterationDir)\n    ? fs.readdirSync(iterationDir)\n        .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n        .sort((a, b) => {\n          // Numeric sort on trailing iter number; default .sort() puts iteration-10.md between iteration-1.md and iteration-2.md.\n          const numA = parseInt(a.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n          const numB = parseInt(b.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n          return numA - numB;\n        })\n        .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n    : [];\n\n  const terminalStop = buildTerminalStopState(completionBearingRecords);\n  const lineage = buildLineageState(config, events);\n  config.lineage = {\n    ...(config.lineage && typeof config.lineage === 'object' ? config.lineage : {}),\n    sessionId: lineage.sessionId,\n    parentSessionId: lineage.parentSessionId,\n    lineageMode: lineage.lineageMode,\n    generation: lineage.generation,\n    continuedFromRun: lineage.continuedFromRun,\n  };\n  const status = deriveDashboardStatus(config, records, events, terminalStop);\n  const registry = buildRegistry(questionInputs, iterationFiles, records, events, {\n    lineage,\n    terminalStop,\n    status,\n    questionConflicts: questionResolution.questionConflicts,\n    rejectedPatternFuzzyThreshold: resolveRejectedPatternFuzzyThreshold(config),\n    minIdeaObservations: resolveMinIdeaObservations(config),\n  });\n  // Expose corruptionWarnings as a top-level registry field for parity with\n  // deep-review.\n  registry.corruptionWarnings = corruptionWarnings;\n  registry.inboxPath = inboxPath;\n  registry.inboxWarnings = inbox.warnings;\n  registry.status = status;\n  if (write) {\n    for (const warning of registry.rejectedPatternWarnings) {\n      console.warn(warning);\n    }\n  }\n  const evidenceRecords = records.filter((record) => record.status !== 'thought');\n  const ratioHistory = evidenceRecords\n    .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n    .filter((value) => value !== null);\n  const scoreHistory = evidenceRecords\n    .map(readIterationScore)\n    .filter(isFiniteNumber);\n  registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n    newInfoRatio: ratioHistory,\n    score: scoreHistory,\n  }, evidenceRecords.at(-1));\n  const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n  const dashboard = renderDashboard(config, registry, records, iterationFiles);\n  let resourceMap = null;","lineStart":2670,"lineEnd":2789,"totalLines":2940,"truncated":true}},"title":".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","time":{"start":1783744141290,"end":1783744141296}},"metadata":{"openai":{"itemId":"fc_08a3ca3c1ab97a23016a51c68d2b9081919e424b3b1a7880e0"}},"id":"prt_f4f6f97de001m3q5lBWdMyqKUD","sessionID":"ses_0b0929e3affe1FHkKX9E1sdw9Y","messageID":"msg_f4f6f77ec001MPJKt5UQCFLw6X"}}
{"type":"tool_use","timestamp":1783744141339,"sessionID":"ses_0b0929e3affe1FHkKX9E1sdw9Y","part":{"type":"tool","tool":"read","callID":"call_V9y48or21v0NqJfgXx0VCMDq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts","offset":1,"limit":250},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Executor Config\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: import { z } from 'zod';\n6: \n7: // ───────────────────────────────────────────────────────────────────\n8: // 1. TYPE DEFINITIONS\n9: // ───────────────────────────────────────────────────────────────────\n10: \n11: export const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\n12: export type ExecutorKind = typeof EXECUTOR_KINDS[number];\n13: \n14: export const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\n15: export type ReasoningEffort = typeof REASONING_EFFORTS[number];\n16: \n17: export const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\n18: export type ServiceTier = typeof SERVICE_TIERS[number];\n19: \n20: /** Fan-out assignment models accepted by the schema. */\n21: export const FANOUT_ASSIGNMENT_MODELS = ['flat_pool', 'wave'] as const;\n22: \n23: /** Fan-out assignment model selected for a lineage or fan-out block. */\n24: export type FanoutAssignmentModel = typeof FANOUT_ASSIGNMENT_MODELS[number];\n25: \n26: const SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;\n27: export type SandboxMode = typeof SANDBOX_MODES[number];\n28: export type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';\n29: \n30: // ───────────────────────────────────────────────────────────────────\n31: // 2. CONSTANTS\n32: // ───────────────────────────────────────────────────────────────────\n33: \n34: export const executorConfigSchema = z.object({\n35:   kind: z.enum(EXECUTOR_KINDS).default('native'),\n36:   model: z.string().min(1).nullable().default(null),\n37:   configDir: z.string().trim().min(1).nullable().default(null),\n38:   reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),\n39:   serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),\n40:   sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),\n41:   timeoutSeconds: z.number().int().positive().default(900),\n42:   // Optional fable-5 governor capsule for this executor's prompts. Universal and\n43:   // kind-agnostic on purpose: intentionally absent from EXECUTOR_KIND_FLAG_SUPPORT\n44:   // and the unsupported-field scan, so any executor kind may carry it. null = none.\n45:   governor: z.string().min(1).nullable().default(null),\n46: });\n47: \n48: export type ExecutorConfig = z.infer<typeof executorConfigSchema>;\n49: \n50: export const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {\n51:   native: [],\n52:   'cli-claude-code': ['model', 'configDir', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n53:   'cli-opencode': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n54: };\n55: \n56: // ───────────────────────────────────────────────────────────────────\n57: // 3. DOMAIN ERRORS\n58: // ───────────────────────────────────────────────────────────────────\n59: \n60: type ExecutorConfigIssue = {\n61:   path: PropertyKey[];\n62:   message: string;\n63: };\n64: \n65: /** Error thrown when a reserved executor kind is selected before wiring exists. */\n66: export class ExecutorNotWiredError extends Error {\n67:   kind: Extract<ExecutorKind, 'cli-claude-code'>;\n68: \n69:   constructor(kind: Extract<ExecutorKind, 'cli-claude-code'>) {\n70:     super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);\n71:     this.name = 'ExecutorNotWiredError';\n72:     this.kind = kind;\n73:   }\n74: }\n75: \n76: /** Error thrown when executor configuration validation fails. */\n77: export class ExecutorConfigError extends Error {\n78:   issues: ExecutorConfigIssue[];\n79: \n80:   constructor(input: { issues: ExecutorConfigIssue[] }) {\n81:     super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));\n82:     this.name = 'ExecutorConfigError';\n83:     this.issues = input.issues;\n84:   }\n85: }\n86: \n87: // ───────────────────────────────────────────────────────────────────\n88: // 4. HELPERS\n89: // ───────────────────────────────────────────────────────────────────\n90: \n91: function isRecord(value: unknown): value is Record<string, unknown> {\n92:   return value !== null && !Array.isArray(value) && typeof value === 'object';\n93: }\n94: \n95: function normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n96:   return mode ?? 'workspace-write';\n97: }\n98: \n99: function normalizeExecutorConfigInput(raw: unknown): unknown {\n100:   if (!isRecord(raw) || !Object.prototype.hasOwnProperty.call(raw, 'type')) {\n101:     return raw;\n102:   }\n103: \n104:   const legacyKind = raw.type;\n105:   if (typeof legacyKind !== 'string') {\n106:     return raw;\n107:   }\n108: \n109:   if (typeof raw.kind === 'string' && raw.kind !== legacyKind) {\n110:     throw new ExecutorConfigError({\n111:       issues: [{\n112:         path: ['type'],\n113:         message: `deprecated executor field 'type' conflicts with canonical kind '${raw.kind}'`,\n114:       }],\n115:     });\n116:   }\n117: \n118:   console.warn(\"[executor-config] Deprecated executor field 'type' was provided; use 'kind' instead.\");\n119:   const { type: _legacyType, ...rest } = raw;\n120:   return {\n121:     ...rest,\n122:     kind: typeof raw.kind === 'string' ? raw.kind : legacyKind,\n123:   };\n124: }\n125: \n126: function normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {\n127:   return error.issues.map((issue) => ({\n128:     path: issue.path,\n129:     message: issue.message,\n130:   }));\n131: }\n132: \n133: // ───────────────────────────────────────────────────────────────────\n134: // 5. EXPORTS\n135: // ───────────────────────────────────────────────────────────────────\n136: \n137: /**\n138:  * Map a generic sandbox mode to the executor-agnostic CLI sandbox mode.\n139:  *\n140:  * @param mode - Generic sandbox mode or undefined.\n141:  * @returns CLI-compatible sandbox mode.\n142:  */\n143: export function resolveSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n144:   return normalizeSandboxMode(mode);\n145: }\n146: \n147: /**\n148:  * Map a generic sandbox mode to the Claude Code permission mode.\n149:  *\n150:  * @param mode - Generic sandbox mode or undefined.\n151:  * @returns Claude-compatible permission mode.\n152:  */\n153: export function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {\n154:   switch (normalizeSandboxMode(mode)) {\n155:     case 'read-only':\n156:       return 'plan';\n157:     case 'danger-full-access':\n158:       return 'bypassPermissions';\n159:     default:\n160:       return 'acceptEdits';\n161:   }\n162: }\n163: \n164: /**\n165:  * Parse and validate a raw executor configuration.\n166:  *\n167:  * Normalizes legacy `type` fields, validates against the Zod schema,\n168:  * and enforces executor-kind-specific field support.\n169:  *\n170:  * @param raw - Raw input to parse (JSON-parsed object).\n171:  * @returns Validated ExecutorConfig.\n172:  * @throws {@link ExecutorConfigError} If validation fails.\n173:  */\n174: export function parseExecutorConfig(raw: unknown): ExecutorConfig {\n175:   const parsed = executorConfigSchema.safeParse(normalizeExecutorConfigInput(raw));\n176:   if (!parsed.success) {\n177:     throw new ExecutorConfigError({\n178:       issues: normalizeIssues(parsed.error),\n179:     });\n180:   }\n181: \n182:   const config = parsed.data;\n183:   const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];\n184:   const unsupportedFields: string[] = [];\n185:   const allOptionalFields: (keyof ExecutorConfig)[] = [\n186:     'model',\n187:     'configDir',\n188:     'reasoningEffort',\n189:     'serviceTier',\n190:     'sandboxMode',\n191:     'timeoutSeconds',\n192:   ];\n193: \n194:   for (const field of allOptionalFields) {\n195:     if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {\n196:       unsupportedFields.push(field);\n197:     }\n198:   }\n199: \n200:   if (unsupportedFields.length > 0) {\n201:     throw new ExecutorConfigError({\n202:       issues: unsupportedFields.map((field) => ({\n203:         path: [field],\n204:         message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${\n205:           supportedFlags.length ? supportedFlags.join(', ') : 'none'\n206:         }.`,\n207:       })),\n208:     });\n209:   }\n210: \n211:   return config;\n212: }\n213: \n214: /**\n215:  * Resolve an executor configuration by merging CLI and file sources.\n216:  *\n217:  * @param sources - CLI and file partial configs (CLI takes precedence).\n218:  * @returns Validated ExecutorConfig.\n219:  */\n220: export function resolveExecutorConfig(sources: {\n221:   cli?: Partial<ExecutorConfig>;\n222:   file?: Partial<ExecutorConfig>;\n223: }): ExecutorConfig {\n224:   const merged = {\n225:     ...(sources.file ?? {}),\n226:     ...(sources.cli ?? {}),\n227:   };\n228:   return parseExecutorConfig(merged);\n229: }\n230: \n231: // ───────────────────────────────────────────────────────────────────\n232: // 6. FAN-OUT CONFIG\n233: // ───────────────────────────────────────────────────────────────────\n234: //\n235: // Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n236: // the loop runs N executor \"lineages\" concurrently (capped), each running the\n237: // existing sequential loop in its own isolated sub-packet. The single-executor\n238: // path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n239: // default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n240: \n241: const LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n242: \n243: /**\n244:  * One fan-out lineage: a single executor config plus fan-out metadata.\n245:  *\n246:  * - `label`: directory-safe id for the lineage's isolated sub-packet.\n247:  * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n248:  * - `iterations`: per-lineage max-iterations override; null = packet default.\n249:  * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n250:  *   \"tidd-ec\") resolved against sk-prompt/prompt-models when a consumer renders the\n\n(Showing lines 1-250 of 376. Use offset=251 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Executor Config\n// ───────────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\nexport type ExecutorKind = typeof EXECUTOR_KINDS[number];\n\nexport const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\nexport type ReasoningEffort = typeof REASONING_EFFORTS[number];\n\nexport const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\nexport type ServiceTier = typeof SERVICE_TIERS[number];\n\n/** Fan-out assignment models accepted by the schema. */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Executor Config\n// ───────────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\nexport type ExecutorKind = typeof EXECUTOR_KINDS[number];\n\nexport const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\nexport type ReasoningEffort = typeof REASONING_EFFORTS[number];\n\nexport const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\nexport type ServiceTier = typeof SERVICE_TIERS[number];\n\n/** Fan-out assignment models accepted by the schema. */\nexport const FANOUT_ASSIGNMENT_MODELS = ['flat_pool', 'wave'] as const;\n\n/** Fan-out assignment model selected for a lineage or fan-out block. */\nexport type FanoutAssignmentModel = typeof FANOUT_ASSIGNMENT_MODELS[number];\n\nconst SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;\nexport type SandboxMode = typeof SANDBOX_MODES[number];\nexport type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';\n\n// ───────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────────\n\nexport const executorConfigSchema = z.object({\n  kind: z.enum(EXECUTOR_KINDS).default('native'),\n  model: z.string().min(1).nullable().default(null),\n  configDir: z.string().trim().min(1).nullable().default(null),\n  reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),\n  serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),\n  sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),\n  timeoutSeconds: z.number().int().positive().default(900),\n  // Optional fable-5 governor capsule for this executor's prompts. Universal and\n  // kind-agnostic on purpose: intentionally absent from EXECUTOR_KIND_FLAG_SUPPORT\n  // and the unsupported-field scan, so any executor kind may carry it. null = none.\n  governor: z.string().min(1).nullable().default(null),\n});\n\nexport type ExecutorConfig = z.infer<typeof executorConfigSchema>;\n\nexport const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {\n  native: [],\n  'cli-claude-code': ['model', 'configDir', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n  'cli-opencode': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n};\n\n// ───────────────────────────────────────────────────────────────────\n// 3. DOMAIN ERRORS\n// ───────────────────────────────────────────────────────────────────\n\ntype ExecutorConfigIssue = {\n  path: PropertyKey[];\n  message: string;\n};\n\n/** Error thrown when a reserved executor kind is selected before wiring exists. */\nexport class ExecutorNotWiredError extends Error {\n  kind: Extract<ExecutorKind, 'cli-claude-code'>;\n\n  constructor(kind: Extract<ExecutorKind, 'cli-claude-code'>) {\n    super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);\n    this.name = 'ExecutorNotWiredError';\n    this.kind = kind;\n  }\n}\n\n/** Error thrown when executor configuration validation fails. */\nexport class ExecutorConfigError extends Error {\n  issues: ExecutorConfigIssue[];\n\n  constructor(input: { issues: ExecutorConfigIssue[] }) {\n    super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));\n    this.name = 'ExecutorConfigError';\n    this.issues = input.issues;\n  }\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return value !== null && !Array.isArray(value) && typeof value === 'object';\n}\n\nfunction normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n  return mode ?? 'workspace-write';\n}\n\nfunction normalizeExecutorConfigInput(raw: unknown): unknown {\n  if (!isRecord(raw) || !Object.prototype.hasOwnProperty.call(raw, 'type')) {\n    return raw;\n  }\n\n  const legacyKind = raw.type;\n  if (typeof legacyKind !== 'string') {\n    return raw;\n  }\n\n  if (typeof raw.kind === 'string' && raw.kind !== legacyKind) {\n    throw new ExecutorConfigError({\n      issues: [{\n        path: ['type'],\n        message: `deprecated executor field 'type' conflicts with canonical kind '${raw.kind}'`,\n      }],\n    });\n  }\n\n  console.warn(\"[executor-config] Deprecated executor field 'type' was provided; use 'kind' instead.\");\n  const { type: _legacyType, ...rest } = raw;\n  return {\n    ...rest,\n    kind: typeof raw.kind === 'string' ? raw.kind : legacyKind,\n  };\n}\n\nfunction normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {\n  return error.issues.map((issue) => ({\n    path: issue.path,\n    message: issue.message,\n  }));\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 5. EXPORTS\n// ───────────────────────────────────────────────────────────────────\n\n/**\n * Map a generic sandbox mode to the executor-agnostic CLI sandbox mode.\n *\n * @param mode - Generic sandbox mode or undefined.\n * @returns CLI-compatible sandbox mode.\n */\nexport function resolveSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n  return normalizeSandboxMode(mode);\n}\n\n/**\n * Map a generic sandbox mode to the Claude Code permission mode.\n *\n * @param mode - Generic sandbox mode or undefined.\n * @returns Claude-compatible permission mode.\n */\nexport function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {\n  switch (normalizeSandboxMode(mode)) {\n    case 'read-only':\n      return 'plan';\n    case 'danger-full-access':\n      return 'bypassPermissions';\n    default:\n      return 'acceptEdits';\n  }\n}\n\n/**\n * Parse and validate a raw executor configuration.\n *\n * Normalizes legacy `type` fields, validates against the Zod schema,\n * and enforces executor-kind-specific field support.\n *\n * @param raw - Raw input to parse (JSON-parsed object).\n * @returns Validated ExecutorConfig.\n * @throws {@link ExecutorConfigError} If validation fails.\n */\nexport function parseExecutorConfig(raw: unknown): ExecutorConfig {\n  const parsed = executorConfigSchema.safeParse(normalizeExecutorConfigInput(raw));\n  if (!parsed.success) {\n    throw new ExecutorConfigError({\n      issues: normalizeIssues(parsed.error),\n    });\n  }\n\n  const config = parsed.data;\n  const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];\n  const unsupportedFields: string[] = [];\n  const allOptionalFields: (keyof ExecutorConfig)[] = [\n    'model',\n    'configDir',\n    'reasoningEffort',\n    'serviceTier',\n    'sandboxMode',\n    'timeoutSeconds',\n  ];\n\n  for (const field of allOptionalFields) {\n    if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {\n      unsupportedFields.push(field);\n    }\n  }\n\n  if (unsupportedFields.length > 0) {\n    throw new ExecutorConfigError({\n      issues: unsupportedFields.map((field) => ({\n        path: [field],\n        message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${\n          supportedFlags.length ? supportedFlags.join(', ') : 'none'\n        }.`,\n      })),\n    });\n  }\n\n  return config;\n}\n\n/**\n * Resolve an executor configuration by merging CLI and file sources.\n *\n * @param sources - CLI and file partial configs (CLI takes precedence).\n * @returns Validated ExecutorConfig.\n */\nexport function resolveExecutorConfig(sources: {\n  cli?: Partial<ExecutorConfig>;\n  file?: Partial<ExecutorConfig>;\n}): ExecutorConfig {\n  const merged = {\n    ...(sources.file ?? {}),\n    ...(sources.cli ?? {}),\n  };\n  return parseExecutorConfig(merged);\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 6. FAN-OUT CONFIG\n// ───────────────────────────────────────────────────────────────────\n//\n// Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n// the loop runs N executor \"lineages\" concurrently (capped), each running the\n// existing sequential loop in its own isolated sub-packet. The single-executor\n// path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n// default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n\nconst LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n\n/**\n * One fan-out lineage: a single executor config plus fan-out metadata.\n *\n * - `label`: directory-safe id for the lineage's isolated sub-packet.\n * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n * - `iterations`: per-lineage max-iterations override; null = packet default.\n * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n *   \"tidd-ec\") resolved against sk-prompt/prompt-models when a consumer renders the","lineStart":1,"lineEnd":250,"totalLines":376,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts","time":{"start":1783744141336,"end":1783744141338}},"metadata":{"openai":{"itemId":"fc_08a3ca3c1ab97a23016a51c68d2b988191ad6bf09b601dda5b"}},"id":"prt_f4f6f97ec001kP9eQ0SiAhtZ9o","sessionID":"ses_0b0929e3affe1FHkKX9E1sdw9Y","messageID":"msg_f4f6f77ec001MPJKt5UQCFLw6X"}}
{"type":"tool_use","timestamp":1783744141409,"sessionID":"ses_0b0929e3affe1FHkKX9E1sdw9Y","part":{"type":"tool","tool":"read","callID":"call_NdDNea38FRE6eg695faXwTmz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts","offset":1,"limit":250},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts</path>\n<type>file</type>\n<content>\n1: // MODULE: Deep-Loop Prompt Pack Renderer\n2: \n3: import { readFileSync } from 'node:fs';\n4: import { z } from 'zod';\n5: \n6: // ───── TYPE DEFINITIONS ─────\n7: \n8: export type PromptPackVariables = Record<string, string | number>;\n9: \n10: // ───── CONSTANTS ─────\n11: \n12: const PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\n13: const promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n14: \n15: // ───── DOMAIN ERRORS ─────\n16: \n17: export class PromptPackError extends Error {\n18:   missingVariables: string[];\n19: \n20:   constructor(missingVariables: string[]) {\n21:     super(`Missing prompt pack variables: ${missingVariables.join(', ')}`);\n22:     this.name = 'PromptPackError';\n23:     this.missingVariables = missingVariables;\n24:   }\n25: }\n26: \n27: // ───── HELPERS ─────\n28: \n29: function extractTemplateTokens(template: string): string[] {\n30:   const tokens = new Set<string>();\n31: \n32:   for (const match of template.matchAll(PROMPT_PACK_TOKEN_PATTERN)) {\n33:     const tokenName = match[1];\n34:     if (promptPackVariableNameSchema.safeParse(tokenName).success) {\n35:       tokens.add(tokenName);\n36:     }\n37:   }\n38: \n39:   return [...tokens];\n40: }\n41: \n42: // ───── EXPORTS ─────\n43: \n44: /**\n45:  * Render a prompt pack template by substituting variables.\n46:  *\n47:  * Reads the template file and replaces all `{variableName}` tokens\n48:  * with values from the variables map.\n49:  *\n50:  * @param templatePath - Path to the prompt pack template file.\n51:  * @param variables - Mapping of variable names to replacement values.\n52:  * @returns Rendered template string with all variables substituted.\n53:  * @throws {@link PromptPackError} If any required variables are missing.\n54:  */\n55: export function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {\n56:   const template = readFileSync(templatePath, 'utf8');\n57:   const missingVariables = new Set<string>();\n58: \n59:   const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {\n60:     if (!(tokenName in variables)) {\n61:       missingVariables.add(tokenName);\n62:       return `{${tokenName}}`;\n63:     }\n64: \n65:     return String(variables[tokenName]);\n66:   });\n67: \n68:   if (missingVariables.size > 0) {\n69:     throw new PromptPackError([...missingVariables]);\n70:   }\n71: \n72:   return rendered;\n73: }\n74: \n75: /**\n76:  * Validate that a prompt pack template contains expected variables.\n77:  *\n78:  * @param templatePath - Path to the prompt pack template file.\n79:  * @param expectedVariables - Variable names that should be present.\n80:  * @returns Report with present, missing, and extra variables.\n81:  */\n82: export function validatePromptPackTemplate(\n83:   templatePath: string,\n84:   expectedVariables: string[],\n85: ): { present: string[]; missing: string[]; extra: string[] } {\n86:   const template = readFileSync(templatePath, 'utf8');\n87:   const templateTokens = extractTemplateTokens(template);\n88:   const templateTokenSet = new Set(templateTokens);\n89:   const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));\n90: \n91:   return {\n92:     present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),\n93:     missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),\n94:     extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),\n95:   };\n96: }\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"// MODULE: Deep-Loop Prompt Pack Renderer\n\nimport { readFileSync } from 'node:fs';\nimport { z } from 'zod';\n\n// ───── TYPE DEFINITIONS ─────\n\nexport type PromptPackVariables = Record<string, string | number>;\n\n// ───── CONSTANTS ─────\n\nconst PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\nconst promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n\n// ───── DOMAIN ERRORS ─────\n\nexport class PromptPackError extends Error {\n  missingVariables: string[];\n\n  constructor(missingVariables: string[]) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts","text":"// MODULE: Deep-Loop Prompt Pack Renderer\n\nimport { readFileSync } from 'node:fs';\nimport { z } from 'zod';\n\n// ───── TYPE DEFINITIONS ─────\n\nexport type PromptPackVariables = Record<string, string | number>;\n\n// ───── CONSTANTS ─────\n\nconst PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\nconst promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n\n// ───── DOMAIN ERRORS ─────\n\nexport class PromptPackError extends Error {\n  missingVariables: string[];\n\n  constructor(missingVariables: string[]) {\n    super(`Missing prompt pack variables: ${missingVariables.join(', ')}`);\n    this.name = 'PromptPackError';\n    this.missingVariables = missingVariables;\n  }\n}\n\n// ───── HELPERS ─────\n\nfunction extractTemplateTokens(template: string): string[] {\n  const tokens = new Set<string>();\n\n  for (const match of template.matchAll(PROMPT_PACK_TOKEN_PATTERN)) {\n    const tokenName = match[1];\n    if (promptPackVariableNameSchema.safeParse(tokenName).success) {\n      tokens.add(tokenName);\n    }\n  }\n\n  return [...tokens];\n}\n\n// ───── EXPORTS ─────\n\n/**\n * Render a prompt pack template by substituting variables.\n *\n * Reads the template file and replaces all `{variableName}` tokens\n * with values from the variables map.\n *\n * @param templatePath - Path to the prompt pack template file.\n * @param variables - Mapping of variable names to replacement values.\n * @returns Rendered template string with all variables substituted.\n * @throws {@link PromptPackError} If any required variables are missing.\n */\nexport function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {\n  const template = readFileSync(templatePath, 'utf8');\n  const missingVariables = new Set<string>();\n\n  const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {\n    if (!(tokenName in variables)) {\n      missingVariables.add(tokenName);\n      return `{${tokenName}}`;\n    }\n\n    return String(variables[tokenName]);\n  });\n\n  if (missingVariables.size > 0) {\n    throw new PromptPackError([...missingVariables]);\n  }\n\n  return rendered;\n}\n\n/**\n * Validate that a prompt pack template contains expected variables.\n *\n * @param templatePath - Path to the prompt pack template file.\n * @param expectedVariables - Variable names that should be present.\n * @returns Report with present, missing, and extra variables.\n */\nexport function validatePromptPackTemplate(\n  templatePath: string,\n  expectedVariables: string[],\n): { present: string[]; missing: string[]; extra: string[] } {\n  const template = readFileSync(templatePath, 'utf8');\n  const templateTokens = extractTemplateTokens(template);\n  const templateTokenSet = new Set(templateTokens);\n  const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));\n\n  return {\n    present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),\n    missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),\n    extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),\n  };\n}","lineStart":1,"lineEnd":96,"totalLines":96,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts","time":{"start":1783744141399,"end":1783744141407}},"metadata":{"openai":{"itemId":"fc_08a3ca3c1ab97a23016a51c68d2b9c8191903b88462ed27d91"}},"id":"prt_f4f6f9848001OBbxkUHpHmwsgD","sessionID":"ses_0b0929e3affe1FHkKX9E1sdw9Y","messageID":"msg_f4f6f77ec001MPJKt5UQCFLw6X"}}
