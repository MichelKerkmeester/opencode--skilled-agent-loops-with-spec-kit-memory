n341: \n342:   const projection = getActiveProjection(database, logicalKey);\n343:   const rows = database.prepare(`\n344:     SELECT *\n345:     FROM memory_lineage\n346:     WHERE logical_key = ?\n347:     ORDER BY version_number ASC, created_at ASC\n348:   `).all(logicalKey) as MemoryLineageRow[];\n349: \n350:   return { logicalKey, projection, rows };\n351: }\n352: \n353: function isLogicalVersionConflict(error: unknown): boolean {\n354:   const message = error instanceof Error\n355:     ? error.message\n356:     : typeof error === 'object' && error !== null && typeof Reflect.get(error, 'message') === 'string'\n357:       ? String(Reflect.get(error, 'message'))\n358:       : String(error);\n359:   const code = typeof error === 'object' && error !== null && typeof Reflect.get(error, 'code') === 'string'\n360:     ? String(Reflect.get(error, 'code'))\n361:     : '';\n362: \n363:   return (\n364:     (code.includes('SQLITE_CONSTRAINT') || message.includes('SQLITE_CONSTRAINT') || message.includes('UNIQUE constraint failed'))\n365:     && message.includes('memory_lineage.logical_key')\n366:     && message.includes('memory_lineage.version_number')\n367:   );\n368: }\n369: \n370: function buildMetadata(\n371:   row: MemoryIndexRow,\n372:   actor: string,\n373:   historyEvents: HistoryLineageEvent[] = [],\n374: ): string {\n375:   // D1: All fields are serialized for archival — only `.snapshot` is read back\n376:   // during lineage inspection, but the full metadata provides forensic context\n377:   // for post-mortem analysis and backfill validation.\n378:   const metadata: LineageMetadata = {\n379:     contentHash: typeof row.content_hash === 'string' ? row.content_hash : null,\n380:     filePath: row.file_path,\n381:     canonicalFilePath: typeof row.canonical_file_path === 'string' ? row.canonical_file_path : null,\n382:     anchorId: typeof row.anchor_id === 'string' ? row.anchor_id : null,\n383:     specFolder: row.spec_folder,\n384:     snapshot: row,\n385:     history: historyEvents,\n386:     actor,\n387:   };\n388:   return JSON.stringify(metadata);\n389: }\n390: \n391: function parseMetadata(row: MemoryLineageRow): LineageMetadata | null {\n392:   if (typeof row.metadata !== 'string' || row.metadata.length === 0) {\n393:     return null;\n394:   }\n395: \n396:   try {\n397:     const parsed: unknown = JSON.parse(row.metadata);\n398:     if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {\n399:       return parsed as LineageMetadata;\n400:     }\n401:     logger.warn(`Invalid lineage metadata shape for memory ${row.memory_id}`);\n402:     return null;\n403:   } catch (error: unknown) {\n404:     logger.warn(`Failed to parse lineage metadata for memory ${row.memory_id}: ${error instanceof Error ? error.message : String(error)}`);\n405:     return null;\n406:   }\n407: }\n408: \n409: function resolveSnapshotFromLineageRow(\n410:   database: Database.Database,\n411:   row: MemoryLineageRow,\n412: ): ResolvedLineageSnapshot {\n413:   const metadata = parseMetadata(row);\n414:   return {\n415:     logicalKey: row.logical_key,\n416:     memoryId: row.memory_id,\n417:     versionNumber: row.version_number,\n418:     rootMemoryId: row.root_memory_id,\n419:     validFrom: row.valid_from,\n420:     validTo: row.valid_to,\n421:     transitionEvent: row.transition_event,\n422:     snapshot: metadata?.snapshot ?? getMemoryRow(database, row.memory_id),\n423:   };\n424: }\n425: \n426: function upsertActiveProjection(\n427:   database: Database.Database,\n428:   logicalKey: string,\n429:   rootMemoryId: number,\n430:   activeMemoryId: number,\n431:   updatedAt: string,\n432: ): void {\n433:   // Evict any stale projection row that maps a *different* logical_key to the\n434:   // same active_memory_id — prevents UNIQUE constraint violation on re-index\n435:   // when the logical_key changes (e.g. anchor or path normalization drift).\n436:   database.prepare(\n437:     'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n438:   ).run(activeMemoryId, logicalKey);\n439:   database.prepare(`\n440:     INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n441:     VALUES (?, ?, ?, ?)\n442:     ON CONFLICT(logical_key) DO UPDATE SET\n443:       root_memory_id = excluded.root_memory_id,\n444:       active_memory_id = excluded.active_memory_id,\n445:       updated_at = excluded.updated_at\n446:   `).run(logicalKey, rootMemoryId, activeMemoryId, updatedAt);\n447: }\n448: \n449: /**\n450:  * Admit archived/cold (deprecated-tier) rows into `active_memory_projection` so the\n451:  * vector (semantic) lane — which joins the projection — can reach them. Option A:\n452:  * only rows whose logical key has NO active winner already in the projection, so the\n453:  * one-active-per-logical-key UNIQUE invariant is preserved and superseded\n454:  * dedup-losers are not surfaced. Picks the most recent embedded row per key.\n455:  *\n456:  * Uses `buildLogicalKey` (the same key builder the incremental upsert uses) — a\n457:  * SQL key expression would not match the stored `logical_key` format. Idempotent:\n458:  * keys already present are skipped, so re-running admits nothing new.\n459:  *\n460:  * Opt-in (default OFF) via SPECKIT_INCLUDE_ARCHIVED_VECTOR — a live projection\n461:  * mutation whose correctness is confirmed against the running daemon.\n462:  */\n463: export function backfillColdOrphanProjection(\n464:   database: Database.Database,\n465: ): { scanned: number; admitted: number; skippedActiveKey: number } {\n466:   if (!isArchivedVectorInclusionEnabled()) {\n467:     return { scanned: 0, admitted: 0, skippedActiveKey: 0 };\n468:   }\n469:   let rows: MemoryIndexRow[];\n470:   try {\n471:     rows = database.prepare(`\n472:       SELECT id, spec_folder, file_path, canonical_file_path, anchor_id,\n473:              tenant_id, user_id, agent_id, session_id, updated_at\n474:       FROM memory_index\n475:       WHERE