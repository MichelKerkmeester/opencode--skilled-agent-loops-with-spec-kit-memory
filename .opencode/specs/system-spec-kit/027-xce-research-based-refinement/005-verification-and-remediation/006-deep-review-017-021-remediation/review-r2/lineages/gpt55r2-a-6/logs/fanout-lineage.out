lteredSummaryHits, specFolder);\n\n(Showing lines 1318-1342 of 1510. Use offset=1343 to continue.)\n</content>","metadata":{"preview":"\n            if (newSummaryIds.length > 0) {\n              const placeholders = newSummaryIds.map(() => '?').join(', ');\n              const memRows = db.prepare(\n                `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n              ).all(...newSummaryIds) as PipelineRow[];\n\n              const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n              for (const sr of summaryResults) {\n                if (!existingIds.has(String(sr.memoryId))) {\n                  const memRow = memRowMap.get(sr.memoryId);\n                  if (memRow) {\n                    newSummaryHits.push({\n                      ...memRow,\n                      similarity: sr.similarity * 100,\n                      score: sr.similarity,\n                    });\n                    existingIds.add(String(sr.memoryId));\n                  }\n                }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"\n            if (newSummaryIds.length > 0) {\n              const placeholders = newSummaryIds.map(() => '?').join(', ');\n              const memRows = db.prepare(\n                `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n              ).all(...newSummaryIds) as PipelineRow[];\n\n              const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n              for (const sr of summaryResults) {\n                if (!existingIds.has(String(sr.memoryId))) {\n                  const memRow = memRowMap.get(sr.memoryId);\n                  if (memRow) {\n                    newSummaryHits.push({\n                      ...memRow,\n                      similarity: sr.similarity * 100,\n                      score: sr.similarity,\n                    });\n                    existingIds.add(String(sr.memoryId));\n                  }\n                }\n              }\n            }\n\n            const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n            const folderFilteredSummaryHits = applyFolderFilter(archiveFilteredSummaryHits, specFolder);","lineStart":1318,"lineEnd":1342,"totalLines":1510,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781762698706,"end":1781762698718}},"metadata":{"openai":{"itemId":"fc_0ca6a69e419d0321016a338a89c7108191a76b3924a7dfce96"}},"id":"prt_ed9552dd00016HD92wjaaszbno","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed955035b001aDkee2keYWcIds"}}
