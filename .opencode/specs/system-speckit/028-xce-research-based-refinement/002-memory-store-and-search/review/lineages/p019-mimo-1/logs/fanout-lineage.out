orage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequested