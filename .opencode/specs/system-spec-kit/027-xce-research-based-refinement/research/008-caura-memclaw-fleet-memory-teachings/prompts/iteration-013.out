ror, OpenAIError, GoogleAPIError):\n2211:         logger.exception(\"Background enrichment error for memory %s\", memory_id)\n2212: \n2213: \n2214: async def soft_delete_memory(db: AsyncSession, memory_id: UUID, tenant_id: str) -> None:\n2215:     sc = get_storage_client()\n2216:     mem = await sc.get_memory_for_tenant(tenant_id, str(memory_id))\n2217:     if not mem:\n2218:         raise HTTPException(status_code=404, detail=\"Memory not found\")\n2219: \n2220:     await sc.soft_delete_memory(str(memory_id))\n2221: \n2222:     _hooks = get_hooks()\n2223:     if _hooks.audit_log:\n2224:         try:\n2225:             await _hooks.audit_log(\n2226:                 db,\n2227:                 tenant_id=tenant_id,\n2228:                 agent_id=mem.get(\"agent_id\"),\n2229:                 action=\"soft_delete\",\n2230:                 resource_type=\"memory\",\n2231:                 resource_id=memory_id,\n2232:             )\n2233:         except Exception:\n2234:             logger.warning(\"Audit hook failed (non-critical)\", exc_info=True)\n\n(Showing lines 2190-2234 of 3230. Use offset=2235 to continue.)\n</content>","metadata":{"preview":"                        memory_type,\n                    ),\n                    \"entity_extraction\",\n                    memory_id,\n                    tenant_id,\n                )\n            )\n        # F3 Phase 3 removed the asymmetric ``(embed=deferred,\n        # enrich=inline)`` race-guard branch that previously lived here.\n        # Under ``deployment_mode`` the two axes co-vary, so the branch\n        # was unreachable in any real deployment: inline mode entered\n        # this function with ``inline_embedding=True`` (guard short-\n        # circuits); deferred mode never enters this function because\n        # ``_schedule_enrich_or_inline`` publishes ``ENRICH_REQUESTED``\n        # instead. Contradiction detection on the deferred path is now\n        # owned solely by the ``handle_memory_embedded`` and\n        # ``handle_memory_enriched`` consumers in ``consumer.py`` —\n        # they fire ``detect_contradictions_async`` when their\n        # respective worker PATCHes land.\n        logger.info(\"Background enrichment succeeded for memory %s\", memory_id)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"                        memory_type,\n                    ),\n                    \"entity_extraction\",\n                    memory_id,\n                    tenant_id,\n                )\n            )\n        # F3 Phase 3 removed the asymmetric ``(embed=deferred,\n        # enrich=inline)`` race-guard branch that previously lived here.\n        # Under ``deployment_mode`` the two axes co-vary, so the branch\n        # was unreachable in any real deployment: inline mode entered\n        # this function with ``inline_embedding=True`` (guard short-\n        # circuits); deferred mode never enters this function because\n        # ``_schedule_enrich_or_inline`` publishes ``ENRICH_REQUESTED``\n        # instead. Contradiction detection on the deferred path is now\n        # owned solely by the ``handle_memory_embedded`` and\n        # ``handle_memory_enriched`` consumers in ``consumer.py`` —\n        # they fire ``detect_contradictions_async`` when their\n        # respective worker PATCHes land.\n        logger.info(\"Background enrichment succeeded for memory %s\", memory_id)\n    except (TimeoutError, ValueError, RuntimeError, SQLAlchemyError, OpenAIError, GoogleAPIError):\n        logger.exception(\"Background enrichment error for memory %s\", memory_id)\n\n\nasync def soft_delete_memory(db: AsyncSession, memory_id: UUID, tenant_id: str) -> None:\n    sc = get_storage_client()\n    mem = await sc.get_memory_for_tenant(tenant_id, str(memory_id))\n    if not mem:\n        raise HTTPException(status_code=404, detail=\"Memory not found\")\n\n    await sc.soft_delete_memory(str(memory_id))\n\n    _hooks = get_hooks()\n    if _hooks.audit_log:\n        try:\n            await _hooks.audit_log(\n                db,\n                tenant_id=tenant_id,\n                agent_id=mem.get(\"agent_id\"),\n                action=\"soft_delete\",\n                resource_type=\"memory\",\n                resource_id=memory_id,\n            )\n        except Exception:\n            logger.warning(\"Audit hook failed (non-critical)\", exc_info=True)","lineStart":2190,"lineEnd":2234,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728936643,"end":1780728936650}},"metadata":{"openai":{"itemId":"fc_0f3918f9d84a920c016a23c4688bbc8191a02403ebc85aa62f"}},"id":"prt_e9bb738af001Wa5jqVjXzHfpLR","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb716d60018pqKAQz7ADjOc8"}}
