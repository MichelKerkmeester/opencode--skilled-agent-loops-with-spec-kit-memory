hed to avoid full-table scans on large databases.\n168:     // Over-fetch by a factor so that after cosine ranking we can still return `limit` results.\n169:     const fetchCap = Math.max(limit * 10, 1000);\n170:     const rows = db.prepare(`\n171:       SELECT id, memory_id, summary_embedding\n172:       FROM memory_summaries\n173:       WHERE summary_embedding IS NOT NULL\n174:       LIMIT ?\n175:     `).all(fetchCap) as Array<{ id: number; memory_id: number; summary_embedding: Buffer }>;\n176: \n177:     const results: SummarySearchResult[] = [];\n178: \n179:     for (const row of rows) {\n180:       const storedEmbedding = bufferToFloat32(row.summary_embedding);\n181:       const similarity = cosineSimilarity(queryEmbedding, storedEmbedding);\n182: \n183:       results.push({\n184:         id: row.id,\n185:         memoryId: row.memory_id,\n186:         similarity,\n187:       });\n188:     }\n189: \n190:     // Sort by similarity descending, take top `limit`\n191:     results.sort((a, b) => b.similarity - a.similarity);\n192:     return results.slice(0, limit);\n193:   } catch (error: unknown) {\n194:     console.warn(\n195:       '[memory-summaries] Failed to query summary embeddings:',\n196:       error instanceof Error ? error.message : error\n197:     );\n198:     return [];\n199:   }\n200: }\n201: \n202: /**\n203:  * Runtime scale gate check: returns true when >5000 indexed memories.\n204:  * Used to determine if the summary search channel should be activated\n205:  * as an additional retrieval source.\n206:  *\n207:  * @param db - SQLite database instance\n208:  * @returns True if indexed memory count exceeds 5000\n209:  */\n210: export function checkScaleGate(db: Database.Database): boolean {\n211:   try {\n212:     const row = db.prepare(`\n213:       SELECT COUNT(*) AS cnt\n214:       FROM memory_index\n215:       WHERE embedding_status = 'success'\n216:     `).get() as { cnt: number } | undefined;\n217: \n218:     return (row?.cnt ?? 0) > 5000;\n219:   } catch (error: unknown) {\n220:     console.warn(\n221:       '[memory-summaries] Failed to check scale gate:',\n222:       error instanceof Error ? error.message : error\n223:     );\n224:     return false;\n225:   }\n226: }\n227: \n228: // ───────────────────────────────────────────────────────────────\n229: // 4. TEST EXPORTS\n230: \n231: // ───────────────────────────────────────────────────────────────\n232: /**\n233:  * Internal functions exposed for unit testing.\n234:  * Do NOT use in production code paths.\n235:  *\n236:  * @internal\n237:  */\n238: export const __testables = {\n239:   cosineSimilarity,\n240:   float32ToBuffer,\n241:   bufferToFloat32,\n242: };\n\n(End of file - total 242 lines)\n</content>","metadata":{"preview":"      embeddingBlob,\n      keySentencesJson,\n      memoryId,\n      now,\n      now\n    );\n\n    return { stored: true, summary };\n  } catch (error: unknown) {\n    console.warn(\n      `[memory-summaries] Failed to generate/store summary for memory ${memoryId}:`,\n      error instanceof Error ? error.message : error\n    );\n    return { stored: false, summary: '' };\n  }\n}\n\n/**\n * Vector search on summary embeddings — parallel channel for stage1.\n *","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts","text":"      embeddingBlob,\n      keySentencesJson,\n      memoryId,\n      now,\n      now\n    );\n\n    return { stored: true, summary };\n  } catch (error: unknown) {\n    console.warn(\n      `[memory-summaries] Failed to generate/store summary for memory ${memoryId}:`,\n      error instanceof Error ? error.message : error\n    );\n    return { stored: false, summary: '' };\n  }\n}\n\n/**\n * Vector search on summary embeddings — parallel channel for stage1.\n *\n * 1. SELECT id, memory_id, summary_embedding FROM memory_summaries\n *    WHERE summary_embedding IS NOT NULL\n * 2. Compute cosine similarity between query embedding and each summary embedding\n * 3. Return top `limit` results sorted by similarity descending\n * 4. Convert BLOB back to Float32Array for comparison\n *\n * @param db - SQLite database instance\n * @param queryEmbedding - Query vector to compare against stored summaries\n * @param limit - Maximum number of results to return\n * @returns Array of summary search results sorted by similarity descending\n */\nexport function querySummaryEmbeddings(\n  db: Database.Database,\n  queryEmbedding: Float32Array | number[],\n  limit: number\n): SummarySearchResult[] {\n  try {\n    // Cap rows fetched to avoid full-table scans on large databases.\n    // Over-fetch by a factor so that after cosine ranking we can still return `limit` results.\n    const fetchCap = Math.max(limit * 10, 1000);\n    const rows = db.prepare(`\n      SELECT id, memory_id, summary_embedding\n      FROM memory_summaries\n      WHERE summary_embedding IS NOT NULL\n      LIMIT ?\n    `).all(fetchCap) as Array<{ id: number; memory_id: number; summary_embedding: Buffer }>;\n\n    const results: SummarySearchResult[] = [];\n\n    for (const row of rows) {\n      const storedEmbedding = bufferToFloat32(row.summary_embedding);\n      const similarity = cosineSimilarity(queryEmbedding, storedEmbedding);\n\n      results.push({\n        id: row.id,\n        memoryId: row.memory_id,\n        similarity,\n      });\n    }\n\n    // Sort by similarity descending, take top `limit`\n    results.sort((a, b) => b.similarity - a.similarity);\n    return results.slice(0, limit);\n  } catch (error: unknown) {\n    console.warn(\n      '[memory-summaries] Failed to query summary embeddings:',\n      error instanceof Error ? error.message : error\n    );\n    return [];\n  }\n}\n\n/**\n * Runtime scale gate check: returns true when >5000 indexed memories.\n * Used to determine if the summary search channel should be activated\n * as an additional retrieval source.\n *\n * @param db - SQLite database instance\n * @returns True if indexed memory count exceeds 5000\n */\nexport function checkScaleGate(db: Database.Database): boolean {\n  try {\n    const row = db.prepare(`\n      SELECT COUNT(*) AS cnt\n      FROM memory_index\n      WHERE embedding_status = 'success'\n    `).get() as { cnt: number } | undefined;\n\n    return (row?.cnt ?? 0) > 5000;\n  } catch (error: unknown) {\n    console.warn(\n      '[memory-summaries] Failed to check scale gate:',\n      error instanceof Error ? error.message : error\n    );\n    return false;\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. TEST EXPORTS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Internal functions exposed for unit testing.\n * Do NOT use in production code paths.\n *\n * @internal\n */\nexport const __testables = {\n  cosineSimilarity,\n  float32ToBuffer,\n  bufferToFloat32,\n};","lineStart":130,"lineEnd":242,"totalLines":242,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts","time":{"start":1781761532462,"end":1781761532465}},"metadata":{"openai":{"itemId":"fc_0b6feef4a8aa8cb9016a3385fb3d288191820aada956dba97a"}},"id":"prt_ed9435d610016ys5E4tJo4i9kj","sessionID":"ses_126bff004ffeidXJpk4781In70","messageID":"msg_ed94352cb001FO38v53YtKn60l"}}
