{"type":"tool_use","timestamp":1780372922033,"sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","part":{"type":"tool","tool":"read","callID":"call_E3TsNUUlEl1UQFuM23UIUE4I","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/router-replay.cjs","offset":1,"limit":188},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/router-replay.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * router-replay.cjs — Mode A deterministic in-skill smart-router replay.\n6:  *\n7:  * The converged design needs the intra-skill router replayed deterministically\n8:  * (zero leakage, CI-friendly) as the D1-intra signal and the D2 discovery proxy.\n9:  * The router lives as INTENT_SIGNALS + RESOURCE_MAP inside a fenced block in the\n10:  * target SKILL.md; it is documentation, not an importable module, so this script\n11:  * extracts the dictionaries and reproduces the exact substring-scoring semantics:\n12:  * lowercase the task, score each intent by whether each keyword is a substring,\n13:  * keep intents within an ambiguity delta of the top score, then union the default\n14:  * resource + RESOURCE_MAP[intent] for the selected intents.\n15:  *\n16:  * Exit: 0 on a successful replay (even with zero intents), 2 on unparseable router.\n17:  */\n18: \n19: const fs = require('fs');\n20: const path = require('path');\n21: \n22: const AMBIGUITY_DELTA = 1; // mirror the in-skill router: keep near-tied intents\n23: \n24: function readSkillMd(skillRoot) {\n25:   const p = path.join(skillRoot, 'SKILL.md');\n26:   if (!fs.existsSync(p)) throw new Error(`SKILL.md not found under ${skillRoot}`);\n27:   return fs.readFileSync(p, 'utf8');\n28: }\n29: \n30: // Pull the {...}-balanced body that follows `NAME = {` from the SKILL.md text.\n31: function extractDictBody(text, name) {\n32:   const start = text.indexOf(`${name} = {`);\n33:   if (start === -1) return null;\n34:   let i = text.indexOf('{', start);\n35:   let depth = 0;\n36:   for (let j = i; j < text.length; j += 1) {\n37:     const ch = text[j];\n38:     if (ch === '{') depth += 1;\n39:     else if (ch === '}') {\n40:       depth -= 1;\n41:       if (depth === 0) return text.slice(i + 1, j);\n42:     }\n43:   }\n44:   return null;\n45: }\n46: \n47: function quotedStrings(segment) {\n48:   const out = [];\n49:   const re = /\"([^\"]*)\"|'([^']*)'/g;\n50:   let m;\n51:   while ((m = re.exec(segment)) !== null) out.push(m[1] !== undefined ? m[1] : m[2]);\n52:   return out;\n53: }\n54: \n55: // INTENT_SIGNALS = { \"KEY\": {\"weight\": N, \"keywords\": [\"a\",\"b\"]}, ... }\n56: function parseIntentSignals(body) {\n57:   const signals = {};\n58:   if (!body) return signals;\n59:   const entryRe = /[\"']([A-Z0-9_]+)[\"']\\s*:\\s*\\{([^}]*)\\}/g;\n60:   let m;\n61:   while ((m = entryRe.exec(body)) !== null) {\n62:     const key = m[1];\n63:     const inner = m[2];\n64:     const weightMatch = /[\"']weight[\"']\\s*:\\s*(\\d+(?:\\.\\d+)?)/.exec(inner);\n65:     const kwMatch = /[\"']keywords[\"']\\s*:\\s*\\[([^\\]]*)\\]/.exec(inner);\n66:     signals[key] = {\n67:       weight: weightMatch ? Number(weightMatch[1]) : 1,\n68:       keywords: kwMatch ? quotedStrings(kwMatch[1]).map((k) => k.toLowerCase()) : [],\n69:     };\n70:   }\n71:   return signals;\n72: }\n73: \n74: // RESOURCE_MAP = { \"KEY\": [\"path/a.md\", \"path/b.md\"], ... }\n75: function parseResourceMap(body) {\n76:   const map = {};\n77:   if (!body) return map;\n78:   const entryRe = /[\"']([A-Z0-9_]+)[\"']\\s*:\\s*\\[([^\\]]*)\\]/g;\n79:   let m;\n80:   while ((m = entryRe.exec(body)) !== null) map[m[1]] = quotedStrings(m[2]);\n81:   return map;\n82: }\n83: \n84: // DEFAULT_RESOURCE may be a single quoted path or a list of them. A skill's\n85: // always-loaded routing preamble (e.g. stack/phase detection plus the router\n86: // doc) is genuinely consulted on every route, so the replay seeds every result\n87: // with the whole set. Always returns an array; [] when absent.\n88: function parseDefaultResource(text) {\n89:   const listM = /DEFAULT_RESOURCE\\s*=\\s*\\[([\\s\\S]*?)\\]/.exec(text);\n90:   if (listM) {\n91:     return [...listM[1].matchAll(/[\"']([^\"']+)[\"']/g)].map((m) => m[1]);\n92:   }\n93:   const strM = /DEFAULT_RESOURCE\\s*=\\s*[\"']([^\"']+)[\"']/.exec(text);\n94:   return strM ? [strM[1]] : [];\n95: }\n96: \n97: // Some skills keep the authoritative router in a referenced doc (e.g.\n98: // references/smart_routing.md) rather than inlining it in SKILL.md. When the\n99: // inline dictionaries are absent we follow that pointer and parse the same\n100: // INTENT_SIGNALS / RESOURCE_MAP block from the referenced file. Inline always\n101: // wins; a skill with no inline block and no parseable referenced doc stays\n102: // unparseable, so a genuinely router-less skill is still reported as such.\n103: const ROUTER_REF_HINT = /(resource_map|intent_signals|intent_model|smart[ _-]?rout|routing logic)/i;\n104: \n105: function findReferencedRouterDoc(skillMdText, skillRoot) {\n106:   const pathRe = /(?:\\.\\/)?(references\\/[A-Za-z0-9_./-]+\\.md)/;\n107:   for (const line of skillMdText.split('\\n')) {\n108:     if (!ROUTER_REF_HINT.test(line)) continue;\n109:     const m = pathRe.exec(line);\n110:     if (m) {\n111:       const candidate = path.join(skillRoot, m[1]);\n112:       if (fs.existsSync(candidate)) return candidate;\n113:     }\n114:   }\n115:   // Convention fallback: a router doc at the well-known location.\n116:   const conventional = path.join(skillRoot, 'references', 'smart_routing.md');\n117:   return fs.existsSync(conventional) ? conventional : null;\n118: }\n119: \n120: function parseRouter(skillMdText, skillRoot) {\n121:   let intentSignals = parseIntentSignals(extractDictBody(skillMdText, 'INTENT_SIGNALS'));\n122:   let resourceMap = parseResourceMap(extractDictBody(skillMdText, 'RESOURCE_MAP'));\n123:   let defaultResource = parseDefaultResource(skillMdText);\n124:   let routerSource = 'inline';\n125: \n126:   const inlineEmpty = Object.keys(intentSignals).length === 0 && Object.keys(resourceMap).length === 0;\n127:   if (inlineEmpty && skillRoot) {\n128:     const refDoc = findReferencedRouterDoc(skillMdText, skillRoot);\n129:     if (refDoc) {\n130:       const refText = fs.readFileSync(refDoc, 'utf8');\n131:       const refSignals = parseIntentSignals(extractDictBody(refText, 'INTENT_SIGNALS'));\n132:       const refMap = parseResourceMap(extractDictBody(refText, 'RESOURCE_MAP'));\n133:       if (Object.keys(refSignals).length > 0 || Object.keys(refMap).length > 0) {\n134:         intentSignals = refSignals;\n135:         resourceMap = refMap;\n136:         defaultResource = defaultResource.length ? defaultResource : parseDefaultResource(refText);\n137:         routerSource = path.relative(skillRoot, refDoc);\n138:       }\n139:     }\n140:   }\n141: \n142:   const parseable = Object.keys(intentSignals).length > 0 || Object.keys(resourceMap).length > 0;\n143:   return { intentSignals, resourceMap, defaultResource, parseable, routerSource };\n144: }\n145: \n146: function scoreIntents(taskLower, intentSignals) {\n147:   const scores = [];\n148:   for (const [key, sig] of Object.entries(intentSignals)) {\n149:     let score = 0;\n150:     for (const kw of sig.keywords) {\n151:       if (kw && taskLower.includes(kw)) score += sig.weight;\n152:     }\n153:     if (score > 0) scores.push({ intent: key, score });\n154:   }\n155:   scores.sort((a, b) => b.score - a.score);\n156:   return scores;\n157: }\n158: \n159: function selectIntents(scores) {\n160:   if (scores.length === 0) return [];\n161:   const top = scores[0].score;\n162:   return scores.filter((s) => top - s.score <= AMBIGUITY_DELTA).map((s) => s.intent);\n163: }\n164: \n165: // Which surface a resource belongs to, by its on-disk path prefix. Webflow,\n166: // OpenCode, and Motion.dev resources live under their own folders, so the prefix\n167: // IS the surface. Everything else (universal refs, the detection/router preamble)\n168: // is surface-agnostic.\n169: const SURFACE_PREFIXES = {\n170:   WEBFLOW: ['references/webflow/', 'assets/webflow/'],\n171:   OPENCODE: ['references/opencode/', 'assets/opencode/'],\n172:   MOTION: ['references/motion_dev/', 'assets/motion_dev/'],\n173: };\n174: function resourceSurface(r) {\n175:   for (const [surface, prefixes] of Object.entries(SURFACE_PREFIXES)) {\n176:     if (prefixes.some((p) => r.startsWith(p))) return surface;\n177:   }\n178:   return 'UNIVERSAL';\n179: }\n180: // Detect the task's code surface from path / extension / marker signals, mirroring\n181: // the prose stack-detection contract: OpenCode system code wins, then Webflow\n182: // markers, else UNKNOWN. A task that names both is MIXED (cross-surface).\n183: function detectSurface(taskLower) {\n184:   const opencode = /\\.opencode\\/|\\bskill\\.md\\b|\\.cjs\\b|\\.mjs\\b|\\.tsx?\\b|\\.py\\b|\\.sh\\b|\\bspec-folder\\b|\\bargparse\\b|graph-metadata/.test(taskLower);\n185:   const webflow = /src\\/2_javascript|\\bwebflow\\b|\\.webflow\\b|--vw-/.test(taskLower);\n186:   if (opencode && webflow) return 'MIXED';\n187:   if (opencode) return 'OPENCODE';\n188:   if (webflow) return 'WEBFLOW';\n\n(Showing lines 1-188 of 278. Use offset=189 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * router-replay.cjs — Mode A deterministic in-skill smart-router replay.\n *\n * The converged design needs the intra-skill router replayed deterministically\n * (zero leakage, CI-friendly) as the D1-intra signal and the D2 discovery proxy.\n * The router lives as INTENT_SIGNALS + RESOURCE_MAP inside a fenced block in the\n * target SKILL.md; it is documentation, not an importable module, so this script\n * extracts the dictionaries and reproduces the exact substring-scoring semantics:\n * lowercase the task, score each intent by whether each keyword is a substring,\n * keep intents within an ambiguity delta of the top score, then union the default\n * resource + RESOURCE_MAP[intent] for the selected intents.\n *\n * Exit: 0 on a successful replay (even with zero intents), 2 on unparseable router.\n */\n\nconst fs = require('fs');\nconst path = require('path');","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/router-replay.cjs","time":{"start":1780372921988,"end":1780372922024}},"metadata":{"openai":{"itemId":"fc_05e68bb8ceab49bb016a1e55b9ef4081919087d43af945d0dd"}},"id":"prt_e867ede67001tzANBo2wrJ6QwA","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867ebf17001C9Xqk30Qc4xtun"}}
