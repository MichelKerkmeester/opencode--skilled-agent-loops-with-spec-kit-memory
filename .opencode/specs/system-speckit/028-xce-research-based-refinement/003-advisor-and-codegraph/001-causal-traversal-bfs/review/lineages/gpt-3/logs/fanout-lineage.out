rce_id, target_id, relation, strength)\n    VALUES (?, ?, ?, ?)\n  `);\n  insertCausal.run('1', '2', 'supports', 0.5);\n  insertCausal.run('2', '3', 'enabled', 0.25);\n\n  const insertDependency = database.prepare(`\n    INSERT INTO dependency_edges (parent_path, child_path)\n    VALUES (?, ?)\n  `);\n  insertDependency.run('root', 'child');\n  insertDependency.run('child', 'grandchild');\n\n  return database;\n}\n\nfunction createFakeGraphTraversal(): FakeGraphTraversal {\n  return new FakeGraphTraversal({\n    causalEdges: [\n      { sourceId: 1, targetId: 2, relation: 'supports', strength: 0.5 },\n      { sourceId: 2, targetId: 3, relation: 'enabled', strength: 0.25 },\n    ],\n    dependencyEdges: [\n      { parentPath: 'root', childPath: 'child' },\n      { parentPath: 'child', childPath: 'grandchild' },","lineStart":60,"lineEnd":109,"totalLines":599,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","time":{"start":1781150606119,"end":1781150606130}},"metadata":{"openai":{"itemId":"fc_007a106417d0b16d016a2a338e08048191815d157b83e59501"}},"id":"prt_eb4d96325001IjRzVYMZs6w0Hj","sessionID":"ses_14b284513ffeIITXJTJTMH97Er","messageID":"msg_eb4d94473001wNgG4NYx1v0JeC"}}
