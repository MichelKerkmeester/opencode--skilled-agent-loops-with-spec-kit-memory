bose\n43:   $(basename \"$0\") specs/042-feature/ --json\n44: EOF\n45: }\n46: \n47: # ─── Args ─────────────────────────────────────────────────────\n48: FOLDER_PATH=\"\"\n49: JSON_MODE=false\n50: VERBOSE=false\n51: \n52: while [[ $# -gt 0 ]]; do\n53:     case \"$1\" in\n54:         --json)     JSON_MODE=true; shift ;;\n55:         --verbose)  VERBOSE=true; shift ;;\n56:         --help|-h)  usage; exit 0 ;;\n57:         -*)         echo \"Unknown option: $1\" >&2; usage >&2; exit 2 ;;\n58:         *)\n59:             if [[ -z \"$FOLDER_PATH\" ]]; then\n60:                 FOLDER_PATH=\"$1\"\n61:             else\n62:                 echo \"Error: unexpected argument '$1'\" >&2\n63:                 usage >&2\n64:                 exit 2\n65:             fi\n66:             shift\n67:             ;;\n68:     esac\n69: done\n70: \n71: if [[ -z \"$FOLDER_PATH\" ]]; then\n72:     echo \"Error: spec folder path required\" >&2\n73:     usage >&2\n74:     exit 2\n75: fi\n76: \n77: # Normalize trailing slash\n78: FOLDER_PATH=\"${FOLDER_PATH%/}\"\n79: \n80: if [[ ! -d \"$FOLDER_PATH\" ]]; then\n81:     echo \"Error: folder not found: $FOLDER_PATH\" >&2\n82:     exit 2\n83: fi\n84: \n85: # ─── Placeholder patterns ────────────────────────────────────\n86: # Match bracket patterns that look like template placeholders:\n87: #   [Response time target], [Low/Med/High], [Component A],\n88: #   [YOUR_VALUE_HERE], [PLACEHOLDER], etc.\n89: #\n90: # Exclude patterns that are NOT placeholders:\n91: #   [x] / [ ] (checkbox), [P0] / [P1] / [P2] (priority tags),\n92: #   [SPECKIT...] (markers), [ANCHOR...] (anchors),\n93: #   [EVIDENCE...] (checklist evidence), [W:...] (workstream),\n94: #   [NEEDS CLARIFICATION] (spec markers), [B] (blocked task)\n95: #\n96: # Also exclude lines where brackets appear inside code blocks\n97: # (backtick-wrapped) since those describe placeholder concepts\n98: # Rather than being actual unfilled placeholders.\n99: \n100: TOTAL=0\n101: MATCHES=\"\"\n102: \n103: # Process each .md file (skip backup/temp directories)\n104: while IFS= read -r file; do\n105:     # Skip backup directories and non-template subfolders.\n106:     # Memory/ contains generated session context markdown that legitimately\n107:     # Uses bracketed TOC links (e.g., [CONTINUE SESSION]); scratch/ is temp.\n108:     case \"$file\" in\n109:         */.backup-*) continue ;;\n110:         */memory/*) continue ;;\n111:         */scratch/*) continue ;;\n112:     esac\n113: \n114:     line_num=0\n115:     while IFS= read -r line; do\n116:         line_num=$((line_num + 1))\n117: \n118:         # Skip lines inside code fences or with backtick-wrapped brackets\n119:         case \"$line\" in\n120:             '```'*) continue ;;\n121:             *'`['*) continue ;;\n122:         esac\n123: \n124:         # Skip HTML comments\n125:         case \"$line\" in\n126:             *'<!--'*'-->'*) continue ;;\n127:         esac\n128: \n129:         # Match bracket patterns that look like placeholders\n130:         # Use grep to find [Something here] patterns\n131:         if echo \"$line\" | grep -qE '\\[[A-Z][A-Za-z0-9 /,._-]+\\]' 2>/dev/null; then\n132:             # Exclude known non-placeholder patterns\n133:             cleaned=\"$line\"\n134:             # Remove known safe patterns before re-checking\n135:             cleaned=$(echo \"$cleaned\" | sed -E \\\n136:                 -e 's/\\[x\\]//g' \\\n137:                 -e 's/\\[ \\]//g' \\\n138:                 -e 's/\\[P[0-2]\\]//g' \\\n139:                 -e 's/\\[B\\]//g' \\\n140:                 -e 's/\\[SPECKIT[^]]*\\]//g' \\\n141:                 -e 's/\\[ANCHOR[^]]*\\]//g' \\\n142:                 -e 's/\\[EVIDENCE[^]]*\\]//g' \\\n143:                 -e 's/\\[NEEDS CLARIFICATION\\]//g' \\\n144:                 -e 's/\\[W:[^]]*\\]//g' \\\n145:                 -e 's/`[^`]*`//g' \\\n146:             )\n147: \n148:             # Check if any placeholder-like patterns remain after cleanup\n149:             if echo \"$cleaned\" | grep -qE '\\[[A-Z][A-Za-z0-9 /,._-]{2,}\\]' 2>/dev/null; then\n150:                 TOTAL=$((TOTAL + 1))\n151:                 match_text=$(echo \"$line\" | grep -oE '\\[[A-Z][A-Za-z0-9 /,._-]{2,}\\]' 2>/dev/null | head -1)\n152:                 if [[ \"$VERBOSE\" == \"true\" ]]; then\n153:                     MATCHES=\"${MATCHES}  ${file}:${line_num}: ${match_text}\\n\"\n154:                 fi\n155:             fi\n156:         fi\n157:     done < \"$file\"\n158: done < <(find \"$FOLDER_PATH\" -name \"*.md\" -type f 2>/dev/null | sort)\n159: \n160: # ─── Output ──────────────────────────────────────────────────\n161: if [[ \"$JSON_MODE\" == \"true\" ]]; then\n162:     if [[ $TOTAL -eq 0 ]]; then\n163:         echo \"{\\\"status\\\":\\\"PASS\\\",\\\"placeholders\\\":0,\\\"folder\\\":\\\"$FOLDER_PATH\\\"}\"\n164:     else\n165:         echo \"{\\\"status\\\":\\\"FAIL\\\",\\\"placeholders\\\":$TOTAL,\\\"folder\\\":\\\"$FOLDER_PATH\\\"}\"\n166:     fi\n167: else\n168:     if [[ $TOTAL -eq 0 ]]; then\n169:         echo -e \"${GREEN}${BOLD}PASS${NC} — Zero placeholder patterns found in ${FOLDER_PATH}\"\n170:     else\n171:         echo -e \"${RED}${BOLD}FAIL${NC} — ${TOTAL} placeholder pattern(s) found in ${FOLDER_PATH}\" >&2\n172:         if [[ \"$VERBOSE\" == \"true\" && -n \"$MATCHES\" ]]; then\n173:             echo \"\"\n174:             echo -e \"$MATCHES\"\n175:         fi\n176:     fi\n177: fi\n178: \n179: # Exit code: 0 = pass, 1 = fail\n180: if [[ $TOTAL -eq 0 ]]; then\n\n(Showing lines 1-180 of 184. Use offset=181 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# ───────────────────────────────────────────────────────────────\n# SPECKIT: CHECK PLACEHOLDERS\n# ───────────────────────────────────────────────────────────────\n# Scan spec folder .md files for remaining bracket placeholder\n# Patterns after upgrade-level.sh + auto-populate.\n# Bash 3.2+ compatible (macOS and Linux).\n\nset -euo pipefail\n\nVERSION=\"1.0.0\"\n\n# Colors (disabled for non-TTY)\nif [[ -t 1 ]]; then\n    RED='\\033[0;31m' GREEN='\\033[0;32m' YELLOW='\\033[1;33m' BOLD='\\033[1m' NC='\\033[0m'\nelse\n    RED='' GREEN='' YELLOW='' BOLD='' NC=''\nfi\n\n# ─── Usage ────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/spec/check-placeholders.sh","text":"#!/usr/bin/env bash\n# ───────────────────────────────────────────────────────────────\n# SPECKIT: CHECK PLACEHOLDERS\n# ───────────────────────────────────────────────────────────────\n# Scan spec folder .md files for remaining bracket placeholder\n# Patterns after upgrade-level.sh + auto-populate.\n# Bash 3.2+ compatible (macOS and Linux).\n\nset -euo pipefail\n\nVERSION=\"1.0.0\"\n\n# Colors (disabled for non-TTY)\nif [[ -t 1 ]]; then\n    RED='\\033[0;31m' GREEN='\\033[0;32m' YELLOW='\\033[1;33m' BOLD='\\033[1m' NC='\\033[0m'\nelse\n    RED='' GREEN='' YELLOW='' BOLD='' NC=''\nfi\n\n# ─── Usage ────────────────────────────────────────────────────\nusage() {\n    cat <<EOF\nUsage: $(basename \"$0\") <spec-folder> [OPTIONS]\n\nScan a spec folder for remaining bracket placeholder patterns.\n\nArguments:\n  <spec-folder>    Path to spec folder (e.g., specs/042-feature/)\n\nOptions:\n  --json           Output results in JSON format\n  --verbose        Show each match with file and line number\n  --help, -h       Show this help message\n\nExit codes:\n  0  No placeholders found (PASS)\n  1  Placeholders found (FAIL)\n  2  Invalid arguments or folder not found\n\nExamples:\n  $(basename \"$0\") specs/042-feature/\n  $(basename \"$0\") specs/042-feature/ --verbose\n  $(basename \"$0\") specs/042-feature/ --json\nEOF\n}\n\n# ─── Args ─────────────────────────────────────────────────────\nFOLDER_PATH=\"\"\nJSON_MODE=false\nVERBOSE=false\n\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --json)     JSON_MODE=true; shift ;;\n        --verbose)  VERBOSE=true; shift ;;\n        --help|-h)  usage; exit 0 ;;\n        -*)         echo \"Unknown option: $1\" >&2; usage >&2; exit 2 ;;\n        *)\n            if [[ -z \"$FOLDER_PATH\" ]]; then\n                FOLDER_PATH=\"$1\"\n            else\n                echo \"Error: unexpected argument '$1'\" >&2\n                usage >&2\n                exit 2\n            fi\n            shift\n            ;;\n    esac\ndone\n\nif [[ -z \"$FOLDER_PATH\" ]]; then\n    echo \"Error: spec folder path required\" >&2\n    usage >&2\n    exit 2\nfi\n\n# Normalize trailing slash\nFOLDER_PATH=\"${FOLDER_PATH%/}\"\n\nif [[ ! -d \"$FOLDER_PATH\" ]]; then\n    echo \"Error: folder not found: $FOLDER_PATH\" >&2\n    exit 2\nfi\n\n# ─── Placeholder patterns ────────────────────────────────────\n# Match bracket patterns that look like template placeholders:\n#   [Response time target], [Low/Med/High], [Component A],\n#   [YOUR_VALUE_HERE], [PLACEHOLDER], etc.\n#\n# Exclude patterns that are NOT placeholders:\n#   [x] / [ ] (checkbox), [P0] / [P1] / [P2] (priority tags),\n#   [SPECKIT...] (markers), [ANCHOR...] (anchors),\n#   [EVIDENCE...] (checklist evidence), [W:...] (workstream),\n#   [NEEDS CLARIFICATION] (spec markers), [B] (blocked task)\n#\n# Also exclude lines where brackets appear inside code blocks\n# (backtick-wrapped) since those describe placeholder concepts\n# Rather than being actual unfilled placeholders.\n\nTOTAL=0\nMATCHES=\"\"\n\n# Process each .md file (skip backup/temp directories)\nwhile IFS= read -r file; do\n    # Skip backup directories and non-template subfolders.\n    # Memory/ contains generated session context markdown that legitimately\n    # Uses bracketed TOC links (e.g., [CONTINUE SESSION]); scratch/ is temp.\n    case \"$file\" in\n        */.backup-*) continue ;;\n        */memory/*) continue ;;\n        */scratch/*) continue ;;\n    esac\n\n    line_num=0\n    while IFS= read -r line; do\n        line_num=$((line_num + 1))\n\n        # Skip lines inside code fences or with backtick-wrapped brackets\n        case \"$line\" in\n            '```'*) continue ;;\n            *'`['*) continue ;;\n        esac\n\n        # Skip HTML comments\n        case \"$line\" in\n            *'<!--'*'-->'*) continue ;;\n        esac\n\n        # Match bracket patterns that look like placeholders\n        # Use grep to find [Something here] patterns\n        if echo \"$line\" | grep -qE '\\[[A-Z][A-Za-z0-9 /,._-]+\\]' 2>/dev/null; then\n            # Exclude known non-placeholder patterns\n            cleaned=\"$line\"\n            # Remove known safe patterns before re-checking\n            cleaned=$(echo \"$cleaned\" | sed -E \\\n                -e 's/\\[x\\]//g' \\\n                -e 's/\\[ \\]//g' \\\n                -e 's/\\[P[0-2]\\]//g' \\\n                -e 's/\\[B\\]//g' \\\n                -e 's/\\[SPECKIT[^]]*\\]//g' \\\n                -e 's/\\[ANCHOR[^]]*\\]//g' \\\n                -e 's/\\[EVIDENCE[^]]*\\]//g' \\\n                -e 's/\\[NEEDS CLARIFICATION\\]//g' \\\n                -e 's/\\[W:[^]]*\\]//g' \\\n                -e 's/`[^`]*`//g' \\\n            )\n\n            # Check if any placeholder-like patterns remain after cleanup\n            if echo \"$cleaned\" | grep -qE '\\[[A-Z][A-Za-z0-9 /,._-]{2,}\\]' 2>/dev/null; then\n                TOTAL=$((TOTAL + 1))\n                match_text=$(echo \"$line\" | grep -oE '\\[[A-Z][A-Za-z0-9 /,._-]{2,}\\]' 2>/dev/null | head -1)\n                if [[ \"$VERBOSE\" == \"true\" ]]; then\n                    MATCHES=\"${MATCHES}  ${file}:${line_num}: ${match_text}\\n\"\n                fi\n            fi\n        fi\n    done < \"$file\"\ndone < <(find \"$FOLDER_PATH\" -name \"*.md\" -type f 2>/dev/null | sort)\n\n# ─── Output ──────────────────────────────────────────────────\nif [[ \"$JSON_MODE\" == \"true\" ]]; then\n    if [[ $TOTAL -eq 0 ]]; then\n        echo \"{\\\"status\\\":\\\"PASS\\\",\\\"placeholders\\\":0,\\\"folder\\\":\\\"$FOLDER_PATH\\\"}\"\n    else\n        echo \"{\\\"status\\\":\\\"FAIL\\\",\\\"placeholders\\\":$TOTAL,\\\"folder\\\":\\\"$FOLDER_PATH\\\"}\"\n    fi\nelse\n    if [[ $TOTAL -eq 0 ]]; then\n        echo -e \"${GREEN}${BOLD}PASS${NC} — Zero placeholder patterns found in ${FOLDER_PATH}\"\n    else\n        echo -e \"${RED}${BOLD}FAIL${NC} — ${TOTAL} placeholder pattern(s) found in ${FOLDER_PATH}\" >&2\n        if [[ \"$VERBOSE\" == \"true\" && -n \"$MATCHES\" ]]; then\n            echo \"\"\n            echo -e \"$MATCHES\"\n        fi\n    fi\nfi\n\n# Exit code: 0 = pass, 1 = fail\nif [[ $TOTAL -eq 0 ]]; then","lineStart":1,"lineEnd":180,"totalLines":184,"truncated":true}},"title":".opencode/skills/system-spec-kit/scripts/spec/check-placeholders.sh","time":{"start":1782885135209,"end":1782885135212}},"metadata":{"openai":{"itemId":"fc_08d9ba3343293e7c016a44ab0ec03c8191b09d931f0f118e9a"}},"id":"prt_f1c3c3207001yGZlPmDW0JH4UY","sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","messageID":"msg_f1c3bf42c001WfviR0BiYzmhCI"}}
{"type":"tool_use","timestamp":1782885135318,"sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","part":{"type":"tool","tool":"read","callID":"call_QHffk6MHTFa6F6PCZuZwdnFk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/validation/evidence-marker-lint.ts","offset":1,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/validation/evidence-marker-lint.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ───────────────────────────────────────────────────────────────\n3: // MODULE: Evidence Marker Lint\n4: // ───────────────────────────────────────────────────────────────\n5: // Strict-mode bridge for evidence-marker-audit.ts. Warns on invalid\n6: // markers and exits 1 under --strict so validate.sh can elevate it.\n7: \n8: import path from 'node:path';\n9: \n10: import {\n11:   auditFolder,\n12:   type Marker,\n13: } from './evidence-marker-audit.js';\n14: import { isMainModule } from '../lib/esm-entry.js';\n15: \n16: type ResultStatus = 'pass' | 'warn';\n17: \n18: export interface EvidenceMarkerLintResult {\n19:   readonly rule: 'EVIDENCE_MARKER_LINT';\n20:   readonly status: ResultStatus;\n21:   readonly code: 'clean' | 'invalid_markers';\n22:   readonly message: string;\n23:   readonly details: string[];\n24:   readonly malformed: number;\n25:   readonly unclosed: number;\n26: }\n27: \n28: interface CliOptions {\n29:   folder: string;\n30:   json: boolean;\n31:   strict: boolean;\n32: }\n33: \n34: function toErrorMessage(error: unknown): string {\n35:   return error instanceof Error ? error.message : String(error);\n36: }\n37: \n38: function parseArgs(argv: string[]): CliOptions {\n39:   let folder = '';\n40:   let json = false;\n41:   let strict = false;\n42: \n43:   for (let index = 0; index < argv.length; index += 1) {\n44:     const arg = argv[index];\n45:     if (arg === '--help' || arg === '-h') {\n46:       console.log([\n47:         'evidence-marker-lint — validate [EVIDENCE: ...] markers',\n48:         '',\n49:         'Usage:',\n50:         '  node evidence-marker-lint.js --folder <spec-folder> [--json] [--strict]',\n51:         '  node evidence-marker-lint.js --folder=<spec-folder> [--json] [--strict]',\n52:         '  node evidence-marker-lint.js <spec-folder> [--json] [--strict]',\n53:       ].join('\\n'));\n54:       process.exit(0);\n55:     }\n56:     if (arg.startsWith('--folder=')) {\n57:       folder = arg.slice('--folder='.length);\n58:       continue;\n59:     }\n60:     if (arg === '--folder') {\n61:       folder = argv[index + 1] ?? '';\n62:       index += 1;\n63:       continue;\n64:     }\n65:     if (arg === '--json') {\n66:       json = true;\n67:       continue;\n68:     }\n69:     if (arg === '--strict') {\n70:       strict = true;\n71:       continue;\n72:     }\n73:     if (!arg.startsWith('-') && !folder) {\n74:       folder = arg;\n75:       continue;\n76:     }\n77:     throw new Error(`Unknown argument: ${arg}`);\n78:   }\n79: \n80:   if (!folder) {\n81:     throw new Error('--folder is required');\n82:   }\n83: \n84:   return { folder, json, strict };\n85: }\n86: \n87: function formatMarkerDetail(folderPath: string, marker: Marker): string {\n88:   const relativePath = path.relative(folderPath, marker.file) || path.basename(marker.file);\n89:   const rawPreview = marker.raw.replace(/\\s+/g, ' ').trim();\n90:   return `${relativePath}:${marker.line}:${marker.col + 1} ${marker.status} ${rawPreview}`;\n91: }\n92: \n93: /**\n94:  * Lint evidence markers within a spec folder using the audit parser.\n95:  *\n96:  * @param folderPath - Spec folder to scan\n97:  * @returns Structured pass/warn result for validate.sh bridging\n98:  */\n99: export async function lintEvidenceMarkers(\n100:   folderPath: string,\n101: ): Promise<EvidenceMarkerLintResult> {\n102:   const resolvedFolder = path.resolve(folderPath);\n103:   const auditResult = await auditFolder(resolvedFolder, { rewrap: false });\n104:   const invalidMarkers = auditResult.markers.filter((marker) => marker.status !== 'ok');\n105: \n106:   if (invalidMarkers.length === 0) {\n107:     return {\n108:       rule: 'EVIDENCE_MARKER_LINT',\n109:       status: 'pass',\n110:       code: 'clean',\n111:       message: 'Evidence marker lint passed: all markers closed with balanced brackets',\n112:       details: [\n113:         `filesScanned=${auditResult.filesScanned}`,\n114:         `totalMarkers=${auditResult.totalMarkers}`,\n115:       ],\n116:       malformed: 0,\n117:       unclosed: 0,\n118:     };\n119:   }\n120: \n121:   return {\n122:     rule: 'EVIDENCE_MARKER_LINT',\n123:     status: 'warn',\n124:     code: 'invalid_markers',\n125:     message: `Evidence marker lint found ${auditResult.malformed} malformed and ${auditResult.unclosed} unclosed markers`,\n126:     details: [\n127:       `filesScanned=${auditResult.filesScanned}`,\n128:       `totalMarkers=${auditResult.totalMarkers}`,\n129:       ...invalidMarkers.map((marker) => formatMarkerDetail(resolvedFolder, marker)),\n130:     ],\n\n(Showing lines 1-130 of 167. Use offset=131 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// MODULE: Evidence Marker Lint\n// ───────────────────────────────────────────────────────────────\n// Strict-mode bridge for evidence-marker-audit.ts. Warns on invalid\n// markers and exits 1 under --strict so validate.sh can elevate it.\n\nimport path from 'node:path';\n\nimport {\n  auditFolder,\n  type Marker,\n} from './evidence-marker-audit.js';\nimport { isMainModule } from '../lib/esm-entry.js';\n\ntype ResultStatus = 'pass' | 'warn';\n\nexport interface EvidenceMarkerLintResult {\n  readonly rule: 'EVIDENCE_MARKER_LINT';\n  readonly status: ResultStatus;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/validation/evidence-marker-lint.ts","text":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// MODULE: Evidence Marker Lint\n// ───────────────────────────────────────────────────────────────\n// Strict-mode bridge for evidence-marker-audit.ts. Warns on invalid\n// markers and exits 1 under --strict so validate.sh can elevate it.\n\nimport path from 'node:path';\n\nimport {\n  auditFolder,\n  type Marker,\n} from './evidence-marker-audit.js';\nimport { isMainModule } from '../lib/esm-entry.js';\n\ntype ResultStatus = 'pass' | 'warn';\n\nexport interface EvidenceMarkerLintResult {\n  readonly rule: 'EVIDENCE_MARKER_LINT';\n  readonly status: ResultStatus;\n  readonly code: 'clean' | 'invalid_markers';\n  readonly message: string;\n  readonly details: string[];\n  readonly malformed: number;\n  readonly unclosed: number;\n}\n\ninterface CliOptions {\n  folder: string;\n  json: boolean;\n  strict: boolean;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction parseArgs(argv: string[]): CliOptions {\n  let folder = '';\n  let json = false;\n  let strict = false;\n\n  for (let index = 0; index < argv.length; index += 1) {\n    const arg = argv[index];\n    if (arg === '--help' || arg === '-h') {\n      console.log([\n        'evidence-marker-lint — validate [EVIDENCE: ...] markers',\n        '',\n        'Usage:',\n        '  node evidence-marker-lint.js --folder <spec-folder> [--json] [--strict]',\n        '  node evidence-marker-lint.js --folder=<spec-folder> [--json] [--strict]',\n        '  node evidence-marker-lint.js <spec-folder> [--json] [--strict]',\n      ].join('\\n'));\n      process.exit(0);\n    }\n    if (arg.startsWith('--folder=')) {\n      folder = arg.slice('--folder='.length);\n      continue;\n    }\n    if (arg === '--folder') {\n      folder = argv[index + 1] ?? '';\n      index += 1;\n      continue;\n    }\n    if (arg === '--json') {\n      json = true;\n      continue;\n    }\n    if (arg === '--strict') {\n      strict = true;\n      continue;\n    }\n    if (!arg.startsWith('-') && !folder) {\n      folder = arg;\n      continue;\n    }\n    throw new Error(`Unknown argument: ${arg}`);\n  }\n\n  if (!folder) {\n    throw new Error('--folder is required');\n  }\n\n  return { folder, json, strict };\n}\n\nfunction formatMarkerDetail(folderPath: string, marker: Marker): string {\n  const relativePath = path.relative(folderPath, marker.file) || path.basename(marker.file);\n  const rawPreview = marker.raw.replace(/\\s+/g, ' ').trim();\n  return `${relativePath}:${marker.line}:${marker.col + 1} ${marker.status} ${rawPreview}`;\n}\n\n/**\n * Lint evidence markers within a spec folder using the audit parser.\n *\n * @param folderPath - Spec folder to scan\n * @returns Structured pass/warn result for validate.sh bridging\n */\nexport async function lintEvidenceMarkers(\n  folderPath: string,\n): Promise<EvidenceMarkerLintResult> {\n  const resolvedFolder = path.resolve(folderPath);\n  const auditResult = await auditFolder(resolvedFolder, { rewrap: false });\n  const invalidMarkers = auditResult.markers.filter((marker) => marker.status !== 'ok');\n\n  if (invalidMarkers.length === 0) {\n    return {\n      rule: 'EVIDENCE_MARKER_LINT',\n      status: 'pass',\n      code: 'clean',\n      message: 'Evidence marker lint passed: all markers closed with balanced brackets',\n      details: [\n        `filesScanned=${auditResult.filesScanned}`,\n        `totalMarkers=${auditResult.totalMarkers}`,\n      ],\n      malformed: 0,\n      unclosed: 0,\n    };\n  }\n\n  return {\n    rule: 'EVIDENCE_MARKER_LINT',\n    status: 'warn',\n    code: 'invalid_markers',\n    message: `Evidence marker lint found ${auditResult.malformed} malformed and ${auditResult.unclosed} unclosed markers`,\n    details: [\n      `filesScanned=${auditResult.filesScanned}`,\n      `totalMarkers=${auditResult.totalMarkers}`,\n      ...invalidMarkers.map((marker) => formatMarkerDetail(resolvedFolder, marker)),\n    ],","lineStart":1,"lineEnd":130,"totalLines":167,"truncated":true}},"title":".opencode/skills/system-spec-kit/scripts/validation/evidence-marker-lint.ts","time":{"start":1782885135314,"end":1782885135317}},"metadata":{"openai":{"itemId":"fc_08d9ba3343293e7c016a44ab0ec04c8191a6c67024c2cb3258"}},"id":"prt_f1c3c337f001JQmhUG5Yj1xPub","sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","messageID":"msg_f1c3bf42c001WfviR0BiYzmhCI"}}
{"type":"tool_use","timestamp":1782885135427,"sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","part":{"type":"tool","tool":"read","callID":"call_r7HoM9CR7DoC3QJHHTx8mTrB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/validation/generated-metadata-integrity.ts","offset":1,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/validation/generated-metadata-integrity.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ───────────────────────────────────────────────────────────────\n3: // MODULE: Generated Metadata Integrity Bridge\n4: // ───────────────────────────────────────────────────────────────\n5: // Strict-mode bridge for the generated-metadata integrity check. Validates the\n6: // description.json and graph-metadata.json a spec folder carries through the shared\n7: // schemas plus the path-prefix and status-enum invariants, then emits the validate.sh\n8: // bridge protocol. Grandfather report mode keeps violations non-blocking until the\n9: // scoped migration graduates the rule to a hard error.\n10: \n11: import {\n12:   checkGeneratedMetadataIntegrity,\n13:   resolveGeneratedMetadataIntegrity,\n14: } from '../../mcp_server/lib/validation/generated-metadata-integrity.js';\n15: import { isGeneratedMetadataGrandfatherEnabled } from '../../mcp_server/lib/config/capability-flags.js';\n16: import { isMainModule } from '../lib/esm-entry.js';\n17: \n18: interface CliOptions {\n19:   folder: string;\n20:   json: boolean;\n21:   strict: boolean;\n22: }\n23: \n24: function toErrorMessage(error: unknown): string {\n25:   return error instanceof Error ? error.message : String(error);\n26: }\n27: \n28: function parseArgs(argv: string[]): CliOptions {\n29:   let folder = '';\n30:   let json = false;\n31:   let strict = false;\n32: \n33:   for (let index = 0; index < argv.length; index += 1) {\n34:     const arg = argv[index];\n35:     if (arg === '--help' || arg === '-h') {\n36:       console.log([\n37:         'generated-metadata-integrity: validate generated description/graph metadata',\n38:         '',\n39:         'Usage:',\n40:         '  node generated-metadata-integrity.js --folder <spec-folder> [--json] [--strict]',\n41:       ].join('\\n'));\n42:       process.exit(0);\n43:     }\n44:     if (arg.startsWith('--folder=')) {\n45:       folder = arg.slice('--folder='.length);\n46:       continue;\n47:     }\n48:     if (arg === '--folder') {\n49:       folder = argv[index + 1] ?? '';\n50:       index += 1;\n51:       continue;\n52:     }\n53:     if (arg === '--json') {\n54:       json = true;\n55:       continue;\n56:     }\n57:     if (arg === '--strict') {\n58:       strict = true;\n59:       continue;\n60:     }\n61:     if (!arg.startsWith('-') && !folder) {\n62:       folder = arg;\n63:       continue;\n64:     }\n65:     throw new Error(`Unknown argument: ${arg}`);\n66:   }\n67: \n68:   if (!folder) {\n69:     throw new Error('--folder is required');\n70:   }\n71: \n72:   return { folder, json, strict };\n73: }\n74: \n75: function runCli(): void {\n76:   try {\n77:     const options = parseArgs(process.argv.slice(2));\n78:     const report = checkGeneratedMetadataIntegrity(options.folder);\n79:     const resolved = resolveGeneratedMetadataIntegrity(report, {\n80:       grandfather: isGeneratedMetadataGrandfatherEnabled(),\n81:     });\n82: \n83:     if (options.json) {\n84:       process.stdout.write(`${JSON.stringify({ report, resolved }, null, 2)}\\n`);\n85:     } else {\n86:       // validate.sh maps an 'error' status to a hard failure, so emit it as 'fail'.\n87:       const bridgeStatus = resolved.status === 'error' ? 'fail' : resolved.status;\n88:       process.stdout.write(`rule\\t${resolved.rule}\\n`);\n89:       process.stdout.write(`status\\t${bridgeStatus}\\n`);\n90:       process.stdout.write(`message\\t${resolved.message}\\n`);\n91:       for (const detail of resolved.details) {\n92:         process.stdout.write(`detail\\t${detail}\\n`);\n93:       }\n94:     }\n95: \n96:     if (resolved.status === 'error' && options.strict) {\n97:       process.exit(1);\n98:     }\n99:   } catch (error: unknown) {\n100:     process.stderr.write(`${toErrorMessage(error)}\\n`);\n101:     process.exit(2);\n102:   }\n103: }\n104: \n105: if (isMainModule(import.meta.url)) {\n106:   runCli();\n107: }\n\n(End of file - total 107 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// MODULE: Generated Metadata Integrity Bridge\n// ───────────────────────────────────────────────────────────────\n// Strict-mode bridge for the generated-metadata integrity check. Validates the\n// description.json and graph-metadata.json a spec folder carries through the shared\n// schemas plus the path-prefix and status-enum invariants, then emits the validate.sh\n// bridge protocol. Grandfather report mode keeps violations non-blocking until the\n// scoped migration graduates the rule to a hard error.\n\nimport {\n  checkGeneratedMetadataIntegrity,\n  resolveGeneratedMetadataIntegrity,\n} from '../../mcp_server/lib/validation/generated-metadata-integrity.js';\nimport { isGeneratedMetadataGrandfatherEnabled } from '../../mcp_server/lib/config/capability-flags.js';\nimport { isMainModule } from '../lib/esm-entry.js';\n\ninterface CliOptions {\n  folder: string;\n  json: boolean;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/validation/generated-metadata-integrity.ts","text":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// MODULE: Generated Metadata Integrity Bridge\n// ───────────────────────────────────────────────────────────────\n// Strict-mode bridge for the generated-metadata integrity check. Validates the\n// description.json and graph-metadata.json a spec folder carries through the shared\n// schemas plus the path-prefix and status-enum invariants, then emits the validate.sh\n// bridge protocol. Grandfather report mode keeps violations non-blocking until the\n// scoped migration graduates the rule to a hard error.\n\nimport {\n  checkGeneratedMetadataIntegrity,\n  resolveGeneratedMetadataIntegrity,\n} from '../../mcp_server/lib/validation/generated-metadata-integrity.js';\nimport { isGeneratedMetadataGrandfatherEnabled } from '../../mcp_server/lib/config/capability-flags.js';\nimport { isMainModule } from '../lib/esm-entry.js';\n\ninterface CliOptions {\n  folder: string;\n  json: boolean;\n  strict: boolean;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction parseArgs(argv: string[]): CliOptions {\n  let folder = '';\n  let json = false;\n  let strict = false;\n\n  for (let index = 0; index < argv.length; index += 1) {\n    const arg = argv[index];\n    if (arg === '--help' || arg === '-h') {\n      console.log([\n        'generated-metadata-integrity: validate generated description/graph metadata',\n        '',\n        'Usage:',\n        '  node generated-metadata-integrity.js --folder <spec-folder> [--json] [--strict]',\n      ].join('\\n'));\n      process.exit(0);\n    }\n    if (arg.startsWith('--folder=')) {\n      folder = arg.slice('--folder='.length);\n      continue;\n    }\n    if (arg === '--folder') {\n      folder = argv[index + 1] ?? '';\n      index += 1;\n      continue;\n    }\n    if (arg === '--json') {\n      json = true;\n      continue;\n    }\n    if (arg === '--strict') {\n      strict = true;\n      continue;\n    }\n    if (!arg.startsWith('-') && !folder) {\n      folder = arg;\n      continue;\n    }\n    throw new Error(`Unknown argument: ${arg}`);\n  }\n\n  if (!folder) {\n    throw new Error('--folder is required');\n  }\n\n  return { folder, json, strict };\n}\n\nfunction runCli(): void {\n  try {\n    const options = parseArgs(process.argv.slice(2));\n    const report = checkGeneratedMetadataIntegrity(options.folder);\n    const resolved = resolveGeneratedMetadataIntegrity(report, {\n      grandfather: isGeneratedMetadataGrandfatherEnabled(),\n    });\n\n    if (options.json) {\n      process.stdout.write(`${JSON.stringify({ report, resolved }, null, 2)}\\n`);\n    } else {\n      // validate.sh maps an 'error' status to a hard failure, so emit it as 'fail'.\n      const bridgeStatus = resolved.status === 'error' ? 'fail' : resolved.status;\n      process.stdout.write(`rule\\t${resolved.rule}\\n`);\n      process.stdout.write(`status\\t${bridgeStatus}\\n`);\n      process.stdout.write(`message\\t${resolved.message}\\n`);\n      for (const detail of resolved.details) {\n        process.stdout.write(`detail\\t${detail}\\n`);\n      }\n    }\n\n    if (resolved.status === 'error' && options.strict) {\n      process.exit(1);\n    }\n  } catch (error: unknown) {\n    process.stderr.write(`${toErrorMessage(error)}\\n`);\n    process.exit(2);\n  }\n}\n\nif (isMainModule(import.meta.url)) {\n  runCli();\n}","lineStart":1,"lineEnd":107,"totalLines":107,"truncated":false}},"title":".opencode/skills/system-spec-kit/scripts/validation/generated-metadata-integrity.ts","time":{"start":1782885135423,"end":1782885135426}},"metadata":{"openai":{"itemId":"fc_08d9ba3343293e7c016a44ab0ec0548191948bb9f91eaae8bc"}},"id":"prt_f1c3c33de001u7E2LrC8VTiqKd","sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","messageID":"msg_f1c3bf42c001WfviR0BiYzmhCI"}}
{"type":"tool_use","timestamp":1782885136206,"sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","part":{"type":"tool","tool":"read","callID":"call_fnwczTryjBkdWo4Zcmgra2xS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/rules/check-graph-metadata-shape.sh","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/rules/check-graph-metadata-shape.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # ───────────────────────────────────────────────────────────────\n3: # RULE: CHECK-GRAPH-METADATA-SHAPE\n4: # ───────────────────────────────────────────────────────────────\n5: \n6: # Sourced by validate.sh and compatible with strict mode.\n7: set -euo pipefail\n8: \n9: # Rule: GRAPH_METADATA_SHAPE\n10: # Severity: warn\n11: # Description: Validates graph-metadata.json shape and phase-parent child pointers.\n12: \n13: run_check() {\n14:     local folder=\"$1\"\n15:     local _level=\"$2\"\n16:     local graph_file=\"$folder/graph-metadata.json\"\n17: \n18:     RULE_NAME=\"GRAPH_METADATA_SHAPE\"\n19:     RULE_STATUS=\"pass\"\n20:     RULE_MESSAGE=\"\"\n21:     RULE_DETAILS=()\n22:     RULE_REMEDIATION=\"\"\n23: \n24:     if [[ ! -f \"$graph_file\" ]]; then\n25:         RULE_STATUS=\"info\"\n26:         RULE_MESSAGE=\"graph-metadata.json missing; shape validation skipped\"\n27:         RULE_DETAILS=(\"Presence is handled by GRAPH_METADATA_PRESENT\")\n28:         return 0\n29:     fi\n30: \n31:     local shape_output\n32:     shape_output=$(node - \"$graph_file\" <<'EOF' 2>&1\n33: const fs = require(\"fs\");\n34: const filePath = process.argv[2];\n35: const errors = [];\n36: const warnings = [];\n37: \n38: let data;\n39: try {\n40:   data = JSON.parse(fs.readFileSync(filePath, \"utf8\"));\n41: } catch (error) {\n42:   console.log(`ERROR\\tInvalid JSON: ${error.message}`);\n43:   process.exit(0);\n44: }\n45: \n46: const isObject = (value) => value !== null && typeof value === \"object\" && !Array.isArray(value);\n47: const hasString = (object, key) => typeof object?.[key] === \"string\" && object[key].trim() !== \"\";\n48: const hasNumber = (object, key) => typeof object?.[key] === \"number\" && Number.isFinite(object[key]);\n49: \n50: if (isObject(data.packet)) {\n51:   if (!hasString(data.packet, \"id\")) errors.push(\"packet.id must be a non-empty string\");\n52:   if (\"track\" in data.packet && typeof data.packet.track !== \"string\") errors.push(\"packet.track must be a string when present\");\n53:   if (!hasNumber(data.packet, \"level\")) errors.push(\"packet.level must be a finite number\");\n54: } else if (!hasString(data, \"packet_id\")) {\n55:   errors.push(\"packet object with id/level is missing, and legacy packet_id fallback is absent\");\n56: }\n57: \n58: if (!isObject(data.derived)) {\n59:   errors.push(\"derived object is missing\");\n60: } else {\n61:   if (!hasString(data.derived, \"last_known_status\") && !hasString(data.derived, \"status\")) {\n62:     warnings.push(\"derived.last_known_status is missing, and legacy derived.status fallback is absent\");\n63:   }\n64: }\n65: \n66: for (const error of errors) console.log(`ERROR\\t${error}`);\n67: for (const warning of warnings) console.log(`WARN\\t${warning}`);\n68: EOF\n69: )\n70: \n71:     local -a errors=()\n72:     local -a warnings=()\n73:     local kind message\n74:     while IFS=$'\\t' read -r kind message; do\n75:         [[ -z \"${kind:-}\" ]] && continue\n76:         case \"$kind\" in\n77:             ERROR) errors+=(\"$message\") ;;\n78:             WARN) warnings+=(\"$message\") ;;\n79:             *) errors+=(\"$kind${message:+\t$message}\") ;;\n80:         esac\n81:     done <<< \"$shape_output\"\n82: \n83:     if is_phase_parent \"$folder\"; then\n84:         local last_active_child_id\n85:         last_active_child_id=$(node - \"$graph_file\" <<'EOF' 2>/dev/null || true\n86: const fs = require(\"fs\");\n87: const filePath = process.argv[2];\n88: try {\n89:   const data = JSON.parse(fs.readFileSync(filePath, \"utf8\"));\n90:   const value = data?.derived?.last_active_child_id;\n91:   if (typeof value === \"string\" && value.trim()) process.stdout.write(value.trim());\n92: } catch (_error) {}\n93: EOF\n94: )\n95:         # Accept a full packet_id (e.g. track/parent/004-child) by also testing\n96:         # the final path component, so callers that store the full id don't\n97:         # produce a spurious warning when the bare child dir exists.\n98:         local last_active_child_basename=\"${last_active_child_id##*/}\"\n99:         if [[ -n \"$last_active_child_id\" && ! -d \"$folder/$last_active_child_id\" && ! -d \"$folder/$last_active_child_basename\" ]]; then\n100:             warnings+=(\"derived.last_active_child_id '$last_active_child_id' does not match a real child folder\")\n101:         fi\n102:     fi\n103: \n104:     if [[ ${#errors[@]} -gt 0 ]]; then\n105:         RULE_STATUS=\"fail\"\n106:         RULE_MESSAGE=\"graph-metadata.json has ${#errors[@]} shape error(s)\"\n107:         RULE_DETAILS=(\"${errors[@]}\")\n108:         if [[ ${#warnings[@]} -gt 0 ]]; then\n109:             RULE_DETAILS+=(\"${warnings[@]}\")\n110:         fi\n111:         RULE_REMEDIATION=\"Refresh graph-metadata.json through the canonical save/backfill flow, or repair packet and derived metadata fields.\"\n112:         return 0\n113:     fi\n114: \n115:     if [[ ${#warnings[@]} -gt 0 ]]; then\n116:         RULE_STATUS=\"warn\"\n117:         RULE_MESSAGE=\"graph-metadata.json has ${#warnings[@]} shape warning(s)\"\n118:         RULE_DETAILS=(\"${warnings[@]}\")\n119:         RULE_REMEDIATION=\"Refresh graph-metadata.json so derived status and phase-parent pointers match the current contract.\"\n120:         return 0\n121:     fi\n122: \n123:     RULE_STATUS=\"pass\"\n124:     RULE_MESSAGE=\"graph-metadata.json shape validation passed\"\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# ───────────────────────────────────────────────────────────────\n# RULE: CHECK-GRAPH-METADATA-SHAPE\n# ───────────────────────────────────────────────────────────────\n\n# Sourced by validate.sh and compatible with strict mode.\nset -euo pipefail\n\n# Rule: GRAPH_METADATA_SHAPE\n# Severity: warn\n# Description: Validates graph-metadata.json shape and phase-parent child pointers.\n\nrun_check() {\n    local folder=\"$1\"\n    local _level=\"$2\"\n    local graph_file=\"$folder/graph-metadata.json\"\n\n    RULE_NAME=\"GRAPH_METADATA_SHAPE\"\n    RULE_STATUS=\"pass\"\n    RULE_MESSAGE=\"\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/rules/check-graph-metadata-shape.sh","text":"#!/usr/bin/env bash\n# ───────────────────────────────────────────────────────────────\n# RULE: CHECK-GRAPH-METADATA-SHAPE\n# ───────────────────────────────────────────────────────────────\n\n# Sourced by validate.sh and compatible with strict mode.\nset -euo pipefail\n\n# Rule: GRAPH_METADATA_SHAPE\n# Severity: warn\n# Description: Validates graph-metadata.json shape and phase-parent child pointers.\n\nrun_check() {\n    local folder=\"$1\"\n    local _level=\"$2\"\n    local graph_file=\"$folder/graph-metadata.json\"\n\n    RULE_NAME=\"GRAPH_METADATA_SHAPE\"\n    RULE_STATUS=\"pass\"\n    RULE_MESSAGE=\"\"\n    RULE_DETAILS=()\n    RULE_REMEDIATION=\"\"\n\n    if [[ ! -f \"$graph_file\" ]]; then\n        RULE_STATUS=\"info\"\n        RULE_MESSAGE=\"graph-metadata.json missing; shape validation skipped\"\n        RULE_DETAILS=(\"Presence is handled by GRAPH_METADATA_PRESENT\")\n        return 0\n    fi\n\n    local shape_output\n    shape_output=$(node - \"$graph_file\" <<'EOF' 2>&1\nconst fs = require(\"fs\");\nconst filePath = process.argv[2];\nconst errors = [];\nconst warnings = [];\n\nlet data;\ntry {\n  data = JSON.parse(fs.readFileSync(filePath, \"utf8\"));\n} catch (error) {\n  console.log(`ERROR\\tInvalid JSON: ${error.message}`);\n  process.exit(0);\n}\n\nconst isObject = (value) => value !== null && typeof value === \"object\" && !Array.isArray(value);\nconst hasString = (object, key) => typeof object?.[key] === \"string\" && object[key].trim() !== \"\";\nconst hasNumber = (object, key) => typeof object?.[key] === \"number\" && Number.isFinite(object[key]);\n\nif (isObject(data.packet)) {\n  if (!hasString(data.packet, \"id\")) errors.push(\"packet.id must be a non-empty string\");\n  if (\"track\" in data.packet && typeof data.packet.track !== \"string\") errors.push(\"packet.track must be a string when present\");\n  if (!hasNumber(data.packet, \"level\")) errors.push(\"packet.level must be a finite number\");\n} else if (!hasString(data, \"packet_id\")) {\n  errors.push(\"packet object with id/level is missing, and legacy packet_id fallback is absent\");\n}\n\nif (!isObject(data.derived)) {\n  errors.push(\"derived object is missing\");\n} else {\n  if (!hasString(data.derived, \"last_known_status\") && !hasString(data.derived, \"status\")) {\n    warnings.push(\"derived.last_known_status is missing, and legacy derived.status fallback is absent\");\n  }\n}\n\nfor (const error of errors) console.log(`ERROR\\t${error}`);\nfor (const warning of warnings) console.log(`WARN\\t${warning}`);\nEOF\n)\n\n    local -a errors=()\n    local -a warnings=()\n    local kind message\n    while IFS=$'\\t' read -r kind message; do\n        [[ -z \"${kind:-}\" ]] && continue\n        case \"$kind\" in\n            ERROR) errors+=(\"$message\") ;;\n            WARN) warnings+=(\"$message\") ;;\n            *) errors+=(\"$kind${message:+\t$message}\") ;;\n        esac\n    done <<< \"$shape_output\"\n\n    if is_phase_parent \"$folder\"; then\n        local last_active_child_id\n        last_active_child_id=$(node - \"$graph_file\" <<'EOF' 2>/dev/null || true\nconst fs = require(\"fs\");\nconst filePath = process.argv[2];\ntry {\n  const data = JSON.parse(fs.readFileSync(filePath, \"utf8\"));\n  const value = data?.derived?.last_active_child_id;\n  if (typeof value === \"string\" && value.trim()) process.stdout.write(value.trim());\n} catch (_error) {}\nEOF\n)\n        # Accept a full packet_id (e.g. track/parent/004-child) by also testing\n        # the final path component, so callers that store the full id don't\n        # produce a spurious warning when the bare child dir exists.\n        local last_active_child_basename=\"${last_active_child_id##*/}\"\n        if [[ -n \"$last_active_child_id\" && ! -d \"$folder/$last_active_child_id\" && ! -d \"$folder/$last_active_child_basename\" ]]; then\n            warnings+=(\"derived.last_active_child_id '$last_active_child_id' does not match a real child folder\")\n        fi\n    fi\n\n    if [[ ${#errors[@]} -gt 0 ]]; then\n        RULE_STATUS=\"fail\"\n        RULE_MESSAGE=\"graph-metadata.json has ${#errors[@]} shape error(s)\"\n        RULE_DETAILS=(\"${errors[@]}\")\n        if [[ ${#warnings[@]} -gt 0 ]]; then\n            RULE_DETAILS+=(\"${warnings[@]}\")\n        fi\n        RULE_REMEDIATION=\"Refresh graph-metadata.json through the canonical save/backfill flow, or repair packet and derived metadata fields.\"\n        return 0\n    fi\n\n    if [[ ${#warnings[@]} -gt 0 ]]; then\n        RULE_STATUS=\"warn\"\n        RULE_MESSAGE=\"graph-metadata.json has ${#warnings[@]} shape warning(s)\"\n        RULE_DETAILS=(\"${warnings[@]}\")\n        RULE_REMEDIATION=\"Refresh graph-metadata.json so derived status and phase-parent pointers match the current contract.\"\n        return 0\n    fi\n\n    RULE_STATUS=\"pass\"\n    RULE_MESSAGE=\"graph-metadata.json shape validation passed\"\n}","lineStart":1,"lineEnd":125,"totalLines":125,"truncated":false}},"title":".opencode/skills/system-spec-kit/scripts/rules/check-graph-metadata-shape.sh","time":{"start":1782885136203,"end":1782885136205}},"metadata":{"openai":{"itemId":"fc_08d9ba3343293e7c016a44ab0ec05c8191bc135e747f054197"}},"id":"prt_f1c3c3486001zost6z0GM8XgmP","sessionID":"ses_0e3d47d8bffeJ9bmuc4AVIwhXC","messageID":"msg_f1c3bf42c001WfviR0BiYzmhCI"}}
