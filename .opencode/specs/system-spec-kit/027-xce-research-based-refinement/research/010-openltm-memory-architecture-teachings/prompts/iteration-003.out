rs/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/index.ts:\n  Line 8: import { findDuplicates, saveDedupCandidates, type DedupResult } from \"./dedup.js\";\n\n  Line 35:   dedup: { pairsCompared: number; candidatesFound: number };\n\n  Line 103:     // 5. Find duplicates and save as pending for review\n\n  Line 105:       dedupResult = await findDuplicates(0.85, true);\n\n  Line 107:         saveDedupCandidates(dedupResult.candidates);\n\n  Line 110:       errors.push(`dedup: ${String(e)}`);\n\n  Line 123:     dedup: {\n\n  Line 211: export { mergeMemories, parseDedupSource } from \"./dedup.js\";\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/embeddings.ts:\n  Line 99:       `SELECT id, content FROM memories WHERE id IN (${placeholders}) AND status IN ('active', 'pending') ORDER BY id ASC`,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dao/types.ts:\n  Line 9: export type MemoryStatus = \"active\" | \"pending\" | \"deprecated\" | \"superseded\";\n\n  Line 11: export type ContextItemStatus = \"active\" | \"pending_promotion\" | \"promoted\";\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/dedup.ts:\n  Line 73: export async function findDuplicates(\n\n  Line 196: /** Parse a \"dedup:<idA>:<idB>\" source string. Returns null if not a dedup source. */\n\n  Line 198:   if (!source.startsWith(\"dedup:\")) return null;\n\n  Line 208:  * Persist dedup candidates as pending memories for UI review.\n\n  Line 209:  * source encodes \"dedup:<idA>:<idB>\" so the approve route can call mergeMemories.\n\n  Line 211: export function saveDedupCandidates(candidates: DedupCandidate[]): number {\n\n  Line 216:     const source = `dedup:${c.memoryA.id}:${c.memoryB.id}`;\n\n  Line 217:     // Skip if already pending for this pair\n\n  Line 220:         \"SELECT id FROM memories WHERE source = ? AND status = 'pending'\",\n\n  Line 235:        VALUES (?, ?, 3, ?, ?, NULL, NULL, 'pending')`,\n\n  Line 248: export function mergeMemories(\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/promote.ts:\n  Line 2:  * promote.ts — Auto-promote context_items (decisions/gotchas) to pending memories.\n\n  Line 4:  * this creates them as 'pending' for review in the approval UI.\n\n  Line 11:   /** Number of context_items promoted to pending memories. */\n\n  Line 24:  * 2. Status is 'active' (not already pending_promotion or promoted)\n\n  Line 28:  * Creates memories with status='pending' for review/approval.\n\n  Line 87:     // Create a pending memory\n\n  Line 90:        VALUES (?, ?, ?, 0.8, 'auto-promote', ?, ?, 'pending')`,\n\n  Line 96:     // Update the context_item to link it and mark as pending_promotion\n\n  Line 98:       \"UPDATE context_items SET memory_id = ?, status = 'pending_promotion' WHERE id = ?\",\n\n  Line 109:  * Approve a pending memory — set status to 'active'.\n\n  Line 120:   if (!mem || mem.status !== \"pending\") return false;\n\n  Line 132:  * Reject a pending memory — delete it and reset the context_item.\n\n  Line 142:   if (!mem || mem.status !== \"pending\") return false;\n\n  Line 150:   // Delete the pending memory\n\n  Line 157:  * Get all pending memories for the review UI.\n\n  Line 185:        FROM memories WHERE status = 'pending' ORDER BY created_at DESC`,\n","metadata":{"matches":48,"truncated":false},"title":"findDuplicates|saveDedupCandidates|mergeMemories|dedup:|pending","time":{"start":1780925365821,"end":1780925365851}},"metadata":{"openai":{"itemId":"fc_0513cea0dc69bacb016a26c3b5b5448191abcc86cb24c99184"}},"id":"prt_ea76c7e3b001fMyXXiJkshQ2m2","sessionID":"ses_158954ac9ffePahLx5YfsvlJLH","messageID":"msg_ea76c5425001IBHy3MXz8iMJrD"}}
