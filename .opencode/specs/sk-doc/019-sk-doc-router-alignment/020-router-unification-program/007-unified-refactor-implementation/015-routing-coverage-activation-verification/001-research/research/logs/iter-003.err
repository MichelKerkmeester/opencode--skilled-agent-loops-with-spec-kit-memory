.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deep-research-state.jsonl:4:{"type":"iteration","iteration":3,"run":3,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.82,"status":"complete","focus":"Automation surfaces and existing art for serialized publication and recovery","findingsCount":8,"noveltyJustification":"Compared local hooks, wrappers, daemons, remote queues, and adjacent tools; identified the daemon plus clean publisher as the low-latency surface and merge queues/Gerrit as stronger CI-gated remote analogues.","keyQuestions":["Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?","What do the named existing tools and workflows demonstrate or fail to guarantee?","Which conflict-avoidance and conflict-handling rules make concurrent additive work tractable?"],"answeredQuestions":["Which automation surface provides the right lifecycle, observability, and failure recovery characteristics?"],"ruledOut":[{"approach":"client hooks as the sole serializer","reason":"Hooks can reject or notify but do not provide durable shared queue ownership","evidence":"https://git-scm.com/docs/githooks"},{"approach":"force-push mirroring as shared-branch default","reason":"The cited action explicitly uses force push and requires a mirror backup","evidence":"https://github.com/wei/git-sync"},{"approach":"Syncthing-style file mirroring as Git integration","reason":"Replicates files but does not establish Git ref parentage or fast-forward publication","evidence":"https://docs.syncthing.net/users/faq.html"}],"graphEvents":[{"type":"node","id":"q-rq5","kind":"QUESTION","label":"RQ5 automation surface"},{"type":"node","id":"q-rq6","kind":"QUESTION","label":"RQ6 conflict handling"},{"type":"node","id":"q-rq7","kind":"QUESTION","label":"RQ7 existing art"},{"type":"node"