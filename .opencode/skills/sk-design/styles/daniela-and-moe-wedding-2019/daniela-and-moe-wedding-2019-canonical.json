    "components": [
      {
        "name": "Pill Navigation Button",
        "role": "Top nav links and interactive links",
        "description": "Text-only with 1-2px solid bottom border in Coral Vermillion (#ff5734). Calibre weight 400, ~16px, letter-spacing 0.2em. No background fill. The colored underline appears on hover/active. 200px border-radius despite being text links — the pill system is universal."
      },
      {
        "name": "Outlined Pill Button",
        "role": "Primary action buttons (RSVP, etc.)",
        "description": "1-2px solid border in Coral Vermillion (#ff5734), no fill, 200px border-radius. Padding approximately 6px 24px. Calibre weight 500, 12-16px, letter-spacing 0.2em, uppercase. White or blush background."
      },
      {
        "name": "White Quiz Card",
        "role": "Fun Facts grid items",
        "description": "Pure white (#ffffff) surface, no border, no shadow, no radius. Padding ~20-32px. Contains a line-art icon (64-80px) centered above a Calibre 16px label. Icons are thin-stroke line illustrations in #000000 or coral."
      },
      {
        "name": "Botanical Illustration Frame",
