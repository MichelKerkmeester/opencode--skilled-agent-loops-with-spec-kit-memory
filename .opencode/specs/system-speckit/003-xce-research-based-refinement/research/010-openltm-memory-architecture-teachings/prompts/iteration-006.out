path.basename(filePath)}`);\n2796:   }\n2797: \n2798:   // When a governance decision is threaded in (bulk scan/ingest), derive the\n2799:   // scope tuple from it so the row is created under the governed scope, matching\n2800:   // how the direct save path seeds saveScope from governanceDecision.normalized.\n2801:   const effectiveScope: MemoryScopeMatch = governance\n2802:     ? {\n2803:         tenantId: governance.normalized.tenantId ?? null,\n2804:         userId: governance.normalized.userId ?? null,\n2805:         agentId: governance.normalized.agentId ?? null,\n2806:         sessionId: governance.normalized.sessionId ?? null,\n2807:       }\n2808:     : scope;\n2809: \n2810:   const result = await processPreparedMemory(prepared, filePath, {\n2811:     force,\n2812:     asyncEmbedding,\n2813:     plannerMode,\n2814:     origin: indexingOrigin,\n2815:     persistQualityLoopContent: true,\n2816:     refreshFromDiskAfterLock: parsedOverride !== null,\n2817:     scope: effectiveScope,\n2818:     qualityGateMode,\n2819:     routing,\n2820:   });\n2821: \n2822:   // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n2823:   // direct memory_save path so governed bulk/scan/async ingests are not silently\n2824:   // downgraded to ungoverned rows. Only for freshly written rows.\n2825:   if (governance && typeof result.id === 'number' && result.id > 0\n2826:     && result.status !== 'unchanged' && result.status !== 'duplicate') {\n2827:     applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n2828:   }\n2829: \n2830:   return result;\n2831: }\n2832: \n2833: async function indexMemoryFileFromScan(\n2834:   filePath: string,\n2835:   options: BaseIndexMemoryFileOptions = {},\n2836: ): Promise<IndexResult> {\n2837:   return indexMemoryFile(filePath, {\n2838:     ...options,\n2839:     origin: 'scan',\n2840:   });\n2841: }\n2842: \n2843: /* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n2844: \n2845: // Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n2846: // entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n2847: // slots free.\n2848: const MAX_BACKGROUND_ENRICHMENTS = 4;\n2849: let activeBackgroundEnrichments = 0;\n2850: const backgroundEnrichmentQueue: Array<() => void> = [];\n2851: \n2852: /**\n2853:  * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n2854:  * - re-resolves the DB handle at run time (the save-time handle may have been recycled),\n2855:  * - skips rows that were superseded/deprecated before the deferred run starts, so it never\n2856:  *   repopulates purged entity/graph data for an inactive row,\n2857:  * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n2858:  *   skipped or dropped run is recovered by the pending-marker replay/backfill path.\n2859:  */\n2860: function scheduleBackgroundEnrichment(\n2861:   memoryId: number,\n2862:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n2863: ): void {\n2864:   const run = (): void => {\n2865:     activeBackgroundEnrichments++;\n2866:     void (async () => {\n2867:       try {\n2868:         let db: ReturnType<typeof requireDb>;\n2869:         try {\n2870:           db = requireDb();\n2871:         } catch {\n2872:           return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n2873:         }\n2874:         const row = db\n2875:           .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n2876:           .get(memoryId) as { importance_tier?: string } | undefined;\n2877:         if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n2878:           return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n2879:         }\n2880:         const result = await runPostInsertEnrichment(db, memoryId, parsed);\n2881:         recordEnrichmentResult(db, memoryId, result);\n2882:         invalidateEntityDensityCacheAfterSave();\n2883:       } catch (bgErr: unknown) {\n2884:         console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${bgErr instanceof Error ? bgErr.message : String(bgErr)}`);\n2885:       } finally {\n2886:         activeBackgroundEnrichments--;\n2887:         const next = backgroundEnrichmentQueue.shift();\n2888:         if (next) next();\n2889:       }\n2890:     })();\n2891:   };\n2892:   if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n2893:     setImmediate(run);\n2894:   } else {\n2895:     backgroundEnrichmentQueue.push(run);\n2896:   }\n2897: }\n2898: \n2899: /* --- 9. MEMORY SAVE HANDLER --- */\n2900: \n2901: /** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\n2902: async function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n2903:   // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n2904:   // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n2905:   // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n2906:   // carries a code (e.g. preflight.PreflightError) keeps it.\n2907:   const requestId = randomUUID();\n2908:   try {\n2909:     return await handleMemorySaveInner(args, requestId);\n\n(Showing lines 2770-2909 of 3763. Use offset=2910 to continue.)\n</content>","metadata":{"preview":"/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);\n  const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n  const database = requireDb();\n  const prepared = prepareParsedMemoryForIndexing(parsed, database);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"/** Parse, validate, and index a memory file with PE gating, FSRS scheduling, and causal links */\nasync function indexMemoryFile(\n  filePath: string,\n  {\n    force = false,\n    parsedOverride = null as ReturnType<typeof memoryParser.parseMemoryFile> | null,\n    asyncEmbedding = false,\n    plannerMode,\n    scope = {} as MemoryScopeMatch,\n    qualityGateMode = 'enforce' as 'enforce' | 'warn-only',\n    routing,\n    governance,\n    ...originOptions\n  }: IndexMemoryFileOptions | LegacyIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  // Reuse parsed content when provided by caller to avoid a second parse.\n  const indexingOrigin = resolveIndexingOrigin(originOptions);\n  const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n  const database = requireDb();\n  const prepared = prepareParsedMemoryForIndexing(parsed, database);\n  const validation = prepared.validation;\n  if (!validation.valid) {\n    throw new Error(`Validation failed: ${validation.errors.join(', ')}`);\n  }\n  if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n    console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(filePath)}`);\n  }\n\n  // When a governance decision is threaded in (bulk scan/ingest), derive the\n  // scope tuple from it so the row is created under the governed scope, matching\n  // how the direct save path seeds saveScope from governanceDecision.normalized.\n  const effectiveScope: MemoryScopeMatch = governance\n    ? {\n        tenantId: governance.normalized.tenantId ?? null,\n        userId: governance.normalized.userId ?? null,\n        agentId: governance.normalized.agentId ?? null,\n        sessionId: governance.normalized.sessionId ?? null,\n      }\n    : scope;\n\n  const result = await processPreparedMemory(prepared, filePath, {\n    force,\n    asyncEmbedding,\n    plannerMode,\n    origin: indexingOrigin,\n    persistQualityLoopContent: true,\n    refreshFromDiskAfterLock: parsedOverride !== null,\n    scope: effectiveScope,\n    qualityGateMode,\n    routing,\n  });\n\n  // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n  // direct memory_save path so governed bulk/scan/async ingests are not silently\n  // downgraded to ungoverned rows. Only for freshly written rows.\n  if (governance && typeof result.id === 'number' && result.id > 0\n    && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n  }\n\n  return result;\n}\n\nasync function indexMemoryFileFromScan(\n  filePath: string,\n  options: BaseIndexMemoryFileOptions = {},\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    ...options,\n    origin: 'scan',\n  });\n}\n\n/* --- 8b. BACKGROUND ENRICHMENT SCHEDULER --- */\n\n// Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n// entity extraction + a summary embedding + graph lifecycle). Excess work queues and drains as\n// slots free.\nconst MAX_BACKGROUND_ENRICHMENTS = 4;\nlet activeBackgroundEnrichments = 0;\nconst backgroundEnrichmentQueue: Array<() => void> = [];\n\n/**\n * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n * - re-resolves the DB handle at run time (the save-time handle may have been recycled),\n * - skips rows that were superseded/deprecated before the deferred run starts, so it never\n *   repopulates purged entity/graph data for an inactive row,\n * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n *   skipped or dropped run is recovered by the pending-marker replay/backfill path.\n */\nfunction scheduleBackgroundEnrichment(\n  memoryId: number,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n): void {\n  const run = (): void => {\n    activeBackgroundEnrichments++;\n    void (async () => {\n      try {\n        let db: ReturnType<typeof requireDb>;\n        try {\n          db = requireDb();\n        } catch {\n          return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n        }\n        const row = db\n          .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n          .get(memoryId) as { importance_tier?: string } | undefined;\n        if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n          return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n        }\n        const result = await runPostInsertEnrichment(db, memoryId, parsed);\n        recordEnrichmentResult(db, memoryId, result);\n        invalidateEntityDensityCacheAfterSave();\n      } catch (bgErr: unknown) {\n        console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${bgErr instanceof Error ? bgErr.message : String(bgErr)}`);\n      } finally {\n        activeBackgroundEnrichments--;\n        const next = backgroundEnrichmentQueue.shift();\n        if (next) next();\n      }\n    })();\n  };\n  if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n    setImmediate(run);\n  } else {\n    backgroundEnrichmentQueue.push(run);\n  }\n}\n\n/* --- 9. MEMORY SAVE HANDLER --- */\n\n/** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\nasync function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n  // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n  // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n  // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n  // carries a code (e.g. preflight.PreflightError) keeps it.\n  const requestId = randomUUID();\n  try {\n    return await handleMemorySaveInner(args, requestId);","lineStart":2770,"lineEnd":2909,"totalLines":3763,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1780925364049,"end":1780925364065}},"metadata":{"openai":{"itemId":"fc_0645ace1d6b6240d016a26c3b3aeac819190e40b8b2812260d"}},"id":"prt_ea76c7725001Uy95JeQhIt96Sz","sessionID":"ses_158954ad0ffekXAW2kKDcdcDwD","messageID":"msg_ea76c59f5001MdavuTb67rAqi1"}}
