{"type":"tool_use","timestamp":1780372922033,"sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","part":{"type":"tool","tool":"read","callID":"call_zxecqv8rWvmMmPGy1B1q43Hf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d4-ablation.cjs","offset":1,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d4-ablation.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * d4-ablation.cjs — D4 usefulness ablation (APPROXIMATE).\n6:  *\n7:  * \"Does the skill actually help?\" measured as the quality delta between a\n8:  * skill-ON run and a skill-OFF run of the same scenario, graded by the existing\n9:  * Lane B grader (gradeD4).\n10:  *\n11:  * Honest constraint (validated in the Phase 0 spike): opencode has no clean\n12:  * single-skill suppression. Skill-OFF is APPROXIMATED with\n13:  * MK_SKILL_ADVISOR_HOOK_DISABLED=1 + a \"do not load any skill\" preamble, then\n14:  * verified by checking the skill was NOT loaded/read (else the pair is dropped\n15:  * as contaminated). D4 scores are stamped attribution:\"approximate\".\n16:  */\n17: \n18: const path = require('path');\n19: const { runDispatch, parseLiveResult, buildLiveDispatchPrompt } = require('./live-executor.cjs');\n20: const grader = require('../model-benchmark/scorer/grader/harness.cjs');\n21: \n22: function clamp01(x) { return Math.max(0, Math.min(1, Number.isFinite(x) ? x : 0)); }\n23: \n24: // skill-OFF prompt: answer from the model's own knowledge, no skill, no project\n25: // skill-file reads. Pairs with MK_SKILL_ADVISOR_HOOK_DISABLED=1.\n26: function buildSkillOffPrompt(scenario) {\n27:   return [\n28:     'Answer ONLY from your own knowledge. Do NOT load any skill and do NOT read project skill files.',\n29:     `Task: ${scenario.prompt || ''}`,\n30:     'Emit ONLY a fenced ```json code block: {\"surface\": \"...\", \"resources\": [\"...\"], \"assets\": [\"...\"], \"agent\": \"none\"}',\n31:   ].join('\\n');\n32: }\n33: \n34: /**\n35:  * Grade the on/off output pair into a normalized D4 usefulness score.\n36:  * Deterministic when graderMode is a mock mode. score in [0,1]: 0.5 = no delta,\n37:  * 1 = skill-on fully better, 0 = skill-off better (skill hurt).\n38:  */\n39: async function gradeAblation({ scenario, onText, offText, graderMode = 'mock', cacheDir }) {\n40:   const base = {\n41:     variant_hash: 'live', rubric_version: 'v1.0.0', grader_model_build_hash: 'na',\n42:     mode: graderMode,\n43:     mock_mode: graderMode.startsWith('mock-') ? graderMode.slice('mock-'.length) : 'default',\n44:     cache_dir: cacheDir,\n45:   };\n46:   const rubric = scenario.passCriteria || scenario.prompt || '';\n47:   const onG = await grader.gradeD4({ fixture: { id: `${scenario.scenarioId}#on`, rubric }, swe16_output_text: onText || '', ...base });\n48:   const offG = await grader.gradeD4({ fixture: { id: `${scenario.scenarioId}#off`, rubric }, swe16_output_text: offText || '', ...base });\n49:   const onScore = clamp01(onG.score);\n50:   const offScore = clamp01(offG.score);\n51:   const score = clamp01(0.5 + (onScore - offScore) / 2);\n52:   return { d4: { score, onScore, offScore, attribution: 'approximate', graderMode }, raw: { onG, offG } };\n53: }\n54: \n55: /**\n56:  * Full live ablation: two real dispatches (on/off) + grade. Spends API.\n57:  */\n58: async function runD4Ablation({ scenario, skillRoot, model, variant, graderMode = 'mock', cacheDir }) {\n59:   const dir = path.resolve(skillRoot, '..', '..', '..');\n60:   const skillId = path.basename(skillRoot || '');\n61: \n62:   const on = runDispatch({ prompt: buildLiveDispatchPrompt(scenario), dir, model, variant });\n63:   const off = runDispatch({ prompt: buildSkillOffPrompt(scenario), dir, model, variant, extraEnv: { MK_SKILL_ADVISOR_HOOK_DISABLED: '1' } });\n64:   if (on.status !== 0 || off.status !== 0) {\n65:     return { d4: { score: null, unscored: 'ablation dispatch failed', attribution: 'approximate' } };\n66:   }\n67:   const onParsed = parseLiveResult(on.stdout, { skillId });\n68:   const offParsed = parseLiveResult(off.stdout, { skillId });\n69: \n70:   // Contamination guard: skill-OFF must NOT have loaded/read the skill.\n\n(Showing lines 1-70 of 83. Use offset=71 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * d4-ablation.cjs — D4 usefulness ablation (APPROXIMATE).\n *\n * \"Does the skill actually help?\" measured as the quality delta between a\n * skill-ON run and a skill-OFF run of the same scenario, graded by the existing\n * Lane B grader (gradeD4).\n *\n * Honest constraint (validated in the Phase 0 spike): opencode has no clean\n * single-skill suppression. Skill-OFF is APPROXIMATED with\n * MK_SKILL_ADVISOR_HOOK_DISABLED=1 + a \"do not load any skill\" preamble, then\n * verified by checking the skill was NOT loaded/read (else the pair is dropped\n * as contaminated). D4 scores are stamped attribution:\"approximate\".\n */\n\nconst path = require('path');\nconst { runDispatch, parseLiveResult, buildLiveDispatchPrompt } = require('./live-executor.cjs');\nconst grader = require('../model-benchmark/scorer/grader/harness.cjs');","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/d4-ablation.cjs","time":{"start":1780372922019,"end":1780372922032}},"metadata":{"openai":{"itemId":"fc_05e68bb8ceab49bb016a1e55b9ef648191ba5886f0abb03b07"}},"id":"prt_e867edea0001dkkSiUdvv8TijZ","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867ebf17001C9Xqk30Qc4xtun"}}
