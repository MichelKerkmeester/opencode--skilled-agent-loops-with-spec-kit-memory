{"type":"tool_use","timestamp":1784180629693,"sessionID":"ses_0968f2113ffehJfWsGHuGr12Oc","part":{"type":"tool","tool":"read","callID":"call_538392c3ff44446aa387742f","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/shared/scripts/validate_document.py","offset":410,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/shared/scripts/validate_document.py</path>\n<type>file</type>\n<content>\n410:     return errors\n411: \n412: \n413: # ───────────────────────────────────────────────────────────────\n414: # 5. SECTION VALIDATION\n415: # ───────────────────────────────────────────────────────────────\n416: \n417: def validate_required_sections(content: str, doc_type_rules: Dict[str, Any]) -> List[Dict[str, Any]]:\n418:     \"\"\"Check that required sections are present.\"\"\"\n419:     errors = []\n420: \n421:     required = doc_type_rules.get('requiredSections', [])\n422:     section_aliases = doc_type_rules.get('sectionAliases', {})\n423: \n424:     # Compiled-contract commands are thin runtime dispatchers whose section content is\n425:     # rendered from a compiled source at invocation, not written in the .md file, so\n426:     # there is no prose section shape to require here.\n427:     contract_marker = doc_type_rules.get('compiledContractMarker')\n428:     if contract_marker and contract_marker in content:\n429:         return errors\n430: \n431:     # Build reverse alias map\n432:     reverse_aliases = {}\n433:     for alias, canonical in section_aliases.items():\n434:         reverse_aliases.setdefault(canonical, []).append(alias)\n435: \n436:     h2_pattern = re.compile(r'^## \\d+\\.\\s+[^\\n]+', re.MULTILINE)\n437:     headers = h2_pattern.findall(content)\n438: \n439:     # Keep both normalized and raw names for partial matching fallback\n440:     found_sections = set()\n441:     found_sections_raw = []\n442:     for header in headers:\n443:         match = re.search(r'^## \\d+\\.\\s+(?:[^\\w\\s]\\s+)?(.+)$', header)\n444:         if match:\n445:             raw_name = match.group(1).strip().lower()\n446:             section_name = normalize_section_name(raw_name)\n447:             found_sections.add(section_name)\n448:             found_sections_raw.append(raw_name)\n449: \n450:             if section_name in section_aliases:\n451:                 found_sections.add(section_aliases[section_name])\n452: \n453:     # A router command is a thin dispatcher (verify agent -> resolve mode/args -> hand\n454:     # off to owned presentation/workflow assets). It carries a router-specific section\n455:     # vocabulary instead of the general purpose/instructions sections, so detect that\n456:     # shape and require only the minimal router core, treating the rest as recommended.\n457:     # A section counts as present if its canonical name is a found header OR a known\n458:     # space-form alias of it normalizes (space->underscore) to a found header.\n459:     def section_present(canonical: str) -> bool:\n460:         if canonical in found_sections:\n461:             return True\n462:         for alias in reverse_aliases.get(canonical, []):\n463:             if alias.replace(' ', '_') in found_sections:\n464:                 return True\n465:         return False\n466: \n467:     detect_primary = doc_type_rules.get('routerDetectPrimary', [])\n468:     structural = doc_type_rules.get('routerStructuralSections', [])\n469:     is_router = (\n470:         any(section_present(sig) for sig in detect_primary)\n471:         or sum(1 for sig in structural if section_present(sig)) >= 2\n472:     )\n473:     if is_router:\n474:         required = doc_type_rules.get('routerRequiredSections', required)\n475: \n476:     for req_section in required:\n477:         found = req_section in found_sections\n478: \n479:         if not found:\n480:             aliases = reverse_aliases.get(req_section, [])\n481:             for alias in aliases:\n482:                 if alias.replace(' ', '_') in found_sections:\n483:                     found = True\n484:                     break\n485: \n486:         # Fuzzy match: accept if all required words appear in section name\n487:         if not found:\n488:             req_words = req_section.replace('_', ' ').split()\n489:             for raw_section in found_sections_raw:\n490:                 if all(word in raw_section for word in req_words):\n491:                     found = True\n492:                     break\n493: \n494:         if not found:\n495:             errors.append({\n496:                 'type': 'missing_required_section',\n497:                 'severity': 'blocking',\n498:                 'message': f'Missing required section: {req_section}',\n499:                 'fix_hint': f'Add section with name containing \"{req_section}\"'\n500:             })\n501: \n502:     # Router shape beyond the minimal core is recommended, not required: surface any\n503:     # missing canonical router section as a non-blocking warning so authors converge on\n504:     # the full vocabulary without failing incremental migrations.\n505:     if is_router:\n506:         for rec_section in doc_type_rules.get('routerRecommendedSections', []):\n507:             if not section_present(rec_section):\n508:                 errors.append({\n509:                     'type': 'missing_recommended_router_section',\n510:                     'severity': 'warning',\n511:                     'message': f'Missing recommended router section: {rec_section}',\n512:                     'fix_hint': f'Add a \"{rec_section}\" section (recommended for router commands)'\n513:                 })\n514: \n515:     return errors\n516: \n517: \n518: # ───────────────────────────────────────────────────────────────\n519: # 6. AUTO-FIX\n520: # ───────────────────────────────────────────────────────────────\n521: \n522: def apply_fixes(content: str, errors: List[Dict[str, Any]]) -> Tuple[str, List[Dict[str, Any]]]:\n523:     \"\"\"\n524:     Apply auto-fixes to content.\n525: \n526:     Uses iterative approach: after each fix, re-validates and applies more fixes\n527:     until no more fixes can be applied. This handles cases where multiple fixes\n528:     affect the same line (e.g., single-dash anchor AND missing emoji).\n529:     \"\"\"\n530:     fixed_content = content\n531:     all_fixes_applied = []\n532:     max_iterations = 10  # Safety limit\n533: \n534:     for iteration in range(max_iterations):\n535:         fixes_this_round = []\n536: \n537:         for error in errors:\n538:             if not error.get('auto_fixable'):\n539:                 continue\n\n(Showing lines 410-539 of 933. Use offset=540 to continue.)\n</content>","metadata":{"preview":"    return errors\n\n\n# ───────────────────────────────────────────────────────────────\n# 5. SECTION VALIDATION\n# ───────────────────────────────────────────────────────────────\n\ndef validate_required_sections(content: str, doc_type_rules: Dict[str, Any]) -> List[Dict[str, Any]]:\n    \"\"\"Check that required sections are present.\"\"\"\n    errors = []\n\n    required = doc_type_rules.get('requiredSections', [])\n    section_aliases = doc_type_rules.get('sectionAliases', {})\n\n    # Compiled-contract commands are thin runtime dispatchers whose section content is\n    # rendered from a compiled source at invocation, not written in the .md file, so\n    # there is no prose section shape to require here.\n    contract_marker = doc_type_rules.get('compiledContractMarker')\n    if contract_marker and contract_marker in content:\n        return errors","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/shared/scripts/validate_document.py","text":"    return errors\n\n\n# ───────────────────────────────────────────────────────────────\n# 5. SECTION VALIDATION\n# ───────────────────────────────────────────────────────────────\n\ndef validate_required_sections(content: str, doc_type_rules: Dict[str, Any]) -> List[Dict[str, Any]]:\n    \"\"\"Check that required sections are present.\"\"\"\n    errors = []\n\n    required = doc_type_rules.get('requiredSections', [])\n    section_aliases = doc_type_rules.get('sectionAliases', {})\n\n    # Compiled-contract commands are thin runtime dispatchers whose section content is\n    # rendered from a compiled source at invocation, not written in the .md file, so\n    # there is no prose section shape to require here.\n    contract_marker = doc_type_rules.get('compiledContractMarker')\n    if contract_marker and contract_marker in content:\n        return errors\n\n    # Build reverse alias map\n    reverse_aliases = {}\n    for alias, canonical in section_aliases.items():\n        reverse_aliases.setdefault(canonical, []).append(alias)\n\n    h2_pattern = re.compile(r'^## \\d+\\.\\s+[^\\n]+', re.MULTILINE)\n    headers = h2_pattern.findall(content)\n\n    # Keep both normalized and raw names for partial matching fallback\n    found_sections = set()\n    found_sections_raw = []\n    for header in headers:\n        match = re.search(r'^## \\d+\\.\\s+(?:[^\\w\\s]\\s+)?(.+)$', header)\n        if match:\n            raw_name = match.group(1).strip().lower()\n            section_name = normalize_section_name(raw_name)\n            found_sections.add(section_name)\n            found_sections_raw.append(raw_name)\n\n            if section_name in section_aliases:\n                found_sections.add(section_aliases[section_name])\n\n    # A router command is a thin dispatcher (verify agent -> resolve mode/args -> hand\n    # off to owned presentation/workflow assets). It carries a router-specific section\n    # vocabulary instead of the general purpose/instructions sections, so detect that\n    # shape and require only the minimal router core, treating the rest as recommended.\n    # A section counts as present if its canonical name is a found header OR a known\n    # space-form alias of it normalizes (space->underscore) to a found header.\n    def section_present(canonical: str) -> bool:\n        if canonical in found_sections:\n            return True\n        for alias in reverse_aliases.get(canonical, []):\n            if alias.replace(' ', '_') in found_sections:\n                return True\n        return False\n\n    detect_primary = doc_type_rules.get('routerDetectPrimary', [])\n    structural = doc_type_rules.get('routerStructuralSections', [])\n    is_router = (\n        any(section_present(sig) for sig in detect_primary)\n        or sum(1 for sig in structural if section_present(sig)) >= 2\n    )\n    if is_router:\n        required = doc_type_rules.get('routerRequiredSections', required)\n\n    for req_section in required:\n        found = req_section in found_sections\n\n        if not found:\n            aliases = reverse_aliases.get(req_section, [])\n            for alias in aliases:\n                if alias.replace(' ', '_') in found_sections:\n                    found = True\n                    break\n\n        # Fuzzy match: accept if all required words appear in section name\n        if not found:\n            req_words = req_section.replace('_', ' ').split()\n            for raw_section in found_sections_raw:\n                if all(word in raw_section for word in req_words):\n                    found = True\n                    break\n\n        if not found:\n            errors.append({\n                'type': 'missing_required_section',\n                'severity': 'blocking',\n                'message': f'Missing required section: {req_section}',\n                'fix_hint': f'Add section with name containing \"{req_section}\"'\n            })\n\n    # Router shape beyond the minimal core is recommended, not required: surface any\n    # missing canonical router section as a non-blocking warning so authors converge on\n    # the full vocabulary without failing incremental migrations.\n    if is_router:\n        for rec_section in doc_type_rules.get('routerRecommendedSections', []):\n            if not section_present(rec_section):\n                errors.append({\n                    'type': 'missing_recommended_router_section',\n                    'severity': 'warning',\n                    'message': f'Missing recommended router section: {rec_section}',\n                    'fix_hint': f'Add a \"{rec_section}\" section (recommended for router commands)'\n                })\n\n    return errors\n\n\n# ───────────────────────────────────────────────────────────────\n# 6. AUTO-FIX\n# ───────────────────────────────────────────────────────────────\n\ndef apply_fixes(content: str, errors: List[Dict[str, Any]]) -> Tuple[str, List[Dict[str, Any]]]:\n    \"\"\"\n    Apply auto-fixes to content.\n\n    Uses iterative approach: after each fix, re-validates and applies more fixes\n    until no more fixes can be applied. This handles cases where multiple fixes\n    affect the same line (e.g., single-dash anchor AND missing emoji).\n    \"\"\"\n    fixed_content = content\n    all_fixes_applied = []\n    max_iterations = 10  # Safety limit\n\n    for iteration in range(max_iterations):\n        fixes_this_round = []\n\n        for error in errors:\n            if not error.get('auto_fixable'):\n                continue","lineStart":410,"lineEnd":539,"totalLines":933,"truncated":true}},"title":".opencode/skills/sk-doc/shared/scripts/validate_document.py","time":{"start":1784180629687,"end":1784180629691}},"id":"prt_f6973e0b5001V9UX53KQDjIeEU","sessionID":"ses_0968f2113ffehJfWsGHuGr12Oc","messageID":"msg_f6973b341001AZHoCgcZhSPmWK"}}
