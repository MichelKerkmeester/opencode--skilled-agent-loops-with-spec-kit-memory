ge unavailable (${reason}); reconnect`,\n600:       data: { retryable: true },\n601:     },\n602:   })}\\n`);\n603: }\n604: \n605: function bridgeReadiness(leaseResult) {\n606:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n607:     return { ready: false, reason: 'bridge-disabled' };\n608:   }\n609:   const storedSocketPath = leaseResult.socketPath;\n610:   if (\n611:     typeof storedSocketPath === 'string' &&\n612:     storedSocketPath.length > 0 &&\n613:     (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n614:   ) {\n\n(Showing lines 520-614 of 1612. Use offset=615 to continue.)\n</content>","metadata":{"preview":"  ownerLeaseHeartbeatTimer.unref?.();\n}\n\nfunction ownsOwnerLeaseFile(ownerPid = process.pid) {\n  const lease = readOwnerLeaseFile();\n  return lease?.ownerPid === ownerPid;\n}\n\nfunction clearOwnerLeaseFile() {\n  if (!Number.isInteger(ownerLeasePid)) return;\n  try {\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerLeasePid\n        && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  } finally {\n    clearOwnerLeaseHeartbeat();","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"  ownerLeaseHeartbeatTimer.unref?.();\n}\n\nfunction ownsOwnerLeaseFile(ownerPid = process.pid) {\n  const lease = readOwnerLeaseFile();\n  return lease?.ownerPid === ownerPid;\n}\n\nfunction clearOwnerLeaseFile() {\n  if (!Number.isInteger(ownerLeasePid)) return;\n  try {\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerLeasePid\n        && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  } finally {\n    clearOwnerLeaseHeartbeat();\n    ownerLeasePid 