en/paged.canonical.json\n      20 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/scales.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/structured-only.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/vector-only.canonical.json\n      70 total\n","metadata":{"output":"       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/degraded-disable-fts.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/exact-reuse.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/exclusions.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/facet-filter.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/fts-text.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/hybrid.canonical.json\n      41 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/index.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/paged.canonical.json\n      20 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/scales.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/structured-only.canonical.json\n       1 /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/vector-only.canonical.json\n      70 total\n","exit":0,"truncated":false},"title":"wc -l /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/golden/*.json 2>&1","time":{"start":1784606433716,"end":1784606433717}},"id":"prt_f82d521a3001nCLKeWMEfAygpB","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d50795001dpHeisOrucJchJ"}}
{"type":"tool_use","timestamp":1784606433719,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"bash","callID":"call_019f82d5212a73909c7db65e","state":{"status":"completed","input":{"command":"cd /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work && head -10 .opencode/skills/sk-design/styles/_db/oracle/golden/index.json 2>&1; echo \"---\"; head -3 .opencode/skills/sk-design/styles/_db/oracle/golden/scales.json 2>&1"},"output":"{\n  \"version\": 1,\n  \"scenarios\": [\n    {\n      \"name\": \"structured-only\",\n      \"sha256\": \"sha256:857d93b769410fa9f011a3a1850758dbfb05b655c9b87cd9847174baee80e724\"\n    },\n    {\n      \"name\": \"fts-text\",\n      \"sha256\": \"sha256:1aba97ee2cfe801388cace45683df78b535f1c595016b6116925cea5a07cefd8\"\n---\n{\n  \"version\": 1,\n  \"scales\": {\n","metadata":{"output":"{\n  \"version\": 1,\n  \"scenarios\": [\n    {\n      \"name\": \"structured-only\",\n      \"sha256\": \"sha256:857d93b769410fa9f011a3a1850758dbfb05b655c9b87cd9847174baee80e724\"\n    },\n    {\n      \"name\": \"fts-text\",\n      \"sha256\": \"sha256:1aba97ee2cfe801388cace45683df78b535f1c595016b6116925cea5a07cefd8\"\n---\n{\n  \"version\": 1,\n  \"scales\": {\n","exit":0,"truncated":false},"title":"cd /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work && head -10 .opencode/skills/sk-design/styles/_db/oracle/golden/index.json 2>&1; echo \"---\"; head -3 .opencode/skills/sk-design/styles/_db/oracle/golden/scales.json 2>&1","time":{"start":1784606433714,"end":1784606433718}},"id":"prt_f82d521a10015QR3W86gQ7osEU","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d50795001dpHeisOrucJchJ"}}
{"type":"tool_use","timestamp":1784606433724,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d5212a73909c7db670","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/replay-fixtures.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/replay-fixtures.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deterministic Replay Fixtures                                           ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Materialize representative corpora at three scales so every later phase can\n6: // replay parity and measure cost against a stable, reproducible input. Every\n7: // byte of a generated corpus is a pure function of an index-derived seed — no\n8: // wall-clock, no randomness — so regenerating a scale yields identical bytes and\n9: // the oracle reproduces identical query output. The 100x scale approximates the\n10: // real ~1,290-bundle corpus; the base multiplier is tunable per environment.\n11: \n12: import { mkdir, mkdtemp, readFile, readdir, rm } from 'node:fs/promises';\n13: import os from 'node:os';\n14: import path from 'node:path';\n15: \n16: import {\n17:   writeFixtureCrawlManifest,\n18:   writeFixtureStyle,\n19: } from '../../_engine/__tests__/fixtures.mjs';\n20: import { HASH_PREFIX, compareRawStrings, digest, stableJson } from '../canonical.mjs';\n21: import { buildOracleDatabase, captureOracle } from './differential-oracle.mjs';\n22: import { ORACLE_QUERY_SET } from './query-set.mjs';\n23: \n24: export const REPLAY_SCALES = Object.freeze({ '1x': 13, '10x': 130, '100x': 1_300 });\n25: \n26: // Per-class vocabulary pools. Cycling each field through a differently sized\n27: // pool keyed on the ordinal gives every style its own content while staying a\n28: // pure function of position: a 100x corpus is genuinely varied documents, not\n29: // a handful of duplicated templates, so ranking and fusion are exercised for\n30: // real at scale.\n31: const EDITORIAL_SURFACES = Object.freeze([\n32:   'warm cream', 'soft ivory', 'pale linen', 'sunlit sand', 'muted bone', 'gentle beige',\n33: ]);\n34: const EDITORIAL_VOICES = Object.freeze([\n35:   'a deliberate serif voice', 'an old-style serif rhythm',\n36:   'a transitional serif pairing', 'a humanist serif column',\n37: ]);\n38: const EDITORIAL_INDUSTRIES = Object.freeze(['Editorial', 'Publishing', 'Journalism', 'Longform']);\n39: const PRODUCT_SURFACES = Object.freeze([\n40:   'deep charcoal', 'cool slate', 'ink black', 'graphite steel', 'midnight navy', 'dim carbon',\n41: ]);\n42: const PRODUCT_MOTIONS = Object.freeze([\n43:   'kinetic motion', 'scroll-driven animation', 'springy transitions', 'animated overlays',\n44: ]);\n45: const PRODUCT_INDUSTRIES = Object.freeze(['SaaS', 'Fintech', 'Commerce', 'Gaming', 'Travel', 'Healthcare']);\n46: \n47: function toHex(value, length) {\n48:   return value.toString(16).padStart(length, '0');\n49: }\n50: \n51: function seededUuid(ordinal) {\n52:   return `${toHex(ordinal, 8)}-0000-4000-8000-${toHex(ordinal, 12)}`;\n53: }\n54: \n55: function pick(pool, ordinal) {\n56:   return pool[ordinal % pool.length];\n57: }\n58: \n59: /**\n60:  * Project document text onto the two-dimensional oracle vector space.\n61:  *\n62:  * The vector is a pure function of the document bytes, so a scaled corpus draws\n63:  * a stable spread of cosine similarities against the fixed query basis without\n64:  * a real embedding model — the vector, hybrid, and fusion lanes get honestly\n65:  * varied inputs that still reproduce byte-for-byte on every replay.\n66:  *\n67:  * @param {string} text - Document text passed by the vector drain.\n68:  * @returns {number[]} A stable, positive two-dimensional vector.\n69:  */\n70: export function scaledOracleEmbedder(text) {\n71:   const hex = digest(text).slice(HASH_PREFIX.length);\n72:   const first = (parseInt(hex.slice(0, 8), 16) % 997) + 1;\n73:   const second = (parseInt(hex.slice(8, 16), 16) % 997) + 1;\n74:   return [first, second];\n75: }\n76: \n77: /**\n78:  * Produce a deterministic list of scaled style definitions.\n79:  *\n80:  * @param {number} count - Number of styles to generate.\n81:  * @returns {Object[]} Ordered, reproducible style definitions.\n82:  */\n83: export function generateScaledStyles(count) {\n84:   return Array.from({ length: count }, (_, index) => {\n85:     const ordinal = index + 1;\n86:     const common = {\n87:       id: seededUuid(ordinal),\n88:       slug: `replay-${String(ordinal).padStart(5, '0')}`,\n89:     };\n90:     if (ordinal % 2 === 1) {\n91:       const surface = pick(EDITORIAL_SURFACES, ordinal);\n92:       const voice = pick(EDITORIAL_VOICES, ordinal);\n93:       const industry = pick(EDITORIAL_INDUSTRIES, ordinal);\n94:       return {\n95:         ...common,\n96:         title: `Replay Editorial ${ordinal}`,\n97:         thesis: `Warm ${surface} editorial system with ${voice}.`,\n98:         theme: 'light',\n99:         industry,\n100:         text: `${surface} serif typography with measured spacing, `\n101:           + `quiet ${industry.toLowerCase()} components, and ${voice}.`,\n102:       };\n103:     }\n104:     const surface = pick(PRODUCT_SURFACES, ordinal);\n105:     const motion = pick(PRODUCT_MOTIONS, ordinal);\n106:     const industry = pick(PRODUCT_INDUSTRIES, ordinal);\n107:     return {\n108:       ...common,\n109:       title: `Replay Product ${ordinal}`,\n110:       thesis: `${surface} product system with ${motion} and compact controls.`,\n111:       theme: 'dark',\n112:       industry,\n113:       text: `${surface} sans-serif ${industry.toLowerCase()} interface `\n114:         + `with ${motion} and animation transitions.`,\n115:     };\n116:   });\n117: }\n118: \n119: /**\n120:  * Materialize a deterministic corpus of the requested size to a temp directory.\n121:  *\n122:  * @param {number} count - Number of style bundles to write.\n123:  * @param {Object} [options] - Overrides.\n124:  * @param {Object[]} [options.styles] - Explicit style definitions.\n125:  * @returns {Promise<{root:string, base:string, styles:Object[], cleanup:Function}>} Fixture handle.\n126:  */\n127: export async function materializeReplayCorpus(count, { styles } = {}) {\n128:   const resolved = styles ?? generateScaledStyles(count);\n129:   const base = await mkdtemp(path.join(os.tmpdir(), 'style-replay-fixture-'));\n130:   const root = path.join(base, 'styles');\n131:   await mkdir(root);\n132:   await writeFixtureCrawlManifest(root, resolved);\n133:   for (const style of resolved) await writeFixtureStyle(root, style);\n134:   return {\n135:     root,\n136:     base,\n137:     styles: resolved,\n138:     cleanup: () => rm(base, { recursive: true, force: true }),\n139:   };\n140: }\n141: \n142: async function collectRelativeFiles(root, prefix = '') {\n143:   const entries = (await readdir(path.join(root, prefix), { withFileTypes: true }))\n144:     .sort((left, right) => compareRawStrings(left.name, right.name));\n145:   const files = [];\n146:   for (const entry of entries) {\n147:     const relative = prefix ? `${prefix}/${entry.name}` : entry.name;\n148:     if (entry.isDirectory()) files.push(...await collectRelativeFiles(root, relative));\n149:     else files.push(relative);\n150:   }\n151:   return files;\n152: }\n153: \n154: /**\n155:  * Content-address every byte of a materialized corpus for determinism checks.\n156:  *\n157:  * @param {string} root - Materialized corpus root.\n158:  * @returns {Promise<string>} Stable digest over all bundle bytes.\n159:  */\n160: export async function replayCorpusContentHash(root) {\n161:   const files = await collectRelativeFiles(root);\n162:   const entries = [];\n163:   for (const relative of files) {\n164:     entries.push({ path: relative, sha256: digest([await readFile(path.join(root, relative))]) });\n165:   }\n166:   return digest(stableJson(entries));\n167: }\n168: \n169: /**\n170:  * Build a scaled corpus into a query-ready oracle database with vectors drained.\n171:  *\n172:  * @param {string} root - Materialized corpus root.\n173:  * @returns {Promise<import('node:sqlite').DatabaseSync>} Ready database.\n174:  */\n175: export async function buildScaledOracleDatabase(root) {\n176:   return buildOracleDatabase({ corpusRoot: root, embedder: scaledOracleEmbedder });\n177: }\n178: \n179: /**\n180:  * Index a materialized corpus and hash the full oracle matrix outputs.\n181:  *\n182:  * The full query matrix — including the vector, hybrid, exact-reuse, and cursor\n183:  * lanes — replays against the scaled corpus with vectors drained, so parity is\n184:  * pinned across every ranking path at scale rather than only the structured and\n185:  * lexical probes.\n186:  *\n187:  * @param {string} root - Materialized corpus root.\n188:  * @returns {Promise<string>} Stable digest over the full-matrix captures.\n189:  */\n190: export async function captureScaleOracle(root) {\n191:   const database = await buildScaledOracleDatabase(root);\n192:   try {\n193:     const captures = captureOracle(database, ORACLE_QUERY_SET);\n194:     return digest(stableJson(captures.map(({ name, sha256 }) => ({ name, sha256 }))));\n195:   } finally {\n196:     database.close();\n197:   }\n198: }\n\n(End of file - total 198 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deterministic Replay Fixtures                                           ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Materialize representative corpora at three scales so every later phase can\n// replay parity and measure cost against a stable, reproducible input. Every\n// byte of a generated corpus is a pure function of an index-derived seed — no\n// wall-clock, no randomness — so regenerating a scale yields identical bytes and\n// the oracle reproduces identical query output. The 100x scale approximates the\n// real ~1,290-bundle corpus; the base multiplier is tunable per environment.\n\nimport { mkdir, mkdtemp, readFile, readdir, rm } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport {\n  writeFixtureCrawlManifest,\n  writeFixtureStyle,\n} from '../../_engine/__tests__/fixtures.mjs';\nimport { HASH_PREFIX, compareRawStrings, digest, stableJson } from '../canonical.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/replay-fixtures.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deterministic Replay Fixtures                                           ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Materialize representative corpora at three scales so every later phase can\n// replay parity and measure cost against a stable, reproducible input. Every\n// byte of a generated corpus is a pure function of an index-derived seed — no\n// wall-clock, no randomness — so regenerating a scale yields identical bytes and\n// the oracle reproduces identical query output. The 100x scale approximates the\n// real ~1,290-bundle corpus; the base multiplier is tunable per environment.\n\nimport { mkdir, mkdtemp, readFile, readdir, rm } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport {\n  writeFixtureCrawlManifest,\n  writeFixtureStyle,\n} from '../../_engine/__tests__/fixtures.mjs';\nimport { HASH_PREFIX, compareRawStrings, digest, stableJson } from '../canonical.mjs';\nimport { buildOracleDatabase, captureOracle } from './differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from './query-set.mjs';\n\nexport const REPLAY_SCALES = Object.freeze({ '1x': 13, '10x': 130, '100x': 1_300 });\n\n// Per-class vocabulary pools. Cycling each field through a differently sized\n// pool keyed on the ordinal gives every style its own content while staying a\n// pure function of position: a 100x corpus is genuinely varied documents, not\n// a handful of duplicated templates, so ranking and fusion are exercised for\n// real at scale.\nconst EDITORIAL_SURFACES = Object.freeze([\n  'warm cream', 'soft ivory', 'pale linen', 'sunlit sand', 'muted bone', 'gentle beige',\n]);\nconst EDITORIAL_VOICES = Object.freeze([\n  'a deliberate serif voice', 'an old-style serif rhythm',\n  'a transitional serif pairing', 'a humanist serif column',\n]);\nconst EDITORIAL_INDUSTRIES = Object.freeze(['Editorial', 'Publishing', 'Journalism', 'Longform']);\nconst PRODUCT_SURFACES = Object.freeze([\n  'deep charcoal', 'cool slate', 'ink black', 'graphite steel', 'midnight navy', 'dim carbon',\n]);\nconst PRODUCT_MOTIONS = Object.freeze([\n  'kinetic motion', 'scroll-driven animation', 'springy transitions', 'animated overlays',\n]);\nconst PRODUCT_INDUSTRIES = Object.freeze(['SaaS', 'Fintech', 'Commerce', 'Gaming', 'Travel', 'Healthcare']);\n\nfunction toHex(value, length) {\n  return value.toString(16).padStart(length, '0');\n}\n\nfunction seededUuid(ordinal) {\n  return `${toHex(ordinal, 8)}-0000-4000-8000-${toHex(ordinal, 12)}`;\n}\n\nfunction pick(pool, ordinal) {\n  return pool[ordinal % pool.length];\n}\n\n/**\n * Project document text onto the two-dimensional oracle vector space.\n *\n * The vector is a pure function of the document bytes, so a scaled corpus draws\n * a stable spread of cosine similarities against the fixed query basis without\n * a real embedding model — the vector, hybrid, and fusion lanes get honestly\n * varied inputs that still reproduce byte-for-byte on every replay.\n *\n * @param {string} text - Document text passed by the vector drain.\n * @returns {number[]} A stable, positive two-dimensional vector.\n */\nexport function scaledOracleEmbedder(text) {\n  const hex = digest(text).slice(HASH_PREFIX.length);\n  const first = (parseInt(hex.slice(0, 8), 16) % 997) + 1;\n  const second = (parseInt(hex.slice(8, 16), 16) % 997) + 1;\n  return [first, second];\n}\n\n/**\n * Produce a deterministic list of scaled style definitions.\n *\n * @param {number} count - Number of styles to generate.\n * @returns {Object[]} Ordered, reproducible style definitions.\n */\nexport function generateScaledStyles(count) {\n  return Array.from({ length: count }, (_, index) => {\n    const ordinal = index + 1;\n    const common = {\n      id: seededUuid(ordinal),\n      slug: `replay-${String(ordinal).padStart(5, '0')}`,\n    };\n    if (ordinal % 2 === 1) {\n      const surface = pick(EDITORIAL_SURFACES, ordinal);\n      const voice = pick(EDITORIAL_VOICES, ordinal);\n      const industry = pick(EDITORIAL_INDUSTRIES, ordinal);\n      return {\n        ...common,\n        title: `Replay Editorial ${ordinal}`,\n        thesis: `Warm ${surface} editorial system with ${voice}.`,\n        theme: 'light',\n        industry,\n        text: `${surface} serif typography with measured spacing, `\n          + `quiet ${industry.toLowerCase()} components, and ${voice}.`,\n      };\n    }\n    const surface = pick(PRODUCT_SURFACES, ordinal);\n    const motion = pick(PRODUCT_MOTIONS, ordinal);\n    const industry = pick(PRODUCT_INDUSTRIES, ordinal);\n    return {\n      ...common,\n      title: `Replay Product ${ordinal}`,\n      thesis: `${surface} product system with ${motion} and compact controls.`,\n      theme: 'dark',\n      industry,\n      text: `${surface} sans-serif ${industry.toLowerCase()} interface `\n        + `with ${motion} and animation transitions.`,\n    };\n  });\n}\n\n/**\n * Materialize a deterministic corpus of the requested size to a temp directory.\n *\n * @param {number} count - Number of style bundles to write.\n * @param {Object} [options] - Overrides.\n * @param {Object[]} [options.styles] - Explicit style definitions.\n * @returns {Promise<{root:string, base:string, styles:Object[], cleanup:Function}>} Fixture handle.\n */\nexport async function materializeReplayCorpus(count, { styles } = {}) {\n  const resolved = styles ?? generateScaledStyles(count);\n  const base = await mkdtemp(path.join(os.tmpdir(), 'style-replay-fixture-'));\n  const root = path.join(base, 'styles');\n  await mkdir(root);\n  await writeFixtureCrawlManifest(root, resolved);\n  for (const style of resolved) await writeFixtureStyle(root, style);\n  return {\n    root,\n    base,\n    styles: resolved,\n    cleanup: () => rm(base, { recursive: true, force: true }),\n  };\n}\n\nasync function collectRelativeFiles(root, prefix = '') {\n  const entries = (await readdir(path.join(root, prefix), { withFileTypes: true }))\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const files = [];\n  for (const entry of entries) {\n    const relative = prefix ? `${prefix}/${entry.name}` : entry.name;\n    if (entry.isDirectory()) files.push(...await collectRelativeFiles(root, relative));\n    else files.push(relative);\n  }\n  return files;\n}\n\n/**\n * Content-address every byte of a materialized corpus for determinism checks.\n *\n * @param {string} root - Materialized corpus root.\n * @returns {Promise<string>} Stable digest over all bundle bytes.\n */\nexport async function replayCorpusContentHash(root) {\n  const files = await collectRelativeFiles(root);\n  const entries = [];\n  for (const relative of files) {\n    entries.push({ path: relative, sha256: digest([await readFile(path.join(root, relative))]) });\n  }\n  return digest(stableJson(entries));\n}\n\n/**\n * Build a scaled corpus into a query-ready oracle database with vectors drained.\n *\n * @param {string} root - Materialized corpus root.\n * @returns {Promise<import('node:sqlite').DatabaseSync>} Ready database.\n */\nexport async function buildScaledOracleDatabase(root) {\n  return buildOracleDatabase({ corpusRoot: root, embedder: scaledOracleEmbedder });\n}\n\n/**\n * Index a materialized corpus and hash the full oracle matrix outputs.\n *\n * The full query matrix — including the vector, hybrid, exact-reuse, and cursor\n * lanes — replays against the scaled corpus with vectors drained, so parity is\n * pinned across every ranking path at scale rather than only the structured and\n * lexical probes.\n *\n * @param {string} root - Materialized corpus root.\n * @returns {Promise<string>} Stable digest over the full-matrix captures.\n */\nexport async function captureScaleOracle(root) {\n  const database = await buildScaledOracleDatabase(root);\n  try {\n    const captures = captureOracle(database, ORACLE_QUERY_SET);\n    return digest(stableJson(captures.map(({ name, sha256 }) => ({ name, sha256 }))));\n  } finally {\n    database.close();\n  }\n}","lineStart":1,"lineEnd":198,"totalLines":198,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/oracle/replay-fixtures.mjs","time":{"start":1784606433708,"end":1784606433722}},"id":"prt_f82d521a6001YzE0jLFv3gT75S","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d50795001dpHeisOrucJchJ"}}
{"type":"step_finish","timestamp":1784606434162,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d52370001N1YIyOFcYBS4wZ","reason":"tool-calls","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","messageID":"msg_f82d50795001dpHeisOrucJchJ","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","type":"step-finish","tokens":{"total":133043,"input":905,"output":426,"reasoning":0,"cache":{"write":0,"read":131712}},"cost":0.00868542}}
{"type":"step_start","timestamp":1784606437510,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d53085001dXhgM6foV1mliz","messageID":"msg_f82d524f5001zunJvYppKOqU06","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","type":"step-start"}}
{"type":"tool_use","timestamp":1784606439649,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d537da75f0807c5ae8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/relevance-judgments.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/relevance-judgments.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Honestly-Labeled Relevance Judgments                                    ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Retrieval-quality ground truth without inventing a single label. Two real\n6: // signals are the only sources: `authored-similar` rows trace to a style's own\n7: // designSystem.similar[] authorship (a human wrote \"these are alike\") resolved\n8: // against the corpus, and `silver-heuristic` rows are retrieval-derived weak\n9: // positives where a candidate independently agrees across lanes. Every row\n10: // carries its source and provenance; none is presented as human gold, and the\n11: // seed header states that human relevance labeling is still required.\n12: \n13: import { mkdir, mkdtemp, readFile, rm } from 'node:fs/promises';\n14: import os from 'node:os';\n15: import path from 'node:path';\n16: \n17: import { compareRawStrings } from '../canonical.mjs';\n18: import { indexStyleCorpus } from '../indexer.mjs';\n19: import { queryPersistentStyles } from '../retrieval.mjs';\n20: import { openStyleDatabase } from '../schema.mjs';\n21: \n22: export const JUDGMENT_LABEL_SOURCES = Object.freeze(['authored-similar', 'silver-heuristic']);\n23: export const JUDGMENT_SEED_VERSION = 1;\n24: \n25: // A small deterministic corpus whose styles cite each other in designSystem\n26: // .similar[], giving authored-similar derivation real resolved relationships.\n27: const JUDGMENT_STYLES = Object.freeze([\n28:   {\n29:     id: 'aaaaaaaa-1111-4111-8111-aaaaaaaaaaaa',\n30:     slug: 'alpha-editorial',\n31:     title: 'Alpha Editorial',\n32:     theme: 'light',\n33:     industry: 'Editorial',\n34:     text: 'Warm cream serif typography with measured spacing and quiet components.',\n35:     similar: [{ business: 'Beta Product', why: 'Shared editorial restraint.' }],\n36:   },\n37:   {\n38:     id: 'bbbbbbbb-2222-4222-8222-bbbbbbbbbbbb',\n39:     slug: 'beta-product',\n40:     title: 'Beta Product',\n41:     theme: 'dark',\n42:     industry: 'SaaS',\n43:     text: 'Dark sans-serif product interface with animation and motion transitions.',\n44:     similar: [{ business: 'Alpha Editorial', why: 'Shared structural rigor.' }],\n45:   },\n46:   {\n47:     id: 'cccccccc-3333-4333-8333-cccccccccccc',\n48:     slug: 'gamma-editorial',\n49:     title: 'Gamma Editorial',\n50:     theme: 'light',\n51:     industry: 'Editorial',\n52:     text: 'Warm cream serif typography with a deliberate serif role.',\n53:     similar: [{ business: 'Alpha Editorial', why: 'Editorial kinship.' }],\n54:   },\n55:   {\n56:     id: 'dddddddd-4444-4444-8444-dddddddddddd',\n57:     slug: 'delta-product',\n58:     title: 'Delta Product',\n59:     theme: 'dark',\n60:     industry: 'SaaS',\n61:     text: 'Dark sans-serif motion product interface with animation.',\n62:     similar: [{ business: 'Beta Product', why: 'Product-system kinship.' }],\n63:   },\n64: ]);\n65: \n66: // Fixed probes that force independent lane agreement: an exact required-facet\n67: // match (structured) that also matches lexically (FTS).\n68: const SILVER_PROBE_QUERIES = Object.freeze([\n69:   { text: 'warm cream serif typography', requiredFacets: ['warm-surface'] },\n70:   { text: 'motion animation product interface', requiredFacets: ['motion'] },\n71: ]);\n72: \n73: function judgmentCanonical(style) {\n74:   return {\n75:     source: `https://styles.example.test/${style.id}`,\n76:     uuid: style.id,\n77:     name: style.title,\n78:     northStar: style.text,\n79:     capturedAt: '2026-01-01T00:00:00.000Z',\n80:     meta: { url: `https://${style.slug}.example.test` },\n81:     screenshot: { url: `https://images.example.test/${style.slug}.jpg` },\n82:     designSystem: {\n83:       theme: style.theme,\n84:       industry: style.industry,\n85:       description: style.text,\n86:       colors: [{ name: 'Canvas', hex: '#ffffff' }],\n87:       typography: [{ family: style.text.includes('serif') ? 'Source Serif' : 'Inter' }],\n88:       spacing: { sectionGap: '64px' },\n89:       components: [{ name: 'Button' }],\n90:       dos: ['Keep one coherent anchor.'],\n91:       donts: ['Do not average token values.'],\n92:       layout: 'Centered grid',\n93:       imagery: 'Editorial photography',\n94:       similar: style.similar,\n95:     },\n96:   };\n97: }\n98: \n99: function judgmentDesignMarkdown(style) {\n100:   return `# ${style.title} — Style Reference\\n> ${style.text}\\n\\n`\n101:     + `## Tokens — Colors\\n${style.text}\\n\\n`\n102:     + '## Tokens — Typography\\nSource Serif and Inter\\n\\n'\n103:     + '## Components\\nButton\\n';\n104: }\n105: \n106: async function writeJudgmentStyle(root, style) {\n107:   const { writeFile } = await import('node:fs/promises');\n108:   const styleRoot = path.join(root, style.slug);\n109:   await mkdir(styleRoot, { recursive: true });\n110:   await writeFile(\n111:     path.join(styleRoot, `${style.slug}-canonical.json`),\n112:     `${JSON.stringify(judgmentCanonical(style), null, 2)}\\n`,\n113:   );\n114:   await writeFile(path.join(styleRoot, 'DESIGN.md'), judgmentDesignMarkdown(style));\n115:   await writeFile(\n116:     path.join(styleRoot, 'source.md'),\n117:     `# ${style.title} — source\\n\\n- **Style UUID:** \\`${style.id}\\`\\n`,\n118:   );\n119: }\n120: \n121: async function writeJudgmentCrawlManifest(root, styles) {\n122:   const { writeFile } = await import('node:fs/promises');\n123:   const records = styles.map((style) => ({\n124:     uuid: style.id,\n125:     url: `https://styles.example.test/${style.id}`,\n126:     slug: style.slug,\n127:     status: 'captured',\n128:     capturedAt: '2026-01-01T00:00:00.000Z',\n129:     error: null,\n130:   }));\n131:   await writeFile(path.join(root, '_manifest.json'), `${JSON.stringify(records, null, 2)}\\n`);\n132: }\n133: \n134: /**\n135:  * Build an in-memory database over the deterministic judgment corpus.\n136:  *\n137:  * @returns {Promise<{database:Object, styles:Object[], cleanup:Function}>} Judgment database handle.\n138:  */\n139: export async function buildJudgmentDatabase() {\n140:   const base = await mkdtemp(path.join(os.tmpdir(), 'style-judgment-fixture-'));\n141:   const root = path.join(base, 'styles');\n142:   await mkdir(root);\n143:   await writeJudgmentCrawlManifest(root, JUDGMENT_STYLES);\n144:   for (const style of JUDGMENT_STYLES) await writeJudgmentStyle(root, style);\n145:   const database = openStyleDatabase();\n146:   await indexStyleCorpus({ corpusRoot: root, database, corpusWalkMode: 'migration' });\n147:   await rm(base, { recursive: true, force: true });\n148:   return { database, styles: JUDGMENT_STYLES, cleanup: () => database.close() };\n149: }\n150: \n151: /**\n152:  * Derive positive judgments from resolved authored similarity relationships.\n153:  *\n154:  * @param {Object} database - Indexed style database.\n155:  * @returns {Object[]} Authored-similar judgment rows.\n156:  */\n157: export function deriveAuthoredSimilarJudgments(database) {\n158:   const rows = database.prepare(`\n159:     SELECT source.style_id AS source_id, target.style_id AS target_id,\n160:       relationship.raw_target_label AS raw_target_label\n161:     FROM style_relationships relationship\n162:     JOIN styles source ON source.style_rowid = relationship.source_style_rowid\n163:     JOIN styles target ON target.style_rowid = relationship.target_style_rowid\n164:     WHERE relationship.resolution_state = 'resolved'\n165:     ORDER BY source.style_id ASC, target.style_id ASC\n166:   `).all();\n167:   return rows.map((row) => ({\n168:     query: { styleId: row.source_id },\n169:     relevant: [row.target_id],\n170:     label_source: 'authored-similar',\n171:     confidence: 1,\n172:     provenance: {\n173:       table: 'style_relationships',\n174:       resolutionState: 'resolved',\n175:       rawTargetLabel: row.raw_target_label,\n176:     },\n177:   }));\n178: }\n179: \n180: /**\n181:  * Derive weak positives where a candidate independently agrees across lanes.\n182:  *\n183:  * @param {Object} database - Indexed style database.\n184:  * @param {Object} [options] - Overrides.\n185:  * @param {Object[]} [options.queries=SILVER_PROBE_QUERIES] - Probe requests.\n186:  * @returns {Object[]} Silver-heuristic judgment rows.\n187:  */\n188: export function deriveSilverHeuristicJudgments(database, { queries = SILVER_PROBE_QUERIES } = {}) {\n189:   const judgments = [];\n190:   for (const query of queries) {\n191:     const result = queryPersistentStyles(query, { database });\n192:     for (const card of result.cards) {\n193:       const attribution = result.attributions[card.id];\n194:       const agreeingChannels = Object.keys(attribution?.sourceRanks ?? {}).sort(compareRawStrings);\n195:       if (agreeingChannels.length < 2) continue;\n196:       judgments.push({\n197:         query: { text: query.text, requiredFacets: query.requiredFacets ?? [] },\n198:         relevant: [card.id],\n199:         label_source: 'silver-heuristic',\n200:         confidence: 0.4,\n201:         provenance: {\n202:           method: 'cross-lane-agreement',\n203:           agreeingChannels,\n204:           requiredFacets: query.requiredFacets ?? [],\n205:         },\n206:       });\n207:     }\n208:   }\n209:   return judgments.sort((left, right) => (\n210:     compareRawStrings(stableProbeKey(left), stableProbeKey(right))\n211:     || compareRawStrings(left.relevant[0], right.relevant[0])\n212:   ));\n213: }\n214: \n215: function stableProbeKey(judgment) {\n216:   return `${judgment.query.text}\u0000${(judgment.query.requiredFacets ?? []).join(',')}`;\n217: }\n218: \n219: /**\n220:  * Assemble the full, honestly-labeled judgment seed document.\n221:  *\n222:  * @param {Object} database - Indexed judgment database.\n223:  * @returns {Object} Versioned seed with a human-labeling-required header.\n224:  */\n225: export function buildJudgmentSeed(database) {\n226:   const authored = deriveAuthoredSimilarJudgments(database);\n227:   const silver = deriveSilverHeuristicJudgments(database);\n228:   return {\n229:     seedVersion: JUDGMENT_SEED_VERSION,\n230:     humanLabelingRequired: true,\n231:     warning: 'No row here is human-authored gold. authored-similar rows trace to '\n232:       + 'designSystem.similar[] authorship resolved against the corpus; silver-heuristic '\n233:       + 'rows are retrieval-derived pseudo-labels from cross-lane agreement. A true judged '\n234:       + 'qrels set still requires human relevance labeling.',\n235:     labelSources: [...JUDGMENT_LABEL_SOURCES],\n236:     method: {\n237:       'authored-similar': 'Resolved style_relationships parsed from each style\\'s '\n238:         + 'designSystem.similar[] similarity claims.',\n239:       'silver-heuristic': 'Candidates appearing in two or more independent retrieval lanes '\n240:         + 'for a fixed exact-facet probe query; weak positive at confidence 0.4.',\n241:     },\n242:     judgments: [...authored, ...silver],\n243:   };\n244: }\n245: \n246: /**\n247:  * Validate one judgment row's provenance and label honesty.\n248:  *\n249:  * @param {Object} row - Judgment row.\n250:  * @returns {string[]} Problem descriptions; empty when the row is valid.\n251:  */\n252: export function validateJudgmentRow(row) {\n253:   const problems = [];\n254:   if (!row || typeof row !== 'object') return ['row is not an object'];\n255:   if (!JUDGMENT_LABEL_SOURCES.includes(row.label_source)) {\n256:     problems.push(`label_source must be one of ${JUDGMENT_LABEL_SOURCES.join(', ')}`);\n257:   }\n258:   if (!row.provenance || typeof row.provenance !== 'object' || Object.keys(row.provenance).length === 0) {\n259:     problems.push('provenance is required on every row');\n260:   }\n261:   if (!Array.isArray(row.relevant) || row.relevant.length === 0) {\n262:     problems.push('relevant must be a non-empty array');\n263:   }\n264:   if (typeof row.confidence !== 'number' || row.confidence < 0 || row.confidence > 1) {\n265:     problems.push('confidence must be a number in [0, 1]');\n266:   }\n267:   if (!row.query || typeof row.query !== 'object') {\n268:     problems.push('query context is required');\n269:   }\n270:   return problems;\n271: }\n272: \n273: /**\n274:  * Load and validate a judgment seed from a path or a parsed object.\n275:  *\n276:  * @param {string|Object} source - Seed file path or parsed seed object.\n277:  * @returns {Promise<Object>} The validated seed document.\n278:  */\n279: export async function loadJudgmentSeed(source) {\n280:   const seed = typeof source === 'string'\n281:     ? JSON.parse(await readFile(source, 'utf8'))\n282:     : source;\n283:   if (seed.humanLabelingRequired !== true) {\n284:     throw new Error('Judgment seed must flag that human labeling is still required.');\n285:   }\n286:   if (!Array.isArray(seed.judgments) || seed.judgments.length === 0) {\n287:     throw new Error('Judgment seed must contain at least one judgment row.');\n288:   }\n289:   for (const [index, row] of seed.judgments.entries()) {\n290:     const problems = validateJudgmentRow(row);\n291:     if (problems.length > 0) {\n292:       throw new Error(`Judgment row ${index} is invalid: ${problems.join('; ')}`);\n293:     }\n294:   }\n295:   return seed;\n296: }\n\n(End of file - total 296 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Honestly-Labeled Relevance Judgments                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Retrieval-quality ground truth without inventing a single label. Two real\n// signals are the only sources: `authored-similar` rows trace to a style's own\n// designSystem.similar[] authorship (a human wrote \"these are alike\") resolved\n// against the corpus, and `silver-heuristic` rows are retrieval-derived weak\n// positives where a candidate independently agrees across lanes. Every row\n// carries its source and provenance; none is presented as human gold, and the\n// seed header states that human relevance labeling is still required.\n\nimport { mkdir, mkdtemp, readFile, rm } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { compareRawStrings } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/relevance-judgments.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Honestly-Labeled Relevance Judgments                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Retrieval-quality ground truth without inventing a single label. Two real\n// signals are the only sources: `authored-similar` rows trace to a style's own\n// designSystem.similar[] authorship (a human wrote \"these are alike\") resolved\n// against the corpus, and `silver-heuristic` rows are retrieval-derived weak\n// positives where a candidate independently agrees across lanes. Every row\n// carries its source and provenance; none is presented as human gold, and the\n// seed header states that human relevance labeling is still required.\n\nimport { mkdir, mkdtemp, readFile, rm } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { compareRawStrings } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\n\nexport const JUDGMENT_LABEL_SOURCES = Object.freeze(['authored-similar', 'silver-heuristic']);\nexport const JUDGMENT_SEED_VERSION = 1;\n\n// A small deterministic corpus whose styles cite each other in designSystem\n// .similar[], giving authored-similar derivation real resolved relationships.\nconst JUDGMENT_STYLES = Object.freeze([\n  {\n    id: 'aaaaaaaa-1111-4111-8111-aaaaaaaaaaaa',\n    slug: 'alpha-editorial',\n    title: 'Alpha Editorial',\n    theme: 'light',\n    industry: 'Editorial',\n    text: 'Warm cream serif typography with measured spacing and quiet components.',\n    similar: [{ business: 'Beta Product', why: 'Shared editorial restraint.' }],\n  },\n  {\n    id: 'bbbbbbbb-2222-4222-8222-bbbbbbbbbbbb',\n    slug: 'beta-product',\n    title: 'Beta Product',\n    theme: 'dark',\n    industry: 'SaaS',\n    text: 'Dark sans-serif product interface with animation and motion transitions.',\n    similar: [{ business: 'Alpha Editorial', why: 'Shared structural rigor.' }],\n  },\n  {\n    id: 'cccccccc-3333-4333-8333-cccccccccccc',\n    slug: 'gamma-editorial',\n    title: 'Gamma Editorial',\n    theme: 'light',\n    industry: 'Editorial',\n    text: 'Warm cream serif typography with a deliberate serif role.',\n    similar: [{ business: 'Alpha Editorial', why: 'Editorial kinship.' }],\n  },\n  {\n    id: 'dddddddd-4444-4444-8444-dddddddddddd',\n    slug: 'delta-product',\n    title: 'Delta Product',\n    theme: 'dark',\n    industry: 'SaaS',\n    text: 'Dark sans-serif motion product interface with animation.',\n    similar: [{ business: 'Beta Product', why: 'Product-system kinship.' }],\n  },\n]);\n\n// Fixed probes that force independent lane agreement: an exact required-facet\n// match (structured) that also matches lexically (FTS).\nconst SILVER_PROBE_QUERIES = Object.freeze([\n  { text: 'warm cream serif typography', requiredFacets: ['warm-surface'] },\n  { text: 'motion animation product interface', requiredFacets: ['motion'] },\n]);\n\nfunction judgmentCanonical(style) {\n  return {\n    source: `https://styles.example.test/${style.id}`,\n    uuid: style.id,\n    name: style.title,\n    northStar: style.text,\n    capturedAt: '2026-01-01T00:00:00.000Z',\n    meta: { url: `https://${style.slug}.example.test` },\n    screenshot: { url: `https://images.example.test/${style.slug}.jpg` },\n    designSystem: {\n      theme: style.theme,\n      industry: style.industry,\n      description: style.text,\n      colors: [{ name: 'Canvas', hex: '#ffffff' }],\n      typography: [{ family: style.text.includes('serif') ? 'Source Serif' : 'Inter' }],\n      spacing: { sectionGap: '64px' },\n      components: [{ name: 'Button' }],\n      dos: ['Keep one coherent anchor.'],\n      donts: ['Do not average token values.'],\n      layout: 'Centered grid',\n      imagery: 'Editorial photography',\n      similar: style.similar,\n    },\n  };\n}\n\nfunction judgmentDesignMarkdown(style) {\n  return `# ${style.title} — Style Reference\\n> ${style.text}\\n\\n`\n    + `## Tokens — Colors\\n${style.text}\\n\\n`\n    + '## Tokens — Typography\\nSource Serif and Inter\\n\\n'\n    + '## Components\\nButton\\n';\n}\n\nasync function writeJudgmentStyle(root, style) {\n  const { writeFile } = await import('node:fs/promises');\n  const styleRoot = path.join(root, style.slug);\n  await mkdir(styleRoot, { recursive: true });\n  await writeFile(\n    path.join(styleRoot, `${style.slug}-canonical.json`),\n    `${JSON.stringify(judgmentCanonical(style), null, 2)}\\n`,\n  );\n  await writeFile(path.join(styleRoot, 'DESIGN.md'), judgmentDesignMarkdown(style));\n  await writeFile(\n    path.join(styleRoot, 'source.md'),\n    `# ${style.title} — source\\n\\n- **Style UUID:** \\`${style.id}\\`\\n`,\n  );\n}\n\nasync function writeJudgmentCrawlManifest(root, styles) {\n  const { writeFile } = await import('node:fs/promises');\n  const records = styles.map((style) => ({\n    uuid: style.id,\n    url: `https://styles.example.test/${style.id}`,\n    slug: style.slug,\n    status: 'captured',\n    capturedAt: '2026-01-01T00:00:00.000Z',\n    error: null,\n  }));\n  await writeFile(path.join(root, '_manifest.json'), `${JSON.stringify(records, null, 2)}\\n`);\n}\n\n/**\n * Build an in-memory database over the deterministic judgment corpus.\n *\n * @returns {Promise<{database:Object, styles:Object[], cleanup:Function}>} Judgment database handle.\n */\nexport async function buildJudgmentDatabase() {\n  const base = await mkdtemp(path.join(os.tmpdir(), 'style-judgment-fixture-'));\n  const root = path.join(base, 'styles');\n  await mkdir(root);\n  await writeJudgmentCrawlManifest(root, JUDGMENT_STYLES);\n  for (const style of JUDGMENT_STYLES) await writeJudgmentStyle(root, style);\n  const database = openStyleDatabase();\n  await indexStyleCorpus({ corpusRoot: root, database, corpusWalkMode: 'migration' });\n  await rm(base, { recursive: true, force: true });\n  return { database, styles: JUDGMENT_STYLES, cleanup: () => database.close() };\n}\n\n/**\n * Derive positive judgments from resolved authored similarity relationships.\n *\n * @param {Object} database - Indexed style database.\n * @returns {Object[]} Authored-similar judgment rows.\n */\nexport function deriveAuthoredSimilarJudgments(database) {\n  const rows = database.prepare(`\n    SELECT source.style_id AS source_id, target.style_id AS target_id,\n      relationship.raw_target_label AS raw_target_label\n    FROM style_relationships relationship\n    JOIN styles source ON source.style_rowid = relationship.source_style_rowid\n    JOIN styles target ON target.style_rowid = relationship.target_style_rowid\n    WHERE relationship.resolution_state = 'resolved'\n    ORDER BY source.style_id ASC, target.style_id ASC\n  `).all();\n  return rows.map((row) => ({\n    query: { styleId: row.source_id },\n    relevant: [row.target_id],\n    label_source: 'authored-similar',\n    confidence: 1,\n    provenance: {\n      table: 'style_relationships',\n      resolutionState: 'resolved',\n      rawTargetLabel: row.raw_target_label,\n    },\n  }));\n}\n\n/**\n * Derive weak positives where a candidate independently agrees across lanes.\n *\n * @param {Object} database - Indexed style database.\n * @param {Object} [options] - Overrides.\n * @param {Object[]} [options.queries=SILVER_PROBE_QUERIES] - Probe requests.\n * @returns {Object[]} Silver-heuristic judgment rows.\n */\nexport function deriveSilverHeuristicJudgments(database, { queries = SILVER_PROBE_QUERIES } = {}) {\n  const judgments = [];\n  for (const query of queries) {\n    const result = queryPersistentStyles(query, { database });\n    for (const card of result.cards) {\n      const attribution = result.attributions[card.id];\n      const agreeingChannels = Object.keys(attribution?.sourceRanks ?? {}).sort(compareRawStrings);\n      if (agreeingChannels.length < 2) continue;\n      judgments.push({\n        query: { text: query.text, requiredFacets: query.requiredFacets ?? [] },\n        relevant: [card.id],\n        label_source: 'silver-heuristic',\n        confidence: 0.4,\n        provenance: {\n          method: 'cross-lane-agreement',\n          agreeingChannels,\n          requiredFacets: query.requiredFacets ?? [],\n        },\n      });\n    }\n  }\n  return judgments.sort((left, right) => (\n    compareRawStrings(stableProbeKey(left), stableProbeKey(right))\n    || compareRawStrings(left.relevant[0], right.relevant[0])\n  ));\n}\n\nfunction stableProbeKey(judgment) {\n  return `${judgment.query.text}\u0000${(judgment.query.requiredFacets ?? []).join(',')}`;\n}\n\n/**\n * Assemble the full, honestly-labeled judgment seed document.\n *\n * @param {Object} database - Indexed judgment database.\n * @returns {Object} Versioned seed with a human-labeling-required header.\n */\nexport function buildJudgmentSeed(database) {\n  const authored = deriveAuthoredSimilarJudgments(database);\n  const silver = deriveSilverHeuristicJudgments(database);\n  return {\n    seedVersion: JUDGMENT_SEED_VERSION,\n    humanLabelingRequired: true,\n    warning: 'No row here is human-authored gold. authored-similar rows trace to '\n      + 'designSystem.similar[] authorship resolved against the corpus; silver-heuristic '\n      + 'rows are retrieval-derived pseudo-labels from cross-lane agreement. A true judged '\n      + 'qrels set still requires human relevance labeling.',\n    labelSources: [...JUDGMENT_LABEL_SOURCES],\n    method: {\n      'authored-similar': 'Resolved style_relationships parsed from each style\\'s '\n        + 'designSystem.similar[] similarity claims.',\n      'silver-heuristic': 'Candidates appearing in two or more independent retrieval lanes '\n        + 'for a fixed exact-facet probe query; weak positive at confidence 0.4.',\n    },\n    judgments: [...authored, ...silver],\n  };\n}\n\n/**\n * Validate one judgment row's provenance and label honesty.\n *\n * @param {Object} row - Judgment row.\n * @returns {string[]} Problem descriptions; empty when the row is valid.\n */\nexport function validateJudgmentRow(row) {\n  const problems = [];\n  if (!row || typeof row !== 'object') return ['row is not an object'];\n  if (!JUDGMENT_LABEL_SOURCES.includes(row.label_source)) {\n    problems.push(`label_source must be one of ${JUDGMENT_LABEL_SOURCES.join(', ')}`);\n  }\n  if (!row.provenance || typeof row.provenance !== 'object' || Object.keys(row.provenance).length === 0) {\n    problems.push('provenance is required on every row');\n  }\n  if (!Array.isArray(row.relevant) || row.relevant.length === 0) {\n    problems.push('relevant must be a non-empty array');\n  }\n  if (typeof row.confidence !== 'number' || row.confidence < 0 || row.confidence > 1) {\n    problems.push('confidence must be a number in [0, 1]');\n  }\n  if (!row.query || typeof row.query !== 'object') {\n    problems.push('query context is required');\n  }\n  return problems;\n}\n\n/**\n * Load and validate a judgment seed from a path or a parsed object.\n *\n * @param {string|Object} source - Seed file path or parsed seed object.\n * @returns {Promise<Object>} The validated seed document.\n */\nexport async function loadJudgmentSeed(source) {\n  const seed = typeof source === 'string'\n    ? JSON.parse(await readFile(source, 'utf8'))\n    : source;\n  if (seed.humanLabelingRequired !== true) {\n    throw new Error('Judgment seed must flag that human labeling is still required.');\n  }\n  if (!Array.isArray(seed.judgments) || seed.judgments.length === 0) {\n    throw new Error('Judgment seed must contain at least one judgment row.');\n  }\n  for (const [index, row] of seed.judgments.entries()) {\n    const problems = validateJudgmentRow(row);\n    if (problems.length > 0) {\n      throw new Error(`Judgment row ${index} is invalid: ${problems.join('; ')}`);\n    }\n  }\n  return seed;\n}","lineStart":1,"lineEnd":296,"totalLines":296,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/oracle/relevance-judgments.mjs","time":{"start":1784606439643,"end":1784606439647}},"id":"prt_f82d538bb001zjbqBEqa4WTjdg","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d524f5001zunJvYppKOqU06"}}
