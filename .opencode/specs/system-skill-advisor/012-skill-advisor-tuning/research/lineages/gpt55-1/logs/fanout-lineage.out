 \"rrf_guard\": {\n      \"runToRunStable\": true\n    }\n  },\n  \"byteIdentity\": {\n    \"byteIdentical\": true,\n    \"checkedPrompts\": 42,\n    \"overlayChangesOffTop1\": false,\n    \"overlayChangesOffHash\": true,\n    \"overlayOffNote\": \"the conflict overlay does not change the default-off top-1, the lower-rank hash difference is the native weighted-sum graph-causal conflict handling, not a flag leak\"\n  },\n  \"perPrompt\": [\n    {\n      \"id\": \"q01\",\n      \"band\": \"exact\",\n      \"prompt\": \"claude code cli orchestration\",\n      \"gold\": \"cli-claude-code\",\n      \"top\": {\n        \"baseline\": \"cli-claude-code\",\n        \"rrf\": \"cli-claude-code\",","lineStart":1,"lineEnd":260,"totalLines":716,"truncated":true}},"title":".opencode/specs/system-skill-advisor/012-skill-advisor-tuning/003-advisor-rrf-fusion/results/metrics.json","time":{"start":1783437231302,"end":1783437231320}},"metadata":{"openai":{"itemId":"fc_03af2589b4852b05016a4d17af2ea88191ad71ac56371ba781"}},"id":"prt_f3d2484c4001Usq2d55l9EqPF0","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d245c5200140b62AQM3PbjEK"}}
{"type":"tool_use","timestamp":1783437231327,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_IdawfjE18OyIt5WM09j5QP6y","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Semantic Shadow Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { getAdapter } from '../../embedders/registry.js';\n6: import { getActiveEmbedder } from '../../embedders/schema.js';\n7: import { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\n8: import { scoreTokenOverlap, tokenize } from '../text.js';\n9: import type { AdvisorProjection, LaneMatch } from '../types.js';\n10: \n11: const COSINE_THRESHOLD = 0.2;\n12: \n13: let activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n14: \n15: export interface SemanticShadowRuntimeHealth {\n16:   readonly checkedAt: string;\n17:   readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n18:   readonly dimMismatch: boolean;\n19:   readonly disabledReason: string | null;\n20:   readonly lastPromptEmbeddingAt: string | null;\n21: }\n22: \n23: let runtimeHealth: SemanticShadowRuntimeHealth = {\n24:   checkedAt: new Date(0).toISOString(),\n25:   activeEmbedder: null,\n26:   dimMismatch: false,\n27:   disabledReason: null,\n28:   lastPromptEmbeddingAt: null,\n29: };\n30: \n31: function setRuntimeHealth(update: Partial<SemanticShadowRuntimeHealth>): void {\n32:   runtimeHealth = {\n33:     ...runtimeHealth,\n34:     ...update,\n35:     checkedAt: new Date().toISOString(),\n36:   };\n37: }\n38: \n39: export function getSemanticShadowRuntimeHealth(): SemanticShadowRuntimeHealth {\n40:   return runtimeHealth;\n41: }\n42: \n43: function toFloat32Array(vector: Float32Array | readonly number[]): Float32Array {\n44:   return vector instanceof Float32Array ? vector : Float32Array.from(vector);\n45: }\n46: \n47: function cosineSimilarity(left: Float32Array, right: Float32Array): number {\n48:   const length = Math.min(left.length, right.length);\n49:   if (length === 0) {\n50:     return 0;\n51:   }\n52: \n53:   let dot = 0;\n54:   let leftNorm = 0;\n55:   let rightNorm = 0;\n56:   for (let index = 0; index < length; index++) {\n57:     const leftValue = left[index];\n58:     const rightValue = right[index];\n59:     dot += leftValue * rightValue;\n60:     leftNorm += leftValue * leftValue;\n61:     rightNorm += rightValue * rightValue;\n62:   }\n63: \n64:   if (leftNorm === 0 || rightNorm === 0) {\n65:     return 0;\n66:   }\n67: \n68:   return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n69: }\n70: \n71: function fixtureVector(text: string): Float32Array {\n72:   const normalized = text.toLowerCase().split(/\\W+/).filter(Boolean);\n73:   const vector = new Float32Array(32);\n74:   for (const token of normalized) {\n75:     let hash = 0;\n76:     for (let index = 0; index < token.length; index++) {\n77:       hash = ((hash << 5) - hash + token.charCodeAt(index)) | 0;\n78:     }\n79:     vector[Math.abs(hash) % vector.length] += 1;\n80:   }\n81:   return vector;\n82: }\n83: \n84: export function setSemanticShadowPromptEmbedding(prompt: string, vector: Float32Array | readonly number[] | null | undefined): void {\n85:   activePromptEmbedding = vector ? { prompt, vector: toFloat32Array(vector) } : null;\n86: }\n87: \n88: export function clearSemanticShadowPromptEmbedding(): void {\n89:   activePromptEmbedding = null;\n90: }\n91: \n92: export async function withSemanticShadowPromptEmbedding<T>(prompt: string, run: () => T): Promise<T> {\n93:   if (process.env.VITEST === 'true') {\n94:     return run();\n95:   }\n96: \n97:   try {\n98:     // Read-only access: recommend calls must never open the daemon-owned\n99:     // database read-write (dual-writer hazard) or create it when absent.\n100:     const database = getDbReadOnly();\n101:     if (!database) {\n102:       setRuntimeHealth({\n103:         activeEmbedder: null,\n104:         dimMismatch: false,\n105:         disabledReason: 'database_absent',\n106:       });\n107:       throw new Error('skill graph database is absent; shadow scoring disabled');\n108:     }\n109:     const active = getActiveEmbedder(database);\n110:     const adapter = getAdapter(active.name);\n111:     if (!adapter) {\n112:       setRuntimeHealth({\n113:         activeEmbedder: { name: active.name, dim: active.dim, adapterDim: null },\n114:         dimMismatch: false,\n115:         disabledReason: 'adapter_unavailable',\n116:       });\n117:       throw new Error(`active embedder is not registered: ${active.name}`);\n118:     }\n119:     if (adapter.dim !== active.dim) {\n120:       setRuntimeHealth({\n121:         activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n122:         dimMismatch: true,\n123:         disabledReason: 'dim_mismatch',\n124:       });\n125:       throw new Error(`active embedder dimension mismatch: ${active.name} reports ${adapter.dim}, pointer expects ${active.dim}`);\n126:     }\n127: \n128:     const [vector] = await adapter.embed([prompt], { inputType: 'query' });\n129:     setSemanticShadowPromptEmbedding(prompt, vector ?? null);\n130:     setRuntimeHealth({\n131:       activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n132:       dimMismatch: false,\n133:       disabledReason: vector ? null : 'prompt_embedding_empty',\n134:       lastPromptEmbeddingAt: vector ? new Date().toISOString() : runtimeHealth.lastPromptEmbeddingAt,\n135:     });\n136:   } catch (error: unknown) {\n137:     setSemanticShadowPromptEmbedding(prompt, null);\n138:     const message = error instanceof Error ? error.message : String(error);\n139:     if (!runtimeHealth.disabledReason) {\n140:       setRuntimeHealth({ disabledReason: 'prompt_embedding_failed' });\n141:     }\n142:     console.warn(`[semantic-shadow] Prompt embedding failed; cosine lane disabled for this call (${message})`);\n143:   }\n144: \n145:   try {\n146:     return run();\n147:   } finally {\n148:     clearSemanticShadowPromptEmbedding();\n149:   }\n150: }\n151: \n152: export const _semanticShadowTest = {\n153:   cosineSimilarity,\n154:   fixtureVector,\n155: };\n156: \n157: export function scoreSemanticShadowExactSubset(\n158:   prompt: string,\n159:   projection: AdvisorProjection,\n160:   skillIds: readonly string[],\n161: ): LaneMatch[] {\n162:   if (projection.embeddingStaleness?.stale) {\n163:     setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n164:     return [];\n165:   }\n166: \n167:   const orderedSkillIds = [...new Set(skillIds)];\n168:   if (orderedSkillIds.length === 0) return [];\n169: \n170:   const promptVector = activePromptEmbedding?.prompt === prompt\n171:     ? activePromptEmbedding.vector\n172:     : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n173:   if (!promptVector) {\n174:     return [];\n175:   }\n176: \n177:   const requested = new Set(orderedSkillIds);\n178:   const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n179:     ? new Map(projection.skills\n180:         .filter((skill) => requested.has(skill.id))\n181:         .map((skill) => [skill.id, fixtureVector([\n182:           skill.name,\n183:           skill.description,\n184:           ...skill.domains,\n185:           ...skill.intentSignals,\n186:           ...skill.derivedTriggers,\n187:         ].join(' '))]))\n188:     : new Map<string, Float32Array>();\n189: \n190:   let cachedVectors = new Map<string, Float32Array>();\n191:   if (projection.source !== 'fixture' && process.env.VITEST !== 'true') {\n192:     try {\n193:       cachedVectors = new Map(\n194:         loadSkillEmbeddings(orderedSkillIds)\n195:           .map((row) => [row.skillId, row.embedding]),\n196:       );\n197:     } catch (error: unknown) {\n198:       const message = error instanceof Error ? error.message : String(error);\n199:       setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n200:       console.warn(`[semantic-shadow] Exact skill embedding load failed; rerank disabled (${message})`);\n201:       return [];\n202:     }\n203:   }\n204: \n205:   return orderedSkillIds\n206:     .map((skillId): LaneMatch | null => {\n207:       const skillVector = cachedVectors.get(skillId) ?? fixtureVectors.get(skillId);\n208:       if (!skillVector) {\n209:         return null;\n210:       }\n211:       const score = cosineSimilarity(promptVector, skillVector);\n212:       const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n213:       return {\n214:         skillId,\n215:         lane: 'semantic_shadow' as const,\n216:         score: roundedScore,\n217:         evidence: [`cosine-exact:${score.toFixed(4)}`],\n218:         shadowOnly: false,\n219:       };\n220:     })\n221:     .filter((match): match is LaneMatch => match !== null);\n222: }\n223: \n224: export function scoreSemanticShadowLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n225:   if (projection.embeddingStaleness?.stale) {\n226:     setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n227:     return [];\n228:   }\n229: \n230:   if (!activePromptEmbedding && process.env.VITEST === 'true') {\n231:     const tokens = tokenize(prompt);\n232:     return projection.skills\n233:       .map((skill) => ({\n234:         skillId: skill.id,\n235:         lane: 'semantic_shadow' as const,\n236:         score: Math.min(scoreTokenOverlap(tokens, [\n237:           skill.name,\n238:           skill.description,\n239:           ...skill.domains,\n240:           ...skill.intentSignals,\n241:           ...skill.derivedTriggers,\n242:         ]) * 0.8, 1),\n243:         evidence: ['shadow:test-fallback'],\n244:         shadowOnly: false,\n245:       }))\n246:       .filter((match) => match.score > 0.08);\n247:   }\n248: \n249:   const promptVector = activePromptEmbedding?.prompt === prompt\n250:     ? activePromptEmbedding.vector\n251:     : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n252:   if (!promptVector) {\n253:     return [];\n254:   }\n255: \n256:   const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n257:     ? new Map(projection.skills.map((skill) => [skill.id, fixtureVector([\n258:         skill.name,\n259:         skill.description,\n260:         ...skill.domains,\n261:         ...skill.intentSignals,\n262:         ...skill.derivedTriggers,\n263:       ].join(' '))]))\n264:     : new Map<string, Float32Array>();\n265: \n266:   let cachedVectors = new Map<string, Float32Array>();\n267:   try {\n268:     cachedVectors = new Map(\n269:       loadSkillEmbeddings(projection.skills.map((skill) => skill.id))\n270:         .map((row) => [row.skillId, row.embedding]),\n271:     );\n272:   } catch (error: unknown) {\n273:     if (projection.source !== 'fixture') {\n274:       const message = error instanceof Error ? error.message : String(error);\n275:       setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n276:       console.warn(`[semantic-shadow] Skill embedding load failed; cosine lane disabled (${message})`);\n277:       return [];\n278:     }\n279:   }\n280: \n281:   if (projection.source !== 'fixture' && process.env.VITEST !== 'true' && projection.skills.length > 0 && cachedVectors.size === 0) {\n282:     setRuntimeHealth({ disabledReason: 'no_skill_vectors' });\n283:   }\n284: \n285:   return projection.skills\n286:     .map((skill): LaneMatch | null => {\n287:       const skillVector = cachedVectors.get(skill.id) ?? fixtureVectors.get(skill.id);\n288:       if (!skillVector) {\n289:         return null;\n290:       }\n291:       const score = cosineSimilarity(promptVector, skillVector);\n292:       if (score <= COSINE_THRESHOLD) {\n293:         return null;\n294:       }\n295: \n296:       // The cutoff suppresses random near-zero vector noise. The semantic lane is\n297:       // LIVE in the registry (weight 0.05, live=true), so the raw match tags\n298:       // shadowOnly:false to match lane liveness. Fusion independently derives the\n299:       // effective shadowOnly from isLiveScorerLane, so the two values now agree and\n300:       // any direct reader of the raw LaneMatch sees the same answer as attribution.\n301:       const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n302:       return {\n303:         skillId: skill.id,\n304:         lane: 'semantic_shadow' as const,\n305:         score: roundedScore,\n306:         evidence: [`cosine:${score.toFixed(4)}`],\n307:         shadowOnly: false,\n308:       };\n309:     })\n310:     .filter((match): match is LaneMatch => match !== null);\n311: }\n\n(End of file - total 311 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport { getAdapter } from '../../embedders/registry.js';\nimport { getActiveEmbedder } from '../../embedders/schema.js';\nimport { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\nimport { scoreTokenOverlap, tokenize } from '../text.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nconst COSINE_THRESHOLD = 0.2;\n\nlet activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n\nexport interface SemanticShadowRuntimeHealth {\n  readonly checkedAt: string;\n  readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n  readonly dimMismatch: boolean;\n  readonly disabledReason: string | null;\n  readonly lastPromptEmbeddingAt: string | null;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport { getAdapter } from '../../embedders/registry.js';\nimport { getActiveEmbedder } from '../../embedders/schema.js';\nimport { getDbReadOnly, loadSkillEmbeddings } from '../../skill-graph/skill-graph-db.js';\nimport { scoreTokenOverlap, tokenize } from '../text.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nconst COSINE_THRESHOLD = 0.2;\n\nlet activePromptEmbedding: { prompt: string; vector: Float32Array } | null = null;\n\nexport interface SemanticShadowRuntimeHealth {\n  readonly checkedAt: string;\n  readonly activeEmbedder: { readonly name: string; readonly dim: number; readonly adapterDim: number | null } | null;\n  readonly dimMismatch: boolean;\n  readonly disabledReason: string | null;\n  readonly lastPromptEmbeddingAt: string | null;\n}\n\nlet runtimeHealth: SemanticShadowRuntimeHealth = {\n  checkedAt: new Date(0).toISOString(),\n  activeEmbedder: null,\n  dimMismatch: false,\n  disabledReason: null,\n  lastPromptEmbeddingAt: null,\n};\n\nfunction setRuntimeHealth(update: Partial<SemanticShadowRuntimeHealth>): void {\n  runtimeHealth = {\n    ...runtimeHealth,\n    ...update,\n    checkedAt: new Date().toISOString(),\n  };\n}\n\nexport function getSemanticShadowRuntimeHealth(): SemanticShadowRuntimeHealth {\n  return runtimeHealth;\n}\n\nfunction toFloat32Array(vector: Float32Array | readonly number[]): Float32Array {\n  return vector instanceof Float32Array ? vector : Float32Array.from(vector);\n}\n\nfunction cosineSimilarity(left: Float32Array, right: Float32Array): number {\n  const length = Math.min(left.length, right.length);\n  if (length === 0) {\n    return 0;\n  }\n\n  let dot = 0;\n  let leftNorm = 0;\n  let rightNorm = 0;\n  for (let index = 0; index < length; index++) {\n    const leftValue = left[index];\n    const rightValue = right[index];\n    dot += leftValue * rightValue;\n    leftNorm += leftValue * leftValue;\n    rightNorm += rightValue * rightValue;\n  }\n\n  if (leftNorm === 0 || rightNorm === 0) {\n    return 0;\n  }\n\n  return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n}\n\nfunction fixtureVector(text: string): Float32Array {\n  const normalized = text.toLowerCase().split(/\\W+/).filter(Boolean);\n  const vector = new Float32Array(32);\n  for (const token of normalized) {\n    let hash = 0;\n    for (let index = 0; index < token.length; index++) {\n      hash = ((hash << 5) - hash + token.charCodeAt(index)) | 0;\n    }\n    vector[Math.abs(hash) % vector.length] += 1;\n  }\n  return vector;\n}\n\nexport function setSemanticShadowPromptEmbedding(prompt: string, vector: Float32Array | readonly number[] | null | undefined): void {\n  activePromptEmbedding = vector ? { prompt, vector: toFloat32Array(vector) } : null;\n}\n\nexport function clearSemanticShadowPromptEmbedding(): void {\n  activePromptEmbedding = null;\n}\n\nexport async function withSemanticShadowPromptEmbedding<T>(prompt: string, run: () => T): Promise<T> {\n  if (process.env.VITEST === 'true') {\n    return run();\n  }\n\n  try {\n    // Read-only access: recommend calls must never open the daemon-owned\n    // database read-write (dual-writer hazard) or create it when absent.\n    const database = getDbReadOnly();\n    if (!database) {\n      setRuntimeHealth({\n        activeEmbedder: null,\n        dimMismatch: false,\n        disabledReason: 'database_absent',\n      });\n      throw new Error('skill graph database is absent; shadow scoring disabled');\n    }\n    const active = getActiveEmbedder(database);\n    const adapter = getAdapter(active.name);\n    if (!adapter) {\n      setRuntimeHealth({\n        activeEmbedder: { name: active.name, dim: active.dim, adapterDim: null },\n        dimMismatch: false,\n        disabledReason: 'adapter_unavailable',\n      });\n      throw new Error(`active embedder is not registered: ${active.name}`);\n    }\n    if (adapter.dim !== active.dim) {\n      setRuntimeHealth({\n        activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n        dimMismatch: true,\n        disabledReason: 'dim_mismatch',\n      });\n      throw new Error(`active embedder dimension mismatch: ${active.name} reports ${adapter.dim}, pointer expects ${active.dim}`);\n    }\n\n    const [vector] = await adapter.embed([prompt], { inputType: 'query' });\n    setSemanticShadowPromptEmbedding(prompt, vector ?? null);\n    setRuntimeHealth({\n      activeEmbedder: { name: active.name, dim: active.dim, adapterDim: adapter.dim },\n      dimMismatch: false,\n      disabledReason: vector ? null : 'prompt_embedding_empty',\n      lastPromptEmbeddingAt: vector ? new Date().toISOString() : runtimeHealth.lastPromptEmbeddingAt,\n    });\n  } catch (error: unknown) {\n    setSemanticShadowPromptEmbedding(prompt, null);\n    const message = error instanceof Error ? error.message : String(error);\n    if (!runtimeHealth.disabledReason) {\n      setRuntimeHealth({ disabledReason: 'prompt_embedding_failed' });\n    }\n    console.warn(`[semantic-shadow] Prompt embedding failed; cosine lane disabled for this call (${message})`);\n  }\n\n  try {\n    return run();\n  } finally {\n    clearSemanticShadowPromptEmbedding();\n  }\n}\n\nexport const _semanticShadowTest = {\n  cosineSimilarity,\n  fixtureVector,\n};\n\nexport function scoreSemanticShadowExactSubset(\n  prompt: string,\n  projection: AdvisorProjection,\n  skillIds: readonly string[],\n): LaneMatch[] {\n  if (projection.embeddingStaleness?.stale) {\n    setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n    return [];\n  }\n\n  const orderedSkillIds = [...new Set(skillIds)];\n  if (orderedSkillIds.length === 0) return [];\n\n  const promptVector = activePromptEmbedding?.prompt === prompt\n    ? activePromptEmbedding.vector\n    : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n  if (!promptVector) {\n    return [];\n  }\n\n  const requested = new Set(orderedSkillIds);\n  const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n    ? new Map(projection.skills\n        .filter((skill) => requested.has(skill.id))\n        .map((skill) => [skill.id, fixtureVector([\n          skill.name,\n          skill.description,\n          ...skill.domains,\n          ...skill.intentSignals,\n          ...skill.derivedTriggers,\n        ].join(' '))]))\n    : new Map<string, Float32Array>();\n\n  let cachedVectors = new Map<string, Float32Array>();\n  if (projection.source !== 'fixture' && process.env.VITEST !== 'true') {\n    try {\n      cachedVectors = new Map(\n        loadSkillEmbeddings(orderedSkillIds)\n          .map((row) => [row.skillId, row.embedding]),\n      );\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n      console.warn(`[semantic-shadow] Exact skill embedding load failed; rerank disabled (${message})`);\n      return [];\n    }\n  }\n\n  return orderedSkillIds\n    .map((skillId): LaneMatch | null => {\n      const skillVector = cachedVectors.get(skillId) ?? fixtureVectors.get(skillId);\n      if (!skillVector) {\n        return null;\n      }\n      const score = cosineSimilarity(promptVector, skillVector);\n      const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n      return {\n        skillId,\n        lane: 'semantic_shadow' as const,\n        score: roundedScore,\n        evidence: [`cosine-exact:${score.toFixed(4)}`],\n        shadowOnly: false,\n      };\n    })\n    .filter((match): match is LaneMatch => match !== null);\n}\n\nexport function scoreSemanticShadowLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n  if (projection.embeddingStaleness?.stale) {\n    setRuntimeHealth({ disabledReason: 'projection_embedding_stale' });\n    return [];\n  }\n\n  if (!activePromptEmbedding && process.env.VITEST === 'true') {\n    const tokens = tokenize(prompt);\n    return projection.skills\n      .map((skill) => ({\n        skillId: skill.id,\n        lane: 'semantic_shadow' as const,\n        score: Math.min(scoreTokenOverlap(tokens, [\n          skill.name,\n          skill.description,\n          ...skill.domains,\n          ...skill.intentSignals,\n          ...skill.derivedTriggers,\n        ]) * 0.8, 1),\n        evidence: ['shadow:test-fallback'],\n        shadowOnly: false,\n      }))\n      .filter((match) => match.score > 0.08);\n  }\n\n  const promptVector = activePromptEmbedding?.prompt === prompt\n    ? activePromptEmbedding.vector\n    : (projection.source === 'fixture' || process.env.VITEST === 'true' ? fixtureVector(prompt) : null);\n  if (!promptVector) {\n    return [];\n  }\n\n  const fixtureVectors = projection.source === 'fixture' || process.env.VITEST === 'true'\n    ? new Map(projection.skills.map((skill) => [skill.id, fixtureVector([\n        skill.name,\n        skill.description,\n        ...skill.domains,\n        ...skill.intentSignals,\n        ...skill.derivedTriggers,\n      ].join(' '))]))\n    : new Map<string, Float32Array>();\n\n  let cachedVectors = new Map<string, Float32Array>();\n  try {\n    cachedVectors = new Map(\n      loadSkillEmbeddings(projection.skills.map((skill) => skill.id))\n        .map((row) => [row.skillId, row.embedding]),\n    );\n  } catch (error: unknown) {\n    if (projection.source !== 'fixture') {\n      const message = error instanceof Error ? error.message : String(error);\n      setRuntimeHealth({ disabledReason: 'skill_embedding_load_failed' });\n      console.warn(`[semantic-shadow] Skill embedding load failed; cosine lane disabled (${message})`);\n      return [];\n    }\n  }\n\n  if (projection.source !== 'fixture' && process.env.VITEST !== 'true' && projection.skills.length > 0 && cachedVectors.size === 0) {\n    setRuntimeHealth({ disabledReason: 'no_skill_vectors' });\n  }\n\n  return projection.skills\n    .map((skill): LaneMatch | null => {\n      const skillVector = cachedVectors.get(skill.id) ?? fixtureVectors.get(skill.id);\n      if (!skillVector) {\n        return null;\n      }\n      const score = cosineSimilarity(promptVector, skillVector);\n      if (score <= COSINE_THRESHOLD) {\n        return null;\n      }\n\n      // The cutoff suppresses random near-zero vector noise. The semantic lane is\n      // LIVE in the registry (weight 0.05, live=true), so the raw match tags\n      // shadowOnly:false to match lane liveness. Fusion independently derives the\n      // effective shadowOnly from isLiveScorerLane, so the two values now agree and\n      // any direct reader of the raw LaneMatch sees the same answer as attribution.\n      const roundedScore = Math.round(score * 1_000_000) / 1_000_000;\n      return {\n        skillId: skill.id,\n        lane: 'semantic_shadow' as const,\n        score: roundedScore,\n        evidence: [`cosine:${score.toFixed(4)}`],\n        shadowOnly: false,\n      };\n    })\n    .filter((match): match is LaneMatch => match !== null);\n}","lineStart":1,"lineEnd":311,"totalLines":311,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/semantic-shadow.ts","time":{"start":1783437231314,"end":1783437231324}},"metadata":{"openai":{"itemId":"fc_03af2589b4852b05016a4d17af2eb08191996f72cb92ec80e3"}},"id":"prt_f3d2484c9001cWjYPH4m01Fmkn","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d245c5200140b62AQM3PbjEK"}}
{"type":"tool_use","timestamp":1783437231327,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_9LCOJcP7j4rUnKONiAxYQ5lF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/__tests__/semantic-shadow-cosine.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/__tests__/semantic-shadow-cosine.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Semantic Shadow Cosine Lane Tests\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\n6: import { tmpdir } from 'node:os';\n7: import { join } from 'node:path';\n8: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n9: \n10: const { embedDocument, embedQuery, createEmbeddingsProvider } = vi.hoisted(() => {\n11:   const embedDocument = vi.fn(async (text: string) => (\n12:     text.includes('changed')\n13:       ? new Float32Array([0, 1])\n14:       : new Float32Array([1, 0])\n15:   ));\n16:   const embedQuery = vi.fn(async () => new Float32Array([1, 0]));\n17:   return {\n18:     embedDocument,\n19:     embedQuery,\n20:     createEmbeddingsProvider: vi.fn(async () => ({\n21:       embedDocument,\n22:       embedQuery,\n23:       getProfile: () => ({\n24:         provider: 'mock',\n25:         model: 'fixture',\n26:         dim: 2,\n27:         slug: 'mock-fixture-2',\n28:       }),\n29:     })),\n30:   };\n31: });\n32: \n33: vi.mock('@spec-kit/shared/embeddings/factory', async (importOriginal) => {\n34:   const actual = await importOriginal<typeof import('@spec-kit/shared/embeddings/factory')>();\n35:   return {\n36:     ...actual,\n37:     createEmbeddingsProvider,\n38:   };\n39: });\n40: \n41: import {\n42:   closeDb,\n43:   getDb,\n44:   indexSkillMetadata,\n45:   initDb,\n46:   refreshSkillEmbeddings,\n47: } from '../../../../../lib/skill-graph/skill-graph-db.js';\n48: import {\n49:   _semanticShadowTest,\n50:   clearSemanticShadowPromptEmbedding,\n51:   scoreSemanticShadowLane,\n52:   setSemanticShadowPromptEmbedding,\n53: } from '../semantic-shadow.js';\n54: import { scoreAdvisorPrompt } from '../../fusion.js';\n55: import { createFixtureProjection } from '../../projection.js';\n56: import type { AdvisorProjection, SkillProjection } from '../../types.js';\n57: import { writeGraphMetadata } from '../../../../../tests/fixtures/skill-graph-db.js';\n58: \n59: function buffer(values: readonly number[]): Buffer {\n60:   const vector = Float32Array.from(values);\n61:   return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n62: }\n63: \n64: function skill(overrides: Partial<SkillProjection> & Pick<SkillProjection, 'id'>): SkillProjection {\n65:   return {\n66:     kind: 'skill',\n67:     family: 'system',\n68:     category: 'test',\n69:     name: overrides.id,\n70:     description: '',\n71:     keywords: [],\n72:     domains: [],\n73:     intentSignals: [],\n74:     derivedTriggers: [],\n75:     derivedKeywords: [],\n76:     sourcePath: null,\n77:     lifecycleStatus: 'active',\n78:     ...overrides,\n79:     id: overrides.id,\n80:   };\n81: }\n82: \n83: function writeSkill(skillRoot: string, skillId: string, description: string): void {\n84:   writeGraphMetadata(skillRoot, skillId);\n85:   writeFileSync(join(skillRoot, skillId, 'SKILL.md'), [\n86:     '---',\n87:     `name: ${skillId}`,\n88:     `description: \"${description}\"`,\n89:     '---',\n90:     '',\n91:   ].join('\\n'), 'utf8');\n92: }\n93: \n94: describe('semantic shadow cosine lane', () => {\n95:   let root: string;\n96:   let dbDir: string;\n97:   let skillRoot: string;\n98: \n99:   beforeEach(() => {\n100:     root = mkdtempSync(join(tmpdir(), 'semantic-shadow-cosine-'));\n101:     dbDir = join(root, 'db');\n102:     skillRoot = join(root, 'skills');\n103:     initDb(dbDir);\n104:     embedDocument.mockClear();\n105:     embedQuery.mockClear();\n106:     createEmbeddingsProvider.mockClear();\n107:   });\n108: \n109:   afterEach(() => {\n110:     clearSemanticShadowPromptEmbedding();\n111:     closeDb();\n112:     rmSync(root, { recursive: true, force: true });\n113:     vi.restoreAllMocks();\n114:   });\n115: \n116:   it('applies the embedding schema migration idempotently', () => {\n117:     closeDb();\n118:     initDb(dbDir);\n119:     closeDb();\n120:     initDb(dbDir);\n121: \n122:     const columns = getDb().prepare('PRAGMA table_info(skill_nodes)').all() as Array<{ name: string }>;\n123:     expect(columns.map((column) => column.name)).toEqual(expect.arrayContaining([\n124:       'embedding',\n125:       'embedding_model_id',\n126:       'embedding_content_hash',\n127:     ]));\n128:   });\n129: \n130:   it('embeds changed skill descriptions and skips matching hash/model rows', async () => {\n131:     writeSkill(skillRoot, 'alpha', 'stable local embedding workflow');\n132:     indexSkillMetadata(skillRoot);\n133: \n134:     const first = await refreshSkillEmbeddings(skillRoot);\n135:     const second = await refreshSkillEmbeddings(skillRoot);\n136: \n137:     expect(first).toEqual(expect.objectContaining({ embedded: 1, skipped: 0, failed: 0 }));\n138:     expect(second).toEqual(expect.objectContaining({ embedded: 0, skipped: 1, failed: 0 }));\n139:     expect(embedDocument).toHaveBeenCalledTimes(1);\n140: \n141:     writeSkill(skillRoot, 'alpha', 'changed local embedding workflow');\n142:     indexSkillMetadata(skillRoot);\n143:     const third = await refreshSkillEmbeddings(skillRoot);\n144: \n145:     expect(third).toEqual(expect.objectContaining({ embedded: 1, failed: 0 }));\n146:     expect(embedDocument).toHaveBeenCalledTimes(2);\n147:   });\n148: \n149:   it('computes cosine lane matches from cached skill vectors', () => {\n150:     writeSkill(skillRoot, 'alpha', 'north vector');\n151:     writeSkill(skillRoot, 'beta', 'east vector');\n152:     indexSkillMetadata(skillRoot);\n153:     getDb().prepare(`\n154:       UPDATE skill_nodes\n155:       SET embedding = ?, embedding_model_id = ?, embedding_content_hash = ?\n156:       WHERE id = ?\n157:     `).run(buffer([1, 0]), 'mock-fixture-2', 'hash-alpha', 'alpha');\n158:     getDb().prepare(`\n159:       UPDATE skill_nodes\n160:       SET embedding = ?, embedding_model_id = ?, embedding_content_hash = ?\n161:       WHERE id = ?\n162:     `).run(buffer([0, 1]), 'mock-fixture-2', 'hash-beta', 'beta');\n163: \n164:     const projection: AdvisorProjection = {\n165:       skills: [skill({ id: 'alpha' }), skill({ id: 'beta' })],\n166:       edges: [],\n167:       generatedAt: '2026-05-13T00:00:00.000Z',\n168:       source: 'sqlite',\n169:     };\n170:     setSemanticShadowPromptEmbedding('north', new Float32Array([1, 0]));\n171: \n172:     expect(_semanticShadowTest.cosineSimilarity(new Float32Array([1, 0]), new Float32Array([1, 0]))).toBe(1);\n173:     expect(_semanticShadowTest.cosineSimilarity(new Float32Array([1, 0]), new Float32Array([0, 1]))).toBe(0);\n174:     expect(scoreSemanticShadowLane('north', projection)).toEqual([\n175:       {\n176:         skillId: 'alpha',\n177:         lane: 'semantic_shadow',\n178:         score: 1,\n179:         evidence: ['cosine:1.0000'],\n180:         shadowOnly: false,\n181:       },\n182:     ]);\n183:   });\n184: \n185:   it('keeps semantic matches from overturning an explicit top route', () => {\n186:     const projection = createFixtureProjection([\n187:       skill({\n188:         id: 'alpha',\n189:         description: 'plain implementation route',\n190:         intentSignals: ['alpha exact route'],\n191:       }),\n192:       skill({\n193:         id: 'beta',\n194:         description: 'semantic shadow should not promote beta',\n195:       }),\n196:     ]);\n197: \n198:     const withShadow = scoreAdvisorPrompt('alpha exact route', {\n199:       workspaceRoot: process.cwd(),\n200:       projection,\n201:     });\n202:     const withoutShadow = scoreAdvisorPrompt('alpha exact route', {\n203:       workspaceRoot: process.cwd(),\n204:       projection,\n205:       disabledLanes: ['semantic_shadow'],\n206:     });\n207: \n208:     const semantic = withShadow.recommendations[0]?.laneContributions.find((lane) => lane.lane === 'semantic_shadow');\n209: \n210:     expect(withShadow.topSkill).toBe(withoutShadow.topSkill);\n211:     expect(withShadow.topSkill).toBe('alpha');\n212:     expect(semantic?.weightedScore).toBeGreaterThan(0);\n213:     expect(semantic?.shadowOnly).toBe(false);\n214:   });\n215: });\n\n(End of file - total 215 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Cosine Lane Tests\n// ───────────────────────────────────────────────────────────────\n\nimport { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst { embedDocument, embedQuery, createEmbeddingsProvider } = vi.hoisted(() => {\n  const embedDocument = vi.fn(async (text: string) => (\n    text.includes('changed')\n      ? new Float32Array([0, 1])\n      : new Float32Array([1, 0])\n  ));\n  const embedQuery = vi.fn(async () => new Float32Array([1, 0]));\n  return {\n    embedDocument,\n    embedQuery,\n    createEmbeddingsProvider: vi.fn(async () => ({","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/__tests__/semantic-shadow-cosine.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Semantic Shadow Cosine Lane Tests\n// ───────────────────────────────────────────────────────────────\n\nimport { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst { embedDocument, embedQuery, createEmbeddingsProvider } = vi.hoisted(() => {\n  const embedDocument = vi.fn(async (text: string) => (\n    text.includes('changed')\n      ? new Float32Array([0, 1])\n      : new Float32Array([1, 0])\n  ));\n  const embedQuery = vi.fn(async () => new Float32Array([1, 0]));\n  return {\n    embedDocument,\n    embedQuery,\n    createEmbeddingsProvider: vi.fn(async () => ({\n      embedDocument,\n      embedQuery,\n      getProfile: () => ({\n        provider: 'mock',\n        model: 'fixture',\n        dim: 2,\n        slug: 'mock-fixture-2',\n      }),\n    })),\n  };\n});\n\nvi.mock('@spec-kit/shared/embeddings/factory', async (importOriginal) => {\n  const actual = await importOriginal<typeof import('@spec-kit/shared/embeddings/factory')>();\n  return {\n    ...actual,\n    createEmbeddingsProvider,\n  };\n});\n\nimport {\n  closeDb,\n  getDb,\n  indexSkillMetadata,\n  initDb,\n  refreshSkillEmbeddings,\n} from '../../../../../lib/skill-graph/skill-graph-db.js';\nimport {\n  _semanticShadowTest,\n  clearSemanticShadowPromptEmbedding,\n  scoreSemanticShadowLane,\n  setSemanticShadowPromptEmbedding,\n} from '../semantic-shadow.js';\nimport { scoreAdvisorPrompt } from '../../fusion.js';\nimport { createFixtureProjection } from '../../projection.js';\nimport type { AdvisorProjection, SkillProjection } from '../../types.js';\nimport { writeGraphMetadata } from '../../../../../tests/fixtures/skill-graph-db.js';\n\nfunction buffer(values: readonly number[]): Buffer {\n  const vector = Float32Array.from(values);\n  return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n}\n\nfunction skill(overrides: Partial<SkillProjection> & Pick<SkillProjection, 'id'>): SkillProjection {\n  return {\n    kind: 'skill',\n    family: 'system',\n    category: 'test',\n    name: overrides.id,\n    description: '',\n    keywords: [],\n    domains: [],\n    intentSignals: [],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n    ...overrides,\n    id: overrides.id,\n  };\n}\n\nfunction writeSkill(skillRoot: string, skillId: string, description: string): void {\n  writeGraphMetadata(skillRoot, skillId);\n  writeFileSync(join(skillRoot, skillId, 'SKILL.md'), [\n    '---',\n    `name: ${skillId}`,\n    `description: \"${description}\"`,\n    '---',\n    '',\n  ].join('\\n'), 'utf8');\n}\n\ndescribe('semantic shadow cosine lane', () => {\n  let root: string;\n  let dbDir: string;\n  let skillRoot: string;\n\n  beforeEach(() => {\n    root = mkdtempSync(join(tmpdir(), 'semantic-shadow-cosine-'));\n    dbDir = join(root, 'db');\n    skillRoot = join(root, 'skills');\n    initDb(dbDir);\n    embedDocument.mockClear();\n    embedQuery.mockClear();\n    createEmbeddingsProvider.mockClear();\n  });\n\n  afterEach(() => {\n    clearSemanticShadowPromptEmbedding();\n    closeDb();\n    rmSync(root, { recursive: true, force: true });\n    vi.restoreAllMocks();\n  });\n\n  it('applies the embedding schema migration idempotently', () => {\n    closeDb();\n    initDb(dbDir);\n    closeDb();\n    initDb(dbDir);\n\n    const columns = getDb().prepare('PRAGMA table_info(skill_nodes)').all() as Array<{ name: string }>;\n    expect(columns.map((column) => column.name)).toEqual(expect.arrayContaining([\n      'embedding',\n      'embedding_model_id',\n      'embedding_content_hash',\n    ]));\n  });\n\n  it('embeds changed skill descriptions and skips matching hash/model rows', async () => {\n    writeSkill(skillRoot, 'alpha', 'stable local embedding workflow');\n    indexSkillMetadata(skillRoot);\n\n    const first = await refreshSkillEmbeddings(skillRoot);\n    const second = await refreshSkillEmbeddings(skillRoot);\n\n    expect(first).toEqual(expect.objectContaining({ embedded: 1, skipped: 0, failed: 0 }));\n    expect(second).toEqual(expect.objectContaining({ embedded: 0, skipped: 1, failed: 0 }));\n    expect(embedDocument).toHaveBeenCalledTimes(1);\n\n    writeSkill(skillRoot, 'alpha', 'changed local embedding workflow');\n    indexSkillMetadata(skillRoot);\n    const third = await refreshSkillEmbeddings(skillRoot);\n\n    expect(third).toEqual(expect.objectContaining({ embedded: 1, failed: 0 }));\n    expect(embedDocument).toHaveBeenCalledTimes(2);\n  });\n\n  it('computes cosine lane matches from cached skill vectors', () => {\n    writeSkill(skillRoot, 'alpha', 'north vector');\n    writeSkill(skillRoot, 'beta', 'east vector');\n    indexSkillMetadata(skillRoot);\n    getDb().prepare(`\n      UPDATE skill_nodes\n      SET embedding = ?, embedding_model_id = ?, embedding_content_hash = ?\n      WHERE id = ?\n    `).run(buffer([1, 0]), 'mock-fixture-2', 'hash-alpha', 'alpha');\n    getDb().prepare(`\n      UPDATE skill_nodes\n      SET embedding = ?, embedding_model_id = ?, embedding_content_hash = ?\n      WHERE id = ?\n    `).run(buffer([0, 1]), 'mock-fixture-2', 'hash-beta', 'beta');\n\n    const projection: AdvisorProjection = {\n      skills: [skill({ id: 'alpha' }), skill({ id: 'beta' })],\n      edges: [],\n      generatedAt: '2026-05-13T00:00:00.000Z',\n      source: 'sqlite',\n    };\n    setSemanticShadowPromptEmbedding('north', new Float32Array([1, 0]));\n\n    expect(_semanticShadowTest.cosineSimilarity(new Float32Array([1, 0]), new Float32Array([1, 0]))).toBe(1);\n    expect(_semanticShadowTest.cosineSimilarity(new Float32Array([1, 0]), new Float32Array([0, 1]))).toBe(0);\n    expect(scoreSemanticShadowLane('north', projection)).toEqual([\n      {\n        skillId: 'alpha',\n        lane: 'semantic_shadow',\n        score: 1,\n        evidence: ['cosine:1.0000'],\n        shadowOnly: false,\n      },\n    ]);\n  });\n\n  it('keeps semantic matches from overturning an explicit top route', () => {\n    const projection = createFixtureProjection([\n      skill({\n        id: 'alpha',\n        description: 'plain implementation route',\n        intentSignals: ['alpha exact route'],\n      }),\n      skill({\n        id: 'beta',\n        description: 'semantic shadow should not promote beta',\n      }),\n    ]);\n\n    const withShadow = scoreAdvisorPrompt('alpha exact route', {\n      workspaceRoot: process.cwd(),\n      projection,\n    });\n    const withoutShadow = scoreAdvisorPrompt('alpha exact route', {\n      workspaceRoot: process.cwd(),\n      projection,\n      disabledLanes: ['semantic_shadow'],\n    });\n\n    const semantic = withShadow.recommendations[0]?.laneContributions.find((lane) => lane.lane === 'semantic_shadow');\n\n    expect(withShadow.topSkill).toBe(withoutShadow.topSkill);\n    expect(withShadow.topSkill).toBe('alpha');\n    expect(semantic?.weightedScore).toBeGreaterThan(0);\n    expect(semantic?.shadowOnly).toBe(false);\n  });\n});","lineStart":1,"lineEnd":215,"totalLines":215,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/__tests__/semantic-shadow-cosine.vitest.ts","time":{"start":1783437231317,"end":1783437231326}},"metadata":{"openai":{"itemId":"fc_03af2589b4852b05016a4d17af2eb48191a8971954bfa670b6"}},"id":"prt_f3d2484d3001GCF3y7htCCGlnG","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d245c5200140b62AQM3PbjEK"}}
{"type":"step_finish","timestamp":1783437231783,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"id":"prt_f3d2486a4001cQ6PbsGzmCWfi2","reason":"tool-calls","snapshot":"96f83c3666c4c2444feca811692e00609362c41f","messageID":"msg_f3d245c5200140b62AQM3PbjEK","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","type":"step-finish","tokens":{"total":115081,"input":15320,"output":422,"reasoning":11,"cache":{"write":0,"read":99328}},"cost":0}}
{"type":"step_start","timestamp":1783437246697,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"id":"prt_f3d24c0e800105hqbOkcxEbw1I","messageID":"msg_f3d248933001MNSO87SJculP5K","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","snapshot":"96f83c3666c4c2444feca811692e00609362c41f","type":"step-start"}}
{"type":"tool_use","timestamp":1783437255189,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_4XbjDz28WTfVZPMdhzvj4E5Y","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/scoring-constants.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/scoring-constants.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Scorer Calibration Constants\n3: // ───────────────────────────────────────────────────────────────\n4: // Single source of truth for the numeric tuning constants used by\n5: // `lib/scorer/fusion.ts` (`confidenceFor`, `uncertaintyFor`, and\n6: // `primaryIntentBonus`). The scorer-calibration bench\n7: // (`bench/scorer-calibration.bench.ts`) treats these values as the\n8: // \"tuned\" surface — naming them here lets a calibration pass be diffed\n9: // in PRs and rolled back in one place.\n10: //\n11: // IMPORTANT: This refactor MUST be byte-equivalent to the prior inline\n12: // numerics. Tweaking any value here is a behavior change, not a refactor.\n13: \n14: /**\n15:  * Confidence-assembly knobs used by `confidenceFor` in `fusion.ts`.\n16:  */\n17: export interface ConfidenceCalibration {\n18:   /** Floor confidence assigned to read-only explainer prompts that target the\n19:    * advisor itself, OR read-only explainer prompts where the read-only route\n20:    * is not allow-listed. */\n21:   readonly readOnlyExplainerFloor: number;\n22:   /** Base term added to the live-normalized confidence ramp. */\n23:   readonly baseConstant: number;\n24:   /** Multiplier applied to `liveNormalized` before clipping at 1.0. */\n25:   readonly liveNormalizedRampGain: number;\n26:   /** Coefficient on the ramp output that decides how much live-evidence\n27:    * pressure can lift base confidence. */\n28:   readonly liveNormalizedRampCoefficient: number;\n29:   /** When `readOnlyRouteAllowed` is true, base confidence is lifted to at\n30:    * least this value before rounding. */\n31:   readonly readOnlyRouteAllowedFloor: number;\n32:   /** When the derived lane dominates and direct evidence is below the\n33:    * `derivedDominantDirectScoreCeiling`, confidence is pinned to this value. */\n34:   readonly derivedDominantConfidence: number;\n35:   /** Maximum direct score still considered \"low direct evidence\" for the\n36:    * derived-dominant short-circuit. */\n37:   readonly derivedDominantDirectScoreCeiling: number;\n38:   /** Direct-score floor that, when paired with task-intent, lifts confidence\n39:    * to at least the task-intent floor. */\n40:   readonly taskIntentDirectScoreFloor: number;\n41:   /** Live-normalized floor that, when paired with task-intent, lifts\n42:    * confidence to at least the task-intent floor. */\n43:   readonly taskIntentLiveNormalizedFloor: number;\n44:   /** Confidence floor applied when task-intent is met. */\n45:   readonly taskIntentFloor: number;\n46:   /** Direct score above which confidence is lifted to at least the\n47:    * `directScoreFloor` (regardless of task-intent). */\n48:   readonly directScoreLiftThreshold: number;\n49:   /** Confidence floor applied to high-direct-score prompts. */\n50:   readonly directScoreFloor: number;\n51:   /** Direct-score threshold above which a fixed bonus is added to the base\n52:    * confidence (without forcing the floor). */\n53:   readonly directScoreBonusThreshold: number;\n54:   /** Bonus added when the direct score clears `directScoreBonusThreshold`. */\n55:   readonly directScoreBonus: number;\n56:   /** Hard ceiling on the final assembled confidence value. */\n57:   readonly hardCeiling: number;\n58: }\n59: \n60: /**\n61:  * Uncertainty-assembly knobs used by `uncertaintyFor` in `fusion.ts`.\n62:  */\n63: export interface UncertaintyCalibration {\n64:   /** Default uncertainty when no evidence is observed. */\n65:   readonly noEvidenceDefault: number;\n66:   /** Evidence count that drops uncertainty to the low floor. */\n67:   readonly highEvidenceCount: number;\n68:   /** Uncertainty applied at and above the high evidence count. */\n69:   readonly lowFloor: number;\n70:   /** Evidence count for the medium uncertainty band. */\n71:   readonly mediumEvidenceCount: number;\n72:   /** Uncertainty applied at the medium evidence band. */\n73:   readonly mediumFloor: number;\n74:   /** Evidence count for the elevated uncertainty band. */\n75:   readonly someEvidenceCount: number;\n76:   /** Uncertainty applied at the elevated band. */\n77:   readonly elevatedFloor: number;\n78:   /** Direct evidence threshold that triggers an uncertainty discount. */\n79:   readonly directEvidenceDiscountThreshold: number;\n80:   /** Discount applied when direct evidence clears the threshold. */\n81:   readonly directEvidenceDiscount: number;\n82:   /** Confidence threshold below which an uncertainty penalty is applied. */\n83:   readonly lowConfidencePenaltyThreshold: number;\n84:   /** Penalty added when confidence falls below the threshold. */\n85:   readonly lowConfidencePenalty: number;\n86:   /** Uncertainty floor applied to every member of a low-information ambiguity\n87:    * cluster. Above the default strict threshold so strict callers abstain,\n88:    * but below 1 so confidence-only callers still surface the best guess. */\n89:   readonly lowInfoAmbiguityFloor: number;\n90:   /** Hard floor on the final uncertainty value. */\n91:   readonly hardFloor: number;\n92:   /** Hard ceiling on the final uncertainty value. */\n93:   readonly hardCeiling: number;\n94: }\n95: \n96: /**\n97:  * Per-skill routing biases applied by `primaryIntentBonus` in `fusion.ts`.\n98:  *\n99:  * Naming convention: `<intent>SkillBonus` for positive (upweight) terms,\n100:  * `<intent>SkillPenalty` for negative (downweight) terms. The leading\n101:  * `routing.` namespace keeps the calibration surface scannable as a single\n102:  * block per call site.\n103:  */\n104: export interface RoutingCalibration {\n105:   // semantic search intent\n106:   readonly semanticSearchCodeGraphBonus: number;\n107:   // deep-review intent\n108:   readonly deepReviewSkCodeReviewPenalty: number;\n109:   // deep-research intent (text-only)\n110:   readonly deepResearchOtherSkillsPenalty: number;\n111:   // deep-research-cycle phrase intent\n112:   readonly deepResearchCycleOtherSkillsPenalty: number;\n113:   // compare/audit/review + classifier-vocabulary intent\n114:   readonly compareAuditCodeReviewBonus: number;\n115:   // corpus/predictions/continuation/study-config intent\n116:   readonly corpusStudySpecKitBonus: number;\n117:   readonly corpusStudyOtherSkillsPenalty: number;\n118:   // explicit slash-command bonuses\n119:   readonly speckitResumeSpecKitBonus: number;\n120:   readonly speckitResumeCommandPenalty: number;\n121:   // explicit /speckit:plan command-bridge intent: the literal slash command must\n122:   // route to the command-spec-kit bridge even when the prompt also carries a\n123:   // strong skill signal like \"docs\".\n124:   readonly speckitPlanCommandBonus: number;\n125:   readonly speckitPlanSkDocPenalty: number;\n126:   // code-mode / external-tool-chain intent: disambiguate toolchain-shaped\n127:   // prompts toward mcp-code-mode rather than the generic code skill.\n128:   readonly mcpToolchainCodeModeBonus: number;\n129:   readonly mcpToolchainSkCodePenalty: number;\n130:   // \"code audit\" review-target intent: a code audit is a code-review task, so\n131:   // it must beat the deep-review loop skill on the near-tie.\n132:   readonly codeAuditCodeReviewBonus: number;\n133:   readonly codeAuditDeepReviewPenalty: number;\n134:   // review-loop colon syntax (\":review:auto\"): rank the deep-review loop above\n135:   // single-pass code review (the direct anchor already lifts its confidence).\n136:   readonly reviewLoopDeepReviewBonus: number;\n137:   // \"audit ... recommendations\" is a review task, not an advisor-self task.\n138:   readonly auditRecsCodeReviewBonus: number;\n139:   // Demotes the advisor — both its canonical id and its alias — from\n140:   // recommending itself on a read-only \"audit the recommendation quality\"\n141:   // prompt; auditing routing output is a review task, not an advisor\n142:   // invocation. This penalty is the SOLE remaining defense against advisor\n143:   // self-recommendation on those prompts: the explicit opt-in guard that used\n144:   // to back it up was removed as redundant precisely because this implicit\n145:   // penalty already fires. It must be applied through the canonical self-rec id\n146:   // set so the alias is demoted too, not just the exact id. Do not remove or\n147:   // zero it without a documented, tested replacement, or the advisor can rank\n148:   // itself first on audit/explainer prompts again with nothing to stop it.\n149:   readonly auditRecsAdvisorPenalty: number;\n150:   // phase-folder intent\n151:   readonly phaseFolderSpecKitBonus: number;\n152:   // save-context / save-memory intent\n153:   readonly saveContextMemorySaveBonus: number;\n154:   readonly saveContextMemorySpecKitPenalty: number;\n155:   // create-agent intent\n156:   readonly createAgentCreateAgentBonus: number;\n157:   readonly createAgentSkDocPenalty: number;\n158:   // create-testing-playbook intent\n159:   readonly createTestingPlaybookBonus: number;\n160:   readonly createTestingPlaybookSkDocPenalty: number;\n161:   readonly createTestingPlaybookOtherSkillsPenalty: number;\n162: }\n163: \n164: export interface ScoringCalibration {\n165:   readonly confidence: ConfidenceCalibration;\n166:   readonly uncertainty: UncertaintyCalibration;\n167:   readonly routing: RoutingCalibration;\n168: }\n169: \n170: export const SCORING_CALIBRATION: ScoringCalibration = Object.freeze({\n171:   confidence: Object.freeze({\n172:     readOnlyExplainerFloor: 0.25,\n173:     baseConstant: 0.52,\n174:     liveNormalizedRampGain: 1.25,\n175:     liveNormalizedRampCoefficient: 0.43,\n176:     readOnlyRouteAllowedFloor: 0.82,\n177:     derivedDominantConfidence: 0.72,\n178:     derivedDominantDirectScoreCeiling: 0.2,\n179:     taskIntentDirectScoreFloor: 0.18,\n180:     taskIntentLiveNormalizedFloor: 0.2,\n181:     taskIntentFloor: 0.82,\n182:     directScoreLiftThreshold: 0.65,\n183:     directScoreFloor: 0.82,\n184:     directScoreBonusThreshold: 0.85,\n185:     directScoreBonus: 0.04,\n186:     hardCeiling: 0.95,\n187:   }),\n188:   uncertainty: Object.freeze({\n189:     noEvidenceDefault: 0.42,\n190:     highEvidenceCount: 5,\n191:     lowFloor: 0.18,\n192:     mediumEvidenceCount: 3,\n193:     mediumFloor: 0.22,\n194:     someEvidenceCount: 1,\n195:     elevatedFloor: 0.30,\n196:     directEvidenceDiscountThreshold: 0.75,\n197:     directEvidenceDiscount: 0.06,\n198:     lowConfidencePenaltyThreshold: 0.8,\n199:     lowConfidencePenalty: 0.08,\n200:     lowInfoAmbiguityFloor: 0.42,\n201:     hardFloor: 0.08,\n202:     hardCeiling: 0.95,\n203:   }),\n204:   routing: Object.freeze({\n205:     semanticSearchCodeGraphBonus: 0.5,\n206:     deepReviewSkCodeReviewPenalty: -0.25,\n207:     deepResearchOtherSkillsPenalty: -0.18,\n208:     deepResearchCycleOtherSkillsPenalty: -0.18,\n209:     compareAuditCodeReviewBonus: 0.35,\n210:     corpusStudySpecKitBonus: 0.35,\n211:     corpusStudyOtherSkillsPenalty: -0.16,\n212:     speckitResumeSpecKitBonus: 0.16,\n213:     speckitResumeCommandPenalty: -0.12,\n214:     speckitPlanCommandBonus: 0.5,\n215:     speckitPlanSkDocPenalty: -0.18,\n216:     mcpToolchainCodeModeBonus: 0.5,\n217:     mcpToolchainSkCodePenalty: -0.18,\n218:     codeAuditCodeReviewBonus: 0.2,\n219:     codeAuditDeepReviewPenalty: -0.2,\n220:     reviewLoopDeepReviewBonus: 0.5,\n221:     auditRecsCodeReviewBonus: 0.35,\n222:     // Sole defense against advisor self-recommendation on audit prompts; see the\n223:     // interface declaration above. Must not be zeroed without a tested replacement.\n224:     auditRecsAdvisorPenalty: -0.25,\n225:     phaseFolderSpecKitBonus: 0.35,\n226:     saveContextMemorySaveBonus: 0.55,\n227:     saveContextMemorySpecKitPenalty: -0.25,\n228:     createAgentCreateAgentBonus: 0.55,\n229:     createAgentSkDocPenalty: -0.18,\n230:     createTestingPlaybookBonus: 0.65,\n231:     createTestingPlaybookSkDocPenalty: -0.3,\n232:     createTestingPlaybookOtherSkillsPenalty: -0.2,\n233:   }),\n234: });\n235: \n236: export interface RoutingCalibrationOverride {\n237:   memorySaveBonus?: number;\n238:   createAgentBonus?: number;\n239:   testingPlaybookBonus?: number;\n240: }\n\n(Showing lines 1-240 of 260. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Calibration Constants\n// ───────────────────────────────────────────────────────────────\n// Single source of truth for the numeric tuning constants used by\n// `lib/scorer/fusion.ts` (`confidenceFor`, `uncertaintyFor`, and\n// `primaryIntentBonus`). The scorer-calibration bench\n// (`bench/scorer-calibration.bench.ts`) treats these values as the\n// \"tuned\" surface — naming them here lets a calibration pass be diffed\n// in PRs and rolled back in one place.\n//\n// IMPORTANT: This refactor MUST be byte-equivalent to the prior inline\n// numerics. Tweaking any value here is a behavior change, not a refactor.\n\n/**\n * Confidence-assembly knobs used by `confidenceFor` in `fusion.ts`.\n */\nexport interface ConfidenceCalibration {\n  /** Floor confidence assigned to read-only explainer prompts that target the\n   * advisor itself, OR read-only explainer prompts where the read-only route\n   * is not allow-listed. */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/scoring-constants.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Calibration Constants\n// ───────────────────────────────────────────────────────────────\n// Single source of truth for the numeric tuning constants used by\n// `lib/scorer/fusion.ts` (`confidenceFor`, `uncertaintyFor`, and\n// `primaryIntentBonus`). The scorer-calibration bench\n// (`bench/scorer-calibration.bench.ts`) treats these values as the\n// \"tuned\" surface — naming them here lets a calibration pass be diffed\n// in PRs and rolled back in one place.\n//\n// IMPORTANT: This refactor MUST be byte-equivalent to the prior inline\n// numerics. Tweaking any value here is a behavior change, not a refactor.\n\n/**\n * Confidence-assembly knobs used by `confidenceFor` in `fusion.ts`.\n */\nexport interface ConfidenceCalibration {\n  /** Floor confidence assigned to read-only explainer prompts that target the\n   * advisor itself, OR read-only explainer prompts where the read-only route\n   * is not allow-listed. */\n  readonly readOnlyExplainerFloor: number;\n  /** Base term added to the live-normalized confidence ramp. */\n  readonly baseConstant: number;\n  /** Multiplier applied to `liveNormalized` before clipping at 1.0. */\n  readonly liveNormalizedRampGain: number;\n  /** Coefficient on the ramp output that decides how much live-evidence\n   * pressure can lift base confidence. */\n  readonly liveNormalizedRampCoefficient: number;\n  /** When `readOnlyRouteAllowed` is true, base confidence is lifted to at\n   * least this value before rounding. */\n  readonly readOnlyRouteAllowedFloor: number;\n  /** When the derived lane dominates and direct evidence is below the\n   * `derivedDominantDirectScoreCeiling`, confidence is pinned to this value. */\n  readonly derivedDominantConfidence: number;\n  /** Maximum direct score still considered \"low direct evidence\" for the\n   * derived-dominant short-circuit. */\n  readonly derivedDominantDirectScoreCeiling: number;\n  /** Direct-score floor that, when paired with task-intent, lifts confidence\n   * to at least the task-intent floor. */\n  readonly taskIntentDirectScoreFloor: number;\n  /** Live-normalized floor that, when paired with task-intent, lifts\n   * confidence to at least the task-intent floor. */\n  readonly taskIntentLiveNormalizedFloor: number;\n  /** Confidence floor applied when task-intent is met. */\n  readonly taskIntentFloor: number;\n  /** Direct score above which confidence is lifted to at least the\n   * `directScoreFloor` (regardless of task-intent). */\n  readonly directScoreLiftThreshold: number;\n  /** Confidence floor applied to high-direct-score prompts. */\n  readonly directScoreFloor: number;\n  /** Direct-score threshold above which a fixed bonus is added to the base\n   * confidence (without forcing the floor). */\n  readonly directScoreBonusThreshold: number;\n  /** Bonus added when the direct score clears `directScoreBonusThreshold`. */\n  readonly directScoreBonus: number;\n  /** Hard ceiling on the final assembled confidence value. */\n  readonly hardCeiling: number;\n}\n\n/**\n * Uncertainty-assembly knobs used by `uncertaintyFor` in `fusion.ts`.\n */\nexport interface UncertaintyCalibration {\n  /** Default uncertainty when no evidence is observed. */\n  readonly noEvidenceDefault: number;\n  /** Evidence count that drops uncertainty to the low floor. */\n  readonly highEvidenceCount: number;\n  /** Uncertainty applied at and above the high evidence count. */\n  readonly lowFloor: number;\n  /** Evidence count for the medium uncertainty band. */\n  readonly mediumEvidenceCount: number;\n  /** Uncertainty applied at the medium evidence band. */\n  readonly mediumFloor: number;\n  /** Evidence count for the elevated uncertainty band. */\n  readonly someEvidenceCount: number;\n  /** Uncertainty applied at the elevated band. */\n  readonly elevatedFloor: number;\n  /** Direct evidence threshold that triggers an uncertainty discount. */\n  readonly directEvidenceDiscountThreshold: number;\n  /** Discount applied when direct evidence clears the threshold. */\n  readonly directEvidenceDiscount: number;\n  /** Confidence threshold below which an uncertainty penalty is applied. */\n  readonly lowConfidencePenaltyThreshold: number;\n  /** Penalty added when confidence falls below the threshold. */\n  readonly lowConfidencePenalty: number;\n  /** Uncertainty floor applied to every member of a low-information ambiguity\n   * cluster. Above the default strict threshold so strict callers abstain,\n   * but below 1 so confidence-only callers still surface the best guess. */\n  readonly lowInfoAmbiguityFloor: number;\n  /** Hard floor on the final uncertainty value. */\n  readonly hardFloor: number;\n  /** Hard ceiling on the final uncertainty value. */\n  readonly hardCeiling: number;\n}\n\n/**\n * Per-skill routing biases applied by `primaryIntentBonus` in `fusion.ts`.\n *\n * Naming convention: `<intent>SkillBonus` for positive (upweight) terms,\n * `<intent>SkillPenalty` for negative (downweight) terms. The leading\n * `routing.` namespace keeps the calibration surface scannable as a single\n * block per call site.\n */\nexport interface RoutingCalibration {\n  // semantic search intent\n  readonly semanticSearchCodeGraphBonus: number;\n  // deep-review intent\n  readonly deepReviewSkCodeReviewPenalty: number;\n  // deep-research intent (text-only)\n  readonly deepResearchOtherSkillsPenalty: number;\n  // deep-research-cycle phrase intent\n  readonly deepResearchCycleOtherSkillsPenalty: number;\n  // compare/audit/review + classifier-vocabulary intent\n  readonly compareAuditCodeReviewBonus: number;\n  // corpus/predictions/continuation/study-config intent\n  readonly corpusStudySpecKitBonus: number;\n  readonly corpusStudyOtherSkillsPenalty: number;\n  // explicit slash-command bonuses\n  readonly speckitResumeSpecKitBonus: number;\n  readonly speckitResumeCommandPenalty: number;\n  // explicit /speckit:plan command-bridge intent: the literal slash command must\n  // route to the command-spec-kit bridge even when the prompt also carries a\n  // strong skill signal like \"docs\".\n  readonly speckitPlanCommandBonus: number;\n  readonly speckitPlanSkDocPenalty: number;\n  // code-mode / external-tool-chain intent: disambiguate toolchain-shaped\n  // prompts toward mcp-code-mode rather than the generic code skill.\n  readonly mcpToolchainCodeModeBonus: number;\n  readonly mcpToolchainSkCodePenalty: number;\n  // \"code audit\" review-target intent: a code audit is a code-review task, so\n  // it must beat the deep-review loop skill on the near-tie.\n  readonly codeAuditCodeReviewBonus: number;\n  readonly codeAuditDeepReviewPenalty: number;\n  // review-loop colon syntax (\":review:auto\"): rank the deep-review loop above\n  // single-pass code review (the direct anchor already lifts its confidence).\n  readonly reviewLoopDeepReviewBonus: number;\n  // \"audit ... recommendations\" is a review task, not an advisor-self task.\n  readonly auditRecsCodeReviewBonus: number;\n  // Demotes the advisor — both its canonical id and its alias — from\n  // recommending itself on a read-only \"audit the recommendation quality\"\n  // prompt; auditing routing output is a review task, not an advisor\n  // invocation. This penalty is the SOLE remaining defense against advisor\n  // self-recommendation on those prompts: the explicit opt-in guard that used\n  // to back it up was removed as redundant precisely because this implicit\n  // penalty already fires. It must be applied through the canonical self-rec id\n  // set so the alias is demoted too, not just the exact id. Do not remove or\n  // zero it without a documented, tested replacement, or the advisor can rank\n  // itself first on audit/explainer prompts again with nothing to stop it.\n  readonly auditRecsAdvisorPenalty: number;\n  // phase-folder intent\n  readonly phaseFolderSpecKitBonus: number;\n  // save-context / save-memory intent\n  readonly saveContextMemorySaveBonus: number;\n  readonly saveContextMemorySpecKitPenalty: number;\n  // create-agent intent\n  readonly createAgentCreateAgentBonus: number;\n  readonly createAgentSkDocPenalty: number;\n  // create-testing-playbook intent\n  readonly createTestingPlaybookBonus: number;\n  readonly createTestingPlaybookSkDocPenalty: number;\n  readonly createTestingPlaybookOtherSkillsPenalty: number;\n}\n\nexport interface ScoringCalibration {\n  readonly confidence: ConfidenceCalibration;\n  readonly uncertainty: UncertaintyCalibration;\n  readonly routing: RoutingCalibration;\n}\n\nexport const SCORING_CALIBRATION: ScoringCalibration = Object.freeze({\n  confidence: Object.freeze({\n    readOnlyExplainerFloor: 0.25,\n    baseConstant: 0.52,\n    liveNormalizedRampGain: 1.25,\n    liveNormalizedRampCoefficient: 0.43,\n    readOnlyRouteAllowedFloor: 0.82,\n    derivedDominantConfidence: 0.72,\n    derivedDominantDirectScoreCeiling: 0.2,\n    taskIntentDirectScoreFloor: 0.18,\n    taskIntentLiveNormalizedFloor: 0.2,\n    taskIntentFloor: 0.82,\n    directScoreLiftThreshold: 0.65,\n    directScoreFloor: 0.82,\n    directScoreBonusThreshold: 0.85,\n    directScoreBonus: 0.04,\n    hardCeiling: 0.95,\n  }),\n  uncertainty: Object.freeze({\n    noEvidenceDefault: 0.42,\n    highEvidenceCount: 5,\n    lowFloor: 0.18,\n    mediumEvidenceCount: 3,\n    mediumFloor: 0.22,\n    someEvidenceCount: 1,\n    elevatedFloor: 0.30,\n    directEvidenceDiscountThreshold: 0.75,\n    directEvidenceDiscount: 0.06,\n    lowConfidencePenaltyThreshold: 0.8,\n    lowConfidencePenalty: 0.08,\n    lowInfoAmbiguityFloor: 0.42,\n    hardFloor: 0.08,\n    hardCeiling: 0.95,\n  }),\n  routing: Object.freeze({\n    semanticSearchCodeGraphBonus: 0.5,\n    deepReviewSkCodeReviewPenalty: -0.25,\n    deepResearchOtherSkillsPenalty: -0.18,\n    deepResearchCycleOtherSkillsPenalty: -0.18,\n    compareAuditCodeReviewBonus: 0.35,\n    corpusStudySpecKitBonus: 0.35,\n    corpusStudyOtherSkillsPenalty: -0.16,\n    speckitResumeSpecKitBonus: 0.16,\n    speckitResumeCommandPenalty: -0.12,\n    speckitPlanCommandBonus: 0.5,\n    speckitPlanSkDocPenalty: -0.18,\n    mcpToolchainCodeModeBonus: 0.5,\n    mcpToolchainSkCodePenalty: -0.18,\n    codeAuditCodeReviewBonus: 0.2,\n    codeAuditDeepReviewPenalty: -0.2,\n    reviewLoopDeepReviewBonus: 0.5,\n    auditRecsCodeReviewBonus: 0.35,\n    // Sole defense against advisor self-recommendation on audit prompts; see the\n    // interface declaration above. Must not be zeroed without a tested replacement.\n    auditRecsAdvisorPenalty: -0.25,\n    phaseFolderSpecKitBonus: 0.35,\n    saveContextMemorySaveBonus: 0.55,\n    saveContextMemorySpecKitPenalty: -0.25,\n    createAgentCreateAgentBonus: 0.55,\n    createAgentSkDocPenalty: -0.18,\n    createTestingPlaybookBonus: 0.65,\n    createTestingPlaybookSkDocPenalty: -0.3,\n    createTestingPlaybookOtherSkillsPenalty: -0.2,\n  }),\n});\n\nexport interface RoutingCalibrationOverride {\n  memorySaveBonus?: number;\n  createAgentBonus?: number;\n  testingPlaybookBonus?: number;\n}","lineStart":1,"lineEnd":240,"totalLines":260,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/scoring-constants.ts","time":{"start":1783437255183,"end":1783437255187}},"metadata":{"openai":{"itemId":"fc_0c442450af3a11dd016a4d17c6f09481998bb250129dfca696"}},"id":"prt_f3d24e196001raeOJKeSlq7bUY","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d248933001MNSO87SJculP5K"}}
{"type":"tool_use","timestamp":1783437255283,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_0BniSAB3BeJpOZ6rtoZEXe58","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Lexical Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorProjection, LaneMatch } from '../types.js';\n6: import { matchesPhraseBoundary, scoreTokenOverlap, tokenize } from '../text.js';\n7: import { scoreBm25LexicalShadowLane, type AdvisorBm25Match } from './bm25.js';\n8: \n9: const SYNONYMS: Readonly<Record<string, readonly string[]>> = {\n10:   branch: ['git', 'worktree', 'merge'],\n11:   commit: ['git', 'changes'],\n12:   context: ['memory', 'session', 'save'],\n13:   docs: ['documentation', 'readme', 'markdown'],\n14:   document: ['documentation', 'markdown'],\n15:   find: ['search', 'locate'],\n16:   fix: ['debug', 'correct', 'patch'],\n17:   prompt: ['improve', 'enhance', 'optimize'],\n18:   review: ['audit', 'findings', 'regression'],\n19:   save: ['memory', 'context', 'preserve'],\n20:   search: ['find', 'locate', 'semantic'],\n21:   spec: ['plan', 'packet', 'tasks', 'checklist'],\n22:   test: ['vitest', 'verify'],\n23:   write: ['create', 'generate', 'documentation'],\n24: };\n25: \n26: const CATEGORY_HINTS: Readonly<Record<string, readonly string[]>> = {\n27:   'sk-doc': ['readme', 'feature catalog', 'playbook', 'taxonomy', 'documentation', 'docs', 'manual testing'],\n28:   'system-spec-kit': ['spec folder', 'packet', 'plan', 'tasks', 'checklist', 'memory save', 'handover', 'implementation summary', 'corpus'],\n29:   'system-code-graph': ['code graph', 'structural search', 'grep not enough', 'find code', 'where logic'],\n30:   'deep-loop-workflows': ['deep research', 'research loop', 'overnight research', 'delta record', 'state log', 'lineage', 'deep review', 'review loop', 'release readiness', 'canonical jsonl', 'convergence tracked', 'iterative review', 'iterative review loop', 'spec folder audit', 'iterative audit', 'multi-pass review', 'review iteration', 'convergence detection', 'review packet', 'spec folder review', 'deep ai council', 'ai council', 'planning council', 'council deliberation', 'multi-seat planning', 'ai-council artifacts', 'persist council artifacts', 'multi-ai-council'],\n31:   'mcp-chrome-devtools': ['chrome devtools', 'har', 'console errors', 'staging'],\n32:   'sk-prompt': ['better prompt', 'cleaner prompt', 'prompt package', 'system prompt', 'prompt variant'],\n33:   'sk-git': ['git worktree', 'experiment branch', 'clean branch'],\n34:   'sk-code': ['css', 'html', 'javascript', 'browser', 'frontend', 'layout', 'viewport', 'responsive', 'mobile', 'cdn', 'opencode', 'classifier', 'helper', 'fixture', 'vitest', 'commonjs', 'typescript', 'python', 'script', 'mcp json', 'gate3 baseline'],\n35: };\n36: \n37: const BM25_SHADOW_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'shadow', 'experimental']);\n38: \n39: export function isBm25LexicalShadowEnabled(): boolean {\n40:   const value = process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW?.trim().toLowerCase();\n41:   return value ? BM25_SHADOW_ENABLED_VALUES.has(value) : false;\n42: }\n43: \n44: function expandedTokens(prompt: string): string[] {\n45:   const tokens = tokenize(prompt);\n46:   const expanded = new Set(tokens);\n47:   for (const token of tokens) {\n48:     for (const synonym of SYNONYMS[token] ?? []) {\n49:       expanded.add(synonym);\n50:     }\n51:   }\n52:   return [...expanded];\n53: }\n54: \n55: export function scoreLexicalLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n56:   const lower = prompt.toLowerCase();\n57:   const tokens = expandedTokens(prompt);\n58:   // Normalize against the un-expanded prompt length so injected synonyms only add\n59:   // recall and never enlarge the denominator against a literally-matching skill.\n60:   const originalTokenCount = tokenize(prompt).length;\n61:   const matches: LaneMatch[] = [];\n62: \n63:   for (const skill of projection.skills) {\n64:     const evidence: string[] = [];\n65:     let score = scoreTokenOverlap(tokens, [\n66:       skill.id.replace(/-/g, ' '),\n67:       skill.name,\n68:       skill.description,\n69:       ...skill.domains,\n70:       ...skill.intentSignals,\n71:       ...skill.keywords,\n72:     ], originalTokenCount);\n73: \n74:     for (const hint of CATEGORY_HINTS[skill.id] ?? []) {\n75:       if (matchesPhraseBoundary(lower, hint)) {\n76:         score += 0.38;\n77:         evidence.push(`hint:${hint}`);\n78:       }\n79:     }\n80: \n81:     const tokenHits = tokens.filter((token) => {\n82:       const haystack = `${skill.id} ${skill.name} ${skill.description} ${skill.domains.join(' ')}`.toLowerCase();\n83:       return haystack.includes(token);\n84:     }).slice(0, 5);\n85:     evidence.push(...tokenHits.map((token) => `token:${token}`));\n86: \n87:     if (score <= 0.05) continue;\n88:     matches.push({\n89:       skillId: skill.id,\n90:       lane: 'lexical',\n91:       score: Math.min(score, 1),\n92:       evidence: evidence.slice(0, 6),\n93:     });\n94:   }\n95: \n96:   return matches;\n97: }\n98: \n99: export function scoreLexicalShadowLanes(\n100:   prompt: string,\n101:   projection: AdvisorProjection,\n102: ): { lexical: LaneMatch[]; bm25: AdvisorBm25Match[] } {\n103:   const lexical = scoreLexicalLane(prompt, projection);\n104:   return {\n105:     lexical,\n106:     bm25: isBm25LexicalShadowEnabled() ? scoreBm25LexicalShadowLane(prompt, projection) : [],\n107:   };\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Lexical Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, scoreTokenOverlap, tokenize } from '../text.js';\nimport { scoreBm25LexicalShadowLane, type AdvisorBm25Match } from './bm25.js';\n\nconst SYNONYMS: Readonly<Record<string, readonly string[]>> = {\n  branch: ['git', 'worktree', 'merge'],\n  commit: ['git', 'changes'],\n  context: ['memory', 'session', 'save'],\n  docs: ['documentation', 'readme', 'markdown'],\n  document: ['documentation', 'markdown'],\n  find: ['search', 'locate'],\n  fix: ['debug', 'correct', 'patch'],\n  prompt: ['improve', 'enhance', 'optimize'],\n  review: ['audit', 'findings', 'regression'],\n  save: ['memory', 'context', 'preserve'],\n  search: ['find', 'locate', 'semantic'],","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Lexical Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, scoreTokenOverlap, tokenize } from '../text.js';\nimport { scoreBm25LexicalShadowLane, type AdvisorBm25Match } from './bm25.js';\n\nconst SYNONYMS: Readonly<Record<string, readonly string[]>> = {\n  branch: ['git', 'worktree', 'merge'],\n  commit: ['git', 'changes'],\n  context: ['memory', 'session', 'save'],\n  docs: ['documentation', 'readme', 'markdown'],\n  document: ['documentation', 'markdown'],\n  find: ['search', 'locate'],\n  fix: ['debug', 'correct', 'patch'],\n  prompt: ['improve', 'enhance', 'optimize'],\n  review: ['audit', 'findings', 'regression'],\n  save: ['memory', 'context', 'preserve'],\n  search: ['find', 'locate', 'semantic'],\n  spec: ['plan', 'packet', 'tasks', 'checklist'],\n  test: ['vitest', 'verify'],\n  write: ['create', 'generate', 'documentation'],\n};\n\nconst CATEGORY_HINTS: Readonly<Record<string, readonly string[]>> = {\n  'sk-doc': ['readme', 'feature catalog', 'playbook', 'taxonomy', 'documentation', 'docs', 'manual testing'],\n  'system-spec-kit': ['spec folder', 'packet', 'plan', 'tasks', 'checklist', 'memory save', 'handover', 'implementation summary', 'corpus'],\n  'system-code-graph': ['code graph', 'structural search', 'grep not enough', 'find code', 'where logic'],\n  'deep-loop-workflows': ['deep research', 'research loop', 'overnight research', 'delta record', 'state log', 'lineage', 'deep review', 'review loop', 'release readiness', 'canonical jsonl', 'convergence tracked', 'iterative review', 'iterative review loop', 'spec folder audit', 'iterative audit', 'multi-pass review', 'review iteration', 'convergence detection', 'review packet', 'spec folder review', 'deep ai council', 'ai council', 'planning council', 'council deliberation', 'multi-seat planning', 'ai-council artifacts', 'persist council artifacts', 'multi-ai-council'],\n  'mcp-chrome-devtools': ['chrome devtools', 'har', 'console errors', 'staging'],\n  'sk-prompt': ['better prompt', 'cleaner prompt', 'prompt package', 'system prompt', 'prompt variant'],\n  'sk-git': ['git worktree', 'experiment branch', 'clean branch'],\n  'sk-code': ['css', 'html', 'javascript', 'browser', 'frontend', 'layout', 'viewport', 'responsive', 'mobile', 'cdn', 'opencode', 'classifier', 'helper', 'fixture', 'vitest', 'commonjs', 'typescript', 'python', 'script', 'mcp json', 'gate3 baseline'],\n};\n\nconst BM25_SHADOW_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'shadow', 'experimental']);\n\nexport function isBm25LexicalShadowEnabled(): boolean {\n  const value = process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW?.trim().toLowerCase();\n  return value ? BM25_SHADOW_ENABLED_VALUES.has(value) : false;\n}\n\nfunction expandedTokens(prompt: string): string[] {\n  const tokens = tokenize(prompt);\n  const expanded = new Set(tokens);\n  for (const token of tokens) {\n    for (const synonym of SYNONYMS[token] ?? []) {\n      expanded.add(synonym);\n    }\n  }\n  return [...expanded];\n}\n\nexport function scoreLexicalLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = expandedTokens(prompt);\n  // Normalize against the un-expanded prompt length so injected synonyms only add\n  // recall and never enlarge the denominator against a literally-matching skill.\n  const originalTokenCount = tokenize(prompt).length;\n  const matches: LaneMatch[] = [];\n\n  for (const skill of projection.skills) {\n    const evidence: string[] = [];\n    let score = scoreTokenOverlap(tokens, [\n      skill.id.replace(/-/g, ' '),\n      skill.name,\n      skill.description,\n      ...skill.domains,\n      ...skill.intentSignals,\n      ...skill.keywords,\n    ], originalTokenCount);\n\n    for (const hint of CATEGORY_HINTS[skill.id] ?? []) {\n      if (matchesPhraseBoundary(lower, hint)) {\n        score += 0.38;\n        evidence.push(`hint:${hint}`);\n      }\n    }\n\n    const tokenHits = tokens.filter((token) => {\n      const haystack = `${skill.id} ${skill.name} ${skill.description} ${skill.domains.join(' ')}`.toLowerCase();\n      return haystack.includes(token);\n    }).slice(0, 5);\n    evidence.push(...tokenHits.map((token) => `token:${token}`));\n\n    if (score <= 0.05) continue;\n    matches.push({\n      skillId: skill.id,\n      lane: 'lexical',\n      score: Math.min(score, 1),\n      evidence: evidence.slice(0, 6),\n    });\n  }\n\n  return matches;\n}\n\nexport function scoreLexicalShadowLanes(\n  prompt: string,\n  projection: AdvisorProjection,\n): { lexical: LaneMatch[]; bm25: AdvisorBm25Match[] } {\n  const lexical = scoreLexicalLane(prompt, projection);\n  return {\n    lexical,\n    bm25: isBm25LexicalShadowEnabled() ? scoreBm25LexicalShadowLane(prompt, projection) : [],\n  };\n}","lineStart":1,"lineEnd":108,"totalLines":108,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts","time":{"start":1783437255279,"end":1783437255282}},"metadata":{"openai":{"itemId":"fc_0c442450af3a11dd016a4d17c6f0ac8199ad500247edb3712e"}},"id":"prt_f3d24e241001kfhQElf3Co69n3","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d248933001MNSO87SJculP5K"}}
{"type":"tool_use","timestamp":1783437255332,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_Ujnlrs0cLGIKtdFlPBOPrc9Q","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Graph Causal Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { NormalizedAffordance } from '../../affordance-normalizer.js';\n6: import type { AdvisorProjection, LaneMatch } from '../types.js';\n7: \n8: export interface GraphCausalOptions {\n9:   readonly maxDepth?: number;\n10:   readonly maxBreadth?: number;\n11: }\n12: \n13: export interface GraphCausalLaneSplit {\n14:   readonly combinedMatches: LaneMatch[];\n15:   readonly positiveMatches: LaneMatch[];\n16:   readonly conflictMatches: LaneMatch[];\n17: }\n18: \n19: interface GraphCausalScoreEntry {\n20:   readonly combinedScore: number;\n21:   readonly positiveScore: number;\n22:   readonly conflictScore: number;\n23:   readonly evidence: readonly string[];\n24:   readonly positiveEvidence: readonly string[];\n25:   readonly conflictEvidence: readonly string[];\n26: }\n27: \n28: const EDGE_MULTIPLIER: Readonly<Record<string, number>> = {\n29:   enhances: 0.55,\n30:   siblings: 0.35,\n31:   depends_on: 0.35,\n32:   prerequisite_for: 0.30,\n33:   conflicts_with: -0.35,\n34: };\n35: \n36: function buildGraphCausalScores(\n37:   seedMatches: readonly LaneMatch[],\n38:   projection: AdvisorProjection,\n39:   options: GraphCausalOptions = {},\n40:   affordances: readonly NormalizedAffordance[] = [],\n41: ): Map<string, GraphCausalScoreEntry> {\n42:   const maxDepth = options.maxDepth ?? 2;\n43:   const maxBreadth = options.maxBreadth ?? 4;\n44:   const adjacency = new Map<string, typeof projection.edges>();\n45:   for (const edge of projection.edges) {\n46:     const current = adjacency.get(edge.sourceId) ?? [];\n47:     adjacency.set(edge.sourceId, [...current, edge]);\n48:   }\n49:   for (const affordance of affordances) {\n50:     const current = adjacency.get(affordance.skillId) ?? [];\n51:     adjacency.set(affordance.skillId, [\n52:       ...current,\n53:       ...affordance.edges.map((edge) => ({\n54:         sourceId: affordance.skillId,\n55:         targetId: edge.targetSkillId,\n56:         edgeType: edge.edgeType,\n57:         weight: edge.weight,\n58:         context: affordance.evidenceLabel,\n59:       })),\n60:     ]);\n61:   }\n62: \n63:   const seedScores = new Map<string, number>();\n64:   for (const match of seedMatches) {\n65:     if (match.lane === 'semantic_shadow') continue;\n66:     seedScores.set(match.skillId, Math.max(seedScores.get(match.skillId) ?? 0, match.score));\n67:   }\n68: \n69:   const scores = new Map<string, {\n70:     combinedScore: number;\n71:     positiveScore: number;\n72:     conflictScore: number;\n73:     evidence: string[];\n74:     positiveEvidence: string[];\n75:     conflictEvidence: string[];\n76:   }>();\n77:   for (const [seedId, seedScore] of seedScores) {\n78:     // Best positive strength discovered per target; also the visited/expansion ledger.\n79:     // Seeded with the origin so a back-edge to the seed can never re-expand it.\n80:     const bestPositiveStrengthByTarget = new Map<string, number>([[seedId, seedScore]]);\n81:     const queue: Array<{ id: string; depth: number }> = [{ id: seedId, depth: 0 }];\n82:     while (queue.length > 0) {\n83:       // queue.length was checked immediately before shifting the next item.\n84:       const current = queue.shift()!;\n85:       if (current.depth >= maxDepth) continue;\n86:       const currentStrength = bestPositiveStrengthByTarget.get(current.id) ?? 0;\n87:       if (currentStrength <= 0) continue;\n88:       const outgoing = [...(adjacency.get(current.id) ?? [])]\n89:         .sort((left, right) => right.weight - left.weight)\n90:         .slice(0, maxBreadth);\n91:       for (const edge of outgoing) {\n92:         const multiplier = EDGE_MULTIPLIER[edge.edgeType];\n93:         if (multiplier === undefined) continue;\n94:         const propagated = currentStrength * edge.weight * Math.abs(multiplier) * (1 / (current.depth + 1));\n95:         if (propagated < 0.05) continue;\n96:         const signed = multiplier < 0 ? -propagated : propagated;\n97:         // Score every qualifying edge before deciding expansion, so a weaker or earlier\n98:         // edge can no longer suppress a stronger later edge to the same target.\n99:         const entry = scores.get(edge.targetId) ?? {\n100:           combinedScore: 0,\n101:           positiveScore: 0,\n102:           conflictScore: 0,\n103:           evidence: [],\n104:           positiveEvidence: [],\n105:           conflictEvidence: [],\n106:         };\n107:         const evidence = `edge:${current.id}->${edge.targetId}:${edge.edgeType}`;\n108:         entry.combinedScore += signed;\n109:         entry.evidence.push(evidence);\n110:         if (signed > 0) {\n111:           entry.positiveScore += signed;\n112:           entry.positiveEvidence.push(evidence);\n113:         } else {\n114:           entry.conflictScore += signed;\n115:           entry.conflictEvidence.push(evidence);\n116:         }\n117:         scores.set(edge.targetId, entry);\n118:         // Expand a target once, on its first positive reach, tracking its best positive\n119:         // strength for onward propagation. Negative edges score but never expand, so no\n120:         // positive graph-causal support propagates through a negative edge.\n121:         if (signed > 0) {\n122:           const prevBest = bestPositiveStrengthByTarget.get(edge.targetId);\n123:           if (prevBest === undefined) {\n124:             bestPositiveStrengthByTarget.set(edge.targetId, signed);\n125:             queue.push({ id: edge.targetId, depth: current.depth + 1 });\n126:           } else if (signed > prevBest) {\n127:             bestPositiveStrengthByTarget.set(edge.targetId, signed);\n128:           }\n129:         }\n130:       }\n131:     }\n132:   }\n133: \n134:   return scores;\n135: }\n136: \n137: function toLaneMatches(\n138:   scores: Map<string, GraphCausalScoreEntry>,\n139:   scoreKey: 'combinedScore' | 'positiveScore' | 'conflictScore',\n140:   evidenceKey: 'evidence' | 'positiveEvidence' | 'conflictEvidence',\n141: ): LaneMatch[] {\n142:   return [...scores.entries()]\n143:     .filter(([, value]) => value[scoreKey] !== 0)\n144:     .map(([skillId, value]) => ({\n145:       skillId,\n146:       lane: 'graph_causal' as const,\n147:       score: Math.max(-1, Math.min(value[scoreKey], 1)),\n148:       evidence: value[evidenceKey].slice(0, 6),\n149:     }));\n150: }\n151: \n152: export function scoreGraphCausalLaneSplit(\n153:   seedMatches: readonly LaneMatch[],\n154:   projection: AdvisorProjection,\n155:   options: GraphCausalOptions = {},\n156:   affordances: readonly NormalizedAffordance[] = [],\n157: ): GraphCausalLaneSplit {\n158:   const scores = buildGraphCausalScores(seedMatches, projection, options, affordances);\n159:   return {\n160:     combinedMatches: toLaneMatches(scores, 'combinedScore', 'evidence'),\n161:     positiveMatches: toLaneMatches(scores, 'positiveScore', 'positiveEvidence'),\n162:     conflictMatches: toLaneMatches(scores, 'conflictScore', 'conflictEvidence'),\n163:   };\n164: }\n165: \n166: export function scoreGraphCausalLane(\n167:   seedMatches: readonly LaneMatch[],\n168:   projection: AdvisorProjection,\n169:   options: GraphCausalOptions = {},\n170:   affordances: readonly NormalizedAffordance[] = [],\n171: ): LaneMatch[] {\n172:   return scoreGraphCausalLaneSplit(seedMatches, projection, options, affordances).combinedMatches;\n173: }\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Graph Causal Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nexport interface GraphCausalOptions {\n  readonly maxDepth?: number;\n  readonly maxBreadth?: number;\n}\n\nexport interface GraphCausalLaneSplit {\n  readonly combinedMatches: LaneMatch[];\n  readonly positiveMatches: LaneMatch[];\n  readonly conflictMatches: LaneMatch[];\n}\n\ninterface GraphCausalScoreEntry {\n  readonly combinedScore: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Graph Causal Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { NormalizedAffordance } from '../../affordance-normalizer.js';\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\n\nexport interface GraphCausalOptions {\n  readonly maxDepth?: number;\n  readonly maxBreadth?: number;\n}\n\nexport interface GraphCausalLaneSplit {\n  readonly combinedMatches: LaneMatch[];\n  readonly positiveMatches: LaneMatch[];\n  readonly conflictMatches: LaneMatch[];\n}\n\ninterface GraphCausalScoreEntry {\n  readonly combinedScore: number;\n  readonly positiveScore: number;\n  readonly conflictScore: number;\n  readonly evidence: readonly string[];\n  readonly positiveEvidence: readonly string[];\n  readonly conflictEvidence: readonly string[];\n}\n\nconst EDGE_MULTIPLIER: Readonly<Record<string, number>> = {\n  enhances: 0.55,\n  siblings: 0.35,\n  depends_on: 0.35,\n  prerequisite_for: 0.30,\n  conflicts_with: -0.35,\n};\n\nfunction buildGraphCausalScores(\n  seedMatches: readonly LaneMatch[],\n  projection: AdvisorProjection,\n  options: GraphCausalOptions = {},\n  affordances: readonly NormalizedAffordance[] = [],\n): Map<string, GraphCausalScoreEntry> {\n  const maxDepth = options.maxDepth ?? 2;\n  const maxBreadth = options.maxBreadth ?? 4;\n  const adjacency = new Map<string, typeof projection.edges>();\n  for (const edge of projection.edges) {\n    const current = adjacency.get(edge.sourceId) ?? [];\n    adjacency.set(edge.sourceId, [...current, edge]);\n  }\n  for (const affordance of affordances) {\n    const current = adjacency.get(affordance.skillId) ?? [];\n    adjacency.set(affordance.skillId, [\n      ...current,\n      ...affordance.edges.map((edge) => ({\n        sourceId: affordance.skillId,\n        targetId: edge.targetSkillId,\n        edgeType: edge.edgeType,\n        weight: edge.weight,\n        context: affordance.evidenceLabel,\n      })),\n    ]);\n  }\n\n  const seedScores = new Map<string, number>();\n  for (const match of seedMatches) {\n    if (match.lane === 'semantic_shadow') continue;\n    seedScores.set(match.skillId, Math.max(seedScores.get(match.skillId) ?? 0, match.score));\n  }\n\n  const scores = new Map<string, {\n    combinedScore: number;\n    positiveScore: number;\n    conflictScore: number;\n    evidence: string[];\n    positiveEvidence: string[];\n    conflictEvidence: string[];\n  }>();\n  for (const [seedId, seedScore] of seedScores) {\n    // Best positive strength discovered per target; also the visited/expansion ledger.\n    // Seeded with the origin so a back-edge to the seed can never re-expand it.\n    const bestPositiveStrengthByTarget = new Map<string, number>([[seedId, seedScore]]);\n    const queue: Array<{ id: string; depth: number }> = [{ id: seedId, depth: 0 }];\n    while (queue.length > 0) {\n      // queue.length was checked immediately before shifting the next item.\n      const current = queue.shift()!;\n      if (current.depth >= maxDepth) continue;\n      const currentStrength = bestPositiveStrengthByTarget.get(current.id) ?? 0;\n      if (currentStrength <= 0) continue;\n      const outgoing = [...(adjacency.get(current.id) ?? [])]\n        .sort((left, right) => right.weight - left.weight)\n        .slice(0, maxBreadth);\n      for (const edge of outgoing) {\n        const multiplier = EDGE_MULTIPLIER[edge.edgeType];\n        if (multiplier === undefined) continue;\n        const propagated = currentStrength * edge.weight * Math.abs(multiplier) * (1 / (current.depth + 1));\n        if (propagated < 0.05) continue;\n        const signed = multiplier < 0 ? -propagated : propagated;\n        // Score every qualifying edge before deciding expansion, so a weaker or earlier\n        // edge can no longer suppress a stronger later edge to the same target.\n        const entry = scores.get(edge.targetId) ?? {\n          combinedScore: 0,\n          positiveScore: 0,\n          conflictScore: 0,\n          evidence: [],\n          positiveEvidence: [],\n          conflictEvidence: [],\n        };\n        const evidence = `edge:${current.id}->${edge.targetId}:${edge.edgeType}`;\n        entry.combinedScore += signed;\n        entry.evidence.push(evidence);\n        if (signed > 0) {\n          entry.positiveScore += signed;\n          entry.positiveEvidence.push(evidence);\n        } else {\n          entry.conflictScore += signed;\n          entry.conflictEvidence.push(evidence);\n        }\n        scores.set(edge.targetId, entry);\n        // Expand a target once, on its first positive reach, tracking its best positive\n        // strength for onward propagation. Negative edges score but never expand, so no\n        // positive graph-causal support propagates through a negative edge.\n        if (signed > 0) {\n          const prevBest = bestPositiveStrengthByTarget.get(edge.targetId);\n          if (prevBest === undefined) {\n            bestPositiveStrengthByTarget.set(edge.targetId, signed);\n            queue.push({ id: edge.targetId, depth: current.depth + 1 });\n          } else if (signed > prevBest) {\n            bestPositiveStrengthByTarget.set(edge.targetId, signed);\n          }\n        }\n      }\n    }\n  }\n\n  return scores;\n}\n\nfunction toLaneMatches(\n  scores: Map<string, GraphCausalScoreEntry>,\n  scoreKey: 'combinedScore' | 'positiveScore' | 'conflictScore',\n  evidenceKey: 'evidence' | 'positiveEvidence' | 'conflictEvidence',\n): LaneMatch[] {\n  return [...scores.entries()]\n    .filter(([, value]) => value[scoreKey] !== 0)\n    .map(([skillId, value]) => ({\n      skillId,\n      lane: 'graph_causal' as const,\n      score: Math.max(-1, Math.min(value[scoreKey], 1)),\n      evidence: value[evidenceKey].slice(0, 6),\n    }));\n}\n\nexport function scoreGraphCausalLaneSplit(\n  seedMatches: readonly LaneMatch[],\n  projection: AdvisorProjection,\n  options: GraphCausalOptions = {},\n  affordances: readonly NormalizedAffordance[] = [],\n): GraphCausalLaneSplit {\n  const scores = buildGraphCausalScores(seedMatches, projection, options, affordances);\n  return {\n    combinedMatches: toLaneMatches(scores, 'combinedScore', 'evidence'),\n    positiveMatches: toLaneMatches(scores, 'positiveScore', 'positiveEvidence'),\n    conflictMatches: toLaneMatches(scores, 'conflictScore', 'conflictEvidence'),\n  };\n}\n\nexport function scoreGraphCausalLane(\n  seedMatches: readonly LaneMatch[],\n  projection: AdvisorProjection,\n  options: GraphCausalOptions = {},\n  affordances: readonly NormalizedAffordance[] = [],\n): LaneMatch[] {\n  return scoreGraphCausalLaneSplit(seedMatches, projection, options, affordances).combinedMatches;\n}","lineStart":1,"lineEnd":173,"totalLines":173,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/graph-causal.ts","time":{"start":1783437255327,"end":1783437255331}},"metadata":{"openai":{"itemId":"fc_0c442450af3a11dd016a4d17c6f0b48199bc1879de911c3ad9"}},"id":"prt_f3d24e28c001oIixX0hXMAh6aS","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d248933001MNSO87SJculP5K"}}
{"type":"tool_use","timestamp":1783437255425,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_dmMjZL9TaNt2SjZa6M4qDczN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/README.md","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/README.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Scorer Library: Skill Advisor Ranking\"\n3: description: \"Native advisor scorer modules for lane attribution, fusion, ambiguity handling, alias canonicalization, text scoring, weights and projection.\"\n4: trigger_phrases:\n5:   - \"advisor scorer\"\n6:   - \"skill advisor ranking\"\n7:   - \"scorer lanes\"\n8: ---\n9: \n10: # Scorer Library: Skill Advisor Ranking\n11: \n12: <!-- sk-doc-template: skill_readme -->\n13: \n14: ---\n15: \n16: ## 1. OVERVIEW\n17: \n18: `lib/scorer/` contains the native scoring modules used by the skill advisor to rank candidate skills. It combines lane-specific evidence, text matching, age policy, ambiguity handling, explicit alias canonicalization, fusion and output projection into prompt-safe recommendation scores.\n19: \n20: Current state:\n21: \n22: - Defines scorer types, constants and configurable weights.\n23: - Separates lane registration and lane implementations from fusion and projection.\n24: - Canonicalizes narrow command/skill alias groups before campaign scoring compares expected and actual routes.\n25: - Supports attribution and ablation helpers for advisor quality checks.\n26: \n27: ---\n28: \n29: ## 2. DIRECTORY TREE\n30: \n31: ```text\n32: scorer/\n33: +-- ablation.ts              # Scorer ablation helpers\n34: +-- age-policy.ts            # Age-aware ranking policy\n35: +-- aliases.ts               # Narrow command/skill alias canonicalization\n36: +-- ambiguity.ts             # Ambiguity detection and handling\n37: +-- attribution.ts           # Lane attribution assembly\n38: +-- beta-reliability.ts      # Beta-posterior reliability primitive for the shadow learning loop\n39: +-- feedback-calibration.ts  # Advisor feedback calibration reducer\n40: +-- fusion.ts                # Score fusion logic\n41: +-- lane-registry.ts         # Lane registration\n42: +-- lanes/                   # Lane-specific scoring modules\n43: +-- projection.ts            # Output projection helpers\n44: +-- scoring-constants.ts     # Scoring constants\n45: +-- text.ts                  # Text matching helpers\n46: +-- types.ts                 # Scorer types\n47: +-- weights-config.ts        # Weight configuration\n48: `-- README.md\n49: ```\n50: \n51: ---\n52: \n53: ## 3. KEY FILES\n54: \n55: | File | Responsibility |\n56: |---|---|\n57: | `fusion.ts` | Combines lane scores into final advisor ranking signals through RRF fusion, with a conflict-match rerank seam and a self-recommendation guard that penalizes advisor self-recommendations. |\n58: | `lane-registry.ts` | Registers available scoring lanes. |\n59: | `aliases.ts` | Canonicalizes explicit command/skill alias groups for route comparisons. |\n60: | `attribution.ts` | Builds prompt-safe lane attribution details. |\n61: | `ambiguity.ts` | Detects close or unclear recommendation states. |\n62: | `feedback-calibration.ts` | Reduces advisor feedback into shadow calibration reports. |\n63: | `projection.ts` | Projects scorer internals into caller-facing output. |\n64: | `weights-config.ts` | Stores configurable lane and scorer weights. |\n65: | `types.ts` | Defines scorer input, output and lane types. |\n66: \n67: ---\n68: \n69: ## 4. BOUNDARIES AND FLOW\n70: \n71: | Boundary | Rule |\n72: |---|---|\n73: | Imports | May import derived metadata, corpus weighting and schema types needed for scoring. |\n74: | Exports | Export scorer functions and types, not handler response formatting. |\n75: | Ownership | Put scoring and attribution here. Put prompt-safe rendering in `../render.ts` and handler orchestration in `../../handlers/`. |\n76: | Aliases | Keep command/skill aliases fixed and explicit. Do not use fuzzy or prefix matching. |\n77: \n78: Main flow:\n79: \n80: ```text\n81: prompt and candidate skills\n82:   -> lane scoring and text evidence\n83:   -> score fusion and ambiguity checks\n84:   -> alias-aware route comparison when scenario expectations use command ids\n85:   -> attribution and projection\n86:   -> caller renders recommendation\n87: ```\n88: \n89: ---\n90: \n91: ## 5. ENTRYPOINTS\n92: \n93: | Entrypoint | Type | Purpose |\n94: |---|---|---|\n95: | `fusion.ts` | TypeScript module | Score fusion logic. |\n96: | `aliases.ts` | TypeScript module | Canonical command/skill alias helpers. |\n97: | `lane-registry.ts` | TypeScript module | Lane registration. |\n98: | `projection.ts` | TypeScript module | Output projection. |\n99: | `types.ts` | TypeScript module | Scorer contracts. |\n100: | `lanes/` | Folder | Lane-specific scoring modules. |\n101: \n102: ---\n103: \n104: ## 6. VALIDATION\n105: \n106: Run from the repository root.\n107: \n108: ```bash\n109: python3 .opencode/skills/sk-doc/scripts/validate_document.py .opencode/skills/system-skill-advisor/mcp_server/lib/scorer/README.md\n110: ```\n111: \n112: Expected result: exit code `0`.\n113: \n114: ---\n115: \n116: ## 7. RELATED\n117: \n118: - [`../README.md`](../README.md)\n119: - [`../../tests/scorer/README.md`](../../tests/scorer/README.md)\n120: - [`../corpus/README.md`](../corpus/README.md)\n\n(End of file - total 120 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Scorer Library: Skill Advisor Ranking\"\ndescription: \"Native advisor scorer modules for lane attribution, fusion, ambiguity handling, alias canonicalization, text scoring, weights and projection.\"\ntrigger_phrases:\n  - \"advisor scorer\"\n  - \"skill advisor ranking\"\n  - \"scorer lanes\"\n---\n\n# Scorer Library: Skill Advisor Ranking\n\n<!-- sk-doc-template: skill_readme -->\n\n---\n\n## 1. OVERVIEW\n\n`lib/scorer/` contains the native scoring modules used by the skill advisor to rank candidate skills. It combines lane-specific evidence, text matching, age policy, ambiguity handling, explicit alias canonicalization, fusion and output projection into prompt-safe recommendation scores.\n\nCurrent state:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/README.md","text":"---\ntitle: \"Scorer Library: Skill Advisor Ranking\"\ndescription: \"Native advisor scorer modules for lane attribution, fusion, ambiguity handling, alias canonicalization, text scoring, weights and projection.\"\ntrigger_phrases:\n  - \"advisor scorer\"\n  - \"skill advisor ranking\"\n  - \"scorer lanes\"\n---\n\n# Scorer Library: Skill Advisor Ranking\n\n<!-- sk-doc-template: skill_readme -->\n\n---\n\n## 1. OVERVIEW\n\n`lib/scorer/` contains the native scoring modules used by the skill advisor to rank candidate skills. It combines lane-specific evidence, text matching, age policy, ambiguity handling, explicit alias canonicalization, fusion and output projection into prompt-safe recommendation scores.\n\nCurrent state:\n\n- Defines scorer types, constants and configurable weights.\n- Separates lane registration and lane implementations from fusion and projection.\n- Canonicalizes narrow command/skill alias groups before campaign scoring compares expected and actual routes.\n- Supports attribution and ablation helpers for advisor quality checks.\n\n---\n\n## 2. DIRECTORY TREE\n\n```text\nscorer/\n+-- ablation.ts              # Scorer ablation helpers\n+-- age-policy.ts            # Age-aware ranking policy\n+-- aliases.ts               # Narrow command/skill alias canonicalization\n+-- ambiguity.ts             # Ambiguity detection and handling\n+-- attribution.ts           # Lane attribution assembly\n+-- beta-reliability.ts      # Beta-posterior reliability primitive for the shadow learning loop\n+-- feedback-calibration.ts  # Advisor feedback calibration reducer\n+-- fusion.ts                # Score fusion logic\n+-- lane-registry.ts         # Lane registration\n+-- lanes/                   # Lane-specific scoring modules\n+-- projection.ts            # Output projection helpers\n+-- scoring-constants.ts     # Scoring constants\n+-- text.ts                  # Text matching helpers\n+-- types.ts                 # Scorer types\n+-- weights-config.ts        # Weight configuration\n`-- README.md\n```\n\n---\n\n## 3. KEY FILES\n\n| File | Responsibility |\n|---|---|\n| `fusion.ts` | Combines lane scores into final advisor ranking signals through RRF fusion, with a conflict-match rerank seam and a self-recommendation guard that penalizes advisor self-recommendations. |\n| `lane-registry.ts` | Registers available scoring lanes. |\n| `aliases.ts` | Canonicalizes explicit command/skill alias groups for route comparisons. |\n| `attribution.ts` | Builds prompt-safe lane attribution details. |\n| `ambiguity.ts` | Detects close or unclear recommendation states. |\n| `feedback-calibration.ts` | Reduces advisor feedback into shadow calibration reports. |\n| `projection.ts` | Projects scorer internals into caller-facing output. |\n| `weights-config.ts` | Stores configurable lane and scorer weights. |\n| `types.ts` | Defines scorer input, output and lane types. |\n\n---\n\n## 4. BOUNDARIES AND FLOW\n\n| Boundary | Rule |\n|---|---|\n| Imports | May import derived metadata, corpus weighting and schema types needed for scoring. |\n| Exports | Export scorer functions and types, not handler response formatting. |\n| Ownership | Put scoring and attribution here. Put prompt-safe rendering in `../render.ts` and handler orchestration in `../../handlers/`. |\n| Aliases | Keep command/skill aliases fixed and explicit. Do not use fuzzy or prefix matching. |\n\nMain flow:\n\n```text\nprompt and candidate skills\n  -> lane scoring and text evidence\n  -> score fusion and ambiguity checks\n  -> alias-aware route comparison when scenario expectations use command ids\n  -> attribution and projection\n  -> caller renders recommendation\n```\n\n---\n\n## 5. ENTRYPOINTS\n\n| Entrypoint | Type | Purpose |\n|---|---|---|\n| `fusion.ts` | TypeScript module | Score fusion logic. |\n| `aliases.ts` | TypeScript module | Canonical command/skill alias helpers. |\n| `lane-registry.ts` | TypeScript module | Lane registration. |\n| `projection.ts` | TypeScript module | Output projection. |\n| `types.ts` | TypeScript module | Scorer contracts. |\n| `lanes/` | Folder | Lane-specific scoring modules. |\n\n---\n\n## 6. VALIDATION\n\nRun from the repository root.\n\n```bash\npython3 .opencode/skills/sk-doc/scripts/validate_document.py .opencode/skills/system-skill-advisor/mcp_server/lib/scorer/README.md\n```\n\nExpected result: exit code `0`.\n\n---\n\n## 7. RELATED\n\n- [`../README.md`](../README.md)\n- [`../../tests/scorer/README.md`](../../tests/scorer/README.md)\n- [`../corpus/README.md`](../corpus/README.md)","lineStart":1,"lineEnd":120,"totalLines":120,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/README.md","time":{"start":1783437255417,"end":1783437255421}},"metadata":{"openai":{"itemId":"fc_0c442450af3a11dd016a4d17c6f0b881998a546fe6eca13c43"}},"id":"prt_f3d24e2b6001U5Okx2bCSbEYUQ","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d248933001MNSO87SJculP5K"}}
{"type":"tool_use","timestamp":1783437255468,"sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","part":{"type":"tool","tool":"read","callID":"call_zxbMZowgKGOqR7GqQlwqYSI8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/parity/scorer-eval-baseline-ratchet.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/parity/scorer-eval-baseline-ratchet.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Scorer Eval Baseline Ratchet\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: // A non-writing accuracy gate. It re-scores the full corpus, the independent\n6: // holdout, the frozen ambiguity slice, and the named intent buckets live under\n7: // the reproducible filesystem projection, and holds every metric to a committed\n8: // baseline. Numbers may only hold: a drop is a regression, and an improvement\n9: // must be captured into the baseline rather than drifting silently (so a real\n10: // gain is never mistaken for the new normal without review). The fixture hashes\n11: // are pinned so a corpus/holdout/ambiguity edit forces a conscious re-baseline,\n12: // and the release floors are retained as an absolute minimum beneath the\n13: // ratchet. This catches a regression confined to contested or single-intent\n14: // prompts that the aggregate corpus number would hide.\n15: \n16: import { createHash } from 'node:crypto';\n17: import { mkdtempSync, readFileSync } from 'node:fs';\n18: import { tmpdir } from 'node:os';\n19: import { dirname, join, resolve } from 'node:path';\n20: import { fileURLToPath } from 'node:url';\n21: \n22: import { beforeAll, describe, expect, it } from 'vitest';\n23: import type { AdvisorScoringOptions, AdvisorScoringResult } from '../../lib/scorer/types.js';\n24: \n25: // The release floors that live in the validate handler. The ratchet sits above\n26: // these: the baseline is always at least this healthy, and the exact-match\n27: // ratchet additionally forbids dropping below the last-known-good even while\n28: // still above the floor.\n29: const FULL_CORPUS_FLOOR = 0.75;\n30: const HOLDOUT_FLOOR = 0.725;\n31: \n32: interface MetricCount {\n33:   readonly correct: number;\n34:   readonly total: number;\n35:   readonly accuracy: number;\n36: }\n37: \n38: interface Baseline {\n39:   readonly schemaVersion: number;\n40:   readonly corpusSha256: string;\n41:   readonly holdoutSha256: string;\n42:   readonly ambiguitySha256: string;\n43:   readonly metrics: {\n44:     readonly full_corpus_top1: MetricCount;\n45:     readonly unknown_count: { readonly value: number };\n46:     readonly gold_none_false_fire: { readonly value: number };\n47:     readonly holdout_top1: MetricCount;\n48:     readonly ambiguity_top1: MetricCount & { readonly tau: number };\n49:     readonly buckets: {\n50:       readonly review: MetricCount;\n51:       readonly memory_save: MetricCount;\n52:       readonly delegation: MetricCount;\n53:     };\n54:   };\n55: }\n56: \n57: interface LabeledRow {\n58:   readonly prompt: string;\n59:   readonly skill_top_1: string;\n60:   readonly bucket?: string;\n61: }\n62: \n63: interface DelegationCase {\n64:   readonly prompt: string;\n65:   readonly expectedTop: string;\n66: }\n67: \n68: const HERE = dirname(fileURLToPath(import.meta.url));\n69: const ROUTING = resolve(HERE, '../../scripts/routing-accuracy');\n70: const BASELINE_PATH = join(ROUTING, 'scorer-eval-baseline.json');\n71: const CORPUS_PATH = join(ROUTING, 'labeled-prompts.jsonl');\n72: const HOLDOUT_PATH = join(ROUTING, 'holdout-prompts.jsonl');\n73: const AMBIGUITY_PATH = join(ROUTING, 'ambiguity-prompts.jsonl');\n74: const DELEGATION_PATH = resolve(HERE, 'fixtures/executor-delegation-cases.json');\n75: const SENTINEL = '.opencode/skills/system-spec-kit/SKILL.md';\n76: \n77: // Minimum bucket sizes below which a slice is statistically meaningless.\n78: const REVIEW_MIN_N = 32;\n79: const MEMORY_SAVE_MIN_N = 32;\n80: const DELEGATION_MIN_N = 11;\n81: \n82: function sha256File(path: string): string {\n83:   return `sha256:${createHash('sha256').update(readFileSync(path)).digest('hex')}`;\n84: }\n85: \n86: function readJsonl<T>(path: string): T[] {\n87:   return readFileSync(path, 'utf8').trim().split('\\n').filter(Boolean).map((line) => JSON.parse(line) as T);\n88: }\n89: \n90: // Freeze scoring to the reproducible filesystem projection: an empty\n91: // MK_SKILL_ADVISOR_DB_DIR makes the SQLite loader return null (clean FS\n92: // projection from committed metadata), semantic embeddings are disabled, and\n93: // the native lane-ranking overrides are cleared so the top-1 decision is\n94: // deterministic across machines.\n95: function freezeEvalEnv(): void {\n96:   process.env.MK_SKILL_ADVISOR_DB_DIR = mkdtempSync(join(tmpdir(), 'advisor-eval-ratchet-'));\n97:   process.env.SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC = '1';\n98:   process.env.SPECKIT_SKILL_ADVISOR_FORCE_LOCAL = '1';\n99:   delete process.env.SPECKIT_ADVISOR_LANE_WEIGHTS_JSON;\n100:   delete process.env.SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON;\n101:   delete process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW;\n102: }\n103: \n104: let scoreAdvisorPrompt: (prompt: string, options: AdvisorScoringOptions) => AdvisorScoringResult;\n105: let mergedSkillForAlias: (skillId: string) => string;\n106: let skillMatchesAlias: (actual: string, expected: string) => boolean;\n107: let workspaceRoot = '';\n108: \n109: function topSkill(prompt: string): string | null {\n110:   return scoreAdvisorPrompt(prompt, { workspaceRoot }).topSkill;\n111: }\n112: \n113: // Alias-aware top-1 match, mirroring the validate handler: superseded ids and\n114: // folded deep-loop modes are canonicalized on both sides; a both-null result is\n115: // a correct abstain.\n116: function isTop1Correct(top: string | null, goldRaw: string): boolean {\n117:   const gold = goldRaw === 'none' ? null : goldRaw;\n118:   const expected = gold === null ? null : mergedSkillForAlias(gold);\n119:   const actual = top === null ? null : mergedSkillForAlias(top);\n120:   return actual === expected\n121:     || (actual !== null && expected !== null && skillMatchesAlias(actual, expected));\n122: }\n123: \n124: function scoreSet(rows: readonly LabeledRow[]): number {\n125:   let correct = 0;\n126:   for (const row of rows) {\n127:     if (isTop1Correct(topSkill(row.prompt), row.skill_top_1)) correct += 1;\n128:   }\n129:   return correct;\n130: }\n131: \n132: // Directional non-regression message: an exact hold passes; any deviation fails\n133: // naming whether it is a regression or an unrecaptured improvement.\n134: function ratchetMessage(name: string, live: number, baseline: number, higherIsBetter: boolean): string {\n135:   const improved = higherIsBetter ? live > baseline : live < baseline;\n136:   const verdict = improved\n137:     ? 'improvement detected — re-capture the baseline (capture-scorer-eval-baseline.mjs --write)'\n138:     : 'regression — a scorer or metadata change moved this metric below the last-known-good';\n139:   return `${name}: live=${live} baseline=${baseline}. ${verdict}.`;\n140: }\n141: \n142: interface LiveMetrics {\n143:   fullCorrect: number;\n144:   unknown: number;\n145:   goldNoneFalseFire: number;\n146:   holdoutCorrect: number;\n147:   ambiguityCorrect: number;\n148:   reviewCorrect: number;\n149:   reviewTotal: number;\n150:   memorySaveCorrect: number;\n151:   memorySaveTotal: number;\n152:   delegationCorrect: number;\n153:   delegationTotal: number;\n154:   fullTotal: number;\n155:   holdoutTotal: number;\n156: }\n157: \n158: let BASELINE: Baseline;\n159: let LIVE: LiveMetrics;\n160: \n161: describe('scorer eval baseline ratchet (accuracy non-regression gate)', () => {\n162:   beforeAll(async () => {\n163:     freezeEvalEnv();\n164:     const fusion = await import('../../lib/scorer/fusion.js');\n165:     const aliases = await import('../../lib/scorer/aliases.js');\n166:     const workspace = await import('../../lib/utils/workspace-root.js');\n167:     scoreAdvisorPrompt = fusion.scoreAdvisorPrompt;\n168:     mergedSkillForAlias = aliases.mergedSkillForAlias;\n169:     skillMatchesAlias = aliases.skillMatchesAlias;\n170:     workspaceRoot = workspace.findAdvisorWorkspaceRoot(HERE, { maxDepth: 14, sentinel: SENTINEL });\n171: \n172:     BASELINE = JSON.parse(readFileSync(BASELINE_PATH, 'utf8')) as Baseline;\n173: \n174:     const corpus = readJsonl<LabeledRow>(CORPUS_PATH);\n175:     let fullCorrect = 0;\n176:     let unknown = 0;\n177:     let goldNoneFalseFire = 0;\n178:     for (const row of corpus) {\n179:       const top = topSkill(row.prompt);\n180:       if (top === null) unknown += 1;\n181:       if (row.skill_top_1 === 'none' && top !== null) goldNoneFalseFire += 1;\n182:       if (isTop1Correct(top, row.skill_top_1)) fullCorrect += 1;\n183:     }\n184: \n185:     const holdout = readJsonl<LabeledRow>(HOLDOUT_PATH);\n186:     const ambiguity = readJsonl<LabeledRow>(AMBIGUITY_PATH);\n187:     const reviewRows = corpus.filter((row) => row.bucket === 'true_read_only');\n188:     const memorySaveRows = corpus.filter((row) => row.bucket === 'memory_save_resume');\n189:     const delegation = (JSON.parse(readFileSync(DELEGATION_PATH, 'utf8')) as { cases: DelegationCase[] }).cases;\n190: \n191:     let delegationCorrect = 0;\n192:     for (const testCase of delegation) {\n193:       const expected = testCase.expectedTop === 'none' ? null : testCase.expectedTop;\n194:       if (topSkill(testCase.prompt) === expected) delegationCorrect += 1;\n195:     }\n196: \n197:     LIVE = {\n198:       fullCorrect,\n199:       unknown,\n200:       goldNoneFalseFire,\n201:       holdoutCorrect: scoreSet(holdout),\n202:       ambiguityCorrect: scoreSet(ambiguity),\n203:       reviewCorrect: scoreSet(reviewRows),\n204:       reviewTotal: reviewRows.length,\n205:       memorySaveCorrect: scoreSet(memorySaveRows),\n206:       memorySaveTotal: memorySaveRows.length,\n207:       delegationCorrect,\n208:       delegationTotal: delegation.length,\n209:       fullTotal: corpus.length,\n210:       holdoutTotal: holdout.length,\n211:     };\n212:   }, 120_000);\n213: \n214:   it('the baseline is well-formed', () => {\n215:     expect(BASELINE.schemaVersion).toBe(1);\n216:     expect(BASELINE.metrics.full_corpus_top1.total).toBeGreaterThan(190);\n217:   });\n218: \n219:   it('fixture hashes match the pinned baseline (no silent fixture drift)', () => {\n220:     expect(sha256File(CORPUS_PATH), 'corpus changed — re-baseline').toBe(BASELINE.corpusSha256);\n221:     expect(sha256File(HOLDOUT_PATH), 'holdout changed — re-baseline').toBe(BASELINE.holdoutSha256);\n222:     expect(sha256File(AMBIGUITY_PATH), 'ambiguity slice changed — re-baseline').toBe(BASELINE.ambiguitySha256);\n223:   });\n224: \n225:   it('full-corpus top-1 holds exactly and clears the release floor', () => {\n226:     expect(\n227:       LIVE.fullCorrect,\n228:       ratchetMessage('full_corpus_top1.correct', LIVE.fullCorrect, BASELINE.metrics.full_corpus_top1.correct, true),\n229:     ).toBe(BASELINE.metrics.full_corpus_top1.correct);\n230:     expect(LIVE.fullCorrect / LIVE.fullTotal).toBeGreaterThanOrEqual(FULL_CORPUS_FLOOR);\n231:   });\n232: \n233:   it('unknown_count and gold_none_false_fire hold (both improve downward)', () => {\n234:     expect(\n235:       LIVE.unknown,\n236:       ratchetMessage('unknown_count', LIVE.unknown, BASELINE.metrics.unknown_count.value, false),\n237:     ).toBe(BASELINE.metrics.unknown_count.value);\n238:     expect(\n239:       LIVE.goldNoneFalseFire,\n240:       ratchetMessage('gold_none_false_fire', LIVE.goldNoneFalseFire, BASELINE.metrics.gold_none_false_fire.value, false),\n241:     ).toBe(BASELINE.metrics.gold_none_false_fire.value);\n242:   });\n243: \n244:   it('holdout top-1 holds exactly and clears the release floor', () => {\n245:     expect(\n246:       LIVE.holdoutCorrect,\n247:       ratchetMessage('holdout_top1.correct', LIVE.holdoutCorrect, BASELINE.metrics.holdout_top1.correct, true),\n248:     ).toBe(BASELINE.metrics.holdout_top1.correct);\n249:     expect(LIVE.holdoutCorrect / LIVE.holdoutTotal).toBeGreaterThanOrEqual(HOLDOUT_FLOOR);\n250:   });\n251: \n252:   it('ambiguity slice top-1 holds exactly', () => {\n253:     expect(\n254:       LIVE.ambiguityCorrect,\n255:       ratchetMessage('ambiguity_top1.correct', LIVE.ambiguityCorrect, BASELINE.metrics.ambiguity_top1.correct, true),\n256:     ).toBe(BASELINE.metrics.ambiguity_top1.correct);\n257:   });\n258: \n259:   it('named buckets hold exactly and satisfy minN', () => {\n260:     expect(LIVE.reviewTotal).toBeGreaterThanOrEqual(REVIEW_MIN_N);\n\n(Showing lines 1-260 of 276. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Scorer Eval Baseline Ratchet\n// ───────────────────────────────────────────────────────────────\n\n// A non-writing accuracy gate. It re-scores the full corpus, the independent\n// holdout, the frozen ambiguity slice, and the named intent buckets live under\n// the reproducible filesystem projection, and holds every metric to a committed\n// baseline. Numbers may only hold: a drop is a regression, and an improvement\n// must be captured into the baseline rather than drifting silently (so a real\n// gain is never mistaken for the new normal without review). The fixture hashes\n// are pinned so a corpus/holdout/ambiguity edit forces a conscious re-baseline,\n// and the release floors are retained as an absolute minimum beneath the\n// ratchet. This catches a regression confined to contested or single-intent\n// prompts that the aggregate corpus number would hide.\n\nimport { createHash } from 'node:crypto';\nimport { mkdtempSync, readFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/parity/scorer-eval-baseline-ratchet.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Scorer Eval Baseline Ratchet\n// ───────────────────────────────────────────────────────────────\n\n// A non-writing accuracy gate. It re-scores the full corpus, the independent\n// holdout, the frozen ambiguity slice, and the named intent buckets live under\n// the reproducible filesystem projection, and holds every metric to a committed\n// baseline. Numbers may only hold: a drop is a regression, and an improvement\n// must be captured into the baseline rather than drifting silently (so a real\n// gain is never mistaken for the new normal without review). The fixture hashes\n// are pinned so a corpus/holdout/ambiguity edit forces a conscious re-baseline,\n// and the release floors are retained as an absolute minimum beneath the\n// ratchet. This catches a regression confined to contested or single-intent\n// prompts that the aggregate corpus number would hide.\n\nimport { createHash } from 'node:crypto';\nimport { mkdtempSync, readFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { beforeAll, describe, expect, it } from 'vitest';\nimport type { AdvisorScoringOptions, AdvisorScoringResult } from '../../lib/scorer/types.js';\n\n// The release floors that live in the validate handler. The ratchet sits above\n// these: the baseline is always at least this healthy, and the exact-match\n// ratchet additionally forbids dropping below the last-known-good even while\n// still above the floor.\nconst FULL_CORPUS_FLOOR = 0.75;\nconst HOLDOUT_FLOOR = 0.725;\n\ninterface MetricCount {\n  readonly correct: number;\n  readonly total: number;\n  readonly accuracy: number;\n}\n\ninterface Baseline {\n  readonly schemaVersion: number;\n  readonly corpusSha256: string;\n  readonly holdoutSha256: string;\n  readonly ambiguitySha256: string;\n  readonly metrics: {\n    readonly full_corpus_top1: MetricCount;\n    readonly unknown_count: { readonly value: number };\n    readonly gold_none_false_fire: { readonly value: number };\n    readonly holdout_top1: MetricCount;\n    readonly ambiguity_top1: MetricCount & { readonly tau: number };\n    readonly buckets: {\n      readonly review: MetricCount;\n      readonly memory_save: MetricCount;\n      readonly delegation: MetricCount;\n    };\n  };\n}\n\ninterface LabeledRow {\n  readonly prompt: string;\n  readonly skill_top_1: string;\n  readonly bucket?: string;\n}\n\ninterface DelegationCase {\n  readonly prompt: string;\n  readonly expectedTop: string;\n}\n\nconst HERE = dirname(fileURLToPath(import.meta.url));\nconst ROUTING = resolve(HERE, '../../scripts/routing-accuracy');\nconst BASELINE_PATH = join(ROUTING, 'scorer-eval-baseline.json');\nconst CORPUS_PATH = join(ROUTING, 'labeled-prompts.jsonl');\nconst HOLDOUT_PATH = join(ROUTING, 'holdout-prompts.jsonl');\nconst AMBIGUITY_PATH = join(ROUTING, 'ambiguity-prompts.jsonl');\nconst DELEGATION_PATH = resolve(HERE, 'fixtures/executor-delegation-cases.json');\nconst SENTINEL = '.opencode/skills/system-spec-kit/SKILL.md';\n\n// Minimum bucket sizes below which a slice is statistically meaningless.\nconst REVIEW_MIN_N = 32;\nconst MEMORY_SAVE_MIN_N = 32;\nconst DELEGATION_MIN_N = 11;\n\nfunction sha256File(path: string): string {\n  return `sha256:${createHash('sha256').update(readFileSync(path)).digest('hex')}`;\n}\n\nfunction readJsonl<T>(path: string): T[] {\n  return readFileSync(path, 'utf8').trim().split('\\n').filter(Boolean).map((line) => JSON.parse(line) as T);\n}\n\n// Freeze scoring to the reproducible filesystem projection: an empty\n// MK_SKILL_ADVISOR_DB_DIR makes the SQLite loader return null (clean FS\n// projection from committed metadata), semantic embeddings are disabled, and\n// the native lane-ranking overrides are cleared so the top-1 decision is\n// deterministic across machines.\nfunction freezeEvalEnv(): void {\n  process.env.MK_SKILL_ADVISOR_DB_DIR = mkdtempSync(join(tmpdir(), 'advisor-eval-ratchet-'));\n  process.env.SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC = '1';\n  process.env.SPECKIT_SKILL_ADVISOR_FORCE_LOCAL = '1';\n  delete process.env.SPECKIT_ADVISOR_LANE_WEIGHTS_JSON;\n  delete process.env.SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON;\n  delete process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW;\n}\n\nlet scoreAdvisorPrompt: (prompt: string, options: AdvisorScoringOptions) => AdvisorScoringResult;\nlet mergedSkillForAlias: (skillId: string) => string;\nlet skillMatchesAlias: (actual: string, expected: string) => boolean;\nlet workspaceRoot = '';\n\nfunction topSkill(prompt: string): string | null {\n  return scoreAdvisorPrompt(prompt, { workspaceRoot }).topSkill;\n}\n\n// Alias-aware top-1 match, mirroring the validate handler: superseded ids and\n// folded deep-loop modes are canonicalized on both sides; a both-null result is\n// a correct abstain.\nfunction isTop1Correct(top: string | null, goldRaw: string): boolean {\n  const gold = goldRaw === 'none' ? null : goldRaw;\n  const expected = gold === null ? null : mergedSkillForAlias(gold);\n  const actual = top === null ? null : mergedSkillForAlias(top);\n  return actual === expected\n    || (actual !== null && expected !== null && skillMatchesAlias(actual, expected));\n}\n\nfunction scoreSet(rows: readonly LabeledRow[]): number {\n  let correct = 0;\n  for (const row of rows) {\n    if (isTop1Correct(topSkill(row.prompt), row.skill_top_1)) correct += 1;\n  }\n  return correct;\n}\n\n// Directional non-regression message: an exact hold passes; any deviation fails\n// naming whether it is a regression or an unrecaptured improvement.\nfunction ratchetMessage(name: string, live: number, baseline: number, higherIsBetter: boolean): string {\n  const improved = higherIsBetter ? live > baseline : live < baseline;\n  const verdict = improved\n    ? 'improvement detected — re-capture the baseline (capture-scorer-eval-baseline.mjs --write)'\n    : 'regression — a scorer or metadata change moved this metric below the last-known-good';\n  return `${name}: live=${live} baseline=${baseline}. ${verdict}.`;\n}\n\ninterface LiveMetrics {\n  fullCorrect: number;\n  unknown: number;\n  goldNoneFalseFire: number;\n  holdoutCorrect: number;\n  ambiguityCorrect: number;\n  reviewCorrect: number;\n  reviewTotal: number;\n  memorySaveCorrect: number;\n  memorySaveTotal: number;\n  delegationCorrect: number;\n  delegationTotal: number;\n  fullTotal: number;\n  holdoutTotal: number;\n}\n\nlet BASELINE: Baseline;\nlet LIVE: LiveMetrics;\n\ndescribe('scorer eval baseline ratchet (accuracy non-regression gate)', () => {\n  beforeAll(async () => {\n    freezeEvalEnv();\n    const fusion = await import('../../lib/scorer/fusion.js');\n    const aliases = await import('../../lib/scorer/aliases.js');\n    const workspace = await import('../../lib/utils/workspace-root.js');\n    scoreAdvisorPrompt = fusion.scoreAdvisorPrompt;\n    mergedSkillForAlias = aliases.mergedSkillForAlias;\n    skillMatchesAlias = aliases.skillMatchesAlias;\n    workspaceRoot = workspace.findAdvisorWorkspaceRoot(HERE, { maxDepth: 14, sentinel: SENTINEL });\n\n    BASELINE = JSON.parse(readFileSync(BASELINE_PATH, 'utf8')) as Baseline;\n\n    const corpus = readJsonl<LabeledRow>(CORPUS_PATH);\n    let fullCorrect = 0;\n    let unknown = 0;\n    let goldNoneFalseFire = 0;\n    for (const row of corpus) {\n      const top = topSkill(row.prompt);\n      if (top === null) unknown += 1;\n      if (row.skill_top_1 === 'none' && top !== null) goldNoneFalseFire += 1;\n      if (isTop1Correct(top, row.skill_top_1)) fullCorrect += 1;\n    }\n\n    const holdout = readJsonl<LabeledRow>(HOLDOUT_PATH);\n    const ambiguity = readJsonl<LabeledRow>(AMBIGUITY_PATH);\n    const reviewRows = corpus.filter((row) => row.bucket === 'true_read_only');\n    const memorySaveRows = corpus.filter((row) => row.bucket === 'memory_save_resume');\n    const delegation = (JSON.parse(readFileSync(DELEGATION_PATH, 'utf8')) as { cases: DelegationCase[] }).cases;\n\n    let delegationCorrect = 0;\n    for (const testCase of delegation) {\n      const expected = testCase.expectedTop === 'none' ? null : testCase.expectedTop;\n      if (topSkill(testCase.prompt) === expected) delegationCorrect += 1;\n    }\n\n    LIVE = {\n      fullCorrect,\n      unknown,\n      goldNoneFalseFire,\n      holdoutCorrect: scoreSet(holdout),\n      ambiguityCorrect: scoreSet(ambiguity),\n      reviewCorrect: scoreSet(reviewRows),\n      reviewTotal: reviewRows.length,\n      memorySaveCorrect: scoreSet(memorySaveRows),\n      memorySaveTotal: memorySaveRows.length,\n      delegationCorrect,\n      delegationTotal: delegation.length,\n      fullTotal: corpus.length,\n      holdoutTotal: holdout.length,\n    };\n  }, 120_000);\n\n  it('the baseline is well-formed', () => {\n    expect(BASELINE.schemaVersion).toBe(1);\n    expect(BASELINE.metrics.full_corpus_top1.total).toBeGreaterThan(190);\n  });\n\n  it('fixture hashes match the pinned baseline (no silent fixture drift)', () => {\n    expect(sha256File(CORPUS_PATH), 'corpus changed — re-baseline').toBe(BASELINE.corpusSha256);\n    expect(sha256File(HOLDOUT_PATH), 'holdout changed — re-baseline').toBe(BASELINE.holdoutSha256);\n    expect(sha256File(AMBIGUITY_PATH), 'ambiguity slice changed — re-baseline').toBe(BASELINE.ambiguitySha256);\n  });\n\n  it('full-corpus top-1 holds exactly and clears the release floor', () => {\n    expect(\n      LIVE.fullCorrect,\n      ratchetMessage('full_corpus_top1.correct', LIVE.fullCorrect, BASELINE.metrics.full_corpus_top1.correct, true),\n    ).toBe(BASELINE.metrics.full_corpus_top1.correct);\n    expect(LIVE.fullCorrect / LIVE.fullTotal).toBeGreaterThanOrEqual(FULL_CORPUS_FLOOR);\n  });\n\n  it('unknown_count and gold_none_false_fire hold (both improve downward)', () => {\n    expect(\n      LIVE.unknown,\n      ratchetMessage('unknown_count', LIVE.unknown, BASELINE.metrics.unknown_count.value, false),\n    ).toBe(BASELINE.metrics.unknown_count.value);\n    expect(\n      LIVE.goldNoneFalseFire,\n      ratchetMessage('gold_none_false_fire', LIVE.goldNoneFalseFire, BASELINE.metrics.gold_none_false_fire.value, false),\n    ).toBe(BASELINE.metrics.gold_none_false_fire.value);\n  });\n\n  it('holdout top-1 holds exactly and clears the release floor', () => {\n    expect(\n      LIVE.holdoutCorrect,\n      ratchetMessage('holdout_top1.correct', LIVE.holdoutCorrect, BASELINE.metrics.holdout_top1.correct, true),\n    ).toBe(BASELINE.metrics.holdout_top1.correct);\n    expect(LIVE.holdoutCorrect / LIVE.holdoutTotal).toBeGreaterThanOrEqual(HOLDOUT_FLOOR);\n  });\n\n  it('ambiguity slice top-1 holds exactly', () => {\n    expect(\n      LIVE.ambiguityCorrect,\n      ratchetMessage('ambiguity_top1.correct', LIVE.ambiguityCorrect, BASELINE.metrics.ambiguity_top1.correct, true),\n    ).toBe(BASELINE.metrics.ambiguity_top1.correct);\n  });\n\n  it('named buckets hold exactly and satisfy minN', () => {\n    expect(LIVE.reviewTotal).toBeGreaterThanOrEqual(REVIEW_MIN_N);","lineStart":1,"lineEnd":260,"totalLines":276,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/tests/parity/scorer-eval-baseline-ratchet.vitest.ts","time":{"start":1783437255453,"end":1783437255465}},"metadata":{"openai":{"itemId":"fc_0c442450af3a11dd016a4d17c6f0c081998c97994a1ff44751"}},"id":"prt_f3d24e300001p7EgM7uo0pwSjn","sessionID":"ses_0c2dd1dfdffe3xOI17ORqH0qGV","messageID":"msg_f3d248933001MNSO87SJculP5K"}}
