ironment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py:\n  Line 444: GRAPH_HOP_BOOST = {\n\n  Line 449: GRAPH_MAX_BOOSTED_MEMORIES = 50  # cap on memories receiving graph boost (prevents popular-entity fan-out)\n\n  Line 468: FTS_WEIGHT = 0.3  # blend: (1 - FTS_WEIGHT) * vector + FTS_WEIGHT * keyword\n\n  Line 469: FTS_WEIGHT_BOOSTED = 0.6  # for short specific queries (1-3 proper nouns / identifiers)\n\n  Line 470: FTS_BOOST_MAX_TOKENS = 3  # queries with more meaningful tokens than this stay at FTS_WEIGHT\n\n  Line 472: SIMILARITY_BLEND = 0.85  # base_score = SIMILARITY_BLEND * similarity + (1 - SIMILARITY_BLEND) * weight (raised from 0.75 — LoCoMo sweep showed +13pp recall)\n\n  Line 473: SEARCH_OVERFETCH_FACTOR = 2  # fetch top_k * N candidates from storage, trim to top_k after min_similarity filter — gives post-filter headroom\n\n  Line 474: RECALL_BOOST_CAP = 1.5  # max multiplier from frequent recall\n\n  Line 475: RECALL_DECAY_WINDOW_DAYS = 90  # only recalls within this window contribute to boost\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py:\n  Line 18:     GRAPH_HOP_BOOST,\n\n  Line 19:     GRAPH_MAX_BOOSTED_MEMORIES,\n\n  Line 20:     RECALL_BOOST_CAP,\n\n  Line 109:                 hop_boost = GRAPH_HOP_BOOST.get(hop, GRAPH_HOP_BOOST[max(GRAPH_HOP_BOOST)])\n\n  Line 113:                 if len(memory_boost_factor) >= GRAPH_MAX_BOOSTED_MEMORIES:\n\n  Line 131:                             RECALL_BOOST_CAP,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/classify_query.py:\n  Line 22:     FTS_WEIGHT_BOOSTED,\n\n  Line 2