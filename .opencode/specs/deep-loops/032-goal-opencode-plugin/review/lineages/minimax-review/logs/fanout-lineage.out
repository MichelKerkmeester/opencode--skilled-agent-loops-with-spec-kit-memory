/.opencode/specs/deep-loops/032-goal-opencode-plugin/review/lineages/minimax-review/deep-review-findings-registry.json'\nd=json.load(open(p))\nnew_findings = [\n    {\"findingId\":\"F024\",\"severity\":\"P1\",\"category\":\"traceability\",\"status\":\"active\",\"dimension\":\"traceability\",\"title\":\"Both feature catalogs miss speckit-goal-offer-contract.test.cjs (8th goal test file)\",\"file\":\".opencode/skills/system-spec-kit/feature_catalog/18--ux-hooks/goal-opencode-plugin.md\",\"line\":58,\"firstSeen\":7,\"lastSeen\":7,\"transitions\":[{\"iteration\":7,\"from\":None,\"to\":\"P1\",\"reason\":\"Initial discovery (feature_catalog_code overlay)\"}],\"content_hash\":\"sha256:f024-feature-catalog-missing-test-file-2026-07-04\"},\n    {\"findingId\":\"F025\",\"severity\":\"P1\",\"category\":\"traceability\",\"status\":\"active\",\"dimension\":\"traceability\",\"title\":\"Two catalog rows describe mk-goal-state.test.cjs with different scopes (description parity broken)\",\"file\":\".opencode/skills/system-skill-advisor/feature_catalog/07--hooks-and-plugin/goal-opencode-plugin.md\",\"line\":61,\"firstSeen\":7,\"lastSeen\":7,\"transitions\":[{\"iteration\":7,\"from\":None,\"to\":\"P1\",\"reason\":\"Initial discovery (catalog description parity drift)\"}],\"content_hash\":\"sha256:f025-catalog-description-parity-broken-2026-07-04\"},\n    {\"findingId\":\"F026\",\"severity\":\"P2\",\"category\":\"traceability\",\"status\":\"active\",\"dimension\":\"traceability\",\"title\":\"Audit dossier DOC-2 (missing export-contract row) is now obsolete; row is present\",\"file\":\".opencode/skills/system-spec-kit/feature_catalog/18--ux-hooks/goal-opencode-plugin.md\",\"line\":60,\"firstSeen\":7,\"lastSeen\":7,\"transitions\":[{\"iteration\":7,\"from\":None,\"to\":\"P2\",\"reason\":\"Initial discovery (audit dossier drift; F010/F012 same family)\"}],\"content_hash\":\"sha256:f026-audit-doc2-obsolete-2026-07-04\"},\n]\nd['openFindings'].extend(new_findings)\nd['openFindingsCount']=26