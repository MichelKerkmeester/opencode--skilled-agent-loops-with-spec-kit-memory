{"type":"tool_use","timestamp":1784444203223,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"type":"tool","tool":"read","callID":"call_x8N2ZgPtzojq1BsGspC2K4N3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":1440,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1440:     ));\n1441:     return { command: 'opencode', args, input: '' };\n1442:   }\n1443: \n1444:   if (kind === 'cli-opencode') {\n1445:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1446:     // on a top-level `run`. The default agent runs when none is named, and a\n1447:     // specific agent profile can be requested in the prompt body instead.\n1448:     const args = [\n1449:       'run',\n1450:       '--model',\n1451:       lineage.model || 'anthropic/claude-opus-4-8',\n1452:       '--format',\n1453:       'json',\n1454:       '--pure',\n1455:       '--dir',\n1456:       process.cwd(),\n1457:     ];\n1458:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1459:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1460:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1461:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1462:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n1463:     // must now opt into full bypass rather than getting it silently by default.\n1464:     const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n1465:     if (useDangerousBypass) {\n1466:       args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n1467:       process.stderr.write(\n1468:         `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n1469:           + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n1470:       );\n1471:     }\n1472:     if (lineage.reasoningEffort) {\n1473:       args.push('--variant', lineage.reasoningEffort);\n1474:     }\n1475:     args.push(prompt);\n1476:     return { command: 'opencode', args, input: '' };\n1477:   }\n1478: \n1479:   throw inputError(`Unknown fan-out executor kind: ${kind}`);\n1480: }\n1481: \n1482: function isCodexBinaryAvailable(env = process.env) {\n1483:   const result = spawnSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], {\n1484:     env,\n1485:     stdio: 'ignore',\n1486:   });\n1487:   return result.status === 0;\n1488: }\n1489: \n1490: // ─────────────────────────────────────────────────────────────────────────────\n1491: // 4. CORE LOGIC\n1492: // ─────────────────────────────────────────────────────────────────────────────\n1493: \n1494: async function main() {\n1495:   const args = parseArgs();\n1496:   const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n1497:   const loopType = ensureString(args, 'loopType');\n1498:   assertActiveFanoutLoopType(loopType);\n1499:   // Optional shared research question, threaded into each lineage prompt so a research\n1500:   // fan-out can bind research_topic. Absent for review, which scopes by folder.\n1501:   const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n1502:     ? args.researchTopic.trim()\n1503:     : null;\n1504:   const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n1505:   const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n1506:   const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n1507:   const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n1508:   assertLineageTimeoutHoursOverrideWithinCeiling(lineageTimeoutHoursOverride);\n1509:   const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n1510: \n1511:   const {\n1512:     parseFanoutConfig,\n1513:     expandLineages,\n1514:     resolveSandboxMode,\n1515:     resolveClaudePermissionMode,\n1516:   } = await import('../lib/deep-loop/executor-config.ts');\n1517:   const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n1518:   const {\n1519:     DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1520:     checkLineageTimestampWindow,\n1521:   } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n1522: \n1523:   maybeThrowTestFault();\n1524: \n1525:   let rawConfig;\n1526:   try {\n1527:     rawConfig = JSON.parse(fanoutConfigJson);\n1528:   } catch {\n1529:     throw inputError('fanoutConfigJson is not valid JSON');\n1530:   }\n1531: \n1532:   const lineagesDir = path.join(baseArtifactDir, 'lineages');\n1533:   const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n1534:   const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n1535:   const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n1536:   const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n1537:   const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n1538:   const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n1539:   const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n1540:   const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n1541:   const fanoutConfig = guardedAssignment.config;\n1542:   const allLineages = expandLineages(fanoutConfig);\n1543: \n1544:   // Aggregate budget is a SEPARATE ceiling from the per-lineage cap enforced inside the\n1545:   // worker below — both must pass, neither replaces the other. Checked upfront (before any\n1546:   // lineage spawns) because it is fully computable from static config, so failing fast here\n1547:   // avoids burning real subprocess time on a run that was already over budget at submission.\n1548:   const aggregateBudgetDecision = evaluateAggregateBudgetCap({\n1549:     lineages: allLineages,\n1550:     guards: rawGuardConfig,\n1551:     maxRetries: fanoutConfig.maxRetries,\n1552:   });\n1553:   if (!aggregateBudgetDecision.continue_allowed) {\n1554:     appendFanoutStatusLedger(ledgerPath, {\n1555:       event: 'aggregate_budget_cap_exceeded',\n1556:       at: new Date().toISOString(),\n1557:       run_id: runId,\n1558:       loop_type: loopType,\n1559:       spec_folder: specFolder,\n1560:       severity: 'error',\n1561:       stop_reasons: aggregateBudgetDecision.stop_reasons,\n1562:       upper_bound: aggregateBudgetDecision.upper_bound,\n1563:     });\n1564:     throw inputError(\n1565:       `fan-out aggregate budget exceeded: ${aggregateBudgetDecision.upper_bound.estimated_cost_units} > `\n1566:         + `${aggregateBudgetDecision.upper_bound.max_aggregate_cost_units} cost units across `\n1567:         + `${aggregateBudgetDecision.upper_bound.lineage_count} lineage(s)`,\n1568:     );\n1569:   }\n1570: \n1571:   const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n1572:   const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n1573:   const slotIntervalMs = progressHeartbeatMs;\n1574: \n1575:   logFlatPoolGuardRejections({\n1576:     rejections: guardedAssignment.rejections,\n1577:     ledgerPath,\n1578:     runId,\n1579:     loopType,\n1580:     specFolder,\n1581:   });\n1582: \n1583:   // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n1584:   // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n1585:   // ownership here so all lineages share the same retries and artifact validation.\n1586:   const cliLineages = allLineages;\n1587:   const checkpointPath = waitCheckpointPath(baseArtifactDir);\n1588:   const resumeWaiting = await resumeWaitingCheckpoint({\n1589:     checkpointPath,\n1590:     ledgerPath,\n1591:     runId,\n1592:     loopType,\n1593:     specFolder,\n1594:   });\n1595:   if (!resumeWaiting.didWait) {\n1596:     await persistPreDispatchWait({\n1597:       checkpointPath,\n1598:       ledgerPath,\n1599:       runId,\n1600:       loopType,\n1601:       specFolder,\n1602:       waitMs: args.preDispatchWaitMs,\n1603:     });\n1604:   }\n1605: \n1606:   if (cliLineages.length === 0) {\n1607:     const summary = {\n1608:       total: 0,\n1609:       succeeded: 0,\n1610:       failed: 0,\n1611:       all_failed: false,\n1612:       gauges: { lag: 0, pending: 0, failed: 0 },\n1613:       convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n1614:     };\n1615:     writeOrchestrationSummary(summaryPath, {\n1616:       run_id: runId,\n1617:       loop_type: loopType,\n1618:       spec_folder: specFolder,\n1619:       base_artifact_dir: baseArtifactDir,\n1620:       total_cli_lineages: 0,\n1621:       ...summary,\n1622:     });\n1623:     jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n1624:     return;\n1625:   }\n1626: \n1627:   fs.mkdirSync(lineagesDir, { recursive: true });\n1628:   const orphanedLineages = markOrphanedLineages(ledgerPath);\n1629:   const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n1630: \n1631:   const lineageSnapshots = new Map();\n1632:   const lineageSlotAccounting = new Map();\n1633:   const lineageProcessLiveness = new Map();\n1634:   let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n1635:   let stoppedSummaryWritten = false;\n1636: \n1637:   const writeStoppedSummary = (signal) => {\n1638:     if (stoppedSummaryWritten) return;\n1639:     stoppedSummaryWritten = true;\n1640:     stopActiveLineageProcesses(signal);\n1641:     const stoppedAtIso = new Date().toISOString();\n1642:     const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n1643:     const gauges = {\n1644:       lag: latestGauges.lag,\n1645:       pending: latestGauges.pending,\n1646:       failed: Math.max(latestGauges.failed, partial.summary.failed),\n1647:     };\n1648:     appendFanoutStatusLedger(ledgerPath, {\n1649:       event: 'stopped',\n1650:       signal,\n1651:       at: stoppedAtIso,\n1652:       gauges,\n1653:     });\n1654:     writeOrchestrationSummary(summaryPath, {\n1655:       run_id: runId,\n1656:       loop_type: loopType,\n1657:       spec_folder: specFolder,\n1658:       base_artifact_dir: baseArtifactDir,\n1659:       total_cli_lineages: cliLineages.length,\n1660:       stopped: true,\n1661:       stopped_signal: signal,\n1662:       stopped_at_iso: stoppedAtIso,\n1663:       status: 'partial',\n1664:       ...partial.summary,\n1665:       gauges,\n1666:       results: partial.results,\n1667:     });\n1668:   };\n1669: \n1670:   installFanoutSignalHandlers(writeStoppedSummary);\n1671: \n1672:   const { results, summary } = await runCappedPool({\n1673:     items: cliLineages,\n1674:     concurrency: fanoutConfig.concurrency,\n1675:     maxRetries: fanoutConfig.maxRetries,\n1676:     lagCeilingMs: fanoutConfig.lagCeilingMs,\n1677:     postExitGraceMs,\n1678:     initialRetryCounts,\n1679:     getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n1680:     onEvent: (event) => {\n1681:       const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n1682:       updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n1683:       if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n1684:       appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n1685:     },\n1686:     worker: async (lineage, context) => {\n1687:       const slotWindowStartIso = new Date().toISOString();\n1688:       const hrStart = process.hrtime();\n1689:       const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n1690:       const livenessKey = `${lineage.label}:${attempt}`;\n1691:       const lineageDir = path.join(lineagesDir, lineage.label);\n1692:       const stateDir = path.join(lineageDir, '.executor-state');\n1693:       fs.mkdirSync(lineageDir, { recursive: true });\n1694:       fs.mkdirSync(stateDir, { recursive: true });\n1695: \n1696:       const budgetDecision = evaluateLineageBudgetCap({\n1697:         lineage,\n1698:         guards: lineageBudgetGuards,\n1699:         maxRetries: fanoutConfig.maxRetries,\n1700:       });\n1701:       if (!budgetDecision.continue_allowed) {\n1702:         appendFanoutStatusLedger(ledgerPath, {\n1703:           event: 'budget_cap_exceeded',\n1704:           label: lineage.label,\n1705:           at: new Date().toISOString(),\n1706:           severity: 'error',\n1707:           stop_reasons: budgetDecision.stop_reasons,\n1708:           upper_bound: budgetDecision.upper_bound,\n1709:           gauges: latestGauges,\n1710:         });\n1711:         const failure = new Error(\n1712:           `lineage ${lineage.label} exceeds configured budget cap: `\n1713:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1714:         );\n1715:         failure.label = lineage.label;\n1716:         failure.exitCode = null;\n1717:         failure.timedOut = false;\n1718:         failure.budgetCap = budgetDecision;\n1719:         throw failure;\n1720:       }\n1721: \n1722:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1723:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1724:         convergenceThreshold,\n1725:         stopPolicy,\n1726:       });\n1727: \n1728:       // Sandbox resolution stays write-capable by default even for review lineages:\n1729:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1730:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1731:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1732:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1733:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1734:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1735:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1736:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1737: \n1738:       const effectiveSandbox = resolvedSandbox;\n1739:       const effectivePermission = resolvedPermission;\n1740: \n1741:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1742:         lineage,\n1743:         prompt,\n1744:         effectiveSandbox,\n1745:         effectivePermission,\n1746:         {\n1747:           loopType,\n1748:           specFolder,\n1749:           lineageDir,\n1750:           sessionId,\n1751:           convergenceThreshold,\n1752:           stopPolicy,\n1753:           researchTopic,\n1754:         },\n1755:       );\n1756: \n1757:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1758:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1759:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1760:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1761:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1762:       // is deliberately avoided here because relocating the home breaks credential/auth\n1763:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1764:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1765:       const extraEnv = {\n1766:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1767:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1768:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1769:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1770:           : {}),\n1771:       };\n1772: \n1773:       // Recursion guard (fail closed): the executor stack can already name the hosting\n1774:       // runtime before the first detached fan-out spawn. The lineage marker is added only\n1775:       // to a spawned seat, so both signals are required to prove that a seat is trying to\n1776:       // fan out its own executor kind again.\n1777:       const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n1778:       const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n1779:         && inheritedLineageId.trim() !== '';\n1780:       if (\n1781:         isInsideFanoutLineage\n1782:         && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n1783:       ) {\n1784:         throw new Error(\n1785:           `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n1786:         );\n1787:       }\n1788: \n1789:       // Stamp the dispatch stack with this lineage's executor kind so a seat that\n1790:       // tries to recursively launch the same kind is detectable by the runtime\n1791:       // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n1792:       // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n1793:       // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n1794:       // preserve the per-replica lockfile isolation they provide.\n1795:       const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n1796: \n1797:       const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n1798:       let lastLineageEventAtMs = Date.now();\n1799:       const markLineageEvent = () => {\n1800:         lastLineageEventAtMs = Date.now();\n1801:       };\n1802:       const stopStallWatchdog = startLineageStallWatchdog({\n1803:         thresholdMs: stallWatchdogMs,\n1804:         label: lineage.label,\n1805:         ledgerPath,\n1806:         getLastEventAtMs: () => lastLineageEventAtMs,\n1807:         getGauges: () => latestGauges,\n1808:       });\n1809: \n1810:       const stopProgressHeartbeat = startLineageProgressHeartbeat({\n1811:         cadenceMs: progressHeartbeatMs,\n1812:         label: lineage.label,\n1813:         ledgerPath,\n1814:         getGauges: () => latestGauges,\n1815:       });\n1816:       let result;\n1817:       try {\n1818:         result = await runLineageProcess(command, cmdArgs, {\n1819:           cwd: process.cwd(),\n1820:           timeoutMs,\n1821:           env: dispatchEnv,\n1822:           maxBuffer: 20 * 1024 * 1024,\n1823:           abortSignal: context.signal,\n1824:           onOutput: markLineageEvent,\n1825:           onSpawn: ({ pid }) => {\n1826:             lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n1827:           },\n1828:           onExit: ({ pid, exitedAtMs }) => {\n1829:             lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n1830:           },\n1831:           ...(typeof input === 'string' ? { input } : {}),\n1832:         });\n1833:       } finally {\n1834:         stopProgressHeartbeat();\n1835:         stopStallWatchdog();\n1836:       }\n1837: \n1838:       // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n1839:       const logsDir = path.join(lineageDir, 'logs');\n1840:       fs.mkdirSync(logsDir, { recursive: true });\n1841:       const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n1842:       fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n1843: \n1844:       // Recover missing iteration files from captured stdout when possible. Runs\n1845:       // BEFORE the failure throw below so iteration recovery is never lost.\n1846:       const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n1847:       const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n1848:       lineageSlotAccounting.set(lineage.label, slotAccounting);\n1849: \n1850:       const exitCode = result.status ?? (result.error ? 1 : 0);\n1851:       const timedOut = result.signal === 'SIGTERM';\n1852:       // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n1853:       // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n1854:       // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n1855:       const killedBySignal = result.signal != null;\n1856:       const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n1857:       const stateRead = readLineageStateRecords(loopType, lineageDir);\n1858:       const stopPolicyViolation = findMaxIterationsPolicyViolation({\n1859:         loopType,\n1860:         stateRead,\n1861:         lineage,\n1862:         stopPolicy,\n1863:       });\n1864: \n1865:       // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n1866:       // not a success. Throw so the pool settles this item as rejected and counts it\n1867:       // in summary.failed/all_failed, which drives the process exit code. Returning a\n1868:       // plain object here would let the pool record any completed worker as fulfilled\n1869:       // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n1870:       if (timedOut || killedBySignal || exitCode !== 0) {\n1871:         const reason = timedOut\n1872:           ? 'timed out'\n1873:           : killedBySignal\n1874:             ? `killed by signal ${result.signal}`\n1875:             : `exited with code ${exitCode}`;\n1876:         const failure = new Error(`lineage ${lineage.label} ${reason}`);\n1877:         failure.label = lineage.label;\n1878:         failure.exitCode = exitCode;\n1879:         failure.timedOut = timedOut;\n1880:         failure.killedBySignal = killedBySignal;\n1881:         failure.salvage = salvage;\n1882:         throw failure;\n1883:       }\n1884: \n1885:       if (missingArtifacts.length > 0) {\n1886:         const failure = new Error(\n1887:           `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n1888:         );\n1889:         failure.label = lineage.label;\n1890:         failure.exitCode = exitCode;\n1891:         failure.timedOut = false;\n1892:         failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n1893:         failure.missingArtifacts = missingArtifacts;\n1894:         throw failure;\n1895:       }\n1896: \n1897:       if (stopPolicyViolation) {\n1898:         const failure = new Error(\n1899:           `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n1900:         );\n1901:         failure.label = lineage.label;\n1902:         failure.exitCode = exitCode;\n1903:         failure.timedOut = false;\n1904:         failure.salvage = salvage;\n1905:         failure.stopPolicyViolation = stopPolicyViolation;\n1906:         throw failure;\n1907:       }\n1908: \n1909:       // An exit-0 lineage whose salvage sweep could not recover every iteration\n1910:       // markdown is NOT fulfilled, even when the top-level report exists. Returning\n1911:       // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n1912:       // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n1913:       // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n1914:       if (salvage && salvage.failed > 0) {\n1915:         const failure = new Error(\n1916:           `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n1917:         );\n1918:         failure.label = lineage.label;\n1919:         failure.exitCode = exitCode;\n1920:         failure.timedOut = false;\n1921:         failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n1922:         failure.missingArtifacts = [];\n1923:         throw failure;\n1924:       }\n1925: \n1926:       const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n1927:       if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n1928:         const slotWindowEndIso = new Date().toISOString();\n1929:         try {\n1930:           const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n1931:             windowStart: slotWindowStartIso,\n1932:             windowEnd: slotWindowEndIso,\n1933:             toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1934:           });\n1935:           if (timestampCheck.anomalous > 0) {\n1936:             const timestampAnomaly = buildTimestampAnomalyPayload({\n1937:               lineage,\n1938:               statePath: stateRead.statePath,\n1939:               check: timestampCheck,\n\n(Showing lines 1440-1939 of 2021. Use offset=1940 to continue.)\n</content>","metadata":{"preview":"    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n    // --dangerously-skip-permissions so their writes are subject to the CLI permission\n    // boundary. opencode has no path-scoped write flag, so a workspace-write review\n    // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n    // must now opt into full bypass rather than getting it silently by default.\n    const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n    if (useDangerousBypass) {\n      args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n      process.stderr.write(\n        `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n          + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n      );\n    }\n    if (lineage.reasoningEffort) {\n      args.push('--variant', lineage.reasoningEffort);\n    }\n    args.push(prompt);\n    return { command: 'opencode', args, input: '' };\n  }\n\n  throw inputError(`Unknown fan-out executor kind: ${kind}`);\n}\n\nfunction isCodexBinaryAvailable(env = process.env) {\n  const result = spawnSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], {\n    env,\n    stdio: 'ignore',\n  });\n  return result.status === 0;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const args = parseArgs();\n  const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n  const loopType = ensureString(args, 'loopType');\n  assertActiveFanoutLoopType(loopType);\n  // Optional shared research question, threaded into each lineage prompt so a research\n  // fan-out can bind research_topic. Absent for review, which scopes by folder.\n  const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n    ? args.researchTopic.trim()\n    : null;\n  const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n  const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n  const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n  const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n  assertLineageTimeoutHoursOverrideWithinCeiling(lineageTimeoutHoursOverride);\n  const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n\n  const {\n    parseFanoutConfig,\n    expandLineages,\n    resolveSandboxMode,\n    resolveClaudePermissionMode,\n  } = await import('../lib/deep-loop/executor-config.ts');\n  const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n  const {\n    DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n    checkLineageTimestampWindow,\n  } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n\n  maybeThrowTestFault();\n\n  let rawConfig;\n  try {\n    rawConfig = JSON.parse(fanoutConfigJson);\n  } catch {\n    throw inputError('fanoutConfigJson is not valid JSON');\n  }\n\n  const lineagesDir = path.join(baseArtifactDir, 'lineages');\n  const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n  const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n  const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n  const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n  const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n  const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n  const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n  const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n  const fanoutConfig = guardedAssignment.config;\n  const allLineages = expandLineages(fanoutConfig);\n\n  // Aggregate budget is a SEPARATE ceiling from the per-lineage cap enforced inside the\n  // worker below — both must pass, neither replaces the other. Checked upfront (before any\n  // lineage spawns) because it is fully computable from static config, so failing fast here\n  // avoids burning real subprocess time on a run that was already over budget at submission.\n  const aggregateBudgetDecision = evaluateAggregateBudgetCap({\n    lineages: allLineages,\n    guards: rawGuardConfig,\n    maxRetries: fanoutConfig.maxRetries,\n  });\n  if (!aggregateBudgetDecision.continue_allowed) {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'aggregate_budget_cap_exceeded',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      severity: 'error',\n      stop_reasons: aggregateBudgetDecision.stop_reasons,\n      upper_bound: aggregateBudgetDecision.upper_bound,\n    });\n    throw inputError(\n      `fan-out aggregate budget exceeded: ${aggregateBudgetDecision.upper_bound.estimated_cost_units} > `\n        + `${aggregateBudgetDecision.upper_bound.max_aggregate_cost_units} cost units across `\n        + `${aggregateBudgetDecision.upper_bound.lineage_count} lineage(s)`,\n    );\n  }\n\n  const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n  const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n  const slotIntervalMs = progressHeartbeatMs;\n\n  logFlatPoolGuardRejections({\n    rejections: guardedAssignment.rejections,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n\n  // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n  // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n  // ownership here so all lineages share the same retries and artifact validation.\n  const cliLineages = allLineages;\n  const checkpointPath = waitCheckpointPath(baseArtifactDir);\n  const resumeWaiting = await resumeWaitingCheckpoint({\n    checkpointPath,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n  if (!resumeWaiting.didWait) {\n    await persistPreDispatchWait({\n      checkpointPath,\n      ledgerPath,\n      runId,\n      loopType,\n      specFolder,\n      waitMs: args.preDispatchWaitMs,\n    });\n  }\n\n  if (cliLineages.length === 0) {\n    const summary = {\n      total: 0,\n      succeeded: 0,\n      failed: 0,\n      all_failed: false,\n      gauges: { lag: 0, pending: 0, failed: 0 },\n      convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n    };\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: 0,\n      ...summary,\n    });\n    jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n    return;\n  }\n\n  fs.mkdirSync(lineagesDir, { recursive: true });\n  const orphanedLineages = markOrphanedLineages(ledgerPath);\n  const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n\n  const lineageSnapshots = new Map();\n  const lineageSlotAccounting = new Map();\n  const lineageProcessLiveness = new Map();\n  let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n  let stoppedSummaryWritten = false;\n\n  const writeStoppedSummary = (signal) => {\n    if (stoppedSummaryWritten) return;\n    stoppedSummaryWritten = true;\n    stopActiveLineageProcesses(signal);\n    const stoppedAtIso = new Date().toISOString();\n    const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n    const gauges = {\n      lag: latestGauges.lag,\n      pending: latestGauges.pending,\n      failed: Math.max(latestGauges.failed, partial.summary.failed),\n    };\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'stopped',\n      signal,\n      at: stoppedAtIso,\n      gauges,\n    });\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: cliLineages.length,\n      stopped: true,\n      stopped_signal: signal,\n      stopped_at_iso: stoppedAtIso,\n      status: 'partial',\n      ...partial.summary,\n      gauges,\n      results: partial.results,\n    });\n  };\n\n  installFanoutSignalHandlers(writeStoppedSummary);\n\n  const { results, summary } = await runCappedPool({\n    items: cliLineages,\n    concurrency: fanoutConfig.concurrency,\n    maxRetries: fanoutConfig.maxRetries,\n    lagCeilingMs: fanoutConfig.lagCeilingMs,\n    postExitGraceMs,\n    initialRetryCounts,\n    getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n    onEvent: (event) => {\n      const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n      updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n      if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n      appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n    },\n    worker: async (lineage, context) => {\n      const slotWindowStartIso = new Date().toISOString();\n      const hrStart = process.hrtime();\n      const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n      const livenessKey = `${lineage.label}:${attempt}`;\n      const lineageDir = path.join(lineagesDir, lineage.label);\n      const stateDir = path.join(lineageDir, '.executor-state');\n      fs.mkdirSync(lineageDir, { recursive: true });\n      fs.mkdirSync(stateDir, { recursive: true });\n\n      const budgetDecision = evaluateLineageBudgetCap({\n        lineage,\n        guards: lineageBudgetGuards,\n        maxRetries: fanoutConfig.maxRetries,\n      });\n      if (!budgetDecision.continue_allowed) {\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'budget_cap_exceeded',\n          label: lineage.label,\n          at: new Date().toISOString(),\n          severity: 'error',\n          stop_reasons: budgetDecision.stop_reasons,\n          upper_bound: budgetDecision.upper_bound,\n          gauges: latestGauges,\n        });\n        const failure = new Error(\n          `lineage ${lineage.label} exceeds configured budget cap: `\n            + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = null;\n        failure.timedOut = false;\n        failure.budgetCap = budgetDecision;\n        throw failure;\n      }\n\n      const sessionId = `fanout-${lineage.label}-${runId}`;\n      const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n        convergenceThreshold,\n        stopPolicy,\n      });\n\n      // Sandbox resolution stays write-capable by default even for review lineages:\n      // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n      // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n      // blanket read-only default would break those writes. The lineageDir-only write boundary\n      // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n      // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n      // exposed one. Callers can still pass an explicit sandboxMode to override.\n      const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n      const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n\n      const effectiveSandbox = resolvedSandbox;\n      const effectivePermission = resolvedPermission;\n\n      const { command, args: cmdArgs, input } = buildLineageCommand(\n        lineage,\n        prompt,\n        effectiveSandbox,\n        effectivePermission,\n        {\n          loopType,\n          specFolder,\n          lineageDir,\n          sessionId,\n          convergenceThreshold,\n          stopPolicy,\n          researchTopic,\n        },\n      );\n\n      // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n      // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n      // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n      // native lockfile. Real same-kind-replica isolation comes from each lineage's\n      // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n      // is deliberately avoided here because relocating the home breaks credential/auth\n      // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n      const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n      const extraEnv = {\n        SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n        ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n        ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n          ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n          : {}),\n      };\n\n      // Recursion guard (fail closed): the executor stack can already name the hosting\n      // runtime before the first detached fan-out spawn. The lineage marker is added only\n      // to a spawned seat, so both signals are required to prove that a seat is trying to\n      // fan out its own executor kind again.\n      const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n      const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n        && inheritedLineageId.trim() !== '';\n      if (\n        isInsideFanoutLineage\n        && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n      ) {\n        throw new Error(\n          `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n        );\n      }\n\n      // Stamp the dispatch stack with this lineage's executor kind so a seat that\n      // tries to recursively launch the same kind is detectable by the runtime\n      // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n      // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n      // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n      // preserve the per-replica lockfile isolation they provide.\n      const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n\n      const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n      let lastLineageEventAtMs = Date.now();\n      const markLineageEvent = () => {\n        lastLineageEventAtMs = Date.now();\n      };\n      const stopStallWatchdog = startLineageStallWatchdog({\n        thresholdMs: stallWatchdogMs,\n        label: lineage.label,\n        ledgerPath,\n        getLastEventAtMs: () => lastLineageEventAtMs,\n        getGauges: () => latestGauges,\n      });\n\n      const stopProgressHeartbeat = startLineageProgressHeartbeat({\n        cadenceMs: progressHeartbeatMs,\n        label: lineage.label,\n        ledgerPath,\n        getGauges: () => latestGauges,\n      });\n      let result;\n      try {\n        result = await runLineageProcess(command, cmdArgs, {\n          cwd: process.cwd(),\n          timeoutMs,\n          env: dispatchEnv,\n          maxBuffer: 20 * 1024 * 1024,\n          abortSignal: context.signal,\n          onOutput: markLineageEvent,\n          onSpawn: ({ pid }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n          },\n          onExit: ({ pid, exitedAtMs }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n          },\n          ...(typeof input === 'string' ? { input } : {}),\n        });\n      } finally {\n        stopProgressHeartbeat();\n        stopStallWatchdog();\n      }\n\n      // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n      const logsDir = path.join(lineageDir, 'logs');\n      fs.mkdirSync(logsDir, { recursive: true });\n      const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n      fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n\n      // Recover missing iteration files from captured stdout when possible. Runs\n      // BEFORE the failure throw below so iteration recovery is never lost.\n      const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n      const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n      lineageSlotAccounting.set(lineage.label, slotAccounting);\n\n      const exitCode = result.status ?? (result.error ? 1 : 0);\n      const timedOut = result.signal === 'SIGTERM';\n      // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n      // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n      // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n      const killedBySignal = result.signal != null;\n      const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n      const stateRead = readLineageStateRecords(loopType, lineageDir);\n      const stopPolicyViolation = findMaxIterationsPolicyViolation({\n        loopType,\n        stateRead,\n        lineage,\n        stopPolicy,\n      });\n\n      // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n      // not a success. Throw so the pool settles this item as rejected and counts it\n      // in summary.failed/all_failed, which drives the process exit code. Returning a\n      // plain object here would let the pool record any completed worker as fulfilled\n      // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n      if (timedOut || killedBySignal || exitCode !== 0) {\n        const reason = timedOut\n          ? 'timed out'\n          : killedBySignal\n            ? `killed by signal ${result.signal}`\n            : `exited with code ${exitCode}`;\n        const failure = new Error(`lineage ${lineage.label} ${reason}`);\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = timedOut;\n        failure.killedBySignal = killedBySignal;\n        failure.salvage = salvage;\n        throw failure;\n      }\n\n      if (missingArtifacts.length > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n        failure.missingArtifacts = missingArtifacts;\n        throw failure;\n      }\n\n      if (stopPolicyViolation) {\n        const failure = new Error(\n          `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = salvage;\n        failure.stopPolicyViolation = stopPolicyViolation;\n        throw failure;\n      }\n\n      // An exit-0 lineage whose salvage sweep could not recover every iteration\n      // markdown is NOT fulfilled, even when the top-level report exists. Returning\n      // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n      // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n      // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n      if (salvage && salvage.failed > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n        failure.missingArtifacts = [];\n        throw failure;\n      }\n\n      const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n      if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n        const slotWindowEndIso = new Date().toISOString();\n        try {\n          const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n            windowStart: slotWindowStartIso,\n            windowEnd: slotWindowEndIso,\n            toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n          });\n          if (timestampCheck.anomalous > 0) {\n            const timestampAnomaly = buildTimestampAnomalyPayload({\n              lineage,\n              statePath: stateRead.statePath,\n              check: timestampCheck,","lineStart":1440,"lineEnd":1939,"totalLines":2021,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784444203215,"end":1784444203222}},"metadata":{"openai":{"itemId":"fc_01d44f8e52c88243016a5c752acac48191aebe066b7cf46db4"}},"id":"prt_f7929af4e001guJibViTGJ3N92","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","messageID":"msg_f79299f33001NpRI4BbyJrY7vq"}}
