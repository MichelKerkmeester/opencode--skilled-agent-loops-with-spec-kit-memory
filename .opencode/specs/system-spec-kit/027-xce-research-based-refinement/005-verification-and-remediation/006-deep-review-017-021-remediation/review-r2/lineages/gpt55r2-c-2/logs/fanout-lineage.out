{"type":"tool_use","timestamp":1781761568088,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"grep","callID":"call_YKwazTFDRTCY3W2l2DhEmt8E","state":{"status":"completed","input":{"pattern":"memory_delete|memory_bulk_delete|embedder_set|memory_retention_sweep|confirm|dryRun","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas","include":"*.ts"},"output":"Found 27 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts:\n  Line 247:   dryRun: z.boolean().optional(),\n\n  Line 279: // Destructive delete: every mutation path requires `confirm: true`.\n\n  Line 280: // Branch 1 requires `id` + `confirm` (single-record delete).\n\n  Line 281: // Branch 2 requires `specFolder` + `confirm` (bulk folder delete).\n\n  Line 283:   id: positiveInt.optional().describe('Memory ID to delete (required unless specFolder + confirm provided for bulk)'),\n\n  Line 284:   specFolder: optionalPathString().describe('Spec folder scope for bulk delete (requires confirm: true)'),\n\n  Line 285:   confirm: z.literal(true).optional().describe('Must be true for every delete mutation'),\n\n  Line 287:   if (value.confirm !== true) {\n\n  Line 290:       path: ['confirm'],\n\n  Line 291:       message: 'confirm:true is required for every memory_delete mutation',\n\n  Line 329:   confirm: z.literal(true),\n\n  Line 337:   dryRun: z.boolean().optional(),\n\n  Line 373:   confirmed: z.boolean().optional(),\n\n  Line 408:   confirmName: z.string().min(1),\n\n  Line 456:   // { dryRun: false } to commit bounded, idempotent, created_by='auto' edges.\n\n  Line 461:     dryRun: z.boolean().optional(),\n\n  Line 577:   memory_delete: memoryDeleteSchema as unknown as ToolInputSchema,\n\n  Line 580:   memory_bulk_delete: memoryBulkDeleteSchema as unknown as ToolInputSchema,\n\n  Line 581:   memory_retention_sweep: memoryRetentionSweepSchema as unknown as ToolInputSchema,\n\n  Line 603:   embedder_set: embedderSetSchema as unknown as ToolInputSchema,\n\n  Line 625:   memory_save: ['filePath', 'force', 'dryRun', 'skipPreflight', 'asyncEmbedding', 'routeAs', 'mergeModeHint', 'plannerMode', 'targetAnchorId', 'tenantId', 'userId', 'agentId', 'sessionId', 'provenanceSource', 'provenanceActor', 'governedAt', 'retentionPolicy', 'deleteAfter'],\n\n  Line 628:   memory_health: ['reportMode', 'includeFullReport', 'limit', 'specFolder', 'autoRepair', 'confirmed', 'cleanFiles'],\n\n  Line 629:   memory_delete: ['id', 'specFolder', 'confirm'],\n\n  Line 632:   memory_bulk_delete: ['tier', 'specFolder', 'confirm', 'olderThanDays', 'skipCheckpoint'],\n\n  Line 633:   memory_retention_sweep: ['dryRun'],\n\n  Line 638:   checkpoint_delete: ['name', 'tenantId', 'userId', 'agentId', 'confirmName'],\n\n  Line 655:   embedder_set: ['name'],\n","metadata":{"matches":27,"truncated":false},"title":"memory_delete|memory_bulk_delete|embedder_set|memory_retention_sweep|confirm|dryRun","time":{"start":1781761568074,"end":1781761568087}},"metadata":{"openai":{"itemId":"fc_026e871e56cb08f3016a3386200a8c8191aa59e733636e042e"}},"id":"prt_ed943ed41001UV297v63eJNRqM","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943bfd6001k2CtSEjffh6MW2"}}
{"type":"tool_use","timestamp":1781761568159,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_KjeeyGPStxraf56TyyPxfrm8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Input Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // Centralized strict Zod validation schemas for MCP tool inputs.\n5: // Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { z, ZodError } from 'zod';\n12: \n13: import type { ZodType } from 'zod';\n14: \n15: // Feature catalog: Strict Zod schema validation\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: type ToolInput = Record<string, unknown>;\n22: type ToolInputSchema = ZodType<ToolInput>;\n23: \n24: /* ───────────────────────────────────────────────────────────────\n25:    3. HELPERS\n26: ──────────────────────────────────────────────────────────────── */\n27: \n28: export const getSchema = <T extends z.ZodRawShape>(shape: T): z.ZodObject<T> => {\n29:   const strict = process.env.SPECKIT_STRICT_SCHEMAS !== 'false';\n30:   const base = z.object(shape);\n31:   return strict ? base.strict() : base.passthrough();\n32: };\n33: \n34: /* ───────────────────────────────────────────────────────────────\n35:    4. CONSTANTS\n36: ──────────────────────────────────────────────────────────────── */\n37: \n38: // Guard against safeNumericPreprocess.pipe(z.number()) coercing \"\", null, and false to 0.\n39: // Use a safe preprocessor that only accepts actual numbers or numeric strings.\n40: const safeNumericPreprocess = z.preprocess((val) => {\n41:   if (typeof val === 'number') return val;\n42:   if (typeof val === 'string' && val.trim().length > 0) {\n43:     const parsed = Number(val);\n44:     return Number.isFinite(parsed) ? parsed : val;\n45:   }\n46:   return val;\n47: }, z.number());\n48: \n49: const intRange = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().int().min(min).max(max));\n50: const positiveInt = safeNumericPreprocess.pipe(z.number().int().positive());\n51: const positiveIntMax = (max: number) => intRange(1, max);\n52: const boundedNumber = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().min(min).max(max));\n53: const optionalStringArray = z.array(z.string()).optional();\n54: \n55: const PATH_TRAVERSAL_MESSAGE = 'Path must not contain traversal sequences';\n56: const isSafePath = (value: string): boolean => !value.includes('..') && !value.includes('\\0');\n57: const pathString = (minLength = 0) => {\n58:   let schema = z.string();\n59:   if (minLength > 0) {\n60:     schema = schema.min(minLength);\n61:   }\n62:   return schema.refine(isSafePath, { message: PATH_TRAVERSAL_MESSAGE });\n63: };\n64: const optionalPathString = (minLength = 0) => pathString(minLength).optional();\n65: \n66: /** Shared max paths constant — used by both schema and handler. */\n67: export const MAX_INGEST_PATHS = 50;\n68: export const MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS = 1;\n69: export const RESERVED_FEEDBACK_TYPE_ERROR_CODE = 'E_RESERVED_FEEDBACK_TYPE';\n70: \n71: const publicMemoryWriteTools = new Set(['memory_save', 'memory_update']);\n72: const reservedFeedbackEventTypes = new Set([\n73:   'search_shown',\n74:   'result_cited',\n75:   'query_reformulated',\n76:   'same_topic_requery',\n77:   'follow_on_tool_use',\n78: ]);\n79: const reservedFeedbackArtifactTypes = new Set([\n80:   'feedback',\n81:   'feedback_event',\n82:   'feedback_events',\n83:   'feedback-ledger',\n84:   'feedback_ledger',\n85:   'batch_learning_log',\n86:   'learned_feedback',\n87: ]);\n88: \n89: const reservedFeedbackFields = new Set([\n90:   'artifact_type',\n91:   'artifactType',\n92:   'feedback_event_type',\n93:   'feedbackEventType',\n94:   'feedbackType',\n95:   'source_kind',\n96:   'sourceKind',\n97:   'type',\n98: ]);\n99: \n100: const intentEnum = z.enum([\n101:   'add_feature',\n102:   'fix_bug',\n103:   'refactor',\n104:   'security_audit',\n105:   'understand',\n106:   'find_spec',\n107:   'find_decision',\n108: ]);\n109: \n110: const importanceTierEnum = z.enum([\n111:   'constitutional',\n112:   'critical',\n113:   'important',\n114:   'normal',\n115:   'temporary',\n116:   'deprecated',\n117: ]);\n118: \n119: const relationEnum = z.enum([\n120:   'caused',\n121:   'enabled',\n122:   'supersedes',\n123:   'contradicts',\n124:   'derived_from',\n125:   'supports',\n126: ]);\n127: \n128: const routeCategoryEnum = z.enum([\n129:   'narrative_progress',\n130:   'narrative_delivery',\n131:   'decision',\n132:   'handover_state',\n133:   'research_finding',\n134:   'task_update',\n135:   'metadata_only',\n136:   'drop',\n137: ]);\n138: \n139: const mergeModeHintEnum = z.enum([\n140:   'append-as-paragraph',\n141:   'insert-new-adr',\n142:   'append-table-row',\n143:   'update-in-place',\n144:   'append-section',\n145: ]);\n146: \n147: const plannerModeEnum = z.enum(['plan-only', 'hybrid', 'full-auto']);\n148: \n149: const skillGraphQueryTypeEnum = z.enum([\n150:   'depends_on',\n151:   'dependents',\n152:   'enhances',\n153:   'enhanced_by',\n154:   'family_members',\n155:   'conflicts',\n156:   'transitive_path',\n157:   'hub_skills',\n158:   'orphans',\n159:   'subgraph',\n160: ]);\n161: \n162: const skillFamilyEnum = z.enum(['cli', 'mcp', 'sk-code', 'deep-loop', 'sk-util', 'system']);\n163: \n164: /* ───────────────────────────────────────────────────────────────\n165:    5. SCHEMA DEFINITIONS\n166: ──────────────────────────────────────────────────────────────── */\n167: \n168: const memoryContextSchema = getSchema({\n169:   input: z.string().min(1),\n170:   mode: z.enum(['auto', 'quick', 'deep', 'focused', 'resume']).optional(),\n171:   intent: intentEnum.optional(),\n172:   specFolder: optionalPathString(),\n173:   tenantId: z.string().optional(),\n174:   userId: z.string().optional(),\n175:   agentId: z.string().optional(),\n176:   limit: positiveIntMax(100).optional(),\n177:   sessionId: z.string().optional(),\n178:   enableDedup: z.boolean().optional(),\n179:   includeContent: z.boolean().optional(),\n180:   includeTrace: z.boolean().optional(), // Forward to internal memory_search\n181:   tokenUsage: boundedNumber(0, 1).optional(),\n182:   anchors: optionalStringArray,\n183:   profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n184: });\n185: \n186: const memorySearchSchema = getSchema({\n187:   cursor: z.string().min(1).optional(),\n188:   query: z.string().min(2).max(1000).optional(),\n189:   concepts: z.array(z.string().min(1)).min(2).max(5).optional(),\n190:   specFolder: optionalPathString(),\n191:   tenantId: z.string().optional(),\n192:   userId: z.string().optional(),\n193:   agentId: z.string().optional(),\n194:   limit: positiveIntMax(100).optional(),\n195:   sessionId: z.string().optional(),\n196:   enableDedup: z.boolean().optional(),\n197:   tier: importanceTierEnum.optional(),\n198:   contextType: z.string().optional(),\n199:   useDecay: z.boolean().optional(),\n200:   includeContiguity: z.boolean().optional(),\n201:   includeConstitutional: z.boolean().optional(),\n202:   enableSessionBoost: z.boolean().optional(),\n203:   enableCausalBoost: z.boolean().optional(),\n204:   includeContent: z.boolean().optional(),\n205:   anchors: optionalStringArray,\n206:   min_quality_score: boundedNumber(0, 1).optional(),\n207:   minQualityScore: boundedNumber(0, 1).optional(),\n208:   bypassCache: z.boolean().optional(),\n209:   rerank: z.boolean().optional(),\n210:   applyLengthPenalty: z.boolean().optional(),\n211:   applyStateLimits: z.boolean().optional(),\n212:   minState: z.enum(['HOT', 'WARM', 'COLD', 'DORMANT', 'ARCHIVED']).optional(),\n213:   intent: intentEnum.optional(),\n214:   autoDetectIntent: z.boolean().optional(),\n215:   trackAccess: z.boolean().optional(),\n216:   includeArchived: z.boolean().optional(),\n217:   mode: z.enum(['auto', 'deep']).optional(),\n218:   includeTrace: z.boolean().optional(),\n219:   profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n220: });\n221: \n222: // E3: Simplified search schema — 3 params only\n223: const memoryQuickSearchSchema = getSchema({\n224:   query: z.string().min(2).max(1000),\n225:   limit: positiveIntMax(100).optional(),\n226:   specFolder: optionalPathString(),\n227:   tenantId: z.string().optional(),\n228:   userId: z.string().optional(),\n229:   agentId: z.string().optional(),\n230: });\n231: \n232: const memoryMatchTriggersSchema = getSchema({\n233:   prompt: z.string().min(1),\n234:   specFolder: optionalPathString(),\n235:   tenantId: z.string().optional(),\n236:   userId: z.string().optional(),\n237:   agentId: z.string().optional(),\n238:   limit: positiveIntMax(100).optional(),\n239:   session_id: z.string().optional(),\n240:   turnNumber: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n241:   include_cognitive: z.boolean().optional(),\n242: });\n243: \n244: const memorySaveSchema = getSchema({\n245:   filePath: pathString(1),\n246:   force: z.boolean().optional(),\n247:   dryRun: z.boolean().optional(),\n248:   skipPreflight: z.boolean().optional(),\n249:   asyncEmbedding: z.boolean().optional(),\n250:   routeAs: routeCategoryEnum.optional(),\n251:   mergeModeHint: mergeModeHintEnum.optional(),\n252:   plannerMode: plannerModeEnum.optional(),\n253:   targetAnchorId: z.string().optional(),\n254:   // Governance args — accepted by tool-schemas.ts tool definition and\n255:   // validated at runtime by scope-governance.ts.\n256:   tenantId: z.string().optional(),\n257:   userId: z.string().optional(),\n258:   agentId: z.string().optional(),\n259:   sessionId: z.string().optional(),\n260:   provenanceSource: z.string().optional(),\n\n(Showing lines 1-260 of 818. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Input Schemas\n// ───────────────────────────────────────────────────────────────\n// Centralized strict Zod validation schemas for MCP tool inputs.\n// Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { z, ZodError } from 'zod';\n\nimport type { ZodType } from 'zod';\n\n// Feature catalog: Strict Zod schema validation\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Input Schemas\n// ───────────────────────────────────────────────────────────────\n// Centralized strict Zod validation schemas for MCP tool inputs.\n// Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { z, ZodError } from 'zod';\n\nimport type { ZodType } from 'zod';\n\n// Feature catalog: Strict Zod schema validation\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ntype ToolInput = Record<string, unknown>;\ntype ToolInputSchema = ZodType<ToolInput>;\n\n/* ───────────────────────────────────────────────────────────────\n   3. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nexport const getSchema = <T extends z.ZodRawShape>(shape: T): z.ZodObject<T> => {\n  const strict = process.env.SPECKIT_STRICT_SCHEMAS !== 'false';\n  const base = z.object(shape);\n  return strict ? base.strict() : base.passthrough();\n};\n\n/* ───────────────────────────────────────────────────────────────\n   4. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\n// Guard against safeNumericPreprocess.pipe(z.number()) coercing \"\", null, and false to 0.\n// Use a safe preprocessor that only accepts actual numbers or numeric strings.\nconst safeNumericPreprocess = z.preprocess((val) => {\n  if (typeof val === 'number') return val;\n  if (typeof val === 'string' && val.trim().length > 0) {\n    const parsed = Number(val);\n    return Number.isFinite(parsed) ? parsed : val;\n  }\n  return val;\n}, z.number());\n\nconst intRange = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().int().min(min).max(max));\nconst positiveInt = safeNumericPreprocess.pipe(z.number().int().positive());\nconst positiveIntMax = (max: number) => intRange(1, max);\nconst boundedNumber = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().min(min).max(max));\nconst optionalStringArray = z.array(z.string()).optional();\n\nconst PATH_TRAVERSAL_MESSAGE = 'Path must not contain traversal sequences';\nconst isSafePath = (value: string): boolean => !value.includes('..') && !value.includes('\\0');\nconst pathString = (minLength = 0) => {\n  let schema = z.string();\n  if (minLength > 0) {\n    schema = schema.min(minLength);\n  }\n  return schema.refine(isSafePath, { message: PATH_TRAVERSAL_MESSAGE });\n};\nconst optionalPathString = (minLength = 0) => pathString(minLength).optional();\n\n/** Shared max paths constant — used by both schema and handler. */\nexport const MAX_INGEST_PATHS = 50;\nexport const MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS = 1;\nexport const RESERVED_FEEDBACK_TYPE_ERROR_CODE = 'E_RESERVED_FEEDBACK_TYPE';\n\nconst publicMemoryWriteTools = new Set(['memory_save', 'memory_update']);\nconst reservedFeedbackEventTypes = new Set([\n  'search_shown',\n  'result_cited',\n  'query_reformulated',\n  'same_topic_requery',\n  'follow_on_tool_use',\n]);\nconst reservedFeedbackArtifactTypes = new Set([\n  'feedback',\n  'feedback_event',\n  'feedback_events',\n  'feedback-ledger',\n  'feedback_ledger',\n  'batch_learning_log',\n  'learned_feedback',\n]);\n\nconst reservedFeedbackFields = new Set([\n  'artifact_type',\n  'artifactType',\n  'feedback_event_type',\n  'feedbackEventType',\n  'feedbackType',\n  'source_kind',\n  'sourceKind',\n  'type',\n]);\n\nconst intentEnum = z.enum([\n  'add_feature',\n  'fix_bug',\n  'refactor',\n  'security_audit',\n  'understand',\n  'find_spec',\n  'find_decision',\n]);\n\nconst importanceTierEnum = z.enum([\n  'constitutional',\n  'critical',\n  'important',\n  'normal',\n  'temporary',\n  'deprecated',\n]);\n\nconst relationEnum = z.enum([\n  'caused',\n  'enabled',\n  'supersedes',\n  'contradicts',\n  'derived_from',\n  'supports',\n]);\n\nconst routeCategoryEnum = z.enum([\n  'narrative_progress',\n  'narrative_delivery',\n  'decision',\n  'handover_state',\n  'research_finding',\n  'task_update',\n  'metadata_only',\n  'drop',\n]);\n\nconst mergeModeHintEnum = z.enum([\n  'append-as-paragraph',\n  'insert-new-adr',\n  'append-table-row',\n  'update-in-place',\n  'append-section',\n]);\n\nconst plannerModeEnum = z.enum(['plan-only', 'hybrid', 'full-auto']);\n\nconst skillGraphQueryTypeEnum = z.enum([\n  'depends_on',\n  'dependents',\n  'enhances',\n  'enhanced_by',\n  'family_members',\n  'conflicts',\n  'transitive_path',\n  'hub_skills',\n  'orphans',\n  'subgraph',\n]);\n\nconst skillFamilyEnum = z.enum(['cli', 'mcp', 'sk-code', 'deep-loop', 'sk-util', 'system']);\n\n/* ───────────────────────────────────────────────────────────────\n   5. SCHEMA DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nconst memoryContextSchema = getSchema({\n  input: z.string().min(1),\n  mode: z.enum(['auto', 'quick', 'deep', 'focused', 'resume']).optional(),\n  intent: intentEnum.optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  limit: positiveIntMax(100).optional(),\n  sessionId: z.string().optional(),\n  enableDedup: z.boolean().optional(),\n  includeContent: z.boolean().optional(),\n  includeTrace: z.boolean().optional(), // Forward to internal memory_search\n  tokenUsage: boundedNumber(0, 1).optional(),\n  anchors: optionalStringArray,\n  profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n});\n\nconst memorySearchSchema = getSchema({\n  cursor: z.string().min(1).optional(),\n  query: z.string().min(2).max(1000).optional(),\n  concepts: z.array(z.string().min(1)).min(2).max(5).optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  limit: positiveIntMax(100).optional(),\n  sessionId: z.string().optional(),\n  enableDedup: z.boolean().optional(),\n  tier: importanceTierEnum.optional(),\n  contextType: z.string().optional(),\n  useDecay: z.boolean().optional(),\n  includeContiguity: z.boolean().optional(),\n  includeConstitutional: z.boolean().optional(),\n  enableSessionBoost: z.boolean().optional(),\n  enableCausalBoost: z.boolean().optional(),\n  includeContent: z.boolean().optional(),\n  anchors: optionalStringArray,\n  min_quality_score: boundedNumber(0, 1).optional(),\n  minQualityScore: boundedNumber(0, 1).optional(),\n  bypassCache: z.boolean().optional(),\n  rerank: z.boolean().optional(),\n  applyLengthPenalty: z.boolean().optional(),\n  applyStateLimits: z.boolean().optional(),\n  minState: z.enum(['HOT', 'WARM', 'COLD', 'DORMANT', 'ARCHIVED']).optional(),\n  intent: intentEnum.optional(),\n  autoDetectIntent: z.boolean().optional(),\n  trackAccess: z.boolean().optional(),\n  includeArchived: z.boolean().optional(),\n  mode: z.enum(['auto', 'deep']).optional(),\n  includeTrace: z.boolean().optional(),\n  profile: z.enum(['quick', 'research', 'resume', 'debug']).optional(),\n});\n\n// E3: Simplified search schema — 3 params only\nconst memoryQuickSearchSchema = getSchema({\n  query: z.string().min(2).max(1000),\n  limit: positiveIntMax(100).optional(),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n});\n\nconst memoryMatchTriggersSchema = getSchema({\n  prompt: z.string().min(1),\n  specFolder: optionalPathString(),\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  limit: positiveIntMax(100).optional(),\n  session_id: z.string().optional(),\n  turnNumber: safeNumericPreprocess.pipe(z.number().int().min(1)).optional(),\n  include_cognitive: z.boolean().optional(),\n});\n\nconst memorySaveSchema = getSchema({\n  filePath: pathString(1),\n  force: z.boolean().optional(),\n  dryRun: z.boolean().optional(),\n  skipPreflight: z.boolean().optional(),\n  asyncEmbedding: z.boolean().optional(),\n  routeAs: routeCategoryEnum.optional(),\n  mergeModeHint: mergeModeHintEnum.optional(),\n  plannerMode: plannerModeEnum.optional(),\n  targetAnchorId: z.string().optional(),\n  // Governance args — accepted by tool-schemas.ts tool definition and\n  // validated at runtime by scope-governance.ts.\n  tenantId: z.string().optional(),\n  userId: z.string().optional(),\n  agentId: z.string().optional(),\n  sessionId: z.string().optional(),\n  provenanceSource: z.string().optional(),","lineStart":1,"lineEnd":260,"totalLines":818,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","time":{"start":1781761568143,"end":1781761568154}},"metadata":{"openai":{"itemId":"fc_026e871e56cb08f3016a3386200a988191b8075ae2ed575dca"}},"id":"prt_ed943ed70001poNRJFelpf1G0p","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943bfd6001k2CtSEjffh6MW2"}}
{"type":"tool_use","timestamp":1781761568184,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_gMdlWLX2odtbJpXnwNNJXjeQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // All MCP tool definitions (names, descriptions, input schemas).\n5: // Extracted from context-server.ts for maintainability.\n6: import {\n7:   MAX_INGEST_PATHS,\n8:   MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n9: } from './schemas/tool-input-schemas.js';\n10: \n11: /**\n12:  * Re-export schema validation helpers used by the MCP tool entry points.\n13:  */\n14: export {\n15:   ToolSchemaValidationError,\n16:   formatZodError,\n17:   getToolSchema,\n18:   validateToolArgs,\n19:   getSchema,\n20: } from './schemas/tool-input-schemas.js';\n21: \n22: // ───────────────────────────────────────────────────────────────\n23: // 1. TYPES\n24: \n25: // ───────────────────────────────────────────────────────────────\n26: /**\n27:  * Normalized definition for a single MCP tool and its JSON schema.\n28:  */\n29: export interface ToolDefinition {\n30:   name: string;\n31:   description: string;\n32:   inputSchema: Record<string, unknown>;\n33:   outputSchema?: Record<string, unknown>;\n34: }\n35: \n36: export type ToolOwnershipStability = 'stable' | 'deprecated';\n37: \n38: export interface ToolOwnershipEntry {\n39:   name: string;\n40:   owner: string;\n41:   stability: ToolOwnershipStability;\n42:   level: string;\n43:   category: string;\n44: }\n45: \n46: export interface ToolOwnershipMap {\n47:   schemaVersion: 1;\n48:   generatedFrom: 'TOOL_DEFINITIONS';\n49:   tools: ToolOwnershipEntry[];\n50: }\n51: \n52: export interface ToolOwnershipDriftReport {\n53:   ok: boolean;\n54:   missingFromCommitted: string[];\n55:   extraInCommitted: string[];\n56:   changed: Array<{\n57:     name: string;\n58:     field: keyof Omit<ToolOwnershipEntry, 'name'>;\n59:     expected: string;\n60:     actual: string;\n61:   }>;\n62:   expectedMap: ToolOwnershipMap;\n63: }\n64: \n65: const TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n66:   Orchestration: 'memory-orchestration',\n67:   Core: 'memory-core',\n68:   Discovery: 'memory-discovery',\n69:   Mutation: 'memory-mutation',\n70:   Lifecycle: 'memory-lifecycle',\n71:   Analysis: 'memory-analysis',\n72:   Maintenance: 'memory-maintenance',\n73: });\n74: \n75: function readToolContract(definition: ToolDefinition): { level: string; category: string } {\n76:   const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n77:   if (!match) {\n78:     return { level: 'unclassified', category: 'unclassified' };\n79:   }\n80:   return {\n81:     level: match[1] ?? 'unclassified',\n82:     category: match[2] ?? 'unclassified',\n83:   };\n84: }\n85: \n86: function deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n87:   const contract = readToolContract(definition);\n88:   return {\n89:     name: definition.name,\n90:     owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n91:     stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n92:     level: contract.level,\n93:     category: contract.category,\n94:   };\n95: }\n96: \n97: function normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n98:   return {\n99:     schemaVersion: 1,\n100:     generatedFrom: 'TOOL_DEFINITIONS',\n101:     tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n102:   };\n103: }\n104: \n105: function isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n106:   if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n107:   const record = value as Record<string, unknown>;\n108:   return (\n109:     typeof record.name === 'string' &&\n110:     typeof record.owner === 'string' &&\n111:     (record.stability === 'stable' || record.stability === 'deprecated') &&\n112:     typeof record.level === 'string' &&\n113:     typeof record.category === 'string'\n114:   );\n115: }\n116: \n117: function parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n118:   let parsed: unknown;\n119:   try {\n120:     parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n121:   } catch (_error: unknown) {\n122:     return null;\n123:   }\n124:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n125:   const record = parsed as Record<string, unknown>;\n126:   if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n127:   if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n128:   return normalizeToolOwnershipMap({\n129:     schemaVersion: 1,\n130:     generatedFrom: 'TOOL_DEFINITIONS',\n131:     tools: record.tools,\n132:   });\n133: }\n134: \n135: /** Derive the deterministic tool ownership map from live tool definitions. */\n136: export function deriveToolOwnershipMap(\n137:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n138: ): ToolOwnershipMap {\n139:   return normalizeToolOwnershipMap({\n140:     schemaVersion: 1,\n141:     generatedFrom: 'TOOL_DEFINITIONS',\n142:     tools: toolDefinitions.map(deriveToolOwnershipEntry),\n143:   });\n144: }\n145: \n146: /** Serialize a derived ownership map for byte-identical generated output. */\n147: export function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n148:   return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n149: }\n150: \n151: /** Compare a committed ownership map with a fresh derivation. */\n152: export function lintToolOwnershipMapDrift(\n153:   committedMap: unknown,\n154:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n155: ): ToolOwnershipDriftReport {\n156:   const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n157:   const parsed = parseToolOwnershipMap(committedMap);\n158:   if (!parsed) {\n159:     return {\n160:       ok: false,\n161:       missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n162:       extraInCommitted: [],\n163:       changed: [],\n164:       expectedMap,\n165:     };\n166:   }\n167: \n168:   const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n169:   const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n170:   const missingFromCommitted = expectedMap.tools\n171:     .filter((tool) => !actualByName.has(tool.name))\n172:     .map((tool) => tool.name);\n173:   const extraInCommitted = parsed.tools\n174:     .filter((tool) => !expectedByName.has(tool.name))\n175:     .map((tool) => tool.name);\n176:   const changed: ToolOwnershipDriftReport['changed'] = [];\n177:   const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n178: \n179:   for (const expected of expectedMap.tools) {\n180:     const actual = actualByName.get(expected.name);\n181:     if (!actual) continue;\n182:     for (const field of fields) {\n183:       if (expected[field] !== actual[field]) {\n184:         changed.push({\n185:           name: expected.name,\n186:           field,\n187:           expected: expected[field],\n188:           actual: actual[field],\n189:         });\n190:       }\n191:     }\n192:   }\n193: \n194:   return {\n195:     ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n196:     missingFromCommitted,\n197:     extraInCommitted,\n198:     changed,\n199:     expectedMap,\n200:   };\n201: }\n202: \n203: // ───────────────────────────────────────────────────────────────\n204: // 2. TOOL DEFINITIONS\n205: \n206: // ───────────────────────────────────────────────────────────────\n207: // L1 Orchestration - Unified entry point (Token Budget: 3500)\n208: const memoryContext: ToolDefinition = {\n209:   name: 'memory_context',\n210:   description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n211:   inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n212: };\n213: \n214: // L2: Core - Primary operations (Token Budget: 3500)\n215: const memorySearch: ToolDefinition = {\n216:   name: 'memory_search',\n217:   description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n218:   inputSchema: {\n219:     type: 'object',\n220:     additionalProperties: false,\n221:     'x-requiredAnyOf': [['query'], ['concepts'], ['cursor']],\n222:     properties: {\n223:       cursor: {\n224:         type: 'string',\n225:         minLength: 1,\n226:         description: 'Opaque continuation cursor returned by progressive disclosure. When provided, resolves the next page without requiring a new query.'\n227:       },\n228:       query: { type: 'string', minLength: 2, maxLength: 1000, description: 'Natural language search query' },\n229:       concepts: {\n230:         type: 'array',\n231:         items: { type: 'string', minLength: 1 },\n232:         minItems: 2,\n233:         maxItems: 5,\n234:         description: 'Multiple concepts for AND search (requires 2-5 concepts). Results must match ALL concepts.'\n235:       },\n236:       specFolder: { type: 'string', description: 'Limit search to a specific spec folder (e.g., \"011-spec-kit-memory-upgrade\")' },\n237:       tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval. When provided with scope enforcement, results are isolated to this tenant.' },\n238:       userId: { type: 'string', description: 'User boundary for governed retrieval. Filters private user-scoped spec-doc records.' },\n239:       agentId: { type: 'string', description: 'Agent boundary for governed retrieval. Filters agent-scoped spec-doc records.' },\n240:       limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n241:       sessionId: {\n242:         type: 'string',\n243:         description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n244:       },\n245:       enableDedup: {\n246:         type: 'boolean',\n247:         default: true,\n248:         description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n249:       },\n250:       tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n251:       contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n252:       useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n253:       includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n254:       includeConstitutional: {\n255:         type: 'boolean',\n256:         default: true,\n257:         description: 'Include constitutional tier rules at top of results (default: true)'\n258:       },\n259:       enableSessionBoost: {\n260:         type: 'boolean',\n261:         description: 'Enable session-based score boost from working_memory attention signals. Defaults to SPECKIT_SESSION_BOOST env flag.'\n262:       },\n263:       enableCausalBoost: {\n264:         type: 'boolean',\n265:         description: 'Enable causal-neighbor boost (2-hop traversal on causal_edges). Defaults to SPECKIT_CAUSAL_BOOST env flag.'\n266:       },\n267:       includeContent: {\n268:         type: 'boolean',\n269:         default: false,\n270:         description: 'Include full file content in results. When true, each result includes a \"content\" field with the spec-doc file contents. This embeds load logic directly in search, eliminating the need for separate load calls. When implicit feedback logging is enabled, includeContent searches also emit shadow-only result_cited events for returned spec-doc records.'\n271:       },\n272:       anchors: {\n273:         type: 'array',\n274:         items: { type: 'string' },\n275:         description: 'Specific anchor IDs to extract from content. If provided, returned content will be filtered to only these sections. Requires includeContent: true.'\n276:       },\n277:       profile: {\n278:         type: 'string',\n279:         enum: ['quick', 'research', 'resume', 'debug'],\n280:         description: 'Optional response profile formatter. Returns a reduced or mode-aware response shape when profile formatting is enabled.'\n\n(Showing lines 1-280 of 955. Use offset=281 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Normalized definition for a single MCP tool and its JSON schema.\n */\nexport interface ToolDefinition {\n  name: string;\n  description: string;\n  inputSchema: Record<string, unknown>;\n  outputSchema?: Record<string, unknown>;\n}\n\nexport type ToolOwnershipStability = 'stable' | 'deprecated';\n\nexport interface ToolOwnershipEntry {\n  name: string;\n  owner: string;\n  stability: ToolOwnershipStability;\n  level: string;\n  category: string;\n}\n\nexport interface ToolOwnershipMap {\n  schemaVersion: 1;\n  generatedFrom: 'TOOL_DEFINITIONS';\n  tools: ToolOwnershipEntry[];\n}\n\nexport interface ToolOwnershipDriftReport {\n  ok: boolean;\n  missingFromCommitted: string[];\n  extraInCommitted: string[];\n  changed: Array<{\n    name: string;\n    field: keyof Omit<ToolOwnershipEntry, 'name'>;\n    expected: string;\n    actual: string;\n  }>;\n  expectedMap: ToolOwnershipMap;\n}\n\nconst TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n  Orchestration: 'memory-orchestration',\n  Core: 'memory-core',\n  Discovery: 'memory-discovery',\n  Mutation: 'memory-mutation',\n  Lifecycle: 'memory-lifecycle',\n  Analysis: 'memory-analysis',\n  Maintenance: 'memory-maintenance',\n});\n\nfunction readToolContract(definition: ToolDefinition): { level: string; category: string } {\n  const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n  if (!match) {\n    return { level: 'unclassified', category: 'unclassified' };\n  }\n  return {\n    level: match[1] ?? 'unclassified',\n    category: match[2] ?? 'unclassified',\n  };\n}\n\nfunction deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n  const contract = readToolContract(definition);\n  return {\n    name: definition.name,\n    owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n    stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n    level: contract.level,\n    category: contract.category,\n  };\n}\n\nfunction normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n  return {\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n  };\n}\n\nfunction isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n  const record = value as Record<string, unknown>;\n  return (\n    typeof record.name === 'string' &&\n    typeof record.owner === 'string' &&\n    (record.stability === 'stable' || record.stability === 'deprecated') &&\n    typeof record.level === 'string' &&\n    typeof record.category === 'string'\n  );\n}\n\nfunction parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n  let parsed: unknown;\n  try {\n    parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n  } catch (_error: unknown) {\n    return null;\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n  const record = parsed as Record<string, unknown>;\n  if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n  if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: record.tools,\n  });\n}\n\n/** Derive the deterministic tool ownership map from live tool definitions. */\nexport function deriveToolOwnershipMap(\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipMap {\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: toolDefinitions.map(deriveToolOwnershipEntry),\n  });\n}\n\n/** Serialize a derived ownership map for byte-identical generated output. */\nexport function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n  return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n}\n\n/** Compare a committed ownership map with a fresh derivation. */\nexport function lintToolOwnershipMapDrift(\n  committedMap: unknown,\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipDriftReport {\n  const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n  const parsed = parseToolOwnershipMap(committedMap);\n  if (!parsed) {\n    return {\n      ok: false,\n      missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n      extraInCommitted: [],\n      changed: [],\n      expectedMap,\n    };\n  }\n\n  const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n  const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n  const missingFromCommitted = expectedMap.tools\n    .filter((tool) => !actualByName.has(tool.name))\n    .map((tool) => tool.name);\n  const extraInCommitted = parsed.tools\n    .filter((tool) => !expectedByName.has(tool.name))\n    .map((tool) => tool.name);\n  const changed: ToolOwnershipDriftReport['changed'] = [];\n  const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n\n  for (const expected of expectedMap.tools) {\n    const actual = actualByName.get(expected.name);\n    if (!actual) continue;\n    for (const field of fields) {\n      if (expected[field] !== actual[field]) {\n        changed.push({\n          name: expected.name,\n          field,\n          expected: expected[field],\n          actual: actual[field],\n        });\n      }\n    }\n  }\n\n  return {\n    ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n    missingFromCommitted,\n    extraInCommitted,\n    changed,\n    expectedMap,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. TOOL DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n// L1 Orchestration - Unified entry point (Token Budget: 3500)\nconst memoryContext: ToolDefinition = {\n  name: 'memory_context',\n  description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n};\n\n// L2: Core - Primary operations (Token Budget: 3500)\nconst memorySearch: ToolDefinition = {\n  name: 'memory_search',\n  description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: {\n    type: 'object',\n    additionalProperties: false,\n    'x-requiredAnyOf': [['query'], ['concepts'], ['cursor']],\n    properties: {\n      cursor: {\n        type: 'string',\n        minLength: 1,\n        description: 'Opaque continuation cursor returned by progressive disclosure. When provided, resolves the next page without requiring a new query.'\n      },\n      query: { type: 'string', minLength: 2, maxLength: 1000, description: 'Natural language search query' },\n      concepts: {\n        type: 'array',\n        items: { type: 'string', minLength: 1 },\n        minItems: 2,\n        maxItems: 5,\n        description: 'Multiple concepts for AND search (requires 2-5 concepts). Results must match ALL concepts.'\n      },\n      specFolder: { type: 'string', description: 'Limit search to a specific spec folder (e.g., \"011-spec-kit-memory-upgrade\")' },\n      tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval. When provided with scope enforcement, results are isolated to this tenant.' },\n      userId: { type: 'string', description: 'User boundary for governed retrieval. Filters private user-scoped spec-doc records.' },\n      agentId: { type: 'string', description: 'Agent boundary for governed retrieval. Filters agent-scoped spec-doc records.' },\n      limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n      sessionId: {\n        type: 'string',\n        description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n      },\n      enableDedup: {\n        type: 'boolean',\n        default: true,\n        description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n      },\n      tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n      contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n      useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n      includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n      includeConstitutional: {\n        type: 'boolean',\n        default: true,\n        description: 'Include constitutional tier rules at top of results (default: true)'\n      },\n      enableSessionBoost: {\n        type: 'boolean',\n        description: 'Enable session-based score boost from working_memory attention signals. Defaults to SPECKIT_SESSION_BOOST env flag.'\n      },\n      enableCausalBoost: {\n        type: 'boolean',\n        description: 'Enable causal-neighbor boost (2-hop traversal on causal_edges). Defaults to SPECKIT_CAUSAL_BOOST env flag.'\n      },\n      includeContent: {\n        type: 'boolean',\n        default: false,\n        description: 'Include full file content in results. When true, each result includes a \"content\" field with the spec-doc file contents. This embeds load logic directly in search, eliminating the need for separate load calls. When implicit feedback logging is enabled, includeContent searches also emit shadow-only result_cited events for returned spec-doc records.'\n      },\n      anchors: {\n        type: 'array',\n        items: { type: 'string' },\n        description: 'Specific anchor IDs to extract from content. If provided, returned content will be filtered to only these sections. Requires includeContent: true.'\n      },\n      profile: {\n        type: 'string',\n        enum: ['quick', 'research', 'resume', 'debug'],\n        description: 'Optional response profile formatter. Returns a reduced or mode-aware response shape when profile formatting is enabled.'","lineStart":1,"lineEnd":280,"totalLines":955,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1781761568171,"end":1781761568179}},"metadata":{"openai":{"itemId":"fc_026e871e56cb08f3016a3386200aa081919e213bd9d7911ce5"}},"id":"prt_ed943ed9d0016djIwkL3MeQBTk","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943bfd6001k2CtSEjffh6MW2"}}
