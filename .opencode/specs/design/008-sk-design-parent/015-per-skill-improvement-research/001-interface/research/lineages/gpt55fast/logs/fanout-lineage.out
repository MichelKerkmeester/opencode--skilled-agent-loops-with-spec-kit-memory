cenario\"\n675:         },\n676:         \"d1inter\": {\n677:           \"score\": null,\n678:           \"unscored\": \"no advisor probe (run with --advisor-mode=python)\"\n679:         },\n680:         \"d4\": {\n681:           \"score\": null,\n682:           \"unscored\": \"requires skill-on/off ablation (live mode)\"\n683:         },\n684:         \"modePrecision\": {\n685:           \"score\": null,\n686:           \"expectedMode\": null,\n687:           \"observedMode\": null,\n688:           \"advisory\": true,\n689:           \"unscored\": \"fixture carries no expected.mode\"\n690:         }\n691:       },\n692:       \"firstFailingStage\": null,\n693:       \"modeAScore\": 89,\n694:       \"applicable\": true,\n695:       \"classKind\": \"routing\",\n696:       \"expectedSurface\": null,\n697:       \"observedSurface\": \"UNKNOWN\",\n698:       \"surfaceMatch\": null,\n699:       \"traceMode\": \"live\",\n700:       \"liveEvidence\": {\n701:         \"eventCount\": 6,\n702:         \"activated\": false,\n703:         \"toolCalls\": [\n704:           \"read\"\n705:         ],\n706:         \"observedReads\": [],\n707:         \"statedRoutingParsed\": true,\n708:         \"responseHead\": \"```json\\n{\\n  \\\"surface\\\": \\\"UNKNOWN\\\",\\n  \\\"subLanguage\\\": \\\"none\\\",\\n  \\\"resources\\\": [\\n    \\\"references/design-process/design_principles.md\\\"\\n  ],\\n  \\\"assets\\\": [],\\n  \\\"agent\\\": \\\"none\\\",\\n  \\\"disambiguation\\\": false\\n}\\n```\"\n709:       }\n710:     },\n711:     {\n712:       \"scenarioId\": \"ID-004\",\n713:       \"tier\": \"live\",\n714:       \"dims\": {\n715:         \"d1intra\": {\n716:           \"score\": 0.6,\n717:           \"intentRecall\": 0,\n718:           \"resourceRecall\": 1,\n719:           \"negative\": false\n720:         },\n721:         \"d2\": {\n722:           \"score\": 1,\n723:           \"proxy\": \"router-replay-recall\",\n724:           \"note\": \"Mode A proxy; live-mode replaces with