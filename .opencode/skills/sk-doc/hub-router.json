{
  "skill": "sk-doc",
  "version": "2.0.0.0",
  "routerPolicy": {
    "defaultMode": null,
    "ambiguityDelta": 1,
    "tieBreak": ["create-quality-control", "create-skill", "create-skill-parent", "create-readme", "create-agent", "create-command", "create-feature-catalog", "create-manual-testing-playbook", "create-benchmark", "create-flowchart", "create-changelog", "create-diff"],
    "outcomes": {
      "single": "one dominant authoring/quality intent routes to one workflow mode",
      "orderedBundle": "clearly separate authoring intents route to an ordered workflow mode list",
      "defer": "unclear or contradictory intent asks for disambiguation"
    },
    "defaultResource": ["shared/references/quick-reference.md"],
    "bundleRules": [
      {
        "name": "create-then-quality",
        "whenAll": ["create-skill", "create-quality-control"],
        "outcome": "orderedBundle"
      }
    ]
  },
  "routerSignals": {
    "create-skill": { "weight": 4, "classes": ["create-skill-aliases"], "resources": ["create-skill/SKILL.md"] },
    "create-skill-parent": { "weight": 4, "classes": ["create-skill-parent-aliases"], "resources": ["create-skill/SKILL.md"] },
    "create-readme": { "weight": 4, "classes": ["create-readme-aliases"], "resources": ["create-readme/SKILL.md"] },
    "create-agent": { "weight": 4, "classes": ["create-agent-aliases"], "resources": ["create-agent/SKILL.md"] },
    "create-command": { "weight": 3, "classes": ["create-command-aliases"], "resources": ["create-command/SKILL.md"] },
    "create-feature-catalog": { "weight": 4, "classes": ["create-feature-catalog-aliases"], "resources": ["create-feature-catalog/SKILL.md"] },
    "create-manual-testing-playbook": { "weight": 4, "classes": ["create-manual-testing-playbook-aliases"], "resources": ["create-manual-testing-playbook/SKILL.md"] },
    "create-benchmark": { "weight": 3, "classes": ["create-benchmark-aliases"], "resources": ["create-benchmark/SKILL.md"] },
    "create-flowchart": { "weight": 3, "classes": ["create-flowchart-aliases"], "resources": ["create-flowchart/SKILL.md"] },
    "create-changelog": { "weight": 3, "classes": ["create-changelog-aliases"], "resources": ["create-changelog/SKILL.md"] },
    "create-diff": { "weight": 3, "classes": ["create-diff-aliases"], "resources": ["create-diff/SKILL.md"] },
