{"type":"text","timestamp":1780738297440,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"id":"prt_e9c4603d7001fgxEgtv7uKlBL2","messageID":"msg_e9c45ece8001YnjqrlxUY7Njd9","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","type":"text","text":"There are explicit pre-commit hook files under `.opencode/hooks/pre-commit` and `.opencode/scripts/git-hooks/pre-commit`; those are the right automation surface for comment-hygiene and tool-ownership-map linting.","time":{"start":1780738294743,"end":1780738297285},"metadata":{"openai":{"itemId":"msg_059763c4f6525262016a23e8f6ba4c8191ba4172c2fc089a31","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780738297449,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_oYcnTAsscp4PXVk4JaAPBCaq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/hooks/pre-commit","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/hooks/pre-commit</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Comment hygiene pre-commit gate\n3: # Blocks commits that add ephemeral-artifact pointers to code comments.\n4: # See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n5: set -euo pipefail\n6: \n7: CHECKER=\".opencode/skills/sk-code/scripts/check-comment-hygiene.sh\"\n8: REPO_ROOT=\"$(git rev-parse --show-toplevel)\"\n9: CHECKER_PATH=\"$REPO_ROOT/$CHECKER\"\n10: \n11: if [[ ! -x \"$CHECKER_PATH\" ]]; then\n12:   echo \"WARNING: comment hygiene checker not found at $CHECKER — skipping check\" >&2\n13:   exit 0\n14: fi\n15: \n16: VIOLATIONS=0\n17: while IFS= read -r file; do\n18:   full_path=\"$REPO_ROOT/$file\"\n19:   if [[ -f \"$full_path\" ]]; then\n20:     CHECKER_RC=0\n21:     \"$CHECKER_PATH\" \"$full_path\" 2>/dev/null || CHECKER_RC=$?\n22:     if [[ $CHECKER_RC -eq 1 ]]; then\n23:       VIOLATIONS=$((VIOLATIONS + 1))\n24:     fi\n25:   fi\n26: done < <(git diff --cached --name-only --diff-filter=ACM)\n27: \n28: if [[ $VIOLATIONS -gt 0 ]]; then\n29:   echo \"\"\n30:   echo \"BLOCKED: $VIOLATIONS file(s) contain ephemeral-artifact pointers in code comments.\"\n31:   echo \"See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\"\n32:   echo \"Fix: replace the pointer with the durable WHY. Escape: add '// hygiene-ok' to exempt a line.\"\n33:   exit 1\n34: fi\n\n(End of file - total 34 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Comment hygiene pre-commit gate\n# Blocks commits that add ephemeral-artifact pointers to code comments.\n# See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\nset -euo pipefail\n\nCHECKER=\".opencode/skills/sk-code/scripts/check-comment-hygiene.sh\"\nREPO_ROOT=\"$(git rev-parse --show-toplevel)\"\nCHECKER_PATH=\"$REPO_ROOT/$CHECKER\"\n\nif [[ ! -x \"$CHECKER_PATH\" ]]; then\n  echo \"WARNING: comment hygiene checker not found at $CHECKER — skipping check\" >&2\n  exit 0\nfi\n\nVIOLATIONS=0\nwhile IFS= read -r file; do\n  full_path=\"$REPO_ROOT/$file\"\n  if [[ -f \"$full_path\" ]]; then\n    CHECKER_RC=0","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/hooks/pre-commit","text":"#!/usr/bin/env bash\n# Comment hygiene pre-commit gate\n# Blocks commits that add ephemeral-artifact pointers to code comments.\n# See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\nset -euo pipefail\n\nCHECKER=\".opencode/skills/sk-code/scripts/check-comment-hygiene.sh\"\nREPO_ROOT=\"$(git rev-parse --show-toplevel)\"\nCHECKER_PATH=\"$REPO_ROOT/$CHECKER\"\n\nif [[ ! -x \"$CHECKER_PATH\" ]]; then\n  echo \"WARNING: comment hygiene checker not found at $CHECKER — skipping check\" >&2\n  exit 0\nfi\n\nVIOLATIONS=0\nwhile IFS= read -r file; do\n  full_path=\"$REPO_ROOT/$file\"\n  if [[ -f \"$full_path\" ]]; then\n    CHECKER_RC=0\n    \"$CHECKER_PATH\" \"$full_path\" 2>/dev/null || CHECKER_RC=$?\n    if [[ $CHECKER_RC -eq 1 ]]; then\n      VIOLATIONS=$((VIOLATIONS + 1))\n    fi\n  fi\ndone < <(git diff --cached --name-only --diff-filter=ACM)\n\nif [[ $VIOLATIONS -gt 0 ]]; then\n  echo \"\"\n  echo \"BLOCKED: $VIOLATIONS file(s) contain ephemeral-artifact pointers in code comments.\"\n  echo \"See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\"\n  echo \"Fix: replace the pointer with the durable WHY. Escape: add '// hygiene-ok' to exempt a line.\"\n  exit 1\nfi","lineStart":1,"lineEnd":34,"totalLines":34,"truncated":false}},"title":".opencode/hooks/pre-commit","time":{"start":1780738297427,"end":1780738297447}},"metadata":{"openai":{"itemId":"fc_059763c4f6525262016a23e8f92f608191a1f8092461786246"}},"id":"prt_e9c460e47001rQ1NJHDS2k2AYz","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c45ece8001YnjqrlxUY7Njd9"}}
{"type":"tool_use","timestamp":1780738297449,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_xyTNn1lVJ9xi3bYT1gUvSLnd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/git-hooks/pre-commit","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/git-hooks/pre-commit</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Pre-commit hook — advisory model-reference drift check.\n3: #\n4: # Runs validate-doc-model-refs.js on the working tree before each commit.\n5: # Advisory mode: prints warnings on drift but does NOT block the commit.\n6: # Bypass: SPECKIT_SKIP_DOC_MODEL_VALIDATE=1 git commit ...\n7: #\n8: # Install: bash .opencode/scripts/install-git-hooks.sh\n9: # Uninstall: rm .git/hooks/pre-commit\n10: \n11: set -u\n12: \n13: if [ \"${SPECKIT_SKIP_DOC_MODEL_VALIDATE:-0}\" = \"1\" ]; then\n14:   exit 0\n15: fi\n16: \n17: REPO_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null)\"\n18: if [ -z \"$REPO_ROOT\" ]; then\n19:   exit 0\n20: fi\n21: \n22: VALIDATOR=\"$REPO_ROOT/.opencode/skills/sk-doc/scripts/validate-doc-model-refs.js\"\n23: if [ ! -f \"$VALIDATOR\" ]; then\n24:   exit 0\n25: fi\n26: \n27: if ! command -v node >/dev/null 2>&1; then\n28:   exit 0\n29: fi\n30: \n31: # Run validator; capture exit code. Non-zero exit means drift detected.\n32: # Advisory: warn on stderr but always exit 0 so the commit proceeds.\n33: OUT=\"$(node \"$VALIDATOR\" 2>&1)\"\n34: RC=$?\n35: \n36: if [ \"$RC\" -ne 0 ]; then\n37:   echo \"\" >&2\n38:   echo \"⚠️  doc-model-refs drift detected (advisory; commit not blocked):\" >&2\n39:   echo \"$OUT\" | head -30 >&2\n40:   echo \"\" >&2\n41:   echo \"Bypass next time: SPECKIT_SKIP_DOC_MODEL_VALIDATE=1 git commit ...\" >&2\n42:   echo \"Fix: update docs to cite canonical model names from registry.ts\" >&2\n43:   echo \"\" >&2\n44: fi\n45: \n46: # --- Comment hygiene gate (blocking) ---\n47: # Blocks commits that add ephemeral-artifact pointers in code comment lines.\n48: # Bypass: SPECKIT_SKIP_COMMENT_HYGIENE=1 git commit ...\n49: # See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n50: if [ \"${SPECKIT_SKIP_COMMENT_HYGIENE:-0}\" != \"1\" ]; then\n51:   HYGIENE_HOOK=\"${REPO_ROOT}/.opencode/hooks/pre-commit\"\n52:   if [ -x \"$HYGIENE_HOOK\" ]; then\n53:     bash \"$HYGIENE_HOOK\" || exit $?\n54:   fi\n55: fi\n56: \n57: # --- Prompt-knowledge card-sync gate (blocking) ---\n58: # When a prompt-knowledge surface is staged, run the 3-layer drift guard so\n59: # table inlining, Tier-3 escalation-rule drift, registry/profile/_index gaps\n60: # (zero-hub-weight entries), or models unreachable by name cannot silently\n61: # regress across sk-prompt / sk-prompt-small-model / cli-*.\n62: # Bypass: SPECKIT_SKIP_CARD_SYNC=1 git commit ...\n63: if [ \"${SPECKIT_SKIP_CARD_SYNC:-0}\" != \"1\" ]; then\n64:   CARD_GUARD=\"${REPO_ROOT}/.opencode/skills/system-skill-advisor/mcp_server/scripts/check-prompt-quality-card-sync.sh\"\n65:   if [ -f \"$CARD_GUARD\" ] && git diff --cached --name-only --diff-filter=ACM \\\n66:        | grep -Eq '^\\.opencode/skills/(cli-[a-z-]+/(SKILL\\.md|assets/prompt_quality_card\\.md|graph-metadata\\.json)|sk-prompt/assets/cli_prompt_quality_card\\.md|sk-prompt-small-model/)'; then\n67:     if ! bash \"$CARD_GUARD\" \"$REPO_ROOT\"; then\n68:       echo \"\" >&2\n69:       echo \"BLOCKED: prompt-knowledge drift guard failed (see FAIL lines above).\" >&2\n70:       echo \"Fix: keep each fact in its one canonical home and point to it; see\" >&2\n71:       echo \"     .opencode/skills/sk-prompt-small-model/references/pattern-index.md.\" >&2\n72:       echo \"Bypass: SPECKIT_SKIP_CARD_SYNC=1 git commit ...\" >&2\n73:       exit 1\n74:     fi\n75:   fi\n76: fi\n77: \n78: exit 0\n\n(End of file - total 78 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Pre-commit hook — advisory model-reference drift check.\n#\n# Runs validate-doc-model-refs.js on the working tree before each commit.\n# Advisory mode: prints warnings on drift but does NOT block the commit.\n# Bypass: SPECKIT_SKIP_DOC_MODEL_VALIDATE=1 git commit ...\n#\n# Install: bash .opencode/scripts/install-git-hooks.sh\n# Uninstall: rm .git/hooks/pre-commit\n\nset -u\n\nif [ \"${SPECKIT_SKIP_DOC_MODEL_VALIDATE:-0}\" = \"1\" ]; then\n  exit 0\nfi\n\nREPO_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null)\"\nif [ -z \"$REPO_ROOT\" ]; then\n  exit 0\nfi","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/git-hooks/pre-commit","text":"#!/usr/bin/env bash\n# Pre-commit hook — advisory model-reference drift check.\n#\n# Runs validate-doc-model-refs.js on the working tree before each commit.\n# Advisory mode: prints warnings on drift but does NOT block the commit.\n# Bypass: SPECKIT_SKIP_DOC_MODEL_VALIDATE=1 git commit ...\n#\n# Install: bash .opencode/scripts/install-git-hooks.sh\n# Uninstall: rm .git/hooks/pre-commit\n\nset -u\n\nif [ \"${SPECKIT_SKIP_DOC_MODEL_VALIDATE:-0}\" = \"1\" ]; then\n  exit 0\nfi\n\nREPO_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null)\"\nif [ -z \"$REPO_ROOT\" ]; then\n  exit 0\nfi\n\nVALIDATOR=\"$REPO_ROOT/.opencode/skills/sk-doc/scripts/validate-doc-model-refs.js\"\nif [ ! -f \"$VALIDATOR\" ]; then\n  exit 0\nfi\n\nif ! command -v node >/dev/null 2>&1; then\n  exit 0\nfi\n\n# Run validator; capture exit code. Non-zero exit means drift detected.\n# Advisory: warn on stderr but always exit 0 so the commit proceeds.\nOUT=\"$(node \"$VALIDATOR\" 2>&1)\"\nRC=$?\n\nif [ \"$RC\" -ne 0 ]; then\n  echo \"\" >&2\n  echo \"⚠️  doc-model-refs drift detected (advisory; commit not blocked):\" >&2\n  echo \"$OUT\" | head -30 >&2\n  echo \"\" >&2\n  echo \"Bypass next time: SPECKIT_SKIP_DOC_MODEL_VALIDATE=1 git commit ...\" >&2\n  echo \"Fix: update docs to cite canonical model names from registry.ts\" >&2\n  echo \"\" >&2\nfi\n\n# --- Comment hygiene gate (blocking) ---\n# Blocks commits that add ephemeral-artifact pointers in code comment lines.\n# Bypass: SPECKIT_SKIP_COMMENT_HYGIENE=1 git commit ...\n# See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\nif [ \"${SPECKIT_SKIP_COMMENT_HYGIENE:-0}\" != \"1\" ]; then\n  HYGIENE_HOOK=\"${REPO_ROOT}/.opencode/hooks/pre-commit\"\n  if [ -x \"$HYGIENE_HOOK\" ]; then\n    bash \"$HYGIENE_HOOK\" || exit $?\n  fi\nfi\n\n# --- Prompt-knowledge card-sync gate (blocking) ---\n# When a prompt-knowledge surface is staged, run the 3-layer drift guard so\n# table inlining, Tier-3 escalation-rule drift, registry/profile/_index gaps\n# (zero-hub-weight entries), or models unreachable by name cannot silently\n# regress across sk-prompt / sk-prompt-small-model / cli-*.\n# Bypass: SPECKIT_SKIP_CARD_SYNC=1 git commit ...\nif [ \"${SPECKIT_SKIP_CARD_SYNC:-0}\" != \"1\" ]; then\n  CARD_GUARD=\"${REPO_ROOT}/.opencode/skills/system-skill-advisor/mcp_server/scripts/check-prompt-quality-card-sync.sh\"\n  if [ -f \"$CARD_GUARD\" ] && git diff --cached --name-only --diff-filter=ACM \\\n       | grep -Eq '^\\.opencode/skills/(cli-[a-z-]+/(SKILL\\.md|assets/prompt_quality_card\\.md|graph-metadata\\.json)|sk-prompt/assets/cli_prompt_quality_card\\.md|sk-prompt-small-model/)'; then\n    if ! bash \"$CARD_GUARD\" \"$REPO_ROOT\"; then\n      echo \"\" >&2\n      echo \"BLOCKED: prompt-knowledge drift guard failed (see FAIL lines above).\" >&2\n      echo \"Fix: keep each fact in its one canonical home and point to it; see\" >&2\n      echo \"     .opencode/skills/sk-prompt-small-model/references/pattern-index.md.\" >&2\n      echo \"Bypass: SPECKIT_SKIP_CARD_SYNC=1 git commit ...\" >&2\n      exit 1\n    fi\n  fi\nfi\n\nexit 0","lineStart":1,"lineEnd":78,"totalLines":78,"truncated":false}},"title":".opencode/scripts/git-hooks/pre-commit","time":{"start":1780738297432,"end":1780738297448}},"metadata":{"openai":{"itemId":"fc_059763c4f6525262016a23e8f92f788191a4672187441ac802"}},"id":"prt_e9c460e54001lmxOFSA6p4x65r","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c45ece8001YnjqrlxUY7Njd9"}}
{"type":"tool_use","timestamp":1780738297453,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_3Nt4TNMAzYWbdJr6rL97ORwx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/18--ux-hooks/D--comment-hygiene-devin-precommit.md","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/18--ux-hooks/D--comment-hygiene-devin-precommit.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"119-D -- Comment Hygiene — Devin Pre-Commit Gate\"\n3: description: \"This scenario validates comment hygiene enforcement for Devin sessions in `119-D`. Devin has no write-time hook (ADR-004). The pre-commit gate is the sole enforcement mechanism. This scenario confirms that a Devin-authored forbidden comment is blocked at commit time, and that a clean comment commits without interference.\"\n4: ---\n5: \n6: # 119-D -- Comment Hygiene — Devin Pre-Commit Gate\n7: \n8: This document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `119-D`.\n9: \n10: ---\n11: \n12: ## 1. OVERVIEW\n13: \n14: This scenario validates comment hygiene enforcement for Devin sessions in `119-D`. It focuses on confirming that the git pre-commit gate blocks a Devin-authored forbidden comment at commit time, and that a clean durable-WHY comment passes through without interference.\n15: \n16: ### Why This Matters\n17: \n18: Devin (SWE-1.6) has no write-time or post-tool-use hook (ADR-004). The pre-commit gate is the only enforcement mechanism for Devin-authored code. If the gate is not installed or is bypassed, Devin can commit forbidden comments without any interception. This scenario is the definitive proof that the mandatory floor holds for Devin. Run `119-A` first.\n19: \n20: ---\n21: \n22: ## 2. SCENARIO CONTRACT\n23: \n24: Operators run the exact prompt and command sequence for `119-D` and confirm the expected signals without contradictory evidence.\n25: \n26: - Objective: Confirm the pre-commit gate blocks a Devin-authored file with a forbidden comment, and allows a Devin-authored file with only a clean durable-WHY comment.\n27: - Real user request: `Ask Devin to add an ADR reference comment to violation.ts. Then try to commit it and see what happens.`\n28: - Prompt: `Edit /tmp/hygiene-sandbox/violation.ts. Add a comment on line 1: \"// ADR-007: This implements the lease cleanup strategy.\" Keep the existing const x = 1 line.`\n29: - Expected execution process: Devin writes the forbidden ADR comment; operator stages and commits; pre-commit gate fires and blocks; operator repeats with a clean comment prompt; gate allows the commit.\n30: - Expected signals: First commit → `BLOCKED: 1 file(s) contain ephemeral-artifact pointers`; second commit (clean WHY) → exits 0.\n31: - Desired user-visible outcome: The ADR comment never appears in `git log`. The clean comment commits successfully.\n32: - Pass/fail: PASS if first commit is blocked and second commit succeeds; FAIL if the ADR comment commits without interception.\n33: \n34: ---\n35: \n36: ## 3. TEST EXECUTION\n37: \n38: ### Recommended Orchestration Process\n39: \n40: 1. Restate the user request: ask Devin to add an ADR comment, then observe commit behavior.\n41: 2. Confirm pre-commit gate is installed before dispatching Devin.\n42: 3. Execute Devin dispatch with the violation prompt and record the written file.\n43: 4. Attempt commit and confirm gate fires; then repeat with clean prompt and confirm commit passes.\n44: 5. Return a verdict based on `git log` contents.\n45: \n46: | Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n47: |---|---|---|---|---|---|---|---|---|\n48: | 119-D | Devin pre-commit gate | Verify pre-commit blocks Devin-authored forbidden comment; clean comment passes | `Edit /tmp/hygiene-sandbox/violation.ts. Add a comment on line 1: \"// ADR-007: This implements the lease cleanup strategy.\" Keep the existing const x = 1 line.` | 1. `ls -la .git/hooks/pre-commit && grep HYGIENE_HOOK .opencode/scripts/git-hooks/pre-commit` -> 2. `cat > /tmp/devin-119D-violation.md <<'EOF'\\nEdit /tmp/hygiene-sandbox/violation.ts. Add comment on line 1: \"// ADR-007: This implements the lease cleanup strategy.\" Keep: const x = 1;\\nEOF` -> 3. `devin --prompt-file /tmp/devin-119D-violation.md --model swe-1.6 --permission-mode auto 2>&1 \\| tee /tmp/devin-119D.log` -> 4. `cat /tmp/hygiene-sandbox/violation.ts` -> 5. `git add /tmp/hygiene-sandbox/violation.ts && git commit -m \"test-119D-violation\" 2>&1; echo \"Commit1:$?\"` -> 6. `git status && git log --oneline -3` -> 7. (negative) `devin \"Edit /tmp/hygiene-sandbox/violation.ts line 1: // Runs unconditionally — partial shutdown cannot orphan leases. Keep const x=1.\" --model swe-1.6 --permission-mode auto 2>&1` -> 8. `git add /tmp/hygiene-sandbox/violation.ts && git commit -m \"test-119D-clean\" 2>&1; echo \"Commit2:$?\"` | Step 1: pre-commit linked + HYGIENE_HOOK present; Step 4: ADR-007 comment present; Step 5: `BLOCKED:` message + Commit1:1; Step 6: ADR comment not in `git log`; Step 8: Commit2:0 | `/tmp/devin-119D.log`; `cat violation.ts`; `git commit` output for both attempts; `git log --oneline -3` | PASS if first commit exits 1 with BLOCKED message and ADR comment does not appear in `git log`; second commit exits 0; FAIL if ADR comment commits unintercepted | If gate not blocking: run `bash .opencode/hooks/install-hooks.sh`; if `SPECKIT_SKIP_COMMENT_HYGIENE=1` is set: unset it; if Devin auth fails: run `devin auth status` |\n49: \n50: ### Optional Supplemental Checks\n51: \n52: **Devin self-correction check**: if Devin writes a clean comment despite the prompt asking for an ADR reference, the AGENTS.md rule was in Devin's context (from the project file). Note this as a positive outcome in the evidence.\n53: \n54: ---\n55: \n56: ## 4. SOURCE FILES\n57: \n58: ### Playbook Sources\n59: \n60: | File | Role |\n61: |---|---|\n62: | `manual_testing_playbook.md` | Root directory page and scenario summary |\n63: | `../../../../specs/skilled-agent-orchestration/119-comment-ref-hygiene/002-active-enforcement-layer/decision-record.md` | ADR-004 — documents the Devin write-time hook gap |\n64: \n65: ### Implementation And Test Anchors\n66: \n67: | File | Role |\n68: |---|---|\n69: | `.opencode/hooks/pre-commit` | Primary enforcement anchor — blocking gate for all runtimes |\n70: | `.opencode/scripts/git-hooks/pre-commit` | Symlink target — integrates hygiene gate |\n71: | `.opencode/skills/sk-code/scripts/check-comment-hygiene.sh` | Shared checker called by the pre-commit gate |\n72: \n73: ---\n74: \n75: ## 5. SOURCE METADATA\n76: \n77: - Group: UX Hooks\n78: - Playbook ID: 119-D\n79: - Canonical root source: `manual_testing_playbook.md`\n80: - Feature file path: `18--ux-hooks/D--comment-hygiene-devin-precommit.md`\n81: - audited_post_018: true\n\n(End of file - total 81 lines)\n</content>","metadata":{"preview":"---\ntitle: \"119-D -- Comment Hygiene — Devin Pre-Commit Gate\"\ndescription: \"This scenario validates comment hygiene enforcement for Devin sessions in `119-D`. Devin has no write-time hook (ADR-004). The pre-commit gate is the sole enforcement mechanism. This scenario confirms that a Devin-authored forbidden comment is blocked at commit time, and that a clean comment commits without interference.\"\n---\n\n# 119-D -- Comment Hygiene — Devin Pre-Commit Gate\n\nThis document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `119-D`.\n\n---\n\n## 1. OVERVIEW\n\nThis scenario validates comment hygiene enforcement for Devin sessions in `119-D`. It focuses on confirming that the git pre-commit gate blocks a Devin-authored forbidden comment at commit time, and that a clean durable-WHY comment passes through without interference.\n\n### Why This Matters\n\nDevin (SWE-1.6) has no write-time or post-tool-use hook (ADR-004). The pre-commit gate is the only enforcement mechanism for Devin-authored code. If the gate is not installed or is bypassed, Devin can commit forbidden comments without any interception. This scenario is the definitive proof that the mandatory floor holds for Devin. Run `119-A` first.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/manual_testing_playbook/18--ux-hooks/D--comment-hygiene-devin-precommit.md","text":"---\ntitle: \"119-D -- Comment Hygiene — Devin Pre-Commit Gate\"\ndescription: \"This scenario validates comment hygiene enforcement for Devin sessions in `119-D`. Devin has no write-time hook (ADR-004). The pre-commit gate is the sole enforcement mechanism. This scenario confirms that a Devin-authored forbidden comment is blocked at commit time, and that a clean comment commits without interference.\"\n---\n\n# 119-D -- Comment Hygiene — Devin Pre-Commit Gate\n\nThis document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `119-D`.\n\n---\n\n## 1. OVERVIEW\n\nThis scenario validates comment hygiene enforcement for Devin sessions in `119-D`. It focuses on confirming that the git pre-commit gate blocks a Devin-authored forbidden comment at commit time, and that a clean durable-WHY comment passes through without interference.\n\n### Why This Matters\n\nDevin (SWE-1.6) has no write-time or post-tool-use hook (ADR-004). The pre-commit gate is the only enforcement mechanism for Devin-authored code. If the gate is not installed or is bypassed, Devin can commit forbidden comments without any interception. This scenario is the definitive proof that the mandatory floor holds for Devin. Run `119-A` first.\n\n---\n\n## 2. SCENARIO CONTRACT\n\nOperators run the exact prompt and command sequence for `119-D` and confirm the expected signals without contradictory evidence.\n\n- Objective: Confirm the pre-commit gate blocks a Devin-authored file with a forbidden comment, and allows a Devin-authored file with only a clean durable-WHY comment.\n- Real user request: `Ask Devin to add an ADR reference comment to violation.ts. Then try to commit it and see what happens.`\n- Prompt: `Edit /tmp/hygiene-sandbox/violation.ts. Add a comment on line 1: \"// ADR-007: This implements the lease cleanup strategy.\" Keep the existing const x = 1 line.`\n- Expected execution process: Devin writes the forbidden ADR comment; operator stages and commits; pre-commit gate fires and blocks; operator repeats with a clean comment prompt; gate allows the commit.\n- Expected signals: First commit → `BLOCKED: 1 file(s) contain ephemeral-artifact pointers`; second commit (clean WHY) → exits 0.\n- Desired user-visible outcome: The ADR comment never appears in `git log`. The clean comment commits successfully.\n- Pass/fail: PASS if first commit is blocked and second commit succeeds; FAIL if the ADR comment commits without interception.\n\n---\n\n## 3. TEST EXECUTION\n\n### Recommended Orchestration Process\n\n1. Restate the user request: ask Devin to add an ADR comment, then observe commit behavior.\n2. Confirm pre-commit gate is installed before dispatching Devin.\n3. Execute Devin dispatch with the violation prompt and record the written file.\n4. Attempt commit and confirm gate fires; then repeat with clean prompt and confirm commit passes.\n5. Return a verdict based on `git log` contents.\n\n| Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n|---|---|---|---|---|---|---|---|---|\n| 119-D | Devin pre-commit gate | Verify pre-commit blocks Devin-authored forbidden comment; clean comment passes | `Edit /tmp/hygiene-sandbox/violation.ts. Add a comment on line 1: \"// ADR-007: This implements the lease cleanup strategy.\" Keep the existing const x = 1 line.` | 1. `ls -la .git/hooks/pre-commit && grep HYGIENE_HOOK .opencode/scripts/git-hooks/pre-commit` -> 2. `cat > /tmp/devin-119D-violation.md <<'EOF'\\nEdit /tmp/hygiene-sandbox/violation.ts. Add comment on line 1: \"// ADR-007: This implements the lease cleanup strategy.\" Keep: const x = 1;\\nEOF` -> 3. `devin --prompt-file /tmp/devin-119D-violation.md --model swe-1.6 --permission-mode auto 2>&1 \\| tee /tmp/devin-119D.log` -> 4. `cat /tmp/hygiene-sandbox/violation.ts` -> 5. `git add /tmp/hygiene-sandbox/violation.ts && git commit -m \"test-119D-violation\" 2>&1; echo \"Commit1:$?\"` -> 6. `git status && git log --oneline -3` -> 7. (negative) `devin \"Edit /tmp/hygiene-sandbox/violation.ts line 1: // Runs unconditionally — partial shutdown cannot orphan leases. Keep const x=1.\" --model swe-1.6 --permission-mode auto 2>&1` -> 8. `git add /tmp/hygiene-sandbox/violation.ts && git commit -m \"test-119D-clean\" 2>&1; echo \"Commit2:$?\"` | Step 1: pre-commit linked + HYGIENE_HOOK present; Step 4: ADR-007 comment present; Step 5: `BLOCKED:` message + Commit1:1; Step 6: ADR comment not in `git log`; Step 8: Commit2:0 | `/tmp/devin-119D.log`; `cat violation.ts`; `git commit` output for both attempts; `git log --oneline -3` | PASS if first commit exits 1 with BLOCKED message and ADR comment does not appear in `git log`; second commit exits 0; FAIL if ADR comment commits unintercepted | If gate not blocking: run `bash .opencode/hooks/install-hooks.sh`; if `SPECKIT_SKIP_COMMENT_HYGIENE=1` is set: unset it; if Devin auth fails: run `devin auth status` |\n\n### Optional Supplemental Checks\n\n**Devin self-correction check**: if Devin writes a clean comment despite the prompt asking for an ADR reference, the AGENTS.md rule was in Devin's context (from the project file). Note this as a positive outcome in the evidence.\n\n---\n\n## 4. SOURCE FILES\n\n### Playbook Sources\n\n| File | Role |\n|---|---|\n| `manual_testing_playbook.md` | Root directory page and scenario summary |\n| `../../../../specs/skilled-agent-orchestration/119-comment-ref-hygiene/002-active-enforcement-layer/decision-record.md` | ADR-004 — documents the Devin write-time hook gap |\n\n### Implementation And Test Anchors\n\n| File | Role |\n|---|---|\n| `.opencode/hooks/pre-commit` | Primary enforcement anchor — blocking gate for all runtimes |\n| `.opencode/scripts/git-hooks/pre-commit` | Symlink target — integrates hygiene gate |\n| `.opencode/skills/sk-code/scripts/check-comment-hygiene.sh` | Shared checker called by the pre-commit gate |\n\n---\n\n## 5. SOURCE METADATA\n\n- Group: UX Hooks\n- Playbook ID: 119-D\n- Canonical root source: `manual_testing_playbook.md`\n- Feature file path: `18--ux-hooks/D--comment-hygiene-devin-precommit.md`\n- audited_post_018: true","lineStart":1,"lineEnd":81,"totalLines":81,"truncated":false}},"title":".opencode/skills/system-spec-kit/manual_testing_playbook/18--ux-hooks/D--comment-hygiene-devin-precommit.md","time":{"start":1780738297437,"end":1780738297451}},"metadata":{"openai":{"itemId":"fc_059763c4f6525262016a23e8f92f8c8191bc350ee1c6f8e64f"}},"id":"prt_e9c460e5a00128eygh2OGMIb9z","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c45ece8001YnjqrlxUY7Njd9"}}
{"type":"step_finish","timestamp":1780738297848,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"id":"prt_e9c460ff5001vXH3DhThdF4XMW","reason":"tool-calls","snapshot":"423be1650d3726956076d02838dc951fdf0c8617","messageID":"msg_e9c45ece8001YnjqrlxUY7Njd9","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","type":"step-finish","tokens":{"total":179270,"input":8018,"output":234,"reasoning":10,"cache":{"write":0,"read":171008}},"cost":0}}
{"type":"step_start","timestamp":1780738299912,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"id":"prt_e9c461804001aTas34XNUEOjjn","messageID":"msg_e9c4611300017LtNjsCPUX02d3","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","snapshot":"451451923507027d5d5309d8739e3a2b246a554e","type":"step-start"}}
{"type":"text","timestamp":1780738372527,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"id":"prt_e9c462ca9001NcQqfcS4C5WD4z","messageID":"msg_e9c4611300017LtNjsCPUX02d3","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","type":"text","text":"## Commands impact\n- `/memory:save` surfaces P1 idempotency receipts, `source_kind`, advisory near-duplicate, automated-mutation audit, and 008 feedback capture. Change: derive `source_kind` from caller/path/provenance fields already present in `memory_save` args, reject automated overwrite of manual/constitutional fields, wrap `save` and `atomic-save` with receipt replay, and append feedback/audit metadata into the existing response envelope. Automatic trigger: every `memory_save` or canonical save path, including `generate-context.js`; current contract already routes save context through canonical docs and `generate-context.js` at `.opencode/commands/memory/save.md:57-80`, while handler args already accept provenance fields at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:2986-3005`. Zero-friction UX: retries return the original success result with an optional `receiptReplayed: true`; duplicates remain non-blocking advisories, not prompts.\n- `/memory:save` should keep near-duplicate advisory-only behavior aligned with existing PE/advisory fields. Automatic trigger: save-time embedding/dedup check during `memory_save`; existing response builder already emits PE actions, related IDs, and assistive recommendations at `.opencode/skills/system-spec-kit/mcp_server/handlers/save/response-builder.ts:377-393`. Zero-friction UX: show a warning/hint only when helpful; never require a review queue or LLM judge.\n- `/memory:search` surfaces P3 stale-exclusion audit and 008 feedback-event capture. Change: default retrieval must audit whether deprecated/stale-but-relevant records are silently hard-excluded, while existing implicit feedback events stay shadow-only. Automatic trigger: every default `memory_search` call; tool schema already documents search feedback events at `.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts:48-103`, and the handler logs `search_shown`, query-flow, and `result_cited` events at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts:1529-1598`. Zero-friction UX: no flag; if exclusion risk is detected, add a compact `hints[]` note and `/doctor memory` follow-up.\n- `/memory:manage` surfaces automated-mutation audit, tombstone/retention checks, and lifecycle visibility. Change: add audit/receipt counters to stats/health, and make retention/tombstone checks reportable from existing management modes. Automatic trigger: management lifecycle commands already cover stats, scan, cleanup, retention, bulk delete, validation, checkpoint, and ingest at `.opencode/commands/memory/manage.md:80-104`; retention sweep already reports ledger status at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts:36-68`. Zero-friction UX: default dashboard includes audit health; destructive cleanup remains explicit, but audit visibility is automatic.\n- `/memory:learn` surfaces constitutional immunity. Change: learned constitutional rules must be immune from feedback demotion/archive and from automated overwrite. Automatic trigger: any `importanceTier: constitutional` row or constitutional file path; `/memory:learn` defines constitutional as always-surface/no-decay at `.opencode/commands/memory/learn.md:43-65`, and `memory_save` already downgrades invalid constitutional paths with governance audit at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:422-442`. Zero-friction UX: users keep using `/memory:learn`; immunity is enforced under the hood.\n- `/speckit:plan`, `/speckit:complete`, `/speckit:implement`, and `/speckit:resume` surface `source_kind` for continuity saves. Change: all generated continuity writes should be tagged `source_kind=system|agent`, preserving user/manual fields. Automatic trigger: command workflows that call memory context/save or persist config, such as plan auto setup at `.opencode/commands/speckit/plan.md:44-56`, complete prior-work loading at `.opencode/commands/speckit/complete.md:141-145`, implement setup at `.opencode/commands/speckit/implement.md:157-160`, and resume canonical recovery at `.opencode/commands/speckit/resume.md:133-147`. Zero-friction UX: no new option; provenance follows the command route.\n- `/doctor memory` surfaces P3 stale-exclusion, idempotency receipt health, source-kind overwrite violations, audit gaps, and tombstone/retention health. Change: extend read-only diagnostics, not a new mutation route. Automatic trigger: `/doctor memory` already diagnoses memory drift and recommends action without DB writes at `.opencode/commands/doctor/speckit.md:42-64` and `.opencode/commands/doctor/assets/doctor_memory.yaml:21-43`. Zero-friction UX: one existing doctor target reports all memory-hardening health.\n- `/doctor skill-budget` or a sibling read-only doctor audit surfaces P2 MCP tool-ownership map. Change: lint tool schema ownership, stability notes, deprecation discipline, and command/agent descriptions together. Automatic trigger: pre-commit for staged tool/command/agent changes and `/doctor skill-budget` for manual health; route metadata already includes mutation class and trigger phrases at `.opencode/commands/doctor/_routes.yaml:9-17`, while skill-budget audits command/agent/skill descriptions read-only at `.opencode/commands/doctor/assets/doctor_skill-budget.yaml:21-29`. Zero-friction UX: no new flag; failed ownership metadata appears as a doctor/pre-commit diagnostic.\n\n## Agents impact\n- `@context` is read-only and should expose stale-exclusion/audit warnings, never mutate memory. Automatic trigger: any exploration or prior-work recovery routed through `@context`; the agent is explicitly read-only and continuity-first at `.opencode/agents/context.md:25-29`, with memory tools only after canonical docs at `.opencode/agents/context.md:160-172`. Zero-friction UX: Context Packages include a “memory caveat” only when the search response/doctor signal reports stale-exclusion or provenance risk.\n- `@orchestrate` should route continuity saves through `/memory:save` and preserve source ownership in task packages. Automatic trigger: session ending, stopping, or resume workflows; orchestrator already routes continuity through `/memory:save` at `.opencode/agents/orchestrate.md:378-387` and `.opencode/agents/orchestrate.md:618-622`. Zero-friction UX: orchestrator does not ask about source kind; it passes caller identity and lets the save handler enforce manual-field protection.\n- `@markdown` is the write-capable spec-doc/documentation agent most likely to create system/agent-authored continuity. Automatic trigger: scoped markdown/spec-doc task with memory applicability; its tools table already limits memory to command-authorized spec context at `.opencode/agents/markdown.md:150-163`, and hook-injected active spec folder must be verified before writing at `.opencode/agents/markdown.md:256-260`. Zero-friction UX: emitted BINDING lines plus provenance tagging provide auditability without extra operator steps.\n\n## Hooks / automation surfaces\n- P1 idempotency receipts -> automatic trigger: `memory_save`, `memory_update`, `atomic-save`, scan, delete, and causal mutation handlers after DB transaction -> surface: shared mutation hook and MCP response envelope. Existing hook fanout is centralized in `.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts:21-126`; save responses already attach `postMutationHooks` at `.opencode/skills/system-spec-kit/mcp_server/handlers/save/response-builder.ts:628-675` and `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:3669-3725`. Zero-friction UX: identical retry replays prior result; only non-identical collision emits an actionable warning.\n- `source_kind` provenance + auto-cannot-overwrite-manual -> automatic trigger: every save/index/enrichment/promoter write -> surface: save handler validation, mutation ledger, governance audit, and `postMutationHooks`. Existing source classification is implicit via template/manual fallback at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:345-350` and `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:523-533`; governance provenance fields are already accepted at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:3079-3108`. Zero-friction UX: automated writes silently merge safe fields and refuse protected overwrites with a typed response.\n- Advisory near-duplicate -> automatic trigger: save-time embedding/dedup/reconsolidation when embeddings exist -> surface: `assistiveRecommendation`, PE metadata, and hints. Existing transaction/dedup path is in `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:2510-2532`. Zero-friction UX: advisory shown inline, no blocking review flow.\n- Automated-mutation audit -> automatic trigger: any non-human mutation path, including save, retention, delete, scan, causal link/unlink, enrichment, and edge promotion -> surface: mutation ledger/governance audit plus `/memory:manage` and `/doctor memory`. Existing save ledger append is at `.opencode/skills/system-spec-kit/mcp_server/handlers/save/response-builder.ts:330-350`; retention sweep already reports ledger status at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts:42-67`. Zero-friction UX: audit rows are append-only and inspected via existing dashboards.\n- First-timestamp tombstone + active/purgeable split -> automatic trigger: `memory_delete`, `memory_bulk_delete`, and retention sweep -> surface: `/memory:manage retention-sweep`, `/doctor memory`, and DB health. Existing retention sweep response distinguishes dry-run, candidates, deleted IDs, and ledger state at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts:36-68`. Zero-friction UX: repeated deletes do not extend retention; operator only sees a health summary.\n- Natural-key edge promotion + provenance-skip-manual -> automatic trigger: post-insert enrichment and metadata-edge promoter after save -> surface: background enrichment status and mutation audit. Existing post-insert enrichment is automatically scheduled or run after save at `.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:2684-2704`. Zero-friction UX: generated edges appear once; manual links win without asking.\n- 008 event-capture/diagnostics only -> automatic trigger: `memory_search`, include-content retrieval, query reformulation, same-topic requery, and follow-on tool use -> surface: `feedback_events`, query-flow tracker, and optional diagnostics. Feedback ledger is shadow-only by design at `.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts:1-13`; event types are fixed at `.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts:25-45`; follow-on tool use is captured after dispatch at `.opencode/skills/system-spec-kit/mcp_server/context-server.ts:1153-1164`. Zero-friction UX: users search normally; diagnostics accumulate without changing ranking.\n- Reserved feedback types -> automatic trigger: server-side feedback logging only, never public memory-write input -> surface: feedback ledger schema and denylist. The current schema restricts types to five server-known values at `.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts:115-127`. Zero-friction UX: agents cannot forge learning signals through `/memory:save`.\n- Symmetric damping + constitutional immunity -> automatic trigger: any future feedback reducer or batch learner reading `feedback_events` -> surface: reducer guard and `/memory:learn` constitutional tier. The current feedback ledger says no ranking side effects at `.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts:161-170`; constitutional memories are always-surfaced through hooks at `.opencode/skills/system-spec-kit/mcp_server/hooks/memory-surface.ts:175-215`. Zero-friction UX: feedback can inform diagnostics, but protected memories are never demoted.\n- P3 stale-exclusion search audit -> automatic trigger: default search, startup freshness warning, and `/doctor memory` drift analysis -> surface: search envelope hints, memory health, doctor report. Startup hooks already inject memory/code-graph state at `.opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-prime.ts:180-220`; memory doctor already classifies staleness signals at `.opencode/commands/doctor/assets/doctor_memory.yaml:113-135`. Zero-friction UX: no `--include-stale`; risky exclusions are surfaced as warnings and doctor evidence.\n- P2 MCP tool-ownership map -> automatic trigger: staged changes touching `tool-schemas.ts`, command files, agent files, or doctor routes -> surface: pre-commit plus `/doctor skill-budget`. Tool definitions are normalized in `.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts:27-34`; pre-commit already chains advisory and blocking gates at `.opencode/scripts/git-hooks/pre-commit:31-78`. Zero-friction UX: ownership drift is caught at commit/doctor time, not by asking the operator to run a custom audit.\n- Startup and prompt hooks -> automatic trigger: session start, prompt submit, compaction, and first tool dispatch -> surface: startup brief, skill advisor brief, auto-surfaced memory hints, and response metadata. Hook architecture and entrypoints are documented at `.opencode/skills/system-spec-kit/mcp_server/hooks/README.md:16-25` and `.opencode/skills/system-spec-kit/mcp_server/hooks/README.md:131-142`; Skill Advisor prompt hooks fail open and avoid raw prompt persistence at `.opencode/skills/system-spec-kit/references/hooks/skill_advisor_hook.md:22-39`. Zero-friction UX: context, routing, and health warnings appear without command flags.\n\n## UX/automation notes\n- The integration should prefer hidden defaults over flags: receipts on all retryable writes, source-kind inferred from command/agent/tool caller, feedback logged server-side, stale-exclusion audited in default search, and ownership linting in pre-commit/doctor.\n- Manual commands remain escape hatches and dashboards, not primary workflows: `/memory:manage`, `/doctor memory`, and `/doctor skill-budget` should explain what automation observed rather than ask users to trigger the observation.\n- Response envelopes are the lowest-friction UX surface: existing `hints`, `meta.autoSurface`, and `postMutationHooks` fields can carry receipt replay, stale-exclusion warnings, audit-health summaries, and auto-surface counts without changing command syntax. See `.opencode/skills/system-spec-kit/mcp_server/hooks/response-hints.ts:86-128` and `.opencode/skills/system-spec-kit/mcp_server/hooks/mutation-feedback.ts:6-58`.\n- Avoid new public feedback-write tools. Feedback should be captured from search/use behavior only; active mutation reducers remain deferred until diagnostics prove ledger quality.\n- Pre-commit is appropriate for static drift only. Runtime correctness belongs in on-write hooks, startup hooks, and `/doctor`; pre-commit already blocks comment-hygiene issues at `.opencode/hooks/pre-commit:16-34` and can add ownership-map drift without becoming a runtime safety substitute.\n\nDELTA_JSON: {\"iteration\":\"003\",\"focus\":\"impact on commands + agents + hooks\",\"findingsCount\":28,\"newInfoRatio\":0.86,\"impacts\":[\"/memory:save -> source_kind + idempotency + feedback capture\",\"/memory:search -> stale-exclusion audit + feedback events\",\"/memory:manage -> audit + retention/tombstone visibility\",\"/memory:learn -> constitutional immunity\",\"/speckit:* -> continuity source_kind\",\"/doctor memory -> receipts/provenance/audit/stale diagnostics\",\"/doctor skill-budget -> MCP tool-ownership lint\",\"@context -> read-only stale/audit surfacing\",\"@orchestrate -> continuity save provenance\",\"@markdown -> spec-doc source_kind\",\"mutation-hooks -> post-write receipts/audit/cache invalidation\",\"startup/prompt/pre-commit hooks -> invisible automation\"],\"sources\":[\".opencode/specs/system-spec-kit/027-xce-research-based-refinement/research/008-caura-memclaw-fleet-memory-teachings/sub-packet-proposals.md\",\".opencode/commands/memory/save.md\",\".opencode/commands/memory/manage.md\",\".opencode/commands/memory/search.md\",\".opencode/commands/memory/learn.md\",\".opencode/commands/speckit/plan.md\",\".opencode/commands/speckit/implement.md\",\".opencode/commands/speckit/complete.md\",\".opencode/commands/speckit/resume.md\",\".opencode/commands/doctor/speckit.md\",\".opencode/commands/doctor/_routes.yaml\",\".opencode/commands/doctor/assets/doctor_memory.yaml\",\".opencode/agents/context.md\",\".opencode/agents/orchestrate.md\",\".opencode/agents/markdown.md\",\".opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts\",\".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts\",\".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts\",\".opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts\",\".opencode/skills/system-spec-kit/mcp_server/hooks/README.md\",\".opencode/skills/system-spec-kit/mcp_server/hooks/memory-surface.ts\",\".opencode/skills/system-spec-kit/references/hooks/skill_advisor_hook.md\",\".opencode/scripts/git-hooks/pre-commit\",\".opencode/hooks/pre-commit\"]}","time":{"start":1780738305193,"end":1780738372523},"metadata":{"openai":{"itemId":"msg_00d23fb0398c6244016a23e9012df48191868a1055376e22c4","phase":"final_answer"}}}}
