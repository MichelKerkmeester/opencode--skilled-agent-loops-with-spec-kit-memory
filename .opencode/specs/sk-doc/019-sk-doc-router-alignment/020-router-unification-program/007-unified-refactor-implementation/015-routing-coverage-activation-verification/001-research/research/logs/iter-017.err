   542	      // oracle gate, so parse it only when typed gold is present — a scenario
   543	      // with no typed gold stays byte-identical to before this field existed.
   544	      const expectedWorkflowMode = expectedLeafResources
   545	        ? parseFrontmatterScalar(block, 'expected_workflow_mode')
   546	        : undefined;
   547	      const category = path.basename(cur);
   548	      const prompt = parsePromptBlock(text);
   549	      // Explicit per-scenario kind (skill-agnostic) wins over the fallback
   550	      // heuristics; absent for every current fixture, so classification stays
   551	      // driven by category/intent signals until a scenario opts in.
   552	      const declaredKind = parseFrontmatterScalar(block, 'scenario_kind') || parseFrontmatterScalar(block, 'kind');
   553	      const id = idM ? idM[1] : e.name.replace(/\.md$/, '');
   554	      const goldParseErrors = [intentGold.parseError, resourceGold.parseError].filter(Boolean);
   555	      for (const err of goldParseErrors) warnings.push(`${id}: gold-parse-failure — ${err}`);
   556	      const parseWarnings = [
   557	        ...(prompt ? [] : ['missing-exact-prompt']),
   558	        ...goldParseErrors.map((err) => `gold-parse-failure: ${err}`),
   559	      ];
   560	      out.push({
   561	        scenarioId: id,
   562	        category,
   563	        prompt: prompt || null,
   564	        stage,
   565	        classKind: classifyKind(id, category, null, intentGold.intent || '', declaredKind),
   566	        expectedSurface: null,
   567	        expectedSubLanguage: null,
   568	        expectedIntent: intentGold.intent,
   569	        expectedIntents: intentGold.intents,
   570	        expectedResources: resourceGold.resources,
   571	        // Route-gold presence flags: `expected_resources: []` is a real
   572	        // "assembles nothing" assertion, distinguishable from an absent key.
   573	        hasIntentGold: intentGold.present,
   574	        hasResourceGold: resourceGold.present,
   575	        goldParseError: goldParseErrors.length ? goldParseErrors.join('; ') : null,
   576	        expectedAssets: [],
   577	        expectedRankBelowSkillIds,
   578	        // Typed leaf-resource gold rides on its own field so the taxonomy scorer
   579	        // engages only for a scenario that actually declares it; the flat-string
   580	        // `expectedResources` lane above is unaffected either way.
   581	        ...(expectedLeafResources ? { expected_leaf_resources: expectedLeafResources } : {}),
   582	        ...(fullInventoryIntent !== undefined ? { full_inventory_intent: fullInventoryIntent } : {}),
   583	        expected: (expectedRankBelowSkillIds.length || expectedWorkflowMode)
   584	          ? {
   585	            ...(expectedRankBelowSkillIds.length ? { rankBelowSkillIds: expectedRankBelowSkillIds } : {}),
   586	            ...(expectedWorkflowMode ? { workflowMode: expectedWorkflowMode } : {}),
   587	          }
   588	          : undefined,
   589	        passCriteria: null,
   590	        critical: false,
   591	        // A stage:negative fixture is a suppression test — route it through the
   592	        // negative-activation/inversion lane instead of scoring it as a positive
   593	        // routing hit. holdout/routing fixtures stay positive-scored.
   594	        negativeActivation: stage === 'negative',
   595	        source: { featureFile: path.relative(playbookDir, full), shape: 'sk-doc' },
   650	  const counts = new Map();
   651	  for (const pair of resolved) counts.set(pair.workflowMode, (counts.get(pair.workflowMode) || 0) + 1);
   652	  let dominant = null;
   653	  let best = -1;
   654	  for (const [mode, count] of counts) {
   655	    if (count > best) { best = count; dominant = mode; }
   656	  }
   657	  const pairs = resolved.filter((pair) => pair.workflowMode === dominant);
   658	  return { pairs, workflowMode: dominant };
   659	}
