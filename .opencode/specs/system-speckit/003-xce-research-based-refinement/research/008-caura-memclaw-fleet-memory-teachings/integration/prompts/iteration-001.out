{"type":"tool_use","timestamp":1780738241775,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_FtukmnJg5x4XDlO8jfj6dR1b","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Mutation Hooks\n3: // ───────────────────────────────────────────────────────────────\n4: import * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\n5: import * as toolCache from '../lib/cache/tool-cache.js';\n6: import { clearConstitutionalCache } from '../hooks/memory-surface.js';\n7: import { clearGraphSignalsCache } from '../lib/graph/graph-signals.js';\n8: import { clearRelatedCache } from '../lib/cognitive/co-activation.js';\n9: import { clearDegreeCache } from '../lib/search/graph-search-fn.js';\n10: import { invalidateEntityDensityCache } from '../lib/search/entity-density.js';\n11: \n12: import type { MutationHookResult } from './memory-crud-types.js';\n13: \n14: // Feature catalog: Transaction wrappers on mutation handlers\n15: // Feature catalog: Shared post-mutation hook wiring\n16: // Feature catalog: Mutation hook result contract expansion\n17: \n18: \n19: export type { MutationHookResult };\n20: \n21: function runPostMutationHooks(\n22:   operation: string,\n23:   context: Record<string, unknown> = {}\n24: ): MutationHookResult {\n25:   const startTime = Date.now();\n26:   const errors: string[] = [];\n27: \n28:   let triggerCacheCleared = false;\n29:   try {\n30:     triggerMatcher.clearCache();\n31:     triggerCacheCleared = true;\n32:   } catch (error: unknown) {\n33:     const message = error instanceof Error ? error.message : String(error);\n34:     console.warn(\n35:       `[mutation-hooks] triggerMatcher.clearCache failed for operation=\"${operation}\":`,\n36:       message\n37:     );\n38:     errors.push(`triggerMatcher.clearCache: ${message}`);\n39:     triggerCacheCleared = false;\n40:   }\n41: \n42:   let toolCacheInvalidated = 0;\n43:   try {\n44:     toolCacheInvalidated = toolCache.invalidateOnWrite(operation, context);\n45:   } catch (error: unknown) {\n46:     const message = error instanceof Error ? error.message : String(error);\n47:     console.warn(\n48:       `[mutation-hooks] toolCache.invalidateOnWrite failed for operation=\"${operation}\":`,\n49:       message\n50:     );\n51:     errors.push(`toolCache.invalidateOnWrite: ${message}`);\n52:     toolCacheInvalidated = 0;\n53:   }\n54: \n55:   let constitutionalCacheCleared = false;\n56:   try {\n57:     clearConstitutionalCache();\n58:     constitutionalCacheCleared = true;\n59:   } catch (error: unknown) {\n60:     const message = error instanceof Error ? error.message : String(error);\n61:     console.warn(\n62:       `[mutation-hooks] clearConstitutionalCache failed for operation=\"${operation}\":`,\n63:       message\n64:     );\n65:     errors.push(`clearConstitutionalCache: ${message}`);\n66:     constitutionalCacheCleared = false;\n67:   }\n68: \n69:   let graphSignalsCacheCleared = false;\n70:   try {\n71:     clearGraphSignalsCache();\n72:     clearDegreeCache();\n73:     graphSignalsCacheCleared = true;\n74:   } catch (error: unknown) {\n75:     const message = error instanceof Error ? error.message : String(error);\n76:     console.warn(\n77:       `[mutation-hooks] graph cache invalidation failed for operation=\"${operation}\":`,\n78:       message\n79:     );\n80:     errors.push(`graphCacheInvalidation: ${message}`);\n81:     graphSignalsCacheCleared = false;\n82:   }\n83: \n84:   let coactivationCacheCleared = false;\n85:   try {\n86:     clearRelatedCache();\n87:     coactivationCacheCleared = true;\n88:   } catch (error: unknown) {\n89:     const message = error instanceof Error ? error.message : String(error);\n90:     console.warn(\n91:       `[mutation-hooks] clearRelatedCache failed for operation=\"${operation}\":`,\n92:       message\n93:     );\n94:     errors.push(`clearRelatedCache: ${message}`);\n95:     coactivationCacheCleared = false;\n96:   }\n97: \n98:   // Entity-density routing keys off title + trigger_phrases. Clearing it here,\n99:   // in the shared hook every mutation handler calls, guarantees a rename or\n100:   // trigger-phrase rewrite is reflected immediately instead of lingering until\n101:   // the 60s TTL. Lower-layer invalidations on save/delete stay in place and are\n102:   // idempotent (a second clear just leaves the cache empty/stale).\n103:   let entityDensityCacheCleared = false;\n104:   try {\n105:     invalidateEntityDensityCache();\n106:     entityDensityCacheCleared = true;\n107:   } catch (error: unknown) {\n108:     const message = error instanceof Error ? error.message : String(error);\n109:     console.warn(\n110:       `[mutation-hooks] invalidateEntityDensityCache failed for operation=\"${operation}\":`,\n111:       message\n112:     );\n113:     errors.push(`invalidateEntityDensityCache: ${message}`);\n114:     entityDensityCacheCleared = false;\n115:   }\n116: \n117:   return {\n118:     latencyMs: Date.now() - startTime,\n119:     triggerCacheCleared,\n120:     constitutionalCacheCleared,\n121:     toolCacheInvalidated,\n122:     graphSignalsCacheCleared,\n123:     coactivationCacheCleared,\n124:     entityDensityCacheCleared,\n125:     errors,\n126:   };\n127: }\n128: \n129: export { runPostMutationHooks };\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Hooks\n// ───────────────────────────────────────────────────────────────\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport { clearConstitutionalCache } from '../hooks/memory-surface.js';\nimport { clearGraphSignalsCache } from '../lib/graph/graph-signals.js';\nimport { clearRelatedCache } from '../lib/cognitive/co-activation.js';\nimport { clearDegreeCache } from '../lib/search/graph-search-fn.js';\nimport { invalidateEntityDensityCache } from '../lib/search/entity-density.js';\n\nimport type { MutationHookResult } from './memory-crud-types.js';\n\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Shared post-mutation hook wiring\n// Feature catalog: Mutation hook result contract expansion\n\n\nexport type { MutationHookResult };\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Hooks\n// ───────────────────────────────────────────────────────────────\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport { clearConstitutionalCache } from '../hooks/memory-surface.js';\nimport { clearGraphSignalsCache } from '../lib/graph/graph-signals.js';\nimport { clearRelatedCache } from '../lib/cognitive/co-activation.js';\nimport { clearDegreeCache } from '../lib/search/graph-search-fn.js';\nimport { invalidateEntityDensityCache } from '../lib/search/entity-density.js';\n\nimport type { MutationHookResult } from './memory-crud-types.js';\n\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Shared post-mutation hook wiring\n// Feature catalog: Mutation hook result contract expansion\n\n\nexport type { MutationHookResult };\n\nfunction runPostMutationHooks(\n  operation: string,\n  context: Record<string, unknown> = {}\n): MutationHookResult {\n  const startTime = Date.now();\n  const errors: string[] = [];\n\n  let triggerCacheCleared = false;\n  try {\n    triggerMatcher.clearCache();\n    triggerCacheCleared = true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(\n      `[mutation-hooks] triggerMatcher.clearCache failed for operation=\"${operation}\":`,\n      message\n    );\n    errors.push(`triggerMatcher.clearCache: ${message}`);\n    triggerCacheCleared = false;\n  }\n\n  let toolCacheInvalidated = 0;\n  try {\n    toolCacheInvalidated = toolCache.invalidateOnWrite(operation, context);\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(\n      `[mutation-hooks] toolCache.invalidateOnWrite failed for operation=\"${operation}\":`,\n      message\n    );\n    errors.push(`toolCache.invalidateOnWrite: ${message}`);\n    toolCacheInvalidated = 0;\n  }\n\n  let constitutionalCacheCleared = false;\n  try {\n    clearConstitutionalCache();\n    constitutionalCacheCleared = true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(\n      `[mutation-hooks] clearConstitutionalCache failed for operation=\"${operation}\":`,\n      message\n    );\n    errors.push(`clearConstitutionalCache: ${message}`);\n    constitutionalCacheCleared = false;\n  }\n\n  let graphSignalsCacheCleared = false;\n  try {\n    clearGraphSignalsCache();\n    clearDegreeCache();\n    graphSignalsCacheCleared = true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(\n      `[mutation-hooks] graph cache invalidation failed for operation=\"${operation}\":`,\n      message\n    );\n    errors.push(`graphCacheInvalidation: ${message}`);\n    graphSignalsCacheCleared = false;\n  }\n\n  let coactivationCacheCleared = false;\n  try {\n    clearRelatedCache();\n    coactivationCacheCleared = true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(\n      `[mutation-hooks] clearRelatedCache failed for operation=\"${operation}\":`,\n      message\n    );\n    errors.push(`clearRelatedCache: ${message}`);\n    coactivationCacheCleared = false;\n  }\n\n  // Entity-density routing keys off title + trigger_phrases. Clearing it here,\n  // in the shared hook every mutation handler calls, guarantees a rename or\n  // trigger-phrase rewrite is reflected immediately instead of lingering until\n  // the 60s TTL. Lower-layer invalidations on save/delete stay in place and are\n  // idempotent (a second clear just leaves the cache empty/stale).\n  let entityDensityCacheCleared = false;\n  try {\n    invalidateEntityDensityCache();\n    entityDensityCacheCleared = true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(\n      `[mutation-hooks] invalidateEntityDensityCache failed for operation=\"${operation}\":`,\n      message\n    );\n    errors.push(`invalidateEntityDensityCache: ${message}`);\n    entityDensityCacheCleared = false;\n  }\n\n  return {\n    latencyMs: Date.now() - startTime,\n    triggerCacheCleared,\n    constitutionalCacheCleared,\n    toolCacheInvalidated,\n    graphSignalsCacheCleared,\n    coactivationCacheCleared,\n    entityDensityCacheCleared,\n    errors,\n  };\n}\n\nexport { runPostMutationHooks };","lineStart":1,"lineEnd":129,"totalLines":129,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts","time":{"start":1780738241772,"end":1780738241775}},"metadata":{"openai":{"itemId":"fc_02c54eb278c2def9016a23e8c19cc08191b6bafbd0a2d76481"}},"id":"prt_e9c4534d2001VoJ4q926fikINq","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c45101a001IFKvp8Hf3MsQNL"}}
{"type":"tool_use","timestamp":1780738241786,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_u9Yx9xinZ3pafeipH5NXBZQJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: \n11: import type { MCPResponse } from './types.js';\n12: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n13: \n14: /** Handle the memory_retention_sweep MCP tool request. */\n15: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n16:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n17:   await checkDatabaseUpdated();\n18: \n19:   const database = vectorIndex.getDb();\n20:   if (!database) {\n21:     return createMCPErrorResponse({\n22:       tool: 'memory_retention_sweep',\n23:       error: 'Retention sweep aborted: database unavailable',\n24:       code: 'E_DB_UNAVAILABLE',\n25:       details: {\n26:         dryRun: args?.dryRun === true,\n27:       },\n28:       recovery: {\n29:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n30:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n31:         severity: 'error',\n32:       },\n33:     });\n34:   }\n35: \n36:   try {\n37:     const result = runMemoryRetentionSweep(database, { dryRun: args?.dryRun === true });\n38:     const summary = result.dryRun\n39:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted`\n40:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}`;\n41: \n42:     const hints: string[] = [];\n43:     if (result.ledgerRecorded === false) {\n44:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n45:     }\n46:     if (result.dryRun && result.candidates.length > 0) {\n47:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n48:     }\n49: \n50:     return createMCPSuccessResponse({\n51:       tool: 'memory_retention_sweep',\n52:       summary,\n53:       data: {\n54:         swept: result.swept,\n55:         retained: result.retained,\n56:         dryRun: result.dryRun,\n57:         durationMs: result.durationMs,\n58:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n59:           id: candidate.id,\n60:           deleteAfter: candidate.deleteAfter,\n61:           specFolder: candidate.specFolder,\n62:           filePath: candidate.filePath,\n63:         })),\n64:         deletedIds: result.deletedIds,\n65:         ledgerRecorded: result.ledgerRecorded,\n66:       },\n67:       hints,\n68:     });\n69:   } catch (error: unknown) {\n70:     return createMCPErrorResponse({\n71:       tool: 'memory_retention_sweep',\n72:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n73:       code: 'E_RETENTION_SWEEP_FAILED',\n74:       details: {\n75:         dryRun: args?.dryRun === true,\n76:       },\n77:       recovery: {\n78:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n79:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n80:         severity: 'error',\n81:       },\n82:     });\n83:   }\n84: }\n85: \n86: export { handleMemoryRetentionSweep };\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, { dryRun: args?.dryRun === true });\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        ledgerRecorded: result.ledgerRecorded,\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":86,"totalLines":86,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1780738241782,"end":1780738241785}},"metadata":{"openai":{"itemId":"fc_02c54eb278c2def9016a23e8c19ccc8191b2ab72473b0e5641"}},"id":"prt_e9c4534ed001mZvm65EQRPAjXT","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c45101a001IFKvp8Hf3MsQNL"}}
{"type":"tool_use","timestamp":1780738241814,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_8UoUisYlaLuDUD5bGpLUoYsV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-links-processor.ts","offset":1,"limit":200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-links-processor.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Causal Links Processor\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: // ───────────────────────────────────────────────────────────────────\n6: // 1. IMPORTS\n7: // ───────────────────────────────────────────────────────────────────\n8: \n9: import type BetterSqlite3 from 'better-sqlite3';\n10: \n11: import type { CausalLinks } from '../lib/parsing/memory-parser.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n14: import { toErrorMessage } from '../utils/index.js';\n15: import { escapeLikePattern } from './handler-utils.js';\n16: \n17: // Feature catalog: Causal edge creation (memory_causal_link)\n18: // Feature catalog: Causal edge deletion (memory_causal_unlink)\n19: // Feature catalog: Memory indexing (memory_save)\n20: \n21: // ───────────────────────────────────────────────────────────────────\n22: // 2. TYPES\n23: // ───────────────────────────────────────────────────────────────────\n24: \n25: interface CausalLinkMapping {\n26:   relation: typeof causalEdges.RELATION_TYPES[keyof typeof causalEdges.RELATION_TYPES];\n27:   reverse: boolean;\n28: }\n29: \n30: interface CausalLinksResult {\n31:   processed: number;\n32:   inserted: number;\n33:   resolved: number;\n34:   unresolved: { type: string; reference: string }[];\n35:   errors: { type: string; reference: string; error: string }[];\n36: }\n37: \n38: interface MemoryIdRow {\n39:   id: number;\n40: }\n41: \n42: interface PathLookupRow extends MemoryIdRow {\n43:   canonical_file_path: string | null;\n44:   file_path: string | null;\n45:   spec_folder: string | null;\n46: }\n47: \n48: interface TitleLookupRow extends MemoryIdRow {\n49:   title: string | null;\n50: }\n51: \n52: interface PreparedReference {\n53:   original: string;\n54:   trimmed: string;\n55:   normalizedReference: string;\n56:   normalizedLower: string;\n57:   escapedLike: string;\n58:   numericId: number | null;\n59:   isSessionLike: boolean;\n60:   isPathLike: boolean;\n61: }\n62: \n63: // ───────────────────────────────────────────────────────────────────\n64: // 3. CONSTANTS\n65: // ───────────────────────────────────────────────────────────────────\n66: \n67: const CAUSAL_LINK_MAPPINGS: Record<string, CausalLinkMapping> = {\n68:   caused_by: { relation: causalEdges.RELATION_TYPES.CAUSED, reverse: true },\n69:   supersedes: { relation: causalEdges.RELATION_TYPES.SUPERSEDES, reverse: false },\n70:   derived_from: { relation: causalEdges.RELATION_TYPES.DERIVED_FROM, reverse: false },\n71:   blocks: { relation: causalEdges.RELATION_TYPES.ENABLED, reverse: true },\n72:   related_to: { relation: causalEdges.RELATION_TYPES.SUPPORTS, reverse: false }\n73: };\n74: \n75: // ───────────────────────────────────────────────────────────────────\n76: // 4. HELPERS\n77: // ───────────────────────────────────────────────────────────────────\n78: \n79: /** Resolve a memory reference (ID, path, or title) to a numeric memory ID */\n80: function resolveMemoryReference(database: BetterSqlite3.Database, reference: string): number | null {\n81:   const resolved = resolveMemoryReferencesBatch(database, [reference]).get(reference);\n82:   return typeof resolved === 'number' ? resolved : null;\n83: }\n84: \n85: function buildPreparedReference(reference: string): PreparedReference | null {\n86:   if (!reference || typeof reference !== 'string') {\n87:     return null;\n88:   }\n89: \n90:   const trimmed = reference.trim();\n91:   if (!trimmed) {\n92:     return null;\n93:   }\n94: \n95:   const normalizedReference = trimmed.replace(/\\\\/g, '/');\n96:   const normalizedLower = normalizedReference.toLowerCase();\n97:   const numericId = /^\\d+$/.test(trimmed) ? Number.parseInt(trimmed, 10) : null;\n98: \n99:   return {\n100:     original: reference,\n101:     trimmed,\n102:     normalizedReference,\n103:     normalizedLower,\n104:     escapedLike: escapeLikePattern(normalizedReference),\n105:     numericId: Number.isFinite(numericId) ? numericId : null,\n106:     isSessionLike: normalizedLower.includes('session') || /^\\d{4}-\\d{2}-\\d{2}/.test(normalizedReference),\n107:     isPathLike:\n108:       normalizedLower.includes('specs/')\n109:       || normalizedLower.includes('memory/')\n110:       || normalizedReference.includes('/'),\n111:   };\n112: }\n113: \n114: function buildPathExactCandidates(normalizedReference: string): string[] {\n115:   const candidates = new Set<string>();\n116: \n117:   const canonical = getCanonicalPathKey(normalizedReference);\n118:   const trimmedLeadingSlash = normalizedReference.replace(/^\\/+/, '');\n119: \n120:   candidates.add(normalizedReference);\n121:   candidates.add(canonical);\n122:   candidates.add(trimmedLeadingSlash);\n123:   if (!normalizedReference.startsWith('/')) {\n124:     candidates.add(`/${normalizedReference}`);\n125:   }\n126:   if (!canonical.startsWith('/')) {\n127:     candidates.add(`/${canonical}`);\n128:   }\n129: \n130:   return Array.from(candidates).filter((candidate) => candidate.length > 0);\n131: }\n132: \n133: function buildInClause(values: readonly unknown[]): string {\n134:   return values.map(() => '?').join(', ');\n135: }\n136: \n137: function getMemoryIndexColumns(database: BetterSqlite3.Database): Set<string> {\n138:   const rows = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name?: string }>;\n139:   return new Set(rows.map((row) => row.name).filter((name): name is string => typeof name === 'string'));\n140: }\n141: \n142: /** Resolve many memory references in batch (exact first, fuzzy fallback). */\n143: function resolveMemoryReferencesBatch(\n144:   database: BetterSqlite3.Database,\n145:   references: readonly string[],\n146: ): Map<string, number | null> {\n147:   const resolved = new Map<string, number | null>();\n148:   const preparedRefs: PreparedReference[] = [];\n149:   const memoryIndexColumns = getMemoryIndexColumns(database);\n150:   const hasCanonicalFilePath = memoryIndexColumns.has('canonical_file_path');\n151: \n152:   for (const reference of references) {\n153:     const prepared = buildPreparedReference(reference);\n154:     if (!prepared) {\n155:       resolved.set(reference, null);\n156:       continue;\n157:     }\n158:     preparedRefs.push(prepared);\n159:     resolved.set(reference, null);\n160:   }\n161: \n162:   if (preparedRefs.length === 0) {\n163:     return resolved;\n164:   }\n165: \n166:   const unresolved = (reference: PreparedReference): boolean => {\n167:     return !resolved.has(reference.original) || resolved.get(reference.original) == null;\n168:   };\n169: \n170:   const setResolved = (reference: PreparedReference, id: number | null): void => {\n171:     if (typeof id === 'number' && Number.isFinite(id)) {\n172:       resolved.set(reference.original, id);\n173:     }\n174:   };\n175: \n176:   // 1) Batch numeric IDs\n177:   const numericIds = Array.from(\n178:     new Set(preparedRefs.map((ref) => ref.numericId).filter((id): id is number => typeof id === 'number')),\n179:   );\n180:   if (numericIds.length > 0) {\n181:     const numericRows = database.prepare(`\n182:       SELECT id\n183:       FROM memory_index\n184:       WHERE id IN (${buildInClause(numericIds)})\n185:     `).all(...numericIds) as MemoryIdRow[];\n186: