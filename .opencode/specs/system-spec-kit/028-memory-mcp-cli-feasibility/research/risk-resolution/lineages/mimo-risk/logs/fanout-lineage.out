uncher: () => launcherShutdownInProgress,\n1131:     onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n1132:     ...options,\n1133:   });\n1134: }\n1135: \n1136: function launchModelServer(options = null) {\n1137:   if (options && typeof options === 'object') {\n1138:     return createModelServerSupervisor(options).launch();\n1139:   }\n1140:   return hfControl.launch();\n1141: }\n1142: \n1143: function startModelServerDemandListener(options = {}) {\n1144:   return hfControl.startDemandListener(options);\n1145: }\n1146: \n1147: function stopModelServerDemandListener() {\n1148:   return hfControl.stopDemandListener();\n1149: }\n1150: \n1151: async function acquireBootstrapLock(options = {}) {\n1152:   const requireLock = options.requireLock === true;\n1153:   fs.mkdirSync(dbDir, { recursive: true });\n1154:   const deadline = Date.now() + 120000;\n1155:   while (true) {\n1156:     try {\n1157:       fs.mkdirSync(lockDir);\n1158:       return true;\n1159:     } catch (error) {\n1160:       if (error.code !== 'EEXIST') {\n1161:         throw error;\n1162:       }\n1163:       // Reclaim a stale lockdir left by a SIGKILL'd launcher (mtime-based; the lockdir records no pid),\n1164:       // so a crashed holder cannot block a requireLock respawn for the full 120s deadline.\n1165:       try {\n1166:         const ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n1167:         if (ageMs > BOOTSTRAP_LOCK_STALE_MS) {\n1168:           log(`reclaiming stale bootstrap lock ${rel(lockDir)} (age ${Math.round(ageMs / 1000)}s)`);\n1169:           // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n1170:           // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n1171:           // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n1172:           // live successor lock. A losing racer's rename throws ENOENT and falls through to\n1173:           // the outer retry.\n1174:           const