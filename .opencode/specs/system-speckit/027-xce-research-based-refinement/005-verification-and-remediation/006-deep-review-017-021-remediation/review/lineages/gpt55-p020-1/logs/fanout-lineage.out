  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1499: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1500:   if (!args.background) {\n1501:     return runIndexScan(args, {});\n1502:   }\n1503: \n1504:   const jobId = createJobId();\n1505:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1506: \n1507:   setImmediate(() => {\n1508:     void (async () => {\n1509:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1510:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1511:       // background-embedding queue draining this scan's deferred embeddings can\n1512:       // keep it held past the scan itself.\n1513:       const maintenance = beginMaintenance('index_scan');\n1514:       try {\n1515:         await setJobState(jobId, 'running');\n1516:         const response = await runIndexScan(args, {\n1517:           isCancelled: () => isCancelRequestedFast(jobId),\n1518:           onPhase: (phase) => {\n1519:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1520:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1521:             maintenance.refresh();\n1522:             void setJobPhase(jobId, phase).catch(() => {});\n1523:           },\n1524:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1525:         });\n1526:         const scanData = extractEnvelopeData(response);\n1527:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1528:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1529:         if (wasCancelled) {\n1530:           // The run itself short-circuited on cancellation. A cancel that arrives\n1531:           // after the scan already finished does not retroactively cancel it.\n1532:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1533:         } else if (response.isError === true) {\n1534:           // An error envelope (not a thrown error) still means the scan failed.\n1535:           await appendJobError(jobId, '__scan__', scanData);\n1536:           await setJobState(jobId, 'failed');\n1537:         } else {\n1538:           await completeJob(jobId, { state: 'complete', result: scanData });\n1539:         }\n1540:       } catch (error: unknown) {\n1541:         try {\n1542:           await appendJobError(jobId, '__job__', error);\n1543:           await setJobState(jobId, 'failed');\n1544:         } catch (_secondaryError: unknown) {\n1545:           // Best-effort failure record; never surface a background unhandled rejection.\n1546:         }\n1547:       } finally {\n1548:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1549:         // Release this scan's hold; the marker stays present only while the\n1550:         // background-embedding queue still holds it.\n1551:         maintenance.end();\n1552:       }\n1553:     })();\n1554:   });\n1555: \n1556:   return createMCPSuccessResponse({\n1557:     tool: 'memory_index_scan',\n1558:     summary: `Queued background index scan ${jobId}`,\n1559:     data: { jobId, state: 'queued', background: true },\n1560:     hints: [\n1561:       'Use memory_index_scan_status with jobId to poll progress',\n1562:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1563:     ],\n1564:   });\n1565: }\n1566: \n1567: /* ───────────────────────────────────────────────────────────────\n1568:    9. EXPORTS\n1569: ──────────────────────────────────────────────────────────────── */\n1570: \n1571: export {\n1572:   handleMemoryIndexScan,\n1573:   indexSingleFile,\n1574:   findConstitutionalFiles,\n1575:   findSpecDocuments,\n1576:   detectSpecLevel,\n1577:   summarizeAliasConflicts,\n1578:   runDivergenceReconcileHooks,\n1579: };\n1580: \n1581: // Backward-compatible aliases (snake_case)\n1582: const handle_memory_index_scan = handleMemoryIndexScan;\n1583: const index_single_file = indexSingleFile;\n1584: const find_constitutional_files = findConstitutionalFiles;\n1585: const find_spec_documents = findSpecDocuments;\n1586: const detect_spec_level = detectSpecLevel;\n1587: const summarize_alias_conflicts = summarizeAliasConflicts;\n1588: const run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n1589: \n1590: export {\n1591:   handle_memory_index_scan,\n1592:   index_single_file,\n1593:   find_constitutional_files,\n1594:   find_spec_documents,\n1595:   detect_spec_level,\n1596:   summarize_alias_conflicts,\n1597:   run_divergence_reconcile_hooks,\n1598: };\n\n(End of file - total 1598 lines)\n</content>","metadata":{"preview":"    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})\n    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_index_scan = handleMemoryIndexScan;\nconst index_single_file = indexSingleFile;\nconst find_constitutional_files = findConstitutionalFiles;\nconst find_spec_documents = findSpecDocuments;\nconst detect_spec_level = detectSpecLevel;\nconst summarize_alias_conflicts = summarizeAliasConflicts;\nconst run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n\nexport {\n  handle_memory_index_scan,\n  index_single_file,\n  find_constitutional_files,\n  find_spec_documents,\n  detect_spec_level,\n  summarize_alias_conflicts,\n  run_divergence_reconcile_hooks,\n};","lineStart":1460,"lineEnd":1598,"totalLines":1598,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781756744957,"end":1781756744963}},"metadata":{"openai":{"itemId":"fc_0ea3ba2690057375016a3373483d8c81919e0b2b61cc21c2b8"}},"id":"prt_ed8fa525b001rAJWBmDVfQPXV7","sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","messageID":"msg_ed8fa2900001pIY02o7PxE4xOe"}}
{"type":"tool_use","timestamp":1781756745005,"sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","part":{"type":"tool","tool":"read","callID":"call_m3VDxwxuhJOnreOGczL0CgEw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","offset":1,"limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { createRequire } from 'node:module';\n2: \n3: import { describe, expect, it } from 'vitest';\n4: \n5: type MaintenanceMarker = {\n6:   childPid: number;\n7:   activeUntilMs: number;\n8:   jobId?: string;\n9:   refreshedAtIso?: string;\n10: };\n11: \n12: const require = createRequire(import.meta.url);\n13: const launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n14:   readMaintenanceMarker: (\n15:     dbDir: string,\n16:     options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n17:   ) => MaintenanceMarker | null;\n18:   shouldAdoptDespiteProbe: (options?: {\n19:     marker?: MaintenanceMarker | null;\n20:     childPid?: number;\n21:     childLiveness?: string;\n22:     nowMs?: number | (() => number);\n23:   }) => boolean;\n24: };\n25: \n26: describe('launcher maintenance-active adopt guard', () => {\n27:   const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n28:   const freshMarker = (childPid: number): MaintenanceMarker => ({\n29:     childPid,\n30:     activeUntilMs: NOW + 30_000,\n31:     jobId: 'index-scan-1',\n32:     refreshedAtIso: '2026-06-09T00:00:00.000Z',\n33:   });\n34: \n35:   it('adopts a fresh marker that names this exact live child (a)', () => {\n36:     // Busy-by-design: the marker is unexpired, names the probed child, and the\n37:     // child is alive — the only case where adoption beats reaping.\n38:     expect(\n39:       launcher.shouldAdoptDespiteProbe({\n40:         marker: freshMarker(4242),\n41:         childPid: 4242,\n42:         childLiveness: 'alive',\n43:         nowMs: NOW,\n44:       }),\n45:     ).toBe(true);\n46:   });\n47: \n48:   it('reaps once the marker has expired (b)', () => {\n49:     // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n50:     // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n51:     expect(\n52:       launcher.shouldAdoptDespiteProbe({\n53:         marker: { ...freshMarker(4242), activeUntilMs: NOW },\n54:         childPid: 4242,\n55:         childLiveness: 'alive',\n56:         nowMs: NOW,\n57:       }),\n58:     ).toBe(false);\n59:   });\n60: \n61:   it('reaps when the marker names a different child (c)', () => {\n62:     // A marker left over from a prior daemon child must never pin the current\n63:     // one; a childPid mismatch falls through to the reap path.\n64:     expect(\n65:       launcher.shouldAdoptDespiteProbe({\n66:         marker: freshMarker(4242),\n67:         childPid: 9999,\n68:         childLiveness: 'alive',\n69:         nowMs: NOW,\n70:       }),\n71:     ).toBe(false);\n72:   });\n73: \n74:   it('reaps when the probed child is dead (d)', () => {\n75:     expect(\n76:       launcher.shouldAdoptDespiteProbe({\n77:         marker: freshMarker(4242),\n78:         childPid: 4242,\n79:         childLiveness: 'dead',\n80:         nowMs: NOW,\n81:       }),\n82:     ).toBe(false);\n83:   });\n84: \n85:   it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n86:     // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n87:     // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n88:     expect(\n89:       launcher.shouldAdoptDespiteProbe({\n90:         marker: freshMarker(4242),\n91:         childPid: 4242,\n92:         childLiveness: 'unknown-eperm',\n93:         nowMs: NOW,\n94:       }),\n95:     ).toBe(false);\n96:   });\n97: \n98:   it('reaps when there is no marker at all (f)', () => {\n99:     expect(\n100:       launcher.shouldAdoptDespiteProbe({\n101:         marker: null,\n102:         childPid: 4242,\n103:         childLiveness: 'alive',\n104:         nowMs: NOW,\n105:       }),\n106:     ).toBe(false);\n107:   });\n108: \n109:   it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n110:     for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n111:       expect(\n112:         launcher.shouldAdoptDespiteProbe({\n113:           marker: freshMarker(4242),\n114:           childPid,\n115:           childLiveness: 'alive',\n116:           nowMs: NOW,\n117:         }),\n118:       ).toBe(false);\n119:     }\n120:   });\n121: });\n122: \n123: describe('launcher maintenance marker reader (injected fs)', () => {\n124:   const injectFs = (readFileSync: (path: string) => string) =>\n125:     ({ fs: { readFileSync } });\n126: \n127:   it('returns the parsed object for a valid marker (a)', () => {\n128:     const marker = {\n129:       childPid: 4242,\n130:       activeUntilMs: 1_700_000_000_000,\n131:       jobId: 'index-scan-1',\n132:       refreshedAtIso: '2026-06-09T00:00:00.000Z',\n133:     };\n134:     expect(\n135:       launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n136:     ).toEqual(marker);\n137:   });\n138: \n139:   it('returns null when the marker file is missing (ENOENT) (b)', () => {\n140:     expect(\n141:       launcher.readMaintenanceMarker('/db', injectFs(() => {\n142:         throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n143:       })),\n144:     ).toBeNull();\n145:   });\n146: \n147:   it('returns null for corrupt JSON (c)', () => {\n148:     expect(\n149:       launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n150:     ).toBeNull();\n151:   });\n152: \n153:   it('returns null when childPid is missing (d)', () => {\n154:     expect(\n155:       launcher.readMaintenanceMarker(\n156:         '/db',\n157:         injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n158:       ),\n159:     ).toBeNull();\n160:   });\n161: \n162:   it('returns null when activeUntilMs is non-finite (e)', () => {\n163:     expect(\n164:       launcher.readMaintenanceMarker(\n165:         '/db',\n166:         // JSON.stringify turns Infinity into null, which is non-finite by the\n167:         // reader's Number.isFinite gate — the canonical corrupt-time shape.\n168:         injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n169:       ),\n170:     ).toBeNull();\n171:   });\n172: });\n\n(End of file - total 172 lines)\n</content>","metadata":{"preview":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","text":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;\n    childLiveness?: string;\n    nowMs?: number | (() => number);\n  }) => boolean;\n};\n\ndescribe('launcher maintenance-active adopt guard', () => {\n  const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n  const freshMarker = (childPid: number): MaintenanceMarker => ({\n    childPid,\n    activeUntilMs: NOW + 30_000,\n    jobId: 'index-scan-1',\n    refreshedAtIso: '2026-06-09T00:00:00.000Z',\n  });\n\n  it('adopts a fresh marker that names this exact live child (a)', () => {\n    // Busy-by-design: the marker is unexpired, names the probed child, and the\n    // child is alive — the only case where adoption beats reaping.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(true);\n  });\n\n  it('reaps once the marker has expired (b)', () => {\n    // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n    // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: { ...freshMarker(4242), activeUntilMs: NOW },\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the marker names a different child (c)', () => {\n    // A marker left over from a prior daemon child must never pin the current\n    // one; a childPid mismatch falls through to the reap path.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 9999,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the probed child is dead (d)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'dead',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n    // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n    // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'unknown-eperm',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when there is no marker at all (f)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: null,\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n    for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n      expect(\n        launcher.shouldAdoptDespiteProbe({\n          marker: freshMarker(4242),\n          childPid,\n          childLiveness: 'alive',\n          nowMs: NOW,\n        }),\n      ).toBe(false);\n    }\n  });\n});\n\ndescribe('launcher maintenance marker reader (injected fs)', () => {\n  const injectFs = (readFileSync: (path: string) => string) =>\n    ({ fs: { readFileSync } });\n\n  it('returns the parsed object for a valid marker (a)', () => {\n    const marker = {\n      childPid: 4242,\n      activeUntilMs: 1_700_000_000_000,\n      jobId: 'index-scan-1',\n      refreshedAtIso: '2026-06-09T00:00:00.000Z',\n    };\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n    ).toEqual(marker);\n  });\n\n  it('returns null when the marker file is missing (ENOENT) (b)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => {\n        throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n      })),\n    ).toBeNull();\n  });\n\n  it('returns null for corrupt JSON (c)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n    ).toBeNull();\n  });\n\n  it('returns null when childPid is missing (d)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n      ),\n    ).toBeNull();\n  });\n\n  it('returns null when activeUntilMs is non-finite (e)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        // JSON.stringify turns Infinity into null, which is non-finite by the\n        // reader's Number.isFinite gate — the canonical corrupt-time shape.\n        injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n      ),\n    ).toBeNull();\n  });\n});","lineStart":1,"lineEnd":172,"totalLines":172,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","time":{"start":1781756744999,"end":1781756745004}},"metadata":{"openai":{"itemId":"fc_0ea3ba2690057375016a3373483da081918c19446314dcb3b7"}},"id":"prt_ed8fa5514001Rh40dTmS22o6cI","sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","messageID":"msg_ed8fa2900001pIY02o7PxE4xOe"}}
{"type":"tool_use","timestamp":1781756745022,"sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","part":{"type":"tool","tool":"read","callID":"call_IK7XhAEf47JEdAdNar9dVIRF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: Background index scan dispatch + status/cancel handlers\n3: // ───────────────────────────────────────────────────────────────\n4: import { beforeEach, describe, expect, it, vi } from 'vitest';\n5: import { setTimeout as delay } from 'node:timers/promises';\n6: \n7: // ──────────────────────────────────────────────────────────────\n8: // 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n9: // ──────────────────────────────────────────────────────────────\n10: \n11: const mocks = vi.hoisted(() => ({\n12:   mockAcquireIndexScanLease: vi.fn(),\n13:   mockCompleteIndexScanLease: vi.fn(),\n14:   mockCheckDatabaseUpdated: vi.fn(),\n15:   mockProcessBatches: vi.fn(),\n16:   mockFindSpecDocuments: vi.fn((): string[] => []),\n17:   mockFindConstitutionalFiles: vi.fn((): string[] => []),\n18:   mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n19:   mockRequireDb: vi.fn(() => ({\n20:     prepare: vi.fn(() => ({\n21:       all: vi.fn(() => []),\n22:       get: vi.fn(() => undefined),\n23:     })),\n24:   })),\n25:   mockCategorizeFilesForIndexing: vi.fn((files: string[]) => ({\n26:     toIndex: files,\n27:     toUpdate: [] as string[],\n28:     toSkip: [] as string[],\n29:     toDelete: [] as string[],\n30:   })),\n31:   mockBatchUpdateMtimes: vi.fn(() => ({ updated: 0 })),\n32:   mockListIndexedRecordIdsForDeletedPaths: vi.fn((): number[] => []),\n33:   mockDeleteMemory: vi.fn((): boolean => true),\n34:   mockGetDb: vi.fn(() => ({\n35:     prepare: vi.fn(() => ({\n36:       get: vi.fn(() => undefined),\n37:     })),\n38:   })),\n39:   mockRunPostMutationHooks: vi.fn(() => ({ latencyMs: 0 })),\n40:   mockIndexMemoryFile: vi.fn(async () => ({ status: 'indexed', id: 1, specFolder: 'specs/test' })),\n41: }));\n42: \n43: // In-memory maintenance job store standing in for the persisted SQLite store.\n44: const jobStore = vi.hoisted(() => {\n45:   interface FakeJob {\n46:     id: string;\n47:     kind: string;\n48:     state: string;\n49:     phase: string | null;\n50:     progressTotal: number;\n51:     progressProcessed: number;\n52:     cancelRequested: boolean;\n53:     errors: Array<{ source: string; message: string; timestamp: string }>;\n54:     result: unknown;\n55:     payload: unknown;\n56:     createdAt: string;\n57:     updatedAt: string;\n58:   }\n59:   const jobs = new Map<string, FakeJob>();\n60:   let counter = 0;\n61:   return {\n62:     jobs,\n63:     createJobId: vi.fn(() => { counter += 1; return `job_test_${counter}`; }),\n64:     ensureMaintenanceJobsTable: vi.fn(),\n65:     createMaintenanceJob: vi.fn(async (args: { id: string; kind: string; payload?: unknown }) => {\n66:       const job: FakeJob = {\n67:         id: args.id,\n68:         kind: args.kind,\n69:         state: 'queued',\n70:         phase: null,\n71:         progressTotal: 0,\n72:         progressProcessed: 0,\n73:         cancelRequested: false,\n74:         errors: [],\n75:         result: null,\n76:         payload: args.payload ?? null,\n77:         createdAt: 'seed',\n78:         updatedAt: 'seed',\n79:       };\n80:       jobs.set(args.id, job);\n81:       return job;\n82:     }),\n83:     getMaintenanceJob: vi.fn((id: string) => jobs.get(id) ?? null),\n84:     setJobState: vi.fn(async (id: string, state: string) => {\n85:       const job = jobs.get(id);\n86:       if (job) job.state = state;\n87:       return job ?? null;\n88:     }),\n89:     setJobPhase: vi.fn(async (id: string, phase: string) => {\n90:       const job = jobs.get(id);\n91:       if (job) job.phase = phase;\n92:     }),\n93:     setJobProgress: vi.fn(async (id: string, progress: { processed: number; total: number }) => {\n94:       const job = jobs.get(id);\n95:       if (job) { job.progressProcessed = progress.processed; job.progressTotal = progress.total; }\n96:     }),\n97:     appendJobError: vi.fn(async (id: string, source: string, error: unknown) => {\n98:       const job = jobs.get(id);\n99:       if (job) job.errors.push({ source, message: String(error), timestamp: 'seed' });\n100:       return job ?? null;\n101:     }),\n102:     requestCancel: vi.fn(async (id: string) => {\n103:       const job = jobs.get(id);\n104:       if (job) job.cancelRequested = true;\n105:     }),\n106:     isCancelRequested: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n107:     isCancelRequestedFast: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n108:     completeJob: vi.fn(async (id: string, options: { state: string; result?: unknown }) => {\n109:       const job = jobs.get(id);\n110:       if (job) { job.state = options.state; job.result = options.result ?? null; }\n111:       return job ?? null;\n112:     }),\n113:     resetRunningJobsForKind: vi.fn(() => [] as string[]),\n114:     isTerminalJobState: vi.fn((state: string) => state === 'complete' || state === 'failed' || state === 'cancelled'),\n115:     MAX_STORED_ERRORS: 50,\n116:   };\n117: });\n118: \n119: // ──────────────────────────────────────────────────────────────\n120: // 2. MODULE MOCKS\n121: // ──────────────────────────────────────────────────────────────\n122: \n123: vi.mock('../lib/ops/job-store', () => jobStore);\n124: \n125: vi.mock('../core', () => ({\n126:   checkDatabaseUpdated: mocks.mockCheckDatabaseUpdated,\n127: }));\n128: \n129: vi.mock('../core/db-state', async (importOriginal) => {\n130:   const actual = await importOriginal<typeof import('../core/db-state')>();\n131:   return {\n132:     ...actual,\n133:     acquireIndexScanLease: mocks.mockAcquireIndexScanLease,\n134:     completeIndexScanLease: mocks.mockCompleteIndexScanLease,\n135:   };\n136: });\n137: \n138: vi.mock('../core/config', async (importOriginal) => {\n139:   const actual = await importOriginal<typeof import('../core/config')>();\n140:   return {\n141:     ...actual,\n142:     INDEX_SCAN_COOLDOWN: 60000,\n143:     DEFAULT_BASE_PATH: '/tmp/mock-workspace',\n144:     BATCH_SIZE: 5,\n145:     SERVER_DIR: '/tmp/mock-server',\n146:   };\n147: });\n148: \n149: vi.mock('../utils', () => ({\n150:   processBatches: mocks.mockProcessBatches,\n151:   requireDb: mocks.mockRequireDb,\n152:   toErrorMessage: (error: unknown) => error instanceof Error ? error.message : String(error),\n153: }));\n154: \n155: vi.mock('../handlers/memory-index-discovery', () => ({\n156:   findSpecDocuments: mocks.mockFindSpecDocuments,\n157:   findConstitutionalFiles: mocks.mockFindConstitutionalFiles,\n158:   findGraphMetadataFiles: mocks.mockFindGraphMetadataFiles,\n159:   detectSpecLevel: vi.fn(() => null),\n160: }));\n161: \n162: vi.mock('../lib/providers/embeddings', () => ({\n163:   getEmbeddingProfile: vi.fn(() => null),\n164: }));\n165: \n166: vi.mock('../lib/storage/incremental-index', () => ({\n167:   categorizeFilesForIndexing: mocks.mockCategorizeFilesForIndexing,\n168:   batchUpdateMtimes: mocks.mockBatchUpdateMtimes,\n169:   listIndexedRecordIdsForDeletedPaths: mocks.mockListIndexedRecordIdsForDeletedPaths,\n170: }));\n171: \n172: vi.mock('../lib/search/vector-index', () => ({\n173:   deleteMemory: mocks.mockDeleteMemory,\n174:   getDb: mocks.mockGetDb,\n175: }));\n176: \n177: vi.mock('../handlers/mutation-hooks', () => ({\n178:   runPostMutationHooks: mocks.mockRunPostMutationHooks,\n179: }));\n180: \n181: vi.mock('../lib/response/envelope', () => ({\n182:   createMCPSuccessResponse: (payload: unknown) => ({\n183:     content: [{ type: 'text', text: JSON.stringify(payload) }],\n184:   }),\n185:   createMCPErrorResponse: (payload: unknown) => ({\n186:     content: [{ type: 'text', text: JSON.stringify(payload) }],\n187:   }),\n188: }));\n189: \n190: vi.mock('../handlers/memory-save', () => ({\n191:   indexMemoryFile: mocks.mockIndexMemoryFile,\n192: }));\n193: \n194: vi.mock('../lib/governance/scope-governance', () => ({\n195:   requiresGovernedIngest: vi.fn(() => false),\n196:   validateGovernedIngest: vi.fn(() => ({ allowed: true, issues: [] })),\n197: }));\n198: \n199: vi.mock('../lib/runtime/memory-runtime-guard', () => ({\n200:   ensureMemoryRuntimeInitialized: vi.fn(async () => undefined),\n201: }));\n202: \n203: vi.mock('../lib/utils/canonical-path', () => ({\n204:   getCanonicalPathKey: (p: string) => p,\n205: }));\n206: \n207: vi.mock('../handlers/memory-index-alias', () => ({\n208:   EMPTY_ALIAS_CONFLICT_SUMMARY: { groups: 0, divergentHashGroups: 0 },\n209:   createDefaultDivergenceReconcileSummary: () => ({ retriesScheduled: 0, escalated: 0, errors: [] }),\n210:   detectAliasConflictsFromIndex: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n211:   summarizeAliasConflicts: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n212:   runDivergenceReconcileHooks: vi.fn(() => ({ retriesScheduled: 0, escalated: 0, errors: [] })),\n213: }));\n214: \n215: vi.mock('../lib/storage/checkpoints', () => ({\n216:   getRestoreBarrierStatus: vi.fn(() => null),\n217:   repairNeedsRebuildSentinel: vi.fn(() => ({\n218:     sentinelPresent: false,\n219:     attempted: false,\n220:     cleared: false,\n221:     summary: null,\n222:     error: null,\n223:   })),\n224: }));\n225: \n226: // ──────────────────────────────────────────────────────────────\n227: // 3. MODULES UNDER TEST (imported after all vi.mock() calls)\n228: // ──────────────────────────────────────────────────────────────\n229: \n230: import * as scanHandler from '../handlers/memory-index';\n231: import * as scanJobHandlers from '../handlers/memory-index-scan-jobs';\n232: \n233: // ──────────────────────────────────────────────────────────────\n234: // 4. HELPERS\n235: // ──────────────────────────────────────────────────────────────\n236: \n237: const TEST_FILE = '/tmp/mock-workspace/.opencode/specs/test/spec.md';\n238: \n239: async function waitFor(predicate: () => boolean, timeoutMs = 3000): Promise<void> {\n240:   const deadline = Date.now() + timeoutMs;\n241:   while (Date.now() < deadline) {\n242:     if (predicate()) return;\n243:     await delay(10);\n244:   }\n245:   throw new Error('Timed out waiting for condition');\n246: }\n247: \n248: function parseEnvelope(response: { content: Array<{ text: string }> }): { data: Record<string, unknown> } {\n249:   return JSON.parse(response.content[0].text) as { data: Record<string, unknown> };\n250: }\n251: \n252: function createBatchGate(): { gate: Promise<void>; release: () => void } {\n253:   let release = (): void => {};\n254:   const gate = new Promise<void>((resolve) => { release = resolve; });\n255:   return { gate, release };\n256: }\n257: \n258: // ──────────────────────────────────────────────────────────────\n259: // 5. TESTS\n260: // ──────────────────────────────────────────────────────────────\n261: \n262: describe('memory_index_scan background dispatch', () => {\n263:   beforeEach(() => {\n264:     vi.clearAllMocks();\n265:     jobStore.jobs.clear();\n266: \n267:     mocks.mockAcquireIndexScanLease.mockResolvedValue({\n268:       acquired: true,\n269:       reason: 'ok',\n270:       waitSeconds: 0,\n271:       lastIndexScan: 0,\n272:       scanStartedAt: 0,\n273:       leaseExpiryMs: 120000,\n274:       cooldownMs: 60000,\n275:     });\n276:     mocks.mockCompleteIndexScanLease.mockResolvedValue(undefined);\n277:     mocks.mockCheckDatabaseUpdated.mockResolvedValue(false);\n278:     mocks.mockFindSpecDocuments.mockReturnValue([TEST_FILE]);\n279:     mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n280:     mocks.mockFindGraphMetadataFiles.mockReturnValue([]);\n281:     mocks.mockCategorizeFilesForIndexing.mockReturnValue({\n282:       toIndex: [TEST_FILE],\n283:       toUpdate: [],\n284:       toSkip: [],\n285:       toDelete: [],\n286:     });\n287:     mocks.mockBatchUpdateMtimes.mockReturnValue({ updated: 0 });\n288:     mocks.mockListIndexedRecordIdsForDeletedPaths.mockReturnValue([]);\n289:     mocks.mockDeleteMemory.mockReturnValue(true);\n290:     mocks.mockGetDb.mockReturnValue({\n291:       prepare: vi.fn(() => ({ get: vi.fn(() => undefined), all: vi.fn(() => []) })),\n292:     });\n293:     mocks.mockRunPostMutationHooks.mockReturnValue({ latencyMs: 0 });\n294:     mocks.mockRequireDb.mockReturnValue({\n295:       prepare: vi.fn(() => ({ all: vi.fn(() => []), get: vi.fn(() => undefined) })),\n296:     });\n297:     mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'indexed', id: 1, specFolder: 'specs/test' });\n298:     mocks.mockProcessBatches.mockImplementation(\n299:       async (files: string[], worker: (file: string) => Promise<unknown>) => Promise.all(files.map(worker)),\n300:     );\n301:   });\n302: \n303:   it('background:true returns a queued jobId immediately without blocking on the scan', async () => {\n304:     const { gate, release } = createBatchGate();\n305:     mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n306:       await gate;\n307:       return Promise.all(files.map(worker));\n308:     });\n309: \n310:     const result = await scanHandler.handleMemoryIndexScan({\n311:       background: true,\n312:       includeConstitutional: false,\n313:       includeSpecDocs: true,\n314:       incremental: false,\n315:       force: false,\n316:     });\n317: \n318:     const { data } = parseEnvelope(result);\n319:     expect(data.background).toBe(true);\n320:     expect(data.state).toBe('queued');\n321:     expect(typeof data.jobId).toBe('string');\n322: \n323:     const jobId = data.jobId as string;\n324:     // The runner advances to 'running' but parks at the gated batch loop — the\n325:     // handler already returned, proving the call did not block on the scan.\n326:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'running');\n327:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n328: \n329:     release();\n330:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n331:     expect(mocks.mockIndexMemoryFile).toHaveBeenCalledTimes(1);\n332:   });\n333: \n334:   it('without background runs synchronously and never creates a job', async () => {\n335:     const result = await scanHandler.handleMemoryIndexScan({\n336:       includeConstitutional: false,\n337:       includeSpecDocs: true,\n338:       incremental: false,\n339:       force: false,\n340:     });\n341: \n342:     const { data } = parseEnvelope(result);\n343:     expect(data.status).toBe('complete');\n344:     expect(data.jobId).toBeUndefined();\n345:     expect(jobStore.createMaintenanceJob).not.toHaveBeenCalled();\n346:   });\n347: \n348:   it('memory_index_scan_status echoes the terminal result and returns E404 for unknown ids', async () => {\n349:     const started = await scanHandler.handleMemoryIndexScan({\n350:       background: true,\n351:       includeConstitutional: false,\n352:       includeSpecDocs: true,\n353:       incremental: false,\n354:       force: false,\n355:     });\n356:     const jobId = parseEnvelope(started).data.jobId as string;\n357:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n358: \n359:     const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n360:     const statusData = parseEnvelope(statusRes).data;\n361:     expect(statusData.state).toBe('complete');\n362:     const echoed = statusData.result as Record<string, unknown>;\n363:     expect(echoed.status).toBe('complete');\n364: \n365:     const missing = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId: 'job_missing' });\n366:     // The error envelope carries the code at the top level of the payload.\n367:     const missingPayload = JSON.parse(missing.content[0].text) as { code?: string };\n368:     expect(missingPayload.code).toBe('E404');\n369:   });\n370: \n371:   it('counts a cancelled file as neither failed nor success', async () => {\n372:     // A file whose worker returns 'cancelled' (operator-requested stop mid-batch)\n373:     // must not inflate the failure tally — the cancel is not a file error.\n374:     mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'cancelled' });\n375: \n376:     const result = await scanHandler.handleMemoryIndexScan({\n377:       includeConstitutional: false,\n378:       includeSpecDocs: true,\n379:       incremental: false,\n380:       force: false,\n381:     });\n382: \n383:     const { data } = parseEnvelope(result);\n384:     expect(data.failed).toBe(0);\n385:     expect(data.indexed).toBe(0);\n386:     expect(data.updated).toBe(0);\n387:   });\n388: \n389:   it('instruments the empty-files tail phases via timedPhase (onPhase markers)', async () => {\n390:     // No discoverable files routes through the empty-files branch; that branch must\n391:     // still fire onPhase for each tail maintenance phase so the busy marker refreshes\n392:     // and per-phase timing is emitted — symmetry with the main scan path.\n393:     mocks.mockFindSpecDocuments.mockReturnValue([]);\n394:     mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n395: \n396:     const started = await scanHandler.handleMemoryIndexScan({\n397:       background: true,\n398:       includeConstitutional: false,\n399:       includeSpecDocs: true,\n400:       incremental: false,\n401:       force: false,\n402:     });\n403:     const jobId = parseEnvelope(started).data.jobId as string;\n404:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n405: \n406:     const phases = jobStore.setJobPhase.mock.calls.map((call) => call[1]);\n407:     expect(phases).toContain('orphan-sweep');\n408:     expect(phases).toContain('enrichment-repair');\n409:     expect(phases).toContain('near-dup-repair');\n410:     expect(phases).toContain('trigger-backfill');\n411: \n412:     // The empty-files branch never enters the indexing loop.\n413:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n414:     const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n415:     const echoed = parseEnvelope(statusRes).data.result as Record<string, unknown>;\n416:     expect(echoed.status).toBe('complete');\n417:   });\n418: \n419:   it('cancel stops the runner at a phase boundary, releases the lease, and is idempotent', async () => {\n420:     const { gate, release } = createBatchGate();\n421:     mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n422:       await gate;\n423:       return Promise.all(files.map(worker));\n424:     });\n425: \n426:     const started = await scanHandler.handleMemoryIndexScan({\n427:       background: true,\n428:       includeConstitutional: false,\n429:       includeSpecDocs: true,\n430:       incremental: false,\n431:       force: false,\n432:     });\n433:     const jobId = parseEnvelope(started).data.jobId as string;\n434: \n435:     // Runner parks in the indexing phase, before any file work.\n436:     await waitFor(() => jobStore.jobs.get(jobId)?.phase === 'indexing');\n437: \n438:     const cancelRes = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n439:     expect(parseEnvelope(cancelRes).data.cancelRequested).toBe(true);\n440: \n441:     release();\n442:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'cancelled');\n443:     expect(mocks.mockCompleteIndexScanLease).toHaveBeenCalled();\n444:     // Cancellation at the phase boundary must prevent the indexing work itself.\n445:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n446: \n447:     // Cancelling an already-terminal job is a no-op success.\n448:     const again = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n449:     expect(parseEnvelope(again).data.state).toBe('cancelled');\n450:   });\n451: });\n\n(End of file - total 451 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: Background index scan dispatch + status/cancel handlers\n// ───────────────────────────────────────────────────────────────\nimport { beforeEach, describe, expect, it, vi } from 'vitest';\nimport { setTimeout as delay } from 'node:timers/promises';\n\n// ──────────────────────────────────────────────────────────────\n// 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n// ──────────────────────────────────────────────────────────────\n\nconst mocks = vi.hoisted(() => ({\n  mockAcquireIndexScanLease: vi.fn(),\n  mockCompleteIndexScanLease: vi.fn(),\n  mockCheckDatabaseUpdated: vi.fn(),\n  mockProcessBatches: vi.fn(),\n  mockFindSpecDocuments: vi.fn((): string[] => []),\n  mockFindConstitutionalFiles: vi.fn((): string[] => []),\n  mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n  mockRequireDb: vi.fn(() => ({\n    prepare: vi.fn(() => ({","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: Background index scan dispatch + status/cancel handlers\n// ───────────────────────────────────────────────────────────────\nimport { beforeEach, describe, expect, it, vi } from 'vitest';\nimport { setTimeout as delay } from 'node:timers/promises';\n\n// ──────────────────────────────────────────────────────────────\n// 1. HOISTED MOCKS — must be declared before any vi.mock() calls\n// ──────────────────────────────────────────────────────────────\n\nconst mocks = vi.hoisted(() => ({\n  mockAcquireIndexScanLease: vi.fn(),\n  mockCompleteIndexScanLease: vi.fn(),\n  mockCheckDatabaseUpdated: vi.fn(),\n  mockProcessBatches: vi.fn(),\n  mockFindSpecDocuments: vi.fn((): string[] => []),\n  mockFindConstitutionalFiles: vi.fn((): string[] => []),\n  mockFindGraphMetadataFiles: vi.fn((): string[] => []),\n  mockRequireDb: vi.fn(() => ({\n    prepare: vi.fn(() => ({\n      all: vi.fn(() => []),\n      get: vi.fn(() => undefined),\n    })),\n  })),\n  mockCategorizeFilesForIndexing: vi.fn((files: string[]) => ({\n    toIndex: files,\n    toUpdate: [] as string[],\n    toSkip: [] as string[],\n    toDelete: [] as string[],\n  })),\n  mockBatchUpdateMtimes: vi.fn(() => ({ updated: 0 })),\n  mockListIndexedRecordIdsForDeletedPaths: vi.fn((): number[] => []),\n  mockDeleteMemory: vi.fn((): boolean => true),\n  mockGetDb: vi.fn(() => ({\n    prepare: vi.fn(() => ({\n      get: vi.fn(() => undefined),\n    })),\n  })),\n  mockRunPostMutationHooks: vi.fn(() => ({ latencyMs: 0 })),\n  mockIndexMemoryFile: vi.fn(async () => ({ status: 'indexed', id: 1, specFolder: 'specs/test' })),\n}));\n\n// In-memory maintenance job store standing in for the persisted SQLite store.\nconst jobStore = vi.hoisted(() => {\n  interface FakeJob {\n    id: string;\n    kind: string;\n    state: string;\n    phase: string | null;\n    progressTotal: number;\n    progressProcessed: number;\n    cancelRequested: boolean;\n    errors: Array<{ source: string; message: string; timestamp: string }>;\n    result: unknown;\n    payload: unknown;\n    createdAt: string;\n    updatedAt: string;\n  }\n  const jobs = new Map<string, FakeJob>();\n  let counter = 0;\n  return {\n    jobs,\n    createJobId: vi.fn(() => { counter += 1; return `job_test_${counter}`; }),\n    ensureMaintenanceJobsTable: vi.fn(),\n    createMaintenanceJob: vi.fn(async (args: { id: string; kind: string; payload?: unknown }) => {\n      const job: FakeJob = {\n        id: args.id,\n        kind: args.kind,\n        state: 'queued',\n        phase: null,\n        progressTotal: 0,\n        progressProcessed: 0,\n        cancelRequested: false,\n        errors: [],\n        result: null,\n        payload: args.payload ?? null,\n        createdAt: 'seed',\n        updatedAt: 'seed',\n      };\n      jobs.set(args.id, job);\n      return job;\n    }),\n    getMaintenanceJob: vi.fn((id: string) => jobs.get(id) ?? null),\n    setJobState: vi.fn(async (id: string, state: string) => {\n      const job = jobs.get(id);\n      if (job) job.state = state;\n      return job ?? null;\n    }),\n    setJobPhase: vi.fn(async (id: string, phase: string) => {\n      const job = jobs.get(id);\n      if (job) job.phase = phase;\n    }),\n    setJobProgress: vi.fn(async (id: string, progress: { processed: number; total: number }) => {\n      const job = jobs.get(id);\n      if (job) { job.progressProcessed = progress.processed; job.progressTotal = progress.total; }\n    }),\n    appendJobError: vi.fn(async (id: string, source: string, error: unknown) => {\n      const job = jobs.get(id);\n      if (job) job.errors.push({ source, message: String(error), timestamp: 'seed' });\n      return job ?? null;\n    }),\n    requestCancel: vi.fn(async (id: string) => {\n      const job = jobs.get(id);\n      if (job) job.cancelRequested = true;\n    }),\n    isCancelRequested: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n    isCancelRequestedFast: vi.fn((id: string) => jobs.get(id)?.cancelRequested ?? false),\n    completeJob: vi.fn(async (id: string, options: { state: string; result?: unknown }) => {\n      const job = jobs.get(id);\n      if (job) { job.state = options.state; job.result = options.result ?? null; }\n      return job ?? null;\n    }),\n    resetRunningJobsForKind: vi.fn(() => [] as string[]),\n    isTerminalJobState: vi.fn((state: string) => state === 'complete' || state === 'failed' || state === 'cancelled'),\n    MAX_STORED_ERRORS: 50,\n  };\n});\n\n// ──────────────────────────────────────────────────────────────\n// 2. MODULE MOCKS\n// ──────────────────────────────────────────────────────────────\n\nvi.mock('../lib/ops/job-store', () => jobStore);\n\nvi.mock('../core', () => ({\n  checkDatabaseUpdated: mocks.mockCheckDatabaseUpdated,\n}));\n\nvi.mock('../core/db-state', async (importOriginal) => {\n  const actual = await importOriginal<typeof import('../core/db-state')>();\n  return {\n    ...actual,\n    acquireIndexScanLease: mocks.mockAcquireIndexScanLease,\n    completeIndexScanLease: mocks.mockCompleteIndexScanLease,\n  };\n});\n\nvi.mock('../core/config', async (importOriginal) => {\n  const actual = await importOriginal<typeof import('../core/config')>();\n  return {\n    ...actual,\n    INDEX_SCAN_COOLDOWN: 60000,\n    DEFAULT_BASE_PATH: '/tmp/mock-workspace',\n    BATCH_SIZE: 5,\n    SERVER_DIR: '/tmp/mock-server',\n  };\n});\n\nvi.mock('../utils', () => ({\n  processBatches: mocks.mockProcessBatches,\n  requireDb: mocks.mockRequireDb,\n  toErrorMessage: (error: unknown) => error instanceof Error ? error.message : String(error),\n}));\n\nvi.mock('../handlers/memory-index-discovery', () => ({\n  findSpecDocuments: mocks.mockFindSpecDocuments,\n  findConstitutionalFiles: mocks.mockFindConstitutionalFiles,\n  findGraphMetadataFiles: mocks.mockFindGraphMetadataFiles,\n  detectSpecLevel: vi.fn(() => null),\n}));\n\nvi.mock('../lib/providers/embeddings', () => ({\n  getEmbeddingProfile: vi.fn(() => null),\n}));\n\nvi.mock('../lib/storage/incremental-index', () => ({\n  categorizeFilesForIndexing: mocks.mockCategorizeFilesForIndexing,\n  batchUpdateMtimes: mocks.mockBatchUpdateMtimes,\n  listIndexedRecordIdsForDeletedPaths: mocks.mockListIndexedRecordIdsForDeletedPaths,\n}));\n\nvi.mock('../lib/search/vector-index', () => ({\n  deleteMemory: mocks.mockDeleteMemory,\n  getDb: mocks.mockGetDb,\n}));\n\nvi.mock('../handlers/mutation-hooks', () => ({\n  runPostMutationHooks: mocks.mockRunPostMutationHooks,\n}));\n\nvi.mock('../lib/response/envelope', () => ({\n  createMCPSuccessResponse: (payload: unknown) => ({\n    content: [{ type: 'text', text: JSON.stringify(payload) }],\n  }),\n  createMCPErrorResponse: (payload: unknown) => ({\n    content: [{ type: 'text', text: JSON.stringify(payload) }],\n  }),\n}));\n\nvi.mock('../handlers/memory-save', () => ({\n  indexMemoryFile: mocks.mockIndexMemoryFile,\n}));\n\nvi.mock('../lib/governance/scope-governance', () => ({\n  requiresGovernedIngest: vi.fn(() => false),\n  validateGovernedIngest: vi.fn(() => ({ allowed: true, issues: [] })),\n}));\n\nvi.mock('../lib/runtime/memory-runtime-guard', () => ({\n  ensureMemoryRuntimeInitialized: vi.fn(async () => undefined),\n}));\n\nvi.mock('../lib/utils/canonical-path', () => ({\n  getCanonicalPathKey: (p: string) => p,\n}));\n\nvi.mock('../handlers/memory-index-alias', () => ({\n  EMPTY_ALIAS_CONFLICT_SUMMARY: { groups: 0, divergentHashGroups: 0 },\n  createDefaultDivergenceReconcileSummary: () => ({ retriesScheduled: 0, escalated: 0, errors: [] }),\n  detectAliasConflictsFromIndex: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n  summarizeAliasConflicts: vi.fn(() => ({ groups: 0, divergentHashGroups: 0 })),\n  runDivergenceReconcileHooks: vi.fn(() => ({ retriesScheduled: 0, escalated: 0, errors: [] })),\n}));\n\nvi.mock('../lib/storage/checkpoints', () => ({\n  getRestoreBarrierStatus: vi.fn(() => null),\n  repairNeedsRebuildSentinel: vi.fn(() => ({\n    sentinelPresent: false,\n    attempted: false,\n    cleared: false,\n    summary: null,\n    error: null,\n  })),\n}));\n\n// ──────────────────────────────────────────────────────────────\n// 3. MODULES UNDER TEST (imported after all vi.mock() calls)\n// ──────────────────────────────────────────────────────────────\n\nimport * as scanHandler from '../handlers/memory-index';\nimport * as scanJobHandlers from '../handlers/memory-index-scan-jobs';\n\n// ──────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ──────────────────────────────────────────────────────────────\n\nconst TEST_FILE = '/tmp/mock-workspace/.opencode/specs/test/spec.md';\n\nasync function waitFor(predicate: () => boolean, timeoutMs = 3000): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() < deadline) {\n    if (predicate()) return;\n    await delay(10);\n  }\n  throw new Error('Timed out waiting for condition');\n}\n\nfunction parseEnvelope(response: { content: Array<{ text: string }> }): { data: Record<string, unknown> } {\n  return JSON.parse(response.content[0].text) as { data: Record<string, unknown> };\n}\n\nfunction createBatchGate(): { gate: Promise<void>; release: () => void } {\n  let release = (): void => {};\n  const gate = new Promise<void>((resolve) => { release = resolve; });\n  return { gate, release };\n}\n\n// ──────────────────────────────────────────────────────────────\n// 5. TESTS\n// ──────────────────────────────────────────────────────────────\n\ndescribe('memory_index_scan background dispatch', () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n    jobStore.jobs.clear();\n\n    mocks.mockAcquireIndexScanLease.mockResolvedValue({\n      acquired: true,\n      reason: 'ok',\n      waitSeconds: 0,\n      lastIndexScan: 0,\n      scanStartedAt: 0,\n      leaseExpiryMs: 120000,\n      cooldownMs: 60000,\n    });\n    mocks.mockCompleteIndexScanLease.mockResolvedValue(undefined);\n    mocks.mockCheckDatabaseUpdated.mockResolvedValue(false);\n    mocks.mockFindSpecDocuments.mockReturnValue([TEST_FILE]);\n    mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n    mocks.mockFindGraphMetadataFiles.mockReturnValue([]);\n    mocks.mockCategorizeFilesForIndexing.mockReturnValue({\n      toIndex: [TEST_FILE],\n      toUpdate: [],\n      toSkip: [],\n      toDelete: [],\n    });\n    mocks.mockBatchUpdateMtimes.mockReturnValue({ updated: 0 });\n    mocks.mockListIndexedRecordIdsForDeletedPaths.mockReturnValue([]);\n    mocks.mockDeleteMemory.mockReturnValue(true);\n    mocks.mockGetDb.mockReturnValue({\n      prepare: vi.fn(() => ({ get: vi.fn(() => undefined), all: vi.fn(() => []) })),\n    });\n    mocks.mockRunPostMutationHooks.mockReturnValue({ latencyMs: 0 });\n    mocks.mockRequireDb.mockReturnValue({\n      prepare: vi.fn(() => ({ all: vi.fn(() => []), get: vi.fn(() => undefined) })),\n    });\n    mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'indexed', id: 1, specFolder: 'specs/test' });\n    mocks.mockProcessBatches.mockImplementation(\n      async (files: string[], worker: (file: string) => Promise<unknown>) => Promise.all(files.map(worker)),\n    );\n  });\n\n  it('background:true returns a queued jobId immediately without blocking on the scan', async () => {\n    const { gate, release } = createBatchGate();\n    mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n      await gate;\n      return Promise.all(files.map(worker));\n    });\n\n    const result = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.background).toBe(true);\n    expect(data.state).toBe('queued');\n    expect(typeof data.jobId).toBe('string');\n\n    const jobId = data.jobId as string;\n    // The runner advances to 'running' but parks at the gated batch loop — the\n    // handler already returned, proving the call did not block on the scan.\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'running');\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n\n    release();\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n    expect(mocks.mockIndexMemoryFile).toHaveBeenCalledTimes(1);\n  });\n\n  it('without background runs synchronously and never creates a job', async () => {\n    const result = await scanHandler.handleMemoryIndexScan({\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.status).toBe('complete');\n    expect(data.jobId).toBeUndefined();\n    expect(jobStore.createMaintenanceJob).not.toHaveBeenCalled();\n  });\n\n  it('memory_index_scan_status echoes the terminal result and returns E404 for unknown ids', async () => {\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n\n    const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n    const statusData = parseEnvelope(statusRes).data;\n    expect(statusData.state).toBe('complete');\n    const echoed = statusData.result as Record<string, unknown>;\n    expect(echoed.status).toBe('complete');\n\n    const missing = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId: 'job_missing' });\n    // The error envelope carries the code at the top level of the payload.\n    const missingPayload = JSON.parse(missing.content[0].text) as { code?: string };\n    expect(missingPayload.code).toBe('E404');\n  });\n\n  it('counts a cancelled file as neither failed nor success', async () => {\n    // A file whose worker returns 'cancelled' (operator-requested stop mid-batch)\n    // must not inflate the failure tally — the cancel is not a file error.\n    mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'cancelled' });\n\n    const result = await scanHandler.handleMemoryIndexScan({\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.failed).toBe(0);\n    expect(data.indexed).toBe(0);\n    expect(data.updated).toBe(0);\n  });\n\n  it('instruments the empty-files tail phases via timedPhase (onPhase markers)', async () => {\n    // No discoverable files routes through the empty-files branch; that branch must\n    // still fire onPhase for each tail maintenance phase so the busy marker refreshes\n    // and per-phase timing is emitted — symmetry with the main scan path.\n    mocks.mockFindSpecDocuments.mockReturnValue([]);\n    mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n\n    const phases = jobStore.setJobPhase.mock.calls.map((call) => call[1]);\n    expect(phases).toContain('orphan-sweep');\n    expect(phases).toContain('enrichment-repair');\n    expect(phases).toContain('near-dup-repair');\n    expect(phases).toContain('trigger-backfill');\n\n    // The empty-files branch never enters the indexing loop.\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n    const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n    const echoed = parseEnvelope(statusRes).data.result as Record<string, unknown>;\n    expect(echoed.status).toBe('complete');\n  });\n\n  it('cancel stops the runner at a phase boundary, releases the lease, and is idempotent', async () => {\n    const { gate, release } = createBatchGate();\n    mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n      await gate;\n      return Promise.all(files.map(worker));\n    });\n\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n\n    // Runner parks in the indexing phase, before any file work.\n    await waitFor(() => jobStore.jobs.get(jobId)?.phase === 'indexing');\n\n    const cancelRes = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n    expect(parseEnvelope(cancelRes).data.cancelRequested).toBe(true);\n\n    release();\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'cancelled');\n    expect(mocks.mockCompleteIndexScanLease).toHaveBeenCalled();\n    // Cancellation at the phase boundary must prevent the indexing work itself.\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n\n    // Cancelling an already-terminal job is a no-op success.\n    const again = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n    expect(parseEnvelope(again).data.state).toBe('cancelled');\n  });\n});","lineStart":1,"lineEnd":451,"totalLines":451,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","time":{"start":1781756745019,"end":1781756745021}},"metadata":{"openai":{"itemId":"fc_0ea3ba2690057375016a3373483da88191ae8a9e39b47bc5cc"}},"id":"prt_ed8fa5529001Dn47IFpI1wTbr3","sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","messageID":"msg_ed8fa2900001pIY02o7PxE4xOe"}}
{"type":"tool_use","timestamp":1781756745133,"sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","part":{"type":"tool","tool":"read","callID":"call_QRLDoBmsPwx192LwRrBCqYHs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","offset":330,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts</path>\n<type>file</type>\n<content>\n330:     track(newPid!);\n331: \n332:     // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n333:     expect(newPid).not.toBe(orphanPid);\n334:     await waitForExit(orphanPid!, 10_000);\n335:     expect(isAlive(orphanPid!)).toBe(false);\n336:     await delay(800);\n337: \n338:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n339:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n340:     expect(dbWriters.length).toBe(1);\n341:   }, 60_000);\n342: \n343:   it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n344:     const paths = buildFakeRoot();\n345: \n346:     const owner = await startSession(paths, true);\n347:     expect(await statsOk(owner.client)).toBe(true);\n348:     const orphanPid = leaseDaemonPid(paths.base);\n349:     expect(orphanPid).toBeTypeOf('number');\n350:     track(orphanPid!);\n351: \n352:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n353:     owner.child.kill('SIGTERM');\n354:     await waitForExit(owner.child.pid!, 8_000);\n355:     await delay(1_200);\n356:     expect(isAlive(orphanPid!)).toBe(true);\n357: \n358:     // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n359:     // intentionally too busy to service the probe. The launcher resolves the marker dir from\n360:     // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n361:     writeFileSync(\n362:       join(paths.dbDir, '.maintenance-active.json'),\n363:       JSON.stringify({\n364:         childPid: orphanPid,\n365:         activeUntilMs: Date.now() + 60_000,\n366:         jobId: 'test',\n367:         refreshedAtIso: new Date().toISOString(),\n368:       }),\n369:     );\n370: \n371:     // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n372:     // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n373:     // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n374:     // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n375:     process.kill(orphanPid!, 'SIGSTOP');\n376: \n377:     // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n378:     // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n379:     // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n380:     // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n381:     const compete = await spawnCompetingLauncher(paths, {\n382:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n383:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n384:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n385:     });\n386:     await waitForExit(compete.child.pid!, 20_000);\n387:     const settled = compete.settled();\n388:     // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n389:     expect(settled.exited).toBe(true);\n390:     expect(settled.code).toBe(0);\n391:     expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n392:     expect(settled.stdout).toMatch(/maintenance-active/);\n393: \n394:     // Let the marked daemon run again so teardown and the writer checks see a normal process.\n395:     process.kill(orphanPid!, 'SIGCONT');\n396:     await delay(800);\n397: \n398:     // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n399:     // never reaped and respawned, despite the probe failing while it was stopped.\n400:     expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n401:     expect(isAlive(orphanPid!)).toBe(true);\n402: \n403:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n404:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n405:     expect(dbWriters.length).toBe(1);\n406:   }, 60_000);\n407: \n408:   it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n409:     const paths = buildFakeRoot();\n410: \n411:     const owner = await startSession(paths, true);\n412:     expect(await statsOk(owner.client)).toBe(true);\n413:     const orphanPid = leaseDaemonPid(paths.base);\n414:     expect(orphanPid).toBeTypeOf('number');\n415:     track(orphanPid!);\n416: \n417:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n418:     owner.child.kill('SIGTERM');\n419:     await waitForExit(owner.child.pid!, 8_000);\n420:     await delay(1_200);\n421:     expect(isAlive(orphanPid!)).toBe(true);\n422: \n423:     // Publish a STALE maintenance marker (already expired): it names the live child but its\n424:     // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n425:     writeFileSync(\n426:       join(paths.dbDir, '.maintenance-active.json'),\n427:       JSON.stringify({\n428:         childPid: orphanPid,\n429:         activeUntilMs: Date.now() - 1_000,\n430:         jobId: 'test',\n431:         refreshedAtIso: new Date().toISOString(),\n432:       }),\n433:     );\n434: \n435:     // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n436:     process.kill(orphanPid!, 'SIGSTOP');\n437: \n438:     // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n439:     const fresh = await startSession(paths, true, {\n440:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n441:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n442:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n443:     });\n444:     expect(await statsOk(fresh.client, 20_000)).toBe(true);\n445:     const newPid = leaseDaemonPid(paths.base);\n446:     expect(newPid).toBeTypeOf('number');\n447:     track(newPid!);\n448: \n449:     // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n450:     // and a fresh daemon replaced it.\n451:     expect(newPid).not.toBe(orphanPid);\n452:     // The reap SIGKILLs the stopped orphan, so it may already be gone — SIGCONT only to be sure a\n453:     // surviving stopped process is resumable for teardown; tolerate ESRCH when it is already reaped.\n454:     try { process.kill(orphanPid!, 'SIGCONT'); } catch { /* already reaped */ }\n455:     await waitForExit(orphanPid!, 10_000);\n456:     expect(isAlive(orphanPid!)).toBe(false);\n457:     await delay(800);\n458: \n459:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n\n(Showing lines 330-459 of 488. Use offset=460 to continue.)\n</content>","metadata":{"preview":"    track(newPid!);\n\n    // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","text":"    track(newPid!);\n\n    // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n    // intentionally too busy to service the probe. The launcher resolves the marker dir from\n    // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() + 60_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n    // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n    // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n    // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n    // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n    // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n    // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n    const compete = await spawnCompetingLauncher(paths, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    await waitForExit(compete.child.pid!, 20_000);\n    const settled = compete.settled();\n    // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n    expect(settled.exited).toBe(true);\n    expect(settled.code).toBe(0);\n    expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n    expect(settled.stdout).toMatch(/maintenance-active/);\n\n    // Let the marked daemon run again so teardown and the writer checks see a normal process.\n    process.kill(orphanPid!, 'SIGCONT');\n    await delay(800);\n\n    // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n    // never reaped and respawned, despite the probe failing while it was stopped.\n    expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a STALE maintenance marker (already expired): it names the live child but its\n    // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() - 1_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n    const fresh = await startSession(paths, true, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    expect(await statsOk(fresh.client, 20_000)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n\n    // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n    // and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    // The reap SIGKILLs the stopped orphan, so it may already be gone — SIGCONT only to be sure a\n    // surviving stopped process is resumable for teardown; tolerate ESRCH when it is already reaped.\n    try { process.kill(orphanPid!, 'SIGCONT'); } catch { /* already reaped */ }\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.","lineStart":330,"lineEnd":459,"totalLines":488,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","time":{"start":1781756745126,"end":1781756745132}},"metadata":{"openai":{"itemId":"fc_0ea3ba2690057375016a3373483db081918febd52d5a05fae5"}},"id":"prt_ed8fa555c001aPyLlKgfF8ixEj","sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","messageID":"msg_ed8fa2900001pIY02o7PxE4xOe"}}
