{"type":"tool_use","timestamp":1781764106697,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_r7lQiQ55dJwQD0ObDdFhbh0R","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/session/session-manager.ts","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/session/session-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Session Manager\n3: // ───────────────────────────────────────────────────────────────\n4: import crypto from 'crypto';\n5: import fs from 'fs';\n6: import path from 'path';\n7: \n8: // Import working-memory for immediate cleanup on session end (GAP 2).\n9: import * as workingMemory from '../cognitive/working-memory.js';\n10: import { runMemoryRetentionSweep } from '../governance/memory-retention-sweep.js';\n11: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n12: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n13: \n14: import type BetterSqlite from 'better-sqlite3';\n15: import type { DatabaseExtended as Database } from '@spec-kit/shared/types';\n16: \n17: // Feature catalog: Session-manager transaction gap fixes\n18: \n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. TYPES\n22: ──────────────────────────────────────────────────────────────── */\n23: \n24: interface SessionConfig {\n25:   sessionTtlMinutes: number;\n26:   maxEntriesPerSession: number;\n27:   enabled: boolean;\n28:   dbUnavailableMode: 'allow' | 'block';\n29: }\n30: \n31: interface InitResult {\n32:   success: boolean;\n33:   error?: string;\n34: }\n35: \n36: interface MemoryInput {\n37:   id?: number;\n38:   file_path?: string;\n39:   anchorId?: string;\n40:   anchor_id?: string;\n41:   content_hash?: string;\n42:   title?: string;\n43: }\n44: \n45: interface MarkResult {\n46:   success: boolean;\n47:   hash?: string;\n48:   skipped?: boolean;\n49:   error?: string;\n50: }\n51: \n52: interface MarkBatchResult {\n53:   success: boolean;\n54:   markedCount: number;\n55:   skipped?: boolean;\n56:   error?: string;\n57: }\n58: \n59: interface SessionStats {\n60:   totalSent: number;\n61:   oldestEntry: string | null;\n62:   newestEntry: string | null;\n63: }\n64: \n65: interface FilterResult {\n66:   filtered: MemoryInput[];\n67:   dedupStats: {\n68:     enabled: boolean;\n69:     filtered: number;\n70:     total: number;\n71:     tokenSavingsEstimate?: string;\n72:     sessionId?: string;\n73:   };\n74: }\n75: \n76: interface CleanupResult {\n77:   success: boolean;\n78:   deletedCount: number;\n79: }\n80: \n81: interface StaleCleanupResult {\n82:   success: boolean;\n83:   workingMemoryDeleted: number;\n84:   sentMemoriesDeleted: number;\n85:   sessionStateDeleted: number;\n86:   errors: string[];\n87: }\n88: \n89: interface SessionState {\n90:   sessionId: string;\n91:   status: string;\n92:   specFolder: string | null;\n93:   currentTask: string | null;\n94:   lastAction: string | null;\n95:   contextSummary: string | null;\n96:   pendingWork: string | null;\n97:   tenantId: string | null;\n98:   userId: string | null;\n99:   agentId: string | null;\n100:   data: Record<string, unknown> | null;\n101:   createdAt: string;\n102:   updatedAt: string;\n103:   _recovered: boolean;\n104: }\n105: \n106: interface SessionIdentityScope {\n107:   tenantId?: string | null;\n108:   userId?: string | null;\n109:   agentId?: string | null;\n110: }\n111: \n112: interface SessionStateInput extends SessionIdentityScope {\n113:   specFolder?: string | null;\n114:   currentTask?: string | null;\n115:   lastAction?: string | null;\n116:   contextSummary?: string | null;\n117:   pendingWork?: string | null;\n118:   data?: Record<string, unknown> | null;\n119: }\n120: \n121: interface RecoverResult {\n122:   success: boolean;\n123:   state?: SessionState | null;\n124:   _recovered?: boolean;\n125:   error?: string;\n126: }\n127: \n128: interface InterruptedSession {\n129:   sessionId: string;\n130:   specFolder: string | null;\n131:   currentTask: string | null;\n132:   lastAction: string | null;\n133:   contextSummary: string | null;\n134:   pendingWork: string | null;\n135:   updatedAt: string;\n136: }\n137: \n138: interface InterruptedSessionsResult {\n139:   success: boolean;\n140:   sessions: InterruptedSession[];\n141:   error?: string;\n142: }\n143: \n144: interface ResetResult {\n145:   success: boolean;\n146:   interruptedCount: number;\n147:   error?: string;\n148: }\n149: \n150: interface CheckpointResult {\n151:   success: boolean;\n152:   filePath?: string;\n153:   note?: string;\n154:   error?: string;\n155: }\n156: \n157: interface ContinueSessionInput {\n158:   sessionId: string;\n159:   specFolder?: string | null;\n160:   currentTask?: string | null;\n161:   lastAction?: string | null;\n162:   contextSummary?: string | null;\n163:   pendingWork?: string | null;\n164:   tenantId?: string | null;\n165:   userId?: string | null;\n166:   agentId?: string | null;\n167:   data?: Record<string, unknown> | null;\n168: }\n169: \n170: interface TrustedSessionResolution {\n171:   requestedSessionId: string | null;\n172:   effectiveSessionId: string;\n173:   trusted: boolean;\n174:   error?: string;\n175: }\n176: \n177: /* ───────────────────────────────────────────────────────────────\n178:    2. CONFIGURATION\n179: ──────────────────────────────────────────────────────────────── */\n180: \n181: /**\n182:  * Session configuration with defaults from spec.md (mitigation)\n183:  * - Session TTL: 30 minutes\n184:  * - Cap at 100 entries per session\n185:  */\n186: const SESSION_CONFIG: SessionConfig = {\n187:   sessionTtlMinutes: parseInt(process.env.SESSION_TTL_MINUTES as string, 10) || 30,\n188:   maxEntriesPerSession: parseInt(process.env.SESSION_MAX_ENTRIES as string, 10) || 100,\n189:   enabled: process.env.DISABLE_SESSION_DEDUP !== 'true',\n190:   dbUnavailableMode: process.env.SESSION_DEDUP_DB_UNAVAILABLE_MODE === 'allow' ? 'allow' : 'block',\n191: };\n192: \n193: /* ───────────────────────────────────────────────────────────────\n194:    3. DATABASE REFERENCE\n195: ──────────────────────────────────────────────────────────────── */\n196: \n197: let db: Database | null = null;\n198: // Track periodic cleanup interval for expired sessions\n199: let cleanupInterval: ReturnType<typeof setInterval> | null = null;\n200: const CLEANUP_INTERVAL_MS = 30 * 60 * 1000; // 30 minutes\n201: \n202: // Track stale session cleanup interval (runs hourly)\n203: let staleCleanupInterval: ReturnType<typeof setInterval> | null = null;\n204: const STALE_CLEANUP_INTERVAL_MS = parseInt(process.env.STALE_CLEANUP_INTERVAL_MS as string, 10) || 60 * 60 * 1000; // 1 hour\n205: const STALE_SESSION_THRESHOLD_MS = parseInt(process.env.STALE_SESSION_THRESHOLD_MS as string, 10) || 24 * 60 * 60 * 1000; // 24 hours\n206: \n207: // Track governed memory retention cleanup interval (runs hourly by default).\n208: let retentionSweepInterval: ReturnType<typeof setInterval> | null = null;\n209: const RETENTION_SWEEP_ENABLED = process.env.SPECKIT_RETENTION_SWEEP !== 'false';\n210: const RETENTION_SWEEP_INTERVAL_MS = (() => {\n211:   const parsed = parseInt(process.env.SPECKIT_RETENTION_SWEEP_INTERVAL_MS as string, 10);\n212:   return Number.isInteger(parsed) && parsed > 0 ? parsed : 60 * 60 * 1000;\n213: })();\n214: \n215: function init(database: Database): InitResult {\n216:   if (!database) {\n217:     console.error('[session-manager] WARNING: init() called with null database');\n218:     return { success: false, error: 'Database reference is required' };\n219:   }\n220:   db = database;\n221: \n222:   const schemaResult = ensureSchema();\n223:   if (!schemaResult.success) {\n224:     return schemaResult;\n225:   }\n226: \n227:   cleanupExpiredSessions();\n228: \n229:   // Set up periodic cleanup instead of only running once at init (P4-18).\n230:   // Clear any existing interval first (in case of reinitializeDatabase).\n231:   if (cleanupInterval) {\n232:     clearRegisteredTimer(cleanupInterval);\n233:   }\n234:   cleanupInterval = registerInterval(() => {\n235:     try {\n236:       cleanupExpiredSessions();\n237:     } catch (err: unknown) {\n238:       const message = err instanceof Error ? err.message : String(err);\n239:       console.warn(`[session-manager] Periodic cleanup failed: ${message}`);\n240:     }\n241:   }, CLEANUP_INTERVAL_MS, { unref: true });\n242: \n243:   // Run stale session cleanup on startup and set up hourly interval\n244:   try {\n245:     cleanupStaleSessions();\n246:   } catch (err: unknown) {\n247:     const message = err instanceof Error ? err.message : String(err);\n248:     console.warn(`[session-manager] Initial stale session cleanup failed: ${message}`);\n249:   }\n250: \n251:   if (staleCleanupInterval) {\n252:     clearRegisteredTimer(staleCleanupInterval);\n253:   }\n254:   staleCleanupInterval = registerInterval(() => {\n255:     try {\n256:       cleanupStaleSessions();\n257:     } catch (err: unknown) {\n258:       const message = err instanceof Error ? err.message : String(err);\n259:       console.warn(`[session-manager] Periodic stale session cleanup failed: ${message}`);\n260:     }\n261:   }, STALE_CLEANUP_INTERVAL_MS, { unref: true });\n262: \n263:   if (retentionSweepInterval) {\n264:     clearRegisteredTimer(retentionSweepInterval);\n265:     retentionSweepInterval = null;\n266:   }\n267:   if (RETENTION_SWEEP_ENABLED) {\n268:     try {\n269:       runMemoryRetentionSweep(database as unknown as BetterSqlite.Database, { dryRun: false });\n270:     } catch (err: unknown) {\n271:       const message = err instanceof Error ? err.message : String(err);\n272:       console.warn(`[session-manager] Initial memory retention sweep failed: ${message}`);\n273:     }\n274: \n275:     retentionSweepInterval = registerInterval(() => {\n276:       try {\n277:         runMemoryRetentionSweep(database as unknown as BetterSqlite.Database, { dryRun: false });\n278:       } catch (err: unknown) {\n279:         const message = err instanceof Error ? err.message : String(err);\n280:         console.warn(`[session-manager] Periodic memory retention sweep failed: ${message}`);\n281:       }\n282:     }, RETENTION_SWEEP_INTERVAL_MS, { unref: true });\n283:   }\n284: \n285:   return { success: true };\n286: }\n287: \n288: function getDb(): Database | null {\n289:   return db;\n290: }\n291: \n292: function hasTable(tableName: string): boolean {\n293:   if (!db) return false;\n294: \n295:   try {\n296:     const row = db.prepare(\n297:       \"SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n298:     ).get(tableName) as { 1?: number } | undefined;\n299:     return Boolean(row);\n300:   } catch {\n301:     return false;\n302:   }\n303: }\n304: \n305: function hasSessionStateRecord(sessionId: string): boolean {\n306:   if (!db || !hasTable('session_state')) return false;\n307: \n308:   try {\n309:     const row = db.prepare(\n310:       'SELECT 1 FROM session_state WHERE session_id = ? LIMIT 1'\n311:     ).get(sessionId) as { 1?: number } | undefined;\n312:     return Boolean(row);\n313:   } catch (error: unknown) {\n314:     const message = error instanceof Error ? error.message : String(error);\n315:     console.warn(`[session-manager] hasSessionStateRecord failed: ${message}`);\n316:     return false;\n317:   }\n318: }\n319: \n320: function hasSentMemoryRecord(sessionId: string): boolean {\n321:   if (!db || !hasTable('session_sent_memories')) return false;\n322: \n323:   try {\n324:     const row = db.prepare(\n325:       'SELECT 1 FROM session_sent_memories WHERE session_id = ? LIMIT 1'\n326:     ).get(sessionId) as { 1?: number } | undefined;\n327:     return Boolean(row);\n328:   } catch (error: unknown) {\n329:     const message = error instanceof Error ? error.message : String(error);\n330:     console.warn(`[session-manager] hasSentMemoryRecord failed: ${message}`);\n331:     return false;\n332:   }\n333: }\n334: \n335: function isTrackedSession(sessionId: string): boolean {\n336:   if (!sessionId || typeof sessionId !== 'string') {\n337:     return false;\n338:   }\n339: \n340:   const normalizedSessionId = sessionId.trim();\n341:   if (normalizedSessionId.length === 0) {\n342:     return false;\n343:   }\n344: \n345:   return workingMemory.sessionExists(normalizedSessionId)\n346:     || hasSessionStateRecord(normalizedSessionId)\n347:     || hasSentMemoryRecord(normalizedSessionId);\n348: }\n349: \n350: function normalizeIdentityValue(value: unknown): string | null {\n351:   if (typeof value !== 'string') {\n352:     return null;\n353:   }\n354:   const normalizedValue = value.trim();\n355:   return normalizedValue.length > 0 ? normalizedValue : null;\n356: }\n357: \n358: function getSessionIdentityRecord(sessionId: string): {\n359:   tenantId: string | null;\n360:   userId: string | null;\n361:   agentId: string | null;\n362: } | null {\n363:   if (!db || !hasTable('session_state')) {\n364:     return null;\n365:   }\n366: \n367:   const row = db.prepare(`\n368:     SELECT tenant_id, user_id, agent_id\n369:     FROM session_state\n370:     WHERE session_id = ?\n371:     LIMIT 1\n372:   `).get(sessionId) as Record<string, unknown> | undefined;\n373: \n374:   if (!row) {\n375:     return null;\n376:   }\n377: \n378:   return {\n379:     tenantId: normalizeIdentityValue(row.tenant_id),\n380:     userId: normalizeIdentityValue(row.user_id),\n381:     agentId: normalizeIdentityValue(row.agent_id),\n382:   };\n383: }\n384: \n385: function getIdentityMismatch(\n386:   storedIdentity: { tenantId: string | null; userId: string | null; agentId: string | null },\n387:   scope: SessionIdentityScope = {},\n388: ): string | null {\n389:   const requestedTenantId = normalizeIdentityValue(scope.tenantId);\n390:   if (requestedTenantId && storedIdentity.tenantId !== requestedTenantId) {\n391:     return 'tenantId';\n392:   }\n393: \n394:   const requestedUserId = normalizeIdentityValue(scope.userId);\n395:   if (requestedUserId && storedIdentity.userId !== requestedUserId) {\n396:     return 'userId';\n397:   }\n398: \n399:   const requestedAgentId = normalizeIdentityValue(scope.agentId);\n400:   if (requestedAgentId && storedIdentity.agentId !== requestedAgentId) {\n401:     return 'agentId';\n402:   }\n403: \n404:   return null;\n405: }\n406: \n407: function hasCorroboratedIdentity(\n408:   storedIdentity: { tenantId: string | null; userId: string | null; agentId: string | null } | null,\n409: ): storedIdentity is { tenantId: string | null; userId: string | null; agentId: string | null } {\n410:   return Boolean(storedIdentity && (storedIdentity.tenantId || storedIdentity.userId || storedIdentity.agentId));\n411: }\n412: \n413: function resolveTrustedSession(\n414:   requestedSessionId: string | null = null,\n415:   scope: SessionIdentityScope = {},\n416: ): TrustedSessionResolution {\n417:   const normalizedSessionId = typeof requestedSessionId === 'string' && requestedSessionId.trim().length > 0\n418:     ? requestedSessionId.trim()\n419:     : null;\n420: \n421:   if (!normalizedSessionId) {\n422:     return {\n423:       requestedSessionId: null,\n424:       effectiveSessionId: crypto.randomUUID(),\n425:       trusted: false,\n426:     };\n427:   }\n428: \n429:   if (!isTrackedSession(normalizedSessionId)) {\n430:     return {\n431:       requestedSessionId: normalizedSessionId,\n432:       effectiveSessionId: '',\n433:       trusted: false,\n434:       error: `sessionId \"${normalizedSessionId}\" does not match a server-managed session. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.`,\n435:     };\n436:   }\n437: \n438:   const storedIdentity = getSessionIdentityRecord(normalizedSessionId);\n439:   if (!hasCorroboratedIdentity(storedIdentity)) {\n440:     return {\n441:       requestedSessionId: normalizedSessionId,\n442:       effectiveSessionId: '',\n443:       trusted: false,\n444:       error: `sessionId \"${normalizedSessionId}\" is not bound to a corroborated server identity. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.`,\n445:     };\n446:   }\n447: \n448:   const mismatch = getIdentityMismatch(storedIdentity, scope);\n449:   if (mismatch) {\n450:     return {\n451:       requestedSessionId: normalizedSessionId,\n452:       effectiveSessionId: '',\n453:       trusted: false,\n454:       error: `sessionId \"${normalizedSessionId}\" is bound to a different ${mismatch}. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.`,\n455:     };\n456:   }\n457: \n458:   return {\n459:     requestedSessionId: normalizedSessionId,\n460:     effectiveSessionId: normalizedSessionId,\n461:     trusted: true,\n462:   };\n463: }\n464: \n465: /* ───────────────────────────────────────────────────────────────\n466:    4. SCHEMA MANAGEMENT\n467: ──────────────────────────────────────────────────────────────── */\n468: \n469: const SCHEMA_SQL = `\n470:   CREATE TABLE IF NOT EXISTS session_sent_memories (\n471:     session_id TEXT NOT NULL,\n472:     memory_hash TEXT NOT NULL,\n473:     memory_id INTEGER,\n474:     sent_at TEXT DEFAULT CURRENT_TIMESTAMP,\n475:     PRIMARY KEY (session_id, memory_hash)\n476:   );\n477: `;\n478: \n479: const INDEX_SQL: string[] = [\n480:   'CREATE INDEX IF NOT EXISTS idx_session_sent_session ON session_sent_memories(session_id);',\n481:   'CREATE INDEX IF NOT EXISTS idx_session_sent_time ON session_sent_memories(sent_at);',\n482: ];\n483: \n484: function ensureSchema(): InitResult {\n485:   if (!db) {\n486:     return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n487:   }\n488: \n489:   try {\n490:     db.exec(SCHEMA_SQL);\n491:     for (const indexSql of INDEX_SQL) {\n492:       db.exec(indexSql);\n493:     }\n494:     return { success: true };\n495:   } catch (error: unknown) {\n496:     const message = error instanceof Error ? error.message : String(error);\n497:     console.error(`[session-manager] Schema creation failed: ${message}`);\n498:     return { success: false, error: message };\n499:   }\n500: }\n\n(Showing lines 1-500 of 1477. Use offset=501 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Session Manager\n// ───────────────────────────────────────────────────────────────\nimport crypto from 'crypto';\nimport fs from 'fs';\nimport path from 'path';\n\n// Import working-memory for immediate cleanup on session end (GAP 2).\nimport * as workingMemory from '../cognitive/working-memory.js';\nimport { runMemoryRetentionSweep } from '../governance/memory-retention-sweep.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n\nimport type BetterSqlite from 'better-sqlite3';\nimport type { DatabaseExtended as Database } from '@spec-kit/shared/types';\n\n// Feature catalog: Session-manager transaction gap fixes\n\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/session/session-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Session Manager\n// ───────────────────────────────────────────────────────────────\nimport crypto from 'crypto';\nimport fs from 'fs';\nimport path from 'path';\n\n// Import working-memory for immediate cleanup on session end (GAP 2).\nimport * as workingMemory from '../cognitive/working-memory.js';\nimport { runMemoryRetentionSweep } from '../governance/memory-retention-sweep.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n\nimport type BetterSqlite from 'better-sqlite3';\nimport type { DatabaseExtended as Database } from '@spec-kit/shared/types';\n\n// Feature catalog: Session-manager transaction gap fixes\n\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface SessionConfig {\n  sessionTtlMinutes: number;\n  maxEntriesPerSession: number;\n  enabled: boolean;\n  dbUnavailableMode: 'allow' | 'block';\n}\n\ninterface InitResult {\n  success: boolean;\n  error?: string;\n}\n\ninterface MemoryInput {\n  id?: number;\n  file_path?: string;\n  anchorId?: string;\n  anchor_id?: string;\n  content_hash?: string;\n  title?: string;\n}\n\ninterface MarkResult {\n  success: boolean;\n  hash?: string;\n  skipped?: boolean;\n  error?: string;\n}\n\ninterface MarkBatchResult {\n  success: boolean;\n  markedCount: number;\n  skipped?: boolean;\n  error?: string;\n}\n\ninterface SessionStats {\n  totalSent: number;\n  oldestEntry: string | null;\n  newestEntry: string | null;\n}\n\ninterface FilterResult {\n  filtered: MemoryInput[];\n  dedupStats: {\n    enabled: boolean;\n    filtered: number;\n    total: number;\n    tokenSavingsEstimate?: string;\n    sessionId?: string;\n  };\n}\n\ninterface CleanupResult {\n  success: boolean;\n  deletedCount: number;\n}\n\ninterface StaleCleanupResult {\n  success: boolean;\n  workingMemoryDeleted: number;\n  sentMemoriesDeleted: number;\n  sessionStateDeleted: number;\n  errors: string[];\n}\n\ninterface SessionState {\n  sessionId: string;\n  status: string;\n  specFolder: string | null;\n  currentTask: string | null;\n  lastAction: string | null;\n  contextSummary: string | null;\n  pendingWork: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  data: Record<string, unknown> | null;\n  createdAt: string;\n  updatedAt: string;\n  _recovered: boolean;\n}\n\ninterface SessionIdentityScope {\n  tenantId?: string | null;\n  userId?: string | null;\n  agentId?: string | null;\n}\n\ninterface SessionStateInput extends SessionIdentityScope {\n  specFolder?: string | null;\n  currentTask?: string | null;\n  lastAction?: string | null;\n  contextSummary?: string | null;\n  pendingWork?: string | null;\n  data?: Record<string, unknown> | null;\n}\n\ninterface RecoverResult {\n  success: boolean;\n  state?: SessionState | null;\n  _recovered?: boolean;\n  error?: string;\n}\n\ninterface InterruptedSession {\n  sessionId: string;\n  specFolder: string | null;\n  currentTask: string | null;\n  lastAction: string | null;\n  contextSummary: string | null;\n  pendingWork: string | null;\n  updatedAt: string;\n}\n\ninterface InterruptedSessionsResult {\n  success: boolean;\n  sessions: InterruptedSession[];\n  error?: string;\n}\n\ninterface ResetResult {\n  success: boolean;\n  interruptedCount: number;\n  error?: string;\n}\n\ninterface CheckpointResult {\n  success: boolean;\n  filePath?: string;\n  note?: string;\n  error?: string;\n}\n\ninterface ContinueSessionInput {\n  sessionId: string;\n  specFolder?: string | null;\n  currentTask?: string | null;\n  lastAction?: string | null;\n  contextSummary?: string | null;\n  pendingWork?: string | null;\n  tenantId?: string | null;\n  userId?: string | null;\n  agentId?: string | null;\n  data?: Record<string, unknown> | null;\n}\n\ninterface TrustedSessionResolution {\n  requestedSessionId: string | null;\n  effectiveSessionId: string;\n  trusted: boolean;\n  error?: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Session configuration with defaults from spec.md (mitigation)\n * - Session TTL: 30 minutes\n * - Cap at 100 entries per session\n */\nconst SESSION_CONFIG: SessionConfig = {\n  sessionTtlMinutes: parseInt(process.env.SESSION_TTL_MINUTES as string, 10) || 30,\n  maxEntriesPerSession: parseInt(process.env.SESSION_MAX_ENTRIES as string, 10) || 100,\n  enabled: process.env.DISABLE_SESSION_DEDUP !== 'true',\n  dbUnavailableMode: process.env.SESSION_DEDUP_DB_UNAVAILABLE_MODE === 'allow' ? 'allow' : 'block',\n};\n\n/* ───────────────────────────────────────────────────────────────\n   3. DATABASE REFERENCE\n──────────────────────────────────────────────────────────────── */\n\nlet db: Database | null = null;\n// Track periodic cleanup interval for expired sessions\nlet cleanupInterval: ReturnType<typeof setInterval> | null = null;\nconst CLEANUP_INTERVAL_MS = 30 * 60 * 1000; // 30 minutes\n\n// Track stale session cleanup interval (runs hourly)\nlet staleCleanupInterval: ReturnType<typeof setInterval> | null = null;\nconst STALE_CLEANUP_INTERVAL_MS = parseInt(process.env.STALE_CLEANUP_INTERVAL_MS as string, 10) || 60 * 60 * 1000; // 1 hour\nconst STALE_SESSION_THRESHOLD_MS = parseInt(process.env.STALE_SESSION_THRESHOLD_MS as string, 10) || 24 * 60 * 60 * 1000; // 24 hours\n\n// Track governed memory retention cleanup interval (runs hourly by default).\nlet retentionSweepInterval: ReturnType<typeof setInterval> | null = null;\nconst RETENTION_SWEEP_ENABLED = process.env.SPECKIT_RETENTION_SWEEP !== 'false';\nconst RETENTION_SWEEP_INTERVAL_MS = (() => {\n  const parsed = parseInt(process.env.SPECKIT_RETENTION_SWEEP_INTERVAL_MS as string, 10);\n  return Number.isInteger(parsed) && parsed > 0 ? parsed : 60 * 60 * 1000;\n})();\n\nfunction init(database: Database): InitResult {\n  if (!database) {\n    console.error('[session-manager] WARNING: init() called with null database');\n    return { success: false, error: 'Database reference is required' };\n  }\n  db = database;\n\n  const schemaResult = ensureSchema();\n  if (!schemaResult.success) {\n    return schemaResult;\n  }\n\n  cleanupExpiredSessions();\n\n  // Set up periodic cleanup instead of only running once at init (P4-18).\n  // Clear any existing interval first (in case of reinitializeDatabase).\n  if (cleanupInterval) {\n    clearRegisteredTimer(cleanupInterval);\n  }\n  cleanupInterval = registerInterval(() => {\n    try {\n      cleanupExpiredSessions();\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[session-manager] Periodic cleanup failed: ${message}`);\n    }\n  }, CLEANUP_INTERVAL_MS, { unref: true });\n\n  // Run stale session cleanup on startup and set up hourly interval\n  try {\n    cleanupStaleSessions();\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[session-manager] Initial stale session cleanup failed: ${message}`);\n  }\n\n  if (staleCleanupInterval) {\n    clearRegisteredTimer(staleCleanupInterval);\n  }\n  staleCleanupInterval = registerInterval(() => {\n    try {\n      cleanupStaleSessions();\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[session-manager] Periodic stale session cleanup failed: ${message}`);\n    }\n  }, STALE_CLEANUP_INTERVAL_MS, { unref: true });\n\n  if (retentionSweepInterval) {\n    clearRegisteredTimer(retentionSweepInterval);\n    retentionSweepInterval = null;\n  }\n  if (RETENTION_SWEEP_ENABLED) {\n    try {\n      runMemoryRetentionSweep(database as unknown as BetterSqlite.Database, { dryRun: false });\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[session-manager] Initial memory retention sweep failed: ${message}`);\n    }\n\n    retentionSweepInterval = registerInterval(() => {\n      try {\n        runMemoryRetentionSweep(database as unknown as BetterSqlite.Database, { dryRun: false });\n      } catch (err: unknown) {\n        const message = err instanceof Error ? err.message : String(err);\n        console.warn(`[session-manager] Periodic memory retention sweep failed: ${message}`);\n      }\n    }, RETENTION_SWEEP_INTERVAL_MS, { unref: true });\n  }\n\n  return { success: true };\n}\n\nfunction getDb(): Database | null {\n  return db;\n}\n\nfunction hasTable(tableName: string): boolean {\n  if (!db) return false;\n\n  try {\n    const row = db.prepare(\n      \"SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n    ).get(tableName) as { 1?: number } | undefined;\n    return Boolean(row);\n  } catch {\n    return false;\n  }\n}\n\nfunction hasSessionStateRecord(sessionId: string): boolean {\n  if (!db || !hasTable('session_state')) return false;\n\n  try {\n    const row = db.prepare(\n      'SELECT 1 FROM session_state WHERE session_id = ? LIMIT 1'\n    ).get(sessionId) as { 1?: number } | undefined;\n    return Boolean(row);\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[session-manager] hasSessionStateRecord failed: ${message}`);\n    return false;\n  }\n}\n\nfunction hasSentMemoryRecord(sessionId: string): boolean {\n  if (!db || !hasTable('session_sent_memories')) return false;\n\n  try {\n    const row = db.prepare(\n      'SELECT 1 FROM session_sent_memories WHERE session_id = ? LIMIT 1'\n    ).get(sessionId) as { 1?: number } | undefined;\n    return Boolean(row);\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[session-manager] hasSentMemoryRecord failed: ${message}`);\n    return false;\n  }\n}\n\nfunction isTrackedSession(sessionId: string): boolean {\n  if (!sessionId || typeof sessionId !== 'string') {\n    return false;\n  }\n\n  const normalizedSessionId = sessionId.trim();\n  if (normalizedSessionId.length === 0) {\n    return false;\n  }\n\n  return workingMemory.sessionExists(normalizedSessionId)\n    || hasSessionStateRecord(normalizedSessionId)\n    || hasSentMemoryRecord(normalizedSessionId);\n}\n\nfunction normalizeIdentityValue(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalizedValue = value.trim();\n  return normalizedValue.length > 0 ? normalizedValue : null;\n}\n\nfunction getSessionIdentityRecord(sessionId: string): {\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n} | null {\n  if (!db || !hasTable('session_state')) {\n    return null;\n  }\n\n  const row = db.prepare(`\n    SELECT tenant_id, user_id, agent_id\n    FROM session_state\n    WHERE session_id = ?\n    LIMIT 1\n  `).get(sessionId) as Record<string, unknown> | undefined;\n\n  if (!row) {\n    return null;\n  }\n\n  return {\n    tenantId: normalizeIdentityValue(row.tenant_id),\n    userId: normalizeIdentityValue(row.user_id),\n    agentId: normalizeIdentityValue(row.agent_id),\n  };\n}\n\nfunction getIdentityMismatch(\n  storedIdentity: { tenantId: string | null; userId: string | null; agentId: string | null },\n  scope: SessionIdentityScope = {},\n): string | null {\n  const requestedTenantId = normalizeIdentityValue(scope.tenantId);\n  if (requestedTenantId && storedIdentity.tenantId !== requestedTenantId) {\n    return 'tenantId';\n  }\n\n  const requestedUserId = normalizeIdentityValue(scope.userId);\n  if (requestedUserId && storedIdentity.userId !== requestedUserId) {\n    return 'userId';\n  }\n\n  const requestedAgentId = normalizeIdentityValue(scope.agentId);\n  if (requestedAgentId && storedIdentity.agentId !== requestedAgentId) {\n    return 'agentId';\n  }\n\n  return null;\n}\n\nfunction hasCorroboratedIdentity(\n  storedIdentity: { tenantId: string | null; userId: string | null; agentId: string | null } | null,\n): storedIdentity is { tenantId: string | null; userId: string | null; agentId: string | null } {\n  return Boolean(storedIdentity && (storedIdentity.tenantId || storedIdentity.userId || storedIdentity.agentId));\n}\n\nfunction resolveTrustedSession(\n  requestedSessionId: string | null = null,\n  scope: SessionIdentityScope = {},\n): TrustedSessionResolution {\n  const normalizedSessionId = typeof requestedSessionId === 'string' && requestedSessionId.trim().length > 0\n    ? requestedSessionId.trim()\n    : null;\n\n  if (!normalizedSessionId) {\n    return {\n      requestedSessionId: null,\n      effectiveSessionId: crypto.randomUUID(),\n      trusted: false,\n    };\n  }\n\n  if (!isTrackedSession(normalizedSessionId)) {\n    return {\n      requestedSessionId: normalizedSessionId,\n      effectiveSessionId: '',\n      trusted: false,\n      error: `sessionId \"${normalizedSessionId}\" does not match a server-managed session. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.`,\n    };\n  }\n\n  const storedIdentity = getSessionIdentityRecord(normalizedSessionId);\n  if (!hasCorroboratedIdentity(storedIdentity)) {\n    return {\n      requestedSessionId: normalizedSessionId,\n      effectiveSessionId: '',\n      trusted: false,\n      error: `sessionId \"${normalizedSessionId}\" is not bound to a corroborated server identity. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.`,\n    };\n  }\n\n  const mismatch = getIdentityMismatch(storedIdentity, scope);\n  if (mismatch) {\n    return {\n      requestedSessionId: normalizedSessionId,\n      effectiveSessionId: '',\n      trusted: false,\n      error: `sessionId \"${normalizedSessionId}\" is bound to a different ${mismatch}. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.`,\n    };\n  }\n\n  return {\n    requestedSessionId: normalizedSessionId,\n    effectiveSessionId: normalizedSessionId,\n    trusted: true,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. SCHEMA MANAGEMENT\n──────────────────────────────────────────────────────────────── */\n\nconst SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS session_sent_memories (\n    session_id TEXT NOT NULL,\n    memory_hash TEXT NOT NULL,\n    memory_id INTEGER,\n    sent_at TEXT DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (session_id, memory_hash)\n  );\n`;\n\nconst INDEX_SQL: string[] = [\n  'CREATE INDEX IF NOT EXISTS idx_session_sent_session ON session_sent_memories(session_id);',\n  'CREATE INDEX IF NOT EXISTS idx_session_sent_time ON session_sent_memories(sent_at);',\n];\n\nfunction ensureSchema(): InitResult {\n  if (!db) {\n    return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n  }\n\n  try {\n    db.exec(SCHEMA_SQL);\n    for (const indexSql of INDEX_SQL) {\n      db.exec(indexSql);\n    }\n    return { success: true };\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[session-manager] Schema creation failed: ${message}`);\n    return { success: false, error: message };\n  }\n}","lineStart":1,"lineEnd":500,"totalLines":1477,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/session/session-manager.ts","time":{"start":1781764106681,"end":1781764106695}},"metadata":{"openai":{"itemId":"fc_0cc33a5ec2bedb78016a339009da108191ac2a530ebb8fd66f"}},"id":"prt_ed96aa6ab001uDY0p6nsWKAGJB","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed96a81f1001WIu7EsTvfb3IqE"}}
