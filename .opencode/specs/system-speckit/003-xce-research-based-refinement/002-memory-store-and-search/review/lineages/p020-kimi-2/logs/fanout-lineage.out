{"type":"tool_use","timestamp":1781721571377,"sessionID":"ses_1291f676affeVoh3Pb0kJSjTck","part":{"type":"tool","tool":"read","callID":"tool_wN9MYi5O0gwAbQwtTIXLfEVI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Maintenance-Active Marker\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Signals the launcher that this daemon is busy-by-design (a background index\n5: // scan or a background-embedding burst) so a competing launcher adopts it\n6: // instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n7: // and refuses to reap a live daemon that holds a fresh marker (see the\n8: // shouldAdoptDespiteProbe guard in the launcher supervision lib).\n9: //\n10: // Reference-counted: the scan and the embedding queue can overlap (the scan\n11: // defers embeddings the queue then drains), so the marker stays present while\n12: // ANY maintenance source is active and is removed only when the last one ends.\n13: // A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n14: // becomes reapable again.\n15: \n16: import { rmSync } from 'node:fs';\n17: import path from 'node:path';\n18: \n19: import { DATABASE_DIR } from '../../core/config.js';\n20: import { atomicWriteFile } from './transaction-manager.js';\n21: \n22: const MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n23: // The TTL must exceed the longest single synchronous phase that cannot fire the\n24: // refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\n25: const MAINTENANCE_MARKER_TTL_MS = 180_000;\n26: const MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n27: \n28: export interface MaintenanceMarkerHandle {\n29:   // Refresh at a known progress point too: a non-yielding phase cannot fire the\n30:   // interval timer, so it only gets the refresh its caller makes explicitly.\n31:   refresh(): void;\n32:   // Idempotent. Decrements the active count and removes the marker at zero.\n33:   end(): void;\n34: }\n35: \n36: let activeCount = 0;\n37: let refreshTimer: ReturnType<typeof setInterval> | null = null;\n38: let activeLabels: string[] = [];\n39: \n40: function markerPath(): string {\n41:   return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n42: }\n43: \n44: function writeMarker(): void {\n45:   atomicWriteFile(markerPath(), `${JSON.stringify({\n46:     childPid: process.pid,\n47:     activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n48:     labels: activeLabels,\n49:     refreshedAtIso: new Date().toISOString(),\n50:   }, null, 2)}\\n`);\n51: }\n52: \n53: /**\n54:  * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n55:  * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n56:  * overlap with other maintenance sources.\n57:  */\n58: export function beginMaintenance(label: string): MaintenanceMarkerHandle {\n59:   activeCount += 1;\n60:   activeLabels.push(label);\n61:   writeMarker();\n62:   if (!refreshTimer) {\n63:     refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n64:     refreshTimer.unref?.();\n65:   }\n66: \n67:   let ended = false;\n68:   return {\n69:     refresh(): void {\n70:       if (!ended && activeCount > 0) writeMarker();\n71:     },\n72:     end(): void {\n73:       if (ended) return;\n74:       ended = true;\n75:       activeCount = Math.max(0, activeCount - 1);\n76:       const idx = activeLabels.indexOf(label);\n77:       if (idx >= 0) activeLabels.splice(idx, 1);\n78:       if (activeCount === 0) {\n79:         if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n80:         try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n81:       }\n82:     },\n83:   };\n84: }\n85: \n86: // Test-only: reset module state between cases.\n87: export function __resetMaintenanceMarkerForTest(): void {\n88:   if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n89:   activeCount = 0;\n90:   activeLabels = [];\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Maintenance-Active Marker\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Maintenance-Active Marker\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';\n\nconst MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n// The TTL must exceed the longest single synchronous phase that cannot fire the\n// refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\nconst MAINTENANCE_MARKER_TTL_MS = 180_000;\nconst MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n\nexport interface MaintenanceMarkerHandle {\n  // Refresh at a known progress point too: a non-yielding phase cannot fire the\n  // interval timer, so it only gets the refresh its caller makes explicitly.\n  refresh(): void;\n  // Idempotent. Decrements the active count and removes the marker at zero.\n  end(): void;\n}\n\nlet activeCount = 0;\nlet refreshTimer: ReturnType<typeof setInterval> | null = null;\nlet activeLabels: string[] = [];\n\nfunction markerPath(): string {\n  return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n}\n\nfunction writeMarker(): void {\n  atomicWriteFile(markerPath(), `${JSON.stringify({\n    childPid: process.pid,\n    activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n    labels: activeLabels,\n    refreshedAtIso: new Date().toISOString(),\n  }, null, 2)}\\n`);\n}\n\n/**\n * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n * overlap with other maintenance sources.\n */\nexport function beginMaintenance(label: string): MaintenanceMarkerHandle {\n  activeCount += 1;\n  activeLabels.push(label);\n  writeMarker();\n  if (!refreshTimer) {\n    refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n    refreshTimer.unref?.();\n  }\n\n  let ended = false;\n  return {\n    refresh(): void {\n      if (!ended && activeCount > 0) writeMarker();\n    },\n    end(): void {\n      if (ended) return;\n      ended = true;\n      activeCount = Math.max(0, activeCount - 1);\n      const idx = activeLabels.indexOf(label);\n      if (idx >= 0) activeLabels.splice(idx, 1);\n      if (activeCount === 0) {\n        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n        try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n      }\n    },\n  };\n}\n\n// Test-only: reset module state between cases.\nexport function __resetMaintenanceMarkerForTest(): void {\n  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n  activeCount = 0;\n  activeLabels = [];\n}","lineStart":1,"lineEnd":91,"totalLines":91,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","time":{"start":1781721571356,"end":1781721571375}},"id":"prt_ed6e19d77001POnkmsK4ibvGM9","sessionID":"ses_1291f676affeVoh3Pb0kJSjTck","messageID":"msg_ed6e1726f001S3TgagxjSYy42L"}}
{"type":"tool_use","timestamp":1781721572012,"sessionID":"ses_1291f676affeVoh3Pb0kJSjTck","part":{"type":"tool","tool":"read","callID":"tool_S93nTBXW4PoXVQaONVdvD1ky","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Index\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: import path from 'path';\n5: import { createHash } from 'node:crypto';\n6: \n7: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n8:    1. CORE AND UTILS IMPORTS\n9: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\n13: import { beginMaintenance } from '../lib/storage/maintenance-marker.js';\n14: import { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\n15: import { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\n16: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n24:    2. LIB MODULE IMPORTS\n25: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n82:    4. TYPES\n83: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   orphanSwept: number;\n161:   orphanSweepFailed: number;\n162:   orphanSweepScanned: number;\n163:   orphanSweepNextCursor: number | null;\n164:   moveReconciled?: number;\n165:   files: ScanFileEntry[];\n166:   constitutional: {\n167:     found: number;\n168:     indexed: number;\n169:     alreadyIndexed: number;\n170:   };\n171:   incremental: {\n172:     enabled: boolean;\n173:     fast_path_skips: number;\n174:     mtime_changed: number;\n175:     metadataPromoter: {\n176:       processed: number;\n177:       resolved: number;\n178:       inserted: number;\n179:       skippedManual: number;\n180:       staleTombstoned: number;\n181:       staleDeleted: number;\n182:       warnings: number;\n183:     };\n184:   };\n185:   dedup: {\n186:     inputTotal: number;\n187:     uniqueTotal: number;\n188:     duplicatesSkipped: number;\n189:   };\n190:   aliasConflicts: AliasConflictSummary;\n191:   divergenceReconcile: DivergenceReconcileSummary;\n192:   checkpointRepair: CheckpointRepairReport;\n193:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n194:   warnings: string[];\n195:   capExceeded: DiscoveryCapExceeded;\n196: }\n197: \n198: interface CategorizedFiles {\n199:   toIndex: string[];\n200:   toUpdate: string[];\n201:   toSkip: string[];\n202:   toDelete: string[];\n203: }\n204: \n205: interface ScanKeyOptions {\n206:   spec_folder: string | null;\n207:   force: boolean;\n208:   incremental: boolean;\n209:   include_constitutional: boolean;\n210:   include_spec_docs: boolean;\n211: }\n212: \n213: interface RecordDeleteResult {\n214:   deleted: number;\n215:   failed: number;\n216:   actions: StatediffAction[];\n217: }\n218: \n219: interface OrphanSweepDeleteResult {\n220:   swept: number;\n221:   failed: number;\n222:   scannedRows: number;\n223:   nextCursor: number | null;\n224:   actions: StatediffAction[];\n225: }\n226: \n227: interface OrphanSweepCandidates {\n228:   swept: number;\n229:   nextCursor: number | null;\n230:   scannedRows: number;\n231:   orphanRecordIds?: number[];\n232: }\n233: \n234: const ORPHAN_SWEEP_LIMIT = 200;\n235: \n236: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n237: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n238: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n239: // event-loop block from a phase that is merely slow but yields вҖ” the two need\n240: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n241: const LOOP_LAG_SAMPLE_MS = 250;\n242: const LOOP_LAG_WARN_MS = 1000;\n243: \n244: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n245:   return {\n246:     sentinelPresent: false,\n247:     attempted: false,\n248:     completed: 0,\n249:     failed: 0,\n250:     skipped: 0,\n251:     cleared: false,\n252:     error: null,\n253:   };\n254: }\n255: \n256: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n257:   try {\n258:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n259:       source: 'memory_index_scan',\n260:       actor: 'mcp:memory_index_scan',\n261:     });\n262:     return {\n263:       sentinelPresent: repair.sentinelPresent,\n264:       attempted: repair.attempted,\n265:       completed: repair.summary?.completed.length ?? 0,\n266:       failed: repair.summary?.failed.length ?? 0,\n267:       skipped: repair.summary?.skipped.length ?? 0,\n268:       cleared: repair.cleared,\n269:       error: repair.error,\n270:     };\n271:   } catch (error: unknown) {\n272:     return {\n273:       ...emptyCheckpointRepairReport(),\n274:       sentinelPresent: true,\n275:       attempted: true,\n276:       error: toErrorMessage(error),\n277:     };\n278:   }\n279: }\n280: \n281: function createScanKey(options: ScanKeyOptions): string {\n282:   const normalized = {\n283:     spec_folder: options.spec_folder ?? null,\n284:     force: !!options.force,\n285:     incremental: !!options.incremental,\n286:     include_constitutional: !!options.include_constitutional,\n287:     include_spec_docs: !!options.include_spec_docs,\n288:   };\n289: \n290:   return createHash('sha256')\n291:     .update(JSON.stringify(normalized))\n292:     .digest('hex')\n293:     .slice(0, 16);\n294: }\n295: \n296: interface ScanArgs {\n297:   specFolder?: string | null;\n298:   force?: boolean;\n299:   includeConstitutional?: boolean;\n300:   includeSpecDocs?: boolean;\n301:   incremental?: boolean;\n302:   // Opt-in: run the scan as a background job and return a jobId immediately.\n303:   background?: boolean;\n304:   tenantId?: string;\n305:   userId?: string;\n306:   agentId?: string;\n307:   sessionId?: string;\n308:   provenanceSource?: string;\n309:   provenanceActor?: string;\n310:   governedAt?: string;\n311:   retentionPolicy?: 'keep' | 'ephemeral';\n312:   deleteAfter?: string;\n313: }\n314: \n315: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n316:    5. SHARED INDEXING LOGIC\n317: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n318: \n319: import { indexMemoryFile } from './memory-save.js';\n320: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n321: import type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n322: \n323: /** Index a single memory file, delegating to the shared indexMemoryFile logic */\n324: async function indexSingleFile(\n325:   filePath: string,\n326:   force: boolean = false,\n327:   options?: {\n328:     qualityGateMode?: 'enforce' | 'warn-only';\n329:     fromScan?: boolean;\n330:     asyncEmbedding?: boolean;\n331:     governance?: GovernanceDecision;\n332:     provenance?: WriteProvenanceContext;\n333:   },\n334: ): Promise<IndexResult> {\n335:   return indexMemoryFile(filePath, {\n336:     force,\n337:     qualityGateMode: options?.qualityGateMode,\n338:     fromScan: options?.fromScan,\n339:     asyncEmbedding: options?.asyncEmbedding,\n340:     governance: options?.governance,\n341:     provenance: options?.provenance,\n342:   });\n343: }\n344: \n345: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n346:    6. MEMORY INDEX SCAN HANDLER\n347: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n348: \n349: // Hooks let a background runner observe cancellation and report phase/progress.\n350: // On the synchronous path every hook is undefined, so behavior is identical.\n351: interface ScanRunContext {\n352:   isCancelled?: () => boolean;\n353:   onPhase?: (phase: string) => void;\n354:   onProgress?: (progress: { processed: number; total: number }) => void;\n355: }\n356: \n357: // Pull the envelope.data field back out of an MCP response so status can echo it.\n358: function extractEnvelopeData(response: MCPResponse): unknown {\n359:   try {\n360:     const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n361:     if (typeof text !== 'string') return null;\n362:     const parsed = JSON.parse(text) as { data?: unknown };\n363:     return parsed?.data ?? null;\n364:   } catch (_error: unknown) {\n365:     return null;\n366:   }\n367: }\n368: \n369: // Persisted payload for debugging: scan shape only, no governance identifiers.\n370: function redactScanArgs(args: ScanArgs): Record<string, unknown> {\n371:   return {\n372:     specFolder: args.specFolder ?? null,\n373:     force: !!args.force,\n374:     includeConstitutional: args.includeConstitutional !== false,\n375:     includeSpecDocs: args.includeSpecDocs !== false,\n376:     incremental: args.incremental !== false,\n377:     background: true,\n378:   };\n379: }\n380: \n381: function cancelledScanEnvelope(scanKey: string): MCPResponse {\n382:   return createMCPSuccessResponse({\n383:     tool: 'memory_index_scan',\n384:     summary: 'Index scan cancelled before completion',\n385:     data: { status: 'cancelled', cancelled: true, scanKey },\n386:     hints: ['The scan was cancelled via memory_index_scan_cancel'],\n387:   });\n388: }\n389: \n390: /** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\n391: async function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n392:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n393:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n394:   if (restoreBarrier) {\n395:     recordMaintenanceRun('memory_index_scan', { status: 'error' });\n396:     return createMCPErrorResponse({\n397:       tool: 'memory_index_scan',\n398:       error: restoreBarrier.message,\n399:       code: restoreBarrier.code,\n400:       recovery: {\n401:         hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n402:         actions: ['Wait for the restore to finish', 'Retry the index scan'],\n403:         severity: 'warning',\n404:       },\n405:     });\n406:   }\n407: \n408:   const {\n409:     specFolder: spec_folder = null,\n410:     force = false,\n411:     includeConstitutional: include_constitutional = true,\n412:     includeSpecDocs: include_spec_docs = true,\n413:     incremental = true\n414:   } = args;\n415:   const scanKey = createScanKey({\n416:     spec_folder,\n417:     force,\n418:     incremental,\n419:     include_constitutional,\n420:     include_spec_docs,\n421:   });\n422:   const governedIngest = requiresGovernedIngest(args);\n423:   const governanceDecision = validateGovernedIngest(args);\n424:   if (!governanceDecision.allowed) {\n425:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n426:   }\n427: \n428:   // Pre-flight dimension check\n429:   try {\n430:     const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n431:     if (profile) {\n432:       console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n433:     }\n434:   } catch (dimCheckError: unknown) {\n435:     const message = toErrorMessage(dimCheckError);\n436:     console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n437:   }\n438: \n439:   await checkDatabaseUpdated();\n440: \n441:   // Atomic scan lease check.\n442:   // Reserve scan_started_at up front to avoid check-then-set race windows.\n443:   const now = Date.now();\n444:   const lease = await acquireIndexScanLease({\n445:     now,\n446:     cooldownMs: INDEX_SCAN_COOLDOWN,\n447:   });\n448:   if (!lease.acquired) {\n449:     let message: string;\n450:     if (lease.reason === 'lease_active') {\n451:       message = 'A scan is already in progress; this call coalesced onto it.';\n452:     } else if (lease.reason === 'contention') {\n453:       message = 'The index DB is briefly locked by another writer; retry shortly.';\n454:     } else {\n455:       message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n456:     }\n457:     recordMaintenanceRun('memory_index_scan', {\n458:       status: 'coalesced',\n459:       counts: { waitSeconds: lease.waitSeconds },\n460:       staleCandidates: 0,\n461:     });\n462:     return createMCPSuccessResponse({\n463:       tool: 'memory_index_scan',\n464:       summary: message,\n465:       data: {\n466:         success: true,\n467:         coalesced: true,\n468:         status: 'coalesced',\n469:         reason: lease.reason,\n470:         scanKey,\n471:         waitSeconds: lease.waitSeconds,\n472:         nextPollAfterMs: lease.waitSeconds * 1000,\n473:         message,\n474:       },\n475:       hints: [message],\n476:     });\n477:   }\n478: \n479:   let scanLeaseReleased = false;\n480:   const releaseScanLease = async (): Promise<void> => {\n481:     if (scanLeaseReleased) return;\n482:     scanLeaseReleased = true;\n483:     await completeIndexScanLease(Date.now());\n484:   };\n485: \n486:   const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n487: \n488:   // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n489:   // processBatches() runs all batches sequentially and may exceed the lease expiry\n490:   // window (each batch waits on embedding/API latency). Without a periodic refresh\n491:   // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n492:   // launch a second parallel scan. Refresh well inside the expiry window (a third of\n493:   // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n494:   // from holding the event loop open at shutdown; finally clears it before release.\n495:   const leaseExpiryMs = lease.leaseExpiryMs;\n496:   const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n497:   let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n498: \n499:   // Background scans pass an onPhase hook; the synchronous foreground path does not.\n500:   // Gate diagnostics on it so the synchronous path's behavior stays identical.\n501:   const instrument = typeof ctx.onPhase === 'function';\n502:   let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n503:   let maxLoopLagMs = 0;\n504: \n505:   try {\n506:   leaseHeartbeat = setInterval(() => {\n507:     refreshScanLease();\n508:   }, leaseHeartbeatMs);\n509:   leaseHeartbeat.unref?.();\n510: \n511:   if (instrument) {\n512:     let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n513:     loopLagTimer = setInterval(() => {\n514:       const sampledAt = Date.now();\n515:       const lag = sampledAt - loopLagExpectedAt;\n516:       loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n517:       if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n518:       if (lag > LOOP_LAG_WARN_MS) {\n519:         // A late sample means the loop was blocked since the prior tick; logged\n520:         // adjacent to the phase=... line of whatever phase just ran, so the daemon\n521:         // log timeline fingers the blocking phase.\n522:         console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n523:       }\n524:     }, LOOP_LAG_SAMPLE_MS);\n525:     loopLagTimer.unref?.();\n526:   }\n527: \n528:   if (ctx.isCancelled?.()) {\n529:     await releaseScanLease();\n530:     return cancelledScanEnvelope(scanKey);\n531:   }\n532:   ctx.onPhase?.('discovering');\n533: \n534:   const workspacePath: string = DEFAULT_BASE_PATH;\n535: \n536:   const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n537:   const specDocFiles = include_spec_docs\n538:     ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n539:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n540:   const graphMetadataFiles = include_spec_docs\n541:     ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n542:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n543:   const walkerWarnings = [\n544:     ...discoveryWarnings(specDocFiles),\n545:     ...discoveryWarnings(graphMetadataFiles),\n546:   ];\n547:   const walkerCapExceeded = mergeDiscoveryCapExceeded(\n548:     discoveryCaps(specDocFiles),\n549:     discoveryCaps(graphMetadataFiles),\n550:   );\n551: \n552:   const canonicalKeyCache = new Map<string, string>();\n553:   const getCachedKey = (filePath: string): string => {\n554:     const cached = canonicalKeyCache.get(filePath);\n555:     if (cached) {\n556:       return cached;\n557:     }\n558: \n559:     const canonicalKey = getCanonicalPathKey(filePath);\n560:     canonicalKeyCache.set(filePath, canonicalKey);\n561:     return canonicalKey;\n562:   };\n563: \n564:   const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n565:   const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n566:   const seenCanonicalFiles = new Set<string>();\n567:   const files: string[] = [];\n568: \n569:   for (const filePath of mergedFiles) {\n570:     const canonicalKey = getCachedKey(filePath);\n571:     if (seenCanonicalFiles.has(canonicalKey)) {\n572:       continue;\n573:     }\n574:     seenCanonicalFiles.add(canonicalKey);\n575:     files.push(filePath);\n576:   }\n577: \n578:   const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n579:   if (dedupDuplicatesSkipped > 0) {\n580:     console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n581:   }\n582: \n583:   const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n584:     if (recordIds.length === 0) {\n585:       return { deleted: 0, failed: 0, actions: [] };\n586:     }\n587: \n588:     let deleted = 0;\n589:     let failed = 0;\n590:     const actions: StatediffAction[] = [];\n591: \n592:     for (const staleRecordId of recordIds) {\n593:       try {\n594:         const database = vectorIndex.getDb();\n595:         const staleSnapshot = database?.prepare(\n596:           'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n597:         ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n598: \n599:         if (database) {\n600:           causalEdges.init(database);\n601:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n602:             reason: 'memory_index stale record cleanup',\n603:             command: 'memory-index.deleteIndexedRecordIds',\n604:             restoreContext: {\n605:               memoryId: staleRecordId,\n606:               specFolder: staleSnapshot?.spec_folder ?? null,\n607:               filePath: staleSnapshot?.file_path ?? null,\n608:             },\n609:           });\n610:         }\n611: \n612:         if (vectorIndex.deleteMemory(staleRecordId)) {\n613:           deleted++;\n614:           actions.push(createStatediffAction('delete', {\n615:             target: 'memory_index',\n616:             key: String(staleRecordId),\n617:             sourceOperation: 'scan',\n618:             oldStateHash: null,\n619:             newStateHash: null,\n620:             metadata: {\n621:               filePath: staleSnapshot?.file_path ?? null,\n622:               specFolder: staleSnapshot?.spec_folder ?? null,\n623:             },\n624:           }));\n625:           // Record DELETE history only after confirmed deletion.\n626:           try {\n627:             recordHistory(\n628:               staleRecordId,\n629:               'DELETE',\n630:               staleSnapshot?.file_path ?? null,\n631:               null,\n632:               'mcp:memory_index_scan',\n633:               staleSnapshot?.spec_folder ?? null,\n634:             );\n635:           } catch (_histErr: unknown) {\n636:             // History recording is best-effort\n637:           }\n638:         } else {\n639:           failed++;\n640:         }\n641:       } catch (_error: unknown) {\n642:         failed++;\n643:       }\n644:     }\n645: \n646:     return { deleted, failed, actions };\n647:   };\n648: \n649:   const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n650:     if (paths.length === 0) {\n651:       return { deleted: 0, failed: 0, actions: [] };\n652:     }\n653: \n654:     return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n655:   };\n656: \n657:   const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n658:     if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n659:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n660:     }\n661: \n662:     const sweepOrphanIndexRows = (incrementalIndex as {\n663:       sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n664:     }).sweepOrphanIndexRows;\n665: \n666:     if (typeof sweepOrphanIndexRows !== 'function') {\n667:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n668:     }\n669: \n670:     const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n671:     const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n672:     return {\n673:       swept: deleteResult.deleted,\n674:       failed: deleteResult.failed,\n675:       scannedRows: sweep.scannedRows,\n676:       nextCursor: sweep.nextCursor,\n677:       actions: deleteResult.actions,\n678:     };\n679:   };\n680: \n681:   const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n682:     try {\n683:       runPostMutationHooks('scan', { ...context, statediffActions: actions });\n684:     } catch (error: unknown) {\n685:       console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n686:     }\n687:   };\n688: \n689:   const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n690:     result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n691:   );\n692: \n693:   const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n694:     target: 'memory_index',\n695:     key: 'trigger-embedding-backfill',\n696:     sourceOperation: 'scan',\n697:     metadata: {\n698:       readyRows: result.readyRows,\n699:       failedRows: result.failedRows,\n700:       pendingRows: result.pendingRows,\n701:     },\n702:   });\n703: \n704:   const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n705:     if (actions.length === 0) {\n706:       return;\n707:     }\n708:     results.aliasConflicts = detectAliasConflictsFromIndex();\n709:     results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n710:   };\n711: \n712:   const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n713:     try {\n714:       const repairResult = await repairIncompleteMarkers(\n715:         { database: requireDb(), plannerMode: 'full-auto' },\n716:         { limit: BATCH_SIZE },\n717:       );\n718:       if (repairResult.failed > 0) {\n719:         console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n720:       }\n721:       return repairResult.repaired;\n722:     } catch (error: unknown) {\n723:       console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n724:       return 0;\n725:     }\n726:   };\n727: \n728:   const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n729:     if (!isMemoryIdempotencyEnabled()) {\n730:       return 0;\n731:     }\n732:     try {\n733:       const database = requireDb();\n734:       const rows = database.prepare(`\n735:         SELECT id, spec_folder, title, content_text, content_hash,\n736:                tenant_id, user_id, agent_id, session_id\n737:         FROM memory_index\n738:         WHERE parent_id IS NULL\n739:           AND embedding_status = 'success'\n740:           AND content_text IS NOT NULL\n741:           AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n742:         ORDER BY id ASC\n743:         LIMIT ?\n744:       `).all(BATCH_SIZE) as Array<{\n745:         id: number;\n746:         spec_folder: string;\n747:         title: string | null;\n748:         content_text: string;\n749:         content_hash: string | null;\n750:         tenant_id: string | null;\n751:         user_id: string | null;\n752:         agent_id: string | null;\n753:         session_id: string | null;\n754:       }>;\n755:       let repaired = 0;\n756:       for (const row of rows) {\n757:         try {\n758:           const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n759:           const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n760:           recordNearDuplicateCheck({\n761:             database,\n762:             memoryId: row.id,\n763:             specFolder: row.spec_folder,\n764:             contentHash: row.content_hash,\n765:             embedding,\n766:             scope: {\n767:               tenantId: row.tenant_id,\n768:               userId: row.user_id,\n769:               agentId: row.agent_id,\n770:               sessionId: row.session_id,\n771:             },\n772:           });\n773:           repaired++;\n774:         } catch (error: unknown) {\n775:           console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n776:         }\n777:       }\n778:       return repaired;\n779:     } catch (error: unknown) {\n780:       console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n781:       return 0;\n782:     }\n783:   };\n784: \n785:   if (files.length === 0) {\n786:     let staleDeleted = 0;\n787:     let staleDeleteFailed = 0;\n788:     const orphanSweepResult = runGlobalOrphanSweep();\n789:     const postInsertEnrichmentRepaired = await runPostInsertEnrichmentRepairBackfill();\n790:     await runNearDuplicateRepairBackfill();\n791: \n792:     if (incremental && !force) {\n793:       const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n794:       const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n795:       staleDeleted = staleDeleteResult.deleted;\n796:       staleDeleteFailed = staleDeleteResult.failed;\n797:       if (staleDeleted > 0) {\n798:         runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n799:       }\n800:     }\n801: \n802:     const triggerEmbeddingBackfill = await runTriggerEmbeddingBackfill(requireDb(), {\n803:       isCancelled: () => ctx.isCancelled?.() ?? false,\n804:     });\n805: \n806:     if (orphanSweepResult.swept > 0) {\n807:       runScanInvalidationHooks({\n808:         orphanSwept: orphanSweepResult.swept,\n809:         orphanSweepFailed: orphanSweepResult.failed,\n810:         operation: 'orphan-sweep',\n811:       }, orphanSweepResult.actions);\n812:     }\n813:     if (postInsertEnrichmentRepaired > 0) {\n814:       runScanInvalidationHooks({\n815:         postInsertEnrichmentRepaired,\n816:         operation: 'post-insert-enrichment-repair',\n817:       }, [createStatediffAction('upsert', {\n818:         target: 'graph_edge',\n819:         key: 'post-insert-enrichment-repair',\n820:         sourceOperation: 'scan',\n821:         metadata: { postInsertEnrichmentRepaired },\n822:       })]);\n823:     }\n824:     if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n825:       runScanInvalidationHooks({\n826:         triggerEmbeddingBackfill,\n827:         operation: 'trigger-embedding-backfill',\n828:       }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n829:     }\n830: \n831:     recordMaintenanceRun('memory_index_scan', {\n832:       status: 'success',\n833:       counts: {\n834:         scanned: 0,\n835:         indexed: 0,\n836:         updated: 0,\n837:         unchanged: 0,\n838:         failed: 0,\n839:         staleDeleted,\n840:         staleDeleteFailed,\n841:         orphanSwept: orphanSweepResult.swept,\n842:       },\n843:       staleCandidates: staleDeleted + staleDeleteFailed,\n844:     });\n845:     await releaseScanLease();\n846:     return createMCPSuccessResponse({\n847:       tool: 'memory_index_scan',\n848:       summary: 'No memory files found',\n849:       data: {\n850:         status: 'complete',\n851:         scanKey,\n852:         scanned: 0,\n853:         indexed: 0,\n854:         updated: 0,\n855:         unchanged: 0,\n856:         failed: 0,\n857:         staleDeleted,\n858:         staleDeleteFailed,\n859:         postInsertEnrichmentRepaired,\n860:         triggerEmbeddingBackfill,\n861:         orphanSwept: orphanSweepResult.swept,\n862:         orphanSweepFailed: orphanSweepResult.failed,\n863:         orphanSweepScanned: orphanSweepResult.scannedRows,\n864:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n865:         checkpointRepair,\n866:         warnings: walkerWarnings,\n867:         capExceeded: walkerCapExceeded,\n868:       },\n869:       hints: [\n870:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n871:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n872:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n873:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n874:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n875:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n876:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n877:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n878:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n879:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n880:         'Constitutional files go in .opencode/skills/*/constitutional/'\n881:       ]\n882:     });\n883:   }\n884: \n885:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n886: \n887:   const results: ScanResults = {\n888:     scanned: files.length,\n889:     indexed: 0,\n890:     updated: 0,\n891:     unchanged: 0,\n892:     failed: 0,\n893:     deferred: 0,\n894:     skipped_mtime: 0,\n895:     mtimeUpdates: 0,\n896:     staleDeleted: 0,\n897:     staleDeleteFailed: 0,\n898:     postInsertEnrichmentRepaired: 0,\n899:     orphanSwept: 0,\n900:     orphanSweepFailed: 0,\n901:     orphanSweepScanned: 0,\n902:     orphanSweepNextCursor: null,\n903:     files: [],\n904:     constitutional: {\n905:       found: constitutionalFiles.length,\n906:       indexed: 0,\n907:       alreadyIndexed: 0\n908:     },\n909:     incremental: {\n910:       enabled: incremental && !force,\n911:       fast_path_skips: 0,\n912:       mtime_changed: 0,\n913:       metadataPromoter: {\n914:         processed: 0,\n915:         resolved: 0,\n916:         inserted: 0,\n917:         skippedManual: 0,\n918:         staleTombstoned: 0,\n919:         staleDeleted: 0,\n920:         warnings: 0,\n921:       }\n922:     },\n923:     dedup: {\n924:       inputTotal: mergedFiles.length,\n925:       uniqueTotal: files.length,\n926:       duplicatesSkipped: dedupDuplicatesSkipped,\n927:     },\n928:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n929:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n930:     checkpointRepair,\n931:     warnings: walkerWarnings,\n932:     capExceeded: walkerCapExceeded,\n933:   };\n934:   const scanAppliedActions: StatediffAction[] = [];\n935: \n936:   let filesToIndex: string[] = files;\n937:   let filesToDelete: string[] = [];\n938: \n939:   if (incremental && !force) {\n940:     const startCategorize = Date.now();\n941:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n942: \n943:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n944:     filesToDelete = categorized.toDelete;\n945: \n946:     results.unchanged = categorized.toSkip.length;\n947:     results.skipped_mtime = categorized.toSkip.length;\n948:     results.incremental.fast_path_skips = categorized.toSkip.length;\n949:     results.incremental.mtime_changed = categorized.toUpdate.length;\n950: \n951:     for (const unchangedPath of categorized.toSkip) {\n952:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n953:         results.constitutional.alreadyIndexed++;\n954:       }\n955:     }\n956: \n957:     const categorizeTime = Date.now() - startCategorize;\n958:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n959:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n960:   }\n961: \n962:   // Attempt move reconciliation before full delete+reindex cycle.\n963:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n964:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n965:   // stored-document_type cross-checks; the matched row is updated in place.\n966:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n967:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n968:     if (moveResult.reconciled.length > 0) {\n969:       results.moveReconciled = moveResult.reconciled.length;\n970:       filesToDelete = moveResult.filteredToDelete;\n971:       filesToIndex = moveResult.filteredToIndex;\n972:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n973:     }\n974:   }\n975: \n976:   const plannedScanActions = [\n977:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n978:       target: 'memory_index',\n979:       key: getCachedKey(filePath),\n980:       sourceOperation: 'scan',\n981:       metadata: { filePath },\n982:     })),\n983:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n984:       target: 'memory_index',\n985:       key: getCachedKey(filePath),\n986:       sourceOperation: 'scan',\n987:       metadata: { filePath },\n988:     })),\n989:   ];\n990:   if (plannedScanActions.length > 0) {\n991:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n992:   }\n993: \n994:   // Track successfully indexed files for post-indexing mtime update.\n995:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n996:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n997:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n998:   // Before indexing would cause silent data loss вҖ” a failed file would be\n999:   // Marked \"already indexed\" and permanently skipped.\n1000:   const successfullyIndexedFiles: string[] = [];\n1001:   const scanBatchSize = BATCH_SIZE;\n1002: \n1003:   ctx.onPhase?.('indexing');\n1004:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1005: \n1006:   if (filesToIndex.length > 0) {\n1007:     let processedInScan = 0;\n1008:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1009:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1010:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1011:       if (ctx.isCancelled?.()) {\n1012:         return { status: 'cancelled' } as IndexResult;\n1013:       }\n1014:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1015:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1016:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1017:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1018:       // spec docs and pass them through warn-only mode so they index against the same\n1019:       // pipeline without the document-evidence requirements.\n1020:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1021:       // During force reindex, use warn-only for all files вҖ” the goal is to index\n1022:       // everything that has valid frontmatter, not to enforce template contracts on\n1023:       // older files created before current templates were established.\n1024:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1025:       const indexResult = await indexSingleFile(filePath, force, {\n1026:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1027:         fromScan: true,\n1028:         asyncEmbedding: true,\n1029:         governance: governedIngest ? governanceDecision : undefined,\n1030:       });\n1031:       processedInScan += 1;\n1032:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1033:       return indexResult;\n1034:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1035: \n1036:     for (let i = 0; i < batchResults.length; i++) {\n1037:       const result = batchResults[i];\n1038:       const filePath = filesToIndex[i];\n1039:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1040: \n1041:       if (result.error) {\n1042:         results.failed++;\n1043:         results.files.push({\n1044:           file: path.basename(filePath),\n1045:           filePath,\n1046:           status: 'failed',\n1047:           error: result.error,\n1048:           errorDetail: result.errorDetail\n1049:         });\n1050:       } else if (isIndexResult(result)) {\n1051:         const isSuccessfulStatus =\n1052:           result.status === 'success' ||\n1053:           result.status === 'indexed' ||\n1054:           result.status === 'updated' ||\n1055:           result.status === 'unchanged' ||\n1056:           result.status === 'reinforced' ||\n1057:           result.status === 'duplicate' ||\n1058:           result.status === 'deferred';\n1059:         if (!isSuccessfulStatus) {\n1060:           results.failed++;\n1061:         }\n1062: \n1063:         if (result.status === 'indexed') {\n1064:           results.indexed++;\n1065:           successfullyIndexedFiles.push(filePath);\n1066:           scanAppliedActions.push(createStatediffAction('insert', {\n1067:             target: 'memory_index',\n1068:             key: String(result.id ?? getCachedKey(filePath)),\n1069:             sourceOperation: 'scan',\n1070:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1071:           }));\n1072:         } else if (result.status === 'updated') {\n1073:           results.updated++;\n1074:           successfullyIndexedFiles.push(filePath);\n1075:           scanAppliedActions.push(createStatediffAction('upsert', {\n1076:             target: 'memory_index',\n1077:             key: String(result.id ?? getCachedKey(filePath)),\n1078:             sourceOperation: 'scan',\n1079:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1080:           }));\n1081:         } else if (result.status === 'unchanged') {\n1082:           results.unchanged++;\n1083:           successfullyIndexedFiles.push(filePath);\n1084:         } else if (result.status === 'reinforced') {\n1085:           results.updated++;\n1086:           successfullyIndexedFiles.push(filePath);\n1087:           scanAppliedActions.push(createStatediffAction('upsert', {\n1088:             target: 'memory_index',\n1089:             key: String(result.id ?? getCachedKey(filePath)),\n1090:             sourceOperation: 'scan',\n1091:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1092:           }));\n1093:         } else if (result.status === 'duplicate') {\n1094:           results.unchanged++;\n1095:           successfullyIndexedFiles.push(filePath);\n1096:         } else if (result.status === 'deferred') {\n1097:           results.indexed++;\n1098:           results.deferred++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('insert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         }\n1107: \n1108:         if (isConstitutional) {\n1109:           if (result.status === 'indexed') {\n1110:             results.constitutional.indexed++;\n1111:           } else if (result.status === 'unchanged') {\n1112:             results.constitutional.alreadyIndexed++;\n1113:           }\n1114:         }\n1115: \n1116:         if (result.status !== 'unchanged') {\n1117:           const rejectionDetail = !isSuccessfulStatus\n1118:             ? {\n1119:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1120:                   ? { rejectionCode: result.rejectionCode }\n1121:                   : {}),\n1122:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1123:                   ? { rejectionReason: result.rejectionReason }\n1124:                   : (typeof result.message === 'string' && result.message.length > 0\n1125:                     ? { rejectionReason: result.message }\n1126:                     : {})),\n1127:                 ...(typeof result.error === 'string' && result.error.length > 0\n1128:                   ? { error: result.error }\n1129:                   : {}),\n1130:               }\n1131:             : {};\n1132: \n1133:           results.files.push({\n1134:             file: path.basename(filePath),\n1135:             filePath,\n1136:             specFolder: result.specFolder,\n1137:             status: result.status,\n1138:             id: result.id,\n1139:             isConstitutional,\n1140:             ...rejectionDetail,\n1141:           });\n1142:         }\n1143:       } else {\n1144:         results.failed++;\n1145:         results.files.push({\n1146:           file: path.basename(filePath),\n1147:           filePath,\n1148:           status: 'failed',\n1149:           error: 'Unexpected batch result shape',\n1150:           errorDetail: JSON.stringify(result),\n1151:         });\n1152:       }\n1153:     }\n1154:   }\n1155: \n1156:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1157:   // Failed files keep their old mtime so they are retried on next scan.\n1158:   // This is the ONLY place where scan-triggered mtime updates occur.\n1159:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1160:   // Which rolls back atomically on failure вҖ” a complementary safety mechanism.\n1161:   if (successfullyIndexedFiles.length > 0) {\n1162:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1163:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1164:   }\n1165: \n1166:   if (include_spec_docs) {\n1167:     const database = requireDb();\n1168:     let promoterYieldCount = 0;\n1169:     for (const fileResult of results.files) {\n1170:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1171:       // that is the whole corpus, so without a periodic macrotask yield the event\n1172:       // loop is starved for the duration and no IPC (status, cancel, health,\n1173:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1174:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1175:       // inside one, so atomicity on the shared connection is preserved.\n1176:       if (++promoterYieldCount % 200 === 0) {\n1177:         if (ctx.isCancelled?.()) {\n1178:           return cancelledScanEnvelope(scanKey);\n1179:         }\n1180:         await new Promise<void>((resolve) => setImmediate(resolve));\n1181:       }\n1182:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1183:         continue;\n1184:       }\n1185:       try {\n1186:         const promotion = promoteMetadataEdges(database, {\n1187:           memoryId: fileResult.id,\n1188:           filePath: fileResult.filePath,\n1189:         });\n1190:         results.incremental.metadataPromoter.processed += promotion.processed;\n1191:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1192:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1193:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1194:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1195:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1196:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1197:         for (const warning of promotion.warnings) {\n1198:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1199:         }\n1200:       } catch (error: unknown) {\n1201:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1202:       }\n1203:     }\n1204:   }\n1205: \n1206:   if (ctx.isCancelled?.()) {\n1207:     return cancelledScanEnvelope(scanKey);\n1208:   }\n1209:   ctx.onPhase?.('post-processing');\n1210: \n1211:   if (filesToDelete.length > 0) {\n1212:     if (results.failed === 0) {\n1213:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1214:       results.staleDeleted = staleDeleteResult.deleted;\n1215:       results.staleDeleteFailed = staleDeleteResult.failed;\n1216:       scanAppliedActions.push(...staleDeleteResult.actions);\n1217:     } else {\n1218:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1219:     }\n1220:   }\n1221: \n1222:   // Time each un-yielded tail phase: because these phases do not yield, their\n1223:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n1224:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n1225:   // onPhase, which refreshes the busy marker вҖ” giving each phase a full TTL ahead.\n1226:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n1227:     ctx.onPhase?.(phase);\n1228:     if (!instrument) {\n1229:       return await fn();\n1230:     }\n1231:     const startedAt = Date.now();\n1232:     try {\n1233:       return await fn();\n1234:     } finally {\n1235:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n1236:     }\n1237:   };\n1238: \n1239:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1240:   results.orphanSwept = orphanSweepResult.swept;\n1241:   results.orphanSweepFailed = orphanSweepResult.failed;\n1242:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1243:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1244:   scanAppliedActions.push(...orphanSweepResult.actions);\n1245: \n1246:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1247:   if (results.postInsertEnrichmentRepaired > 0) {\n1248:     scanAppliedActions.push(createStatediffAction('upsert', {\n1249:       target: 'graph_edge',\n1250:       key: 'post-insert-enrichment-repair',\n1251:       sourceOperation: 'scan',\n1252:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1253:     }));\n1254:   }\n1255: \n1256:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1257:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1258:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1259:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1260:   }\n1261:   await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1262: \n1263:   // Create causal chains between spec folder documents.\n1264:   // Includes deferred indexing outcomes and incremental single-file updates.\n1265:   if (include_spec_docs) {\n1266:     try {\n1267:       // Determine which spec folders had spec document changes in this scan.\n1268:       // We use parsed document type (not basename) to avoid false positives\n1269:       // From memory/plan.md or similar filenames.\n1270:       const affectedSpecFolders = new Set<string>();\n1271:       for (const fileResult of results.files) {\n1272:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1273:           continue;\n1274:         }\n1275: \n1276:         if (!fileResult.filePath) {\n1277:           continue;\n1278:         }\n1279: \n1280:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1281:         if (\n1282:           docType !== 'memory' &&\n1283:           docType !== 'constitutional'\n1284:         ) {\n1285:           affectedSpecFolders.add(fileResult.specFolder);\n1286:         }\n1287:       }\n1288: \n1289:       if (affectedSpecFolders.size > 0) {\n1290:         const database = requireDb();\n1291:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1292:         initCausalEdges(database);\n1293: \n1294:         // Build full per-folder document map from DB (not just this scan's files).\n1295:         const selectDocIds = database.prepare(`\n1296:           SELECT document_type, MAX(id) AS id\n1297:           FROM memory_index\n1298:           WHERE spec_folder = ?\n1299:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1300:           GROUP BY document_type\n1301:         `);\n1302: \n1303:         let chainsCreated = 0;\n1304:         let foldersProcessed = 0;\n1305:         let chainYieldCount = 0;\n1306: \n1307:         for (const folder of affectedSpecFolders) {\n1308:           // Per-folder synchronous DB work; yield + cancel-check between folders so a\n1309:           // large affected set cannot block the event loop (same rationale as the\n1310:           // metadata-edge sweep above).\n1311:           if (++chainYieldCount % 50 === 0) {\n1312:             if (ctx.isCancelled?.()) {\n1313:               return cancelledScanEnvelope(scanKey);\n1314:             }\n1315:             await new Promise<void>((resolve) => setImmediate(resolve));\n1316:           }\n1317:           const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n1318:           const docIds: Record<string, number> = {};\n1319: \n1320:           for (const row of rows) {\n1321:             if (row.document_type && typeof row.id === 'number') {\n\n(Output capped at 50 KB. Showing lines 1-1321. Use offset=1322 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Index\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CORE AND UTILS IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Index\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CORE AND UTILS IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. LIB MODULE IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields вҖ” the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. SHARED INDEXING LOGIC\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { indexMemoryFile } from './memory-save.js';\nimport type { GovernanceDecision } from '../lib/governance/scope-governance.js';\nimport type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n\n/** Index a single memory file, delegating to the shared indexMemoryFile logic */\nasync function indexSingleFile(\n  filePath: string,\n  force: boolean = false,\n  options?: {\n    qualityGateMode?: 'enforce' | 'warn-only';\n    fromScan?: boolean;\n    asyncEmbedding?: boolean;\n    governance?: GovernanceDecision;\n    provenance?: WriteProvenanceContext;\n  },\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    force,\n    qualityGateMode: options?.qualityGateMode,\n    fromScan: options?.fromScan,\n    asyncEmbedding: options?.asyncEmbedding,\n    governance: options?.governance,\n    provenance: options?.provenance,\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. MEMORY INDEX SCAN HANDLER\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// Hooks let a background runner observe cancellation and report phase/progress.\n// On the synchronous path every hook is undefined, so behavior is identical.\ninterface ScanRunContext {\n  isCancelled?: () => boolean;\n  onPhase?: (phase: string) => void;\n  onProgress?: (progress: { processed: number; total: number }) => void;\n}\n\n// Pull the envelope.data field back out of an MCP response so status can echo it.\nfunction extractEnvelopeData(response: MCPResponse): unknown {\n  try {\n    const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n    if (typeof text !== 'string') return null;\n    const parsed = JSON.parse(text) as { data?: unknown };\n    return parsed?.data ?? null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\n// Persisted payload for debugging: scan shape only, no governance identifiers.\nfunction redactScanArgs(args: ScanArgs): Record<string, unknown> {\n  return {\n    specFolder: args.specFolder ?? null,\n    force: !!args.force,\n    includeConstitutional: args.includeConstitutional !== false,\n    includeSpecDocs: args.includeSpecDocs !== false,\n    incremental: args.incremental !== false,\n    background: true,\n  };\n}\n\nfunction cancelledScanEnvelope(scanKey: string): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: 'Index scan cancelled before completion',\n    data: { status: 'cancelled', cancelled: true, scanKey },\n    hints: ['The scan was cancelled via memory_index_scan_cancel'],\n  });\n}\n\n/** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\nasync function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    recordMaintenanceRun('memory_index_scan', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      recovery: {\n        hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the index scan'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    specFolder: spec_folder = null,\n    force = false,\n    includeConstitutional: include_constitutional = true,\n    includeSpecDocs: include_spec_docs = true,\n    incremental = true\n  } = args;\n  const scanKey = createScanKey({\n    spec_folder,\n    force,\n    incremental,\n    include_constitutional,\n    include_spec_docs,\n  });\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  // Pre-flight dimension check\n  try {\n    const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n    if (profile) {\n      console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n    }\n  } catch (dimCheckError: unknown) {\n    const message = toErrorMessage(dimCheckError);\n    console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n  }\n\n  await checkDatabaseUpdated();\n\n  // Atomic scan lease check.\n  // Reserve scan_started_at up front to avoid check-then-set race windows.\n  const now = Date.now();\n  const lease = await acquireIndexScanLease({\n    now,\n    cooldownMs: INDEX_SCAN_COOLDOWN,\n  });\n  if (!lease.acquired) {\n    let message: string;\n    if (lease.reason === 'lease_active') {\n      message = 'A scan is already in progress; this call coalesced onto it.';\n    } else if (lease.reason === 'contention') {\n      message = 'The index DB is briefly locked by another writer; retry shortly.';\n    } else {\n      message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n    }\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'coalesced',\n      counts: { waitSeconds: lease.waitSeconds },\n      staleCandidates: 0,\n    });\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: message,\n      data: {\n        success: true,\n        coalesced: true,\n        status: 'coalesced',\n        reason: lease.reason,\n        scanKey,\n        waitSeconds: lease.waitSeconds,\n        nextPollAfterMs: lease.waitSeconds * 1000,\n        message,\n      },\n      hints: [message],\n    });\n  }\n\n  let scanLeaseReleased = false;\n  const releaseScanLease = async (): Promise<void> => {\n    if (scanLeaseReleased) return;\n    scanLeaseReleased = true;\n    await completeIndexScanLease(Date.now());\n  };\n\n  const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n\n  // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n  // processBatches() runs all batches sequentially and may exceed the lease expiry\n  // window (each batch waits on embedding/API latency). Without a periodic refresh\n  // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n  // launch a second parallel scan. Refresh well inside the expiry window (a third of\n  // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n  // from holding the event loop open at shutdown; finally clears it before release.\n  const leaseExpiryMs = lease.leaseExpiryMs;\n  const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n  let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n\n  // Background scans pass an onPhase hook; the synchronous foreground path does not.\n  // Gate diagnostics on it so the synchronous path's behavior stays identical.\n  const instrument = typeof ctx.onPhase === 'function';\n  let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n  let maxLoopLagMs = 0;\n\n  try {\n  leaseHeartbeat = setInterval(() => {\n    refreshScanLease();\n  }, leaseHeartbeatMs);\n  leaseHeartbeat.unref?.();\n\n  if (instrument) {\n    let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n    loopLagTimer = setInterval(() => {\n      const sampledAt = Date.now();\n      const lag = sampledAt - loopLagExpectedAt;\n      loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n      if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n      if (lag > LOOP_LAG_WARN_MS) {\n        // A late sample means the loop was blocked since the prior tick; logged\n        // adjacent to the phase=... line of whatever phase just ran, so the daemon\n        // log timeline fingers the blocking phase.\n        console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n      }\n    }, LOOP_LAG_SAMPLE_MS);\n    loopLagTimer.unref?.();\n  }\n\n  if (ctx.isCancelled?.()) {\n    await releaseScanLease();\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('discovering');\n\n  const workspacePath: string = DEFAULT_BASE_PATH;\n\n  const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n  const specDocFiles = include_spec_docs\n    ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const graphMetadataFiles = include_spec_docs\n    ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const walkerWarnings = [\n    ...discoveryWarnings(specDocFiles),\n    ...discoveryWarnings(graphMetadataFiles),\n  ];\n  const walkerCapExceeded = mergeDiscoveryCapExceeded(\n    discoveryCaps(specDocFiles),\n    discoveryCaps(graphMetadataFiles),\n  );\n\n  const canonicalKeyCache = new Map<string, string>();\n  const getCachedKey = (filePath: string): string => {\n    const cached = canonicalKeyCache.get(filePath);\n    if (cached) {\n      return cached;\n    }\n\n    const canonicalKey = getCanonicalPathKey(filePath);\n    canonicalKeyCache.set(filePath, canonicalKey);\n    return canonicalKey;\n  };\n\n  const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n  const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n  const seenCanonicalFiles = new Set<string>();\n  const files: string[] = [];\n\n  for (const filePath of mergedFiles) {\n    const canonicalKey = getCachedKey(filePath);\n    if (seenCanonicalFiles.has(canonicalKey)) {\n      continue;\n    }\n    seenCanonicalFiles.add(canonicalKey);\n    files.push(filePath);\n  }\n\n  const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n  if (dedupDuplicatesSkipped > 0) {\n    console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n  }\n\n  const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n    if (recordIds.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    let deleted = 0;\n    let failed = 0;\n    const actions: StatediffAction[] = [];\n\n    for (const staleRecordId of recordIds) {\n      try {\n        const database = vectorIndex.getDb();\n        const staleSnapshot = database?.prepare(\n          'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n        ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n\n        if (database) {\n          causalEdges.init(database);\n          causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n            reason: 'memory_index stale record cleanup',\n            command: 'memory-index.deleteIndexedRecordIds',\n            restoreContext: {\n              memoryId: staleRecordId,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n              filePath: staleSnapshot?.file_path ?? null,\n            },\n          });\n        }\n\n        if (vectorIndex.deleteMemory(staleRecordId)) {\n          deleted++;\n          actions.push(createStatediffAction('delete', {\n            target: 'memory_index',\n            key: String(staleRecordId),\n            sourceOperation: 'scan',\n            oldStateHash: null,\n            newStateHash: null,\n            metadata: {\n              filePath: staleSnapshot?.file_path ?? null,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n            },\n          }));\n          // Record DELETE history only after confirmed deletion.\n          try {\n            recordHistory(\n              staleRecordId,\n              'DELETE',\n              staleSnapshot?.file_path ?? null,\n              null,\n              'mcp:memory_index_scan',\n              staleSnapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort\n          }\n        } else {\n          failed++;\n        }\n      } catch (_error: unknown) {\n        failed++;\n      }\n    }\n\n    return { deleted, failed, actions };\n  };\n\n  const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n    if (paths.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n  };\n\n  const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n    if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweepOrphanIndexRows = (incrementalIndex as {\n      sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n    }).sweepOrphanIndexRows;\n\n    if (typeof sweepOrphanIndexRows !== 'function') {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n    const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n    return {\n      swept: deleteResult.deleted,\n      failed: deleteResult.failed,\n      scannedRows: sweep.scannedRows,\n      nextCursor: sweep.nextCursor,\n      actions: deleteResult.actions,\n    };\n  };\n\n  const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n    try {\n      runPostMutationHooks('scan', { ...context, statediffActions: actions });\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n    }\n  };\n\n  const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n    result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n  );\n\n  const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n    target: 'memory_index',\n    key: 'trigger-embedding-backfill',\n    sourceOperation: 'scan',\n    metadata: {\n      readyRows: result.readyRows,\n      failedRows: result.failedRows,\n      pendingRows: result.pendingRows,\n    },\n  });\n\n  const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n    if (actions.length === 0) {\n      return;\n    }\n    results.aliasConflicts = detectAliasConflictsFromIndex();\n    results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n  };\n\n  const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n    try {\n      const repairResult = await repairIncompleteMarkers(\n        { database: requireDb(), plannerMode: 'full-auto' },\n        { limit: BATCH_SIZE },\n      );\n      if (repairResult.failed > 0) {\n        console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n      }\n      return repairResult.repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n    if (!isMemoryIdempotencyEnabled()) {\n      return 0;\n    }\n    try {\n      const database = requireDb();\n      const rows = database.prepare(`\n        SELECT id, spec_folder, title, content_text, content_hash,\n               tenant_id, user_id, agent_id, session_id\n        FROM memory_index\n        WHERE parent_id IS NULL\n          AND embedding_status = 'success'\n          AND content_text IS NOT NULL\n          AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n        ORDER BY id ASC\n        LIMIT ?\n      `).all(BATCH_SIZE) as Array<{\n        id: number;\n        spec_folder: string;\n        title: string | null;\n        content_text: string;\n        content_hash: string | null;\n        tenant_id: string | null;\n        user_id: string | null;\n        agent_id: string | null;\n        session_id: string | null;\n      }>;\n      let repaired = 0;\n      for (const row of rows) {\n        try {\n          const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n          const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n          recordNearDuplicateCheck({\n            database,\n            memoryId: row.id,\n            specFolder: row.spec_folder,\n            contentHash: row.content_hash,\n            embedding,\n            scope: {\n              tenantId: row.tenant_id,\n              userId: row.user_id,\n              agentId: row.agent_id,\n              sessionId: row.session_id,\n            },\n          });\n          repaired++;\n        } catch (error: unknown) {\n          console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n        }\n      }\n      return repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  if (files.length === 0) {\n    let staleDeleted = 0;\n    let staleDeleteFailed = 0;\n    const orphanSweepResult = runGlobalOrphanSweep();\n    const postInsertEnrichmentRepaired = await runPostInsertEnrichmentRepairBackfill();\n    await runNearDuplicateRepairBackfill();\n\n    if (incremental && !force) {\n      const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n      const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n      staleDeleted = staleDeleteResult.deleted;\n      staleDeleteFailed = staleDeleteResult.failed;\n      if (staleDeleted > 0) {\n        runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n      }\n    }\n\n    const triggerEmbeddingBackfill = await runTriggerEmbeddingBackfill(requireDb(), {\n      isCancelled: () => ctx.isCancelled?.() ?? false,\n    });\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss вҖ” a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files вҖ” the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        if (!isSuccessfulStatus) {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure вҖ” a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker вҖ” giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {\n          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {","lineStart":1,"lineEnd":1321,"totalLines":1322,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781721572004,"end":1781721572010}},"id":"prt_ed6e1a01c001f9NpZpwXXP11JN","sessionID":"ses_1291f676affeVoh3Pb0kJSjTck","messageID":"msg_ed6e1726f001S3TgagxjSYy42L"}}
{"type":"tool_use","timestamp":1781721572336,"sessionID":"ses_1291f676affeVoh3Pb0kJSjTck","part":{"type":"tool","tool":"read","callID":"tool_mNCoUzfDQltngJSdCep0sYUl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Retry Manager\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Embedding retry orchestrator\n5: // Node stdlib\n6: import * as fsPromises from 'fs/promises';\n7: \n8: // Internal modules\n9: import * as vectorIndex from '../search/vector-index.js';\n10: import { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\n11: import { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\n12: import { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\n13: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n14: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n15: import { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n16: \n17: // Type imports\n18: import type { MemoryDbRow } from '@spec-kit/shared/types';\n19: \n20: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n21:    1. TYPES\n22: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n23: \n24: interface BackgroundJobConfig {\n25:   intervalMs: number;\n26:   batchSize: number;\n27:   enabled: boolean;\n28: }\n29: \n30: interface RetryStats {\n31:   pending: number;\n32:   retry: number;\n33:   failed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health вҖ” no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n221: \n222: function sanitizeEmbeddingFailure(\n223:   raw: unknown,\n224:   options: SanitizeEmbeddingFailureOptions = {},\n225: ): SanitizedEmbeddingFailure {\n226:   const publicMessage = raw instanceof Error\n227:     ? raw.message.trim()\n228:     : String(raw ?? '').trim();\n229: \n230:   if (publicMessage.length === 0) {\n231:     return {\n232:       code: null,\n233:       provider: null,\n234:       errorType: null,\n235:       publicMessage,\n236:       sanitized: false,\n237:     };\n238:   }\n239: \n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n241:     return {\n242:       code: null,\n243:       provider: null,\n244:       errorType: null,\n245:       publicMessage,\n246:       sanitized: false,\n247:     };\n248:   }\n249: \n250:   const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n251:   const { code, errorType } = inferEmbeddingFailure(publicMessage);\n252: \n253:   return {\n254:     code,\n255:     provider,\n256:     errorType,\n257:     publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n258:     sanitized: true,\n259:   };\n260: }\n261: \n262: export function sanitizeEmbeddingFailureMessage(\n263:   raw: unknown,\n264:   options: SanitizeEmbeddingFailureOptions = {},\n265: ): string | null {\n266:   const failure = sanitizeEmbeddingFailure(raw, options);\n267:   return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n268: }\n269: \n270: export function sanitizeAndLogEmbeddingFailure(\n271:   context: string,\n272:   raw: unknown,\n273:   options: SanitizeEmbeddingFailureOptions = {},\n274: ): string | null {\n275:   const failure = sanitizeEmbeddingFailure(raw, options);\n276:   if (failure.publicMessage.length === 0) {\n277:     return null;\n278:   }\n279: \n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n301:   const now = new Date().toISOString();\n302:   const retryCount = getRetryCountValue(memory);\n303:   const lastRetryAt = getLastRetryAtValue(memory);\n304:   // Concurrency: atomic claim prevents double-processing of retry jobs\n305:   const result = previousStatus === 'pending'\n306:     ? db.prepare(`\n307:         UPDATE memory_index\n308:         SET embedding_status = 'retry',\n309:             last_retry_at = ?,\n310:             updated_at = ?\n311:         WHERE id = ?\n312:           AND embedding_status = 'pending'\n313:           AND retry_count = ?\n314:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n315:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n316:     : db.prepare(`\n317:         UPDATE memory_index\n318:         SET last_retry_at = ?,\n319:             updated_at = ?\n320:         WHERE id = ?\n321:           AND embedding_status = 'retry'\n322:           AND retry_count = ?\n323:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n324:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n325: \n326:   return {\n327:     claimed: result.changes > 0,\n328:     previousStatus,\n329:   };\n330: }\n331: \n332: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n333:    2. CONFIGURATION\n334: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n335: \n336: // Backoff delays in milliseconds (1min, 5min, 15min)\n337: const BACKOFF_DELAYS: number[] = [\n338:   60 * 1000,\n339:   5 * 60 * 1000,\n340:   15 * 60 * 1000,\n341: ];\n342: \n343: const MAX_RETRIES = 3;\n344: const MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n345: const MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n346: \n347: // 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n348: // applies to a long-lived daemon without depending on the exact restart sequence. The\n349: // module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\n350: function getMaxRetryQueuePending(): number {\n351:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n352: }\n353: \n354: function getMaxRetryQueueAgeMs(): number {\n355:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n356: }\n357: \n358: // Background retry job configuration\n359: // Env-overrideable\n360: //   SPECKIT_RETRY_INTERVAL_MS вҖ” interval between background batches (default 300000 = 5 min)\n361: //   SPECKIT_RETRY_BATCH_SIZE  вҖ” items processed per batch (default 5)\n362: //   SPECKIT_RETRY_ENABLED     вҖ” set to \"false\" to disable the background loop entirely (default enabled)\n363: const BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n364:   intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n365:   batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n366:   enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n367: };\n368: \n369: // Background job state\n370: let backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\n371: let backgroundJobRunning = false;\n372: let shutdownRequested = false;\n373: let retryAbortController: AbortController | null = null;\n374: \n375: // In-memory retry telemetry (never persisted to DB вҖ” read by getEmbeddingRetryStats)\n376: let lastBackgroundRunAt: string | null = null;\n377: let totalRetryAttempts = 0;\n378: const retryHealthSnapshot: EmbeddingRetryStats = {\n379:   pending: 0,\n380:   failed: 0,\n381:   retryAttempts: 0,\n382:   circuitBreakerOpen: false,\n383:   lastRun: null,\n384:   queueDepth: 0,\n385: };\n386: \n387: // circuit breaker вҖ” prevents the background retry job from\n388: // Hammering the embedding API when the provider is entirely down. After\n389: // PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n390: // Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n391: // The API call and return a transient error instead.\n392: const PROVIDER_FAILURE_THRESHOLD = 5;\n393: const PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\n394: const CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\n395: const FLAPPING_THRESHOLD = 2;\n396: const circuitTransitions: number[] = [];\n397: \n398: let providerFailures = 0;\n399: let providerCircuitOpenedAt: number | null = null;\n400: \n401: function parsePositiveIntEnv(name: string, fallback: number): number {\n402:   const raw = process.env[name];\n403:   if (!raw) return fallback;\n404: \n405:   const parsed = Number.parseInt(raw, 10);\n406:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n407: }\n408: \n409: function recordCircuitTransition(): void {\n410:   const now = Date.now();\n411:   circuitTransitions.push(now);\n412:   while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n413:     circuitTransitions.shift();\n414:   }\n415: }\n416: \n417: function getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n418:   const now = Date.now();\n419:   const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n420:   return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n421: }\n422: \n423: function isProviderCircuitOpen(): boolean {\n424:   if (providerCircuitOpenedAt === null) return false;\n425:   if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n426:     providerCircuitOpenedAt = null;\n427:     providerFailures = 0;\n428:     recordCircuitTransition();\n429:     return false;\n430:   }\n431:   return true;\n432: }\n433: \n434: function recordProviderSuccess(): void {\n435:   providerFailures = 0;\n436:   providerCircuitOpenedAt = null;\n437:   retryHealthSnapshot.circuitBreakerOpen = false;\n438: }\n439: \n440: function recordProviderFailure(): void {\n441:   providerFailures++;\n442:   if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n443:     providerCircuitOpenedAt = Date.now();\n444:     recordCircuitTransition();\n445:     console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n446:   }\n447:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n448: }\n449: \n450: function applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n451:   if (previousStatus === 'pending') {\n452:     retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n453:   }\n454: \n455:   if (previousStatus === 'pending' || previousStatus === 'retry') {\n456:     retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n457:   }\n458: \n459:   if (nextStatus === 'pending') {\n460:     retryHealthSnapshot.pending++;\n461:     retryHealthSnapshot.queueDepth++;\n462:   }\n463: \n464:   if (nextStatus === 'retry') {\n465:     retryHealthSnapshot.queueDepth++;\n466:   }\n467: \n468:   if (previousStatus === 'failed') {\n469:     retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n470:   }\n471: \n472:   if (nextStatus === 'failed') {\n473:     retryHealthSnapshot.failed++;\n474:   }\n475: }\n476: \n477: function refreshRetryHealthSnapshot(stats: RetryStats): void {\n478:   retryHealthSnapshot.pending = stats.pending;\n479:   retryHealthSnapshot.failed = stats.failed;\n480:   retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n481:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n482:   retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n483:   retryHealthSnapshot.queueDepth = stats.queue_size;\n484: }\n485: \n486: function enforceRetryRetentionLimits(\n487:   maxPending = getMaxRetryQueuePending(),\n488:   maxAgeMs = getMaxRetryQueueAgeMs(),\n489:   now: Date = new Date(),\n490: ): { expired: number; overflow: number } {\n491:   const db = vectorIndex.getDb();\n492:   if (!db) return { expired: 0, overflow: 0 };\n493: \n494:   const nowIso = now.toISOString();\n495:   const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n496:   // Retention is non-destructive for never-attempted clean `pending` rows.\n497:   // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n498:   // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n499:   // embedded instead of being parked as `failed` before the drain can claim it.\n500:   const expired = db.prepare(`\n501:     UPDATE memory_index\n502:     SET embedding_status = 'failed',\n503:         failure_reason = 'Retry retention max age exceeded',\n504:         updated_at = ?\n505:     WHERE embedding_status IN ('pending', 'retry')\n506:       AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n507:       AND COALESCE(last_retry_at, created_at, updated_at) < ?\n508:   `).run(nowIso, oldestAllowedIso).changes;\n509: \n510:   const rows = db.prepare(`\n511:     SELECT id FROM memory_index\n512:     WHERE embedding_status IN ('pending', 'retry')\n513:       AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n514:     ORDER BY COALESCE(last_retry_at, created_at, updated_at) ASC, id ASC\n515:     LIMIT -1 OFFSET ?\n516:   `).all(maxPending) as Array<{ id: number }>;\n517: \n518:   let overflow = 0;\n519:   if (rows.length > 0) {\n520:     const updateOverflow = db.prepare(`\n521:       UPDATE memory_index\n522:       SET embedding_status = 'failed',\n523:           failure_reason = 'Retry retention pending cap exceeded',\n524:           updated_at = ?\n525:       WHERE id = ?\n526:         AND embedding_status IN ('pending', 'retry')\n527:         AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n528:     `);\n529:     const txn = db.transaction((ids: number[]) => {\n530:       for (const id of ids) {\n531:         overflow += updateOverflow.run(nowIso, id).changes;\n532:       }\n533:     });\n534:     txn(rows.map((row) => row.id));\n535:   }\n536: \n537:   if (expired > 0 || overflow > 0) {\n538:     console.warn(`[retry-manager] Retention pruned expired=${expired}, overflow=${overflow}`);\n539:   }\n540: \n541:   return { expired, overflow };\n542: }\n543: \n544: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n545:    3. RETRY QUEUE\n546: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n547: \n548: function getRetryQueue(limit = 10): RetryMemoryRow[] {\n549:   vectorIndex.initializeDb();\n550:   const db = vectorIndex.getDb();\n551:   if (!db) {\n552:     console.warn('[retry-manager] Database not initialized. Server may still be starting up.');\n553:     return [];\n554:   }\n555:   enforceRetryRetentionLimits();\n556:   const now = Date.now();\n557: \n558:   const rows = db.prepare(`\n559:     SELECT * FROM memory_index\n560:     WHERE embedding_status IN ('pending', 'retry')\n561:       AND retry_count < ?\n562:     ORDER BY\n563:       CASE WHEN embedding_status = 'pending' THEN 0 ELSE 1 END,\n564:       retry_count ASC,\n565:       created_at ASC\n566:     LIMIT ?\n567:   `).all(MAX_RETRIES, limit * 2) as RetryMemoryRow[];\n568: \n569:   const eligible: RetryMemoryRow[] = [];\n570:   for (const row of rows) {\n571:     if (isEligibleForRetry(row, now)) {\n572:       eligible.push(parseRow(row));\n573:       if (eligible.length >= limit) break;\n574:     }\n575:   }\n576: \n577:   return eligible;\n578: }\n579: \n580: function isEligibleForRetry(row: RetryMemoryRow, now: number): boolean {\n581:   // Note: better-sqlite3 returns snake_case column names from SELECT *\n582:   if (row.embedding_status === 'pending') return true;\n583: \n584:   if (row.embedding_status === 'retry' && row.last_retry_at) {\n585:     const lastRetry = new Date(row.last_retry_at).getTime();\n586:     const retryCount = (row.retry_count as number) ?? (row.retryCount as number) ?? 0;\n587:     // Off-by-one fix: retryCount is already incremented after the failure that triggered\n588:     // The retry status, so use (retryCount - 1) for the backoff index. First retry (retryCount=1)\n589:     // Should use BACKOFF_DELAYS[0] (1 minute), not BACKOFF_DELAYS[1] (5 minutes).\n590:     const backoffIndex = Math.max(0, retryCount - 1);\n591:     const requiredDelay = BACKOFF_DELAYS[Math.min(backoffIndex, BACKOFF_DELAYS.length - 1)];\n592:     return (now - lastRetry) >= requiredDelay;\n593:   }\n594: \n595:   return row.embedding_status === 'retry';\n596: }\n597: \n598: function getFailedEmbeddings(): RetryMemoryRow[] {\n599:   const db = vectorIndex.getDb();\n600:   if (!db) {\n601:     console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning empty array.');\n602:     return [];\n603:   }\n604: \n605:   const rows = db.prepare(`\n606:     SELECT * FROM memory_index\n607:     WHERE embedding_status = 'failed'\n608:     ORDER BY updated_at DESC\n609:   `).all() as RetryMemoryRow[];\n610: \n611:   return rows.map(parseRow);\n612: }\n613: \n614: function getRetryStats(): RetryStats {\n615:   const db = vectorIndex.getDb();\n616:   if (!db) {\n617:     console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning default stats.');\n618:     return { pending: 0, retry: 0, failed: 0, success: 0, total: 0, queue_size: 0 };\n619:   }\n620: \n621:   const stats = db.prepare(`\n622:     SELECT\n623:       SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n624:       SUM(CASE WHEN embedding_status = 'retry' THEN 1 ELSE 0 END) as retry,\n625:       SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed,\n626:       SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as success,\n627:       COUNT(*) as total\n628:     FROM memory_index\n629:   `).get() as Record<string, number>;\n630: \n631:   const result = {\n632:     pending: stats.pending || 0,\n633:     retry: stats.retry || 0,\n634:     failed: stats.failed || 0,\n635:     success: stats.success || 0,\n636:     total: stats.total || 0,\n637:     queue_size: (stats.pending || 0) + (stats.retry || 0),\n638:   };\n639: \n640:   refreshRetryHealthSnapshot(result);\n641:   return result;\n642: }\n643: \n644: /**\n645:  * Return a lightweight in-memory snapshot of embedding retry health.\n646:  * PULL accessor вҖ” synchronous, zero DB access, always safe to call.\n647:  * Returns zero-state when the retry manager has not yet been initialized.\n648:  */\n649: function getEmbeddingRetryStats(): EmbeddingRetryStats {\n650:   return {\n651:     pending: retryHealthSnapshot.pending,\n652:     failed: retryHealthSnapshot.failed,\n653:     retryAttempts: totalRetryAttempts,\n654:     circuitBreakerOpen: isProviderCircuitOpen(),\n655:     lastRun: lastBackgroundRunAt,\n656:     queueDepth: retryHealthSnapshot.queueDepth,\n657:   };\n658: }\n659: \n660: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n661:    4. RETRY OPERATIONS\n662: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n663: \n664: async function retryEmbedding(\n665:   id: number,\n666:   content: string,\n667:   claimedPreviousStatus: RetryQueueStatus | null = null,\n668: ): Promise<RetryResult> {\n669:   const db = vectorIndex.getDb();\n670:   if (!db) return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n671: \n672:   const now = new Date().toISOString();\n673: \n674:   try {\n675:     const memory = vectorIndex.getMemory(id);\n676:     if (!memory) return { success: false, error: 'Memory not found' };\n677:     const previousStatus = claimedPreviousStatus ?? (\n678:       typeof memory.embedding_status === 'string'\n679:         ? memory.embedding_status\n680:         : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n681:           ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n682:           : null\n683:     );\n684: \n685:     if ((memory.retry_count as number) >= MAX_RETRIES) {\n686:       markAsFailed(id, 'Maximum retry attempts exceeded');\n687:       return { success: false, error: 'Maximum retries exceeded', permanent: true };\n688:     }\n689: \n690:     // Normalize content before embedding to match sync save path (memory-save.ts:1119).\n691:     // Without this, async-saved memories get embeddings from raw markdown (YAML frontmatter, HTML\n692:     // Comments, code fences) while sync-saved memories get clean normalized embeddings.\n693:     const normalizedContent = normalizeContentForEmbedding(content);\n694:     const modelId = getModelName();\n695:     const embeddingDim = getEmbeddingDimension();\n696:     const contentHash = computeContentHash(normalizedContent);\n697:     const cachedEmbedding = lookupEmbedding(db, contentHash, modelId, embeddingDim);\n698: \n699:     let embedding: Float32Array | null = null;\n700: \n701:     if (cachedEmbedding) {\n702:       embedding = new Float32Array(\n703:         cachedEmbedding.buffer,\n704:         cachedEmbedding.byteOffset,\n705:         Math.floor(cachedEmbedding.byteLength / Float32Array.BYTES_PER_ELEMENT),\n706:       );\n707:     } else {\n708:       // Skip API call if provider circuit breaker is open\n709:       if (isProviderCircuitOpen()) {\n710:         return { success: false, error: 'Embedding provider circuit breaker open вҖ” skipping API call' };\n711:       }\n712: \n713:       try {\n714:         embedding = await generateDocumentEmbedding(normalizedContent);\n715:       } catch (providerError: unknown) {\n716:         const sanitizedError = sanitizeAndLogEmbeddingFailure(\n717:           `[retry-manager] Embedding retry failed for #${id}`,\n718:           providerError,\n719:           { provider: modelId, force: true },\n720:         ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n721:         recordProviderFailure();\n722:         // Security: raw provider errors sanitized before persistence/response\n723:         incrementRetryCount(id, sanitizedError);\n724:         return { success: false, error: sanitizedError };\n725:       }\n726: \n727:       if (embedding) {\n728:         recordProviderSuccess();\n729:         storeEmbedding(\n730:           db,\n731:           contentHash,\n732:           modelId,\n733:           Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n734:           embedding.length,\n735:         );\n736:       } else {\n737:         recordProviderFailure();\n738:       }\n739:     }\n740: \n741:     if (!embedding) {\n742:       incrementRetryCount(id, 'Embedding generation returned null');\n743:       return { success: false, error: 'Embedding returned null' };\n744:     }\n745: \n746:     const updateTx = db.transaction(() => {\n747:       db.prepare(`\n748:         UPDATE memory_index\n749:         SET embedding_status = 'success',\n750:             embedding_generated_at = ?,\n751:             updated_at = ?,\n752:             failure_reason = NULL\n753:         WHERE id = ?\n754:       `).run(now, now, id);\n755: \n756:       try {\n757:         db.prepare('DELETE FROM vec_memories WHERE rowid = ?').run(BigInt(id));\n758:       } catch (_error: unknown) {\n759:         // Ignore if doesn't exist\n760:       }\n761: \n762:       const embeddingBuffer = Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength);\n763:       db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)').run(BigInt(id), embeddingBuffer);\n764:     });\n765: \n766:     try {\n767:       updateTx();\n768:       applyRetryHealthTransition(previousStatus, 'success');\n769:       return { success: true, id, dimensions: embedding.length };\n770:     } catch (tx_error: unknown) {\n771:       // Security: raw provider errors sanitized before persistence/response\n772:       console.error(`[retry-manager] Transaction error for #${id}:`, tx_error instanceof Error ? tx_error.message : String(tx_error));\n773:       incrementRetryCount(id, 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)');\n774:       return { success: false, error: 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)' };\n775:     }\n776:   } catch (error: unknown) {\n777:     recordProviderFailure();\n778:     // Security: raw provider errors sanitized before persistence/response\n779:     const sanitizedMessage = sanitizeAndLogEmbeddingFailure(\n780:       `[retry-manager] Unexpected retry error for #${id}`,\n781:       error,\n782:       { provider: null, force: true },\n783:     ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n784:     incrementRetryCount(id, sanitizedMessage);\n785:     return { success: false, error: sanitizedMessage };\n786:   }\n787: }\n788: \n789: function incrementRetryCount(id: number, reason: string): void {\n790:   totalRetryAttempts++;\n791:   const db = vectorIndex.getDb();\n792:   if (!db) return;\n793: \n794:   const now = new Date().toISOString();\n795:   const memory = vectorIndex.getMemory(id);\n796:   if (!memory) {\n797:     console.warn(`[retry-manager] Memory ${id} not found during retry count increment`);\n798:     return;\n799:   }\n800: \n801:   const newRetryCount = (Number(memory.retry_count) || 0) + 1;\n802:   // Security: raw provider errors sanitized before persistence/response\n803:   const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n804:   const previousStatus = typeof memory.embedding_status === 'string'\n805:     ? memory.embedding_status\n806:     : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n807:       ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n808:       : null;\n809: \n810:   if (newRetryCount >= MAX_RETRIES) {\n811:     markAsFailed(id, reason);\n812:   } else {\n813:     db.prepare(`\n814:       UPDATE memory_index\n815:       SET embedding_status = 'retry',\n816:           retry_count = ?,\n817:           last_retry_at = ?,\n818:           failure_reason = ?,\n819:           updated_at = ?\n820:       WHERE id = ?\n821:     `).run(newRetryCount, now, persistedReason, now, id);\n822:     applyRetryHealthTransition(previousStatus, 'retry');\n823:   }\n824: }\n825: \n826: function markAsFailed(id: number, reason: string): void {\n827:   const db = vectorIndex.getDb();\n828:   if (!db) {\n829:     console.warn('[retry-manager] Database not initialized. Server may still be starting up. Cannot mark as failed.');\n830:     return;\n831:   }\n832:   const now = new Date().toISOString();\n833:   const memory = vectorIndex.getMemory(id);\n834:   // Security: raw provider errors sanitized before persistence/response\n835:   const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n836:   const previousStatus = memory && typeof memory.embedding_status === 'string'\n837:     ? memory.embedding_status\n838:     : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n839:       ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n840:       : null;\n841: \n842:   db.prepare(`\n843:     UPDATE memory_index\n844:     SET embedding_status = 'failed',\n845:         failure_reason = ?,\n846:         updated_at = ?\n847:     WHERE id = ?\n848:   `).run(persistedReason, now, id);\n849:   applyRetryHealthTransition(previousStatus, 'failed');\n850: }\n851: \n852: function resetForRetry(id: number): boolean {\n853:   const db = vectorIndex.getDb();\n854:   if (!db) return false;\n855:   const now = new Date().toISOString();\n856:   const memory = vectorIndex.getMemory(id);\n857:   const previousStatus = memory && typeof memory.embedding_status === 'string'\n858:     ? memory.embedding_status\n859:     : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n860:       ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n861:       : null;\n862: \n863:   const result = db.prepare(`\n864:     UPDATE memory_index\n865:     SET embedding_status = 'retry',\n866:         retry_count = 0,\n867:         last_retry_at = NULL,\n868:         failure_reason = NULL,\n869:         updated_at = ?\n870:     WHERE id = ? AND embedding_status = 'failed'\n871:   `).run(now, id);\n872: \n873:   if (result.changes > 0) {\n874:     applyRetryHealthTransition(previousStatus, 'retry');\n875:   }\n876: \n877:   return result.changes > 0;\n878: }\n879: \n880: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n881:    5. BATCH PROCESSING\n882: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n883: \n884: async function processRetryQueue(limit = 3, contentLoader: ContentLoader | null = null): Promise<BatchResult> {\n885:   if (shutdownRequested || retryAbortController?.signal.aborted) {\n886:     return { processed: 0, succeeded: 0, failed: 0, details: [] };\n887:   }\n888: \n889:   const queue = getRetryQueue(limit);\n890: \n891:   if (queue.length === 0) {\n892:     return { processed: 0, succeeded: 0, failed: 0 };\n893:   }\n894: \n895:   const results: BatchResult = {\n896:     processed: 0,\n897:     succeeded: 0,\n898:     failed: 0,\n899:     details: [],\n900:   };\n901:   const details = results.details ?? (results.details = []);\n902: \n903:   for (const memory of queue) {\n904:     if (shutdownRequested || retryAbortController?.signal.aborted) {\n905:       break;\n906:     }\n907: \n908:     // For items that have never been attempted (pending), check provider state first.\n909:     // Claiming a pending item promotes it to retry, which is subject to retention pruning.\n910:     // During an outage, leave pending rows as-is so they are not pruned before the drain can embed them.\n911:     if (memory.embedding_status === 'pending' && isProviderCircuitOpen()) {\n912:       continue;\n913:     }\n914: \n915:     const claim = claimRetryCandidate(memory);\n916:     if (!claim.claimed) {\n917:       continue;\n918:     }\n919: \n920:     let content: string | null = null;\n921: \n922:     if (contentLoader) {\n923:       content = await contentLoader(memory);\n924:     } else if (typeof memory.content_text === 'string' && memory.content_text.length > 0) {\n925:       // Use stored content_text вҖ” critical for chunks which share file_path with parent\n926:       content = memory.content_text;\n927:     } else {\n928:       content = await loadContentFromFile(memory.file_path);\n929:     }\n930: \n931:     if (shutdownRequested || retryAbortController?.signal.aborted) {\n932:       break;\n933:     }\n934: \n935:     if (!content) {\n936:       // Count content load failure as a retry attempt to prevent infinite retry loops\n937:       incrementRetryCount(memory.id, 'Content load failed: file unreadable or missing');\n938:       details.push({ id: memory.id, success: false, error: 'Could not load content (counted as retry)' });\n939:       results.failed++;\n940:       results.processed++;\n941:       continue;\n942:     }\n943: \n944:     const result = await retryEmbedding(memory.id, content, claim.previousStatus);\n945:     results.processed++;\n946: \n947:     if (result.success) {\n948:       results.succeeded++;\n949:     } else {\n950:       results.failed++;\n951:     }\n952: \n953:     details.push({ id: memory.id, ...result } as RetryDetailEntry);\n954:   }\n955: \n956:   return results;\n957: }\n958: \n959: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n960:    6. BACKGROUND RETRY JOB\n961: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n962: \n963: function startBackgroundJob(options: Partial<BackgroundJobConfig> = {}): boolean {\n964:   if (backgroundJobInterval) {\n965:     console.error('[retry-manager] Background job already running');\n966:     return false;\n967:   }\n968: \n969:   const config = { ...BACKGROUND_JOB_CONFIG, ...options };\n970:   shutdownRequested = false;\n971:   retryAbortController = new AbortController();\n972: \n973:   if (!config.enabled) {\n974:     console.error('[retry-manager] Background job is disabled');\n975:     return false;\n976:   }\n977: \n978:   console.error(`[retry-manager] Starting background retry job (interval: ${config.intervalMs}ms, batch: ${config.batchSize})`);\n979: \n980:   runBackgroundJob(config.batchSize).catch((err: unknown) => {\n981:     const message = err instanceof Error ? err.message : String(err);\n982:     console.error('[retry-manager] Initial background job failed:', message);\n983:   });\n984: \n985:   backgroundJobInterval = registerInterval(() => {\n986:     runBackgroundJob(config.batchSize).catch((err: unknown) => {\n987:       const message = err instanceof Error ? err.message : String(err);\n988:       console.error('[retry-manager] Background job iteration failed:', message);\n989:     });\n990:   }, config.intervalMs, { unref: true });\n991: \n992:   return true;\n993: }\n994: \n995: function stopBackgroundJob(): boolean {\n996:   shutdownRequested = true;\n997:   retryAbortController?.abort();\n998:   retryAbortController = null;\n999:   if (!backgroundJobInterval) return false;\n1000: \n1001:   clearRegisteredTimer(backgroundJobInterval);\n1002:   backgroundJobInterval = null;\n1003:   backgroundJobRunning = false;\n1004:   console.error('[retry-manager] Background retry job stopped');\n1005:   return true;\n1006: }\n1007: \n1008: function isBackgroundJobRunning(): boolean {\n1009:   return backgroundJobInterval !== null;\n1010: }\n1011: \n1012: async function runBackgroundJob(batchSize: number = BACKGROUND_JOB_CONFIG.batchSize): Promise<BackgroundJobResult> {\n1013:   if (backgroundJobRunning) {\n1014:     return { skipped: true, reason: 'Previous run still in progress' };\n1015:   }\n1016: \n1017:   backgroundJobRunning = true;\n1018:   if (!retryAbortController || retryAbortController.signal.aborted) {\n1019:     retryAbortController = new AbortController();\n1020:   }\n1021: \n1022:   // Held only while a tick has real work; the empty-queue path below never creates\n1023:   // a handle, so an idle tick leaves the daemon reapable.\n1024:   let maintenanceHandle: MaintenanceMarkerHandle | null = null;\n1025:   try {\n1026:     enforceRetryRetentionLimits();\n1027:     if (shutdownRequested || retryAbortController.signal.aborted) {\n1028:       return { skipped: true, reason: 'Shutdown requested' };\n1029:     }\n1030:     const stats = getRetryStats();\n1031: \n1032:     if (stats.queue_size === 0) {\n1033:       return { processed: 0, queue_empty: true };\n1034:     }\n1035: \n1036:     // The deferred-embedding burst keeps the daemon busy; mark it busy-by-design so\n1037:     // a competing launcher adopts it rather than reaping it mid-drain.\n1038:     maintenanceHandle = beginMaintenance('embedding-queue');\n1039:     console.error(`[retry-manager] Background job: Processing up to ${batchSize} of ${stats.queue_size} pending embeddings`);\n1040: \n1041:     const result = await processRetryQueue(batchSize);\n1042: \n1043:     if (result.processed > 0) {\n1044:       console.error(`[retry-manager] Background job complete: ${result.succeeded}/${result.processed} succeeded`);\n1045:     }\n1046: \n1047:     return result;\n1048:   } catch (error: unknown) {\n1049:     const message = error instanceof Error ? error.message : String(error);\n1050:     console.error('[retry-manager] Background job error:', message);\n1051:     return { error: message };\n1052:   } finally {\n1053:     // Release the busy mark on every exit (success, error). The empty-queue path\n1054:     // never set it, so this is a safe no-op there; end() is idempotent regardless.\n1055:     maintenanceHandle?.end();\n1056:     lastBackgroundRunAt = new Date().toISOString();\n1057:     retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n1058:     retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n1059:     retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n1060:     backgroundJobRunning = false;\n1061:   }\n1062: }\n1063: \n1064: registerShutdownHook(() => {\n1065:   stopBackgroundJob();\n1066: }, { timeoutMs: 250 });\n1067: \n1068: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1069:    7. UTILITIES\n1070: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n1071: \n1072: function parseRow(row: RetryMemoryRow): RetryMemoryRow {\n1073:   if (row.triggerPhrases && typeof row.triggerPhrases === 'string') {\n1074:     try {\n1075:       return { ...row, triggerPhrases: JSON.parse(row.triggerPhrases) };\n1076:     } catch (_error: unknown) {\n1077:       return { ...row, triggerPhrases: [] };\n1078:     }\n1079:   }\n1080:   return { ...row };\n1081: }\n1082: \n1083: async function loadContentFromFile(filePath: string): Promise<string | null> {\n1084:   try {\n1085:     return await fsPromises.readFile(filePath, 'utf-8');\n1086:   } catch (_error: unknown) {\n1087:     return null;\n1088:   }\n1089: }\n1090: \n1091: async function claimAndRetryEmbedding(\n1092:   id: number,\n1093:   content: string,\n1094:   expectedStatus: RetryQueueStatus = 'pending',\n1095: ): Promise<RetryResult | null> {\n1096:   const memory = vectorIndex.getMemory(id) as RetryMemoryRow | undefined;\n1097:   if (!memory) {\n1098:     return { success: false, error: 'Memory not found' };\n1099:   }\n1100: \n1101:   const parsedMemory = parseRow(memory);\n1102:   if (getRetryStatus(parsedMemory) !== expectedStatus) {\n1103:     return null;\n1104:   }\n1105: \n1106:   const claim = claimRetryCandidate(parsedMemory);\n1107:   if (!claim.claimed) {\n1108:     return null;\n1109:   }\n1110: \n1111:   return retryEmbedding(id, content, claim.previousStatus);\n1112: }\n1113: \n1114: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1115:    8. EXPORTS\n1116: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n1117: \n1118: export {\n1119:   getRetryQueue,\n1120:   getFailedEmbeddings,\n1121:   getRetryStats,\n1122:   getEmbeddingRetryStats,\n1123:   getCircuitFlapState,\n1124:   retryEmbedding,\n1125:   claimAndRetryEmbedding,\n1126:   markAsFailed,\n1127:   resetForRetry,\n1128:   processRetryQueue,\n1129:   startBackgroundJob,\n1130:   stopBackgroundJob,\n1131:   isBackgroundJobRunning,\n1132:   runBackgroundJob,\n1133:   enforceRetryRetentionLimits,\n1134:   BACKGROUND_JOB_CONFIG,\n1135:   BACKOFF_DELAYS,\n1136:   MAX_RETRIES,\n1137:   MAX_RETRY_QUEUE_PENDING,\n1138:   MAX_RETRY_QUEUE_AGE_MS,\n1139:   getMaxRetryQueuePending,\n1140:   getMaxRetryQueueAgeMs,\n1141: };\n\n(End of file - total 1141 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Retry Manager\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Retry Manager\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health вҖ” no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}\n\nfunction sanitizeEmbeddingFailure(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): SanitizedEmbeddingFailure {\n  const publicMessage = raw instanceof Error\n    ? raw.message.trim()\n    : String(raw ?? '').trim();\n\n  if (publicMessage.length === 0) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };\n}\n\nexport function sanitizeEmbeddingFailureMessage(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n}\n\nexport function sanitizeAndLogEmbeddingFailure(\n  context: string,\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  if (failure.publicMessage.length === 0) {\n    return null;\n  }\n\n  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n\n  const now = new Date().toISOString();\n  const retryCount = getRetryCountValue(memory);\n  const lastRetryAt = getLastRetryAtValue(memory);\n  // Concurrency: atomic claim prevents double-processing of retry jobs\n  const result = previousStatus === 'pending'\n    ? db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'pending'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n    : db.prepare(`\n        UPDATE memory_index\n        SET last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'retry'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n\n  return {\n    claimed: result.changes > 0,\n    previousStatus,\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. CONFIGURATION\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// Backoff delays in milliseconds (1min, 5min, 15min)\nconst BACKOFF_DELAYS: number[] = [\n  60 * 1000,\n  5 * 60 * 1000,\n  15 * 60 * 1000,\n];\n\nconst MAX_RETRIES = 3;\nconst MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\nconst MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n\n// 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n// applies to a long-lived daemon without depending on the exact restart sequence. The\n// module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\nfunction getMaxRetryQueuePending(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n}\n\nfunction getMaxRetryQueueAgeMs(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n}\n\n// Background retry job configuration\n// Env-overrideable\n//   SPECKIT_RETRY_INTERVAL_MS вҖ” interval between background batches (default 300000 = 5 min)\n//   SPECKIT_RETRY_BATCH_SIZE  вҖ” items processed per batch (default 5)\n//   SPECKIT_RETRY_ENABLED     вҖ” set to \"false\" to disable the background loop entirely (default enabled)\nconst BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n  intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n  batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n  enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n};\n\n// Background job state\nlet backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\nlet backgroundJobRunning = false;\nlet shutdownRequested = false;\nlet retryAbortController: AbortController | null = null;\n\n// In-memory retry telemetry (never persisted to DB вҖ” read by getEmbeddingRetryStats)\nlet lastBackgroundRunAt: string | null = null;\nlet totalRetryAttempts = 0;\nconst retryHealthSnapshot: EmbeddingRetryStats = {\n  pending: 0,\n  failed: 0,\n  retryAttempts: 0,\n  circuitBreakerOpen: false,\n  lastRun: null,\n  queueDepth: 0,\n};\n\n// circuit breaker вҖ” prevents the background retry job from\n// Hammering the embedding API when the provider is entirely down. After\n// PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n// Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n// The API call and return a transient error instead.\nconst PROVIDER_FAILURE_THRESHOLD = 5;\nconst PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\nconst CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\nconst FLAPPING_THRESHOLD = 2;\nconst circuitTransitions: number[] = [];\n\nlet providerFailures = 0;\nlet providerCircuitOpenedAt: number | null = null;\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction recordCircuitTransition(): void {\n  const now = Date.now();\n  circuitTransitions.push(now);\n  while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n    circuitTransitions.shift();\n  }\n}\n\nfunction getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n  const now = Date.now();\n  const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n  return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n}\n\nfunction isProviderCircuitOpen(): boolean {\n  if (providerCircuitOpenedAt === null) return false;\n  if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n    providerCircuitOpenedAt = null;\n    providerFailures = 0;\n    recordCircuitTransition();\n    return false;\n  }\n  return true;\n}\n\nfunction recordProviderSuccess(): void {\n  providerFailures = 0;\n  providerCircuitOpenedAt = null;\n  retryHealthSnapshot.circuitBreakerOpen = false;\n}\n\nfunction recordProviderFailure(): void {\n  providerFailures++;\n  if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n    providerCircuitOpenedAt = Date.now();\n    recordCircuitTransition();\n    console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n  }\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n}\n\nfunction applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n  if (previousStatus === 'pending') {\n    retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n  }\n\n  if (previousStatus === 'pending' || previousStatus === 'retry') {\n    retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n  }\n\n  if (nextStatus === 'pending') {\n    retryHealthSnapshot.pending++;\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (nextStatus === 'retry') {\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (previousStatus === 'failed') {\n    retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n  }\n\n  if (nextStatus === 'failed') {\n    retryHealthSnapshot.failed++;\n  }\n}\n\nfunction refreshRetryHealthSnapshot(stats: RetryStats): void {\n  retryHealthSnapshot.pending = stats.pending;\n  retryHealthSnapshot.failed = stats.failed;\n  retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n  retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n  retryHealthSnapshot.queueDepth = stats.queue_size;\n}\n\nfunction enforceRetryRetentionLimits(\n  maxPending = getMaxRetryQueuePending(),\n  maxAgeMs = getMaxRetryQueueAgeMs(),\n  now: Date = new Date(),\n): { expired: number; overflow: number } {\n  const db = vectorIndex.getDb();\n  if (!db) return { expired: 0, overflow: 0 };\n\n  const nowIso = now.toISOString();\n  const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n  // Retention is non-destructive for never-attempted clean `pending` rows.\n  // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n  // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n  // embedded instead of being parked as `failed` before the drain can claim it.\n  const expired = db.prepare(`\n    UPDATE memory_index\n    SET embedding_status = 'failed',\n        failure_reason = 'Retry retention max age exceeded',\n        updated_at = ?\n    WHERE embedding_status IN ('pending', 'retry')\n      AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n      AND COALESCE(last_retry_at, created_at, updated_at) < ?\n  `).run(nowIso, oldestAllowedIso).changes;\n\n  const rows = db.prepare(`\n    SELECT id FROM memory_index\n    WHERE embedding_status IN ('pending', 'retry')\n      AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n    ORDER BY COALESCE(last_retry_at, created_at, updated_at) ASC, id ASC\n    LIMIT -1 OFFSET ?\n  `).all(maxPending) as Array<{ id: number }>;\n\n  let overflow = 0;\n  if (rows.length > 0) {\n    const updateOverflow = db.prepare(`\n      UPDATE memory_index\n      SET embedding_status = 'failed',\n          failure_reason = 'Retry retention pending cap exceeded',\n          updated_at = ?\n      WHERE id = ?\n        AND embedding_status IN ('pending', 'retry')\n        AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n    `);\n    const txn = db.transaction((ids: number[]) => {\n      for (const id of ids) {\n        overflow += updateOverflow.run(nowIso, id).changes;\n      }\n    });\n    txn(rows.map((row) => row.id));\n  }\n\n  if (expired > 0 || overflow > 0) {\n    console.warn(`[retry-manager] Retention pruned expired=${expired}, overflow=${overflow}`);\n  }\n\n  return { expired, overflow };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. RETRY QUEUE\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction getRetryQueue(limit = 10): RetryMemoryRow[] {\n  vectorIndex.initializeDb();\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up.');\n    return [];\n  }\n  enforceRetryRetentionLimits();\n  const now = Date.now();\n\n  const rows = db.prepare(`\n    SELECT * FROM memory_index\n    WHERE embedding_status IN ('pending', 'retry')\n      AND retry_count < ?\n    ORDER BY\n      CASE WHEN embedding_status = 'pending' THEN 0 ELSE 1 END,\n      retry_count ASC,\n      created_at ASC\n    LIMIT ?\n  `).all(MAX_RETRIES, limit * 2) as RetryMemoryRow[];\n\n  const eligible: RetryMemoryRow[] = [];\n  for (const row of rows) {\n    if (isEligibleForRetry(row, now)) {\n      eligible.push(parseRow(row));\n      if (eligible.length >= limit) break;\n    }\n  }\n\n  return eligible;\n}\n\nfunction isEligibleForRetry(row: RetryMemoryRow, now: number): boolean {\n  // Note: better-sqlite3 returns snake_case column names from SELECT *\n  if (row.embedding_status === 'pending') return true;\n\n  if (row.embedding_status === 'retry' && row.last_retry_at) {\n    const lastRetry = new Date(row.last_retry_at).getTime();\n    const retryCount = (row.retry_count as number) ?? (row.retryCount as number) ?? 0;\n    // Off-by-one fix: retryCount is already incremented after the failure that triggered\n    // The retry status, so use (retryCount - 1) for the backoff index. First retry (retryCount=1)\n    // Should use BACKOFF_DELAYS[0] (1 minute), not BACKOFF_DELAYS[1] (5 minutes).\n    const backoffIndex = Math.max(0, retryCount - 1);\n    const requiredDelay = BACKOFF_DELAYS[Math.min(backoffIndex, BACKOFF_DELAYS.length - 1)];\n    return (now - lastRetry) >= requiredDelay;\n  }\n\n  return row.embedding_status === 'retry';\n}\n\nfunction getFailedEmbeddings(): RetryMemoryRow[] {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning empty array.');\n    return [];\n  }\n\n  const rows = db.prepare(`\n    SELECT * FROM memory_index\n    WHERE embedding_status = 'failed'\n    ORDER BY updated_at DESC\n  `).all() as RetryMemoryRow[];\n\n  return rows.map(parseRow);\n}\n\nfunction getRetryStats(): RetryStats {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning default stats.');\n    return { pending: 0, retry: 0, failed: 0, success: 0, total: 0, queue_size: 0 };\n  }\n\n  const stats = db.prepare(`\n    SELECT\n      SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n      SUM(CASE WHEN embedding_status = 'retry' THEN 1 ELSE 0 END) as retry,\n      SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed,\n      SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as success,\n      COUNT(*) as total\n    FROM memory_index\n  `).get() as Record<string, number>;\n\n  const result = {\n    pending: stats.pending || 0,\n    retry: stats.retry || 0,\n    failed: stats.failed || 0,\n    success: stats.success || 0,\n    total: stats.total || 0,\n    queue_size: (stats.pending || 0) + (stats.retry || 0),\n  };\n\n  refreshRetryHealthSnapshot(result);\n  return result;\n}\n\n/**\n * Return a lightweight in-memory snapshot of embedding retry health.\n * PULL accessor вҖ” synchronous, zero DB access, always safe to call.\n * Returns zero-state when the retry manager has not yet been initialized.\n */\nfunction getEmbeddingRetryStats(): EmbeddingRetryStats {\n  return {\n    pending: retryHealthSnapshot.pending,\n    failed: retryHealthSnapshot.failed,\n    retryAttempts: totalRetryAttempts,\n    circuitBreakerOpen: isProviderCircuitOpen(),\n    lastRun: lastBackgroundRunAt,\n    queueDepth: retryHealthSnapshot.queueDepth,\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. RETRY OPERATIONS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nasync function retryEmbedding(\n  id: number,\n  content: string,\n  claimedPreviousStatus: RetryQueueStatus | null = null,\n): Promise<RetryResult> {\n  const db = vectorIndex.getDb();\n  if (!db) return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n\n  const now = new Date().toISOString();\n\n  try {\n    const memory = vectorIndex.getMemory(id);\n    if (!memory) return { success: false, error: 'Memory not found' };\n    const previousStatus = claimedPreviousStatus ?? (\n      typeof memory.embedding_status === 'string'\n        ? memory.embedding_status\n        : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n          ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n          : null\n    );\n\n    if ((memory.retry_count as number) >= MAX_RETRIES) {\n      markAsFailed(id, 'Maximum retry attempts exceeded');\n      return { success: false, error: 'Maximum retries exceeded', permanent: true };\n    }\n\n    // Normalize content before embedding to match sync save path (memory-save.ts:1119).\n    // Without this, async-saved memories get embeddings from raw markdown (YAML frontmatter, HTML\n    // Comments, code fences) while sync-saved memories get clean normalized embeddings.\n    const normalizedContent = normalizeContentForEmbedding(content);\n    const modelId = getModelName();\n    const embeddingDim = getEmbeddingDimension();\n    const contentHash = computeContentHash(normalizedContent);\n    const cachedEmbedding = lookupEmbedding(db, contentHash, modelId, embeddingDim);\n\n    let embedding: Float32Array | null = null;\n\n    if (cachedEmbedding) {\n      embedding = new Float32Array(\n        cachedEmbedding.buffer,\n        cachedEmbedding.byteOffset,\n        Math.floor(cachedEmbedding.byteLength / Float32Array.BYTES_PER_ELEMENT),\n      );\n    } else {\n      // Skip API call if provider circuit breaker is open\n      if (isProviderCircuitOpen()) {\n        return { success: false, error: 'Embedding provider circuit breaker open вҖ” skipping API call' };\n      }\n\n      try {\n        embedding = await generateDocumentEmbedding(normalizedContent);\n      } catch (providerError: unknown) {\n        const sanitizedError = sanitizeAndLogEmbeddingFailure(\n          `[retry-manager] Embedding retry failed for #${id}`,\n          providerError,\n          { provider: modelId, force: true },\n        ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n        recordProviderFailure();\n        // Security: raw provider errors sanitized before persistence/response\n        incrementRetryCount(id, sanitizedError);\n        return { success: false, error: sanitizedError };\n      }\n\n      if (embedding) {\n        recordProviderSuccess();\n        storeEmbedding(\n          db,\n          contentHash,\n          modelId,\n          Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n          embedding.length,\n        );\n      } else {\n        recordProviderFailure();\n      }\n    }\n\n    if (!embedding) {\n      incrementRetryCount(id, 'Embedding generation returned null');\n      return { success: false, error: 'Embedding returned null' };\n    }\n\n    const updateTx = db.transaction(() => {\n      db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'success',\n            embedding_generated_at = ?,\n            updated_at = ?,\n            failure_reason = NULL\n        WHERE id = ?\n      `).run(now, now, id);\n\n      try {\n        db.prepare('DELETE FROM vec_memories WHERE rowid = ?').run(BigInt(id));\n      } catch (_error: unknown) {\n        // Ignore if doesn't exist\n      }\n\n      const embeddingBuffer = Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength);\n      db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)').run(BigInt(id), embeddingBuffer);\n    });\n\n    try {\n      updateTx();\n      applyRetryHealthTransition(previousStatus, 'success');\n      return { success: true, id, dimensions: embedding.length };\n    } catch (tx_error: unknown) {\n      // Security: raw provider errors sanitized before persistence/response\n      console.error(`[retry-manager] Transaction error for #${id}:`, tx_error instanceof Error ? tx_error.message : String(tx_error));\n      incrementRetryCount(id, 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)');\n      return { success: false, error: 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)' };\n    }\n  } catch (error: unknown) {\n    recordProviderFailure();\n    // Security: raw provider errors sanitized before persistence/response\n    const sanitizedMessage = sanitizeAndLogEmbeddingFailure(\n      `[retry-manager] Unexpected retry error for #${id}`,\n      error,\n      { provider: null, force: true },\n    ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n    incrementRetryCount(id, sanitizedMessage);\n    return { success: false, error: sanitizedMessage };\n  }\n}\n\nfunction incrementRetryCount(id: number, reason: string): void {\n  totalRetryAttempts++;\n  const db = vectorIndex.getDb();\n  if (!db) return;\n\n  const now = new Date().toISOString();\n  const memory = vectorIndex.getMemory(id);\n  if (!memory) {\n    console.warn(`[retry-manager] Memory ${id} not found during retry count increment`);\n    return;\n  }\n\n  const newRetryCount = (Number(memory.retry_count) || 0) + 1;\n  // Security: raw provider errors sanitized before persistence/response\n  const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n  const previousStatus = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n      ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n      : null;\n\n  if (newRetryCount >= MAX_RETRIES) {\n    markAsFailed(id, reason);\n  } else {\n    db.prepare(`\n      UPDATE memory_index\n      SET embedding_status = 'retry',\n          retry_count = ?,\n          last_retry_at = ?,\n          failure_reason = ?,\n          updated_at = ?\n      WHERE id = ?\n    `).run(newRetryCount, now, persistedReason, now, id);\n    applyRetryHealthTransition(previousStatus, 'retry');\n  }\n}\n\nfunction markAsFailed(id: number, reason: string): void {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Cannot mark as failed.');\n    return;\n  }\n  const now = new Date().toISOString();\n  const memory = vectorIndex.getMemory(id);\n  // Security: raw provider errors sanitized before persistence/response\n  const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n  const previousStatus = memory && typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n      ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n      : null;\n\n  db.prepare(`\n    UPDATE memory_index\n    SET embedding_status = 'failed',\n        failure_reason = ?,\n        updated_at = ?\n    WHERE id = ?\n  `).run(persistedReason, now, id);\n  applyRetryHealthTransition(previousStatus, 'failed');\n}\n\nfunction resetForRetry(id: number): boolean {\n  const db = vectorIndex.getDb();\n  if (!db) return false;\n  const now = new Date().toISOString();\n  const memory = vectorIndex.getMemory(id);\n  const previousStatus = memory && typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n      ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n      : null;\n\n  const result = db.prepare(`\n    UPDATE memory_index\n    SET embedding_status = 'retry',\n        retry_count = 0,\n        last_retry_at = NULL,\n        failure_reason = NULL,\n        updated_at = ?\n    WHERE id = ? AND embedding_status = 'failed'\n  `).run(now, id);\n\n  if (result.changes > 0) {\n    applyRetryHealthTransition(previousStatus, 'retry');\n  }\n\n  return result.changes > 0;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. BATCH PROCESSING\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nasync function processRetryQueue(limit = 3, contentLoader: ContentLoader | null = null): Promise<BatchResult> {\n  if (shutdownRequested || retryAbortController?.signal.aborted) {\n    return { processed: 0, succeeded: 0, failed: 0, details: [] };\n  }\n\n  const queue = getRetryQueue(limit);\n\n  if (queue.length === 0) {\n    return { processed: 0, succeeded: 0, failed: 0 };\n  }\n\n  const results: BatchResult = {\n    processed: 0,\n    succeeded: 0,\n    failed: 0,\n    details: [],\n  };\n  const details = results.details ?? (results.details = []);\n\n  for (const memory of queue) {\n    if (shutdownRequested || retryAbortController?.signal.aborted) {\n      break;\n    }\n\n    // For items that have never been attempted (pending), check provider state first.\n    // Claiming a pending item promotes it to retry, which is subject to retention pruning.\n    // During an outage, leave pending rows as-is so they are not pruned before the drain can embed them.\n    if (memory.embedding_status === 'pending' && isProviderCircuitOpen()) {\n      continue;\n    }\n\n    const claim = claimRetryCandidate(memory);\n    if (!claim.claimed) {\n      continue;\n    }\n\n    let content: string | null = null;\n\n    if (contentLoader) {\n      content = await contentLoader(memory);\n    } else if (typeof memory.content_text === 'string' && memory.content_text.length > 0) {\n      // Use stored content_text вҖ” critical for chunks which share file_path with parent\n      content = memory.content_text;\n    } else {\n      content = await loadContentFromFile(memory.file_path);\n    }\n\n    if (shutdownRequested || retryAbortController?.signal.aborted) {\n      break;\n    }\n\n    if (!content) {\n      // Count content load failure as a retry attempt to prevent infinite retry loops\n      incrementRetryCount(memory.id, 'Content load failed: file unreadable or missing');\n      details.push({ id: memory.id, success: false, error: 'Could not load content (counted as retry)' });\n      results.failed++;\n      results.processed++;\n      continue;\n    }\n\n    const result = await retryEmbedding(memory.id, content, claim.previousStatus);\n    results.processed++;\n\n    if (result.success) {\n      results.succeeded++;\n    } else {\n      results.failed++;\n    }\n\n    details.push({ id: memory.id, ...result } as RetryDetailEntry);\n  }\n\n  return results;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. BACKGROUND RETRY JOB\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction startBackgroundJob(options: Partial<BackgroundJobConfig> = {}): boolean {\n  if (backgroundJobInterval) {\n    console.error('[retry-manager] Background job already running');\n    return false;\n  }\n\n  const config = { ...BACKGROUND_JOB_CONFIG, ...options };\n  shutdownRequested = false;\n  retryAbortController = new AbortController();\n\n  if (!config.enabled) {\n    console.error('[retry-manager] Background job is disabled');\n    return false;\n  }\n\n  console.error(`[retry-manager] Starting background retry job (interval: ${config.intervalMs}ms, batch: ${config.batchSize})`);\n\n  runBackgroundJob(config.batchSize).catch((err: unknown) => {\n    const message = err instanceof Error ? err.message : String(err);\n    console.error('[retry-manager] Initial background job failed:', message);\n  });\n\n  backgroundJobInterval = registerInterval(() => {\n    runBackgroundJob(config.batchSize).catch((err: unknown) => {\n      const message = err instanceof Error ? err.message : String(err);\n      console.error('[retry-manager] Background job iteration failed:', message);\n    });\n  }, config.intervalMs, { unref: true });\n\n  return true;\n}\n\nfunction stopBackgroundJob(): boolean {\n  shutdownRequested = true;\n  retryAbortController?.abort();\n  retryAbortController = null;\n  if (!backgroundJobInterval) return false;\n\n  clearRegisteredTimer(backgroundJobInterval);\n  backgroundJobInterval = null;\n  backgroundJobRunning = false;\n  console.error('[retry-manager] Background retry job stopped');\n  return true;\n}\n\nfunction isBackgroundJobRunning(): boolean {\n  return backgroundJobInterval !== null;\n}\n\nasync function runBackgroundJob(batchSize: number = BACKGROUND_JOB_CONFIG.batchSize): Promise<BackgroundJobResult> {\n  if (backgroundJobRunning) {\n    return { skipped: true, reason: 'Previous run still in progress' };\n  }\n\n  backgroundJobRunning = true;\n  if (!retryAbortController || retryAbortController.signal.aborted) {\n    retryAbortController = new AbortController();\n  }\n\n  // Held only while a tick has real work; the empty-queue path below never creates\n  // a handle, so an idle tick leaves the daemon reapable.\n  let maintenanceHandle: MaintenanceMarkerHandle | null = null;\n  try {\n    enforceRetryRetentionLimits();\n    if (shutdownRequested || retryAbortController.signal.aborted) {\n      return { skipped: true, reason: 'Shutdown requested' };\n    }\n    const stats = getRetryStats();\n\n    if (stats.queue_size === 0) {\n      return { processed: 0, queue_empty: true };\n    }\n\n    // The deferred-embedding burst keeps the daemon busy; mark it busy-by-design so\n    // a competing launcher adopts it rather than reaping it mid-drain.\n    maintenanceHandle = beginMaintenance('embedding-queue');\n    console.error(`[retry-manager] Background job: Processing up to ${batchSize} of ${stats.queue_size} pending embeddings`);\n\n    const result = await processRetryQueue(batchSize);\n\n    if (result.processed > 0) {\n      console.error(`[retry-manager] Background job complete: ${result.succeeded}/${result.processed} succeeded`);\n    }\n\n    return result;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error('[retry-manager] Background job error:', message);\n    return { error: message };\n  } finally {\n    // Release the busy mark on every exit (success, error). The empty-queue path\n    // never set it, so this is a safe no-op there; end() is idempotent regardless.\n    maintenanceHandle?.end();\n    lastBackgroundRunAt = new Date().toISOString();\n    retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n    retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n    retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n    backgroundJobRunning = false;\n  }\n}\n\nregisterShutdownHook(() => {\n  stopBackgroundJob();\n}, { timeoutMs: 250 });\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   7. UTILITIES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction parseRow(row: RetryMemoryRow): RetryMemoryRow {\n  if (row.triggerPhrases && typeof row.triggerPhrases === 'string') {\n    try {\n      return { ...row, triggerPhrases: JSON.parse(row.triggerPhrases) };\n    } catch (_error: unknown) {\n      return { ...row, triggerPhrases: [] };\n    }\n  }\n  return { ...row };\n}\n\nasync function loadContentFromFile(filePath: string): Promise<string | null> {\n  try {\n    return await fsPromises.readFile(filePath, 'utf-8');\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nasync function claimAndRetryEmbedding(\n  id: number,\n  content: string,\n  expectedStatus: RetryQueueStatus = 'pending',\n): Promise<RetryResult | null> {\n  const memory = vectorIndex.getMemory(id) as RetryMemoryRow | undefined;\n  if (!memory) {\n    return { success: false, error: 'Memory not found' };\n  }\n\n  const parsedMemory = parseRow(memory);\n  if (getRetryStatus(parsedMemory) !== expectedStatus) {\n    return null;\n  }\n\n  const claim = claimRetryCandidate(parsedMemory);\n  if (!claim.claimed) {\n    return null;\n  }\n\n  return retryEmbedding(id, content, claim.previousStatus);\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   8. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport {\n  getRetryQueue,\n  getFailedEmbeddings,\n  getRetryStats,\n  getEmbeddingRetryStats,\n  getCircuitFlapState,\n  retryEmbedding,\n  claimAndRetryEmbedding,\n  markAsFailed,\n  resetForRetry,\n  processRetryQueue,\n  startBackgroundJob,\n  stopBackgroundJob,\n  isBackgroundJobRunning,\n  runBackgroundJob,\n  enforceRetryRetentionLimits,\n  BACKGROUND_JOB_CONFIG,\n  BACKOFF_DELAYS,\n  MAX_RETRIES,\n  MAX_RETRY_QUEUE_PENDING,\n  MAX_RETRY_QUEUE_AGE_MS,\n  getMaxRetryQueuePending,\n  getMaxRetryQueueAgeMs,\n};","lineStart":1,"lineEnd":1141,"totalLines":1141,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781721572328,"end":1781721572334}},"id":"prt_ed6e1a2a4001ziu2wcF7LGLJI9","sessionID":"ses_1291f676affeVoh3Pb0kJSjTck","messageID":"msg_ed6e1726f001S3TgagxjSYy42L"}}
