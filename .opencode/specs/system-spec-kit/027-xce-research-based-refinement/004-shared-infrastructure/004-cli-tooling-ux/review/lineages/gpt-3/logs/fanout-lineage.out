     index += 1;\n496:       continue;\n497:     }\n498:     parsedArgs[propertyName] = parseValue(next);\n499:     index += 2;\n500:   }\n501: \n502:   if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n503:     throw new CliUsageError('--json cannot be combined with per-parameter flags');\n504:   }\n505: \n506:   return {\n507:     command,\n508:     format,\n509:     timeoutMs,\n510:     warmOnly,\n511:     toolListMode,\n512:     completionShell,\n513:     args: jsonPayload ?? parsedArgs,\n514:     help: false,\n515:     version: false,\n516:   };\n517: }\n518: \n519: function declaredSchemaTypes(propertySchema: unknown): string[] {\n520:   if (!isRecord(propertySchema)) return [];\n521:   const type = propertySchema.type;\n522:   if (typeof type === 'string') return [type];\n523:   if (Array.isArray(type)) return type.filter((entry): entry is string => typeof entry === 'string');\n524:   return [];\n525: }\n526: \n527: // Flag values arrive as strings; without schema-driven coercion a numeric\n528: // filter like `--min-confidence 0.8` reaches the daemon as \"0.8\", which\n529: // numeric clamps silently treat as 0 — the user's filter is dropped under\n530: // a status:ok response. Coerce strings to the schema-declared primitive\n531: // and reject unparseable values as usage errors instead.\n532: function coerceArgsToSchema(tool: ToolDefinition, args: Record<string, unknown>): Record<string, unknown> {\n533:   const schema = tool.inputSchema;\n534:   const properties = isRecord(schema) && isRecord(schema.properties) ? schema.properties : null;\n535:   if (!properties) return args;\n536: \n537:   const coerced: Record<string, unknown> = { ...args };\n538:   for (const [key, value] of Object.entries(args)) {\n539:     if (typeof value !== 'string') continue;\n540:     const types = declaredSchemaTypes(properties[key]);\n541:     if (types.includes('number') || types.includes('integer')) {\n542:       const trimmed = value.trim();\n543:       const parsed = trimmed.length > 0 ? Number(trimmed) : Number.NaN;\n544:       if (!Number.isFinite(parsed)) {\n545:         throw new CliUsageError(`Invalid value for ${key}: expected ${types.includes('integer') ? 'an integer' : 'a number'}, received \"${value}\"`);\n546:       }\n547:       if (types.includes('integer') && !Number.isInteger(parsed)) {\n548:         throw new CliUsageError(`Invalid value for ${key}: expected an integer, received \"${value}\"`);\n549:       }\n550:       coerced[key] = parsed;\n551:       continue;\n552:     }\n553:     if (types.includes('boolean')) {\n554:       if (value === 'true' || value === '1') {\n555:         coerced[key] = true;\n556:         continue;\n557:       }\n558:       if (value === 'false' || value === '0') {\n559:         coerced[key] = false;\n560:         continue;\n561:       }\n562:       throw new CliUsageError(`Invalid value for ${key}: expected true or false, received \"${value}\"`);\n563:     }\n564:   }\n565:   return coerced;\n566: }\n567: \n568: function missingRequiredArgs(tool: ToolDefinition, args: Record<string, unknown>): string[] {\n569:   return requiredPropertyNames(tool).filter((key) => {\n570:     const value = args[key];\n571:     return value === undefined || value === null || (typeof value === 'string' && value.trim().length === 0);\n572:   });\n573: }\n574: \n575: function validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n576:   if (RESERVED_COMMANDS.has(parsed.command)) return null;\n577:   const tool = getToolDefinition(parsed.command);\n578:   if (!tool) {\n579:     throw new CliUsageError(`Unknown command: ${parsed.command}`);\n580:   }\n581: \n582:   const args = coerceArgsToSchema(tool, { ...parsed.args });\n583:   const missing = missingRequiredArgs(tool, args);\n584:   if (missing.length > 0) {\n585:     throw new CliUsageError(`Missing required field${missing.length === 1 ? '' : 's'}: ${missing.join(', ')}`);\n586:   }\n587: \n588:   try {\n589:     return {\n590:       tool,\n591:       args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n592:     };\n593:   } catch (error: unknown) {\n594:     const message = error instanceof Error ? error.message : String(error);\n595:     throw new CliUsageError(message);\n596:   }\n597: }\n598: \n599: function renderJson(value: unknown, format: OutputFormat): string {\n600:   if (format === 'jsonl') return JSON.stringify(value);\n601:   return JSON.stringify(value, null, 2);\n602: }\n603: \n604: function compactTool(tool: ToolDefinition): Record<string, unknown> {\n605:   return {\n606:     name: tool.name,\n607:     command: tool.name,\n608:     kebabCommand: toKebabCommand(tool.name),\n609:     camelCommand: toCamelCommand(tool.name),\n610:     aliases: commandAliases(tool.name),\n611:     description: tool.description,\n612:   };\n613: }\n614: \n615: function renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n616:   const tools = toolDefinitions();\n617:   const payload = {\n618:     status: 'ok',\n619:     data: {\n620:       count: tools.length,\n621:       mode,\n622:       tools: tools.map((tool) => ({\n623:         name: tool.name,\n624:         command: tool.name,\n625:         kebabCommand: toKebabCommand(tool.name),\n626:         camelCommand: toCamelCommand(tool.name),\n627:         aliases: commandAliases(tool.name),\n628:         description: tool.description,\n629:         inputSchema: tool.inputSchema,\n630:       })),\n631:     },\n632:   };\n633:   const compactPayload = {\n634:     status: 'ok',\n635:     data: {\n636:       count: tools.length,\n637:       mode,\n638:       tools: tools.map(compactTool),\n639:     },\n\n(Showing lines 220-639 of 1196. Use offset=640 to continue.)\n</content>","metadata":{"preview":"\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  return `code-index - daemon-backed CLI for mk-code-index\n\nUsage:\n  code-index list-tools [--format json|text|jsonl] [--compact|--names-only]\n  code-index completion bash|zsh\n  code-index <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--warm-only]\n  code-index <tool_name> --param value [--another-param value]\n\nExamples:","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/code-index-cli.ts","text":"\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  return `code-index - daemon-backed CLI for mk-code-index\n\nUsage:\n  code-index list-tools [--format json|text|jsonl] [--compact|--names-only]\n  code-index completion bash|zsh\n  code-index <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--warm-only]\n  code-index <tool_name> --param value [--another-param value]\n\nExamples:\n  code-index list-tools --format text\n  code-index list-tools --compact\n  code-index completion zsh\n  code-index code_graph_status --format json\n  code-index code_graph_query --operation outline --subject .opencode/skills/system-code-graph/mcp_server/index.ts\n  code-index detect_changes --json '{\"diff\":\"diff --git a/a.ts b/a.ts\\n\"}' --warm-only --timeout-ms 2000\n\nExit codes:\n  0 success, 1 runtime error, 64 usage/schema error, 69 protocol/dist mismatch, 75 retryable daemon error\n\nExit code notes:\n  detect_changes status:\"parse_error\" (malformed diff input) exits 64.\n  status:\"blocked\" readiness refusals exit 0 deliberately: blocked is an\n  actionable answer (run the surfaced requiredAction), not a CLI failure.`;\n}\n\nfunction parseCompletionShell(raw: string): CompletionShell {\n  if (raw === 'bash' || raw === 'zsh') return raw;\n  throw new CliUsageError('completion shell must be one of: bash, zsh');\n}\n\nfunction normalizeName(value: string): string {\n  return value.replace(/[-_]/g, '').toLowerCase();\n}\n\nfunction toCamelCaseFlag(value: string): string {\n  return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction toolDefinitions(): readonly ToolDefinition[] {\n  try {\n    assertCodeIndexCliManifest();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliProtocolError(message);\n  }\n  return CODE_INDEX_CLI_TOOL_DEFINITIONS;\n}\n\nfunction commandMap(): Map<string, ToolDefinition> {\n  const map = new Map<string, ToolDefinition>();\n  for (const tool of toolDefinitions()) {\n    for (const alias of commandAliases(tool.name)) {\n      const existing = map.get(alias);\n      if (existing && existing.name !== tool.name) {\n        throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n      }\n      map.set(alias, tool);\n    }\n  }\n  return map;\n}\n\nfunction getToolDefinition(command: string): ToolDefinition | null {\n  return commandMap().get(command) ?? null;\n}\n\nfunction inputPropertyNames(tool: ToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly properties?: unknown }).properties\n    : null;\n  if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n  return Object.keys(properties);\n}\n\nfunction requiredPropertyNames(tool: ToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const required = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly required?: unknown }).required\n    : null;\n  if (!Array.isArray(required)) return [];\n  return required.filter((value): value is string => typeof value === 'string');\n}\n\nfunction resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n  const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n  if (exact) return exact;\n\n  const normalized = normalizeName(rawFlag);\n  const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n  if (matched) return matched;\n\n  return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n}\n\nfunction parseValue(raw: string): unknown {\n  const trimmed = raw.trim();\n  if (trimmed === 'true') return true;\n  if (trimmed === 'false') return false;\n  if (trimmed === 'null') return null;\n  if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n    try {\n      return JSON.parse(trimmed) as unknown;\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      throw new CliUsageError(`Invalid JSON value: ${message}`);\n    }\n  }\n  return raw;\n}\n\nfunction parsePositiveInteger(raw: string, flagName: string): number {\n  if (!/^\\d+$/.test(raw)) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  const value = Number.parseInt(raw, 10);\n  if (!Number.isFinite(value) || value <= 0) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  return value;\n}\n\nfunction parseFormat(raw: string): OutputFormat {\n  if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n  throw new CliUsageError('--format must be one of: json, text, jsonl');\n}\n\nfunction parseInlineBoolean(raw: string, flagName: string): boolean {\n  if (raw === 'true' || raw === '1') return true;\n  if (raw === 'false' || raw === '0') return false;\n  throw new CliUsageError(`${flagName} must be true or false`);\n}\n\nfunction readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n  const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n  if (inline) return { value: inline[1], nextIndex: index + 1 };\n  const value = tokens[index + 1];\n  if (value === undefined) {\n    throw new CliUsageError(`${flagName} requires a value`);\n  }\n  return { value, nextIndex: index + 2 };\n}\n\nfunction parseJsonObject(raw: string): Record<string, unknown> {\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw) as unknown;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw new CliUsageError('--json must be a JSON object');\n  }\n  return parsed as Record<string, unknown>;\n}\n\nfunction envFlagEnabled(name: string): boolean {\n  const raw = process.env[name];\n  if (raw === undefined || raw === null) return false;\n  return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n}\n\nfunction defaultWarmOnly(): boolean {\n  return envFlagEnabled('SPECKIT_CODE_INDEX_CLI_WARM_ONLY')\n    || envFlagEnabled('SPECKIT_CODE_INDEX_CLI_PROMPT_TIME')\n    || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n    || envFlagEnabled('OPENCODE_PROMPT_TIME')\n    || envFlagEnabled('CODEX_PROMPT_TIME')\n    || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n}\n\nexport function parseCliArgs(argv: string[]): ParsedCommand {\n  const command = argv[0];\n  const warmOnlyDefault = defaultWarmOnly();\n  if (!command || command === '--help' || command === '-h') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n  }\n  if (command === '--version' || command === '-v') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n  }\n\n  let format: OutputFormat = 'json';\n  let timeoutMs = DEFAULT_TIMEOUT_MS;\n  let warmOnly = warmOnlyDefault;\n  let toolListMode: ToolListMode = 'full';\n  let completionShell: CompletionShell | undefined;\n  let jsonPayload: Record<string, unknown> | null = null;\n  const tool = getToolDefinition(command);\n  const parsedArgs: Record<string, unknown> = {};\n  const tokens = argv.slice(1);\n  let index = 0;\n\n  while (index < tokens.length) {\n    const token = tokens[index];\n    if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n      completionShell = parseCompletionShell(token);\n      index += 1;\n      continue;\n    }\n    if (!token.startsWith('--')) {\n      throw new CliUsageError(`Unexpected positional argument: ${token}`);\n    }\n    const rawFlag = token.slice(2).split('=', 1)[0];\n    const option = `--${rawFlag}`;\n\n    if (rawFlag === 'help' || rawFlag === 'h') {\n      return { command, format: 'text', timeoutMs, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n    }\n    if (rawFlag === 'format') {\n      const read = readOptionValue(tokens, index, option);\n      format = parseFormat(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'timeout-ms') {\n      const read = readOptionValue(tokens, index, option);\n      timeoutMs = parsePositiveInteger(read.value, option);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'warm-only') {\n      const inline = token.match(/^--[^=]+=(.*)$/);\n      warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'no-warm-only') {\n      warmOnly = false;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'compact') {\n      toolListMode = 'compact';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'names-only') {\n      toolListMode = 'names-only';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'json') {\n      const read = readOptionValue(tokens, index, option);\n      jsonPayload = parseJsonObject(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n\n    if (!tool) {\n      throw new CliUsageError(`Unknown command: ${command}`);\n    }\n\n    const propertyName = resolvePropertyName(rawFlag, tool);\n    const inline = token.match(/^--[^=]+=(.*)$/);\n    if (inline) {\n      parsedArgs[propertyName] = parseValue(inline[1]);\n      index += 1;\n      continue;\n    }\n\n    const next = tokens[index + 1];\n    if (next === undefined || next.startsWith('--')) {\n      parsedArgs[propertyName] = true;\n      index += 1;\n      continue;\n    }\n    parsedArgs[propertyName] = parseValue(next);\n    index += 2;\n  }\n\n  if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n    throw new CliUsageError('--json cannot be combined with per-parameter flags');\n  }\n\n  return {\n    command,\n    format,\n    timeoutMs,\n    warmOnly,\n    toolListMode,\n    completionShell,\n    args: jsonPayload ?? parsedArgs,\n    help: false,\n    version: false,\n  };\n}\n\nfunction declaredSchemaTypes(propertySchema: unknown): string[] {\n  if (!isRecord(propertySchema)) return [];\n  const type = propertySchema.type;\n  if (typeof type === 'string') return [type];\n  if (Array.isArray(type)) return type.filter((entry): entry is string => typeof entry === 'string');\n  return [];\n}\n\n// Flag values arrive as strings; without schema-driven coercion a numeric\n// filter like `--min-confidence 0.8` reaches the daemon as \"0.8\", which\n// numeric clamps silently treat as 0 — the user's filter is dropped under\n// a status:ok response. Coerce strings to the schema-declared primitive\n// and reject unparseable values as usage errors instead.\nfunction coerceArgsToSchema(tool: ToolDefinition, args: Record<string, unknown>): Record<string, unknown> {\n  const schema = tool.inputSchema;\n  const properties = isRecord(schema) && isRecord(schema.properties) ? schema.properties : null;\n  if (!properties) return args;\n\n  const coerced: Record<string, unknown> = { ...args };\n  for (const [key, value] of Object.entries(args)) {\n    if (typeof value !== 'string') continue;\n    const types = declaredSchemaTypes(properties[key]);\n    if (types.includes('number') || types.includes('integer')) {\n      const trimmed = value.trim();\n      const parsed = trimmed.length > 0 ? Number(trimmed) : Number.NaN;\n      if (!Number.isFinite(parsed)) {\n        throw new CliUsageError(`Invalid value for ${key}: expected ${types.includes('integer') ? 'an integer' : 'a number'}, received \"${value}\"`);\n      }\n      if (types.includes('integer') && !Number.isInteger(parsed)) {\n        throw new CliUsageError(`Invalid value for ${key}: expected an integer, received \"${value}\"`);\n      }\n      coerced[key] = parsed;\n      continue;\n    }\n    if (types.includes('boolean')) {\n      if (value === 'true' || value === '1') {\n        coerced[key] = true;\n        continue;\n      }\n      if (value === 'false' || value === '0') {\n        coerced[key] = false;\n        continue;\n      }\n      throw new CliUsageError(`Invalid value for ${key}: expected true or false, received \"${value}\"`);\n    }\n  }\n  return coerced;\n}\n\nfunction missingRequiredArgs(tool: ToolDefinition, args: Record<string, unknown>): string[] {\n  return requiredPropertyNames(tool).filter((key) => {\n    const value = args[key];\n    return value === undefined || value === null || (typeof value === 'string' && value.trim().length === 0);\n  });\n}\n\nfunction validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n  if (RESERVED_COMMANDS.has(parsed.command)) return null;\n  const tool = getToolDefinition(parsed.command);\n  if (!tool) {\n    throw new CliUsageError(`Unknown command: ${parsed.command}`);\n  }\n\n  const args = coerceArgsToSchema(tool, { ...parsed.args });\n  const missing = missingRequiredArgs(tool, args);\n  if (missing.length > 0) {\n    throw new CliUsageError(`Missing required field${missing.length === 1 ? '' : 's'}: ${missing.join(', ')}`);\n  }\n\n  try {\n    return {\n      tool,\n      args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n    };\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliUsageError(message);\n  }\n}\n\nfunction renderJson(value: unknown, format: OutputFormat): string {\n  if (format === 'jsonl') return JSON.stringify(value);\n  return JSON.stringify(value, null, 2);\n}\n\nfunction compactTool(tool: ToolDefinition): Record<string, unknown> {\n  return {\n    name: tool.name,\n    command: tool.name,\n    kebabCommand: toKebabCommand(tool.name),\n    camelCommand: toCamelCommand(tool.name),\n    aliases: commandAliases(tool.name),\n    description: tool.description,\n  };\n}\n\nfunction renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n  const tools = toolDefinitions();\n  const payload = {\n    status: 'ok',\n    data: {\n      count: tools.length,\n      mode,\n      tools: tools.map((tool) => ({\n        name: tool.name,\n        command: tool.name,\n        kebabCommand: toKebabCommand(tool.name),\n        camelCommand: toCamelCommand(tool.name),\n        aliases: commandAliases(tool.name),\n        description: tool.description,\n        inputSchema: tool.inputSchema,\n      })),\n    },\n  };\n  const compactPayload = {\n    status: 'ok',\n    data: {\n      count: tools.length,\n      mode,\n      tools: tools.map(compactTool),\n    },","lineStart":220,"lineEnd":639,"totalLines":1196,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/code-index-cli.ts","time":{"start":1781145045918,"end":1781145045921}},"metadata":{"openai":{"itemId":"fc_00a78692d2799090016a2a1dd5d618819182e36d9810c8922d"}},"id":"prt_eb4848b94001tMA1f2JlidXFK2","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb4845a6e001SnpdOkXNAQeCa1"}}
{"type":"tool_use","timestamp":1781145045950,"sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","part":{"type":"tool","tool":"read","callID":"call_OKomoqciODdUVrhqMTtvkGza","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/skill-advisor-cli.ts","offset":250,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/skill-advisor-cli.ts</path>\n<type>file</type>\n<content>\n250: }\n251: \n252: function getToolDefinition(command: string): SkillAdvisorCliToolDefinition | null {\n253:   return commandMap().get(command) ?? commandMap().get(normalizeName(command)) ?? null;\n254: }\n255: \n256: function inputPropertyNames(tool: SkillAdvisorCliToolDefinition): string[] {\n257:   const schema = tool.inputSchema;\n258:   const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n259:     ? (schema as { readonly properties?: unknown }).properties\n260:     : null;\n261:   if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n262:   return Object.keys(properties);\n263: }\n264: \n265: function resolvePropertyName(rawFlag: string, tool: SkillAdvisorCliToolDefinition): string {\n266:   const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n267:   if (exact) return exact;\n268: \n269:   const normalized = normalizeName(rawFlag);\n270:   const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n271:   if (matched) return matched;\n272: \n273:   return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n274: }\n275: \n276: function parseValue(raw: string): unknown {\n277:   const trimmed = raw.trim();\n278:   if (trimmed === 'true') return true;\n279:   if (trimmed === 'false') return false;\n280:   if (trimmed === 'null') return null;\n281:   if (/^-?(?:\\d+|\\d*\\.\\d+)(?:e[+-]?\\d+)?$/i.test(trimmed)) {\n282:     const parsed = Number(trimmed);\n283:     if (Number.isFinite(parsed)) return parsed;\n284:   }\n285:   if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n286:     try {\n287:       return JSON.parse(trimmed) as unknown;\n288:     } catch (error: unknown) {\n289:       const message = error instanceof Error ? error.message : String(error);\n290:       throw new CliUsageError(`Invalid JSON value: ${message}`);\n291:     }\n292:   }\n293:   return raw;\n294: }\n295: \n296: function parsePositiveInteger(raw: string, flagName: string): number {\n297:   if (!/^\\d+$/.test(raw)) {\n298:     throw new CliUsageError(`${flagName} must be a positive integer`);\n299:   }\n300:   const value = Number.parseInt(raw, 10);\n301:   if (!Number.isFinite(value) || value <= 0) {\n302:     throw new CliUsageError(`${flagName} must be a positive integer`);\n303:   }\n304:   return value;\n305: }\n306: \n307: function parseFormat(raw: string): OutputFormat {\n308:   if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n309:   throw new CliUsageError('--format must be one of: json, text, jsonl');\n310: }\n311: \n312: function parseInlineBoolean(raw: string, flagName: string): boolean {\n313:   if (raw === 'true' || raw === '1') return true;\n314:   if (raw === 'false' || raw === '0') return false;\n315:   throw new CliUsageError(`${flagName} must be true or false`);\n316: }\n317: \n318: function readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n319:   const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n320:   if (inline) return { value: inline[1], nextIndex: index + 1 };\n321:   const value = tokens[index + 1];\n322:   if (value === undefined) {\n323:     throw new CliUsageError(`${flagName} requires a value`);\n324:   }\n325:   return { value, nextIndex: index + 2 };\n326: }\n327: \n328: function parseJsonObject(raw: string): Record<string, unknown> {\n329:   let parsed: unknown;\n330:   try {\n331:     parsed = JSON.parse(raw) as unknown;\n332:   } catch (error: unknown) {\n333:     const message = error instanceof Error ? error.message : String(error);\n334:     throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n335:   }\n336:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n337:     throw new CliUsageError('--json must be a JSON object');\n338:   }\n339:   return parsed as Record<string, unknown>;\n340: }\n341: \n342: function envTrustedDefault(): boolean {\n343:   return process.env.MK_SKILL_ADVISOR_CLI_TRUSTED === '1'\n344:     || process.env.SPECKIT_SKILL_ADVISOR_CLI_TRUSTED === '1';\n345: }\n346: \n347: function envFlagEnabled(name: string): boolean {\n348:   const raw = process.env[name];\n349:   if (raw === undefined || raw === null) return false;\n350:   return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n351: }\n352: \n353: function defaultWarmOnly(): boolean {\n354:   return envFlagEnabled('MK_SKILL_ADVISOR_CLI_WARM_ONLY')\n355:     || envFlagEnabled('SPECKIT_SKILL_ADVISOR_CLI_WARM_ONLY')\n356:     || envFlagEnabled('MK_SKILL_ADVISOR_CLI_PROMPT_TIME')\n357:     || envFlagEnabled('SPECKIT_SKILL_ADVISOR_CLI_PROMPT_TIME')\n358:     || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n359:     || envFlagEnabled('OPENCODE_PROMPT_TIME')\n360:     || envFlagEnabled('CODEX_PROMPT_TIME')\n361:     || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n362: }\n363: \n364: export function parseCliArgs(argv: string[]): ParsedCommand {\n365:   const command = argv[0];\n366:   const trustedDefault = envTrustedDefault();\n367:   const warmOnlyDefault = defaultWarmOnly();\n368:   if (!command || command === '--help' || command === '-h') {\n369:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false, trusted: trustedDefault };\n370:   }\n371:   if (command === '--version' || command === '-v') {\n372:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true, trusted: trustedDefault };\n373:   }\n374: \n375:   let format: OutputFormat = 'json';\n376:   let timeoutMs = DEFAULT_TIMEOUT_MS;\n377:   let sessionId: string | undefined;\n378:   let warmOnly = warmOnlyDefault;\n379:   let toolListMode: ToolListMode = 'full';\n380:   let completionShell: CompletionShell | undefined;\n381:   let jsonPayload: Record<string, unknown> | null = null;\n382:   let trusted = trustedDefault;\n383:   const tool = getToolDefinition(command);\n384:   const parsedArgs: Record<string, unknown> = {};\n385:   const tokens = argv.slice(1);\n386:   let index = 0;\n387: \n388:   while (index < tokens.length) {\n389:     const token = tokens[index];\n390:     if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n391:       completionShell = parseCompletionShell(token);\n392:       index += 1;\n393:       continue;\n394:     }\n395:     if (!token.startsWith('--')) {\n396:       throw new CliUsageError(`Unexpected positional argument: ${token}`);\n397:     }\n398:     const rawFlag = token.slice(2).split('=', 1)[0];\n399:     const option = `--${rawFlag}`;\n400: \n401:     if (rawFlag === 'help' || rawFlag === 'h') {\n402:       return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false, trusted };\n403:     }\n404:     if (rawFlag === 'format') {\n405:       const read = readOptionValue(tokens, index, option);\n406:       format = parseFormat(read.value);\n407:       index = read.nextIndex;\n408:       continue;\n409:     }\n410:     if (rawFlag === 'timeout-ms') {\n411:       const read = readOptionValue(tokens, index, option);\n412:       timeoutMs = parsePositiveInteger(read.value, option);\n413:       index = read.nextIndex;\n414:       continue;\n415:     }\n416:     if (rawFlag === 'session-id') {\n417:       const read = readOptionValue(tokens, index, option);\n418:       sessionId = read.value;\n419:       index = read.nextIndex;\n420:       continue;\n421:     }\n422:     if (rawFlag === 'json') {\n423:       const read = readOptionValue(tokens, index, option);\n424:       jsonPayload = parseJsonObject(read.value);\n425:       index = read.nextIndex;\n426:       continue;\n427:     }\n428:     if (rawFlag === 'trusted' || rawFlag === 'maintainer') {\n429:       trusted = true;\n430:       index += 1;\n431:       continue;\n432:     }\n433:     if (rawFlag === 'untrusted') {\n434:       trusted = false;\n435:       index += 1;\n436:       continue;\n437:     }\n438:     if (rawFlag === 'compact') {\n439:       toolListMode = 'compact';\n440:       index += 1;\n441:       continue;\n442:     }\n443:     if (rawFlag === 'names-only') {\n444:       toolListMode = 'names-only';\n445:       index += 1;\n446:       continue;\n447:     }\n448:     if (rawFlag === 'warm-only') {\n449:       const inline = token.match(/^--[^=]+=(.*)$/);\n450:       warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n451:       index += 1;\n452:       continue;\n453:     }\n454:     if (rawFlag === 'no-warm-only') {\n455:       warmOnly = false;\n456:       index += 1;\n457:       continue;\n458:     }\n459: \n460:     if (!tool) {\n461:       throw new CliUsageError(`Unknown command: ${command}`);\n462:     }\n463: \n464:     const propertyName = resolvePropertyName(rawFlag, tool);\n465:     const inline = token.match(/^--[^=]+=(.*)$/);\n466:     if (inline) {\n467:       parsedArgs[propertyName] = parseValue(inline[1]);\n468:       index += 1;\n469:       continue;\n470:     }\n471: \n472:     const next = tokens[index + 1];\n473:     if (next === undefined || next.startsWith('--')) {\n474:       parsedArgs[propertyName] = true;\n475:       index += 1;\n476:       continue;\n477:     }\n478:     parsedArgs[propertyName] = parseValue(next);\n479:     index += 2;\n480:   }\n481: \n482:   if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n483:     throw new CliUsageError('--json cannot be combined with per-parameter flags');\n484:   }\n485: \n486:   return {\n487:     command,\n488:     format,\n489:     timeoutMs,\n490:     sessionId,\n491:     warmOnly,\n492:     toolListMode,\n493:     completionShell,\n494:     args: jsonPayload ?? parsedArgs,\n495:     help: false,\n496:     version: false,\n497:     trusted,\n498:   };\n499: }\n500: \n501: function isRecord(value: unknown): value is Record<string, unknown> {\n502:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n503: }\n504: \n505: function schemaTypes(schema: Record<string, unknown>): string[] {\n506:   const type = schema.type;\n507:   if (typeof type === 'string') return [type];\n508:   if (Array.isArray(type) && type.every((entry) => typeof entry === 'string')) return type as string[];\n509:   return [];\n510: }\n511: \n512: function coerceValueForSchema(schema: unknown, value: unknown): unknown {\n513:   if (!isRecord(schema)) return value;\n514:   const types = schemaTypes(schema);\n515:   if (types.includes('number') && typeof value === 'string') {\n516:     const parsed = Number(value);\n517:     if (Number.isFinite(parsed)) return parsed;\n518:   }\n519:   if (types.includes('boolean') && typeof value === 'string') {\n520:     if (value === 'true') return true;\n521:     if (value === 'false') return false;\n522:   }\n523:   if (types.includes('object') && isRecord(value) && isRecord(schema.properties)) {\n524:     return coerceObjectForSchema(schema, value);\n525:   }\n526:   if (types.includes('array') && Array.isArray(value)) {\n527:     return value.map((entry) => coerceValueForSchema(schema.items, entry));\n528:   }\n529:   return value;\n530: }\n531: \n532: function coerceObjectForSchema(schema: Record<string, unknown>, args: Record<string, unknown>): Record<string, unknown> {\n533:   if (!isRecord(schema.properties)) return args;\n534:   const coerced: Record<string, unknown> = { ...args };\n535:   for (const [key, value] of Object.entries(args)) {\n536:     coerced[key] = coerceValueForSchema(schema.properties[key], value);\n537:   }\n538:   return coerced;\n539: }\n540: \n541: function expectedTypeLabel(types: string[]): string {\n542:   return types.length > 0 ? types.join(' or ') : 'valid JSON schema value';\n543: }\n544: \n545: function valueType(value: unknown): string {\n546:   if (value === null) return 'null';\n547:   if (Array.isArray(value)) return 'array';\n548:   return typeof value;\n549: }\n550: \n551: function valueMatchesTypes(value: unknown, types: string[]): boolean {\n552:   if (types.length === 0) return true;\n553:   return types.some((type) => {\n554:     if (type === 'null') return value === null;\n555:     if (type === 'array') return Array.isArray(value);\n556:     if (type === 'object') return isRecord(value);\n557:     if (type === 'number') return typeof value === 'number' && Number.isFinite(value);\n558:     if (type === 'integer') return Number.isInteger(value);\n559:     return typeof value === type;\n560:   });\n561: }\n562: \n563: function validateJsonSchema(schema: unknown, value: unknown, location: string): void {\n564:   if (!isRecord(schema)) return;\n565:   const types = schemaTypes(schema);\n566:   if (!valueMatchesTypes(value, types)) {\n567:     throw new ToolSchemaValidationError(`${location} expected ${expectedTypeLabel(types)}, received ${valueType(value)}`);\n568:   }\n569: \n570:   if (Object.prototype.hasOwnProperty.call(schema, 'const') && value !== schema.const) {\n571:     throw new ToolSchemaValidationError(`${location} must be ${JSON.stringify(schema.const)}`);\n572:   }\n573:   if (Array.isArray(schema.enum) && !schema.enum.includes(value)) {\n574:     throw new ToolSchemaValidationError(`${location} must be one of: ${schema.enum.map(String).join(', ')}`);\n575:   }\n576: \n577:   if (typeof value === 'string') {\n578:     if (typeof schema.minLength === 'number' && value.length < schema.minLength) {\n579:       throw new ToolSchemaValidationError(`${location} must be at least ${schema.minLength} character(s)`);\n580:     }\n581:     if (typeof schema.maxLength === 'number' && value.length > schema.maxLength) {\n582:       throw new ToolSchemaValidationError(`${location} must be at most ${schema.maxLength} character(s)`);\n583:     }\n584:   }\n585: \n586:   if (typeof value === 'number') {\n587:     if (typeof schema.minimum === 'number' && value < schema.minimum) {\n588:       throw new ToolSchemaValidationError(`${location} must be >= ${schema.minimum}`);\n589:     }\n590:     if (typeof schema.maximum === 'number' && value > schema.maximum) {\n591:       throw new ToolSchemaValidationError(`${location} must be <= ${schema.maximum}`);\n592:     }\n593:   }\n594: \n595:   if (Array.isArray(value)) {\n596:     if (typeof schema.minItems === 'number' && value.length < schema.minItems) {\n597:       throw new ToolSchemaValidationError(`${location} must contain at least ${schema.minItems} item(s)`);\n598:     }\n599:     if (typeof schema.maxItems === 'number' && value.length > schema.maxItems) {\n600:       throw new ToolSchemaValidationError(`${location} must contain at most ${schema.maxItems} item(s)`);\n601:     }\n602:     value.forEach((entry, index) => validateJsonSchema(schema.items, entry, `${location}[${index}]`));\n603:   }\n604: \n605:   if (isRecord(value)) {\n606:     const properties = isRecord(schema.properties) ? schema.properties : {};\n607:     const required = Array.isArray(schema.required) ? schema.required.filter((entry): entry is string => typeof entry === 'string') : [];\n608:     for (const key of required) {\n609:       if (!Object.prototype.hasOwnProperty.call(value, key)) {\n610:         throw new ToolSchemaValidationError(`${location}.${key} is required`);\n611:       }\n612:     }\n613:     if (schema.additionalProperties === false) {\n614:       const unknownKeys = Object.keys(value).filter((key) => !Object.prototype.hasOwnProperty.call(properties, key));\n615:       if (unknownKeys.length > 0) {\n616:         throw new ToolSchemaValidationError(`Unknown parameter(s): ${unknownKeys.join(', ')}`);\n617:       }\n618:     }\n619:     for (const [key, nestedValue] of Object.entries(value)) {\n620:       if (Object.prototype.hasOwnProperty.call(properties, key)) {\n621:         validateJsonSchema(properties[key], nestedValue, `${location}.${key}`);\n622:       }\n623:     }\n624:   }\n625: }\n626: \n627: function formatValidationMessage(error: unknown): string {\n628:   if (error instanceof ToolSchemaValidationError) return error.message;\n629:   if (error instanceof Error) return error.message;\n630:   return String(error);\n631: }\n632: \n633: function applySchemaDefaults(schema: unknown, args: Record<string, unknown>): Record<string, unknown> {\n634:   if (!isRecord(schema) || !isRecord(schema.properties)) return args;\n635:   const withDefaults: Record<string, unknown> = { ...args };\n636:   for (const [key, propertySchema] of Object.entries(schema.properties)) {\n637:     if (Object.prototype.hasOwnProperty.call(withDefaults, key)) continue;\n638:     if (isRecord(propertySchema) && Object.prototype.hasOwnProperty.call(propertySchema, 'default')) {\n639:       withDefaults[key] = propertySchema.default;\n640:     }\n641:   }\n642:   return withDefaults;\n643: }\n644: \n645: function validateToolArgs(tool: SkillAdvisorCliToolDefinition, args: Record<string, unknown>): Record<string, unknown> {\n646:   const coerced = coerceObjectForSchema(tool.inputSchema, applySchemaDefaults(tool.inputSchema, args));\n647:   try {\n648:     validateJsonSchema(tool.inputSchema, coerced, tool.name);\n649:   } catch (error: unknown) {\n650:     throw new ToolSchemaValidationError(`Invalid arguments for ${tool.name}: ${formatValidationMessage(error)}`);\n651:   }\n652:   return coerced;\n653: }\n654: \n655: function isPropagateApply(args: Record<string, unknown>): boolean {\n656:   return args.mode === 'apply' && args.dryRun !== true;\n657: }\n658: \n659: function assertTrustedForMutation(toolName: string, args: Record<string, unknown>, trusted: boolean): void {\n660:   const requiresTrusted = toolName === 'advisor_rebuild'\n661:     || toolName === 'skill_graph_scan'\n662:     || (toolName === 'skill_graph_propagate_enhances' && isPropagateApply(args));\n663:   if (!requiresTrusted || trusted) return;\n664:   throw new CliUsageError(`${toolName} requires --trusted or MK_SKILL_ADVISOR_CLI_TRUSTED=1`);\n665: }\n666: \n667: function validateCommand(parsed: ParsedCommand): { readonly tool: SkillAdvisorCliToolDefinition; readonly args: Record<string, unknown> } | null {\n668:   if (RESERVED_COMMANDS.has(parsed.command)) return null;\n669:   const tool = getToolDefinition(parsed.command);\n670:   if (!tool) {\n671:     throw new CliUsageError(`Unknown command: ${parsed.command}`);\n672:   }\n673: \n674:   const args = { ...parsed.args };\n675:   const properties = new Set(inputPropertyNames(tool));\n676:   if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n677:     args.sessionId = parsed.sessionId;\n678:   } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n679:     args.session_id = parsed.sessionId;\n680:   }\n681: \n682:   const validated = validateToolArgs(tool, args);\n683:   assertTrustedForMutation(tool.name, validated, parsed.trusted);\n684:   return { tool, args: validated };\n685: }\n686: \n687: function renderJson(value: unknown, format: OutputFormat): string {\n688:   if (format === 'jsonl') return JSON.stringify(value);\n689:   return JSON.stringify(value, null, 2);\n690: }\n691: \n692: function usageText(command?: string): string {\n693:   const tool = command ? getToolDefinition(command) : null;\n694:   if (tool) {\n695:     return `skill-advisor ${tool.command}\n696: \n697: Description:\n698:   ${tool.description}\n699: \n700: Aliases:\n701:   ${tool.aliases.join(', ')}\n702: \n703: Input schema:\n704: ${JSON.stringify(tool.inputSchema, null, 2)}`;\n705:   }\n706: \n707:   const commands = SKILL_ADVISOR_CLI_TOOL_MANIFEST\n708:     .map((entry) => `  ${entry.command} (${entry.kebabCommand}, ${entry.camelCommand})`)\n709:     .join('\\n');\n710: \n711:   return `skill-advisor - daemon-backed CLI for mk-skill-advisor\n712: \n713: Usage:\n714:   skill-advisor list-tools [--format json|text|jsonl] [--compact|--names-only]\n715:   skill-advisor completion bash|zsh\n716:   skill-advisor <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--trusted] [--warm-only]\n717:   skill-advisor <tool_name> --param value [--another-param value]\n718: \n719: Commands:\n720: ${commands}\n721: \n722: Examples:\n723:   skill-advisor list-tools --format text\n724:   skill-advisor list-tools --compact\n725:   skill-advisor completion zsh\n726:   skill-advisor advisor_status --workspace-root \"$PWD\" --format text\n727:   skill-advisor advisor_recommend --prompt \"implement cli core\"\n728:   skill-advisor advisor_rebuild --trusted --force true\n729:   skill-advisor skill_graph_scan --trusted --format text\n730: \n731: Trusted context:\n732:   Mutation commands require --trusted or MK_SKILL_ADVISOR_CLI_TRUSTED=1.\n733:   Calls are sent as untrusted by default.\n734: \n735: Exit codes:\n736:   0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error`;\n737: }\n738: \n739: function parseCompletionShell(raw: string): CompletionShell {\n740:   if (raw === 'bash' || raw === 'zsh') return raw;\n741:   throw new CliUsageError('completion shell must be one of: bash, zsh');\n742: }\n743: \n744: function compactTool(tool: SkillAdvisorCliToolDefinition): Record<string, unknown> {\n745:   return {\n746:     name: tool.name,\n747:     command: tool.command,\n748:     kebabCommand: tool.kebabCommand,\n749:     camelCommand: tool.camelCommand,\n750:     aliases: tool.aliases,\n751:     description: tool.description,\n752:   };\n753: }\n754: \n755: function renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n756:   const payload = {\n757:     status: 'ok',\n758:     data: {\n759:       count: SKILL_ADVISOR_CLI_TOOL_MANIFEST.length,\n760:       mode,\n761:       tools: SKILL_ADVISOR_CLI_TOOL_MANIFEST.map((tool) => ({\n762:         name: tool.name,\n763:         command: tool.command,\n764:         kebabCommand: tool.kebabCommand,\n765:         camelCommand: tool.camelCommand,\n766:         description: tool.description,\n767:         inputSchema: tool.inputSchema,\n768:       })),\n769:     },\n\n(Showing lines 250-769 of 1353. Use offset=770 to continue.)\n</content>","metadata":{"preview":"}\n\nfunction getToolDefinition(command: string): SkillAdvisorCliToolDefinition | null {\n  return commandMap().get(command) ?? commandMap().get(normalizeName(command)) ?? null;\n}\n\nfunction inputPropertyNames(tool: SkillAdvisorCliToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly properties?: unknown }).properties\n    : null;\n  if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n  return Object.keys(properties);\n}\n\nfunction resolvePropertyName(rawFlag: string, tool: SkillAdvisorCliToolDefinition): string {\n  const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n  if (exact) return exact;\n\n  const normalized = normalizeName(rawFlag);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/skill-advisor-cli.ts","text":"}\n\nfunction getToolDefinition(command: string): SkillAdvisorCliToolDefinition | null {\n  return commandMap().get(command) ?? commandMap().get(normalizeName(command)) ?? null;\n}\n\nfunction inputPropertyNames(tool: SkillAdvisorCliToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly properties?: unknown }).properties\n    : null;\n  if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n  return Object.keys(properties);\n}\n\nfunction resolvePropertyName(rawFlag: string, tool: SkillAdvisorCliToolDefinition): string {\n  const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n  if (exact) return exact;\n\n  const normalized = normalizeName(rawFlag);\n  const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n  if (matched) return matched;\n\n  return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n}\n\nfunction parseValue(raw: string): unknown {\n  const trimmed = raw.trim();\n  if (trimmed === 'true') return true;\n  if (trimmed === 'false') return false;\n  if (trimmed === 'null') return null;\n  if (/^-?(?:\\d+|\\d*\\.\\d+)(?:e[+-]?\\d+)?$/i.test(trimmed)) {\n    const parsed = Number(trimmed);\n    if (Number.isFinite(parsed)) return parsed;\n  }\n  if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n    try {\n      return JSON.parse(trimmed) as unknown;\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      throw new CliUsageError(`Invalid JSON value: ${message}`);\n    }\n  }\n  return raw;\n}\n\nfunction parsePositiveInteger(raw: string, flagName: string): number {\n  if (!/^\\d+$/.test(raw)) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  const value = Number.parseInt(raw, 10);\n  if (!Number.isFinite(value) || value <= 0) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  return value;\n}\n\nfunction parseFormat(raw: string): OutputFormat {\n  if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n  throw new CliUsageError('--format must be one of: json, text, jsonl');\n}\n\nfunction parseInlineBoolean(raw: string, flagName: string): boolean {\n  if (raw === 'true' || raw === '1') return true;\n  if (raw === 'false' || raw === '0') return false;\n  throw new CliUsageError(`${flagName} must be true or false`);\n}\n\nfunction readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n  const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n  if (inline) return { value: inline[1], nextIndex: index + 1 };\n  const value = tokens[index + 1];\n  if (value === undefined) {\n    throw new CliUsageError(`${flagName} requires a value`);\n  }\n  return { value, nextIndex: index + 2 };\n}\n\nfunction parseJsonObject(raw: string): Record<string, unknown> {\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw) as unknown;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw new CliUsageError('--json must be a JSON object');\n  }\n  return parsed as Record<string, unknown>;\n}\n\nfunction envTrustedDefault(): boolean {\n  return process.env.MK_SKILL_ADVISOR_CLI_TRUSTED === '1'\n    || process.env.SPECKIT_SKILL_ADVISOR_CLI_TRUSTED === '1';\n}\n\nfunction envFlagEnabled(name: string): boolean {\n  const raw = process.env[name];\n  if (raw === undefined || raw === null) return false;\n  return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n}\n\nfunction defaultWarmOnly(): boolean {\n  return envFlagEnabled('MK_SKILL_ADVISOR_CLI_WARM_ONLY')\n    || envFlagEnabled('SPECKIT_SKILL_ADVISOR_CLI_WARM_ONLY')\n    || envFlagEnabled('MK_SKILL_ADVISOR_CLI_PROMPT_TIME')\n    || envFlagEnabled('SPECKIT_SKILL_ADVISOR_CLI_PROMPT_TIME')\n    || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n    || envFlagEnabled('OPENCODE_PROMPT_TIME')\n    || envFlagEnabled('CODEX_PROMPT_TIME')\n    || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n}\n\nexport function parseCliArgs(argv: string[]): ParsedCommand {\n  const command = argv[0];\n  const trustedDefault = envTrustedDefault();\n  const warmOnlyDefault = defaultWarmOnly();\n  if (!command || command === '--help' || command === '-h') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false, trusted: trustedDefault };\n  }\n  if (command === '--version' || command === '-v') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true, trusted: trustedDefault };\n  }\n\n  let format: OutputFormat = 'json';\n  let timeoutMs = DEFAULT_TIMEOUT_MS;\n  let sessionId: string | undefined;\n  let warmOnly = warmOnlyDefault;\n  let toolListMode: ToolListMode = 'full';\n  let completionShell: CompletionShell | undefined;\n  let jsonPayload: Record<string, unknown> | null = null;\n  let trusted = trustedDefault;\n  const tool = getToolDefinition(command);\n  const parsedArgs: Record<string, unknown> = {};\n  const tokens = argv.slice(1);\n  let index = 0;\n\n  while (index < tokens.length) {\n    const token = tokens[index];\n    if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n      completionShell = parseCompletionShell(token);\n      index += 1;\n      continue;\n    }\n    if (!token.startsWith('--')) {\n      throw new CliUsageError(`Unexpected positional argument: ${token}`);\n    }\n    const rawFlag = token.slice(2).split('=', 1)[0];\n    const option = `--${rawFlag}`;\n\n    if (rawFlag === 'help' || rawFlag === 'h') {\n      return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false, trusted };\n    }\n    if (rawFlag === 'format') {\n      const read = readOptionValue(tokens, index, option);\n      format = parseFormat(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'timeout-ms') {\n      const read = readOptionValue(tokens, index, option);\n      timeoutMs = parsePositiveInteger(read.value, option);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'session-id') {\n      const read = readOptionValue(tokens, index, option);\n      sessionId = read.value;\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'json') {\n      const read = readOptionValue(tokens, index, option);\n      jsonPayload = parseJsonObject(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'trusted' || rawFlag === 'maintainer') {\n      trusted = true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'untrusted') {\n      trusted = false;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'compact') {\n      toolListMode = 'compact';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'names-only') {\n      toolListMode = 'names-only';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'warm-only') {\n      const inline = token.match(/^--[^=]+=(.*)$/);\n      warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'no-warm-only') {\n      warmOnly = false;\n      index += 1;\n      continue;\n    }\n\n    if (!tool) {\n      throw new CliUsageError(`Unknown command: ${command}`);\n    }\n\n    const propertyName = resolvePropertyName(rawFlag, tool);\n    const inline = token.match(/^--[^=]+=(.*)$/);\n    if (inline) {\n      parsedArgs[propertyName] = parseValue(inline[1]);\n      index += 1;\n      continue;\n    }\n\n    const next = tokens[index + 1];\n    if (next === undefined || next.startsWith('--')) {\n      parsedArgs[propertyName] = true;\n      index += 1;\n      continue;\n    }\n    parsedArgs[propertyName] = parseValue(next);\n    index += 2;\n  }\n\n  if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n    throw new CliUsageError('--json cannot be combined with per-parameter flags');\n  }\n\n  return {\n    command,\n    format,\n    timeoutMs,\n    sessionId,\n    warmOnly,\n    toolListMode,\n    completionShell,\n    args: jsonPayload ?? parsedArgs,\n    help: false,\n    version: false,\n    trusted,\n  };\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction schemaTypes(schema: Record<string, unknown>): string[] {\n  const type = schema.type;\n  if (typeof type === 'string') return [type];\n  if (Array.isArray(type) && type.every((entry) => typeof entry === 'string')) return type as string[];\n  return [];\n}\n\nfunction coerceValueForSchema(schema: unknown, value: unknown): unknown {\n  if (!isRecord(schema)) return value;\n  const types = schemaTypes(schema);\n  if (types.includes('number') && typeof value === 'string') {\n    const parsed = Number(value);\n    if (Number.isFinite(parsed)) return parsed;\n  }\n  if (types.includes('boolean') && typeof value === 'string') {\n    if (value === 'true') return true;\n    if (value === 'false') return false;\n  }\n  if (types.includes('object') && isRecord(value) && isRecord(schema.properties)) {\n    return coerceObjectForSchema(schema, value);\n  }\n  if (types.includes('array') && Array.isArray(value)) {\n    return value.map((entry) => coerceValueForSchema(schema.items, entry));\n  }\n  return value;\n}\n\nfunction coerceObjectForSchema(schema: Record<string, unknown>, args: Record<string, unknown>): Record<string, unknown> {\n  if (!isRecord(schema.properties)) return args;\n  const coerced: Record<string, unknown> = { ...args };\n  for (const [key, value] of Object.entries(args)) {\n    coerced[key] = coerceValueForSchema(schema.properties[key], value);\n  }\n  return coerced;\n}\n\nfunction expectedTypeLabel(types: string[]): string {\n  return types.length > 0 ? types.join(' or ') : 'valid JSON schema value';\n}\n\nfunction valueType(value: unknown): string {\n  if (value === null) return 'null';\n  if (Array.isArray(value)) return 'array';\n  return typeof value;\n}\n\nfunction valueMatchesTypes(value: unknown, types: string[]): boolean {\n  if (types.length === 0) return true;\n  return types.some((type) => {\n    if (type === 'null') return value === null;\n    if (type === 'array') return Array.isArray(value);\n    if (type === 'object') return isRecord(value);\n    if (type === 'number') return typeof value === 'number' && Number.isFinite(value);\n    if (type === 'integer') return Number.isInteger(value);\n    return typeof value === type;\n  });\n}\n\nfunction validateJsonSchema(schema: unknown, value: unknown, location: string): void {\n  if (!isRecord(schema)) return;\n  const types = schemaTypes(schema);\n  if (!valueMatchesTypes(value, types)) {\n    throw new ToolSchemaValidationError(`${location} expected ${expectedTypeLabel(types)}, received ${valueType(value)}`);\n  }\n\n  if (Object.prototype.hasOwnProperty.call(schema, 'const') && value !== schema.const) {\n    throw new ToolSchemaValidationError(`${location} must be ${JSON.stringify(schema.const)}`);\n  }\n  if (Array.isArray(schema.enum) && !schema.enum.includes(value)) {\n    throw new ToolSchemaValidationError(`${location} must be one of: ${schema.enum.map(String).join(', ')}`);\n  }\n\n  if (typeof value === 'string') {\n    if (typeof schema.minLength === 'number' && value.length < schema.minLength) {\n      throw new ToolSchemaValidationError(`${location} must be at least ${schema.minLength} character(s)`);\n    }\n    if (typeof schema.maxLength === 'number' && value.length > schema.maxLength) {\n      throw new ToolSchemaValidationError(`${location} must be at most ${schema.maxLength} character(s)`);\n    }\n  }\n\n  if (typeof value === 'number') {\n    if (typeof schema.minimum === 'number' && value < schema.minimum) {\n      throw new ToolSchemaValidationError(`${location} must be >= ${schema.minimum}`);\n    }\n    if (typeof schema.maximum === 'number' && value > schema.maximum) {\n      throw new ToolSchemaValidationError(`${location} must be <= ${schema.maximum}`);\n    }\n  }\n\n  if (Array.isArray(value)) {\n    if (typeof schema.minItems === 'number' && value.length < schema.minItems) {\n      throw new ToolSchemaValidationError(`${location} must contain at least ${schema.minItems} item(s)`);\n    }\n    if (typeof schema.maxItems === 'number' && value.length > schema.maxItems) {\n      throw new ToolSchemaValidationError(`${location} must contain at most ${schema.maxItems} item(s)`);\n    }\n    value.forEach((entry, index) => validateJsonSchema(schema.items, entry, `${location}[${index}]`));\n  }\n\n  if (isRecord(value)) {\n    const properties = isRecord(schema.properties) ? schema.properties : {};\n    const required = Array.isArray(schema.required) ? schema.required.filter((entry): entry is string => typeof entry === 'string') : [];\n    for (const key of required) {\n      if (!Object.prototype.hasOwnProperty.call(value, key)) {\n        throw new ToolSchemaValidationError(`${location}.${key} is required`);\n      }\n    }\n    if (schema.additionalProperties === false) {\n      const unknownKeys = Object.keys(value).filter((key) => !Object.prototype.hasOwnProperty.call(properties, key));\n      if (unknownKeys.length > 0) {\n        throw new ToolSchemaValidationError(`Unknown parameter(s): ${unknownKeys.join(', ')}`);\n      }\n    }\n    for (const [key, nestedValue] of Object.entries(value)) {\n      if (Object.prototype.hasOwnProperty.call(properties, key)) {\n        validateJsonSchema(properties[key], nestedValue, `${location}.${key}`);\n      }\n    }\n  }\n}\n\nfunction formatValidationMessage(error: unknown): string {\n  if (error instanceof ToolSchemaValidationError) return error.message;\n  if (error instanceof Error) return error.message;\n  return String(error);\n}\n\nfunction applySchemaDefaults(schema: unknown, args: Record<string, unknown>): Record<string, unknown> {\n  if (!isRecord(schema) || !isRecord(schema.properties)) return args;\n  const withDefaults: Record<string, unknown> = { ...args };\n  for (const [key, propertySchema] of Object.entries(schema.properties)) {\n    if (Object.prototype.hasOwnProperty.call(withDefaults, key)) continue;\n    if (isRecord(propertySchema) && Object.prototype.hasOwnProperty.call(propertySchema, 'default')) {\n      withDefaults[key] = propertySchema.default;\n    }\n  }\n  return withDefaults;\n}\n\nfunction validateToolArgs(tool: SkillAdvisorCliToolDefinition, args: Record<string, unknown>): Record<string, unknown> {\n  const coerced = coerceObjectForSchema(tool.inputSchema, applySchemaDefaults(tool.inputSchema, args));\n  try {\n    validateJsonSchema(tool.inputSchema, coerced, tool.name);\n  } catch (error: unknown) {\n    throw new ToolSchemaValidationError(`Invalid arguments for ${tool.name}: ${formatValidationMessage(error)}`);\n  }\n  return coerced;\n}\n\nfunction isPropagateApply(args: Record<string, unknown>): boolean {\n  return args.mode === 'apply' && args.dryRun !== true;\n}\n\nfunction assertTrustedForMutation(toolName: string, args: Record<string, unknown>, trusted: boolean): void {\n  const requiresTrusted = toolName === 'advisor_rebuild'\n    || toolName === 'skill_graph_scan'\n    || (toolName === 'skill_graph_propagate_enhances' && isPropagateApply(args));\n  if (!requiresTrusted || trusted) return;\n  throw new CliUsageError(`${toolName} requires --trusted or MK_SKILL_ADVISOR_CLI_TRUSTED=1`);\n}\n\nfunction validateCommand(parsed: ParsedCommand): { readonly tool: SkillAdvisorCliToolDefinition; readonly args: Record<string, unknown> } | null {\n  if (RESERVED_COMMANDS.has(parsed.command)) return null;\n  const tool = getToolDefinition(parsed.command);\n  if (!tool) {\n    throw new CliUsageError(`Unknown command: ${parsed.command}`);\n  }\n\n  const args = { ...parsed.args };\n  const properties = new Set(inputPropertyNames(tool));\n  if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n    args.sessionId = parsed.sessionId;\n  } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n    args.session_id = parsed.sessionId;\n  }\n\n  const validated = validateToolArgs(tool, args);\n  assertTrustedForMutation(tool.name, validated, parsed.trusted);\n  return { tool, args: validated };\n}\n\nfunction renderJson(value: unknown, format: OutputFormat): string {\n  if (format === 'jsonl') return JSON.stringify(value);\n  return JSON.stringify(value, null, 2);\n}\n\nfunction usageText(command?: string): string {\n  const tool = command ? getToolDefinition(command) : null;\n  if (tool) {\n    return `skill-advisor ${tool.command}\n\nDescription:\n  ${tool.description}\n\nAliases:\n  ${tool.aliases.join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  const commands = SKILL_ADVISOR_CLI_TOOL_MANIFEST\n    .map((entry) => `  ${entry.command} (${entry.kebabCommand}, ${entry.camelCommand})`)\n    .join('\\n');\n\n  return `skill-advisor - daemon-backed CLI for mk-skill-advisor\n\nUsage:\n  skill-advisor list-tools [--format json|text|jsonl] [--compact|--names-only]\n  skill-advisor completion bash|zsh\n  skill-advisor <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--trusted] [--warm-only]\n  skill-advisor <tool_name> --param value [--another-param value]\n\nCommands:\n${commands}\n\nExamples:\n  skill-advisor list-tools --format text\n  skill-advisor list-tools --compact\n  skill-advisor completion zsh\n  skill-advisor advisor_status --workspace-root \"$PWD\" --format text\n  skill-advisor advisor_recommend --prompt \"implement cli core\"\n  skill-advisor advisor_rebuild --trusted --force true\n  skill-advisor skill_graph_scan --trusted --format text\n\nTrusted context:\n  Mutation commands require --trusted or MK_SKILL_ADVISOR_CLI_TRUSTED=1.\n  Calls are sent as untrusted by default.\n\nExit codes:\n  0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error`;\n}\n\nfunction parseCompletionShell(raw: string): CompletionShell {\n  if (raw === 'bash' || raw === 'zsh') return raw;\n  throw new CliUsageError('completion shell must be one of: bash, zsh');\n}\n\nfunction compactTool(tool: SkillAdvisorCliToolDefinition): Record<string, unknown> {\n  return {\n    name: tool.name,\n    command: tool.command,\n    kebabCommand: tool.kebabCommand,\n    camelCommand: tool.camelCommand,\n    aliases: tool.aliases,\n    description: tool.description,\n  };\n}\n\nfunction renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n  const payload = {\n    status: 'ok',\n    data: {\n      count: SKILL_ADVISOR_CLI_TOOL_MANIFEST.length,\n      mode,\n      tools: SKILL_ADVISOR_CLI_TOOL_MANIFEST.map((tool) => ({\n        name: tool.name,\n        command: tool.command,\n        kebabCommand: tool.kebabCommand,\n        camelCommand: tool.camelCommand,\n        description: tool.description,\n        inputSchema: tool.inputSchema,\n      })),\n    },","lineStart":250,"lineEnd":769,"totalLines":1353,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/skill-advisor-cli.ts","time":{"start":1781145045946,"end":1781145045949}},"metadata":{"openai":{"itemId":"fc_00a78692d2799090016a2a1dd5d6