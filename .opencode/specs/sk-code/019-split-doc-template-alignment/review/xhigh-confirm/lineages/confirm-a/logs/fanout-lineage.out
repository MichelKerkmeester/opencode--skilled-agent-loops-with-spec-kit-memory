{"type":"tool_use","timestamp":1783921315179,"sessionID":"ses_0a6050605ffekKPL0ZIbz84Q5J","part":{"type":"tool","tool":"read","callID":"call_CrwZ5TiWY0nQlyaotzGpD6lg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":1550,"limit":440},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1550:     ledgerPath,\n1551:     runId,\n1552:     loopType,\n1553:     specFolder,\n1554:   });\n1555: \n1556:   // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n1557:   // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n1558:   // ownership here so all lineages share the same retries and artifact validation.\n1559:   const cliLineages = allLineages;\n1560:   const checkpointPath = waitCheckpointPath(baseArtifactDir);\n1561:   const resumeWaiting = await resumeWaitingCheckpoint({\n1562:     checkpointPath,\n1563:     ledgerPath,\n1564:     runId,\n1565:     loopType,\n1566:     specFolder,\n1567:   });\n1568:   if (!resumeWaiting.didWait) {\n1569:     await persistPreDispatchWait({\n1570:       checkpointPath,\n1571:       ledgerPath,\n1572:       runId,\n1573:       loopType,\n1574:       specFolder,\n1575:       waitMs: args.preDispatchWaitMs,\n1576:     });\n1577:   }\n1578: \n1579:   if (cliLineages.length === 0) {\n1580:     const summary = {\n1581:       total: 0,\n1582:       succeeded: 0,\n1583:       failed: 0,\n1584:       all_failed: false,\n1585:       gauges: { lag: 0, pending: 0, failed: 0 },\n1586:       convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n1587:     };\n1588:     writeOrchestrationSummary(summaryPath, {\n1589:       run_id: runId,\n1590:       loop_type: loopType,\n1591:       spec_folder: specFolder,\n1592:       base_artifact_dir: baseArtifactDir,\n1593:       total_cli_lineages: 0,\n1594:       ...summary,\n1595:     });\n1596:     jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n1597:     return;\n1598:   }\n1599: \n1600:   fs.mkdirSync(lineagesDir, { recursive: true });\n1601:   const orphanedLineages = markOrphanedLineages(ledgerPath);\n1602:   const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n1603: \n1604:   const lineageSnapshots = new Map();\n1605:   const lineageSlotAccounting = new Map();\n1606:   const lineageProcessLiveness = new Map();\n1607:   let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n1608:   let stoppedSummaryWritten = false;\n1609: \n1610:   const writeStoppedSummary = (signal) => {\n1611:     if (stoppedSummaryWritten) return;\n1612:     stoppedSummaryWritten = true;\n1613:     stopActiveLineageProcesses(signal);\n1614:     const stoppedAtIso = new Date().toISOString();\n1615:     const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n1616:     const gauges = {\n1617:       lag: latestGauges.lag,\n1618:       pending: latestGauges.pending,\n1619:       failed: Math.max(latestGauges.failed, partial.summary.failed),\n1620:     };\n1621:     appendFanoutStatusLedger(ledgerPath, {\n1622:       event: 'stopped',\n1623:       signal,\n1624:       at: stoppedAtIso,\n1625:       gauges,\n1626:     });\n1627:     writeOrchestrationSummary(summaryPath, {\n1628:       run_id: runId,\n1629:       loop_type: loopType,\n1630:       spec_folder: specFolder,\n1631:       base_artifact_dir: baseArtifactDir,\n1632:       total_cli_lineages: cliLineages.length,\n1633:       stopped: true,\n1634:       stopped_signal: signal,\n1635:       stopped_at_iso: stoppedAtIso,\n1636:       status: 'partial',\n1637:       ...partial.summary,\n1638:       gauges,\n1639:       results: partial.results,\n1640:     });\n1641:   };\n1642: \n1643:   installFanoutSignalHandlers(writeStoppedSummary);\n1644: \n1645:   const { results, summary } = await runCappedPool({\n1646:     items: cliLineages,\n1647:     concurrency: fanoutConfig.concurrency,\n1648:     maxRetries: fanoutConfig.maxRetries,\n1649:     lagCeilingMs: fanoutConfig.lagCeilingMs,\n1650:     postExitGraceMs,\n1651:     initialRetryCounts,\n1652:     getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n1653:     onEvent: (event) => {\n1654:       const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n1655:       updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n1656:       if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n1657:       appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n1658:     },\n1659:     worker: async (lineage, context) => {\n1660:       const slotWindowStartIso = new Date().toISOString();\n1661:       const hrStart = process.hrtime();\n1662:       const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n1663:       const livenessKey = `${lineage.label}:${attempt}`;\n1664:       const lineageDir = path.join(lineagesDir, lineage.label);\n1665:       const stateDir = path.join(lineageDir, '.executor-state');\n1666:       fs.mkdirSync(lineageDir, { recursive: true });\n1667:       fs.mkdirSync(stateDir, { recursive: true });\n1668: \n1669:       const budgetDecision = evaluateLineageBudgetCap({\n1670:         lineage,\n1671:         guards: lineageBudgetGuards,\n1672:         maxRetries: fanoutConfig.maxRetries,\n1673:       });\n1674:       if (!budgetDecision.continue_allowed) {\n1675:         appendFanoutStatusLedger(ledgerPath, {\n1676:           event: 'budget_cap_exceeded',\n1677:           label: lineage.label,\n1678:           at: new Date().toISOString(),\n1679:           severity: 'error',\n1680:           stop_reasons: budgetDecision.stop_reasons,\n1681:           upper_bound: budgetDecision.upper_bound,\n1682:           gauges: latestGauges,\n1683:         });\n1684:         const failure = new Error(\n1685:           `lineage ${lineage.label} exceeds configured budget cap: `\n1686:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1687:         );\n1688:         failure.label = lineage.label;\n1689:         failure.exitCode = null;\n1690:         failure.timedOut = false;\n1691:         failure.budgetCap = budgetDecision;\n1692:         throw failure;\n1693:       }\n1694: \n1695:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1696:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1697:         convergenceThreshold,\n1698:         stopPolicy,\n1699:       });\n1700: \n1701:       // Sandbox resolution stays write-capable by default even for review lineages:\n1702:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1703:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1704:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1705:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1706:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1707:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1708:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1709:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1710: \n1711:       const effectiveSandbox = resolvedSandbox;\n1712:       const effectivePermission = resolvedPermission;\n1713: \n1714:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1715:         lineage,\n1716:         prompt,\n1717:         effectiveSandbox,\n1718:         effectivePermission,\n1719:         {\n1720:           loopType,\n1721:           specFolder,\n1722:           lineageDir,\n1723:           sessionId,\n1724:           convergenceThreshold,\n1725:           stopPolicy,\n1726:           researchTopic,\n1727:         },\n1728:       );\n1729: \n1730:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1731:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1732:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1733:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1734:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1735:       // is deliberately avoided here because relocating the home breaks credential/auth\n1736:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1737:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1738:       const extraEnv = {\n1739:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1740:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1741:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1742:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1743:           : {}),\n1744:       };\n1745: \n1746:       // Recursion guard (fail closed): refuse to spawn when this executor kind is\n1747:       // already on the INHERITED dispatch stack — i.e. a seat that itself runs the loop\n1748:       // tried to fan out the SAME kind again. Only the stack layer is checked here: the\n1749:       // orchestrator legitimately runs inside one of these runtimes, so the runtime-env\n1750:       // (e.g. OPENCODE_SESSION_ID) and ancestry layers would false-positive on the\n1751:       // first-level dispatch. The stack is empty at top level and only carries a kind\n1752:       // once a parent fanout stamped it via buildExecutorDispatchEnv for its child.\n1753:       if (detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)) {\n1754:         throw new Error(\n1755:           `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n1756:         );\n1757:       }\n1758: \n1759:       // Stamp the dispatch stack with this lineage's executor kind so a seat that\n1760:       // tries to recursively launch the same kind is detectable by the runtime\n1761:       // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n1762:       // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n1763:       // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n1764:       // preserve the per-replica lockfile isolation they provide.\n1765:       const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n1766: \n1767:       const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n1768:       let lastLineageEventAtMs = Date.now();\n1769:       const markLineageEvent = () => {\n1770:         lastLineageEventAtMs = Date.now();\n1771:       };\n1772:       const stopStallWatchdog = startLineageStallWatchdog({\n1773:         thresholdMs: stallWatchdogMs,\n1774:         label: lineage.label,\n1775:         ledgerPath,\n1776:         getLastEventAtMs: () => lastLineageEventAtMs,\n1777:         getGauges: () => latestGauges,\n1778:       });\n1779: \n1780:       const stopProgressHeartbeat = startLineageProgressHeartbeat({\n1781:         cadenceMs: progressHeartbeatMs,\n1782:         label: lineage.label,\n1783:         ledgerPath,\n1784:         getGauges: () => latestGauges,\n1785:       });\n1786:       let result;\n1787:       try {\n1788:         result = await runLineageProcess(command, cmdArgs, {\n1789:           cwd: process.cwd(),\n1790:           timeoutMs,\n1791:           env: dispatchEnv,\n1792:           maxBuffer: 20 * 1024 * 1024,\n1793:           abortSignal: context.signal,\n1794:           onOutput: markLineageEvent,\n1795:           onSpawn: ({ pid }) => {\n1796:             lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n1797:           },\n1798:           onExit: ({ pid, exitedAtMs }) => {\n1799:             lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n1800:           },\n1801:           ...(typeof input === 'string' ? { input } : {}),\n1802:         });\n1803:       } finally {\n1804:         stopProgressHeartbeat();\n1805:         stopStallWatchdog();\n1806:       }\n1807: \n1808:       // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n1809:       const logsDir = path.join(lineageDir, 'logs');\n1810:       fs.mkdirSync(logsDir, { recursive: true });\n1811:       const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n1812:       fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n1813: \n1814:       // Recover missing iteration files from captured stdout when possible. Runs\n1815:       // BEFORE the failure throw below so iteration recovery is never lost.\n1816:       const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n1817:       const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n1818:       lineageSlotAccounting.set(lineage.label, slotAccounting);\n1819: \n1820:       const exitCode = result.status ?? (result.error ? 1 : 0);\n1821:       const timedOut = result.signal === 'SIGTERM';\n1822:       // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n1823:       // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n1824:       // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n1825:       const killedBySignal = result.signal != null;\n1826:       const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n1827:       const stateRead = readLineageStateRecords(loopType, lineageDir);\n1828:       const stopPolicyViolation = findMaxIterationsPolicyViolation({\n1829:         loopType,\n1830:         stateRead,\n1831:         lineage,\n1832:         stopPolicy,\n1833:       });\n1834: \n1835:       // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n1836:       // not a success. Throw so the pool settles this item as rejected and counts it\n1837:       // in summary.failed/all_failed, which drives the process exit code. Returning a\n1838:       // plain object here would let the pool record any completed worker as fulfilled\n1839:       // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n1840:       if (timedOut || killedBySignal || exitCode !== 0) {\n1841:         const reason = timedOut\n1842:           ? 'timed out'\n1843:           : killedBySignal\n1844:             ? `killed by signal ${result.signal}`\n1845:             : `exited with code ${exitCode}`;\n1846:         const failure = new Error(`lineage ${lineage.label} ${reason}`);\n1847:         failure.label = lineage.label;\n1848:         failure.exitCode = exitCode;\n1849:         failure.timedOut = timedOut;\n1850:         failure.killedBySignal = killedBySignal;\n1851:         failure.salvage = salvage;\n1852:         throw failure;\n1853:       }\n1854: \n1855:       if (missingArtifacts.length > 0) {\n1856:         const failure = new Error(\n1857:           `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n1858:         );\n1859:         failure.label = lineage.label;\n1860:         failure.exitCode = exitCode;\n1861:         failure.timedOut = false;\n1862:         failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n1863:         failure.missingArtifacts = missingArtifacts;\n1864:         throw failure;\n1865:       }\n1866: \n1867:       if (stopPolicyViolation) {\n1868:         const failure = new Error(\n1869:           `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n1870:         );\n1871:         failure.label = lineage.label;\n1872:         failure.exitCode = exitCode;\n1873:         failure.timedOut = false;\n1874:         failure.salvage = salvage;\n1875:         failure.stopPolicyViolation = stopPolicyViolation;\n1876:         throw failure;\n1877:       }\n1878: \n1879:       // An exit-0 lineage whose salvage sweep could not recover every iteration\n1880:       // markdown is NOT fulfilled, even when the top-level report exists. Returning\n1881:       // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n1882:       // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n1883:       // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n1884:       if (salvage && salvage.failed > 0) {\n1885:         const failure = new Error(\n1886:           `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n1887:         );\n1888:         failure.label = lineage.label;\n1889:         failure.exitCode = exitCode;\n1890:         failure.timedOut = false;\n1891:         failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n1892:         failure.missingArtifacts = [];\n1893:         throw failure;\n1894:       }\n1895: \n1896:       const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n1897:       if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n1898:         const slotWindowEndIso = new Date().toISOString();\n1899:         try {\n1900:           const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n1901:             windowStart: slotWindowStartIso,\n1902:             windowEnd: slotWindowEndIso,\n1903:             toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1904:           });\n1905:           if (timestampCheck.anomalous > 0) {\n1906:             const timestampAnomaly = buildTimestampAnomalyPayload({\n1907:               lineage,\n1908:               statePath: stateRead.statePath,\n1909:               check: timestampCheck,\n1910:             });\n1911:             appendFanoutStatusLedger(ledgerPath, {\n1912:               event: 'timestamp_anomaly',\n1913:               status: 'warning',\n1914:               severity: 'warning',\n1915:               label: lineage.label,\n1916:               at: new Date().toISOString(),\n1917:               ...timestampAnomaly,\n1918:             });\n1919:             output.timestamp_anomaly = timestampAnomaly;\n1920:           }\n1921:         } catch {\n1922:           // Timestamp telemetry is advisory and cannot affect lineage fulfillment.\n1923:         }\n1924:       }\n1925: \n1926:       return output;\n1927:     },\n1928:   });\n1929: \n1930:   const timestampAnomalies = collectTimestampAnomalies(results);\n1931:   const finalSummary = timestampAnomalies.length > 0\n1932:     ? { ...summary, timestamp_anomalies: timestampAnomalies }\n1933:     : summary;\n1934: \n1935:   writeOrchestrationSummary(summaryPath, {\n1936:     run_id: runId,\n1937:     loop_type: loopType,\n1938:     spec_folder: specFolder,\n1939:     base_artifact_dir: baseArtifactDir,\n1940:     total_cli_lineages: cliLineages.length,\n1941:     orphaned_lineages: orphanedLineages,\n1942:     ...finalSummary,\n1943:   });\n1944: \n1945:   const exitCode = finalSummary.all_failed ? 3 : finalSummary.failed > 0 ? 2 : 0;\n1946:   jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary: finalSummary });\n1947:   process.exit(exitCode);\n1948: }\n1949: \n1950: if (require.main === module && isTsxLoaded) {\n1951:   main().catch((err) => {\n1952:     const code = classifyExitCode(err);\n1953:     jsonOut({\n1954:       status: 'error',\n1955:       error: err instanceof Error ? err.message : String(err),\n1956:       code: err && err.code ? err.code : 'SCRIPT_ERROR',\n1957:     });\n1958:     if (code === 1) {\n1959:       process.stderr.write(\n1960:         JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n1961:       );\n1962:     }\n1963:     process.exit(code);\n1964:   });\n1965: }\n1966: \n1967: module.exports = {\n1968:   buildLineageCommand,\n1969:   buildLoopPrompt,\n1970:   findMaxIterationsPolicyViolation,\n1971:   isMaxIterationsStopReason,\n1972:   computeLineageTimeoutMs,\n1973:   assertLineageTimeoutHoursOverrideWithinCeiling,\n1974:   computeLineageBudgetUpperBound,\n1975:   evaluateLineageBudgetCap,\n1976:   computeAggregateBudgetUpperBound,\n1977:   evaluateAggregateBudgetCap,\n1978:   normalizeAggregateBudgetGuards,\n1979:   normalizeProgressHeartbeatMs,\n1980:   normalizePostExitGraceMs,\n1981:   normalizeLineageBudgetGuards,\n1982:   normalizeStallWatchdogMs,\n1983:   computeSkippedCount,\n1984:   decorateSlotAccountingEvent,\n1985:   startLineageProgressHeartbeat,\n1986:   startLineageStallWatchdog,\n1987:   statusForLedgerEvent,\n1988:   updateLineageSnapshot,\n1989:   applyFlatPoolAssignmentGuard,\n\n(Showing lines 1550-1989 of 1990. Use offset=1990 to continue.)\n</content>","metadata":{"preview":"    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n\n  // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n  // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n  // ownership here so all lineages share the same retries and artifact validation.\n  const cliLineages = allLineages;\n  const checkpointPath = waitCheckpointPath(baseArtifactDir);\n  const resumeWaiting = await resumeWaitingCheckpoint({\n    checkpointPath,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n  if (!resumeWaiting.didWait) {\n    await persistPreDispatchWait({","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n\n  // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n  // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n  // ownership here so all lineages share the same retries and artifact validation.\n  const cliLineages = allLineages;\n  const checkpointPath = waitCheckpointPath(baseArtifactDir);\n  const resumeWaiting = await resumeWaitingCheckpoint({\n    checkpointPath,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n  if (!resumeWaiting.didWait) {\n    await persistPreDispatchWait({\n      checkpointPath,\n      ledgerPath,\n      runId,\n      loopType,\n      specFolder,\n      waitMs: args.preDispatchWaitMs,\n    });\n  }\n\n  if (cliLineages.length === 0) {\n    const summary = {\n      total: 0,\n      succeeded: 0,\n      failed: 0,\n      all_failed: false,\n      gauges: { lag: 0, pending: 0, failed: 0 },\n      convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n    };\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: 0,\n      ...summary,\n    });\n    jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n    return;\n  }\n\n  fs.mkdirSync(lineagesDir, { recursive: true });\n  const orphanedLineages = markOrphanedLineages(ledgerPath);\n  const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n\n  const lineageSnapshots = new Map();\n  const lineageSlotAccounting = new Map();\n  const lineageProcessLiveness = new Map();\n  let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n  let stoppedSummaryWritten = false;\n\n  const writeStoppedSummary = (signal) => {\n    if (stoppedSummaryWritten) return;\n    stoppedSummaryWritten = true;\n    stopActiveLineageProcesses(signal);\n    const stoppedAtIso = new Date().toISOString();\n    const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n    const gauges = {\n      lag: latestGauges.lag,\n      pending: latestGauges.pending,\n      failed: Math.max(latestGauges.failed, partial.summary.failed),\n    };\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'stopped',\n      signal,\n      at: stoppedAtIso,\n      gauges,\n    });\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: cliLineages.length,\n      stopped: true,\n      stopped_signal: signal,\n      stopped_at_iso: stoppedAtIso,\n      status: 'partial',\n      ...partial.summary,\n      gauges,\n      results: partial.results,\n    });\n  };\n\n  installFanoutSignalHandlers(writeStoppedSummary);\n\n  const { results, summary } = await runCappedPool({\n    items: cliLineages,\n    concurrency: fanoutConfig.concurrency,\n    maxRetries: fanoutConfig.maxRetries,\n    lagCeilingMs: fanoutConfig.lagCeilingMs,\n    postExitGraceMs,\n    initialRetryCounts,\n    getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n    onEvent: (event) => {\n      const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n      updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n      if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n      appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n    },\n    worker: async (lineage, context) => {\n      const slotWindowStartIso = new Date().toISOString();\n      const hrStart = process.hrtime();\n      const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n      const livenessKey = `${lineage.label}:${attempt}`;\n      const lineageDir = path.join(lineagesDir, lineage.label);\n      const stateDir = path.join(lineageDir, '.executor-state');\n      fs.mkdirSync(lineageDir, { recursive: true });\n      fs.mkdirSync(stateDir, { recursive: true });\n\n      const budgetDecision = evaluateLineageBudgetCap({\n        lineage,\n        guards: lineageBudgetGuards,\n        maxRetries: fanoutConfig.maxRetries,\n      });\n      if (!budgetDecision.continue_allowed) {\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'budget_cap_exceeded',\n          label: lineage.label,\n          at: new Date().toISOString(),\n          severity: 'error',\n          stop_reasons: budgetDecision.stop_reasons,\n          upper_bound: budgetDecision.upper_bound,\n          gauges: latestGauges,\n        });\n        const failure = new Error(\n          `lineage ${lineage.label} exceeds configured budget cap: `\n            + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = null;\n        failure.timedOut = false;\n        failure.budgetCap = budgetDecision;\n        throw failure;\n      }\n\n      const sessionId = `fanout-${lineage.label}-${runId}`;\n      const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n        convergenceThreshold,\n        stopPolicy,\n      });\n\n      // Sandbox resolution stays write-capable by default even for review lineages:\n      // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n      // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n      // blanket read-only default would break those writes. The lineageDir-only write boundary\n      // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n      // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n      // exposed one. Callers can still pass an explicit sandboxMode to override.\n      const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n      const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n\n      const effectiveSandbox = resolvedSandbox;\n      const effectivePermission = resolvedPermission;\n\n      const { command, args: cmdArgs, input } = buildLineageCommand(\n        lineage,\n        prompt,\n        effectiveSandbox,\n        effectivePermission,\n        {\n          loopType,\n          specFolder,\n          lineageDir,\n          sessionId,\n          convergenceThreshold,\n          stopPolicy,\n          researchTopic,\n        },\n      );\n\n      // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n      // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n      // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n      // native lockfile. Real same-kind-replica isolation comes from each lineage's\n      // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n      // is deliberately avoided here because relocating the home breaks credential/auth\n      // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n      const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n      const extraEnv = {\n        SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n        ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n        ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n          ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n          : {}),\n      };\n\n      // Recursion guard (fail closed): refuse to spawn when this executor kind is\n      // already on the INHERITED dispatch stack — i.e. a seat that itself runs the loop\n      // tried to fan out the SAME kind again. Only the stack layer is checked here: the\n      // orchestrator legitimately runs inside one of these runtimes, so the runtime-env\n      // (e.g. OPENCODE_SESSION_ID) and ancestry layers would false-positive on the\n      // first-level dispatch. The stack is empty at top level and only carries a kind\n      // once a parent fanout stamped it via buildExecutorDispatchEnv for its child.\n      if (detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)) {\n        throw new Error(\n          `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n        );\n      }\n\n      // Stamp the dispatch stack with this lineage's executor kind so a seat that\n      // tries to recursively launch the same kind is detectable by the runtime\n      // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n      // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n      // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n      // preserve the per-replica lockfile isolation they provide.\n      const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n\n      const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n      let lastLineageEventAtMs = Date.now();\n      const markLineageEvent = () => {\n        lastLineageEventAtMs = Date.now();\n      };\n      const stopStallWatchdog = startLineageStallWatchdog({\n        thresholdMs: stallWatchdogMs,\n        label: lineage.label,\n        ledgerPath,\n        getLastEventAtMs: () => lastLineageEventAtMs,\n        getGauges: () => latestGauges,\n      });\n\n      const stopProgressHeartbeat = startLineageProgressHeartbeat({\n        cadenceMs: progressHeartbeatMs,\n        label: lineage.label,\n        ledgerPath,\n        getGauges: () => latestGauges,\n      });\n      let result;\n      try {\n        result = await runLineageProcess(command, cmdArgs, {\n          cwd: process.cwd(),\n          timeoutMs,\n          env: dispatchEnv,\n          maxBuffer: 20 * 1024 * 1024,\n          abortSignal: context.signal,\n          onOutput: markLineageEvent,\n          onSpawn: ({ pid }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n          },\n          onExit: ({ pid, exitedAtMs }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n          },\n          ...(typeof input === 'string' ? { input } : {}),\n        });\n      } finally {\n        stopProgressHeartbeat();\n        stopStallWatchdog();\n      }\n\n      // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n      const logsDir = path.join(lineageDir, 'logs');\n      fs.mkdirSync(logsDir, { recursive: true });\n      const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n      fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n\n      // Recover missing iteration files from captured stdout when possible. Runs\n      // BEFORE the failure throw below so iteration recovery is never lost.\n      const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n      const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n      lineageSlotAccounting.set(lineage.label, slotAccounting);\n\n      const exitCode = result.status ?? (result.error ? 1 : 0);\n      const timedOut = result.signal === 'SIGTERM';\n      // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n      // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n      // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n      const killedBySignal = result.signal != null;\n      const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n      const stateRead = readLineageStateRecords(loopType, lineageDir);\n      const stopPolicyViolation = findMaxIterationsPolicyViolation({\n        loopType,\n        stateRead,\n        lineage,\n        stopPolicy,\n      });\n\n      // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n      // not a success. Throw so the pool settles this item as rejected and counts it\n      // in summary.failed/all_failed, which drives the process exit code. Returning a\n      // plain object here would let the pool record any completed worker as fulfilled\n      // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n      if (timedOut || killedBySignal || exitCode !== 0) {\n        const reason = timedOut\n          ? 'timed out'\n          : killedBySignal\n            ? `killed by signal ${result.signal}`\n            : `exited with code ${exitCode}`;\n        const failure = new Error(`lineage ${lineage.label} ${reason}`);\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = timedOut;\n        failure.killedBySignal = killedBySignal;\n        failure.salvage = salvage;\n        throw failure;\n      }\n\n      if (missingArtifacts.length > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n        failure.missingArtifacts = missingArtifacts;\n        throw failure;\n      }\n\n      if (stopPolicyViolation) {\n        const failure = new Error(\n          `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = salvage;\n        failure.stopPolicyViolation = stopPolicyViolation;\n        throw failure;\n      }\n\n      // An exit-0 lineage whose salvage sweep could not recover every iteration\n      // markdown is NOT fulfilled, even when the top-level report exists. Returning\n      // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n      // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n      // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n      if (salvage && salvage.failed > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n        failure.missingArtifacts = [];\n        throw failure;\n      }\n\n      const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n      if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n        const slotWindowEndIso = new Date().toISOString();\n        try {\n          const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n            windowStart: slotWindowStartIso,\n            windowEnd: slotWindowEndIso,\n            toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n          });\n          if (timestampCheck.anomalous > 0) {\n            const timestampAnomaly = buildTimestampAnomalyPayload({\n              lineage,\n              statePath: stateRead.statePath,\n              check: timestampCheck,\n            });\n            appendFanoutStatusLedger(ledgerPath, {\n              event: 'timestamp_anomaly',\n              status: 'warning',\n              severity: 'warning',\n              label: lineage.label,\n              at: new Date().toISOString(),\n              ...timestampAnomaly,\n            });\n            output.timestamp_anomaly = timestampAnomaly;\n          }\n        } catch {\n          // Timestamp telemetry is advisory and cannot affect lineage fulfillment.\n        }\n      }\n\n      return output;\n    },\n  });\n\n  const timestampAnomalies = collectTimestampAnomalies(results);\n  const finalSummary = timestampAnomalies.length > 0\n    ? { ...summary, timestamp_anomalies: timestampAnomalies }\n    : summary;\n\n  writeOrchestrationSummary(summaryPath, {\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    base_artifact_dir: baseArtifactDir,\n    total_cli_lineages: cliLineages.length,\n    orphaned_lineages: orphanedLineages,\n    ...finalSummary,\n  });\n\n  const exitCode = finalSummary.all_failed ? 3 : finalSummary.failed > 0 ? 2 : 0;\n  jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary: finalSummary });\n  process.exit(exitCode);\n}\n\nif (require.main === module && isTsxLoaded) {\n  main().catch((err) => {\n    const code = classifyExitCode(err);\n    jsonOut({\n      status: 'error',\n      error: err instanceof Error ? err.message : String(err),\n      code: err && err.code ? err.code : 'SCRIPT_ERROR',\n    });\n    if (code === 1) {\n      process.stderr.write(\n        JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n      );\n    }\n    process.exit(code);\n  });\n}\n\nmodule.exports = {\n  buildLineageCommand,\n  buildLoopPrompt,\n  findMaxIterationsPolicyViolation,\n  isMaxIterationsStopReason,\n  computeLineageTimeoutMs,\n  assertLineageTimeoutHoursOverrideWithinCeiling,\n  computeLineageBudgetUpperBound,\n  evaluateLineageBudgetCap,\n  computeAggregateBudgetUpperBound,\n  evaluateAggregateBudgetCap,\n  normalizeAggregateBudgetGuards,\n  normalizeProgressHeartbeatMs,\n  normalizePostExitGraceMs,\n  normalizeLineageBudgetGuards,\n  normalizeStallWatchdogMs,\n  computeSkippedCount,\n  decorateSlotAccountingEvent,\n  startLineageProgressHeartbeat,\n  startLineageStallWatchdog,\n  statusForLedgerEvent,\n  updateLineageSnapshot,\n  applyFlatPoolAssignmentGuard,","lineStart":1550,"lineEnd":1989,"totalLines":1990,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1783921315170,"end":1783921315176}},"metadata":{"openai":{"itemId":"fc_00151958606b927a016a547aa2fc008191a1afe7ffb04d2a24"}},"id":"prt_f59ff0d0b001cfpzajDQjy0Yek","sessionID":"ses_0a6050605ffekKPL0ZIbz84Q5J","messageID":"msg_f59fec2d4001WIxOzDCrFcdmKa"}}
