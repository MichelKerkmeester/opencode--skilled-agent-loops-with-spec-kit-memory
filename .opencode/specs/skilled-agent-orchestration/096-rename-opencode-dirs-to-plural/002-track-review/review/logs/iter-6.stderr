    35	}
    36	function normalizeSkillList(values) {
    37	    return [...new Set(values.map(value => value.trim()).filter(value => SKILL_NAME_PATTERN.test(value)))].sort();
    38	}
    39	function normalizeGlobList(values) {
    40	    return [...new Set((values ?? []).map(value => value.trim()).filter(Boolean))].sort();
    41	}
    42	function encodeGlobList(values) {
    43	    return `[${values.map(value => encodeURIComponent(value)).join(',')}]`;
    44	}
    45	function decodeGlobList(value) {
    46	    const match = value?.match(/^\[(.*)\]$/);
    47	    if (!match) {
    48	        return null;
    49	    }
    50	    if (match[1].length === 0) {
    51	        return [];
    52	    }
    53	    try {
    54	        return normalizeGlobList(match[1].split(',').map(segment => decodeURIComponent(segment)));
    55	    }
    56	    catch {
    57	        return null;
    58	    }
    59	}
    60	function parseSkillsEnvValue(value) {
    61	    const normalized = value?.trim();
    62	    if (!normalized || normalized.toLowerCase() === 'false') {
    63	        return 'none';
    64	    }
    65	    if (normalized.toLowerCase() === 'true') {
    66	        return 'all';
    67	    }
    68	    const skills = normalizeSkillList(normalized.split(','));
    69	    return skills.length > 0 ? skills : 'none';
    70	}
