{"type":"tool_use","timestamp":1781144204047,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_EVVdhY1hynMd0nrGsaoELqjY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","offset":300,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts</path>\n<type>file</type>\n<content>\n300:   const edgePrior = resolveEdgePrior(relation, intent);\n301:   const hopDecay = computeHopDecay(hopDistance);\n302:   return seedScore * edgePrior * hopDecay * freshness;\n303: }\n304: \n305: function getIntentEdgePriorities(intent: string): string[] {\n306:   return (INTENT_EDGE_PRIORITY[intent] ?? []).slice(0, 2);\n307: }\n308: \n309: function computeIntentEdgePrior(intent: string, edgeType: string): number {\n310:   const priorities = getIntentEdgePriorities(intent);\n311:   if (priorities.length === 0) {\n312:     return DEFAULT_EDGE_PRIOR;\n313:   }\n314: \n315:   const normalizedEdgeType = edgeType.toUpperCase();\n316:   const directMatchIndex = priorities.findIndex(\n317:     (priority) => priority.toUpperCase() === normalizedEdgeType,\n318:   );\n319:   if (directMatchIndex >= 0) {\n320:     return EDGE_PRIOR_TIERS[Math.min(directMatchIndex, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n321:   }\n322: \n323:   return resolveEdgePrior(edgeType, intent);\n324: }\n325: \n326: function computeTraversalHopDecay(hopDistance: number): number {\n327:   return computeHopDecay(hopDistance);\n328: }\n329: \n330: function computeTraversalFreshnessFactor(\n331:   updatedAt: Date | string,\n332:   now: Date | string = new Date(),\n333: ): number {\n334:   const updatedAtMs = new Date(updatedAt).getTime();\n335:   const nowMs = new Date(now).getTime();\n336:   if (!Number.isFinite(updatedAtMs) || !Number.isFinite(nowMs) || nowMs <= updatedAtMs) {\n337:     return 1;\n338:   }\n339: \n340:   const ageMs = nowMs - updatedAtMs;\n341:   return Math.exp(-(ageMs / FRESHNESS_DECAY_WINDOW_MS));\n342: }\n343: \n344: function computeIntentAwareTraversalScore(params: {\n345:   seedScore: number;\n346:   intent: string;\n347:   edgeType: string;\n348:   hopDistance: number;\n349:   updatedAt: Date | string;\n350:   now?: Date | string;\n351: }): number {\n352:   return params.seedScore *\n353:     computeIntentEdgePrior(params.intent, params.edgeType) *\n354:     computeTraversalHopDecay(params.hopDistance) *\n355:     computeTraversalFreshnessFactor(params.updatedAt, params.now);\n356: }\n357: \n358: /**\n359:  * Resolve the primary numeric score from a result, checking score, rrfScore,\n360:  * and similarity (normalized to 0–1) in precedence order. Returns 0 if none present.\n361:  */\n362: function resolveBaseScore(result: RankedSearchResult): number {\n363:   if (typeof result.score === 'number' && Number.isFinite(result.score)) return result.score;\n364:   if (typeof result.rrfScore === 'number' && Number.isFinite(result.rrfScore)) return result.rrfScore;\n365:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) return result.similarity / 100;\n366:   return 0;\n367: }\n368: \n369: function buildPipelineRow(\n370:   row: RankedSearchResult,\n371:   baseScore: number,\n372:   causalBoost: number\n373: ): RankedSearchResult {\n374:   const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST));\n375:   const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n376:   return {\n377:     ...row,\n378:     score,\n379:     rrfScore: score,\n380:     intentAdjustedScore: score,\n381:     attentionScore: score,\n382:     causalBoost: allowedBoost,\n383:     baseScore,\n384:     injectedByCausalBoost: true,\n385:   };\n386: }\n387: \n388: /**\n389:  * Deduplicate and validate a list of numeric IDs, truncating to integers\n390:  * and dropping non-finite values to guard against DB query injection.\n391:  */\n392: function normalizeIds(inputIds: number[]): number[] {\n393:   const ids = new Set<number>();\n394:   for (const candidate of inputIds) {\n395:     if (typeof candidate === 'number' && Number.isFinite(candidate)) {\n396:       ids.add(Math.trunc(candidate));\n397:     }\n398:   }\n399:   return Array.from(ids);\n400: }\n401: \n402: /**\n403:  * Compute the hop-distance decay boost: MAX_BOOST_PER_HOP / hopDistance,\n404:  * capped at MAX_BOOST_PER_HOP so closer neighbors get the full signal.\n405:  */\n406: function computeBoostByHop(hopDistance: number): number {\n407:   if (!Number.isFinite(hopDistance) || hopDistance <= 0) return 0;\n408:   const rawBoost = MAX_BOOST_PER_HOP / hopDistance;\n409:   return Math.min(MAX_BOOST_PER_HOP, rawBoost);\n410: }\n411: \n412: /**\n413:  * Walk causal edges up to maxHops from the given seed memory IDs,\n414:  * returning a map of neighbor ID to boost score.\n415:  *\n416:    * Accepts an optional maxHops override. When sparse mode is active\n417:  * (density < 0.5 and SPECKIT_TYPED_TRAVERSAL enabled), the caller passes\n418:  * SPARSE_MAX_HOPS (1) to constrain traversal depth.\n419:  */\n420: function getNeighborBoosts(memoryIds: number[], maxHops: number = MAX_HOPS): Map<number, NeighborBoost> {\n421:   const neighborBoosts = new Map<number, NeighborBoost>();\n422:   if (!db || !graphTraversal) return neighborBoosts;\n423: \n424:   const ids = normalizeIds(memoryIds);\n425:   if (ids.length === 0) return neighborBoosts;\n426: \n427:   try {\n428:     const rows = graphTraversal.collectCausalWeightedNeighbors(ids, maxHops, RELATION_WEIGHT_MULTIPLIERS);\n429: \n430:     for (const [neighborId, row] of rows) {\n431:       const hopBoost = computeBoostByHop(row.minHop);\n432:       const walkMultiplier = typeof row.maxWalkScore === 'number' && Number.isFinite(row.maxWalkScore)\n433:         ? Math.max(0.1, Math.min(2.0, row.maxWalkScore))\n434:         : 1.0;\n435:       const boost = hopBoost * walkMultiplier;\n436:       if (boost <= 0) continue;\n437:       const current = neighborBoosts.get(neighborId);\n438:       if (!current || boost > current.boost) {\n439:         neighborBoosts.set(neighborId, {\n440:           boost,\n441:           hopCount: Math.max(1, Math.min(maxHops, row.minHop)),\n442:         });\n443:       }\n444:     }\n445:   } catch (error: unknown) {\n446:     const message = error instanceof Error ? error.message : String(error);\n447:     console.warn(`[causal-boost] Traversal failed: ${message}`);\n448:   }\n449: \n450:   return neighborBoosts;\n451: }\n452: \n453: function fetchNeighborRows(memoryIds: number[]): RankedSearchResult[] {\n454:   if (!db || memoryIds.length === 0) return [];\n455: \n456:   const placeholders = memoryIds.map(() => '?').join(', ');\n457:   const rows = (db.prepare(`\n458:     SELECT id, spec_folder, file_path, title, importance_tier, trigger_phrases, created_at\n459:     FROM memory_index\n460:     WHERE id IN (${placeholders})\n461:   `) as Database.Statement).all(...memoryIds) as RankedSearchResult[];\n462: \n463:   return rows;\n464: }\n465: \n466: /**\n467:  * Apply causal graph boost to ranked search results, injecting\n468:  * graph-discovered neighbors and amplifying scores for connected nodes.\n469:  *\n470:    * Sparse-first and intent-aware traversal extensions:\n471:    * - When SPECKIT_TYPED_TRAVERSAL is enabled and graphDensity < 0.5,\n472:  *   activates sparse mode: traversal depth = 1, community detection suppressed.\n473:    * - When SPECKIT_TYPED_TRAVERSAL is enabled and intent is provided,\n474:  *   applies intent-aware edge traversal scoring using the formula:\n475:  *   score = seedScore * edgePrior * hopDecay * freshness\n476:  *\n477:  * @param results - Ranked search results from prior pipeline stages\n478:    * @param options - Optional traversal parameters (graphDensity, intent, freshness)\n479:  */\n480: function applyCausalBoost(\n481:   results: RankedSearchResult[],\n482:   options: CausalBoostOptions = {}\n483: ): { results: RankedSearchResult[]; metadata: CausalBoostMetadata } {\n484:   const { graphDensity, intent = 'understand', freshness = 1.0 } = options;\n485: \n486:   // Determine sparse mode and effective hop depth.\n487:   const sparseMode = isSparseMode(graphDensity);\n488:   const effectiveMaxHops = sparseMode ? SPARSE_MAX_HOPS : MAX_HOPS;\n489: \n490:   const metadata: CausalBoostMetadata = {\n491:     enabled: isEnabled(),\n492:     applied: false,\n493:     boostedCount: 0,\n494:     injectedCount: 0,\n495:     maxBoostApplied: 0,\n496:     traversalDepth: effectiveMaxHops,\n497:     sparseModeActive: sparseMode,\n498:     intentUsed: isTypedTraversalEnabled() ? intent : undefined,\n499:   };\n500: \n501:   if (!metadata.enabled || !Array.isArray(results) || results.length === 0 || !db) {\n502:     return { results, metadata };\n503:   }\n504: \n505:   const seedLimit = Math.max(1, Math.min(MAX_SEED_RESULTS, Math.ceil(results.length * SEED_FRACTION)));\n506:   const seedResults = results.slice(0, seedLimit);\n507:   const seedIds = seedResults.map((item) => item.id);\n508:   // Pass effectiveMaxHops to constrain traversal in sparse mode.\n509:   const neighborBoosts = getNeighborBoosts(seedIds, effectiveMaxHops);\n510:   if (neighborBoosts.size === 0) {\n511:     return { results, metadata };\n512:   }\n513: \n514:   // When SPECKIT_TYPED_TRAVERSAL is enabled, re-score neighbor boosts\n515:   // using the intent-aware traversal formula: seedScore * edgePrior * hopDecay * freshness.\n516:   // We use the average seed score as the seedScore proxy and the actual hop distance\n517:   // returned by getNeighborBoosts(). This preserves backward compatibility: when flag\n518:   // is OFF, the original boost values from getNeighborBoosts() are used unchanged.\n519:   const intentBoosts: Map<number, number> = new Map();\n\n(Showing lines 300-519 of 773. Use offset=520 to continue.)\n</content>","metadata":{"preview":"  const edgePrior = resolveEdgePrior(relation, intent);\n  const hopDecay = computeHopDecay(hopDistance);\n  return seedScore * edgePrior * hopDecay * freshness;\n}\n\nfunction getIntentEdgePriorities(intent: string): string[] {\n  return (INTENT_EDGE_PRIORITY[intent] ?? []).slice(0, 2);\n}\n\nfunction computeIntentEdgePrior(intent: string, edgeType: string): number {\n  const priorities = getIntentEdgePriorities(intent);\n  if (priorities.length === 0) {\n    return DEFAULT_EDGE_PRIOR;\n  }\n\n  const normalizedEdgeType = edgeType.toUpperCase();\n  const directMatchIndex = priorities.findIndex(\n    (priority) => priority.toUpperCase() === normalizedEdgeType,\n  );\n  if (directMatchIndex >= 0) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","text":"  const edgePrior = resolveEdgePrior(relation, intent);\n  const hopDecay = computeHopDecay(hopDistance);\n  return seedScore * edgePrior * hopDecay * freshness;\n}\n\nfunction getIntentEdgePriorities(intent: string): string[] {\n  return (INTENT_EDGE_PRIORITY[intent] ?? []).slice(0, 2);\n}\n\nfunction computeIntentEdgePrior(intent: string, edgeType: string): number {\n  const priorities = getIntentEdgePriorities(intent);\n  if (priorities.length === 0) {\n    return DEFAULT_EDGE_PRIOR;\n  }\n\n  const normalizedEdgeType = edgeType.toUpperCase();\n  const directMatchIndex = priorities.findIndex(\n    (priority) => priority.toUpperCase() === normalizedEdgeType,\n  );\n  if (directMatchIndex >= 0) {\n    return EDGE_PRIOR_TIERS[Math.min(directMatchIndex, EDGE_PRIOR_TIERS.length - 1)] ?? 0.5;\n  }\n\n  return resolveEdgePrior(edgeType, intent);\n}\n\nfunction computeTraversalHopDecay(hopDistance: number): number {\n  return computeHopDecay(hopDistance);\n}\n\nfunction computeTraversalFreshnessFactor(\n  updatedAt: Date | string,\n  now: Date | string = new Date(),\n): number {\n  const updatedAtMs = new Date(updatedAt).getTime();\n  const nowMs = new Date(now).getTime();\n  if (!Number.isFinite(updatedAtMs) || !Number.isFinite(nowMs) || nowMs <= updatedAtMs) {\n    return 1;\n  }\n\n  const ageMs = nowMs - updatedAtMs;\n  return Math.exp(-(ageMs / FRESHNESS_DECAY_WINDOW_MS));\n}\n\nfunction computeIntentAwareTraversalScore(params: {\n  seedScore: number;\n  intent: string;\n  edgeType: string;\n  hopDistance: number;\n  updatedAt: Date | string;\n  now?: Date | string;\n}): number {\n  return params.seedScore *\n    computeIntentEdgePrior(params.intent, params.edgeType) *\n    computeTraversalHopDecay(params.hopDistance) *\n    computeTraversalFreshnessFactor(params.updatedAt, params.now);\n}\n\n/**\n * Resolve the primary numeric score from a result, checking score, rrfScore,\n * and similarity (normalized to 0–1) in precedence order. Returns 0 if none present.\n */\nfunction resolveBaseScore(result: RankedSearchResult): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) return result.score;\n  if (typeof result.rrfScore === 'number' && Number.isFinite(result.rrfScore)) return result.rrfScore;\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) return result.similarity / 100;\n  return 0;\n}\n\nfunction buildPipelineRow(\n  row: RankedSearchResult,\n  baseScore: number,\n  causalBoost: number\n): RankedSearchResult {\n  const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST));\n  const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n  return {\n    ...row,\n    score,\n    rrfScore: score,\n    intentAdjustedScore: score,\n    attentionScore: score,\n    causalBoost: allowedBoost,\n    baseScore,\n    injectedByCausalBoost: true,\n  };\n}\n\n/**\n * Deduplicate and validate a list of numeric IDs, truncating to integers\n * and dropping non-finite values to guard against DB query injection.\n */\nfunction normalizeIds(inputIds: number[]): number[] {\n  const ids = new Set<number>();\n  for (const candidate of inputIds) {\n    if (typeof candidate === 'number' && Number.isFinite(candidate)) {\n      ids.add(Math.trunc(candidate));\n    }\n  }\n  return Array.from(ids);\n}\n\n/**\n * Compute the hop-distance decay boost: MAX_BOOST_PER_HOP / hopDistance,\n * capped at MAX_BOOST_PER_HOP so closer neighbors get the full signal.\n */\nfunction computeBoostByHop(hopDistance: number): number {\n  if (!Number.isFinite(hopDistance) || hopDistance <= 0) return 0;\n  const rawBoost = MAX_BOOST_PER_HOP / hopDistance;\n  return Math.min(MAX_BOOST_PER_HOP, rawBoost);\n}\n\n/**\n * Walk causal edges up to maxHops from the given seed memory IDs,\n * returning a map of neighbor ID to boost score.\n *\n   * Accepts an optional maxHops override. When sparse mode is active\n * (density < 0.5 and SPECKIT_TYPED_TRAVERSAL enabled), the caller passes\n * SPARSE_MAX_HOPS (1) to constrain traversal depth.\n */\nfunction getNeighborBoosts(memoryIds: number[], maxHops: number = MAX_HOPS): Map<number, NeighborBoost> {\n  const neighborBoosts = new Map<number, NeighborBoost>();\n  if (!db || !graphTraversal) return neighborBoosts;\n\n  const ids = normalizeIds(memoryIds);\n  if (ids.length === 0) return neighborBoosts;\n\n  try {\n    const rows = graphTraversal.collectCausalWeightedNeighbors(ids, maxHops, RELATION_WEIGHT_MULTIPLIERS);\n\n    for (const [neighborId, row] of rows) {\n      const hopBoost = computeBoostByHop(row.minHop);\n      const walkMultiplier = typeof row.maxWalkScore === 'number' && Number.isFinite(row.maxWalkScore)\n        ? Math.max(0.1, Math.min(2.0, row.maxWalkScore))\n        : 1.0;\n      const boost = hopBoost * walkMultiplier;\n      if (boost <= 0) continue;\n      const current = neighborBoosts.get(neighborId);\n      if (!current || boost > current.boost) {\n        neighborBoosts.set(neighborId, {\n          boost,\n          hopCount: Math.max(1, Math.min(maxHops, row.minHop)),\n        });\n      }\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-boost] Traversal failed: ${message}`);\n  }\n\n  return neighborBoosts;\n}\n\nfunction fetchNeighborRows(memoryIds: number[]): RankedSearchResult[] {\n  if (!db || memoryIds.length === 0) return [];\n\n  const placeholders = memoryIds.map(() => '?').join(', ');\n  const rows = (db.prepare(`\n    SELECT id, spec_folder, file_path, title, importance_tier, trigger_phrases, created_at\n    FROM memory_index\n    WHERE id IN (${placeholders})\n  `) as Database.Statement).all(...memoryIds) as RankedSearchResult[];\n\n  return rows;\n}\n\n/**\n * Apply causal graph boost to ranked search results, injecting\n * graph-discovered neighbors and amplifying scores for connected nodes.\n *\n   * Sparse-first and intent-aware traversal extensions:\n   * - When SPECKIT_TYPED_TRAVERSAL is enabled and graphDensity < 0.5,\n *   activates sparse mode: traversal depth = 1, community detection suppressed.\n   * - When SPECKIT_TYPED_TRAVERSAL is enabled and intent is provided,\n *   applies intent-aware edge traversal scoring using the formula:\n *   score = seedScore * edgePrior * hopDecay * freshness\n *\n * @param results - Ranked search results from prior pipeline stages\n   * @param options - Optional traversal parameters (graphDensity, intent, freshness)\n */\nfunction applyCausalBoost(\n  results: RankedSearchResult[],\n  options: CausalBoostOptions = {}\n): { results: RankedSearchResult[]; metadata: CausalBoostMetadata } {\n  const { graphDensity, intent = 'understand', freshness = 1.0 } = options;\n\n  // Determine sparse mode and effective hop depth.\n  const sparseMode = isSparseMode(graphDensity);\n  const effectiveMaxHops = sparseMode ? SPARSE_MAX_HOPS : MAX_HOPS;\n\n  const metadata: CausalBoostMetadata = {\n    enabled: isEnabled(),\n    applied: false,\n    boostedCount: 0,\n    injectedCount: 0,\n    maxBoostApplied: 0,\n    traversalDepth: effectiveMaxHops,\n    sparseModeActive: sparseMode,\n    intentUsed: isTypedTraversalEnabled() ? intent : undefined,\n  };\n\n  if (!metadata.enabled || !Array.isArray(results) || results.length === 0 || !db) {\n    return { results, metadata };\n  }\n\n  const seedLimit = Math.max(1, Math.min(MAX_SEED_RESULTS, Math.ceil(results.length * SEED_FRACTION)));\n  const seedResults = results.slice(0, seedLimit);\n  const seedIds = seedResults.map((item) => item.id);\n  // Pass effectiveMaxHops to constrain traversal in sparse mode.\n  const neighborBoosts = getNeighborBoosts(seedIds, effectiveMaxHops);\n  if (neighborBoosts.size === 0) {\n    return { results, metadata };\n  }\n\n  // When SPECKIT_TYPED_TRAVERSAL is enabled, re-score neighbor boosts\n  // using the intent-aware traversal formula: seedScore * edgePrior * hopDecay * freshness.\n  // We use the average seed score as the seedScore proxy and the actual hop distance\n  // returned by getNeighborBoosts(). This preserves backward compatibility: when flag\n  // is OFF, the original boost values from getNeighborBoosts() are used unchanged.\n  const intentBoosts: Map<number, number> = new Map();","lineStart":300,"lineEnd":519,"totalLines":773,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","time":{"start":1781144204041,"end":1781144204046}},"metadata":{"openai":{"itemId":"fc_0855f74cea9e2624016a2a1a8c02c0819190d5d3332568d082"}},"id":"prt_eb477b3000010unIZav1qgUy5O","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477917c001svZdX4mVh5wPSf"}}
{"type":"tool_use","timestamp":1781144204103,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_2OIaunRQP8h4yaom4SDkgjJE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","offset":520,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts</path>\n<type>file</type>\n<content>\n520:   if (isTypedTraversalEnabled()) {\n521:     const avgSeedScore = seedResults.length > 0\n522:       ? seedResults.map((s) => resolveBaseScore(s)).reduce((a, b) => a + b, 0) / seedResults.length\n523:       : 1.0;\n524:     const clampedFreshness = Math.max(0, Math.min(1, Number.isFinite(freshness) ? freshness : 1.0));\n525: \n526:     for (const [neighborId, neighborBoost] of neighborBoosts) {\n527:       // We don't have the per-edge relation type at this aggregation level,\n528:       // so we use the seed's dominant relation by querying the first-hop edge from the DB.\n529:       // Fall back to 'caused' (neutral default) if unavailable.\n530:       let dominantRelation = 'caused';\n531:       if (db) {\n532:         try {\n533:           const edgeRow = (db.prepare(`\n534:             SELECT relation FROM causal_edges\n535:             WHERE source_id IN (${seedIds.map(() => '?').join(',')})\n536:               AND target_id = ?\n537:             LIMIT 1\n538:           `) as Database.Statement).get(...seedIds.map(String), String(neighborId)) as\n539:             { relation: string } | undefined;\n540:           if (edgeRow?.relation) dominantRelation = edgeRow.relation;\n541:         } catch (_err: unknown) {\n542:           // Fall back to default relation on query failure\n543:         }\n544:       }\n545: \n546:       const intentScore = computeIntentTraversalScore(\n547:         avgSeedScore,\n548:         dominantRelation,\n549:         neighborBoost.hopCount,\n550:         clampedFreshness,\n551:         intent\n552:       );\n553:       intentBoosts.set(neighborId, intentScore);\n554:     }\n555:   }\n556: \n557:   // Select the active boost map: intent-aware when the flag is on, classic otherwise.\n558:   const classicBoosts = new Map<number, number>();\n559:   for (const [neighborId, neighborBoost] of neighborBoosts) {\n560:     classicBoosts.set(neighborId, neighborBoost.boost);\n561:   }\n562:   const activeBoosts = isTypedTraversalEnabled() ? intentBoosts : classicBoosts;\n563: \n564:   const existingIds = new Set(results.map((item) => item.id));\n565:   // Reduce avoids stack overflow on arrays >100K elements (spread pushes all onto call stack)\n566:   const lowestScore = Math.max(0.0001, results.map((item) => resolveBaseScore(item)).reduce((a, b) => Math.min(a, b), Infinity));\n567: \n568:   const boosted = results.map((item) => {\n569:     const causalBoost = activeBoosts.get(item.id) ?? 0;\n570:     if (causalBoost <= 0) {\n571:       return item;\n572:     }\n573: \n574:     const sessionBoost = typeof item.sessionBoost === 'number' ? Math.max(0, item.sessionBoost) : 0;\n575:     const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST - sessionBoost));\n576:     if (allowedBoost <= 0) {\n577:       return item;\n578:     }\n579: \n580:     const baseScore = resolveBaseScore(item);\n581:     const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n582:     metadata.boostedCount += 1;\n583:     metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, allowedBoost);\n584:     return {\n585:       ...item,\n586:       score,\n587:       rrfScore: score,\n588:       intentAdjustedScore: score,\n589:       attentionScore: score,\n590:       causalBoost: allowedBoost,\n591:       baseScore,\n592:     };\n593:   });\n594: \n595:   const injectIds: number[] = [];\n596:   for (const [neighborId] of activeBoosts) {\n597:     if (!existingIds.has(neighborId)) {\n598:       injectIds.push(neighborId);\n599:     }\n600:   }\n601: \n602:   const injectedRows = fetchNeighborRows(injectIds).map((row) => {\n603:     const causalBoost = Math.max(0, Math.min(activeBoosts.get(row.id) ?? 0, MAX_COMBINED_BOOST));\n604:     metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, causalBoost);\n605:     const baseScore = lowestScore * 0.5;\n606:     return buildPipelineRow(row, baseScore, causalBoost);\n607:   });\n608: \n609:   metadata.injectedCount = injectedRows.length;\n610:   metadata.applied = metadata.boostedCount > 0 || metadata.injectedCount > 0;\n611: \n612:   const merged = [...boosted, ...injectedRows].sort((left, right) => {\n613:     const leftScore = resolveBaseScore(left);\n614:     const rightScore = resolveBaseScore(right);\n615:     if (rightScore === leftScore) {\n616:       return left.id - right.id;\n617:     }\n618:     return rightScore - leftScore;\n619:   });\n620: \n621:   return { results: merged, metadata };\n622: }\n623: \n624: // ───────────────────────────────────────────────────────────────\n625: // ALWAYS-ON GRAPH CONTEXT INJECTION\n626: // ───────────────────────────────────────────────────────────────\n627: \n628: /**\n629:  * Graph context metadata returned by injectGraphContext.\n630:  * Contains related memory IDs and edge types discovered from the graph\n631:  * even when the causal boost has no seed results.\n632:  */\n633: interface GraphContextResult {\n634:   /** Whether graph context injection was active and produced results. */\n635:   activated: boolean;\n636:   /** Canonical concept names matched from the query. */\n637:   matchedConcepts: string[];\n638:   /** Memory IDs of graph neighbors related to matched concepts. */\n639:   relatedMemoryIds: number[];\n640:   /** Edge relation types connecting seeds to neighbors. */\n641:   edgeTypes: string[];\n642: }\n643: \n644: /**\n645:  * Always-on graph context injection.\n646:  *\n647:  * Runs concept routing on the query and finds graph neighbors for matched\n648:  * concepts, returning graph context metadata (related memory IDs, edge types).\n649:  * Unlike applyCausalBoost, this runs even when there are no seed results,\n650:  * enabling proactive graph-guided context discovery.\n651:  *\n652:  * Feature-gated by SPECKIT_GRAPH_CONTEXT_INJECTION (default ON).\n653:  * Fail-open: returns empty result on any error.\n654:  *\n655:  * @param query - The search query string.\n656:  * @param database - SQLite database instance for graph lookups.\n657:  * @returns GraphContextResult with related memory IDs and edge types.\n658:  */\n659: function injectGraphContext(\n660:   query: string,\n661:   database: Database.Database,\n662: ): GraphContextResult {\n663:   const empty: GraphContextResult = {\n664:     activated: false,\n665:     matchedConcepts: [],\n666:     relatedMemoryIds: [],\n667:     edgeTypes: [],\n668:   };\n669: \n670:   if (!isGraphContextInjectionEnabled()) return empty;\n671: \n672:   try {\n673:     const routing = routeQueryConcepts(query, database);\n674:     if (!routing.graphActivated || routing.concepts.length === 0) return empty;\n675: \n676:     // Find seed memory IDs whose titles contain matched concept keywords\n677:     const likeClauses = routing.concepts.map(() => 'LOWER(title) LIKE ?').join(' OR ');\n678:     const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n679: \n680:     const seedRows = (database.prepare(`\n681:       SELECT id FROM memory_index WHERE (${likeClauses}) LIMIT 10\n682:     `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n683: \n684:     if (seedRows.length === 0) {\n685:       return { ...empty, activated: true, matchedConcepts: routing.concepts };\n686:     }\n687: \n688:     const seedIds = seedRows.map((r) => String(r.id));\n689:     const seedPlaceholders = seedIds.map(() => '?').join(', ');\n690: \n691:     // Walk 1-hop causal edges to find neighbor nodes and edge types\n692:     const neighborRows = (database.prepare(`\n693:       SELECT DISTINCT\n694:         CASE\n695:           WHEN ce.source_id IN (${seedPlaceholders}) THEN CAST(ce.target_id AS INTEGER)\n696:           ELSE CAST(ce.source_id AS INTEGER)\n697:         END AS neighbor_id,\n698:         ce.relation\n699:       FROM causal_edges ce\n700:       WHERE ce.source_id IN (${seedPlaceholders}) OR ce.target_id IN (${seedPlaceholders})\n701:       LIMIT 20\n702:     `) as Database.Statement).all(\n703:       ...seedIds,\n704:       ...seedIds,\n705:       ...seedIds,\n706:     ) as Array<{ neighbor_id: number; relation: string }>;\n707: \n708:     const relatedMemoryIds: number[] = [];\n709:     const edgeTypes = new Set<string>();\n710:     const seedIdSet = new Set(seedRows.map((r) => r.id));\n711: \n712:     for (const row of neighborRows) {\n713:       if (!seedIdSet.has(row.neighbor_id) && Number.isFinite(row.neighbor_id)) {\n714:         relatedMemoryIds.push(row.neighbor_id);\n715:       }\n716:       if (row.relation) {\n717:         edgeTypes.add(row.relation);\n718:       }\n719:     }\n720: \n721:     return {\n722:       activated: true,\n723:       matchedConcepts: routing.concepts,\n724:       relatedMemoryIds: [...new Set(relatedMemoryIds)].slice(0, 10),\n725:       edgeTypes: Array.from(edgeTypes),\n726:     };\n727:   } catch (error: unknown) {\n728:     const message = error instanceof Error ? error.message : String(error);\n729:     console.warn(`[causal-boost] injectGraphContext failed (fail-open): ${message}`);\n730:     return empty;\n731:   }\n732: }\n733: \n734: export {\n735:   MAX_HOPS,\n736:   MAX_BOOST_PER_HOP,\n737:   RELATION_WEIGHT_MULTIPLIERS,\n738:   // D3 Phase A exports\n739:   SPARSE_DENSITY_THRESHOLD,\n740:   SPARSE_MAX_HOPS,\n741:   DEFAULT_TYPED_TRAVERSAL_DEPTH,\n742:   INTENT_EDGE_PRIORITY,\n743:   DEFAULT_EDGE_PRIORITY,\n744:   DEFAULT_EDGE_PRIOR,\n745:   EDGE_PRIOR_TIERS,\n746:   EDGE_LABEL_ALIASES,\n747:   init,\n748:   isEnabled,\n749:   isTypedTraversalEnabled,\n750:   isSparseMode,\n751:   resolveSparseFirstTraversalPolicy,\n752:   resolveTraversalDepth,\n753:   resolveEdgePrior,\n754:   computeHopDecay,\n755:   computeIntentTraversalScore,\n756:   getIntentEdgePriorities,\n757:   computeIntentEdgePrior,\n758:   computeTraversalHopDecay,\n759:   computeTraversalFreshnessFactor,\n760:   computeIntentAwareTraversalScore,\n761:   getNeighborBoosts,\n762:   applyCausalBoost,\n763:   // Always-on graph context injection\n764:   injectGraphContext,\n765: };\n766: \n767: export type {\n768:   RankedSearchResult,\n769:   CausalBoostMetadata,\n770:   CausalBoostOptions,\n771:   SparseFirstTraversalPolicy,\n772:   GraphContextResult,\n773: };\n\n(End of file - total 773 lines)\n</content>","metadata":{"preview":"  if (isTypedTraversalEnabled()) {\n    const avgSeedScore = seedResults.length > 0\n      ? seedResults.map((s) => resolveBaseScore(s)).reduce((a, b) => a + b, 0) / seedResults.length\n      : 1.0;\n    const clampedFreshness = Math.max(0, Math.min(1, Number.isFinite(freshness) ? freshness : 1.0));\n\n    for (const [neighborId, neighborBoost] of neighborBoosts) {\n      // We don't have the per-edge relation type at this aggregation level,\n      // so we use the seed's dominant relation by querying the first-hop edge from the DB.\n      // Fall back to 'caused' (neutral default) if unavailable.\n      let dominantRelation = 'caused';\n      if (db) {\n        try {\n          const edgeRow = (db.prepare(`\n            SELECT relation FROM causal_edges\n            WHERE source_id IN (${seedIds.map(() => '?').join(',')})\n              AND target_id = ?\n            LIMIT 1\n          `) as Database.Statement).get(...seedIds.map(String), String(neighborId)) as\n            { relation: string } | undefined;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","text":"  if (isTypedTraversalEnabled()) {\n    const avgSeedScore = seedResults.length > 0\n      ? seedResults.map((s) => resolveBaseScore(s)).reduce((a, b) => a + b, 0) / seedResults.length\n      : 1.0;\n    const clampedFreshness = Math.max(0, Math.min(1, Number.isFinite(freshness) ? freshness : 1.0));\n\n    for (const [neighborId, neighborBoost] of neighborBoosts) {\n      // We don't have the per-edge relation type at this aggregation level,\n      // so we use the seed's dominant relation by querying the first-hop edge from the DB.\n      // Fall back to 'caused' (neutral default) if unavailable.\n      let dominantRelation = 'caused';\n      if (db) {\n        try {\n          const edgeRow = (db.prepare(`\n            SELECT relation FROM causal_edges\n            WHERE source_id IN (${seedIds.map(() => '?').join(',')})\n              AND target_id = ?\n            LIMIT 1\n          `) as Database.Statement).get(...seedIds.map(String), String(neighborId)) as\n            { relation: string } | undefined;\n          if (edgeRow?.relation) dominantRelation = edgeRow.relation;\n        } catch (_err: unknown) {\n          // Fall back to default relation on query failure\n        }\n      }\n\n      const intentScore = computeIntentTraversalScore(\n        avgSeedScore,\n        dominantRelation,\n        neighborBoost.hopCount,\n        clampedFreshness,\n        intent\n      );\n      intentBoosts.set(neighborId, intentScore);\n    }\n  }\n\n  // Select the active boost map: intent-aware when the flag is on, classic otherwise.\n  const classicBoosts = new Map<number, number>();\n  for (const [neighborId, neighborBoost] of neighborBoosts) {\n    classicBoosts.set(neighborId, neighborBoost.boost);\n  }\n  const activeBoosts = isTypedTraversalEnabled() ? intentBoosts : classicBoosts;\n\n  const existingIds = new Set(results.map((item) => item.id));\n  // Reduce avoids stack overflow on arrays >100K elements (spread pushes all onto call stack)\n  const lowestScore = Math.max(0.0001, results.map((item) => resolveBaseScore(item)).reduce((a, b) => Math.min(a, b), Infinity));\n\n  const boosted = results.map((item) => {\n    const causalBoost = activeBoosts.get(item.id) ?? 0;\n    if (causalBoost <= 0) {\n      return item;\n    }\n\n    const sessionBoost = typeof item.sessionBoost === 'number' ? Math.max(0, item.sessionBoost) : 0;\n    const allowedBoost = Math.max(0, Math.min(causalBoost, MAX_COMBINED_BOOST - sessionBoost));\n    if (allowedBoost <= 0) {\n      return item;\n    }\n\n    const baseScore = resolveBaseScore(item);\n    const score = Math.min(1, Math.max(0, baseScore * (1 + allowedBoost)));\n    metadata.boostedCount += 1;\n    metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, allowedBoost);\n    return {\n      ...item,\n      score,\n      rrfScore: score,\n      intentAdjustedScore: score,\n      attentionScore: score,\n      causalBoost: allowedBoost,\n      baseScore,\n    };\n  });\n\n  const injectIds: number[] = [];\n  for (const [neighborId] of activeBoosts) {\n    if (!existingIds.has(neighborId)) {\n      injectIds.push(neighborId);\n    }\n  }\n\n  const injectedRows = fetchNeighborRows(injectIds).map((row) => {\n    const causalBoost = Math.max(0, Math.min(activeBoosts.get(row.id) ?? 0, MAX_COMBINED_BOOST));\n    metadata.maxBoostApplied = Math.max(metadata.maxBoostApplied, causalBoost);\n    const baseScore = lowestScore * 0.5;\n    return buildPipelineRow(row, baseScore, causalBoost);\n  });\n\n  metadata.injectedCount = injectedRows.length;\n  metadata.applied = metadata.boostedCount > 0 || metadata.injectedCount > 0;\n\n  const merged = [...boosted, ...injectedRows].sort((left, right) => {\n    const leftScore = resolveBaseScore(left);\n    const rightScore = resolveBaseScore(right);\n    if (rightScore === leftScore) {\n      return left.id - right.id;\n    }\n    return rightScore - leftScore;\n  });\n\n  return { results: merged, metadata };\n}\n\n// ───────────────────────────────────────────────────────────────\n// ALWAYS-ON GRAPH CONTEXT INJECTION\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Graph context metadata returned by injectGraphContext.\n * Contains related memory IDs and edge types discovered from the graph\n * even when the causal boost has no seed results.\n */\ninterface GraphContextResult {\n  /** Whether graph context injection was active and produced results. */\n  activated: boolean;\n  /** Canonical concept names matched from the query. */\n  matchedConcepts: string[];\n  /** Memory IDs of graph neighbors related to matched concepts. */\n  relatedMemoryIds: number[];\n  /** Edge relation types connecting seeds to neighbors. */\n  edgeTypes: string[];\n}\n\n/**\n * Always-on graph context injection.\n *\n * Runs concept routing on the query and finds graph neighbors for matched\n * concepts, returning graph context metadata (related memory IDs, edge types).\n * Unlike applyCausalBoost, this runs even when there are no seed results,\n * enabling proactive graph-guided context discovery.\n *\n * Feature-gated by SPECKIT_GRAPH_CONTEXT_INJECTION (default ON).\n * Fail-open: returns empty result on any error.\n *\n * @param query - The search query string.\n * @param database - SQLite database instance for graph lookups.\n * @returns GraphContextResult with related memory IDs and edge types.\n */\nfunction injectGraphContext(\n  query: string,\n  database: Database.Database,\n): GraphContextResult {\n  const empty: GraphContextResult = {\n    activated: false,\n    matchedConcepts: [],\n    relatedMemoryIds: [],\n    edgeTypes: [],\n  };\n\n  if (!isGraphContextInjectionEnabled()) return empty;\n\n  try {\n    const routing = routeQueryConcepts(query, database);\n    if (!routing.graphActivated || routing.concepts.length === 0) return empty;\n\n    // Find seed memory IDs whose titles contain matched concept keywords\n    const likeClauses = routing.concepts.map(() => 'LOWER(title) LIKE ?').join(' OR ');\n    const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n\n    const seedRows = (database.prepare(`\n      SELECT id FROM memory_index WHERE (${likeClauses}) LIMIT 10\n    `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n\n    if (seedRows.length === 0) {\n      return { ...empty, activated: true, matchedConcepts: routing.concepts };\n    }\n\n    const seedIds = seedRows.map((r) => String(r.id));\n    const seedPlaceholders = seedIds.map(() => '?').join(', ');\n\n    // Walk 1-hop causal edges to find neighbor nodes and edge types\n    const neighborRows = (database.prepare(`\n      SELECT DISTINCT\n        CASE\n          WHEN ce.source_id IN (${seedPlaceholders}) THEN CAST(ce.target_id AS INTEGER)\n          ELSE CAST(ce.source_id AS INTEGER)\n        END AS neighbor_id,\n        ce.relation\n      FROM causal_edges ce\n      WHERE ce.source_id IN (${seedPlaceholders}) OR ce.target_id IN (${seedPlaceholders})\n      LIMIT 20\n    `) as Database.Statement).all(\n      ...seedIds,\n      ...seedIds,\n      ...seedIds,\n    ) as Array<{ neighbor_id: number; relation: string }>;\n\n    const relatedMemoryIds: number[] = [];\n    const edgeTypes = new Set<string>();\n    const seedIdSet = new Set(seedRows.map((r) => r.id));\n\n    for (const row of neighborRows) {\n      if (!seedIdSet.has(row.neighbor_id) && Number.isFinite(row.neighbor_id)) {\n        relatedMemoryIds.push(row.neighbor_id);\n      }\n      if (row.relation) {\n        edgeTypes.add(row.relation);\n      }\n    }\n\n    return {\n      activated: true,\n      matchedConcepts: routing.concepts,\n      relatedMemoryIds: [...new Set(relatedMemoryIds)].slice(0, 10),\n      edgeTypes: Array.from(edgeTypes),\n    };\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-boost] injectGraphContext failed (fail-open): ${message}`);\n    return empty;\n  }\n}\n\nexport {\n  MAX_HOPS,\n  MAX_BOOST_PER_HOP,\n  RELATION_WEIGHT_MULTIPLIERS,\n  // D3 Phase A exports\n  SPARSE_DENSITY_THRESHOLD,\n  SPARSE_MAX_HOPS,\n  DEFAULT_TYPED_TRAVERSAL_DEPTH,\n  INTENT_EDGE_PRIORITY,\n  DEFAULT_EDGE_PRIORITY,\n  DEFAULT_EDGE_PRIOR,\n  EDGE_PRIOR_TIERS,\n  EDGE_LABEL_ALIASES,\n  init,\n  isEnabled,\n  isTypedTraversalEnabled,\n  isSparseMode,\n  resolveSparseFirstTraversalPolicy,\n  resolveTraversalDepth,\n  resolveEdgePrior,\n  computeHopDecay,\n  computeIntentTraversalScore,\n  getIntentEdgePriorities,\n  computeIntentEdgePrior,\n  computeTraversalHopDecay,\n  computeTraversalFreshnessFactor,\n  computeIntentAwareTraversalScore,\n  getNeighborBoosts,\n  applyCausalBoost,\n  // Always-on graph context injection\n  injectGraphContext,\n};\n\nexport type {\n  RankedSearchResult,\n  CausalBoostMetadata,\n  CausalBoostOptions,\n  SparseFirstTraversalPolicy,\n  GraphContextResult,\n};","lineStart":520,"lineEnd":773,"totalLines":773,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","time":{"start":1781144204094,"end":1781144204099}},"metadata":{"openai":{"itemId":"fc_0855f74cea9e2624016a2a1a8c02d08191b0cb7006b68f56d6"}},"id":"prt_eb477b32a001QWiKio0F6nWyuq","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477917c001svZdX4mVh5wPSf"}}
{"type":"tool_use","timestamp":1781144204106,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_kin88RDzwJyCvpdl1GGGksJL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Maintenance\n3: // -------------------------------------------------------------------\n4: \n5: import type { Awaitable } from './common.js';\n6: import type Database from 'better-sqlite3';\n7: \n8: /** Result from a storage maintenance command. */\n9: export interface MaintenanceResult {\n10:   readonly ok: boolean;\n11:   readonly message?: string;\n12:   readonly details?: Readonly<Record<string, unknown>>;\n13: }\n14: \n15: /** Options for checkpoint-style maintenance operations. */\n16: export interface CheckpointOptions {\n17:   readonly mode?: 'passive' | 'full' | 'restart' | 'truncate';\n18: }\n19: \n20: /** Maintenance operation names surfaced to call-site warning hooks. */\n21: export type MaintenanceOperation = 'quick_check' | 'auto_vacuum' | 'incremental_vacuum' | 'wal_checkpoint';\n22: \n23: /** Options for the better-sqlite3 maintenance adapter. */\n24: export interface BetterSqliteMaintenanceOptions {\n25:   readonly onMaintenanceError?: (operation: MaintenanceOperation, error: unknown) => void;\n26: }\n27: \n28: /** Port for operational storage maintenance tasks. */\n29: export interface Maintenance {\n30:   /** Run an integrity check against the active storage backend. */\n31:   integrityCheck(): Awaitable<MaintenanceResult>;\n32: \n33:   /** Compact backend storage when supported. */\n34:   vacuum(): Awaitable<MaintenanceResult>;\n35: \n36:   /** Flush write-ahead or equivalent backend state when supported. */\n37:   checkpoint(options?: CheckpointOptions): Awaitable<MaintenanceResult>;\n38: }\n39: \n40: /** better-sqlite3 implementation of operational storage maintenance. */\n41: export class BetterSqliteMaintenance implements Maintenance {\n42:   private readonly onMaintenanceError: ((operation: MaintenanceOperation, error: unknown) => void) | undefined;\n43: \n44:   constructor(\n45:     private readonly database: Database.Database,\n46:     options: BetterSqliteMaintenanceOptions = {},\n47:   ) {\n48:     this.onMaintenanceError = options.onMaintenanceError;\n49:   }\n50: \n51:   integrityCheck(): MaintenanceResult {\n52:     try {\n53:       const rows = this.database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n54:       const first = Object.values(rows[0] ?? {})[0];\n55:       const verdict = typeof first === 'string' ? first : 'quick_check returned no verdict';\n56:       return { ok: verdict === 'ok', message: verdict, details: { verdict } };\n57:     } catch (error: unknown) {\n58:       this.reportError('quick_check', error);\n59:       return { ok: false, message: errorMessage(error) };\n60:     }\n61:   }\n62: \n63:   vacuum(): MaintenanceResult {\n64:     let shouldRunIncrementalVacuum = false;\n65:     try {\n66:       const autoVacuumMode = this.database.pragma('auto_vacuum', { simple: true });\n67:       shouldRunIncrementalVacuum = Number(autoVacuumMode) === 2;\n68:     } catch (error: unknown) {\n69:       this.reportError('auto_vacuum', error);\n70:       return { ok: false, message: errorMessage(error), details: { operation: 'auto_vacuum' } };\n71:     }\n72: \n73:     if (shouldRunIncrementalVacuum) {\n74:       try {\n75:         this.database.pragma('incremental_vacuum');\n76:       } catch (error: unknown) {\n77:         this.reportError('incremental_vacuum', error);\n78:         return { ok: false, message: errorMessage(error), details: { operation: 'incremental_vacuum' } };\n79:       }\n80:     }\n81: \n82:     return { ok: true, details: { incrementalVacuum: shouldRunIncrementalVacuum } };\n83:   }\n84: \n85:   checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n86:     const mode = (options.mode ?? 'passive').toUpperCase();\n87:     try {\n88:       const result = this.database.pragma(`wal_checkpoint(${mode})`) as unknown;\n89:       return { ok: true, details: { mode: options.mode ?? 'passive', result } };\n90:     } catch (error: unknown) {\n91:       this.reportError('wal_checkpoint', error);\n92:       return { ok: false, message: errorMessage(error), details: { mode: options.mode ?? 'passive' } };\n93:     }\n94:   }\n95: \n96:   private reportError(operation: MaintenanceOperation, error: unknown): void {\n97:     this.onMaintenanceError?.(operation, error);\n98:   }\n99: }\n100: \n101: function errorMessage(error: unknown): string {\n102:   return error instanceof Error ? error.message : String(error);\n103: }\n\n(End of file - total 103 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Maintenance\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\n/** Result from a storage maintenance command. */\nexport interface MaintenanceResult {\n  readonly ok: boolean;\n  readonly message?: string;\n  readonly details?: Readonly<Record<string, unknown>>;\n}\n\n/** Options for checkpoint-style maintenance operations. */\nexport interface CheckpointOptions {\n  readonly mode?: 'passive' | 'full' | 'restart' | 'truncate';\n}\n\n/** Maintenance operation names surfaced to call-site warning hooks. */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Maintenance\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\n/** Result from a storage maintenance command. */\nexport interface MaintenanceResult {\n  readonly ok: boolean;\n  readonly message?: string;\n  readonly details?: Readonly<Record<string, unknown>>;\n}\n\n/** Options for checkpoint-style maintenance operations. */\nexport interface CheckpointOptions {\n  readonly mode?: 'passive' | 'full' | 'restart' | 'truncate';\n}\n\n/** Maintenance operation names surfaced to call-site warning hooks. */\nexport type MaintenanceOperation = 'quick_check' | 'auto_vacuum' | 'incremental_vacuum' | 'wal_checkpoint';\n\n/** Options for the better-sqlite3 maintenance adapter. */\nexport interface BetterSqliteMaintenanceOptions {\n  readonly onMaintenanceError?: (operation: MaintenanceOperation, error: unknown) => void;\n}\n\n/** Port for operational storage maintenance tasks. */\nexport interface Maintenance {\n  /** Run an integrity check against the active storage backend. */\n  integrityCheck(): Awaitable<MaintenanceResult>;\n\n  /** Compact backend storage when supported. */\n  vacuum(): Awaitable<MaintenanceResult>;\n\n  /** Flush write-ahead or equivalent backend state when supported. */\n  checkpoint(options?: CheckpointOptions): Awaitable<MaintenanceResult>;\n}\n\n/** better-sqlite3 implementation of operational storage maintenance. */\nexport class BetterSqliteMaintenance implements Maintenance {\n  private readonly onMaintenanceError: ((operation: MaintenanceOperation, error: unknown) => void) | undefined;\n\n  constructor(\n    private readonly database: Database.Database,\n    options: BetterSqliteMaintenanceOptions = {},\n  ) {\n    this.onMaintenanceError = options.onMaintenanceError;\n  }\n\n  integrityCheck(): MaintenanceResult {\n    try {\n      const rows = this.database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n      const first = Object.values(rows[0] ?? {})[0];\n      const verdict = typeof first === 'string' ? first : 'quick_check returned no verdict';\n      return { ok: verdict === 'ok', message: verdict, details: { verdict } };\n    } catch (error: unknown) {\n      this.reportError('quick_check', error);\n      return { ok: false, message: errorMessage(error) };\n    }\n  }\n\n  vacuum(): MaintenanceResult {\n    let shouldRunIncrementalVacuum = false;\n    try {\n      const autoVacuumMode = this.database.pragma('auto_vacuum', { simple: true });\n      shouldRunIncrementalVacuum = Number(autoVacuumMode) === 2;\n    } catch (error: unknown) {\n      this.reportError('auto_vacuum', error);\n      return { ok: false, message: errorMessage(error), details: { operation: 'auto_vacuum' } };\n    }\n\n    if (shouldRunIncrementalVacuum) {\n      try {\n        this.database.pragma('incremental_vacuum');\n      } catch (error: unknown) {\n        this.reportError('incremental_vacuum', error);\n        return { ok: false, message: errorMessage(error), details: { operation: 'incremental_vacuum' } };\n      }\n    }\n\n    return { ok: true, details: { incrementalVacuum: shouldRunIncrementalVacuum } };\n  }\n\n  checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n    const mode = (options.mode ?? 'passive').toUpperCase();\n    try {\n      const result = this.database.pragma(`wal_checkpoint(${mode})`) as unknown;\n      return { ok: true, details: { mode: options.mode ?? 'passive', result } };\n    } catch (error: unknown) {\n      this.reportError('wal_checkpoint', error);\n      return { ok: false, message: errorMessage(error), details: { mode: options.mode ?? 'passive' } };\n    }\n  }\n\n  private reportError(operation: MaintenanceOperation, error: unknown): void {\n    this.onMaintenanceError?.(operation, error);\n  }\n}\n\nfunction errorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}","lineStart":1,"lineEnd":103,"totalLines":103,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts","time":{"start":1781144204100,"end":1781144204105}},"metadata":{"openai":{"itemId":"fc_0855f74cea9e2624016a2a1a8c02d88191b84c91825f0f8dfb"}},"id":"prt_eb477b33f001pGTeWqxeP9iwUU","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477917c001svZdX4mVh5wPSf"}}
{"type":"tool_use","timestamp":1781144204117,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_eiaLYMJNSnmcTgFDvApRujQN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":320,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n320:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n321:       prior_hash: null,\n322:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n323:       linked_memory_ids: deletedIds.slice(0, 50),\n324:       decision_meta: {\n325:         tool: 'memory_retention_sweep',\n326:         reason: 'retention_expired',\n327:         totalDeleted: deletedIds.length,\n328:         originalDeleteAfter: candidates\n329:           .filter((candidate) => deletedIds.includes(candidate.id))\n330:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n331:       },\n332:       actor: 'mcp:memory_retention_sweep',\n333:     });\n334:     return true;\n335:   } catch (error: unknown) {\n336:     const message = error instanceof Error ? error.message : String(error);\n337:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n338:     return false;\n339:   }\n340: }\n341: \n342: function runPostDeleteMaintenance(database: Database.Database): void {\n343:   try {\n344:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n345:   } catch (error: unknown) {\n346:     const message = error instanceof Error ? error.message : String(error);\n347:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n348:   }\n349: \n350:   const maintenance = new BetterSqliteMaintenance(database, {\n351:     onMaintenanceError: reportRetentionMaintenanceError,\n352:   });\n353:   maintenance.vacuum();\n354:   maintenance.checkpoint({ mode: 'truncate' });\n355: }\n356: \n357: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n358:   const message = error instanceof Error ? error.message : String(error);\n359:   if (operation === 'auto_vacuum') {\n360:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n361:   } else if (operation === 'incremental_vacuum') {\n362:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n363:   } else if (operation === 'wal_checkpoint') {\n364:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n365:   }\n366: }\n367: \n368: /**\n369:  * Sweep expired governed memory rows.\n370:  *\n371:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n372:  * to enforce the ISO timestamps persisted by governed ingest.\n373:  */\n374: export function runMemoryRetentionSweep(\n375:   database: Database.Database,\n376:   args: MemoryRetentionSweepArgs = {},\n377: ): MemoryRetentionSweepResult {\n378:   const startTime = Date.now();\n379:   const dryRun = args.dryRun === true;\n380:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n381: \n382:   if (!hasTable(database, 'memory_index')) {\n383:     return {\n384:       swept: 0,\n385:       retained: 0,\n386:       protectedCount: 0,\n387:       dryRun,\n388:       durationMs: Date.now() - startTime,\n389:       candidates: [],\n390:       deletedIds: [],\n391:       protectedIds: [],\n392:       ledgerRecorded: null,\n393:       tombstoneState: {\n394:         usesPurgeablePartition: false,\n395:         usingPurgeableIndex: false,\n396:         candidateCount: 0,\n397:         deletedCount: 0,\n398:       },\n399:       edgeState: {\n400:         causalEdgesTablePresent: false,\n401:         candidateEdgeCount: 0,\n402:       },\n403:     };\n404:   }\n405: \n406:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n407:   const initialEdgeState = buildEdgeState(database, candidates);\n408:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n409:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n\n(Showing lines 320-409 of 607. Use offset=410 to continue.)\n</content>","metadata":{"preview":"      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)","lineStart":320,"lineEnd":409,"totalLines":607,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781144204113,"end":1781144204116}},"metadata":{"openai":{"itemId":"fc_0855f74cea9e2624016a2a1a8c02e08191aa418aa9eab62a88"}},"id":"prt_eb477b3460013G4u221G4U0Sre","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477917c001svZdX4mVh5wPSf"}}
