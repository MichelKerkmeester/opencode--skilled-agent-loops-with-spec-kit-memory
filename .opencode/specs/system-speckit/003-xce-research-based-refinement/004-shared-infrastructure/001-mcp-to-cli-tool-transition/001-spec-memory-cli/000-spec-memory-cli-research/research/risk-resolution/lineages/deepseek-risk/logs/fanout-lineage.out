kSync(tmpPath);\n133:   } catch (error) {\n134:     if (error.code !== 'ENOENT') {\n135:       // Best-effort cleanup only; the original durable-write failure is more useful.\n136:     }\n137:   }\n138: }\n139: \n140: function writeAtomicJsonFile(targetPath, payload, operation) {\n141:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n142:   const tmp = `${currentPath}.tmp.${process.pid}`;\n143:   try {\n144:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n145:     fs.renameSync(tmp, currentPath);\n146:     return true;\n147:   } catch (error) {\n148:     cleanupTmpFile(tmp);\n149:     if (isDurableWriteUnavailable(error)) {\n150:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n151:       return false;\n152:     }\n153:     throw error;\n154:   }\n155: }\n156: \n157: function loadProjectEnvFiles() {\n158:   for (const fname of ['.env.local', '.env']) {\n159:     const p = path.join(root, fname);\n160:     if (fs.existsSync(p)) {\n161:       const n = loadEnvFile(p);\n162:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n163:     }\n164:   }\n165: }\n166: \n167: function parsePositiveInteger(value, fallback) {\n168:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n169:   const parsed = Number.parseInt(String(value).trim(), 10);\n170:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n171: }\n172: \n173: function loadBridgeModule() {\n174:   try {\n175:     return require('./lib/launcher-ipc-bridge.cjs');\n176:   } catch (error) {\n177:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n178:     return {\n179:       async maybeBridgeLeaseHolder({ leaseResult }) {\n180:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n181:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n182:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n183:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n184:         return { action: 'report', reason: 'bridge-module-missing' };\n185:       },\n186:     };\n187:   }\n188: }\n189: \n190: function resolveSessionProxySocketPath() {\n191:   const { getIpcSocketPath } = loadBridgeModule();\n192:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n193: }\n194: \n195: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n196: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n197: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n198: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n199: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n200: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n201: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n202: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n203:   const createProxy = options.createProxy ?? createSessionProxy;\n204:   const sessionProxy = createProxy({\n205:     socketPath,\n206:     stdin: options.stdin ?? process.stdin,\n207:     stdout: options.stdout ?? process.stdout,\n208:     log,\n209:   });\n210:   return sessionProxy.start();\n211: }\n212: \n213: function refreshPaths() {\n214:   skillsDir = path.join(opencodeDir, 'skills');\n215:   legacySkillDir = path.join(opencodeDir, 'skill');\n216:   kitDir = path.join(skillsDir, 'system-spec-kit');\n217:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n218:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n219:   stateFile = path.join(dbDir, PID_FILE_NAME);\n220:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n221: }\n222: \n223: function exists(p) {\n224:   return fs.existsSync(p);\n225: }\n226: \n227: function writeState(payload) {\n228:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n229:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n230: }\n231: \n232: function resolvedDbDir() {\n233:   return canonicalizePath(dbDir);\n234: }\n235: \n236: function leasePath() {\n237:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n238: }\n239: \n240: function ownerLeasePath() {\n241:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n242: }\n243: \n244: function legacyLeasePaths() {\n245:   return [\n246:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n247:   ].map(canonicalizePath);\n248: }\n249: \n250: function readLeaseFile(filePath = leasePath()) {\n251:   try {\n252:     const raw = fs.readFileSync(filePath, 'utf8');\n253:     const parsed = JSON.parse(raw);\n254:     if (typeof parsed.pid === 'number') return parsed;\n255:   } catch {\n256:     // Missing or corrupt lease files are treated as no active lease.\n257:   }\n258:   return null;\n259: }\n260: \n261: function readOwnerLeaseFile(filePath = ownerLeasePath()) {\n262:   try {\n263:     const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n264:     if (\n265:       Number.isInteger(parsed.ownerPid) &&\n266:       Number.isInteger(parsed.ppid) &&\n267:       typeof parsed.executablePath === 'string' &&\n268:       typeof parsed.startedAtIso === 'string' &&\n269:       typeof parsed.lastHeartbeatIso === 'string' &&\n270:       Number.isInteger(parsed.ttlMs) &&\n271:       typeof parsed.canonicalDbDir === 'string'\n272:     ) {\n273:       return parsed;\n274:     }\n275:   } catch {\n276:     // Missing or corrupt owner leases are treated as no active owner.\n277:   }\n278:   return null;\n279: }\n280: \n281: function writeOwnerLeaseFile(lease) {\n282:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n283:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n284:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n285:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n286:   // after power loss and break ownership detection.\n287:   let fd;\n288:   try {\n289:     fd = fs.openSync(tmp, 'wx', 0o600);\n290:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n291:     fs.fsyncSync(fd);\n292:   } finally {\n293:     if (typeof fd === 'number') fs.closeSync(fd);\n294:   }\n295:   fs.renameSync(tmp, currentLeasePath);\n296: }\n297: \n298: function writeOwnerLeaseFileExclusive(lease) {\n299:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n300:   let fd;\n\n(Showing lines 101-300 of 1470. Use offset=301 to continue.)\n</content>","metadata":{"preview":"let crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"let crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-spec-kit');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n  canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n\nfunction readOwnerLeaseFile(filePath = ownerLeasePath()) {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    if (\n      Number.isInteger(parsed.ownerPid) &&\n      Number.isInteger(parsed.ppid) &&\n      typeof parsed.executablePath === 'string' &&\n      typeof parsed.startedAtIso === 'string' &&\n      typeof parsed.lastHeartbeatIso === 'string' &&\n      Number.isInteger(parsed.ttlMs) &&\n      typeof parsed.canonicalDbDir === 'string'\n    ) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt owner leases are treated as no active owner.\n  }\n  return null;\n}\n\nfunction writeOwnerLeaseFile(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n  // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n  // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n  // after power loss and break ownership detection.\n  let fd;\n  try {\n    fd = fs.openSync(tmp, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction writeOwnerLeaseFileExclusive(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  let fd;","lineStart":101,"lineEnd":300,"totalLines":1470,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780741901140,"end":1780741901145}},"id":"prt_e9c7d081d00112Gn3dqVzrHJA2","sessionID":"ses_16384c53affe2f7jn8iVrlwqWM","messageID":"msg_e9c7cf870001eJoDR6nqUbuNTG"}}
