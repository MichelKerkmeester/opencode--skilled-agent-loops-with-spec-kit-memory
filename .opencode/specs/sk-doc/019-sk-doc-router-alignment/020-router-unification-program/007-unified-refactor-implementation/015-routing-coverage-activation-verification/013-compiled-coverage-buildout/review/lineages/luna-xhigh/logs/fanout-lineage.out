tion');\n665: \n666:   for (const record of candidates) {\n667:     const run = getIterationRun(record);\n668:     if (!isFiniteNumber(run)) {\n669:       continue;\n670:     }\n671:     const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n672:     const summary = normalizeSummaryCounts(record);\n673:     if (!summary && details.length === 0) {\n674:       continue;\n675:     }\n676:     const score = details.length * 10 + (summary ? SEVERITY_KEYS.reduce((sum, key) => sum + summary[key], 0) : 0);\n677:     const existing = byRun.get(run);\n678:     if (!existing || score >= existing.score) {\n679:       byRun.set(run, { record, score });\n680:     }\n681:   }\n682: \n683:   return [...byRun.entries()]\n684:     .sort(([leftRun], [rightRun]) => leftRun - rightRun)\n685:     .map(([run, value]) => ({ run, record: value.record }));\n686: }\n687: \n688: function countFindingsSeenInRun(findingById, run) {\n689:   const counts = zeroSeverityMap();\n690:   for (const finding of findingById.values()) {\n691:     if (!SEVERITY_KEYS.includes(finding.severity)) {\n692:       continue;\n693:     }\n694:     if (finding.firstSeen <= run && finding.lastSeen >= run) {\n695:       counts[finding.severity] += 1;\n696:     }\n697:   }\n698:   return counts;\n699: }\n700: \n701: function summarySlotFinding(run, severity, slotIndex, record) {\n702:   return {\n703:     findingId: `SUMMARY-${severity}-${String(slotIndex + 1).padStart(3, '0')}`,\n704:     severity,\n705:     title: `Summary ${severity} finding ${slotIndex + 1}`,\n706:     file: null,\n707:     line: null,\n708:     description: normalizeText(record.focus || 'Finding carried by iteration summary counts'),\n709:     findingClass: 'summary-only',\n710:     deltaStatus: 'active',\n711:     scopeProof: null,\n712:     affectedSurfaceHints: [],\n713:     contentHash: null,\n714:   };\n715: }\n716: \n717: function fallbackFindingsFromIterationRecord(record, run, representedCounts) {\n718:   const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n719:   const detailFindings = details\n720:     .map((detail, index) => findingDetailToFinding(detail, record, index))\n721:     .filter(Boolean);\n722:   const detailCounts = zeroSeverityMap();\n723:   for (const finding of detailFindings) {\n724:     detailCounts[finding.severity] += 1;\n725:   }\n726: \n727:   const summary = normalizeSummaryCounts(record);\n728:   if (!summary) {\n729:     return detailFindings;\n730:   }\n731: \n732:   const findings = [...detailFindings];\n733:   for (const severity of SEVERITY_KEYS) {\n734:     const alreadyRepresented = (representedCounts[severity] || 0) + detailCounts[severity];\n735:     const missingCount = Math.max(0, summary[severity] - alreadyRepresented);\n736:     for (let index = 0; index < missingCount; index += 1) {\n737:       findings.push(summarySlotFinding(run, severity, alreadyRepresented + index, record));\n738:     }\n739:   }\n740:   return findings;\n741: }\n742: \n743: /**\n744:  * Build a two-tier dedup key. Primary: content_hash. Fallback for legacy\n745:  * records: `file:line + normalized-title`. Namespacing keeps the tiers from\n746:  * colliding.\n747:  */\n748: function findingDedupKey(finding) {\n749:   if (finding.contentHash) {\n750:     return `ch:${finding.contentHash}`;\n751:   }\n752:   const file = finding.file || '';\n753:   const line = isFiniteNumber(finding.line) ? finding.line : '';\n754:   const title = normalizeText(finding.title || '').toLowerCase().slice(0, 80);\n755:   return `fl:${file}:${line}|${title}`;\n756: }\n757: \n758: function dedupeDimensions(dimensions) {\n759:   const seen = new Set();\n\n(Showing lines 580-759 of 2253. Use offset=760 to continue.)\n</content>","metadata":{"preview":"  }\n  if (isFiniteNumber(record.iteration)) {\n    return record.iteration;\n  }\n  if (isFiniteNumber(record.run)) {\n    return record.run;\n  }\n  const runText = normalizeText(record.run || '');\n  const runMatch = runText.match(/(\\d+)$/);\n  return runMatch ? Number(runMatch[1]) : null;\n}\n\nfunction normalizeSummaryCounts(record) {\n  const summary = record && typeof record === 'object'\n    ? getNestedField(record, 'findingsSummary')\n    : null;\n  if (!summary || typeof summary !== 'object' || Array.isArray(summary)) {\n    return null;\n  }\n  const counts = zeroSeverityMap();","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","text":"  }\n  if (isFiniteNumber(record.iteration)) {\n    return record.iteration;\n  }\n  if (isFiniteNumber(record.run)) {\n    return record.run;\n  }\n  const runText = normalizeText(record.run || '');\n  const runMatch = runText.match(/(\\d+)$/);\n  return runMatch ? Number(runMatch[1]) : null;\n}\n\nfunction normalizeSummaryCounts(record) {\n  const summary = record && typeof record === 'object'\n    ? getNestedField(record, 'findingsSummary')\n    : null;\n  if (!summary || typeof summary !== 'object' || Array.isArray(summary)) {\n    return null;\n  }\n  const counts = zeroSeverityMap();\n  let total = 0;\n  for (const severity of SEVERITY_KEYS) {\n    const rawCount = summary[severity];\n    const count = Number.isFinite(rawCount) && rawCount > 0\n      ? Math.floor(rawCount)\n      : 0;\n    counts[severity] = count;\n    total += count;\n  }\n  return total > 0 ? counts : null;\n}\n\nfunction parseFindingLocation(fileValue) {\n  const file = typeof fileValue === 'string' ? fileValue : null;\n  let fileBase = null;\n  let lineNumber = null;\n  if (file) {\n    const m = file.match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n    if (m) {\n      fileBase = m[1];\n      lineNumber = Number(m[2]);\n    } else {\n      fileBase = file;\n    }\n  }\n  return { fileBase, lineNumber };\n}\n\nfunction findingDetailToFinding(detail, record, index) {\n  if (!detail || typeof detail !== 'object') {\n    return null;\n  }\n  const severity = normalizeSeverity(detail.finalSeverity || detail.severity);\n  if (!severity) {\n    return null;\n  }\n  const run = getIterationRun(record) || 0;\n  const findingId = normalizeText(detail.id || detail.findingId || '')\n    || `SUMMARY-${run}-${severity}-${String(index + 1).padStart(3, '0')}`;\n  const { fileBase, lineNumber } = parseFindingLocation(detail.file);\n  return {\n    findingId,\n    severity,\n    title: normalizeText(detail.title || `Summary ${severity} finding`),\n    file: fileBase,\n    line: lineNumber,\n    description: normalizeText(\n      detail.claim || detail.detail || detail.evidence || detail.recommendation || detail.description || '',\n    ),\n    findingClass: detail.findingClass || null,\n    deltaStatus: detail.disposition || detail.status || null,\n    scopeProof: typeof detail.scopeProof === 'string' ? detail.scopeProof : null,\n    affectedSurfaceHints: asStringList(detail.affectedSurfaceHints),\n    contentHash: typeof detail.content_hash === 'string' && detail.content_hash\n      ? detail.content_hash\n      : (typeof detail.contentHash === 'string' && detail.contentHash ? detail.contentHash : null),\n  };\n}\n\nfunction collectSummaryFallbackRecords(iterationRecords, deltaRecords) {\n  const byRun = new Map();\n  const candidates = []\n    .concat(Array.isArray(iterationRecords) ? iterationRecords : [])\n    .concat(Array.isArray(deltaRecords) ? deltaRecords : [])\n    .filter((record) => record?.type === 'iteration');\n\n  for (const record of candidates) {\n    const run = getIterationRun(record);\n    if (!isFiniteNumber(run)) {\n      continue;\n    }\n    const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n    const summary = normalizeSummaryCounts(record);\n    if (!summary && details.length === 0) {\n      continue;\n    }\n    const score = details.length * 10 + (summary ? SEVERITY_KEYS.reduce((sum, key) => sum + summary[key], 0) : 0);\n    const existing = byRun.get(run);\n    if (!existing || score >= existing.score) {\n      byRun.set(run, { record, score });\n    }\n  }\n\n  return [...byRun.entries()]\n    .sort(([leftRun], [rightRun]) => leftRun - rightRun)\n    .map(([run, value]) => ({ run, record: value.record }));\n}\n\nfunction countFindingsSeenInRun(findingById, run) {\n  const counts = zeroSeverityMap();\n  for (const finding of findingById.values()) {\n    if (!SEVERITY_KEYS.includes(finding.severity)) {\n      continue;\n    }\n    if (finding.firstSeen <= run && finding.lastSeen >= run) {\n      counts[finding.severity] += 1;\n    }\n  }\n  return counts;\n}\n\nfunction summarySlotFinding(run, severity, slotIndex, record) {\n  return {\n    findingId: `SUMMARY-${severity}-${String(slotIndex + 1).padStart(3, '0')}`,\n    severity,\n    title: `Summary ${severity} finding ${slotIndex + 1}`,\n    file: null,\n    line: null,\n    description: normalizeText(record.focus || 'Finding carried by iteration summary counts'),\n    findingClass: 'summary-only',\n    deltaStatus: 'active',\n    scopeProof: null,\n    affectedSurfaceHints: [],\n    contentHash: null,\n  };\n}\n\nfunction fallbackFindingsFromIterationRecord(record, run, representedCounts) {\n  const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n  const detailFindings = details\n    .map((detail, index) => findingDetailToFinding(detail, record, index))\n    .filter(Boolean);\n  const detailCounts = zeroSeverityMap();\n  for (const finding of detailFindings) {\n    detailCounts[finding.severity] += 1;\n  }\n\n  const summary = normalizeSummaryCounts(record);\n  if (!summary) {\n    return detailFindings;\n  }\n\n  const findings = [...detailFindings];\n  for (const severity of SEVERITY_KEYS) {\n    const alreadyRepresented = (representedCounts[severity] || 0) + detailCounts[severity];\n    const missingCount = Math.max(0, summary[severity] - alreadyRepresented);\n    for (let index = 0; index < missingCount; index += 1) {\n      findings.push(summarySlotFinding(run, severity, alreadyRepresented + index, record));\n    }\n  }\n  return findings;\n}\n\n/**\n * Build a two-tier dedup key. Primary: content_hash. Fallback for legacy\n * records: `file:line + normalized-title`. Namespacing keeps the tiers from\n * colliding.\n */\nfunction findingDedupKey(finding) {\n  if (finding.contentHash) {\n    return `ch:${finding.contentHash}`;\n  }\n  const file = finding.file || '';\n  const line = isFiniteNumber(finding.line) ? finding.line : '';\n  const title = normalizeText(finding.title || '').toLowerCase().slice(0, 80);\n  return `fl:${file}:${line}|${title}`;\n}\n\nfunction dedupeDimensions(dimensions) {\n  const seen = new Set();","lineStart":580,"lineEnd":759,"totalLines":2253,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","time":{"start":1784692975217,"end":1784692975224}},"metadata":{"openai":{"itemId":"fc_0c19137ef81fed85016a6040ee1ba481918fe3bd83c94dbb8b"}},"id":"prt_f87fda227001Uz8j1a4ZDNRwcO","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87fd99c9001TSdzFTOahZeZ0t"}}
