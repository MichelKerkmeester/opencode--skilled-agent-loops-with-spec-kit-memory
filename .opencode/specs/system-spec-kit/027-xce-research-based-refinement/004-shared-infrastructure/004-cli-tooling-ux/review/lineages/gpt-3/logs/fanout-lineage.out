{"type":"tool_use","timestamp":1781145155574,"sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","part":{"type":"tool","tool":"read","callID":"call_V2f7qOcIH0h84JXIs6bItg5a","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","offset":1,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Input Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // Centralized strict Zod validation schemas for MCP tool inputs.\n5: // Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { z, ZodError } from 'zod';\n12: \n13: import type { ZodType } from 'zod';\n14: \n15: // Feature catalog: Strict Zod schema validation\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: type ToolInput = Record<string, unknown>;\n22: type ToolInputSchema = ZodType<ToolInput>;\n23: \n24: /* ───────────────────────────────────────────────────────────────\n25:    3. HELPERS\n26: ──────────────────────────────────────────────────────────────── */\n27: \n28: export const getSchema = <T extends z.ZodRawShape>(shape: T): z.ZodObject<T> => {\n29:   const strict = process.env.SPECKIT_STRICT_SCHEMAS !== 'false';\n30:   const base = z.object(shape);\n31:   return strict ? base.strict() : base.passthrough();\n32: };\n33: \n34: /* ───────────────────────────────────────────────────────────────\n35:    4. CONSTANTS\n36: ──────────────────────────────────────────────────────────────── */\n37: \n38: // Guard against safeNumericPreprocess.pipe(z.number()) coercing \"\", null, and false to 0.\n39: // Use a safe preprocessor that only accepts actual numbers or numeric strings.\n40: const safeNumericPreprocess = z.preprocess((val) => {\n41:   if (typeof val === 'number') return val;\n42:   if (typeof val === 'string' && val.trim().length > 0) {\n43:     const parsed = Number(val);\n44:     return Number.isFinite(parsed) ? parsed : val;\n45:   }\n46:   return val;\n47: }, z.number());\n48: \n49: const intRange = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().int().min(min).max(max));\n50: const positiveInt = safeNumericPreprocess.pipe(z.number().int().positive());\n51: const positiveIntMax = (max: number) => intRange(1, max);\n52: const boundedNumber = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().min(min).max(max));\n53: const optionalStringArray = z.array(z.string()).optional();\n54: \n55: const PATH_TRAVERSAL_MESSAGE = 'Path must not contain traversal sequences';\n56: const isSafePath = (value: string): boolean => !value.includes('..') && !value.includes('\\0');\n57: const pathString = (minLength = 0) => {\n58:   let schema = z.string();\n59:   if (minLength > 0) {\n60:     schema = schema.min(minLength);\n61:   }\n62:   return schema.refine(isSafePath, { message: PATH_TRAVERSAL_MESSAGE });\n63: };\n64: const optionalPathString = (minLength = 0) => pathString(minLength).optional();\n65: \n66: /** Shared max paths constant — used by both schema and handler. */\n67: export const MAX_INGEST_PATHS = 50;\n68: export const MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS = 1;\n69: export const RESERVED_FEEDBACK_TYPE_ERROR_CODE = 'E_RESERVED_FEEDBACK_TYPE';\n70: \n\n(Showing lines 1-70 of 801. Use offset=71 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Input Schemas\n// ───────────────────────────────────────────────────────────────\n// Centralized strict Zod validation schemas for MCP tool inputs.\n// Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { z, ZodError } from 'zod';\n\nimport type { ZodType } from 'zod';\n\n// Feature catalog: Strict Zod schema validation\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Input Schemas\n// ───────────────────────────────────────────────────────────────\n// Centralized strict Zod validation schemas for MCP tool inputs.\n// Strict mode is controlled by SPECKIT_STRICT_SCHEMAS (default: true).\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { z, ZodError } from 'zod';\n\nimport type { ZodType } from 'zod';\n\n// Feature catalog: Strict Zod schema validation\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ntype ToolInput = Record<string, unknown>;\ntype ToolInputSchema = ZodType<ToolInput>;\n\n/* ───────────────────────────────────────────────────────────────\n   3. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nexport const getSchema = <T extends z.ZodRawShape>(shape: T): z.ZodObject<T> => {\n  const strict = process.env.SPECKIT_STRICT_SCHEMAS !== 'false';\n  const base = z.object(shape);\n  return strict ? base.strict() : base.passthrough();\n};\n\n/* ───────────────────────────────────────────────────────────────\n   4. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\n// Guard against safeNumericPreprocess.pipe(z.number()) coercing \"\", null, and false to 0.\n// Use a safe preprocessor that only accepts actual numbers or numeric strings.\nconst safeNumericPreprocess = z.preprocess((val) => {\n  if (typeof val === 'number') return val;\n  if (typeof val === 'string' && val.trim().length > 0) {\n    const parsed = Number(val);\n    return Number.isFinite(parsed) ? parsed : val;\n  }\n  return val;\n}, z.number());\n\nconst intRange = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().int().min(min).max(max));\nconst positiveInt = safeNumericPreprocess.pipe(z.number().int().positive());\nconst positiveIntMax = (max: number) => intRange(1, max);\nconst boundedNumber = (min: number, max: number) => safeNumericPreprocess.pipe(z.number().min(min).max(max));\nconst optionalStringArray = z.array(z.string()).optional();\n\nconst PATH_TRAVERSAL_MESSAGE = 'Path must not contain traversal sequences';\nconst isSafePath = (value: string): boolean => !value.includes('..') && !value.includes('\\0');\nconst pathString = (minLength = 0) => {\n  let schema = z.string();\n  if (minLength > 0) {\n    schema = schema.min(minLength);\n  }\n  return schema.refine(isSafePath, { message: PATH_TRAVERSAL_MESSAGE });\n};\nconst optionalPathString = (minLength = 0) => pathString(minLength).optional();\n\n/** Shared max paths constant — used by both schema and handler. */\nexport const MAX_INGEST_PATHS = 50;\nexport const MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS = 1;\nexport const RESERVED_FEEDBACK_TYPE_ERROR_CODE = 'E_RESERVED_FEEDBACK_TYPE';\n","lineStart":1,"lineEnd":70,"totalLines":801,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/schemas/tool-input-schemas.ts","time":{"start":1781145155566,"end":1781145155572}},"metadata":{"openai":{"itemId":"fc_0a8b9d197b207855016a2a1e4256408191b9a0cb72f0c057d9"}},"id":"prt_eb48633300014HekKyCzlcbOh2","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb486288a001sWiztcEpnQbnWU"}}
