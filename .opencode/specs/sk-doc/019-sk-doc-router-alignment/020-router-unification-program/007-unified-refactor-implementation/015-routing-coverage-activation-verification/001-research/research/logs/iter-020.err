  1309	        await shutdownModelServerForLauncherExit();
  1310	        if (childProcess && !childProcess.killed) {
  1311	          childProcess.kill(signal);
  1312	          const exited = await waitForChildExit(childProcess, 5000);
  1313	          if (!exited && isChildRunning(childProcess)) {
  1314	            childProcess.kill('SIGKILL');
  1315	          }
  1316	        }
  1317	        clearAllLeaseFiles();
  1318	        process.exit(128);
  1319	      })().catch((error) => {
  1320	        log(`signal shutdown failed: ${error.message}`);
  1321	        debug(error.stack || error.message);
  1322	        clearAllLeaseFiles();
  1323	        process.exit(128);
  1324	      });
  1325	    });
  1326	  }
  1327	  process.on('uncaughtException', (err) => {
  1328	    try {
  1329	      clearAllLeaseFiles();
  1330	    } catch {
  1331	      // Preserve default uncaughtException crash behavior.
  1332	    }
  1333	    throw err;
  1334	  });
  1335	}
