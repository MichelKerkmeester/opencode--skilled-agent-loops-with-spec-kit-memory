   130	
   131	# Template directories with intentionally minimal placeholder READMEs
   132	TEMPLATE_PATTERNS = [
   133	    'system-spec-kit/templates/',  # Spec folder templates are minimal by design
   134	]
   135	
   136	# Specialized leaf-doc root dir names. Both the hyphen and underscore forms are
   137	# accepted while the naming migration is in flight; the shared resolver is the
   138	# single source of truth so this validator and the guards never diverge on which
   139	# root names are recognized. Fall back to local copies so the validator still runs
   140	# standalone if the sibling cannot be imported.
   141	sys.path.insert(0, str(Path(__file__).resolve().parent))
   142	from naming_root_resolver import (  # type: ignore
   143	    PLAYBOOK_ROOT_NAMES as PLAYBOOK_DIR_NAMES,
   144	    CATALOG_ROOT_NAMES as CATALOG_DIR_NAMES,
   145	    assert_supported_root_path,
