   231	async function callAdvisorTool(name, args, workspaceRoot) {
   232	  const transport = new StdioClientTransport({
   233	    command: process.execPath,
   234	    args: [ADVISOR_LAUNCHER_PATH],
   235	    cwd: workspaceRoot,
   236	      env: createChildEnv(),
   237	    stderr: 'pipe',
   238	  });
   239	  transport.stderr?.on('data', () => {});
   240	  const client = new Client({ name: 'mk-skill-advisor-bridge', version: '0.1.0' });
   241	  try {
   242	    await withTimeout(client.connect(transport), ADVISOR_MCP_TIMEOUT_MS, 'mk_skill_advisor initialize');
   243	    return await withTimeout(
   244	      client.callTool({ name, arguments: args }),
   245	      ADVISOR_MCP_TIMEOUT_MS,
   246	      `mk_skill_advisor.${name}`,
   247	    );
   248	  } finally {
   249	    try {
   250	      await client.close();
   251	    } catch {
   252	      // Best-effort process cleanup; bridge callers still get fail-open output.
   253	    }
   254	  }
   255	}
   256	
   257	function parseAdvisorToolData(toolResponse) {
   258	  const first = Array.isArray(toolResponse?.content) ? toolResponse.content[0] : null;
   259	  if (typeof first?.text !== 'string') {
   260	    throw Object.assign(new Error('Advisor MCP response missing text content'), { code: 'ADVISOR_MCP_BAD_RESPONSE' });
   261	  }
   262	  const parsed = JSON.parse(first.text);
   263	  return parsed?.data ?? parsed;
   264	}
