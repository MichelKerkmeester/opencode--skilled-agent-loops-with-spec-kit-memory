ength !== 1 || !AUTHORED_FILENAMES.has(basename)) {\n33:     throw new Error(`Authored output must use ${[...AUTHORED_FILENAMES].join(\" or \")}.`);\n34:   }\n35: \n36:   return basename;\n37: }\n38: \n39: export function validateAuthoredBrand(brand) {\n40:   if (!isRecord(brand) || typeof brand.sourceDescription !== \"string\" || brand.sourceDescription.trim() === \"\") {\n41:     throw new TypeError(\"Authored brand requires a non-empty sourceDescription.\");\n42:   }\n43: \n44:   for (const domain of REQUIRED_DOMAINS) {\n45:     const values = brand[domain];\n46:     if (!Array.isArray(values) || values.length === 0) {\n47:       throw new TypeError(`Authored brand requires at least one ${domain} value.`);\n48:     }\n49:     for (const value of values) {\n50:       validateAuthoredValue(value, domain, brand.sourceDescription);\n51:     }\n52:   }\n53: \n54:   return brand;\n55: }\n56: \n57: export async function writeAuthoredArtifact(rootDirectory, artifactPath, content) {\n58:   const filename = assertAuthoredDestination(artifactPath);\n59:   if (typeof rootDirectory !== \"string\" || rootDirectory.length === 0) {\n60:     throw new TypeError(\"A root directory is required.\");\n61:   }\n62:   if (typeof content !== \"string\") {\n63:     throw new TypeError(\"Authored artifact content must be a string.\");\n64:   }\n65: \n66:   const root = path.resolve(rootDirectory);\n67:   const destination = path.resolve(root, filename);\n68:   if (path.dirname(destination) !== root) {\n69:     throw new Error(\"Authored output escaped its root directory.\");\n70:   }\n71: \n72:   await writeFile(destination, content, \"utf8\");\n73:   return destination;\n74: }\n75: \n76: export async function refreshAuthoredExports({ rootDirectory, renderedDesign, authoredBrand }) {\n77:   validateAuthoredBrand(authoredBrand);\n78:   if (\n79:     typeof renderedDesign !== \"string\" ||\n80:     !/(?:^|\\r?\\n)[ \\t]*origin:[ \\t]*authored[ \\t]*(?:\\r?\\n|$)/.test(renderedDesign)\n81:   ) {\n82:     throw new Error(`${AUTHORED_DESIGN_FILENAME} must declare origin: authored.`);\n83:   }\n84: \n85:   const tokenDocument = `${JSON.stringify({\n86:     schema: \"sk-design/authored-brand/v1\",\n87:     sourceDescription: authoredBrand.sourceDescription,\n88:     palette: authoredBrand.palette,\n89:     type: authoredBrand.type,\n90:     voice: authoredBrand.voice\n91:   }, null, 2)}\\n`;\n92: \n93:   return Promise.all([\n94:     writeAuthoredArtifact(rootDirectory, AUTHORED_DESIGN_FILENAME, renderedDesign),\n95:     writeAuthoredArtifact(rootDirectory, AUTHORED_TOKENS_FILENAME, tokenDocument)\n96:   ]);\n97: }\n98: \n99: export function assertReviewedConversionArtifact(reviewArtifact) {\n100:   if (!isRecord(reviewArtifact) || reviewArtifact.artifactType !== \"reviewed-conversion\") {\n101:     throw new TypeError(\"A reviewed-conversion checklist artifact is required.\");\n102:   }\n103:   if (containsKey(reviewArtifact, \"verified\")) {\n104:     throw new Error(\"Evidence-free verified flags cannot authorize conversion.\");\n105:   }\n106:   for (const field of [\"reviewerName\", \"reviewerRole\", \"reviewedAt\", \"reviewerSignature\"]) {\n107:     if (typeof reviewArtifact[field] !== \"string\" || reviewArtifact[field].trim() === \"\") {\n108:       throw new TypeError(`Reviewed conversion requires ${field}.`);\n109:     }\n110:   }\n111:   if (reviewArtifact.reviewerSignature !== reviewArtifact.reviewerName) {\n112:     throw new Error(\"Reviewer signature must match the named human reviewer.\");\n113:   }\n114:   if (reviewArtifact.sourceArtifact !== AUTHORED_DESIGN_FILENAME) {\n115:     throw new Error(`Reviewed conversion source must be ${AUTHORED_DESIGN_FILENAME}.`);\n116:   }\n117:   if (!Array.isArray(reviewArtifact.attestations)) {\n118:     throw new TypeError(\"Reviewed conversion requires manual attestations.\");\n119:   }\n120:   for (const attestation of REQUIRED_ATTESTATIONS) {\n121:     if (!reviewArtifact.attestations.includes(attestation)) {\n122:       throw new Error(`Reviewed conversion is missing attestation: ${attestation}`);\n123:     }\n124:   }\n125:   if (!Array.isArray(reviewArtifact.selections) || reviewArtifact.selections.length === 0) {\n126:     throw new TypeError(\"Reviewed conversion requires at least one reviewed selection.\");\n127:   }\n128:   for (const selection of reviewArtifact.selections) {\n129:     validateReviewedSelection(selection);\n130:   }\n131: \n132:   return reviewArtifact;\n133: }\n134: \n135: function validateAuthoredValue(record, domain, sourceDescription) {\n136:   if (!isRecord(record) || typeof record.id !== \"string\" || record.id.trim() === \"\") {\n137:     throw new TypeError(`Every ${domain} value requires an id.`);\n138:   }\n139:   if (!Object.hasOwn(record, \"value\")) {\n140:     throw new TypeError(`Authored value ${record.id} requires a value.`);\n141:   }\n142:   if (record.origin !== \"authored\") {\n143:     throw new Error(`Authored value ${record.id} must declare origin: authored.`);\n144:   }\n145:   if (!isRecord(record.provenance)) {\n146:     throw new TypeError(`Authored value ${record.id} requires provenance.`);\n147:   }\n148:   if (record.provenance.sourceDescription !== sourceDescription) {\n149:     throw new Error(`Authored value ${record.id} must retain the source description.`);\n150:   }\n151:   if (!/^\\d{4}-\\d{2}-\\d{2}$/.test(record.provenance.authoredAt ?? \"\")) {\n152:     throw new Error(`Authored value ${record.id} requires an authoredAt date.`);\n153:   }\n154:   if (typeof record.provenance.confidenceNote !== \"string\" || record.provenance.confidenceNote.trim() === \"\") {\n155:     throw new Error(`Authored value ${record.id} requires a confidence note.`);\n156:   }\n157: }\n158: \n159: function validateReviewedSelection(selection) {\n160:   if (!isRecord(selection)) {\n161:     throw new TypeError(\"Reviewed selections must be objects.\");\n162:   }\n163:   if (typeof selection.authoredValueId !== \"string\" || selection.authoredValueId.trim() === \"\") {\n164:     throw new TypeError(\"Reviewed selection requires authoredValueId.\");\n165:   }\n166:   if (!MEASURED_TARGETS.has(selection.targetArtifact)) {\n167:     throw new Error(`Unsupported measured target: ${selection.targetArtifact}`);\n168:   }\n169:   if (selection.decision !== \"approved\") {\n170:     throw new Error(`Reviewed selection ${selection.authoredValueId} is not approved.`);\n171:   }\n172:   if (!Array.isArray(selection.measurementEvidence) || selection.measurementEvidence.length === 0) {\n173:     throw new Error(`Reviewed selection ${selection.authoredValueId} requires measurement evidence.`);\n174:   }\n175:   if (selection.measurementEvidence.some((evidence) => typeof evidence !== \"string\" || evidence.trim() === \"\")) {\n176:     throw new Error(`Reviewed selection ${selection.authoredValueId} contains empty evidence.`);\n177:   }\n178: }\n179: \n180: function containsKey(value, key) {\n181:   if (Array.isArray(value)) {\n182:     return value.some((item) => containsKey(item, key));\n183:   }\n184:   if (!isRecord(value)) {\n185:     return false;\n186:   }\n187:   return Object.hasOwn(value, key) || Object.values(value).some((item) => containsKey(item, key));\n188: }\n189: \n190: function isRecord(value) {\n191:   return value !== null && typeof value === \"object\" && !Array.isArray(value);\n192: }\n\n(End of file - total 192 lines)\n</content>","metadata":{"preview":"import { writeFile } from \"node:fs/promises\";\nimport path from \"node:path\";\n\nexport const AUTHORED_DESIGN_FILENAME = \"AUTHORED-DESIGN.md\";\nexport const AUTHORED_TOKENS_FILENAME = \"authored-tokens.json\";\n\nconst AUTHORED_FILENAMES = new Set([\n  AUTHORED_DESIGN_FILENAME,\n  AUTHORED_TOKENS_FILENAME\n]);\nconst MEASURED_TARGETS = new Set([\"DESIGN.md\", \"tokens.json\", \"styles\"]);\nconst REQUIRED_DOMAINS = [\"palette\", \"type\", \"voice\"];\nconst REQUIRED_ATTESTATIONS = [\n  \"source-provenance-reviewed\",\n  \"measurement-evidence-reviewed\",\n  \"target-conflicts-reviewed\",\n  \"manual-approval-recorded\"\n];\n\nexport function assertAuthoredDestination(artifactPath) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0101-system-deep-loop-deep-alignment-multi-executor/.opencode/skills/sk-design/shared/authored-brand/authored-brand-boundary.mjs","text":"import { writeFile } from \"node:fs/promises\";\nimport path from \"node:path\";\n\nexport const AUTHORED_DESIGN_FILENAME = \"AUTHORED-DESIGN.md\";\nexport const AUTHORED_TOKENS_FILENAME = \"authored-tokens.json\";\n\nconst AUTHORED_FILENAMES = new Set([\n  AUTHORED_DESIGN_FILENAME,\n  AUTHORED_TOKENS_FILENAME\n]);\nconst MEASURED_TARGETS = new Set([\"DESIGN.md\", \"tokens.json\", \"styles\"]);\nconst REQUIRED_DOMAINS = [\"palette\", \"type\", \"voice\"];\nconst REQUIRED_ATTESTATIONS = [\n  \"source-provenance-reviewed\",\n  \"measurement-evidence-reviewed\",\n  \"target-conflicts-reviewed\",\n  \"manual-approval-recorded\"\n];\n\nexport function assertAuthoredDestination(artifactPath) {\n  if (typeof artifactPath !== \"string\" || artifactPath.length === 0) {\n    throw new TypeError(\"An authored artifact path is required.\");\n  }\n\n  const normalized = artifactPath.replaceAll(\"\\\\\", \"/\");\n  const segments = normalized.split(\"/\").filter(Boolean);\n  const basename = segments.at(-1);\n\n  if (MEASURED_TARGETS.has(basename) || segments.includes(\"styles\")) {\n    throw new Error(`Authored output refuses measured destination: ${artifactPath}`);\n  }\n  if (segments.length !== 1 || !AUTHORED_FILENAMES.has(basename)) {\n    throw new Error(`Authored output must use ${[...AUTHORED_FILENAMES].join(\" or \")}.`);\n  }\n\n  return basename;\n}\n\nexport function validateAuthoredBrand(brand) {\n  if (!isRecord(brand) || typeof brand.sourceDescription !== \"string\" || brand.sourceDescription.trim() === \"\") {\n    throw new TypeError(\"Authored brand requires a non-empty sourceDescription.\");\n  }\n\n  for (const domain of REQUIRED_DOMAINS) {\n    const values = brand[domain];\n    if (!Array.isArray(values) || values.length === 0) {\n      throw new TypeError(`Authored brand requires at least one ${domain} value.`);\n    }\n    for (const value of values) {\n      validateAuthoredValue(value, domain, brand.sourceDescription);\n    }\n  }\n\n  return brand;\n}\n\nexport async function writeAuthoredArtifact(rootDirectory, artifactPath, content) {\n  const filename = assertAuthoredDestination(artifactPath);\n  if (typeof rootDirectory !== \"string\" || rootDirectory.length === 0) {\n    throw new TypeError(\"A root directory is required.\");\n  }\n  if (typeof content !== \"string\") {\n    throw new TypeError(\"Authored artifact content must be a string.\");\n  }\n\n  const root = path.resolve(rootDirectory);\n  const destination = path.resolve(root, filename);\n  if (path.dirname(destination) !== root) {\n    throw new Error(\"Authored output escaped its root directory.\");\n  }\n\n  await writeFile(destination, content, \"utf8\");\n  return destination;\n}\n\nexport async function refreshAuthoredExports({ rootDirectory, renderedDesign, authoredBrand }) {\n  validateAuthoredBrand(authoredBrand);\n  if (\n    typeof renderedDesign !== \"string\" ||\n    !/(?:^|\\r?\\n)[ \\t]*origin:[ \\t]*authored[ \\t]*(?:\\r?\\n|$)/.test(renderedDesign)\n  ) {\n    throw new Error(`${AUTHORED_DESIGN_FILENAME} must declare origin: authored.`);\n  }\n\n  const tokenDocument = `${JSON.stringify({\n    schema: \"sk-design/authored-brand/v1\",\n    sourceDescription: authoredBrand.sourceDescription,\n    palette: authoredBrand.palette,\n    type: authoredBrand.type,\n    voice: authoredBrand.voice\n  }, null, 2)}\\n`;\n\n  return Promise.all([\n    writeAuthoredArtifact(rootDirectory, AUTHORED_DESIGN_FILENAME, renderedDesign),\n    writeAuthoredArtifact(rootDirectory, AUTHORED_TOKENS_FILENAME, tokenDocument)\n  ]);\n}\n\nexport function assertReviewedConversionArtifact(reviewArtifact) {\n  if (!isRecord(reviewArtifact) || reviewArtifact.artifactType !== \"reviewed-conversion\") {\n    throw new TypeError(\"A reviewed-conversion checklist artifact is required.\");\n  }\n  if (containsKey(reviewArtifact, \"verified\")) {\n    throw new Error(\"Evidence-free verified flags cannot authorize conversion.\");\n  }\n  for (const field of [\"reviewerName\", \"reviewerRole\", \"reviewedAt\", \"reviewerSignature\"]) {\n    if (typeof reviewArtifact[field] !== \"string\" || reviewArtifact[field].trim() === \"\") {\n      throw new TypeError(`Reviewed conversion requires ${field}.`);\n    }\n  }\n  if (reviewArtifact.reviewerSignature !== reviewArtifact.reviewerName) {\n    throw new Error(\"Reviewer signature must match the named human reviewer.\");\n  }\n  if (reviewArtifact.sourceArtifact !== AUTHORED_DESIGN_FILENAME) {\n    throw new Error(`Reviewed conversion source must be ${AUTHORED_DESIGN_FILENAME}.`);\n  }\n  if (!Array.isArray(reviewArtifact.attestations)) {\n    throw new TypeError(\"Reviewed conversion requires manual attestations.\");\n  }\n  for (const attestation of REQUIRED_ATTESTATIONS) {\n    if (!reviewArtifact.attestations.includes(attestation)) {\n      throw new Error(`Reviewed conversion is missing attestation: ${attestation}`);\n    }\n  }\n  if (!Array.isArray(reviewArtifact.selections) || reviewArtifact.selections.length === 0) {\n    throw new TypeError(\"Reviewed conversion requires at least one reviewed selection.\");\n  }\n  for (const selection of reviewArtifact.selections) {\n    validateReviewedSelection(selection);\n  }\n\n  return reviewArtifact;\n}\n\nfunction validateAuthoredValue(record, domain, sourceDescription) {\n  if (!isRecord(record) || typeof record.id !== \"string\" || record.id.trim() === \"\") {\n    throw new TypeError(`Every ${domain} value requires an id.`);\n  }\n  if (!Object.hasOwn(record, \"value\")) {\n    throw new TypeError(`Authored value ${record.id} requires a value.`);\n  }\n  if (record.origin !== \"authored\") {\n    throw new Error(`Authored value ${record.id} must declare origin: authored.`);\n  }\n  if (!isRecord(record.provenance)) {\n    throw new TypeError(`Authored value ${record.id} requires provenance.`);\n  }\n  if (record.provenance.sourceDescription !== sourceDescription) {\n    throw new Error(`Authored value ${record.id} must retain the source description.`);\n  }\n  if (!/^\\d{4}-\\d{2}-\\d{2}$/.test(record.provenance.authoredAt ?? \"\")) {\n    throw new Error(`Authored value ${record.id} requires an authoredAt date.`);\n  }\n  if (typeof record.provenance.confidenceNote !== \"string\" || record.provenance.confidenceNote.trim() === \"\") {\n    throw new Error(`Authored value ${record.id} requires a confidence note.`);\n  }\n}\n\nfunction validateReviewedSelection(selection) {\n  if (!isRecord(selection)) {\n    throw new TypeError(\"Reviewed selections must be objects.\");\n  }\n  if (typeof selection.authoredValueId !== \"string\" || selection.authoredValueId.trim() === \"\") {\n    throw new TypeError(\"Reviewed selection requires authoredValueId.\");\n  }\n  if (!MEASURED_TARGETS.has(selection.targetArtifact)) {\n    throw new Error(`Unsupported measured target: ${selection.targetArtifact}`);\n  }\n  if (selection.decision !== \"approved\") {\n    throw new Error(`Reviewed selection ${selection.authoredValueId} is not approved.`);\n  }\n  if (!Array.isArray(selection.measurementEvidence) || selection.measurementEvidence.length === 0) {\n    throw new Error(`Reviewed selection ${selection.authoredValueId} requires measurement evidence.`);\n  }\n  if (selection.measurementEvidence.some((evidence) => typeof evidence !== \"string\" || evidence.trim() === \"\")) {\n    throw new Error(`Reviewed selection ${selection.authoredValueId} contains empty evidence.`);\n  }\n}\n\nfunction containsKey(value, key) {\n  if (Array.isArray(value)) {\n    return value.some((item) => containsKey(item, key));\n  }\n  if (!isRecord(value)) {\n    return false;\n  }\n  return Object.hasOwn(value, key) || Object.values(value).some((item) => containsKey(item, key));\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === \"object\" && !Array.isArray(value);\n}","lineStart":1,"lineEnd":192,"totalLines":192,"truncated":false}},"title":".opencode/skills/sk-design/shared/authored-brand/authored-brand-boundary.mjs","time":{"start":1784786470969,"end":1784786470974}},"id":"prt_f8d904837001D3ObcAkeeXiCmN","sessionID":"ses_07275e3edffeaO0otv0k6f0Vff","messageID":"msg_f8d8fef3e001CZoqJpM1P8w597"}}
