{"type":"tool_use","timestamp":1784606352018,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_00_V4cVmbGTFbSGCo6adqg92581","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/schema.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/schema.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Persistent Style Database Schema                                         ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import { DatabaseSync } from 'node:sqlite';\n6: import path from 'node:path';\n7: import { fileURLToPath } from 'node:url';\n8: \n9: import { resolvePublishedTarget } from './generation-manifest.mjs';\n10: \n11: export const STYLE_DB_SCHEMA_VERSION = 2;\n12: export const DEFAULT_STYLE_DATABASE_PATH = path.join(\n13:   path.dirname(fileURLToPath(import.meta.url)),\n14:   'style-library.sqlite',\n15: );\n16: export const STYLE_DATABASE_POINTER_SUFFIX = '.current.json';\n17: \n18: // The published pointer is a versioned multi-artifact manifest; legacy\n19: // single-file pointers still resolve. Manifest ownership lives in\n20: // generation-manifest.mjs so publish and resolve share one shape contract.\n21: function resolvePublishedDatabaseTarget(databasePath) {\n22:   return resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n23: }\n24: \n25: /**\n26:  * Resolve the immutable generation selected by an atomic pointer file.\n27:  *\n28:  * @param {string} [databasePath] - Logical database path.\n29:  * @returns {string} Published generation path, or the direct path for legacy databases.\n30:  */\n31: export function resolvePublishedDatabasePath(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n32:   return resolvePublishedDatabaseTarget(databasePath).databasePath;\n33: }\n34: \n35: const SCHEMA_SQL = `\n36:   CREATE TABLE IF NOT EXISTS style_db_metadata (\n37:     key TEXT PRIMARY KEY,\n38:     value TEXT NOT NULL\n39:   ) STRICT;\n40: \n41:   CREATE TABLE IF NOT EXISTS styles (\n42:     style_rowid INTEGER PRIMARY KEY,\n43:     style_id TEXT NOT NULL UNIQUE,\n44:     slug TEXT NOT NULL UNIQUE,\n45:     lifecycle_state TEXT NOT NULL DEFAULT 'active'\n46:       CHECK (lifecycle_state IN ('active', 'quarantined', 'tombstoned')),\n47:     crawl_status TEXT NOT NULL,\n48:     title TEXT NOT NULL,\n49:     thesis TEXT NOT NULL,\n50:     theme TEXT,\n51:     industry TEXT,\n52:     aggregate_hash TEXT NOT NULL,\n53:     retrieval_hash TEXT NOT NULL,\n54:     quarantine_at TEXT,\n55:     tombstoned_at TEXT,\n56:     created_at TEXT NOT NULL,\n57:     updated_at TEXT NOT NULL,\n58:     CHECK (\n59:       (lifecycle_state = 'active' AND quarantine_at IS NULL AND tombstoned_at IS NULL)\n60:       OR (lifecycle_state = 'quarantined' AND quarantine_at IS NOT NULL AND tombstoned_at IS NULL)\n61:       OR (lifecycle_state = 'tombstoned' AND quarantine_at IS NOT NULL AND tombstoned_at IS NOT NULL)\n62:     )\n63:   ) STRICT;\n64: \n65:   CREATE TABLE IF NOT EXISTS style_provenance (\n66:     style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n67:     status TEXT NOT NULL CHECK (status IN ('known', 'missing')),\n68:     source_url TEXT,\n69:     original_url TEXT,\n70:     screenshot_url TEXT,\n71:     source_uuid TEXT,\n72:     captured_at TEXT,\n73:     license_status TEXT NOT NULL,\n74:     rights_known INTEGER NOT NULL CHECK (rights_known IN (0, 1)),\n75:     evidence_scope_json TEXT NOT NULL\n76:   ) STRICT;\n77: \n78:   CREATE TABLE IF NOT EXISTS style_artifacts (\n79:     artifact_id INTEGER PRIMARY KEY,\n80:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n81:     role TEXT NOT NULL CHECK (role IN (\n82:       'canonical', 'tokens', 'design', 'source', 'css-variables', 'tailwind'\n83:     )),\n84:     relative_path TEXT NOT NULL,\n85:     byte_length INTEGER NOT NULL CHECK (byte_length >= 0),\n86:     sha256 TEXT NOT NULL,\n87:     mtime_ns TEXT NOT NULL,\n88:     ctime_ns TEXT NOT NULL,\n89:     UNIQUE (style_rowid, role),\n90:     UNIQUE (style_rowid, relative_path)\n91:   ) STRICT;\n92: \n93:   CREATE TABLE IF NOT EXISTS style_terms (\n94:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n95:     term_type TEXT NOT NULL CHECK (term_type IN ('facet', 'capability')),\n96:     term TEXT NOT NULL,\n97:     PRIMARY KEY (style_rowid, term_type, term)\n98:   ) WITHOUT ROWID, STRICT;\n99: \n100:   CREATE TABLE IF NOT EXISTS style_token_axes (\n101:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n102:     axis TEXT NOT NULL,\n103:     token_count INTEGER NOT NULL CHECK (token_count >= 0),\n104:     PRIMARY KEY (style_rowid, axis)\n105:   ) WITHOUT ROWID, STRICT;\n106: \n107:   CREATE TABLE IF NOT EXISTS style_sections (\n108:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n109:     ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n110:     name TEXT NOT NULL,\n111:     line_number INTEGER NOT NULL CHECK (line_number > 0),\n112:     PRIMARY KEY (style_rowid, ordinal)\n113:   ) WITHOUT ROWID, STRICT;\n114: \n115:   CREATE TABLE IF NOT EXISTS retrieval_documents (\n116:     style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n117:     title TEXT NOT NULL,\n118:     thesis TEXT NOT NULL,\n119:     theme TEXT NOT NULL,\n120:     industry TEXT NOT NULL,\n121:     terms TEXT NOT NULL,\n122:     body TEXT NOT NULL,\n123:     document_json TEXT NOT NULL,\n124:     retrieval_hash TEXT NOT NULL\n125:   ) STRICT;\n126: \n127:   CREATE VIRTUAL TABLE IF NOT EXISTS style_fts USING fts5(\n128:     title, thesis, theme, industry, terms, body,\n129:     content='retrieval_documents', content_rowid='style_rowid'\n130:   );\n131: \n132:   CREATE TRIGGER IF NOT EXISTS style_fts_insert\n133:   AFTER INSERT ON retrieval_documents BEGIN\n134:     INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n135:     VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n136:       new.terms, new.body);\n137:   END;\n138: \n139:   CREATE TRIGGER IF NOT EXISTS style_fts_update\n140:   AFTER UPDATE ON retrieval_documents BEGIN\n141:     INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n142:     VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n143:       old.industry, old.terms, old.body);\n144:     INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n145:     VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n146:       new.terms, new.body);\n147:   END;\n148: \n149:   CREATE TRIGGER IF NOT EXISTS style_fts_delete\n150:   AFTER DELETE ON retrieval_documents BEGIN\n151:     INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n152:     VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n153:       old.industry, old.terms, old.body);\n154:   END;\n155: \n156:   CREATE TABLE IF NOT EXISTS embedding_profiles (\n157:     profile_id TEXT PRIMARY KEY,\n158:     provider TEXT NOT NULL,\n159:     model TEXT NOT NULL,\n160:     dimensions INTEGER CHECK (dimensions IS NULL OR dimensions > 0),\n161:     config_hash TEXT NOT NULL,\n162:     created_at TEXT NOT NULL\n163:   ) STRICT;\n164: \n165:   CREATE TABLE IF NOT EXISTS embedding_cache (\n166:     retrieval_hash TEXT NOT NULL,\n167:     profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n168:     dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n169:     vector_json TEXT NOT NULL,\n170:     created_at TEXT NOT NULL,\n171:     PRIMARY KEY (retrieval_hash, profile_id)\n172:   ) WITHOUT ROWID, STRICT;\n173: \n174:   CREATE TABLE IF NOT EXISTS style_vector_jobs (\n175:     job_id INTEGER PRIMARY KEY,\n176:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n177:     retrieval_hash TEXT NOT NULL,\n178:     profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n179:     status TEXT NOT NULL DEFAULT 'pending'\n180:       CHECK (status IN ('pending', 'running', 'completed', 'failed', 'superseded')),\n181:     attempts INTEGER NOT NULL DEFAULT 0 CHECK (attempts >= 0),\n182:     next_attempt_at TEXT,\n183:     last_error TEXT,\n184:     created_at TEXT NOT NULL,\n185:     updated_at TEXT NOT NULL,\n186:     UNIQUE (style_rowid, retrieval_hash, profile_id)\n187:   ) STRICT;\n188: \n189:   CREATE TABLE IF NOT EXISTS style_vectors (\n190:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n191:     retrieval_hash TEXT NOT NULL,\n192:     profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n193:     dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n194:     vector_json TEXT NOT NULL,\n195:     created_at TEXT NOT NULL,\n196:     PRIMARY KEY (style_rowid, profile_id)\n197:   ) WITHOUT ROWID, STRICT;\n198: \n199:   CREATE TABLE IF NOT EXISTS style_relationships (\n200:     relationship_id INTEGER PRIMARY KEY,\n201:     source_style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n202:     ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n203:     raw_target_label TEXT NOT NULL,\n204:     target_style_rowid INTEGER REFERENCES styles(style_rowid) ON DELETE SET NULL,\n205:     rationale TEXT NOT NULL,\n206:     resolution_state TEXT NOT NULL\n207:       CHECK (resolution_state IN ('resolved', 'ambiguous', 'unresolved')),\n208:     confidence REAL NOT NULL CHECK (confidence >= 0 AND confidence <= 1),\n209:     UNIQUE (source_style_rowid, ordinal)\n210:   ) STRICT;\n211: \n212:   CREATE TABLE IF NOT EXISTS style_index_state (\n213:     style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n214:     artifact_hint_hash TEXT NOT NULL,\n215:     crawl_record_hash TEXT NOT NULL,\n216:     aggregate_hash TEXT NOT NULL,\n217:     last_success_generation TEXT NOT NULL,\n218:     last_success_at TEXT NOT NULL,\n219:     missing_observations INTEGER NOT NULL DEFAULT 0 CHECK (missing_observations >= 0)\n220:   ) STRICT;\n221: \n222:   CREATE TABLE IF NOT EXISTS corpus_generations (\n223:     generation_hash TEXT PRIMARY KEY,\n224:     parent_generation_hash TEXT REFERENCES corpus_generations(generation_hash),\n225:     crawl_manifest_hash TEXT NOT NULL,\n226:     aggregate_corpus_hash TEXT NOT NULL,\n227:     schema_version INTEGER NOT NULL,\n228:     active_style_count INTEGER NOT NULL CHECK (active_style_count >= 0),\n229:     quarantined_style_count INTEGER NOT NULL CHECK (quarantined_style_count >= 0),\n230:     tombstoned_style_count INTEGER NOT NULL CHECK (tombstoned_style_count >= 0),\n231:     created_at TEXT NOT NULL\n232:   ) STRICT;\n233: \n234:   CREATE TABLE IF NOT EXISTS current_corpus_generation (\n235:     singleton INTEGER PRIMARY KEY CHECK (singleton = 1),\n236:     generation_hash TEXT NOT NULL REFERENCES corpus_generations(generation_hash),\n237:     published_at TEXT NOT NULL\n238:   ) STRICT;\n239: \n240:   CREATE TABLE IF NOT EXISTS vector_projection_revisions (\n241:     profile_id TEXT PRIMARY KEY REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n242:     revision INTEGER NOT NULL DEFAULT 0 CHECK (revision >= 0),\n243:     updated_at TEXT NOT NULL\n244:   ) STRICT;\n245: \n246:   CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_update\n247:   BEFORE UPDATE ON corpus_generations BEGIN\n248:     SELECT RAISE(ABORT, 'corpus generations are immutable');\n249:   END;\n250: \n251:   CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_delete\n252:   BEFORE DELETE ON corpus_generations BEGIN\n253:     SELECT RAISE(ABORT, 'corpus generations are immutable');\n254:   END;\n255: \n256:   CREATE INDEX IF NOT EXISTS idx_styles_active_theme\n257:     ON styles(theme, style_id) WHERE lifecycle_state = 'active';\n258:   CREATE INDEX IF NOT EXISTS idx_styles_lifecycle ON styles(lifecycle_state, style_id);\n259:   CREATE INDEX IF NOT EXISTS idx_style_terms_lookup ON style_terms(term_type, term, style_rowid);\n260:   CREATE INDEX IF NOT EXISTS idx_style_axes_lookup ON style_token_axes(axis, style_rowid);\n261:   CREATE INDEX IF NOT EXISTS idx_style_artifacts_path ON style_artifacts(relative_path);\n262:   CREATE INDEX IF NOT EXISTS idx_style_vectors_profile ON style_vectors(profile_id, style_rowid);\n263:   CREATE INDEX IF NOT EXISTS idx_vector_jobs_drain\n264:     ON style_vector_jobs(status, next_attempt_at, job_id);\n265:   CREATE INDEX IF NOT EXISTS idx_relationships_source\n266:     ON style_relationships(source_style_rowid, resolution_state);\n267:   CREATE INDEX IF NOT EXISTS idx_relationships_target\n268:     ON style_relationships(target_style_rowid) WHERE target_style_rowid IS NOT NULL;\n269: `;\n270: \n271: /**\n272:  * Create or validate the current style database schema.\n273:  *\n274:  * @param {DatabaseSync} database - Open SQLite connection.\n275:  * @returns {DatabaseSync} The configured connection.\n276:  */\n277: export function createSchema(database) {\n278:   if (!(database instanceof DatabaseSync)) {\n279:     throw new TypeError('database must be a node:sqlite DatabaseSync instance.');\n280:   }\n281:   database.exec('PRAGMA foreign_keys = ON; PRAGMA busy_timeout = 5000;');\n282:   const currentVersion = Number(database.prepare('PRAGMA user_version').get().user_version);\n283:   if (currentVersion > STYLE_DB_SCHEMA_VERSION) {\n284:     throw new Error(`Style database schema ${currentVersion} is newer than supported version ${STYLE_DB_SCHEMA_VERSION}.`);\n285:   }\n286:   if (currentVersion === 1) {\n287:     const indexStateColumns = database.prepare(`\n288:       PRAGMA table_info(style_index_state)\n289:     `).all().map((column) => column.name);\n290:     if (!indexStateColumns.includes('crawl_record_hash')) {\n291:       database.exec('BEGIN IMMEDIATE');\n292:       try {\n293:         database.exec(`\n294:           ALTER TABLE style_index_state\n295:           ADD COLUMN crawl_record_hash TEXT NOT NULL DEFAULT 'legacy-unverified'\n296:         `);\n297:         database.exec('COMMIT');\n298:       } catch (error) {\n299:         database.exec('ROLLBACK');\n300:         throw error;\n301:       }\n302:     }\n303:   }\n304:   database.exec(SCHEMA_SQL);\n305:   const requiredIndexStateColumns = new Set([\n306:     'style_rowid',\n307:     'artifact_hint_hash',\n308:     'crawl_record_hash',\n309:     'aggregate_hash',\n310:     'last_success_generation',\n311:     'last_success_at',\n312:     'missing_observations',\n313:   ]);\n314:   const actualIndexStateColumns = new Set(database.prepare(`\n315:     PRAGMA table_info(style_index_state)\n316:   `).all().map((column) => column.name));\n317:   if ([...requiredIndexStateColumns].some((column) => !actualIndexStateColumns.has(column))) {\n318:     throw new Error('Style database index-state schema is incomplete after migration.');\n319:   }\n320:   database.prepare(`\n321:     INSERT INTO style_db_metadata(key, value) VALUES ('schema_version', ?)\n322:     ON CONFLICT(key) DO UPDATE SET value = excluded.value\n323:   `).run(String(STYLE_DB_SCHEMA_VERSION));\n324:   database.exec(`PRAGMA user_version = ${STYLE_DB_SCHEMA_VERSION};`);\n325:   return database;\n326: }\n327: \n328: /**\n329:  * Open a local style database with its versioned schema initialized.\n330:  *\n331:  * @param {string} [databasePath=':memory:'] - SQLite file path or in-memory marker.\n332:  * @returns {DatabaseSync} Ready database connection.\n333:  */\n334: export function openStyleDatabase(databasePath = ':memory:') {\n335:   const database = new DatabaseSync(databasePath);\n336:   if (databasePath !== ':memory:') database.exec('PRAGMA journal_mode = WAL;');\n337:   return createSchema(database);\n338: }\n339: \n340: /**\n341:  * Open the published generation and bind its internal identity to the pointer.\n342:  *\n343:  * @param {string} [databasePath] - Logical database path.\n344:  * @returns {DatabaseSync} Generation-bound database connection.\n345:  */\n346: export function openPublishedStyleDatabase(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n347:   const target = resolvePublishedDatabaseTarget(databasePath);\n348:   const database = openStyleDatabase(target.databasePath);\n349:   if (target.generationHash === null) return database;\n350:   const openedGeneration = database.prepare(`\n351:     SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n352:   `).get()?.generation_hash;\n353:   if (openedGeneration !== target.generationHash) {\n354:     database.close();\n355:     const error = new Error('Published database generation does not match its pointer.');\n356:     error.code = 'generation-pointer-mismatch';\n357:     throw error;\n358:   }\n359:   return database;\n360: }\n\n(End of file - total 360 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Schema                                         ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { DatabaseSync } from 'node:sqlite';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { resolvePublishedTarget } from './generation-manifest.mjs';\n\nexport const STYLE_DB_SCHEMA_VERSION = 2;\nexport const DEFAULT_STYLE_DATABASE_PATH = path.join(\n  path.dirname(fileURLToPath(import.meta.url)),\n  'style-library.sqlite',\n);\nexport const STYLE_DATABASE_POINTER_SUFFIX = '.current.json';\n\n// The published pointer is a versioned multi-artifact manifest; legacy\n// single-file pointers still resolve. Manifest ownership lives in\n// generation-manifest.mjs so publish and resolve share one shape contract.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/schema.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Schema                                         ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { DatabaseSync } from 'node:sqlite';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { resolvePublishedTarget } from './generation-manifest.mjs';\n\nexport const STYLE_DB_SCHEMA_VERSION = 2;\nexport const DEFAULT_STYLE_DATABASE_PATH = path.join(\n  path.dirname(fileURLToPath(import.meta.url)),\n  'style-library.sqlite',\n);\nexport const STYLE_DATABASE_POINTER_SUFFIX = '.current.json';\n\n// The published pointer is a versioned multi-artifact manifest; legacy\n// single-file pointers still resolve. Manifest ownership lives in\n// generation-manifest.mjs so publish and resolve share one shape contract.\nfunction resolvePublishedDatabaseTarget(databasePath) {\n  return resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n}\n\n/**\n * Resolve the immutable generation selected by an atomic pointer file.\n *\n * @param {string} [databasePath] - Logical database path.\n * @returns {string} Published generation path, or the direct path for legacy databases.\n */\nexport function resolvePublishedDatabasePath(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n  return resolvePublishedDatabaseTarget(databasePath).databasePath;\n}\n\nconst SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS style_db_metadata (\n    key TEXT PRIMARY KEY,\n    value TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS styles (\n    style_rowid INTEGER PRIMARY KEY,\n    style_id TEXT NOT NULL UNIQUE,\n    slug TEXT NOT NULL UNIQUE,\n    lifecycle_state TEXT NOT NULL DEFAULT 'active'\n      CHECK (lifecycle_state IN ('active', 'quarantined', 'tombstoned')),\n    crawl_status TEXT NOT NULL,\n    title TEXT NOT NULL,\n    thesis TEXT NOT NULL,\n    theme TEXT,\n    industry TEXT,\n    aggregate_hash TEXT NOT NULL,\n    retrieval_hash TEXT NOT NULL,\n    quarantine_at TEXT,\n    tombstoned_at TEXT,\n    created_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL,\n    CHECK (\n      (lifecycle_state = 'active' AND quarantine_at IS NULL AND tombstoned_at IS NULL)\n      OR (lifecycle_state = 'quarantined' AND quarantine_at IS NOT NULL AND tombstoned_at IS NULL)\n      OR (lifecycle_state = 'tombstoned' AND quarantine_at IS NOT NULL AND tombstoned_at IS NOT NULL)\n    )\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_provenance (\n    style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    status TEXT NOT NULL CHECK (status IN ('known', 'missing')),\n    source_url TEXT,\n    original_url TEXT,\n    screenshot_url TEXT,\n    source_uuid TEXT,\n    captured_at TEXT,\n    license_status TEXT NOT NULL,\n    rights_known INTEGER NOT NULL CHECK (rights_known IN (0, 1)),\n    evidence_scope_json TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_artifacts (\n    artifact_id INTEGER PRIMARY KEY,\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    role TEXT NOT NULL CHECK (role IN (\n      'canonical', 'tokens', 'design', 'source', 'css-variables', 'tailwind'\n    )),\n    relative_path TEXT NOT NULL,\n    byte_length INTEGER NOT NULL CHECK (byte_length >= 0),\n    sha256 TEXT NOT NULL,\n    mtime_ns TEXT NOT NULL,\n    ctime_ns TEXT NOT NULL,\n    UNIQUE (style_rowid, role),\n    UNIQUE (style_rowid, relative_path)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_terms (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    term_type TEXT NOT NULL CHECK (term_type IN ('facet', 'capability')),\n    term TEXT NOT NULL,\n    PRIMARY KEY (style_rowid, term_type, term)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_token_axes (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    axis TEXT NOT NULL,\n    token_count INTEGER NOT NULL CHECK (token_count >= 0),\n    PRIMARY KEY (style_rowid, axis)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_sections (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n    name TEXT NOT NULL,\n    line_number INTEGER NOT NULL CHECK (line_number > 0),\n    PRIMARY KEY (style_rowid, ordinal)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS retrieval_documents (\n    style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    title TEXT NOT NULL,\n    thesis TEXT NOT NULL,\n    theme TEXT NOT NULL,\n    industry TEXT NOT NULL,\n    terms TEXT NOT NULL,\n    body TEXT NOT NULL,\n    document_json TEXT NOT NULL,\n    retrieval_hash TEXT NOT NULL\n  ) STRICT;\n\n  CREATE VIRTUAL TABLE IF NOT EXISTS style_fts USING fts5(\n    title, thesis, theme, industry, terms, body,\n    content='retrieval_documents', content_rowid='style_rowid'\n  );\n\n  CREATE TRIGGER IF NOT EXISTS style_fts_insert\n  AFTER INSERT ON retrieval_documents BEGIN\n    INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n    VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n      new.terms, new.body);\n  END;\n\n  CREATE TRIGGER IF NOT EXISTS style_fts_update\n  AFTER UPDATE ON retrieval_documents BEGIN\n    INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n    VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n      old.industry, old.terms, old.body);\n    INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n    VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n      new.terms, new.body);\n  END;\n\n  CREATE TRIGGER IF NOT EXISTS style_fts_delete\n  AFTER DELETE ON retrieval_documents BEGIN\n    INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n    VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n      old.industry, old.terms, old.body);\n  END;\n\n  CREATE TABLE IF NOT EXISTS embedding_profiles (\n    profile_id TEXT PRIMARY KEY,\n    provider TEXT NOT NULL,\n    model TEXT NOT NULL,\n    dimensions INTEGER CHECK (dimensions IS NULL OR dimensions > 0),\n    config_hash TEXT NOT NULL,\n    created_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS embedding_cache (\n    retrieval_hash TEXT NOT NULL,\n    profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n    vector_json TEXT NOT NULL,\n    created_at TEXT NOT NULL,\n    PRIMARY KEY (retrieval_hash, profile_id)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_vector_jobs (\n    job_id INTEGER PRIMARY KEY,\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    retrieval_hash TEXT NOT NULL,\n    profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    status TEXT NOT NULL DEFAULT 'pending'\n      CHECK (status IN ('pending', 'running', 'completed', 'failed', 'superseded')),\n    attempts INTEGER NOT NULL DEFAULT 0 CHECK (attempts >= 0),\n    next_attempt_at TEXT,\n    last_error TEXT,\n    created_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL,\n    UNIQUE (style_rowid, retrieval_hash, profile_id)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_vectors (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    retrieval_hash TEXT NOT NULL,\n    profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n    vector_json TEXT NOT NULL,\n    created_at TEXT NOT NULL,\n    PRIMARY KEY (style_rowid, profile_id)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_relationships (\n    relationship_id INTEGER PRIMARY KEY,\n    source_style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n    raw_target_label TEXT NOT NULL,\n    target_style_rowid INTEGER REFERENCES styles(style_rowid) ON DELETE SET NULL,\n    rationale TEXT NOT NULL,\n    resolution_state TEXT NOT NULL\n      CHECK (resolution_state IN ('resolved', 'ambiguous', 'unresolved')),\n    confidence REAL NOT NULL CHECK (confidence >= 0 AND confidence <= 1),\n    UNIQUE (source_style_rowid, ordinal)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_index_state (\n    style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    artifact_hint_hash TEXT NOT NULL,\n    crawl_record_hash TEXT NOT NULL,\n    aggregate_hash TEXT NOT NULL,\n    last_success_generation TEXT NOT NULL,\n    last_success_at TEXT NOT NULL,\n    missing_observations INTEGER NOT NULL DEFAULT 0 CHECK (missing_observations >= 0)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS corpus_generations (\n    generation_hash TEXT PRIMARY KEY,\n    parent_generation_hash TEXT REFERENCES corpus_generations(generation_hash),\n    crawl_manifest_hash TEXT NOT NULL,\n    aggregate_corpus_hash TEXT NOT NULL,\n    schema_version INTEGER NOT NULL,\n    active_style_count INTEGER NOT NULL CHECK (active_style_count >= 0),\n    quarantined_style_count INTEGER NOT NULL CHECK (quarantined_style_count >= 0),\n    tombstoned_style_count INTEGER NOT NULL CHECK (tombstoned_style_count >= 0),\n    created_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS current_corpus_generation (\n    singleton INTEGER PRIMARY KEY CHECK (singleton = 1),\n    generation_hash TEXT NOT NULL REFERENCES corpus_generations(generation_hash),\n    published_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS vector_projection_revisions (\n    profile_id TEXT PRIMARY KEY REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    revision INTEGER NOT NULL DEFAULT 0 CHECK (revision >= 0),\n    updated_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_update\n  BEFORE UPDATE ON corpus_generations BEGIN\n    SELECT RAISE(ABORT, 'corpus generations are immutable');\n  END;\n\n  CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_delete\n  BEFORE DELETE ON corpus_generations BEGIN\n    SELECT RAISE(ABORT, 'corpus generations are immutable');\n  END;\n\n  CREATE INDEX IF NOT EXISTS idx_styles_active_theme\n    ON styles(theme, style_id) WHERE lifecycle_state = 'active';\n  CREATE INDEX IF NOT EXISTS idx_styles_lifecycle ON styles(lifecycle_state, style_id);\n  CREATE INDEX IF NOT EXISTS idx_style_terms_lookup ON style_terms(term_type, term, style_rowid);\n  CREATE INDEX IF NOT EXISTS idx_style_axes_lookup ON style_token_axes(axis, style_rowid);\n  CREATE INDEX IF NOT EXISTS idx_style_artifacts_path ON style_artifacts(relative_path);\n  CREATE INDEX IF NOT EXISTS idx_style_vectors_profile ON style_vectors(profile_id, style_rowid);\n  CREATE INDEX IF NOT EXISTS idx_vector_jobs_drain\n    ON style_vector_jobs(status, next_attempt_at, job_id);\n  CREATE INDEX IF NOT EXISTS idx_relationships_source\n    ON style_relationships(source_style_rowid, resolution_state);\n  CREATE INDEX IF NOT EXISTS idx_relationships_target\n    ON style_relationships(target_style_rowid) WHERE target_style_rowid IS NOT NULL;\n`;\n\n/**\n * Create or validate the current style database schema.\n *\n * @param {DatabaseSync} database - Open SQLite connection.\n * @returns {DatabaseSync} The configured connection.\n */\nexport function createSchema(database) {\n  if (!(database instanceof DatabaseSync)) {\n    throw new TypeError('database must be a node:sqlite DatabaseSync instance.');\n  }\n  database.exec('PRAGMA foreign_keys = ON; PRAGMA busy_timeout = 5000;');\n  const currentVersion = Number(database.prepare('PRAGMA user_version').get().user_version);\n  if (currentVersion > STYLE_DB_SCHEMA_VERSION) {\n    throw new Error(`Style database schema ${currentVersion} is newer than supported version ${STYLE_DB_SCHEMA_VERSION}.`);\n  }\n  if (currentVersion === 1) {\n    const indexStateColumns = database.prepare(`\n      PRAGMA table_info(style_index_state)\n    `).all().map((column) => column.name);\n    if (!indexStateColumns.includes('crawl_record_hash')) {\n      database.exec('BEGIN IMMEDIATE');\n      try {\n        database.exec(`\n          ALTER TABLE style_index_state\n          ADD COLUMN crawl_record_hash TEXT NOT NULL DEFAULT 'legacy-unverified'\n        `);\n        database.exec('COMMIT');\n      } catch (error) {\n        database.exec('ROLLBACK');\n        throw error;\n      }\n    }\n  }\n  database.exec(SCHEMA_SQL);\n  const requiredIndexStateColumns = new Set([\n    'style_rowid',\n    'artifact_hint_hash',\n    'crawl_record_hash',\n    'aggregate_hash',\n    'last_success_generation',\n    'last_success_at',\n    'missing_observations',\n  ]);\n  const actualIndexStateColumns = new Set(database.prepare(`\n    PRAGMA table_info(style_index_state)\n  `).all().map((column) => column.name));\n  if ([...requiredIndexStateColumns].some((column) => !actualIndexStateColumns.has(column))) {\n    throw new Error('Style database index-state schema is incomplete after migration.');\n  }\n  database.prepare(`\n    INSERT INTO style_db_metadata(key, value) VALUES ('schema_version', ?)\n    ON CONFLICT(key) DO UPDATE SET value = excluded.value\n  `).run(String(STYLE_DB_SCHEMA_VERSION));\n  database.exec(`PRAGMA user_version = ${STYLE_DB_SCHEMA_VERSION};`);\n  return database;\n}\n\n/**\n * Open a local style database with its versioned schema initialized.\n *\n * @param {string} [databasePath=':memory:'] - SQLite file path or in-memory marker.\n * @returns {DatabaseSync} Ready database connection.\n */\nexport function openStyleDatabase(databasePath = ':memory:') {\n  const database = new DatabaseSync(databasePath);\n  if (databasePath !== ':memory:') database.exec('PRAGMA journal_mode = WAL;');\n  return createSchema(database);\n}\n\n/**\n * Open the published generation and bind its internal identity to the pointer.\n *\n * @param {string} [databasePath] - Logical database path.\n * @returns {DatabaseSync} Generation-bound database connection.\n */\nexport function openPublishedStyleDatabase(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n  const target = resolvePublishedDatabaseTarget(databasePath);\n  const database = openStyleDatabase(target.databasePath);\n  if (target.generationHash === null) return database;\n  const openedGeneration = database.prepare(`\n    SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n  `).get()?.generation_hash;\n  if (openedGeneration !== target.generationHash) {\n    database.close();\n    const error = new Error('Published database generation does not match its pointer.');\n    error.code = 'generation-pointer-mismatch';\n    throw error;\n  }\n  return database;\n}","lineStart":1,"lineEnd":360,"totalLines":360,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/schema.mjs","time":{"start":1784606352010,"end":1784606352016}},"id":"prt_f82d3dfbe001ZTRsNJTSLtL3pL","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ccaa001KjjVqzLXb1VlKJ"}}
{"type":"tool_use","timestamp":1784606352644,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_01_lpCsTORSntlCwvzAy7Z43662","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Incremental Style Database Indexer                                       ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import {\n6:   lstat,\n7:   open,\n8:   readFile,\n9:   readdir,\n10:   realpath,\n11:   rename,\n12:   rm,\n13:   stat,\n14: } from 'node:fs/promises';\n15: import path from 'node:path';\n16: \n17: import {\n18:   compareRawStrings,\n19:   digest,\n20:   lengthFrame,\n21:   stableJson,\n22: } from './canonical.mjs';\n23: import {\n24:   buildManifest,\n25:   hashArtifactFile,\n26:   writeManifestPointer,\n27: } from './generation-manifest.mjs';\n28: import {\n29:   RESIDENCY,\n30: } from './stage-telemetry.mjs';\n31: import {\n32:   DEFAULT_STYLE_DATABASE_PATH,\n33:   STYLE_DB_SCHEMA_VERSION,\n34:   STYLE_DATABASE_POINTER_SUFFIX,\n35:   openStyleDatabase,\n36: } from './schema.mjs';\n37: \n38: export const INDEXER_LIFECYCLE = Object.freeze([\n39:   'DISCOVER',\n40:   'VERIFY',\n41:   'PARSE_VALIDATE',\n42:   'COMMIT',\n43:   'VECTOR_DRAIN',\n44:   'PUBLISH',\n45: ]);\n46: export const DEFAULT_EMBEDDING_PROFILE = 'style-default-v1';\n47: \n48: const AGGREGATE_HASH_VERSION = 'style-all-artifacts-v2';\n49: const RETRIEVAL_HASH_VERSION = 'style-retrieval-document-v1';\n50: const GENERATION_HASH_VERSION = 'style-corpus-generation-v2';\n51: const LICENSE_ALLOWLIST = new Set(['allowed', 'licensed', 'public-domain']);\n52: const RESTRICTED_LICENSE_PATTERN = /\\b(unlicensed trial|license[- ]restricted)\\b/i;\n53: const WARM_SURFACE_PATTERN = /\\b(warm|cream|beige|bone|ivory|linen|sand|tan)\\b/i;\n54: const MOTION_PATTERN = /\\b(motion|animation|animated|transition|kinetic|scroll)\\b/i;\n55: const SERIF_PATTERN = /(^|[^a-z])serif([^a-z]|$)/i;\n56: const SANS_SERIF_PATTERN = /sans[- ]serif/i;\n57: \n58: function nowIso() {\n59:   return new Date().toISOString();\n60: }\n61: \n62: function normalizeTerm(value) {\n63:   return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n64: }\n65: \n66: function normalizeMarkdown(value) {\n67:   return String(value ?? '').normalize('NFC').replace(/\\r\\n?/g, '\\n')\n68:     .split('\\n').map((line) => line.trimEnd()).join('\\n').trimEnd();\n69: }\n70: \n71: function artifactRole(fileName) {\n72:   if (fileName.endsWith('-canonical.json')) return 'canonical';\n73:   if (fileName === 'design-tokens.json') return 'tokens';\n74:   if (fileName === 'DESIGN.md') return 'design';\n75:   if (fileName === 'source.md') return 'source';\n76:   if (fileName === 'css-variables.css') return 'css-variables';\n77:   if (fileName === 'tailwind-v4.css') return 'tailwind';\n78:   return null;\n79: }\n80: \n81: function isContained(rootPath, candidatePath) {\n82:   const relative = path.relative(rootPath, candidatePath);\n83:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n84: }\n85: \n86: function parseJson(artifact, label) {\n87:   if (!artifact) return {};\n88:   try {\n89:     return JSON.parse(artifact.buffer.toString('utf8'));\n90:   } catch (error) {\n91:     const invalid = new Error(`Invalid ${label} JSON: ${artifact.relativePath}`, { cause: error });\n92:     invalid.code = 'invalid-artifact';\n93:     throw invalid;\n94:   }\n95: }\n96: \n97: function countTokenLeaves(value) {\n98:   if (!value || typeof value !== 'object') return 0;\n99:   if (Object.hasOwn(value, '$value')) return 1;\n100:   return Object.values(value).reduce((sum, child) => sum + countTokenLeaves(child), 0);\n101: }\n102: \n103: function deriveTokenAxes(tokens, designSystem) {\n104:   const counts = new Map();\n105:   for (const [axis, value] of Object.entries(tokens ?? {})) {\n106:     const count = countTokenLeaves(value);\n107:     if (count > 0) counts.set(axis, count);\n108:   }\n109:   const fallbackCounts = {\n110:     color: Array.isArray(designSystem.colors) ? designSystem.colors.length : 0,\n111:     spacing: designSystem.spacing ? Object.keys(designSystem.spacing).length : 0,\n112:     typography: Array.isArray(designSystem.typography) ? designSystem.typography.length : 0,\n113:   };\n114:   for (const [axis, count] of Object.entries(fallbackCounts)) {\n115:     if (count > 0 && !counts.has(axis)) counts.set(axis, count);\n116:   }\n117:   return [...counts].map(([axis, count]) => ({ axis, count }))\n118:     .sort((left, right) => compareRawStrings(left.axis, right.axis));\n119: }\n120: \n121: function deriveSections(designMarkdown) {\n122:   const sections = [];\n123:   for (const [index, line] of designMarkdown.split('\\n').entries()) {\n124:     const match = /^##\\s+(.+?)\\s*$/.exec(line);\n125:     if (match) sections.push({ name: match[1], line: index + 1 });\n126:   }\n127:   return sections;\n128: }\n129: \n130: function deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus) {\n131:   const values = new Set();\n132:   if (tokenAxes.length > 0) values.add('tokens');\n133:   if ((designSystem.components?.length ?? 0) > 0) values.add('components');\n134:   if (designSystem.layout) values.add('layout');\n135:   if (designSystem.imagery) values.add('imagery');\n136:   if (designSystem.spacing) values.add('spacing');\n137:   if ((designSystem.dos?.length ?? 0) + (designSystem.donts?.length ?? 0) > 0) {\n138:     values.add('constraints');\n139:   }\n140:   if (provenanceStatus === 'known') values.add('provenance');\n141:   if (sections.some((section) => MOTION_PATTERN.test(section.name))) values.add('motion');\n142:   return [...values].sort(compareRawStrings);\n143: }\n144: \n145: function deriveFacets(style, designSystem, capabilities, tokenAxes, searchableText, licenseStatus) {\n146:   const values = new Set(capabilities);\n147:   for (const { axis } of tokenAxes) values.add(axis);\n148:   if (designSystem.theme) values.add(normalizeTerm(designSystem.theme));\n149:   if (designSystem.industry) values.add(normalizeTerm(designSystem.industry));\n150:   if (SERIF_PATTERN.test(searchableText) && !SANS_SERIF_PATTERN.test(searchableText)) {\n151:     values.add('serif-role');\n152:   }\n153:   if (WARM_SURFACE_PATTERN.test(searchableText)) values.add('warm-surface');\n154:   if (MOTION_PATTERN.test(searchableText)) values.add('motion');\n155:   if (licenseStatus === 'restricted') values.add('license-restricted');\n156:   values.add(normalizeTerm(style.slug));\n157:   return [...values].filter(Boolean).sort(compareRawStrings);\n158: }\n159: \n160: function excerpt(value, maxLength = 240) {\n161:   const normalized = String(value ?? '').replace(/\\s+/g, ' ').trim();\n162:   if (normalized.length <= maxLength) return normalized;\n163:   return `${normalized.slice(0, maxLength - 1).trimEnd()}…`;\n164: }\n165: \n166: function computeAggregateHash(styleId, artifacts) {\n167:   const parts = [\n168:     ...lengthFrame(AGGREGATE_HASH_VERSION),\n169:     ...lengthFrame(styleId),\n170:   ];\n171:   for (const artifact of artifacts.slice()\n172:     .sort((left, right) => compareRawStrings(left.role, right.role))) {\n173:     parts.push(...lengthFrame(artifact.role), ...lengthFrame(artifact.buffer));\n174:   }\n175:   return digest(parts);\n176: }\n177: \n178: function computeHintHash(artifacts) {\n179:   return digest([\n180:     'style-artifact-hints-v1\\0',\n181:     ...artifacts.map((artifact) => (\n182:       `${artifact.relativePath}\\0${artifact.byteLength}\\0${artifact.mtimeNs}\\0${artifact.ctimeNs}\\n`\n183:     )),\n184:   ]);\n185: }\n186: \n187: function computeCrawlRecordHash(crawlRecord) {\n188:   return digest([\n189:     'style-crawl-record-v1\\0',\n190:     stableJson(crawlRecord ?? null),\n191:   ]);\n192: }\n193: \n194: function computeGenerationHash(crawlManifestHash, styles, inactiveStates = []) {\n195:   const parts = [\n196:     ...lengthFrame(GENERATION_HASH_VERSION),\n197:     ...lengthFrame(STYLE_DB_SCHEMA_VERSION),\n198:     ...lengthFrame(crawlManifestHash),\n199:   ];\n200:   for (const style of styles.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n201:     parts.push(...lengthFrame(style.id), ...lengthFrame(style.aggregateHash));\n202:   }\n203:   for (const style of inactiveStates.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n204:     parts.push(...lengthFrame(style.id), ...lengthFrame(style.state));\n205:   }\n206:   return digest(parts);\n207: }\n208: \n209: async function readVerifiedArtifacts(corpusRoot, corpusRealPath, slug) {\n210:   const styleRoot = path.join(corpusRoot, slug);\n211:   const entries = (await readdir(styleRoot, { withFileTypes: true }))\n212:     .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n213:     .sort((left, right) => compareRawStrings(left.name, right.name));\n214:   const artifacts = [];\n215:   for (const entry of entries) {\n216:     const role = artifactRole(entry.name);\n217:     if (!role) {\n218:       const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n219:       error.code = 'invalid-artifact';\n220:       throw error;\n221:     }\n222:     const candidatePath = path.join(styleRoot, entry.name);\n223:     const linkInfo = await lstat(candidatePath, { bigint: true });\n224:     if (!linkInfo.isFile() && !linkInfo.isSymbolicLink()) continue;\n225:     const artifactRealPath = await realpath(candidatePath);\n226:     if (!isContained(corpusRealPath, artifactRealPath)) {\n227:       const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n228:       error.code = 'path-escape';\n229:       throw error;\n230:     }\n231:     const before = await stat(artifactRealPath, { bigint: true });\n232:     const buffer = await readFile(artifactRealPath);\n233:     const after = await stat(artifactRealPath, { bigint: true });\n234:     if (before.size !== after.size || before.mtimeNs !== after.mtimeNs || before.ctimeNs !== after.ctimeNs) {\n235:       const error = new Error(`Corpus changed while reading ${slug}/${entry.name}.`);\n236:       error.code = 'corpus-changing';\n237:       throw error;\n238:     }\n239:     artifacts.push({\n240:       role,\n241:       relativePath: `${slug}/${entry.name}`,\n242:       byteLength: buffer.byteLength,\n243:       sha256: digest([buffer]),\n244:       mtimeNs: String(after.mtimeNs),\n245:       ctimeNs: String(after.ctimeNs),\n246:       buffer,\n247:     });\n248:   }\n249:   if (!artifacts.some((artifact) => artifact.role === 'canonical')\n250:     || !artifacts.some((artifact) => artifact.role === 'design')) {\n251:     const error = new Error(`Style ${slug} lacks its canonical JSON or DESIGN.md artifact.`);\n252:     error.code = 'invalid-artifact';\n253:     throw error;\n254:   }\n255:   return artifacts;\n256: }\n257: \n258: async function readArtifactHints(corpusRoot, corpusRealPath, slug) {\n259:   const styleRoot = path.join(corpusRoot, slug);\n260:   const entries = (await readdir(styleRoot, { withFileTypes: true }))\n261:     .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n262:     .sort((left, right) => compareRawStrings(left.name, right.name));\n263:   const artifacts = [];\n264:   for (const entry of entries) {\n265:     const role = artifactRole(entry.name);\n266:     if (!role) {\n267:       const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n268:       error.code = 'invalid-artifact';\n269:       throw error;\n270:     }\n271:     const candidatePath = path.join(styleRoot, entry.name);\n272:     const artifactRealPath = await realpath(candidatePath);\n273:     if (!isContained(corpusRealPath, artifactRealPath)) {\n274:       const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n275:       error.code = 'path-escape';\n276:       throw error;\n277:     }\n278:     const fileInfo = await stat(artifactRealPath, { bigint: true });\n279:     artifacts.push({\n280:       role,\n281:       relativePath: `${slug}/${entry.name}`,\n282:       byteLength: Number(fileInfo.size),\n283:       mtimeNs: String(fileInfo.mtimeNs),\n284:       ctimeNs: String(fileInfo.ctimeNs),\n285:     });\n286:   }\n287:   return artifacts;\n288: }\n289: \n290: function parseStyle(slug, crawlRecord, artifacts) {\n291:   const canonical = parseJson(artifacts.find((artifact) => artifact.role === 'canonical'), 'canonical');\n292:   const tokens = parseJson(artifacts.find((artifact) => artifact.role === 'tokens'), 'token');\n293:   const designMarkdown = normalizeMarkdown(\n294:     artifacts.find((artifact) => artifact.role === 'design')?.buffer.toString('utf8'),\n295:   );\n296:   const designSystem = canonical.designSystem ?? {};\n297:   const id = canonical.uuid ?? crawlRecord?.uuid;\n298:   if (typeof id !== 'string' || id.length === 0) {\n299:     const error = new Error(`Style ${slug} has no stable UUID.`);\n300:     error.code = 'invalid-artifact';\n301:     throw error;\n302:   }\n303:   const title = excerpt(canonical.name ?? slug, 120);\n304:   const thesis = excerpt(canonical.northStar ?? designSystem.northStar ?? designSystem.description);\n305:   const theme = designSystem.theme == null ? null : String(designSystem.theme);\n306:   const industry = designSystem.industry == null ? null : String(designSystem.industry);\n307:   const sections = deriveSections(designMarkdown);\n308:   const tokenAxes = deriveTokenAxes(tokens, designSystem);\n309:   const provenanceStatus = canonical.source && canonical.uuid && canonical.meta?.url\n310:     ? 'known'\n311:     : 'missing';\n312:   const searchableText = [\n313:     title,\n314:     thesis,\n315:     designSystem.description,\n316:     theme,\n317:     industry,\n318:     designSystem.layout,\n319:     designSystem.imagery,\n320:     ...(Array.isArray(designSystem.typography)\n321:       ? designSystem.typography.map((entry) => `${entry.family ?? ''} ${entry.role ?? ''}`)\n322:       : []),\n323:     designMarkdown.slice(0, 65_536),\n324:   ].join(' ');\n325:   const licenseStatus = RESTRICTED_LICENSE_PATTERN.test(searchableText)\n326:     ? 'restricted'\n327:     : String(canonical.license?.status ?? 'unknown');\n328:   const rightsKnown = LICENSE_ALLOWLIST.has(licenseStatus) || licenseStatus === 'restricted';\n329:   const capabilities = deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus);\n330:   const facets = deriveFacets(\n331:     { slug },\n332:     designSystem,\n333:     capabilities,\n334:     tokenAxes,\n335:     searchableText,\n336:     licenseStatus,\n337:   );\n338:   const retrievalDocument = {\n339:     id,\n340:     title,\n341:     thesis,\n342:     theme,\n343:     industry,\n344:     capabilities,\n345:     facets,\n346:     tokenAxes,\n347:     sections: sections.map((section) => section.name),\n348:     designMarkdown,\n349:   };\n350:   const retrievalJson = stableJson(retrievalDocument);\n351:   const retrievalHash = digest([\n352:     ...lengthFrame(RETRIEVAL_HASH_VERSION),\n353:     ...lengthFrame(retrievalJson),\n354:   ]);\n355:   const aggregateHash = computeAggregateHash(id, artifacts);\n356:   return {\n357:     id,\n358:     slug,\n359:     crawlStatus: crawlRecord?.status ?? 'unknown',\n360:     title,\n361:     thesis,\n362:     theme,\n363:     industry,\n364:     aggregateHash,\n365:     artifactHintHash: computeHintHash(artifacts),\n366:     crawlRecordHash: computeCrawlRecordHash(crawlRecord),\n367:     retrievalHash,\n368:     artifacts,\n369:     tokenAxes,\n370:     sections,\n371:     capabilities,\n372:     facets,\n373:     provenance: {\n374:       status: provenanceStatus,\n375:       sourceUrl: canonical.source ?? crawlRecord?.url ?? null,\n376:       originalUrl: canonical.meta?.url ?? null,\n377:       screenshotUrl: canonical.screenshot?.url ?? null,\n378:       uuid: canonical.uuid ?? crawlRecord?.uuid ?? null,\n379:       capturedAt: canonical.capturedAt ?? crawlRecord?.capturedAt ?? null,\n380:       licenseStatus,\n381:       rightsKnown,\n382:       evidenceScope: ['reference', 'rationale'],\n383:     },\n384:     relationships: (Array.isArray(designSystem.similar) ? designSystem.similar : [])\n385:       .map((relationship, ordinal) => ({\n386:         ordinal,\n387:         rawTargetLabel: String(relationship.business ?? relationship.name ?? '').trim(),\n388:         rationale: String(relationship.why ?? relationship.rationale ?? '').trim(),\n389:       })).filter((relationship) => relationship.rawTargetLabel),\n390:     retrievalDocument: {\n391:       title,\n392:       thesis,\n393:       theme: theme ?? '',\n394:       industry: industry ?? '',\n395:       terms: [...new Set([...facets, ...capabilities, ...tokenAxes.map(({ axis }) => axis)])]\n396:         .sort(compareRawStrings).join(' '),\n397:       body: designMarkdown,\n398:       documentJson: retrievalJson,\n399:       retrievalHash,\n400:     },\n401:   };\n402: }\n403: \n404: function replaceStyleChildren(database, styleRowid, style, timestamp) {\n405:   for (const table of [\n406:     'style_provenance',\n407:     'style_artifacts',\n408:     'style_terms',\n409:     'style_token_axes',\n410:     'style_sections',\n411:     'retrieval_documents',\n412:     'style_relationships',\n413:   ]) {\n414:     const key = table === 'style_relationships' ? 'source_style_rowid' : 'style_rowid';\n415:     database.prepare(`DELETE FROM ${table} WHERE ${key} = ?`).run(styleRowid);\n416:   }\n417:   database.prepare(`\n418:     INSERT INTO style_provenance(\n419:       style_rowid, status, source_url, original_url, screenshot_url, source_uuid,\n420:       captured_at, license_status, rights_known, evidence_scope_json\n421:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n422:   `).run(\n423:     styleRowid,\n424:     style.provenance.status,\n425:     style.provenance.sourceUrl,\n426:     style.provenance.originalUrl,\n427:     style.provenance.screenshotUrl,\n428:     style.provenance.uuid,\n429:     style.provenance.capturedAt,\n430:     style.provenance.licenseStatus,\n431:     style.provenance.rightsKnown ? 1 : 0,\n432:     JSON.stringify(style.provenance.evidenceScope),\n433:   );\n434:   const insertArtifact = database.prepare(`\n435:     INSERT INTO style_artifacts(\n436:       style_rowid, role, relative_path, byte_length, sha256, mtime_ns, ctime_ns\n437:     ) VALUES (?, ?, ?, ?, ?, ?, ?)\n438:   `);\n439:   for (const artifact of style.artifacts) {\n440:     insertArtifact.run(\n441:       styleRowid,\n442:       artifact.role,\n443:       artifact.relativePath,\n444:       artifact.byteLength,\n445:       artifact.sha256,\n446:       artifact.mtimeNs,\n447:       artifact.ctimeNs,\n448:     );\n449:   }\n450:   const insertTerm = database.prepare(\n451:     'INSERT INTO style_terms(style_rowid, term_type, term) VALUES (?, ?, ?)',\n452:   );\n453:   for (const term of style.facets) insertTerm.run(styleRowid, 'facet', term);\n454:   for (const term of style.capabilities) insertTerm.run(styleRowid, 'capability', term);\n455:   const insertAxis = database.prepare(\n456:     'INSERT INTO style_token_axes(style_rowid, axis, token_count) VALUES (?, ?, ?)',\n457:   );\n458:   for (const axis of style.tokenAxes) insertAxis.run(styleRowid, axis.axis, axis.count);\n459:   const insertSection = database.prepare(`\n460:     INSERT INTO style_sections(style_rowid, ordinal, name, line_number) VALUES (?, ?, ?, ?)\n461:   `);\n462:   for (const [ordinal, section] of style.sections.entries()) {\n463:     insertSection.run(styleRowid, ordinal, section.name, section.line);\n464:   }\n465:   const document = style.retrievalDocument;\n466:   database.prepare(`\n467:     INSERT INTO retrieval_documents(\n468:       style_rowid, title, thesis, theme, industry, terms, body, document_json, retrieval_hash\n469:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n470:   `).run(\n471:     styleRowid,\n472:     document.title,\n473:     document.thesis,\n474:     document.theme,\n475:     document.industry,\n476:     document.terms,\n477:     document.body,\n478:     document.documentJson,\n479:     document.retrievalHash,\n480:   );\n481:   const insertRelationship = database.prepare(`\n482:     INSERT INTO style_relationships(\n483:       source_style_rowid, ordinal, raw_target_label, target_style_rowid,\n484:       rationale, resolution_state, confidence\n485:     ) VALUES (?, ?, ?, NULL, ?, 'unresolved', 0)\n486:   `);\n487:   for (const relationship of style.relationships) {\n488:     insertRelationship.run(\n489:       styleRowid,\n490:       relationship.ordinal,\n491:       relationship.rawTargetLabel,\n492:       relationship.rationale,\n493:     );\n494:   }\n495:   database.prepare(`\n496:     INSERT INTO style_index_state(\n497:       style_rowid, artifact_hint_hash, crawl_record_hash, aggregate_hash,\n498:       last_success_generation, last_success_at, missing_observations\n499:     ) VALUES (?, ?, ?, ?, ?, ?, 0)\n500:     ON CONFLICT(style_rowid) DO UPDATE SET\n501:       artifact_hint_hash = excluded.artifact_hint_hash,\n502:       crawl_record_hash = excluded.crawl_record_hash,\n503:       aggregate_hash = excluded.aggregate_hash,\n504:       last_success_generation = excluded.last_success_generation,\n505:       last_success_at = excluded.last_success_at,\n506:       missing_observations = 0\n507:   `).run(\n508:     styleRowid,\n509:     style.artifactHintHash,\n510:     style.crawlRecordHash,\n511:     style.aggregateHash,\n512:     '',\n513:     timestamp,\n514:   );\n515: }\n516: \n517: function resolveRelationships(database) {\n518:   const aliases = new Map();\n519:   for (const style of database.prepare(`\n520:     SELECT style_rowid, slug, title FROM styles WHERE lifecycle_state = 'active'\n521:   `).all()) {\n522:     for (const alias of [style.slug, style.title]) {\n523:       const key = normalizeTerm(alias);\n524:       if (!aliases.has(key)) aliases.set(key, []);\n525:       aliases.get(key).push(Number(style.style_rowid));\n526:     }\n527:   }\n528:   const update = database.prepare(`\n529:     UPDATE style_relationships\n530:     SET target_style_rowid = ?, resolution_state = ?, confidence = ?\n531:     WHERE relationship_id = ?\n532:   `);\n533:   for (const relationship of database.prepare(`\n534:     SELECT relationship_id, raw_target_label FROM style_relationships\n535:   `).all()) {\n536:     const matches = [...new Set(aliases.get(normalizeTerm(relationship.raw_target_label)) ?? [])];\n537:     if (matches.length === 1) update.run(matches[0], 'resolved', 1, relationship.relationship_id);\n538:     else if (matches.length > 1) update.run(null, 'ambiguous', 0.5, relationship.relationship_id);\n539:     else update.run(null, 'unresolved', 0, relationship.relationship_id);\n540:   }\n541: }\n542: \n543: function ensureEmbeddingProfile(database, profile, timestamp) {\n544:   const existing = database.prepare(`\n545:     SELECT provider, model, dimensions, config_hash\n546:     FROM embedding_profiles WHERE profile_id = ?\n547:   `).get(profile.id);\n548:   if (existing && (\n549:     existing.provider !== profile.provider\n550:     || existing.model !== profile.model\n551:     || existing.config_hash !== profile.configHash\n552:     || (existing.dimensions != null && profile.dimensions != null\n553:       && Number(existing.dimensions) !== profile.dimensions)\n554:   )) {\n555:     const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n556:     error.code = 'embedding-profile-conflict';\n557:     throw error;\n558:   }\n559:   if (existing) return;\n560:   database.prepare(`\n561:     INSERT INTO embedding_profiles(\n562:       profile_id, provider, model, dimensions, config_hash, created_at\n563:     ) VALUES (?, ?, ?, ?, ?, ?)\n564:   `).run(\n565:     profile.id,\n566:     profile.provider,\n567:     profile.model,\n568:     profile.dimensions ?? null,\n569:     profile.configHash,\n570:     timestamp,\n571:   );\n572: }\n573: \n574: function enqueueVector(database, styleRowid, retrievalHash, profileId, timestamp) {\n575:   database.prepare(`\n576:     UPDATE style_vector_jobs\n577:     SET status = 'superseded', updated_at = ?\n578:     WHERE style_rowid = ? AND profile_id = ?\n579:       AND retrieval_hash != ? AND status IN ('pending', 'running', 'failed')\n580:   `).run(timestamp, styleRowid, profileId, retrievalHash);\n581:   database.prepare(`\n582:     UPDATE style_vector_jobs\n583:     SET status = 'pending', updated_at = ?, last_error = NULL, next_attempt_at = NULL\n584:     WHERE style_rowid = ? AND retrieval_hash = ? AND profile_id = ?\n585:       AND status = 'completed'\n586:       AND NOT EXISTS (\n587:         SELECT 1 FROM style_vectors v\n588:         WHERE v.style_rowid = style_vector_jobs.style_rowid\n589:           AND v.retrieval_hash = style_vector_jobs.retrieval_hash\n590:           AND v.profile_id = style_vector_jobs.profile_id\n591:       )\n592:   `).run(timestamp, styleRowid, retrievalHash, profileId);\n593:   database.prepare(`\n594:     INSERT INTO style_vector_jobs(\n595:       style_rowid, retrieval_hash, profile_id, status, created_at, updated_at\n596:     ) VALUES (?, ?, ?, 'pending', ?, ?)\n597:     ON CONFLICT(style_rowid, retrieval_hash, profile_id) DO UPDATE SET\n598:       status = CASE\n599:         WHEN style_vector_jobs.status = 'completed' THEN 'completed'\n600:         ELSE 'pending'\n601:       END,\n602:       updated_at = excluded.updated_at,\n603:       last_error = NULL\n604:   `).run(styleRowid, retrievalHash, profileId, timestamp, timestamp);\n605: }\n606: \n607: /**\n608:  * Incrementally project an authoritative flat-file corpus into SQLite.\n609:  *\n610:  * @param {Object} options - Indexing controls.\n611:  * @param {string} options.corpusRoot - Authoritative style corpus root.\n612:  * @param {string} [options.databasePath] - SQLite destination when no connection is supplied.\n613:  * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n614:  * @param {'migration'|'rollback'} options.corpusWalkMode - Explicit filesystem-walk grant.\n615:  * @param {boolean} [options.confirmMissing=false] - Confirm quarantined absences as tombstones.\n616:  * @param {boolean} [options.verifyAll=false] - Bypass metadata hints and hash every bundle.\n617:  * @param {Function} [options.onStage] - Lifecycle observation hook.\n618:  * @param {Function} [options.failureInjector] - Test-only crash hook inside the transaction.\n619:  * @param {Object} [options.embeddingProfile] - Profile metadata for queued vectors.\n620:  * @param {Function} [options.embedder] - Optional asynchronous embedding callback.\n621:  * @returns {Promise<Object>} Publication and incremental-change summary.\n622:  */\n623: export async function indexStyleCorpus(options) {\n624:   if (!options?.corpusRoot || !['migration', 'rollback'].includes(options.corpusWalkMode)) {\n625:     const error = new Error('Corpus walking requires explicit migration or rollback mode.');\n626:     error.code = 'corpus-walk-forbidden';\n627:     throw error;\n628:   }\n629:   const database = options.database ?? openStyleDatabase(\n630:     options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n631:   );\n632:   const ownsDatabase = !options.database;\n633:   const telemetry = options.telemetry ?? null;\n634:   const overallTimer = telemetry?.overall() ?? null;\n635:   const emit = (stage, details = {}) => {\n636:     options.onStage?.(stage, details);\n637:   };\n638:   const profile = {\n639:     id: options.embeddingProfile?.id ?? DEFAULT_EMBEDDING_PROFILE,\n640:     provider: options.embeddingProfile?.provider ?? 'external',\n641:     model: options.embeddingProfile?.model ?? 'configured',\n642:     dimensions: options.embeddingProfile?.dimensions ?? null,\n643:     configHash: options.embeddingProfile?.configHash ?? 'style-default-v1',\n644:   };\n645:   try {\n646:     emit('DISCOVER');\n647:     const discoverSpan = telemetry?.span('discover', RESIDENCY.JS_RESIDENT);\n648:     const corpusRealPath = await realpath(options.corpusRoot);\n649:     const crawlPath = path.join(options.corpusRoot, '_manifest.json');\n650:     const crawlRealPath = await realpath(crawlPath);\n651:     if (!isContained(corpusRealPath, crawlRealPath)) {\n652:       const error = new Error('Crawl manifest escapes the corpus root.');\n653:       error.code = 'path-escape';\n654:       throw error;\n655:     }\n656:     const crawlBuffer = await readFile(crawlRealPath);\n657:     const crawlManifestHash = digest([crawlBuffer]);\n658:     const crawlRecords = JSON.parse(crawlBuffer.toString('utf8'));\n659:     const crawlBySlug = new Map(crawlRecords.map((record) => [record.slug, record]));\n660:     const entries = await readdir(options.corpusRoot, { withFileTypes: true });\n661:     const slugs = entries.filter((entry) => entry.isDirectory() && !entry.name.startsWith('_'))\n662:       .map((entry) => entry.name).sort(compareRawStrings);\n663:     discoverSpan?.end(slugs.length);\n664:     const snapshotSpan = telemetry?.span('snapshot.load', RESIDENCY.NATIVE);\n665:     const currentRows = database.prepare(`\n666:       SELECT s.style_rowid, s.style_id, s.slug, s.crawl_status, s.aggregate_hash,\n667:         s.retrieval_hash, s.lifecycle_state, i.artifact_hint_hash, i.crawl_record_hash\n668:       FROM styles s\n669:       LEFT JOIN style_index_state i ON i.style_rowid = s.style_rowid\n670:     `).all();\n671:     snapshotSpan?.end(currentRows.length);\n672:     const currentBySlug = new Map(currentRows.map((row) => [row.slug, row]));\n673:     const verifySpan = telemetry?.span('verify.parse', RESIDENCY.JS_RESIDENT);\n674:     const discovered = [];\n675:     let candidateCount = 0;\n676:     for (const slug of slugs) {\n677:       const crawlRecord = crawlBySlug.get(slug);\n678:       const crawlRecordHash = computeCrawlRecordHash(crawlRecord);\n679:       const hints = await readArtifactHints(options.corpusRoot, corpusRealPath, slug);\n680:       const artifactHintHash = computeHintHash(hints);\n681:       const current = currentBySlug.get(slug);\n682:       const needsVerification = options.verifyAll === true\n683:         || !current\n684:         || current.lifecycle_state !== 'active'\n685:         || current.artifact_hint_hash !== artifactHintHash\n686:         || current.crawl_record_hash !== crawlRecordHash;\n687:       if (needsVerification) {\n688:         candidateCount += 1;\n689:         const artifacts = await readVerifiedArtifacts(options.corpusRoot, corpusRealPath, slug);\n690:         discovered.push({\n691:           slug,\n692:           crawlRecord,\n693:           artifactHintHash,\n694:           crawlRecordHash,\n695:           style: parseStyle(slug, crawlRecord, artifacts),\n696:         });\n697:       } else {\n698:         discovered.push({\n699:           slug,\n700:           crawlRecord,\n701:           artifactHintHash,\n702:           crawlRecordHash,\n703:           style: {\n704:             id: current.style_id,\n705:             slug,\n706:             crawlStatus: current.crawl_status,\n707:             aggregateHash: current.aggregate_hash,\n708:             retrievalHash: current.retrieval_hash,\n709:           },\n710:         });\n711:       }\n712:     }\n713:     verifySpan?.end(candidateCount);\n714:     emit('VERIFY', { discovered: slugs.length, candidates: candidateCount });\n715:     emit('PARSE_VALIDATE', { verified: candidateCount });\n716:     const planSpan = telemetry?.span('plan.hash', RESIDENCY.JS_RESIDENT);\n717:     const parsedStyles = discovered.map((entry) => entry.style);\n718:     if (new Set(parsedStyles.map((style) => style.id)).size !== parsedStyles.length) {\n719:       const error = new Error('The corpus contains duplicate style UUIDs.');\n720:       error.code = 'duplicate-style-id';\n721:       throw error;\n722:     }\n723:     const currentById = new Map(currentRows.map((row) => [row.style_id, row]));\n724:     const verifiedStyles = discovered.filter((entry) => entry.style.artifacts)\n725:       .map((entry) => entry.style);\n726:     const changedStyles = verifiedStyles.filter((style) => {\n727:       const current = currentById.get(style.id);\n728:       return !current\n729:         || current.slug !== style.slug\n730:         || current.crawl_status !== style.crawlStatus\n731:         || current.aggregate_hash !== style.aggregateHash\n732:         || current.crawl_record_hash !== style.crawlRecordHash\n733:         || current.lifecycle_state !== 'active';\n734:     });\n735:     const changedIds = new Set(changedStyles.map((style) => style.id));\n736:     const hintOnlyStyles = verifiedStyles.filter((style) => !changedIds.has(style.id));\n737:     const discoveredIds = new Set(parsedStyles.map((style) => style.id));\n738:     const absentRows = currentRows.filter((row) => !discoveredIds.has(row.style_id));\n739:     const missingRows = absentRows.filter((row) => row.lifecycle_state !== 'tombstoned');\n740:     const inactiveStates = absentRows.map((row) => ({\n741:       id: row.style_id,\n742:       state: row.lifecycle_state === 'active' ? 'quarantined' : 'tombstoned',\n743:     }));\n744:     const generationHash = computeGenerationHash(\n745:       crawlManifestHash,\n746:       parsedStyles,\n747:       inactiveStates,\n748:     );\n749:     const aggregateCorpusHash = digest([\n750:       'style-corpus-aggregate-v1\\0',\n751:       ...parsedStyles.slice().sort((left, right) => compareRawStrings(left.id, right.id))\n752:         .map((style) => `${style.id}\\0${style.aggregateHash}\\n`),\n753:     ]);\n754:     const timestamp = nowIso();\n755:     planSpan?.end(parsedStyles.length);\n756:     const planLoadSpan = telemetry?.span('plan.load', RESIDENCY.NATIVE);\n757:     const currentGeneration = database.prepare(`\n758:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n759:     `).get()?.generation_hash ?? null;\n760:     const profileRow = database.prepare(`\n761:       SELECT provider, model, dimensions, config_hash\n762:       FROM embedding_profiles WHERE profile_id = ?\n763:     `).get(profile.id);\n764:     if (profileRow && (\n765:       profileRow.provider !== profile.provider\n766:       || profileRow.model !== profile.model\n767:       || profileRow.config_hash !== profile.configHash\n768:       || (profileRow.dimensions != null && profile.dimensions != null\n769:         && Number(profileRow.dimensions) !== profile.dimensions)\n770:     )) {\n771:       const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n772:       error.code = 'embedding-profile-conflict';\n773:       throw error;\n774:     }\n775:     const missingProfileJobs = profileRow ? Number(database.prepare(`\n776:       SELECT COUNT(*) AS count FROM styles s\n777:       WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n778:         SELECT 1 FROM style_vector_jobs j\n779:         WHERE j.style_rowid = s.style_rowid\n780:           AND j.retrieval_hash = s.retrieval_hash\n781:           AND j.profile_id = ?\n782:           AND j.status != 'superseded'\n783:           AND (j.status != 'completed' OR EXISTS (\n784:             SELECT 1 FROM style_vectors v\n785:             WHERE v.style_rowid = j.style_rowid\n786:               AND v.retrieval_hash = j.retrieval_hash\n787:               AND v.profile_id = j.profile_id\n788:           ))\n789:       )\n790:     `).get(profile.id).count) : parsedStyles.length;\n791:     planLoadSpan?.end(1);\n792:     const needsVectorQueue = !profileRow || missingProfileJobs > 0 || changedStyles.length > 0;\n793:     const shouldPublish = changedStyles.length > 0\n794:       || missingRows.length > 0\n795:       || currentGeneration !== generationHash;\n796:     if (!shouldPublish && hintOnlyStyles.length === 0 && !needsVectorQueue) {\n797:       return {\n798:         ok: true,\n799:         generationHash,\n800:         published: false,\n801:         indexed: 0,\n802:         unchanged: parsedStyles.length,\n803:         quarantined: 0,\n804:         tombstoned: 0,\n805:       };\n806:     }\n807: \n808:     database.exec('BEGIN IMMEDIATE');\n809:     try {\n810:       emit('COMMIT', {\n811:         changed: changedStyles.length,\n812:         hintOnly: hintOnlyStyles.length,\n813:         missing: missingRows.length,\n814:       });\n815:       const commitSpan = telemetry?.span('commit.write', RESIDENCY.NATIVE);\n816:       ensureEmbeddingProfile(database, profile, timestamp);\n817:       const upsertStyle = database.prepare(`\n818:         INSERT INTO styles(\n819:           style_id, slug, lifecycle_state, crawl_status, title, thesis, theme,\n820:           industry, aggregate_hash, retrieval_hash, quarantine_at, tombstoned_at,\n821:           created_at, updated_at\n822:         ) VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?, ?, NULL, NULL, ?, ?)\n823:         ON CONFLICT(style_id) DO UPDATE SET\n824:           slug = excluded.slug,\n825:           lifecycle_state = 'active',\n826:           crawl_status = excluded.crawl_status,\n827:           title = excluded.title,\n828:           thesis = excluded.thesis,\n829:           theme = excluded.theme,\n830:           industry = excluded.industry,\n831:           aggregate_hash = excluded.aggregate_hash,\n832:           retrieval_hash = excluded.retrieval_hash,\n833:           quarantine_at = NULL,\n834:           tombstoned_at = NULL,\n835:           updated_at = excluded.updated_at\n836:       `);\n837:       for (const [index, style] of changedStyles.entries()) {\n838:         upsertStyle.run(\n839:           style.id,\n840:           style.slug,\n841:           style.crawlStatus,\n842:           style.title,\n843:           style.thesis,\n844:           style.theme,\n845:           style.industry,\n846:           style.aggregateHash,\n847:           style.retrievalHash,\n848:           timestamp,\n849:           timestamp,\n850:         );\n851:         const styleRowid = Number(database.prepare(\n852:           'SELECT style_rowid FROM styles WHERE style_id = ?',\n853:         ).get(style.id).style_rowid);\n854:         replaceStyleChildren(database, styleRowid, style, timestamp);\n855:         options.failureInjector?.({ phase: 'COMMIT', style, index, database });\n856:       }\n857:       const updateHints = database.prepare(`\n858:         UPDATE style_index_state\n859:         SET artifact_hint_hash = ?, crawl_record_hash = ?, last_success_at = ?\n860:         WHERE style_rowid = ?\n861:       `);\n862:       for (const style of hintOnlyStyles) {\n863:         const current = currentById.get(style.id);\n864:         updateHints.run(\n865:           style.artifactHintHash,\n866:           style.crawlRecordHash,\n867:           timestamp,\n868:           current.style_rowid,\n869:         );\n870:       }\n871: \n872:       let queued = 0;\n873:       const queueRows = database.prepare(`\n874:         SELECT s.style_rowid, s.retrieval_hash FROM styles s\n875:         WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n876:           SELECT 1 FROM style_vector_jobs j\n877:           WHERE j.style_rowid = s.style_rowid\n878:             AND j.retrieval_hash = s.retrieval_hash\n879:             AND j.profile_id = ?\n880:             AND j.status != 'superseded'\n881:             AND (j.status != 'completed' OR EXISTS (\n882:               SELECT 1 FROM style_vectors v\n883:               WHERE v.style_rowid = j.style_rowid\n884:                 AND v.retrieval_hash = j.retrieval_hash\n885:                 AND v.profile_id = j.profile_id\n886:             ))\n887:         )\n888:       `).all(profile.id);\n889:       for (const row of queueRows) {\n890:         enqueueVector(database, row.style_rowid, row.retrieval_hash, profile.id, timestamp);\n891:         queued += 1;\n892:       }\n893:       commitSpan?.end(changedStyles.length + queued);\n894: \n895:       emit('VECTOR_DRAIN', { queued });\n896:       if (!shouldPublish) {\n897:         const finalizeSpan = telemetry?.span('commit.finalize', RESIDENCY.NATIVE);\n898:         database.exec('COMMIT');\n899:         finalizeSpan?.end(1);\n900:         if (options.embedder) {\n901:           const { drainVectorQueue } = await import('./vectors.mjs');\n902:           const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n903:           await drainVectorQueue(database, {\n904:             profileId: profile.id,\n905:             embedder: options.embedder,\n906:             limit: options.vectorDrainLimit,\n907:           });\n908:           drainSpan?.end(queued);\n909:         }\n910:         return {\n911:           ok: true,\n912:           generationHash,\n913:           published: false,\n914:           indexed: 0,\n915:           unchanged: parsedStyles.length,\n916:           quarantined: 0,\n917:           tombstoned: 0,\n918:           queued,\n919:         };\n920:       }\n921: \n922:       const missingSpan = telemetry?.span('publish.missing', RESIDENCY.NATIVE);\n923:       let quarantined = 0;\n924:       let tombstoned = 0;\n925:       for (const row of missingRows) {\n926:         const state = database.prepare(`\n927:           SELECT missing_observations FROM style_index_state WHERE style_rowid = ?\n928:         `).get(row.style_rowid);\n929:         const shouldTombstone = row.lifecycle_state === 'quarantined'\n930:           && (options.confirmMissing === true || Number(state?.missing_observations ?? 0) >= 1);\n931:         if (shouldTombstone) {\n932:           database.prepare(`\n933:             UPDATE styles SET lifecycle_state = 'tombstoned',\n934:               quarantine_at = COALESCE(quarantine_at, ?), tombstoned_at = ?, updated_at = ?\n935:             WHERE style_rowid = ?\n936:           `).run(timestamp, timestamp, timestamp, row.style_rowid);\n937:           tombstoned += 1;\n938:         } else if (row.lifecycle_state !== 'tombstoned') {\n939:           database.prepare(`\n940:             UPDATE styles SET lifecycle_state = 'quarantined', quarantine_at = ?,\n941:               tombstoned_at = NULL, updated_at = ? WHERE style_rowid = ?\n942:           `).run(timestamp, timestamp, row.style_rowid);\n943:           quarantined += 1;\n944:         }\n945:         database.prepare(`\n946:           UPDATE style_index_state\n947:           SET missing_observations = missing_observations + 1, last_success_at = ?\n948:           WHERE style_rowid = ?\n949:         `).run(timestamp, row.style_rowid);\n950:       }\n951:       missingSpan?.end(missingRows.length);\n952:       resolveRelationships(database);\n953: \n954:       const publishSpan = telemetry?.span('publish.write', RESIDENCY.NATIVE);\n955:       const counts = Object.fromEntries(database.prepare(`\n956:         SELECT lifecycle_state, COUNT(*) AS count FROM styles GROUP BY lifecycle_state\n957:       `).all().map((row) => [row.lifecycle_state, Number(row.count)]));\n958:       emit('PUBLISH', { generationHash });\n959:       database.prepare(`\n960:         INSERT OR IGNORE INTO corpus_generations(\n961:           generation_hash, parent_generation_hash, crawl_manifest_hash,\n962:           aggregate_corpus_hash, schema_version, active_style_count,\n963:           quarantined_style_count, tombstoned_style_count, created_at\n964:         ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n965:       `).run(\n966:         generationHash,\n967:         currentGeneration,\n968:         crawlManifestHash,\n969:         aggregateCorpusHash,\n970:         STYLE_DB_SCHEMA_VERSION,\n971:         counts.active ?? 0,\n972:         counts.quarantined ?? 0,\n973:         counts.tombstoned ?? 0,\n974:         timestamp,\n975:       );\n976:       database.prepare(`\n977:         INSERT INTO current_corpus_generation(singleton, generation_hash, published_at)\n978:         VALUES (1, ?, ?)\n979:         ON CONFLICT(singleton) DO UPDATE SET\n980:           generation_hash = excluded.generation_hash,\n981:           published_at = excluded.published_at\n982:       `).run(generationHash, timestamp);\n983:       database.prepare(`\n984:         UPDATE style_index_state SET last_success_generation = ?\n985:         WHERE style_rowid IN (SELECT style_rowid FROM styles WHERE lifecycle_state = 'active')\n986:       `).run(generationHash);\n987:       options.failureInjector?.({ phase: 'PUBLISH', database });\n988:       database.exec('COMMIT');\n989:       publishSpan?.end(changedStyles.length);\n990: \n991:       if (options.embedder) {\n992:         const { drainVectorQueue } = await import('./vectors.mjs');\n993:         const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n994:         await drainVectorQueue(database, {\n995:           profileId: profile.id,\n996:           embedder: options.embedder,\n997:           limit: options.vectorDrainLimit,\n998:         });\n999:         drainSpan?.end(changedStyles.length);\n1000:       }\n1001:       return {\n1002:         ok: true,\n1003:         generationHash,\n1004:         published: true,\n1005:         indexed: changedStyles.length,\n1006:         unchanged: parsedStyles.length - changedStyles.length,\n1007:         quarantined,\n1008:         tombstoned,\n1009:       };\n1010:     } catch (error) {\n1011:       database.exec('ROLLBACK');\n1012:       throw error;\n1013:     }\n1014:   } finally {\n1015:     overallTimer?.end();\n1016:     if (ownsDatabase) database.close();\n1017:   }\n1018: }\n1019: \n1020: /**\n1021:  * Build a complete database projection without making it a query side effect.\n1022:  *\n1023:  * @param {Object} options - The same controls as indexStyleCorpus.\n1024:  * @returns {Promise<Object>} Publication summary.\n1025:  */\n1026: async function writeGenerationPointer(\n1027:   databasePath,\n1028:   generationHash,\n1029:   databaseFile,\n1030:   afterRename,\n1031:   options = {},\n1032: ) {\n1033:   if (path.basename(databaseFile) !== databaseFile) {\n1034:     throw new TypeError('Generation database file must be a basename.');\n1035:   }\n1036:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n1037:   const artifactPath = path.join(path.dirname(databasePath), databaseFile);\n1038:   const { sha256, bytes } = await hashArtifactFile(artifactPath);\n1039:   const manifest = buildManifest({\n1040:     generationHash,\n1041:     createdAt: nowIso(),\n1042:     parentGenerationHash: options.parentGenerationHash ?? null,\n1043:     artifacts: { sqlite: { role: 'sqlite', file: databaseFile, sha256, bytes } },\n1044:   });\n1045:   await writeManifestPointer(pointerPath, manifest, { afterRename });\n1046: }\n1047: \n1048: export async function buildStyleDatabase(options) {\n1049:   if (options?.database) {\n1050:     const error = new Error('Full rebuild publication requires a databasePath, not an open connection.');\n1051:     error.code = 'staging-requires-database-path';\n1052:     throw error;\n1053:   }\n1054:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n1055:   const buildingPath = `${databasePath}.building-${process.pid}-${Date.now()}`;\n1056:   let generationPath = null;\n1057:   const removeSidecars = async (basePath) => {\n1058:     await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n1059:       rm(`${basePath}${suffix}`, { force: true })\n1060:     )));\n1061:   };\n1062:   await removeSidecars(buildingPath);\n1063:   try {\n1064:     const result = await indexStyleCorpus({\n1065:       ...options,\n1066:       databasePath: buildingPath,\n1067:       corpusWalkMode: options.corpusWalkMode ?? 'migration',\n1068:       verifyAll: true,\n1069:     });\n1070:     const staged = openStyleDatabase(buildingPath);\n1071:     try {\n1072:       const integrity = staged.prepare('PRAGMA integrity_check').get().integrity_check;\n1073:       const foreignKeyFailures = staged.prepare('PRAGMA foreign_key_check').all();\n1074:       const current = staged.prepare(`\n1075:         SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n1076:       `).get()?.generation_hash;\n1077:       if (integrity !== 'ok' || foreignKeyFailures.length > 0\n1078:         || current !== result.generationHash) {\n1079:         const error = new Error('Staged style database failed publication validation.');\n1080:         error.code = 'staging-validation-failed';\n1081:         throw error;\n1082:       }\n1083:       staged.prepare(`\n1084:         INSERT INTO style_fts(style_fts) VALUES ('integrity-check')\n1085:       `).run();\n1086:       staged.exec('PRAGMA wal_checkpoint(TRUNCATE)');\n1087:     } finally {\n1088:       staged.close();\n1089:     }\n1090:     const generationName = result.generationHash.replace(':', '-');\n1091:     const databaseFile = `${path.basename(databasePath)}.${generationName}`\n1092:       + `.${process.pid}-${Date.now()}.sqlite`;\n1093:     generationPath = path.join(path.dirname(databasePath), databaseFile);\n1094:     await removeSidecars(generationPath);\n1095:     await rename(buildingPath, generationPath);\n1096:     const immutableGenerationPath = generationPath;\n1097:     generationPath = null;\n1098:     const generationHandle = await open(immutableGenerationPath, 'r');\n1099:     try {\n1100:       await generationHandle.sync();\n1101:     } finally {\n1102:       await generationHandle.close();\n1103:     }\n1104:     const generationDirectory = await open(path.dirname(immutableGenerationPath), 'r');\n1105:     try {\n1106:       await generationDirectory.sync();\n1107:     } finally {\n1108:       await generationDirectory.close();\n1109:     }\n1110:     await writeGenerationPointer(\n1111:       databasePath,\n1112:       result.generationHash,\n1113:       databaseFile,\n1114:       options.failureInjector\n1115:         ? (details) => options.failureInjector({ phase: 'POINTER_RENAMED', ...details })\n1116:         : undefined,\n1117:     );\n1118:     return {\n1119:       ...result,\n1120:       databasePath,\n1121:       generationDatabasePath: path.join(path.dirname(databasePath), databaseFile),\n1122:     };\n1123:   } finally {\n1124:     await removeSidecars(buildingPath);\n1125:     if (generationPath) await removeSidecars(generationPath);\n1126:   }\n1127: }\n1128: \n1129: /**\n1130:  * Roll back by atomically repointing new readers to a retained generation file.\n1131:  *\n1132:  * @param {Object} options - Logical path and retained generation identity.\n1133:  * @param {string} options.databasePath - Logical database path.\n1134:  * @param {string} options.generationDatabasePath - Retained immutable database file.\n1135:  * @returns {Promise<Object>} Restored generation pointer details.\n1136:  */\n1137: export async function rollbackStyleDatabase(options) {\n1138:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n1139:   const generationDatabasePath = options?.generationDatabasePath;\n1140:   if (!generationDatabasePath\n1141:     || path.dirname(path.resolve(generationDatabasePath)) !== path.dirname(path.resolve(databasePath))) {\n1142:     const error = new Error('Rollback generation must be retained beside the logical database path.');\n1143:     error.code = 'rollback-generation-invalid';\n1144:     throw error;\n1145:   }\n1146:   try {\n1147:     const retainedInfo = await stat(generationDatabasePath);\n1148:     if (!retainedInfo.isFile()) throw new Error('not a file');\n1149:     const databaseDirectoryRealPath = await realpath(path.dirname(databasePath));\n1150:     const retainedRealPath = await realpath(generationDatabasePath);\n1151:     if (!isContained(databaseDirectoryRealPath, retainedRealPath)) {\n1152:       throw new Error('generation escapes database directory');\n1153:     }\n1154:   } catch (cause) {\n1155:     const error = new Error('Rollback generation is unavailable.', { cause });\n1156:     error.code = 'rollback-generation-invalid';\n1157:     throw error;\n1158:   }\n1159:   const retained = openStyleDatabase(generationDatabasePath);\n1160:   let generationHash;\n1161:   try {\n1162:     const integrity = retained.prepare('PRAGMA integrity_check').get().integrity_check;\n1163:     generationHash = retained.prepare(`\n1164:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n1165:     `).get()?.generation_hash;\n1166:     if (integrity !== 'ok' || !generationHash) {\n1167:       const error = new Error('Rollback generation failed validation.');\n1168:       error.code = 'rollback-generation-invalid';\n1169:       throw error;\n1170:     }\n1171:   } finally {\n1172:     retained.close();\n1173:   }\n1174:   await writeGenerationPointer(\n1175:     databasePath,\n1176:     generationHash,\n1177:     path.basename(generationDatabasePath),\n1178:   );\n1179:   return { databasePath, generationDatabasePath, generationHash };\n1180: }\n1181: \n1182: export const indexerInternals = Object.freeze({\n1183:   computeAggregateHash,\n1184:   computeGenerationHash,\n1185:   normalizeMarkdown,\n1186:   parseStyle,\n1187: });\n\n(End of file - total 1187 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Incremental Style Database Indexer                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport {\n  lstat,\n  open,\n  readFile,\n  readdir,\n  realpath,\n  rename,\n  rm,\n  stat,\n} from 'node:fs/promises';\nimport path from 'node:path';\n\nimport {\n  compareRawStrings,\n  digest,\n  lengthFrame,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Incremental Style Database Indexer                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport {\n  lstat,\n  open,\n  readFile,\n  readdir,\n  realpath,\n  rename,\n  rm,\n  stat,\n} from 'node:fs/promises';\nimport path from 'node:path';\n\nimport {\n  compareRawStrings,\n  digest,\n  lengthFrame,\n  stableJson,\n} from './canonical.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  writeManifestPointer,\n} from './generation-manifest.mjs';\nimport {\n  RESIDENCY,\n} from './stage-telemetry.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  STYLE_DB_SCHEMA_VERSION,\n  STYLE_DATABASE_POINTER_SUFFIX,\n  openStyleDatabase,\n} from './schema.mjs';\n\nexport const INDEXER_LIFECYCLE = Object.freeze([\n  'DISCOVER',\n  'VERIFY',\n  'PARSE_VALIDATE',\n  'COMMIT',\n  'VECTOR_DRAIN',\n  'PUBLISH',\n]);\nexport const DEFAULT_EMBEDDING_PROFILE = 'style-default-v1';\n\nconst AGGREGATE_HASH_VERSION = 'style-all-artifacts-v2';\nconst RETRIEVAL_HASH_VERSION = 'style-retrieval-document-v1';\nconst GENERATION_HASH_VERSION = 'style-corpus-generation-v2';\nconst LICENSE_ALLOWLIST = new Set(['allowed', 'licensed', 'public-domain']);\nconst RESTRICTED_LICENSE_PATTERN = /\\b(unlicensed trial|license[- ]restricted)\\b/i;\nconst WARM_SURFACE_PATTERN = /\\b(warm|cream|beige|bone|ivory|linen|sand|tan)\\b/i;\nconst MOTION_PATTERN = /\\b(motion|animation|animated|transition|kinetic|scroll)\\b/i;\nconst SERIF_PATTERN = /(^|[^a-z])serif([^a-z]|$)/i;\nconst SANS_SERIF_PATTERN = /sans[- ]serif/i;\n\nfunction nowIso() {\n  return new Date().toISOString();\n}\n\nfunction normalizeTerm(value) {\n  return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n}\n\nfunction normalizeMarkdown(value) {\n  return String(value ?? '').normalize('NFC').replace(/\\r\\n?/g, '\\n')\n    .split('\\n').map((line) => line.trimEnd()).join('\\n').trimEnd();\n}\n\nfunction artifactRole(fileName) {\n  if (fileName.endsWith('-canonical.json')) return 'canonical';\n  if (fileName === 'design-tokens.json') return 'tokens';\n  if (fileName === 'DESIGN.md') return 'design';\n  if (fileName === 'source.md') return 'source';\n  if (fileName === 'css-variables.css') return 'css-variables';\n  if (fileName === 'tailwind-v4.css') return 'tailwind';\n  return null;\n}\n\nfunction isContained(rootPath, candidatePath) {\n  const relative = path.relative(rootPath, candidatePath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction parseJson(artifact, label) {\n  if (!artifact) return {};\n  try {\n    return JSON.parse(artifact.buffer.toString('utf8'));\n  } catch (error) {\n    const invalid = new Error(`Invalid ${label} JSON: ${artifact.relativePath}`, { cause: error });\n    invalid.code = 'invalid-artifact';\n    throw invalid;\n  }\n}\n\nfunction countTokenLeaves(value) {\n  if (!value || typeof value !== 'object') return 0;\n  if (Object.hasOwn(value, '$value')) return 1;\n  return Object.values(value).reduce((sum, child) => sum + countTokenLeaves(child), 0);\n}\n\nfunction deriveTokenAxes(tokens, designSystem) {\n  const counts = new Map();\n  for (const [axis, value] of Object.entries(tokens ?? {})) {\n    const count = countTokenLeaves(value);\n    if (count > 0) counts.set(axis, count);\n  }\n  const fallbackCounts = {\n    color: Array.isArray(designSystem.colors) ? designSystem.colors.length : 0,\n    spacing: designSystem.spacing ? Object.keys(designSystem.spacing).length : 0,\n    typography: Array.isArray(designSystem.typography) ? designSystem.typography.length : 0,\n  };\n  for (const [axis, count] of Object.entries(fallbackCounts)) {\n    if (count > 0 && !counts.has(axis)) counts.set(axis, count);\n  }\n  return [...counts].map(([axis, count]) => ({ axis, count }))\n    .sort((left, right) => compareRawStrings(left.axis, right.axis));\n}\n\nfunction deriveSections(designMarkdown) {\n  const sections = [];\n  for (const [index, line] of designMarkdown.split('\\n').entries()) {\n    const match = /^##\\s+(.+?)\\s*$/.exec(line);\n    if (match) sections.push({ name: match[1], line: index + 1 });\n  }\n  return sections;\n}\n\nfunction deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus) {\n  const values = new Set();\n  if (tokenAxes.length > 0) values.add('tokens');\n  if ((designSystem.components?.length ?? 0) > 0) values.add('components');\n  if (designSystem.layout) values.add('layout');\n  if (designSystem.imagery) values.add('imagery');\n  if (designSystem.spacing) values.add('spacing');\n  if ((designSystem.dos?.length ?? 0) + (designSystem.donts?.length ?? 0) > 0) {\n    values.add('constraints');\n  }\n  if (provenanceStatus === 'known') values.add('provenance');\n  if (sections.some((section) => MOTION_PATTERN.test(section.name))) values.add('motion');\n  return [...values].sort(compareRawStrings);\n}\n\nfunction deriveFacets(style, designSystem, capabilities, tokenAxes, searchableText, licenseStatus) {\n  const values = new Set(capabilities);\n  for (const { axis } of tokenAxes) values.add(axis);\n  if (designSystem.theme) values.add(normalizeTerm(designSystem.theme));\n  if (designSystem.industry) values.add(normalizeTerm(designSystem.industry));\n  if (SERIF_PATTERN.test(searchableText) && !SANS_SERIF_PATTERN.test(searchableText)) {\n    values.add('serif-role');\n  }\n  if (WARM_SURFACE_PATTERN.test(searchableText)) values.add('warm-surface');\n  if (MOTION_PATTERN.test(searchableText)) values.add('motion');\n  if (licenseStatus === 'restricted') values.add('license-restricted');\n  values.add(normalizeTerm(style.slug));\n  return [...values].filter(Boolean).sort(compareRawStrings);\n}\n\nfunction excerpt(value, maxLength = 240) {\n  const normalized = String(value ?? '').replace(/\\s+/g, ' ').trim();\n  if (normalized.length <= maxLength) return normalized;\n  return `${normalized.slice(0, maxLength - 1).trimEnd()}…`;\n}\n\nfunction computeAggregateHash(styleId, artifacts) {\n  const parts = [\n    ...lengthFrame(AGGREGATE_HASH_VERSION),\n    ...lengthFrame(styleId),\n  ];\n  for (const artifact of artifacts.slice()\n    .sort((left, right) => compareRawStrings(left.role, right.role))) {\n    parts.push(...lengthFrame(artifact.role), ...lengthFrame(artifact.buffer));\n  }\n  return digest(parts);\n}\n\nfunction computeHintHash(artifacts) {\n  return digest([\n    'style-artifact-hints-v1\\0',\n    ...artifacts.map((artifact) => (\n      `${artifact.relativePath}\\0${artifact.byteLength}\\0${artifact.mtimeNs}\\0${artifact.ctimeNs}\\n`\n    )),\n  ]);\n}\n\nfunction computeCrawlRecordHash(crawlRecord) {\n  return digest([\n    'style-crawl-record-v1\\0',\n    stableJson(crawlRecord ?? null),\n  ]);\n}\n\nfunction computeGenerationHash(crawlManifestHash, styles, inactiveStates = []) {\n  const parts = [\n    ...lengthFrame(GENERATION_HASH_VERSION),\n    ...lengthFrame(STYLE_DB_SCHEMA_VERSION),\n    ...lengthFrame(crawlManifestHash),\n  ];\n  for (const style of styles.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n    parts.push(...lengthFrame(style.id), ...lengthFrame(style.aggregateHash));\n  }\n  for (const style of inactiveStates.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n    parts.push(...lengthFrame(style.id), ...lengthFrame(style.state));\n  }\n  return digest(parts);\n}\n\nasync function readVerifiedArtifacts(corpusRoot, corpusRealPath, slug) {\n  const styleRoot = path.join(corpusRoot, slug);\n  const entries = (await readdir(styleRoot, { withFileTypes: true }))\n    .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const artifacts = [];\n  for (const entry of entries) {\n    const role = artifactRole(entry.name);\n    if (!role) {\n      const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n      error.code = 'invalid-artifact';\n      throw error;\n    }\n    const candidatePath = path.join(styleRoot, entry.name);\n    const linkInfo = await lstat(candidatePath, { bigint: true });\n    if (!linkInfo.isFile() && !linkInfo.isSymbolicLink()) continue;\n    const artifactRealPath = await realpath(candidatePath);\n    if (!isContained(corpusRealPath, artifactRealPath)) {\n      const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n      error.code = 'path-escape';\n      throw error;\n    }\n    const before = await stat(artifactRealPath, { bigint: true });\n    const buffer = await readFile(artifactRealPath);\n    const after = await stat(artifactRealPath, { bigint: true });\n    if (before.size !== after.size || before.mtimeNs !== after.mtimeNs || before.ctimeNs !== after.ctimeNs) {\n      const error = new Error(`Corpus changed while reading ${slug}/${entry.name}.`);\n      error.code = 'corpus-changing';\n      throw error;\n    }\n    artifacts.push({\n      role,\n      relativePath: `${slug}/${entry.name}`,\n      byteLength: buffer.byteLength,\n      sha256: digest([buffer]),\n      mtimeNs: String(after.mtimeNs),\n      ctimeNs: String(after.ctimeNs),\n      buffer,\n    });\n  }\n  if (!artifacts.some((artifact) => artifact.role === 'canonical')\n    || !artifacts.some((artifact) => artifact.role === 'design')) {\n    const error = new Error(`Style ${slug} lacks its canonical JSON or DESIGN.md artifact.`);\n    error.code = 'invalid-artifact';\n    throw error;\n  }\n  return artifacts;\n}\n\nasync function readArtifactHints(corpusRoot, corpusRealPath, slug) {\n  const styleRoot = path.join(corpusRoot, slug);\n  const entries = (await readdir(styleRoot, { withFileTypes: true }))\n    .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const artifacts = [];\n  for (const entry of entries) {\n    const role = artifactRole(entry.name);\n    if (!role) {\n      const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n      error.code = 'invalid-artifact';\n      throw error;\n    }\n    const candidatePath = path.join(styleRoot, entry.name);\n    const artifactRealPath = await realpath(candidatePath);\n    if (!isContained(corpusRealPath, artifactRealPath)) {\n      const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n      error.code = 'path-escape';\n      throw error;\n    }\n    const fileInfo = await stat(artifactRealPath, { bigint: true });\n    artifacts.push({\n      role,\n      relativePath: `${slug}/${entry.name}`,\n      byteLength: Number(fileInfo.size),\n      mtimeNs: String(fileInfo.mtimeNs),\n      ctimeNs: String(fileInfo.ctimeNs),\n    });\n  }\n  return artifacts;\n}\n\nfunction parseStyle(slug, crawlRecord, artifacts) {\n  const canonical = parseJson(artifacts.find((artifact) => artifact.role === 'canonical'), 'canonical');\n  const tokens = parseJson(artifacts.find((artifact) => artifact.role === 'tokens'), 'token');\n  const designMarkdown = normalizeMarkdown(\n    artifacts.find((artifact) => artifact.role === 'design')?.buffer.toString('utf8'),\n  );\n  const designSystem = canonical.designSystem ?? {};\n  const id = canonical.uuid ?? crawlRecord?.uuid;\n  if (typeof id !== 'string' || id.length === 0) {\n    const error = new Error(`Style ${slug} has no stable UUID.`);\n    error.code = 'invalid-artifact';\n    throw error;\n  }\n  const title = excerpt(canonical.name ?? slug, 120);\n  const thesis = excerpt(canonical.northStar ?? designSystem.northStar ?? designSystem.description);\n  const theme = designSystem.theme == null ? null : String(designSystem.theme);\n  const industry = designSystem.industry == null ? null : String(designSystem.industry);\n  const sections = deriveSections(designMarkdown);\n  const tokenAxes = deriveTokenAxes(tokens, designSystem);\n  const provenanceStatus = canonical.source && canonical.uuid && canonical.meta?.url\n    ? 'known'\n    : 'missing';\n  const searchableText = [\n    title,\n    thesis,\n    designSystem.description,\n    theme,\n    industry,\n    designSystem.layout,\n    designSystem.imagery,\n    ...(Array.isArray(designSystem.typography)\n      ? designSystem.typography.map((entry) => `${entry.family ?? ''} ${entry.role ?? ''}`)\n      : []),\n    designMarkdown.slice(0, 65_536),\n  ].join(' ');\n  const licenseStatus = RESTRICTED_LICENSE_PATTERN.test(searchableText)\n    ? 'restricted'\n    : String(canonical.license?.status ?? 'unknown');\n  const rightsKnown = LICENSE_ALLOWLIST.has(licenseStatus) || licenseStatus === 'restricted';\n  const capabilities = deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus);\n  const facets = deriveFacets(\n    { slug },\n    designSystem,\n    capabilities,\n    tokenAxes,\n    searchableText,\n    licenseStatus,\n  );\n  const retrievalDocument = {\n    id,\n    title,\n    thesis,\n    theme,\n    industry,\n    capabilities,\n    facets,\n    tokenAxes,\n    sections: sections.map((section) => section.name),\n    designMarkdown,\n  };\n  const retrievalJson = stableJson(retrievalDocument);\n  const retrievalHash = digest([\n    ...lengthFrame(RETRIEVAL_HASH_VERSION),\n    ...lengthFrame(retrievalJson),\n  ]);\n  const aggregateHash = computeAggregateHash(id, artifacts);\n  return {\n    id,\n    slug,\n    crawlStatus: crawlRecord?.status ?? 'unknown',\n    title,\n    thesis,\n    theme,\n    industry,\n    aggregateHash,\n    artifactHintHash: computeHintHash(artifacts),\n    crawlRecordHash: computeCrawlRecordHash(crawlRecord),\n    retrievalHash,\n    artifacts,\n    tokenAxes,\n    sections,\n    capabilities,\n    facets,\n    provenance: {\n      status: provenanceStatus,\n      sourceUrl: canonical.source ?? crawlRecord?.url ?? null,\n      originalUrl: canonical.meta?.url ?? null,\n      screenshotUrl: canonical.screenshot?.url ?? null,\n      uuid: canonical.uuid ?? crawlRecord?.uuid ?? null,\n      capturedAt: canonical.capturedAt ?? crawlRecord?.capturedAt ?? null,\n      licenseStatus,\n      rightsKnown,\n      evidenceScope: ['reference', 'rationale'],\n    },\n    relationships: (Array.isArray(designSystem.similar) ? designSystem.similar : [])\n      .map((relationship, ordinal) => ({\n        ordinal,\n        rawTargetLabel: String(relationship.business ?? relationship.name ?? '').trim(),\n        rationale: String(relationship.why ?? relationship.rationale ?? '').trim(),\n      })).filter((relationship) => relationship.rawTargetLabel),\n    retrievalDocument: {\n      title,\n      thesis,\n      theme: theme ?? '',\n      industry: industry ?? '',\n      terms: [...new Set([...facets, ...capabilities, ...tokenAxes.map(({ axis }) => axis)])]\n        .sort(compareRawStrings).join(' '),\n      body: designMarkdown,\n      documentJson: retrievalJson,\n      retrievalHash,\n    },\n  };\n}\n\nfunction replaceStyleChildren(database, styleRowid, style, timestamp) {\n  for (const table of [\n    'style_provenance',\n    'style_artifacts',\n    'style_terms',\n    'style_token_axes',\n    'style_sections',\n    'retrieval_documents',\n    'style_relationships',\n  ]) {\n    const key = table === 'style_relationships' ? 'source_style_rowid' : 'style_rowid';\n    database.prepare(`DELETE FROM ${table} WHERE ${key} = ?`).run(styleRowid);\n  }\n  database.prepare(`\n    INSERT INTO style_provenance(\n      style_rowid, status, source_url, original_url, screenshot_url, source_uuid,\n      captured_at, license_status, rights_known, evidence_scope_json\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    styleRowid,\n    style.provenance.status,\n    style.provenance.sourceUrl,\n    style.provenance.originalUrl,\n    style.provenance.screenshotUrl,\n    style.provenance.uuid,\n    style.provenance.capturedAt,\n    style.provenance.licenseStatus,\n    style.provenance.rightsKnown ? 1 : 0,\n    JSON.stringify(style.provenance.evidenceScope),\n  );\n  const insertArtifact = database.prepare(`\n    INSERT INTO style_artifacts(\n      style_rowid, role, relative_path, byte_length, sha256, mtime_ns, ctime_ns\n    ) VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n  for (const artifact of style.artifacts) {\n    insertArtifact.run(\n      styleRowid,\n      artifact.role,\n      artifact.relativePath,\n      artifact.byteLength,\n      artifact.sha256,\n      artifact.mtimeNs,\n      artifact.ctimeNs,\n    );\n  }\n  const insertTerm = database.prepare(\n    'INSERT INTO style_terms(style_rowid, term_type, term) VALUES (?, ?, ?)',\n  );\n  for (const term of style.facets) insertTerm.run(styleRowid, 'facet', term);\n  for (const term of style.capabilities) insertTerm.run(styleRowid, 'capability', term);\n  const insertAxis = database.prepare(\n    'INSERT INTO style_token_axes(style_rowid, axis, token_count) VALUES (?, ?, ?)',\n  );\n  for (const axis of style.tokenAxes) insertAxis.run(styleRowid, axis.axis, axis.count);\n  const insertSection = database.prepare(`\n    INSERT INTO style_sections(style_rowid, ordinal, name, line_number) VALUES (?, ?, ?, ?)\n  `);\n  for (const [ordinal, section] of style.sections.entries()) {\n    insertSection.run(styleRowid, ordinal, section.name, section.line);\n  }\n  const document = style.retrievalDocument;\n  database.prepare(`\n    INSERT INTO retrieval_documents(\n      style_rowid, title, thesis, theme, industry, terms, body, document_json, retrieval_hash\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    styleRowid,\n    document.title,\n    document.thesis,\n    document.theme,\n    document.industry,\n    document.terms,\n    document.body,\n    document.documentJson,\n    document.retrievalHash,\n  );\n  const insertRelationship = database.prepare(`\n    INSERT INTO style_relationships(\n      source_style_rowid, ordinal, raw_target_label, target_style_rowid,\n      rationale, resolution_state, confidence\n    ) VALUES (?, ?, ?, NULL, ?, 'unresolved', 0)\n  `);\n  for (const relationship of style.relationships) {\n    insertRelationship.run(\n      styleRowid,\n      relationship.ordinal,\n      relationship.rawTargetLabel,\n      relationship.rationale,\n    );\n  }\n  database.prepare(`\n    INSERT INTO style_index_state(\n      style_rowid, artifact_hint_hash, crawl_record_hash, aggregate_hash,\n      last_success_generation, last_success_at, missing_observations\n    ) VALUES (?, ?, ?, ?, ?, ?, 0)\n    ON CONFLICT(style_rowid) DO UPDATE SET\n      artifact_hint_hash = excluded.artifact_hint_hash,\n      crawl_record_hash = excluded.crawl_record_hash,\n      aggregate_hash = excluded.aggregate_hash,\n      last_success_generation = excluded.last_success_generation,\n      last_success_at = excluded.last_success_at,\n      missing_observations = 0\n  `).run(\n    styleRowid,\n    style.artifactHintHash,\n    style.crawlRecordHash,\n    style.aggregateHash,\n    '',\n    timestamp,\n  );\n}\n\nfunction resolveRelationships(database) {\n  const aliases = new Map();\n  for (const style of database.prepare(`\n    SELECT style_rowid, slug, title FROM styles WHERE lifecycle_state = 'active'\n  `).all()) {\n    for (const alias of [style.slug, style.title]) {\n      const key = normalizeTerm(alias);\n      if (!aliases.has(key)) aliases.set(key, []);\n      aliases.get(key).push(Number(style.style_rowid));\n    }\n  }\n  const update = database.prepare(`\n    UPDATE style_relationships\n    SET target_style_rowid = ?, resolution_state = ?, confidence = ?\n    WHERE relationship_id = ?\n  `);\n  for (const relationship of database.prepare(`\n    SELECT relationship_id, raw_target_label FROM style_relationships\n  `).all()) {\n    const matches = [...new Set(aliases.get(normalizeTerm(relationship.raw_target_label)) ?? [])];\n    if (matches.length === 1) update.run(matches[0], 'resolved', 1, relationship.relationship_id);\n    else if (matches.length > 1) update.run(null, 'ambiguous', 0.5, relationship.relationship_id);\n    else update.run(null, 'unresolved', 0, relationship.relationship_id);\n  }\n}\n\nfunction ensureEmbeddingProfile(database, profile, timestamp) {\n  const existing = database.prepare(`\n    SELECT provider, model, dimensions, config_hash\n    FROM embedding_profiles WHERE profile_id = ?\n  `).get(profile.id);\n  if (existing && (\n    existing.provider !== profile.provider\n    || existing.model !== profile.model\n    || existing.config_hash !== profile.configHash\n    || (existing.dimensions != null && profile.dimensions != null\n      && Number(existing.dimensions) !== profile.dimensions)\n  )) {\n    const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n    error.code = 'embedding-profile-conflict';\n    throw error;\n  }\n  if (existing) return;\n  database.prepare(`\n    INSERT INTO embedding_profiles(\n      profile_id, provider, model, dimensions, config_hash, created_at\n    ) VALUES (?, ?, ?, ?, ?, ?)\n  `).run(\n    profile.id,\n    profile.provider,\n    profile.model,\n    profile.dimensions ?? null,\n    profile.configHash,\n    timestamp,\n  );\n}\n\nfunction enqueueVector(database, styleRowid, retrievalHash, profileId, timestamp) {\n  database.prepare(`\n    UPDATE style_vector_jobs\n    SET status = 'superseded', updated_at = ?\n    WHERE style_rowid = ? AND profile_id = ?\n      AND retrieval_hash != ? AND status IN ('pending', 'running', 'failed')\n  `).run(timestamp, styleRowid, profileId, retrievalHash);\n  database.prepare(`\n    UPDATE style_vector_jobs\n    SET status = 'pending', updated_at = ?, last_error = NULL, next_attempt_at = NULL\n    WHERE style_rowid = ? AND retrieval_hash = ? AND profile_id = ?\n      AND status = 'completed'\n      AND NOT EXISTS (\n        SELECT 1 FROM style_vectors v\n        WHERE v.style_rowid = style_vector_jobs.style_rowid\n          AND v.retrieval_hash = style_vector_jobs.retrieval_hash\n          AND v.profile_id = style_vector_jobs.profile_id\n      )\n  `).run(timestamp, styleRowid, retrievalHash, profileId);\n  database.prepare(`\n    INSERT INTO style_vector_jobs(\n      style_rowid, retrieval_hash, profile_id, status, created_at, updated_at\n    ) VALUES (?, ?, ?, 'pending', ?, ?)\n    ON CONFLICT(style_rowid, retrieval_hash, profile_id) DO UPDATE SET\n      status = CASE\n        WHEN style_vector_jobs.status = 'completed' THEN 'completed'\n        ELSE 'pending'\n      END,\n      updated_at = excluded.updated_at,\n      last_error = NULL\n  `).run(styleRowid, retrievalHash, profileId, timestamp, timestamp);\n}\n\n/**\n * Incrementally project an authoritative flat-file corpus into SQLite.\n *\n * @param {Object} options - Indexing controls.\n * @param {string} options.corpusRoot - Authoritative style corpus root.\n * @param {string} [options.databasePath] - SQLite destination when no connection is supplied.\n * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n * @param {'migration'|'rollback'} options.corpusWalkMode - Explicit filesystem-walk grant.\n * @param {boolean} [options.confirmMissing=false] - Confirm quarantined absences as tombstones.\n * @param {boolean} [options.verifyAll=false] - Bypass metadata hints and hash every bundle.\n * @param {Function} [options.onStage] - Lifecycle observation hook.\n * @param {Function} [options.failureInjector] - Test-only crash hook inside the transaction.\n * @param {Object} [options.embeddingProfile] - Profile metadata for queued vectors.\n * @param {Function} [options.embedder] - Optional asynchronous embedding callback.\n * @returns {Promise<Object>} Publication and incremental-change summary.\n */\nexport async function indexStyleCorpus(options) {\n  if (!options?.corpusRoot || !['migration', 'rollback'].includes(options.corpusWalkMode)) {\n    const error = new Error('Corpus walking requires explicit migration or rollback mode.');\n    error.code = 'corpus-walk-forbidden';\n    throw error;\n  }\n  const database = options.database ?? openStyleDatabase(\n    options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n  );\n  const ownsDatabase = !options.database;\n  const telemetry = options.telemetry ?? null;\n  const overallTimer = telemetry?.overall() ?? null;\n  const emit = (stage, details = {}) => {\n    options.onStage?.(stage, details);\n  };\n  const profile = {\n    id: options.embeddingProfile?.id ?? DEFAULT_EMBEDDING_PROFILE,\n    provider: options.embeddingProfile?.provider ?? 'external',\n    model: options.embeddingProfile?.model ?? 'configured',\n    dimensions: options.embeddingProfile?.dimensions ?? null,\n    configHash: options.embeddingProfile?.configHash ?? 'style-default-v1',\n  };\n  try {\n    emit('DISCOVER');\n    const discoverSpan = telemetry?.span('discover', RESIDENCY.JS_RESIDENT);\n    const corpusRealPath = await realpath(options.corpusRoot);\n    const crawlPath = path.join(options.corpusRoot, '_manifest.json');\n    const crawlRealPath = await realpath(crawlPath);\n    if (!isContained(corpusRealPath, crawlRealPath)) {\n      const error = new Error('Crawl manifest escapes the corpus root.');\n      error.code = 'path-escape';\n      throw error;\n    }\n    const crawlBuffer = await readFile(crawlRealPath);\n    const crawlManifestHash = digest([crawlBuffer]);\n    const crawlRecords = JSON.parse(crawlBuffer.toString('utf8'));\n    const crawlBySlug = new Map(crawlRecords.map((record) => [record.slug, record]));\n    const entries = await readdir(options.corpusRoot, { withFileTypes: true });\n    const slugs = entries.filter((entry) => entry.isDirectory() && !entry.name.startsWith('_'))\n      .map((entry) => entry.name).sort(compareRawStrings);\n    discoverSpan?.end(slugs.length);\n    const snapshotSpan = telemetry?.span('snapshot.load', RESIDENCY.NATIVE);\n    const currentRows = database.prepare(`\n      SELECT s.style_rowid, s.style_id, s.slug, s.crawl_status, s.aggregate_hash,\n        s.retrieval_hash, s.lifecycle_state, i.artifact_hint_hash, i.crawl_record_hash\n      FROM styles s\n      LEFT JOIN style_index_state i ON i.style_rowid = s.style_rowid\n    `).all();\n    snapshotSpan?.end(currentRows.length);\n    const currentBySlug = new Map(currentRows.map((row) => [row.slug, row]));\n    const verifySpan = telemetry?.span('verify.parse', RESIDENCY.JS_RESIDENT);\n    const discovered = [];\n    let candidateCount = 0;\n    for (const slug of slugs) {\n      const crawlRecord = crawlBySlug.get(slug);\n      const crawlRecordHash = computeCrawlRecordHash(crawlRecord);\n      const hints = await readArtifactHints(options.corpusRoot, corpusRealPath, slug);\n      const artifactHintHash = computeHintHash(hints);\n      const current = currentBySlug.get(slug);\n      const needsVerification = options.verifyAll === true\n        || !current\n        || current.lifecycle_state !== 'active'\n        || current.artifact_hint_hash !== artifactHintHash\n        || current.crawl_record_hash !== crawlRecordHash;\n      if (needsVerification) {\n        candidateCount += 1;\n        const artifacts = await readVerifiedArtifacts(options.corpusRoot, corpusRealPath, slug);\n        discovered.push({\n          slug,\n          crawlRecord,\n          artifactHintHash,\n          crawlRecordHash,\n          style: parseStyle(slug, crawlRecord, artifacts),\n        });\n      } else {\n        discovered.push({\n          slug,\n          crawlRecord,\n          artifactHintHash,\n          crawlRecordHash,\n          style: {\n            id: current.style_id,\n            slug,\n            crawlStatus: current.crawl_status,\n            aggregateHash: current.aggregate_hash,\n            retrievalHash: current.retrieval_hash,\n          },\n        });\n      }\n    }\n    verifySpan?.end(candidateCount);\n    emit('VERIFY', { discovered: slugs.length, candidates: candidateCount });\n    emit('PARSE_VALIDATE', { verified: candidateCount });\n    const planSpan = telemetry?.span('plan.hash', RESIDENCY.JS_RESIDENT);\n    const parsedStyles = discovered.map((entry) => entry.style);\n    if (new Set(parsedStyles.map((style) => style.id)).size !== parsedStyles.length) {\n      const error = new Error('The corpus contains duplicate style UUIDs.');\n      error.code = 'duplicate-style-id';\n      throw error;\n    }\n    const currentById = new Map(currentRows.map((row) => [row.style_id, row]));\n    const verifiedStyles = discovered.filter((entry) => entry.style.artifacts)\n      .map((entry) => entry.style);\n    const changedStyles = verifiedStyles.filter((style) => {\n      const current = currentById.get(style.id);\n      return !current\n        || current.slug !== style.slug\n        || current.crawl_status !== style.crawlStatus\n        || current.aggregate_hash !== style.aggregateHash\n        || current.crawl_record_hash !== style.crawlRecordHash\n        || current.lifecycle_state !== 'active';\n    });\n    const changedIds = new Set(changedStyles.map((style) => style.id));\n    const hintOnlyStyles = verifiedStyles.filter((style) => !changedIds.has(style.id));\n    const discoveredIds = new Set(parsedStyles.map((style) => style.id));\n    const absentRows = currentRows.filter((row) => !discoveredIds.has(row.style_id));\n    const missingRows = absentRows.filter((row) => row.lifecycle_state !== 'tombstoned');\n    const inactiveStates = absentRows.map((row) => ({\n      id: row.style_id,\n      state: row.lifecycle_state === 'active' ? 'quarantined' : 'tombstoned',\n    }));\n    const generationHash = computeGenerationHash(\n      crawlManifestHash,\n      parsedStyles,\n      inactiveStates,\n    );\n    const aggregateCorpusHash = digest([\n      'style-corpus-aggregate-v1\\0',\n      ...parsedStyles.slice().sort((left, right) => compareRawStrings(left.id, right.id))\n        .map((style) => `${style.id}\\0${style.aggregateHash}\\n`),\n    ]);\n    const timestamp = nowIso();\n    planSpan?.end(parsedStyles.length);\n    const planLoadSpan = telemetry?.span('plan.load', RESIDENCY.NATIVE);\n    const currentGeneration = database.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash ?? null;\n    const profileRow = database.prepare(`\n      SELECT provider, model, dimensions, config_hash\n      FROM embedding_profiles WHERE profile_id = ?\n    `).get(profile.id);\n    if (profileRow && (\n      profileRow.provider !== profile.provider\n      || profileRow.model !== profile.model\n      || profileRow.config_hash !== profile.configHash\n      || (profileRow.dimensions != null && profile.dimensions != null\n        && Number(profileRow.dimensions) !== profile.dimensions)\n    )) {\n      const error = new Error(`Embedding profile identity conflict: ${profile.id}`);\n      error.code = 'embedding-profile-conflict';\n      throw error;\n    }\n    const missingProfileJobs = profileRow ? Number(database.prepare(`\n      SELECT COUNT(*) AS count FROM styles s\n      WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n        SELECT 1 FROM style_vector_jobs j\n        WHERE j.style_rowid = s.style_rowid\n          AND j.retrieval_hash = s.retrieval_hash\n          AND j.profile_id = ?\n          AND j.status != 'superseded'\n          AND (j.status != 'completed' OR EXISTS (\n            SELECT 1 FROM style_vectors v\n            WHERE v.style_rowid = j.style_rowid\n              AND v.retrieval_hash = j.retrieval_hash\n              AND v.profile_id = j.profile_id\n          ))\n      )\n    `).get(profile.id).count) : parsedStyles.length;\n    planLoadSpan?.end(1);\n    const needsVectorQueue = !profileRow || missingProfileJobs > 0 || changedStyles.length > 0;\n    const shouldPublish = changedStyles.length > 0\n      || missingRows.length > 0\n      || currentGeneration !== generationHash;\n    if (!shouldPublish && hintOnlyStyles.length === 0 && !needsVectorQueue) {\n      return {\n        ok: true,\n        generationHash,\n        published: false,\n        indexed: 0,\n        unchanged: parsedStyles.length,\n        quarantined: 0,\n        tombstoned: 0,\n      };\n    }\n\n    database.exec('BEGIN IMMEDIATE');\n    try {\n      emit('COMMIT', {\n        changed: changedStyles.length,\n        hintOnly: hintOnlyStyles.length,\n        missing: missingRows.length,\n      });\n      const commitSpan = telemetry?.span('commit.write', RESIDENCY.NATIVE);\n      ensureEmbeddingProfile(database, profile, timestamp);\n      const upsertStyle = database.prepare(`\n        INSERT INTO styles(\n          style_id, slug, lifecycle_state, crawl_status, title, thesis, theme,\n          industry, aggregate_hash, retrieval_hash, quarantine_at, tombstoned_at,\n          created_at, updated_at\n        ) VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?, ?, NULL, NULL, ?, ?)\n        ON CONFLICT(style_id) DO UPDATE SET\n          slug = excluded.slug,\n          lifecycle_state = 'active',\n          crawl_status = excluded.crawl_status,\n          title = excluded.title,\n          thesis = excluded.thesis,\n          theme = excluded.theme,\n          industry = excluded.industry,\n          aggregate_hash = excluded.aggregate_hash,\n          retrieval_hash = excluded.retrieval_hash,\n          quarantine_at = NULL,\n          tombstoned_at = NULL,\n          updated_at = excluded.updated_at\n      `);\n      for (const [index, style] of changedStyles.entries()) {\n        upsertStyle.run(\n          style.id,\n          style.slug,\n          style.crawlStatus,\n          style.title,\n          style.thesis,\n          style.theme,\n          style.industry,\n          style.aggregateHash,\n          style.retrievalHash,\n          timestamp,\n          timestamp,\n        );\n        const styleRowid = Number(database.prepare(\n          'SELECT style_rowid FROM styles WHERE style_id = ?',\n        ).get(style.id).style_rowid);\n        replaceStyleChildren(database, styleRowid, style, timestamp);\n        options.failureInjector?.({ phase: 'COMMIT', style, index, database });\n      }\n      const updateHints = database.prepare(`\n        UPDATE style_index_state\n        SET artifact_hint_hash = ?, crawl_record_hash = ?, last_success_at = ?\n        WHERE style_rowid = ?\n      `);\n      for (const style of hintOnlyStyles) {\n        const current = currentById.get(style.id);\n        updateHints.run(\n          style.artifactHintHash,\n          style.crawlRecordHash,\n          timestamp,\n          current.style_rowid,\n        );\n      }\n\n      let queued = 0;\n      const queueRows = database.prepare(`\n        SELECT s.style_rowid, s.retrieval_hash FROM styles s\n        WHERE s.lifecycle_state = 'active' AND NOT EXISTS (\n          SELECT 1 FROM style_vector_jobs j\n          WHERE j.style_rowid = s.style_rowid\n            AND j.retrieval_hash = s.retrieval_hash\n            AND j.profile_id = ?\n            AND j.status != 'superseded'\n            AND (j.status != 'completed' OR EXISTS (\n              SELECT 1 FROM style_vectors v\n              WHERE v.style_rowid = j.style_rowid\n                AND v.retrieval_hash = j.retrieval_hash\n                AND v.profile_id = j.profile_id\n            ))\n        )\n      `).all(profile.id);\n      for (const row of queueRows) {\n        enqueueVector(database, row.style_rowid, row.retrieval_hash, profile.id, timestamp);\n        queued += 1;\n      }\n      commitSpan?.end(changedStyles.length + queued);\n\n      emit('VECTOR_DRAIN', { queued });\n      if (!shouldPublish) {\n        const finalizeSpan = telemetry?.span('commit.finalize', RESIDENCY.NATIVE);\n        database.exec('COMMIT');\n        finalizeSpan?.end(1);\n        if (options.embedder) {\n          const { drainVectorQueue } = await import('./vectors.mjs');\n          const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n          await drainVectorQueue(database, {\n            profileId: profile.id,\n            embedder: options.embedder,\n            limit: options.vectorDrainLimit,\n          });\n          drainSpan?.end(queued);\n        }\n        return {\n          ok: true,\n          generationHash,\n          published: false,\n          indexed: 0,\n          unchanged: parsedStyles.length,\n          quarantined: 0,\n          tombstoned: 0,\n          queued,\n        };\n      }\n\n      const missingSpan = telemetry?.span('publish.missing', RESIDENCY.NATIVE);\n      let quarantined = 0;\n      let tombstoned = 0;\n      for (const row of missingRows) {\n        const state = database.prepare(`\n          SELECT missing_observations FROM style_index_state WHERE style_rowid = ?\n        `).get(row.style_rowid);\n        const shouldTombstone = row.lifecycle_state === 'quarantined'\n          && (options.confirmMissing === true || Number(state?.missing_observations ?? 0) >= 1);\n        if (shouldTombstone) {\n          database.prepare(`\n            UPDATE styles SET lifecycle_state = 'tombstoned',\n              quarantine_at = COALESCE(quarantine_at, ?), tombstoned_at = ?, updated_at = ?\n            WHERE style_rowid = ?\n          `).run(timestamp, timestamp, timestamp, row.style_rowid);\n          tombstoned += 1;\n        } else if (row.lifecycle_state !== 'tombstoned') {\n          database.prepare(`\n            UPDATE styles SET lifecycle_state = 'quarantined', quarantine_at = ?,\n              tombstoned_at = NULL, updated_at = ? WHERE style_rowid = ?\n          `).run(timestamp, timestamp, row.style_rowid);\n          quarantined += 1;\n        }\n        database.prepare(`\n          UPDATE style_index_state\n          SET missing_observations = missing_observations + 1, last_success_at = ?\n          WHERE style_rowid = ?\n        `).run(timestamp, row.style_rowid);\n      }\n      missingSpan?.end(missingRows.length);\n      resolveRelationships(database);\n\n      const publishSpan = telemetry?.span('publish.write', RESIDENCY.NATIVE);\n      const counts = Object.fromEntries(database.prepare(`\n        SELECT lifecycle_state, COUNT(*) AS count FROM styles GROUP BY lifecycle_state\n      `).all().map((row) => [row.lifecycle_state, Number(row.count)]));\n      emit('PUBLISH', { generationHash });\n      database.prepare(`\n        INSERT OR IGNORE INTO corpus_generations(\n          generation_hash, parent_generation_hash, crawl_manifest_hash,\n          aggregate_corpus_hash, schema_version, active_style_count,\n          quarantined_style_count, tombstoned_style_count, created_at\n        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n      `).run(\n        generationHash,\n        currentGeneration,\n        crawlManifestHash,\n        aggregateCorpusHash,\n        STYLE_DB_SCHEMA_VERSION,\n        counts.active ?? 0,\n        counts.quarantined ?? 0,\n        counts.tombstoned ?? 0,\n        timestamp,\n      );\n      database.prepare(`\n        INSERT INTO current_corpus_generation(singleton, generation_hash, published_at)\n        VALUES (1, ?, ?)\n        ON CONFLICT(singleton) DO UPDATE SET\n          generation_hash = excluded.generation_hash,\n          published_at = excluded.published_at\n      `).run(generationHash, timestamp);\n      database.prepare(`\n        UPDATE style_index_state SET last_success_generation = ?\n        WHERE style_rowid IN (SELECT style_rowid FROM styles WHERE lifecycle_state = 'active')\n      `).run(generationHash);\n      options.failureInjector?.({ phase: 'PUBLISH', database });\n      database.exec('COMMIT');\n      publishSpan?.end(changedStyles.length);\n\n      if (options.embedder) {\n        const { drainVectorQueue } = await import('./vectors.mjs');\n        const drainSpan = telemetry?.span('vector.drain', RESIDENCY.JS_RESIDENT);\n        await drainVectorQueue(database, {\n          profileId: profile.id,\n          embedder: options.embedder,\n          limit: options.vectorDrainLimit,\n        });\n        drainSpan?.end(changedStyles.length);\n      }\n      return {\n        ok: true,\n        generationHash,\n        published: true,\n        indexed: changedStyles.length,\n        unchanged: parsedStyles.length - changedStyles.length,\n        quarantined,\n        tombstoned,\n      };\n    } catch (error) {\n      database.exec('ROLLBACK');\n      throw error;\n    }\n  } finally {\n    overallTimer?.end();\n    if (ownsDatabase) database.close();\n  }\n}\n\n/**\n * Build a complete database projection without making it a query side effect.\n *\n * @param {Object} options - The same controls as indexStyleCorpus.\n * @returns {Promise<Object>} Publication summary.\n */\nasync function writeGenerationPointer(\n  databasePath,\n  generationHash,\n  databaseFile,\n  afterRename,\n  options = {},\n) {\n  if (path.basename(databaseFile) !== databaseFile) {\n    throw new TypeError('Generation database file must be a basename.');\n  }\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const artifactPath = path.join(path.dirname(databasePath), databaseFile);\n  const { sha256, bytes } = await hashArtifactFile(artifactPath);\n  const manifest = buildManifest({\n    generationHash,\n    createdAt: nowIso(),\n    parentGenerationHash: options.parentGenerationHash ?? null,\n    artifacts: { sqlite: { role: 'sqlite', file: databaseFile, sha256, bytes } },\n  });\n  await writeManifestPointer(pointerPath, manifest, { afterRename });\n}\n\nexport async function buildStyleDatabase(options) {\n  if (options?.database) {\n    const error = new Error('Full rebuild publication requires a databasePath, not an open connection.');\n    error.code = 'staging-requires-database-path';\n    throw error;\n  }\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const buildingPath = `${databasePath}.building-${process.pid}-${Date.now()}`;\n  let generationPath = null;\n  const removeSidecars = async (basePath) => {\n    await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n      rm(`${basePath}${suffix}`, { force: true })\n    )));\n  };\n  await removeSidecars(buildingPath);\n  try {\n    const result = await indexStyleCorpus({\n      ...options,\n      databasePath: buildingPath,\n      corpusWalkMode: options.corpusWalkMode ?? 'migration',\n      verifyAll: true,\n    });\n    const staged = openStyleDatabase(buildingPath);\n    try {\n      const integrity = staged.prepare('PRAGMA integrity_check').get().integrity_check;\n      const foreignKeyFailures = staged.prepare('PRAGMA foreign_key_check').all();\n      const current = staged.prepare(`\n        SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n      `).get()?.generation_hash;\n      if (integrity !== 'ok' || foreignKeyFailures.length > 0\n        || current !== result.generationHash) {\n        const error = new Error('Staged style database failed publication validation.');\n        error.code = 'staging-validation-failed';\n        throw error;\n      }\n      staged.prepare(`\n        INSERT INTO style_fts(style_fts) VALUES ('integrity-check')\n      `).run();\n      staged.exec('PRAGMA wal_checkpoint(TRUNCATE)');\n    } finally {\n      staged.close();\n    }\n    const generationName = result.generationHash.replace(':', '-');\n    const databaseFile = `${path.basename(databasePath)}.${generationName}`\n      + `.${process.pid}-${Date.now()}.sqlite`;\n    generationPath = path.join(path.dirname(databasePath), databaseFile);\n    await removeSidecars(generationPath);\n    await rename(buildingPath, generationPath);\n    const immutableGenerationPath = generationPath;\n    generationPath = null;\n    const generationHandle = await open(immutableGenerationPath, 'r');\n    try {\n      await generationHandle.sync();\n    } finally {\n      await generationHandle.close();\n    }\n    const generationDirectory = await open(path.dirname(immutableGenerationPath), 'r');\n    try {\n      await generationDirectory.sync();\n    } finally {\n      await generationDirectory.close();\n    }\n    await writeGenerationPointer(\n      databasePath,\n      result.generationHash,\n      databaseFile,\n      options.failureInjector\n        ? (details) => options.failureInjector({ phase: 'POINTER_RENAMED', ...details })\n        : undefined,\n    );\n    return {\n      ...result,\n      databasePath,\n      generationDatabasePath: path.join(path.dirname(databasePath), databaseFile),\n    };\n  } finally {\n    await removeSidecars(buildingPath);\n    if (generationPath) await removeSidecars(generationPath);\n  }\n}\n\n/**\n * Roll back by atomically repointing new readers to a retained generation file.\n *\n * @param {Object} options - Logical path and retained generation identity.\n * @param {string} options.databasePath - Logical database path.\n * @param {string} options.generationDatabasePath - Retained immutable database file.\n * @returns {Promise<Object>} Restored generation pointer details.\n */\nexport async function rollbackStyleDatabase(options) {\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const generationDatabasePath = options?.generationDatabasePath;\n  if (!generationDatabasePath\n    || path.dirname(path.resolve(generationDatabasePath)) !== path.dirname(path.resolve(databasePath))) {\n    const error = new Error('Rollback generation must be retained beside the logical database path.');\n    error.code = 'rollback-generation-invalid';\n    throw error;\n  }\n  try {\n    const retainedInfo = await stat(generationDatabasePath);\n    if (!retainedInfo.isFile()) throw new Error('not a file');\n    const databaseDirectoryRealPath = await realpath(path.dirname(databasePath));\n    const retainedRealPath = await realpath(generationDatabasePath);\n    if (!isContained(databaseDirectoryRealPath, retainedRealPath)) {\n      throw new Error('generation escapes database directory');\n    }\n  } catch (cause) {\n    const error = new Error('Rollback generation is unavailable.', { cause });\n    error.code = 'rollback-generation-invalid';\n    throw error;\n  }\n  const retained = openStyleDatabase(generationDatabasePath);\n  let generationHash;\n  try {\n    const integrity = retained.prepare('PRAGMA integrity_check').get().integrity_check;\n    generationHash = retained.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash;\n    if (integrity !== 'ok' || !generationHash) {\n      const error = new Error('Rollback generation failed validation.');\n      error.code = 'rollback-generation-invalid';\n      throw error;\n    }\n  } finally {\n    retained.close();\n  }\n  await writeGenerationPointer(\n    databasePath,\n    generationHash,\n    path.basename(generationDatabasePath),\n  );\n  return { databasePath, generationDatabasePath, generationHash };\n}\n\nexport const indexerInternals = Object.freeze({\n  computeAggregateHash,\n  computeGenerationHash,\n  normalizeMarkdown,\n  parseStyle,\n});","lineStart":1,"lineEnd":1187,"totalLines":1187,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/indexer.mjs","time":{"start":1784606352636,"end":1784606352642}},"id":"prt_f82d3e2ea001zS9suM9UPTek1M","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ccaa001KjjVqzLXb1VlKJ"}}
{"type":"tool_use","timestamp":1784606353287,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_02_dzwnStMFKFgXQFCnTa1J4610","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/retrieval.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/retrieval.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Generation-Bound Persistent Style Retrieval                             ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import { assembleCandidateCards } from '../_engine/cards.mjs';\n6: import { compareRawStrings, digest, stableJson } from './canonical.mjs';\n7: import { RESIDENCY } from './stage-telemetry.mjs';\n8: import {\n9:   STYLE_DB_SCHEMA_VERSION,\n10:   openPublishedStyleDatabase,\n11: } from './schema.mjs';\n12: \n13: export const FUSION_PROFILE = Object.freeze({\n14:   id: 'style-rrf-v1',\n15:   k: 60,\n16:   weights: Object.freeze({ structured: 1, fts: 1, vector: 1 }),\n17: });\n18: \n19: const MAX_QUERY_LENGTH = 1_000;\n20: const MAX_QUERY_TERMS = 12;\n21: const MAX_QUERY_VECTOR_DIMENSIONS = 16_384;\n22: const MAX_QUERY_VECTOR_BYTES = 256 * 1_024;\n23: const MAX_CANDIDATE_K = 200;\n24: const DEFAULT_CANDIDATE_K = 50;\n25: const EXACT_REUSE_LICENSES = new Set(['allowed', 'licensed', 'public-domain']);\n26: \n27: function normalizeFacet(value) {\n28:   return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n29: }\n30: \n31: function queryTerms(text) {\n32:   if (typeof text !== 'string' || text.length > MAX_QUERY_LENGTH) {\n33:     const error = new Error(`Query text must be a string of at most ${MAX_QUERY_LENGTH} characters.`);\n34:     error.code = 'invalid-query';\n35:     throw error;\n36:   }\n37:   return [...new Set(text.toLowerCase().match(/[\\p{L}\\p{N}][\\p{L}\\p{N}-]*/gu) ?? [])]\n38:     .slice(0, MAX_QUERY_TERMS).map((term) => term.slice(0, 64));\n39: }\n40: \n41: function placeholders(count) {\n42:   return Array.from({ length: count }, () => '?').join(', ');\n43: }\n44: \n45: function encodeOpaque(value) {\n46:   return Buffer.from(JSON.stringify(value), 'utf8').toString('base64url');\n47: }\n48: \n49: function decodeOpaque(value, code) {\n50:   try {\n51:     return JSON.parse(Buffer.from(value, 'base64url').toString('utf8'));\n52:   } catch (cause) {\n53:     const error = new Error(`Invalid ${code}.`, { cause });\n54:     error.code = code;\n55:     throw error;\n56:   }\n57: }\n58: \n59: function retrievalError(code, message) {\n60:   const error = new Error(message);\n61:   error.code = code;\n62:   return error;\n63: }\n64: \n65: function validateQueryVector(queryVector) {\n66:   if (queryVector === undefined || queryVector === null) return null;\n67:   if (!Array.isArray(queryVector)\n68:     || queryVector.length === 0\n69:     || queryVector.length > MAX_QUERY_VECTOR_DIMENSIONS\n70:     || queryVector.some((value) => typeof value !== 'number' || !Number.isFinite(value))) {\n71:     throw retrievalError(\n72:       'invalid-query-vector',\n73:       `queryVector must contain 1-${MAX_QUERY_VECTOR_DIMENSIONS} finite numbers.`,\n74:     );\n75:   }\n76:   if (Buffer.byteLength(JSON.stringify(queryVector), 'utf8') > MAX_QUERY_VECTOR_BYTES) {\n77:     throw retrievalError(\n78:       'invalid-query-vector',\n79:       `queryVector must serialize to at most ${MAX_QUERY_VECTOR_BYTES} bytes.`,\n80:     );\n81:   }\n82:   return queryVector;\n83: }\n84: \n85: function requestFingerprint(request, candidateK, profile) {\n86:   return digest(stableJson({\n87:     text: request.text ?? '',\n88:     requiredFacets: (request.requiredFacets ?? []).map(normalizeFacet).sort(compareRawStrings),\n89:     exclusions: (request.exclusions ?? []).map(normalizeFacet).sort(compareRawStrings),\n90:     axes: (request.axes ?? []).map(normalizeFacet).sort(compareRawStrings),\n91:     needs: (request.needs ?? []).map(normalizeFacet).sort(compareRawStrings),\n92:     usage: request.usage ?? null,\n93:     exactReuse: request.exactReuse === true,\n94:     generationHash: request.generationHash ?? null,\n95:     queryVector: request.queryVector ?? null,\n96:     vectorProfile: request.vectorProfile ?? null,\n97:     disableFts: request.disableFts === true,\n98:     disableVector: request.disableVector === true,\n99:     candidateK,\n100:     fusionProfile: profile,\n101:   }));\n102: }\n103: \n104: function loadEligibility(database, request, telemetry) {\n105:   const loadSpan = telemetry?.span('eligibility.load', RESIDENCY.NATIVE);\n106:   const rows = database.prepare(`\n107:     SELECT s.style_rowid, s.style_id, s.slug, s.title, s.thesis, s.theme,\n108:       s.industry, s.aggregate_hash, s.retrieval_hash, p.status AS provenance_status,\n109:       p.source_url, p.original_url, p.screenshot_url, p.source_uuid, p.captured_at,\n110:       p.license_status, p.rights_known, p.evidence_scope_json\n111:     FROM styles s\n112:     JOIN style_provenance p ON p.style_rowid = s.style_rowid\n113:     WHERE s.lifecycle_state = 'active'\n114:     ORDER BY s.style_id ASC\n115:   `).all();\n116:   loadSpan?.end(rows.length);\n117:   if (rows.length === 0) {\n118:     return { eligible: [], rejectedCount: 0, activeCount: 0 };\n119:   }\n120:   const ids = rows.map((row) => row.style_rowid);\n121:   const bindings = placeholders(ids.length);\n122:   const facetsLoadSpan = telemetry?.span('eligibility.facets.load', RESIDENCY.NATIVE);\n123:   const termRows = database.prepare(`\n124:     SELECT style_rowid, term FROM style_terms WHERE style_rowid IN (${bindings})\n125:   `).all(...ids);\n126:   const axisRows = database.prepare(`\n127:     SELECT style_rowid, axis FROM style_token_axes WHERE style_rowid IN (${bindings})\n128:   `).all(...ids);\n129:   const sectionRows = database.prepare(`\n130:     SELECT style_rowid, name FROM style_sections WHERE style_rowid IN (${bindings})\n131:   `).all(...ids);\n132:   facetsLoadSpan?.end(termRows.length + axisRows.length + sectionRows.length);\n133:   const facetsAssembleSpan = telemetry?.span('eligibility.facets.assemble', RESIDENCY.JS_RESIDENT);\n134:   const facetsById = new Map(ids.map((id) => [Number(id), new Set()]));\n135:   for (const term of termRows) {\n136:     facetsById.get(Number(term.style_rowid)).add(normalizeFacet(term.term));\n137:   }\n138:   for (const axis of axisRows) {\n139:     facetsById.get(Number(axis.style_rowid)).add(normalizeFacet(axis.axis));\n140:   }\n141:   for (const section of sectionRows) {\n142:     facetsById.get(Number(section.style_rowid)).add(normalizeFacet(section.name));\n143:   }\n144:   facetsAssembleSpan?.end(rows.length);\n145:   const filterSpan = telemetry?.span('eligibility.filter', RESIDENCY.JS_RESIDENT);\n146:   const required = (request.requiredFacets ?? []).map(normalizeFacet).filter(Boolean);\n147:   const excluded = (request.exclusions ?? []).map(normalizeFacet).filter(Boolean);\n148:   const exactReuse = request.usage === 'exact-reuse' || request.exactReuse === true;\n149:   const eligible = rows.filter((row) => {\n150:     const facets = facetsById.get(Number(row.style_rowid));\n151:     if (row.theme) facets.add(normalizeFacet(row.theme));\n152:     if (row.license_status === 'restricted') facets.add('license-restricted');\n153:     return required.every((facet) => facets.has(facet))\n154:       && excluded.every((facet) => !facets.has(facet))\n155:       && row.provenance_status === 'known'\n156:       && (!exactReuse || (\n157:         Number(row.rights_known) === 1 && EXACT_REUSE_LICENSES.has(row.license_status)\n158:       ));\n159:   }).map((row) => ({\n160:     ...row,\n161:     facets: facetsById.get(Number(row.style_rowid)),\n162:     matchedRequiredFacets: required,\n163:   }));\n164:   filterSpan?.end(eligible.length);\n165:   return { eligible, rejectedCount: rows.length - eligible.length, activeCount: rows.length };\n166: }\n167: \n168: function structuredLane(database, eligible, request, candidateK, telemetry) {\n169:   const axes = new Set((request.axes ?? []).map(normalizeFacet));\n170:   const needs = new Set((request.needs ?? []).map(normalizeFacet));\n171:   const ids = eligible.map((row) => row.style_rowid);\n172:   if (ids.length === 0) return [];\n173:   const loadSpan = telemetry?.span('lane.structured.load', RESIDENCY.NATIVE);\n174:   const axisRows = database.prepare(`\n175:     SELECT style_rowid, axis FROM style_token_axes\n176:     WHERE style_rowid IN (${placeholders(ids.length)})\n177:   `).all(...ids);\n178:   const capabilities = database.prepare(`\n179:     SELECT style_rowid, term FROM style_terms\n180:     WHERE term_type = 'capability' AND style_rowid IN (${placeholders(ids.length)})\n181:   `).all(...ids);\n182:   loadSpan?.end(axisRows.length + capabilities.length);\n183:   const rankSpan = telemetry?.span('lane.structured.rank', RESIDENCY.JS_RESIDENT);\n184:   const axisById = new Map(ids.map((id) => [Number(id), new Set()]));\n185:   const capabilitiesById = new Map(ids.map((id) => [Number(id), new Set()]));\n186:   for (const row of axisRows) axisById.get(Number(row.style_rowid)).add(normalizeFacet(row.axis));\n187:   for (const row of capabilities) {\n188:     capabilitiesById.get(Number(row.style_rowid)).add(normalizeFacet(row.term));\n189:   }\n190:   const ranked = eligible.map((row) => ({\n191:     id: row.style_id,\n192:     rawScore: row.matchedRequiredFacets.length * 10\n193:       + [...axes].filter((axis) => axisById.get(Number(row.style_rowid)).has(axis)).length * 2\n194:       + [...needs].filter((need) => capabilitiesById.get(Number(row.style_rowid)).has(need)).length,\n195:   })).sort((left, right) => right.rawScore - left.rawScore\n196:     || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n197:   rankSpan?.end(ranked.length);\n198:   return ranked;\n199: }\n200: \n201: function ftsLane(database, eligible, request, candidateK, telemetry) {\n202:   const terms = queryTerms(request.text ?? '');\n203:   if (terms.length === 0) return [];\n204:   const ids = eligible.map((row) => row.style_rowid);\n205:   if (ids.length === 0) return [];\n206:   const expression = terms.map((term) => `\"${term.replaceAll('\"', '\"\"')}\"`).join(' OR ');\n207:   const span = telemetry?.span('lane.fts', RESIDENCY.NATIVE);\n208:   const ranked = database.prepare(`\n209:     SELECT s.style_id AS id, bm25(style_fts, 5.0, 3.0, 2.0, 2.0, 1.0, 1.0) AS raw_score\n210:     FROM style_fts\n211:     JOIN styles s ON s.style_rowid = style_fts.rowid\n212:     WHERE style_fts MATCH ? AND s.style_rowid IN (${placeholders(ids.length)})\n213:     ORDER BY raw_score ASC, s.style_id ASC LIMIT ?\n214:   `).all(expression, ...ids, candidateK).map((row) => ({\n215:     id: row.id,\n216:     rawScore: Number(row.raw_score),\n217:   }));\n218:   span?.end(ranked.length);\n219:   return ranked;\n220: }\n221: \n222: function cosine(left, right) {\n223:   if (left.length !== right.length || left.length === 0) return null;\n224:   let dot = 0;\n225:   let leftNorm = 0;\n226:   let rightNorm = 0;\n227:   for (let index = 0; index < left.length; index += 1) {\n228:     dot += left[index] * right[index];\n229:     leftNorm += left[index] ** 2;\n230:     rightNorm += right[index] ** 2;\n231:   }\n232:   if (leftNorm === 0 || rightNorm === 0) return null;\n233:   return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n234: }\n235: \n236: function vectorLane(database, eligible, request, candidateK, telemetry) {\n237:   if (!Array.isArray(request.queryVector) || !request.vectorProfile) return [];\n238:   const queryVector = request.queryVector;\n239:   const ids = eligible.map((row) => row.style_rowid);\n240:   if (ids.length === 0) return [];\n241:   const fetchSpan = telemetry?.span('lane.vector.fetch', RESIDENCY.NATIVE);\n242:   const rows = database.prepare(`\n243:     SELECT s.style_id AS id, v.vector_json\n244:     FROM style_vectors v\n245:     JOIN styles s ON s.style_rowid = v.style_rowid\n246:       AND s.retrieval_hash = v.retrieval_hash\n247:       AND s.lifecycle_state = 'active'\n248:     WHERE v.profile_id = ? AND v.style_rowid IN (${placeholders(ids.length)})\n249:   `).all(request.vectorProfile, ...ids);\n250:   fetchSpan?.end(rows.length);\n251:   const computeSpan = telemetry?.span('lane.vector.cosine', RESIDENCY.JS_RESIDENT);\n252:   const ranked = rows.map((row) => ({\n253:     id: row.id,\n254:     rawScore: cosine(queryVector, JSON.parse(row.vector_json)),\n255:   })).filter((row) => row.rawScore !== null)\n256:     .sort((left, right) => right.rawScore - left.rawScore\n257:       || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n258:   computeSpan?.end(ranked.length);\n259:   return ranked;\n260: }\n261: \n262: /**\n263:  * Fuse ranked channels with a versioned weighted reciprocal-rank formula.\n264:  *\n265:  * @param {Object<string,Object[]>} lanes - Ordered candidate lists by channel.\n266:  * @param {Object} [profile=FUSION_PROFILE] - RRF k and channel weights.\n267:  * @returns {Object[]} Deterministically fused candidates with attribution.\n268:  */\n269: export function weightedRrf(lanes, profile = FUSION_PROFILE) {\n270:   const fused = new Map();\n271:   for (const [channel, results] of Object.entries(lanes)) {\n272:     const weight = Number(profile.weights[channel] ?? 0);\n273:     if (!Number.isFinite(weight) || weight <= 0) continue;\n274:     for (const [index, result] of results.entries()) {\n275:       const rank = index + 1;\n276:       const contribution = weight / (profile.k + rank);\n277:       const existing = fused.get(result.id) ?? {\n278:         id: result.id,\n279:         fusedScore: 0,\n280:         sourceRanks: {},\n281:         channelContributions: {},\n282:         rawScores: {},\n283:       };\n284:       existing.fusedScore += contribution;\n285:       existing.sourceRanks[channel] = rank;\n286:       existing.channelContributions[channel] = contribution;\n287:       existing.rawScores[channel] = result.rawScore;\n288:       fused.set(result.id, existing);\n289:     }\n290:   }\n291:   return [...fused.values()].sort((left, right) => (\n292:     right.fusedScore - left.fusedScore || compareRawStrings(left.id, right.id)\n293:   ));\n294: }\n295: \n296: function validateGeneration(database, telemetry) {\n297:   const readSpan = telemetry?.span('generation.read', RESIDENCY.NATIVE);\n298:   const generation = database.prepare(`\n299:     SELECT g.* FROM current_corpus_generation p\n300:     JOIN corpus_generations g ON g.generation_hash = p.generation_hash\n301:     WHERE p.singleton = 1\n302:   `).get();\n303:   if (!generation || Number(generation.schema_version) !== STYLE_DB_SCHEMA_VERSION) {\n304:     throw retrievalError('generation-unavailable', 'No valid published style generation exists.');\n305:   }\n306:   const activeRows = database.prepare(`\n307:     SELECT style_id, aggregate_hash FROM styles\n308:     WHERE lifecycle_state = 'active' ORDER BY style_id ASC\n309:   `).all();\n310:   readSpan?.end(activeRows.length);\n311:   const verifySpan = telemetry?.span('generation.verify', RESIDENCY.JS_RESIDENT);\n312:   const aggregateHash = digest(\n313:     `style-corpus-aggregate-v1\\0${activeRows.map((row) => (\n314:       `${row.style_id}\\0${row.aggregate_hash}\\n`\n315:     )).join('')}`,\n316:   );\n317:   if (activeRows.length !== Number(generation.active_style_count)\n318:     || aggregateHash !== generation.aggregate_corpus_hash) {\n319:     throw retrievalError('generation-invalid', 'Published generation does not match indexed style state.');\n320:   }\n321:   verifySpan?.end(activeRows.length);\n322:   return generation;\n323: }\n324: \n325: function loadCardStyle(database, row) {\n326:   const axes = database.prepare(`\n327:     SELECT axis, token_count FROM style_token_axes\n328:     WHERE style_rowid = ? ORDER BY axis ASC\n329:   `).all(row.style_rowid).map((axis) => ({ axis: axis.axis, count: Number(axis.token_count) }));\n330:   const capabilities = database.prepare(`\n331:     SELECT term FROM style_terms WHERE style_rowid = ? AND term_type = 'capability'\n332:     ORDER BY term ASC\n333:   `).all(row.style_rowid).map((term) => term.term);\n334:   const sections = database.prepare(`\n335:     SELECT name FROM style_sections WHERE style_rowid = ? ORDER BY ordinal ASC\n336:   `).all(row.style_rowid).map((section) => section.name);\n337:   const estimatedHydrationBytes = Number(database.prepare(`\n338:     SELECT COALESCE(SUM(byte_length), 0) AS bytes FROM style_artifacts\n339:     WHERE style_rowid = ? AND role IN ('design', 'source', 'tokens')\n340:   `).get(row.style_rowid).bytes);\n341:   return {\n342:     id: row.style_id,\n343:     title: row.title,\n344:     thesis: row.thesis,\n345:     contentHash: row.aggregate_hash,\n346:     capabilities,\n347:     availableSections: sections,\n348:     tokenAxes: axes,\n349:     provenance: {\n350:       status: row.provenance_status,\n351:       sourceUrl: row.source_url,\n352:       originalUrl: row.original_url,\n353:       screenshotUrl: row.screenshot_url,\n354:       uuid: row.source_uuid,\n355:       capturedAt: row.captured_at,\n356:       licenseStatus: row.license_status,\n357:       rightsKnown: Number(row.rights_known) === 1,\n358:       evidenceScope: JSON.parse(row.evidence_scope_json),\n359:     },\n360:     estimatedHydrationBytes,\n361:   };\n362: }\n363: \n364: /**\n365:  * Query one immutable generation snapshot without walking the source corpus.\n366:  *\n367:  * @param {Object} request - Eligibility, ranking, and paging request.\n368:  * @param {Object} options - Database connection or path.\n369:  * @returns {Object} Generation-stamped cards, cursor, and channel evidence.\n370:  */\n371: export function queryPersistentStyles(request = {}, options = {}) {\n372:   validateQueryVector(request.queryVector);\n373:   const database = options.database ?? openPublishedStyleDatabase(options.databasePath);\n374:   const ownsDatabase = !options.database;\n375:   const telemetry = options.telemetry;\n376:   const candidateK = Math.max(1, Math.min(MAX_CANDIDATE_K, request.candidateK ?? DEFAULT_CANDIDATE_K));\n377:   const fingerprintSpan = telemetry?.span('request.fingerprint', RESIDENCY.JS_RESIDENT);\n378:   const fingerprint = requestFingerprint(request, candidateK, FUSION_PROFILE);\n379:   fingerprintSpan?.end(1);\n380:   const beginSpan = telemetry?.span('transaction.begin', RESIDENCY.NATIVE);\n381:   database.exec('BEGIN');\n382:   beginSpan?.end(1);\n383:   try {\n384:     const generation = validateGeneration(database, telemetry);\n385:     if (request.generationHash !== undefined\n386:       && request.generationHash !== generation.generation_hash) {\n387:       throw retrievalError(\n388:         'generation-mismatch',\n389:         'Requested generation is not the published generation.',\n390:       );\n391:     }\n392:     const vectorRevisionSpan = telemetry?.span('generation.vector-revision', RESIDENCY.NATIVE);\n393:     const vectorRevision = request.vectorProfile ? Number(database.prepare(`\n394:       SELECT revision FROM vector_projection_revisions WHERE profile_id = ?\n395:     `).get(request.vectorProfile)?.revision ?? 0) : 0;\n396:     vectorRevisionSpan?.end(request.vectorProfile ? 1 : 0);\n397:     let cursor = null;\n398:     if (request.cursor) {\n399:       cursor = decodeOpaque(request.cursor, 'invalid-cursor');\n400:       if (cursor.generationHash !== generation.generation_hash) {\n401:         throw retrievalError('generation-mismatch', 'Cursor belongs to another generation.');\n402:       }\n403:       if (cursor.queryFingerprint !== fingerprint\n404:         || cursor.fusionProfile !== FUSION_PROFILE.id\n405:         || cursor.candidateK !== candidateK\n406:         || cursor.vectorRevision !== vectorRevision) {\n407:         throw retrievalError('invalid-cursor', 'Cursor does not match this retrieval request.');\n408:       }\n409:     }\n410:     const eligibility = loadEligibility(database, request, telemetry);\n411:     const channelHealth = {\n412:       structured: { state: 'healthy' },\n413:       fts: { state: request.disableFts === true ? 'disabled' : 'healthy' },\n414:       vector: { state: request.disableVector === true ? 'disabled' : 'healthy' },\n415:     };\n416:     const lanes = {\n417:       structured: structuredLane(database, eligibility.eligible, request, candidateK, telemetry),\n418:     };\n419:     if (!request.disableFts) {\n420:       try {\n421:         lanes.fts = ftsLane(database, eligibility.eligible, request, candidateK, telemetry);\n422:       } catch (error) {\n423:         if (error.code === 'invalid-query') throw error;\n424:         channelHealth.fts = { state: 'failed', reason: String(error.message ?? error) };\n425:       }\n426:     }\n427:     if (!request.disableVector) {\n428:       try {\n429:         lanes.vector = vectorLane(database, eligibility.eligible, request, candidateK, telemetry);\n430:       } catch (error) {\n431:         if (error.code === 'invalid-query-vector') throw error;\n432:         channelHealth.vector = { state: 'failed', reason: String(error.message ?? error) };\n433:       }\n434:     }\n435:     const hasFts = Array.isArray(lanes.fts) && lanes.fts.length > 0;\n436:     const hasVector = Array.isArray(lanes.vector) && lanes.vector.length > 0;\n437:     const rankingMode = hasFts && hasVector\n438:       ? 'hybrid'\n439:       : hasFts\n440:         ? 'structured+fts'\n441:         : hasVector\n442:           ? 'structured+vector'\n443:           : 'structured-only';\n444:     const fusionSpan = telemetry?.span('fusion.rrf', RESIDENCY.JS_RESIDENT);\n445:     let fused = weightedRrf(lanes);\n446:     if (cursor) {\n447:       fused = fused.filter((entry) => entry.fusedScore < cursor.lastScore\n448:         || (entry.fusedScore === cursor.lastScore\n449:           && compareRawStrings(entry.id, cursor.lastId) > 0));\n450:     }\n451:     fusionSpan?.end(fused.length);\n452:     const limit = Math.max(0, Math.min(5, Number.isInteger(request.limit) ? request.limit : 5));\n453:     const page = fused.slice(0, limit);\n454:     const rowById = new Map(eligibility.eligible.map((row) => [row.style_id, row]));\n455:     const hydrateSpan = telemetry?.span('cards.hydrate', RESIDENCY.NATIVE);\n456:     const ranked = page.map((entry) => ({\n457:       style: loadCardStyle(database, rowById.get(entry.id)),\n458:       score: {\n459:         deterministic: Number(entry.rawScores.structured ?? 0),\n460:         lexical: Number(entry.channelContributions.fts ?? 0),\n461:         total: Number(entry.fusedScore.toFixed(12)),\n462:       },\n463:     }));\n464:     hydrateSpan?.end(ranked.length);\n465:     const assembleSpan = telemetry?.span('cards.assemble', RESIDENCY.JS_RESIDENT);\n466:     const cards = assembleCandidateCards(ranked, generation.generation_hash, request);\n467:     assembleSpan?.end(cards.length);\n468:     const encodeSpan = telemetry?.span('cards.attribution.encode', RESIDENCY.JS_RESIDENT);\n469:     const attributions = Object.fromEntries(page.map((entry) => [entry.id, {\n470:       sourceRanks: entry.sourceRanks,\n471:       channelContributions: entry.channelContributions,\n472:       rawScores: entry.rawScores,\n473:       hydrationToken: encodeOpaque({\n474:         generationHash: generation.generation_hash,\n475:         id: entry.id,\n476:         contentHash: rowById.get(entry.id).aggregate_hash,\n477:       }),\n478:     }]));\n479:     const last = page.at(-1);\n480:     const nextCursor = last && fused.length > page.length ? encodeOpaque({\n481:       generationHash: generation.generation_hash,\n482:       queryFingerprint: fingerprint,\n483:       fusionProfile: FUSION_PROFILE.id,\n484:       candidateK,\n485:       vectorRevision,\n486:       lastScore: last.fusedScore,\n487:       lastId: last.id,\n488:     }) : null;\n489:     encodeSpan?.end(page.length);\n490:     const commitSpan = telemetry?.span('transaction.commit', RESIDENCY.NATIVE);\n491:     database.exec('COMMIT');\n492:     commitSpan?.end(1);\n493:     return {\n494:       ok: true,\n495:       generationHash: generation.generation_hash,\n496:       degraded: rankingMode !== 'hybrid',\n497:       rankingMode,\n498:       queryFingerprint: fingerprint,\n499:       fusionProfile: FUSION_PROFILE.id,\n500:       candidateK,\n501:       vectorRevision,\n502:       channelHealth,\n503:       eligibility: {\n504:         eligibleCount: eligibility.eligible.length,\n505:         rejectedCount: eligibility.rejectedCount,\n506:       },\n507:       cards,\n508:       attributions,\n509:       nextCursor,\n510:     };\n511:   } catch (error) {\n512:     database.exec('ROLLBACK');\n513:     throw error;\n514:   } finally {\n515:     if (ownsDatabase) database.close();\n516:   }\n517: }\n518: \n519: export const retrievalInternals = Object.freeze({\n520:   decodeOpaque,\n521:   requestFingerprint,\n522:   validateQueryVector,\n523:   validateGeneration,\n524: });\n\n(End of file - total 524 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation-Bound Persistent Style Retrieval                             ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { assembleCandidateCards } from '../_engine/cards.mjs';\nimport { compareRawStrings, digest, stableJson } from './canonical.mjs';\nimport { RESIDENCY } from './stage-telemetry.mjs';\nimport {\n  STYLE_DB_SCHEMA_VERSION,\n  openPublishedStyleDatabase,\n} from './schema.mjs';\n\nexport const FUSION_PROFILE = Object.freeze({\n  id: 'style-rrf-v1',\n  k: 60,\n  weights: Object.freeze({ structured: 1, fts: 1, vector: 1 }),\n});\n\nconst MAX_QUERY_LENGTH = 1_000;\nconst MAX_QUERY_TERMS = 12;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/retrieval.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation-Bound Persistent Style Retrieval                             ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { assembleCandidateCards } from '../_engine/cards.mjs';\nimport { compareRawStrings, digest, stableJson } from './canonical.mjs';\nimport { RESIDENCY } from './stage-telemetry.mjs';\nimport {\n  STYLE_DB_SCHEMA_VERSION,\n  openPublishedStyleDatabase,\n} from './schema.mjs';\n\nexport const FUSION_PROFILE = Object.freeze({\n  id: 'style-rrf-v1',\n  k: 60,\n  weights: Object.freeze({ structured: 1, fts: 1, vector: 1 }),\n});\n\nconst MAX_QUERY_LENGTH = 1_000;\nconst MAX_QUERY_TERMS = 12;\nconst MAX_QUERY_VECTOR_DIMENSIONS = 16_384;\nconst MAX_QUERY_VECTOR_BYTES = 256 * 1_024;\nconst MAX_CANDIDATE_K = 200;\nconst DEFAULT_CANDIDATE_K = 50;\nconst EXACT_REUSE_LICENSES = new Set(['allowed', 'licensed', 'public-domain']);\n\nfunction normalizeFacet(value) {\n  return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n}\n\nfunction queryTerms(text) {\n  if (typeof text !== 'string' || text.length > MAX_QUERY_LENGTH) {\n    const error = new Error(`Query text must be a string of at most ${MAX_QUERY_LENGTH} characters.`);\n    error.code = 'invalid-query';\n    throw error;\n  }\n  return [...new Set(text.toLowerCase().match(/[\\p{L}\\p{N}][\\p{L}\\p{N}-]*/gu) ?? [])]\n    .slice(0, MAX_QUERY_TERMS).map((term) => term.slice(0, 64));\n}\n\nfunction placeholders(count) {\n  return Array.from({ length: count }, () => '?').join(', ');\n}\n\nfunction encodeOpaque(value) {\n  return Buffer.from(JSON.stringify(value), 'utf8').toString('base64url');\n}\n\nfunction decodeOpaque(value, code) {\n  try {\n    return JSON.parse(Buffer.from(value, 'base64url').toString('utf8'));\n  } catch (cause) {\n    const error = new Error(`Invalid ${code}.`, { cause });\n    error.code = code;\n    throw error;\n  }\n}\n\nfunction retrievalError(code, message) {\n  const error = new Error(message);\n  error.code = code;\n  return error;\n}\n\nfunction validateQueryVector(queryVector) {\n  if (queryVector === undefined || queryVector === null) return null;\n  if (!Array.isArray(queryVector)\n    || queryVector.length === 0\n    || queryVector.length > MAX_QUERY_VECTOR_DIMENSIONS\n    || queryVector.some((value) => typeof value !== 'number' || !Number.isFinite(value))) {\n    throw retrievalError(\n      'invalid-query-vector',\n      `queryVector must contain 1-${MAX_QUERY_VECTOR_DIMENSIONS} finite numbers.`,\n    );\n  }\n  if (Buffer.byteLength(JSON.stringify(queryVector), 'utf8') > MAX_QUERY_VECTOR_BYTES) {\n    throw retrievalError(\n      'invalid-query-vector',\n      `queryVector must serialize to at most ${MAX_QUERY_VECTOR_BYTES} bytes.`,\n    );\n  }\n  return queryVector;\n}\n\nfunction requestFingerprint(request, candidateK, profile) {\n  return digest(stableJson({\n    text: request.text ?? '',\n    requiredFacets: (request.requiredFacets ?? []).map(normalizeFacet).sort(compareRawStrings),\n    exclusions: (request.exclusions ?? []).map(normalizeFacet).sort(compareRawStrings),\n    axes: (request.axes ?? []).map(normalizeFacet).sort(compareRawStrings),\n    needs: (request.needs ?? []).map(normalizeFacet).sort(compareRawStrings),\n    usage: request.usage ?? null,\n    exactReuse: request.exactReuse === true,\n    generationHash: request.generationHash ?? null,\n    queryVector: request.queryVector ?? null,\n    vectorProfile: request.vectorProfile ?? null,\n    disableFts: request.disableFts === true,\n    disableVector: request.disableVector === true,\n    candidateK,\n    fusionProfile: profile,\n  }));\n}\n\nfunction loadEligibility(database, request, telemetry) {\n  const loadSpan = telemetry?.span('eligibility.load', RESIDENCY.NATIVE);\n  const rows = database.prepare(`\n    SELECT s.style_rowid, s.style_id, s.slug, s.title, s.thesis, s.theme,\n      s.industry, s.aggregate_hash, s.retrieval_hash, p.status AS provenance_status,\n      p.source_url, p.original_url, p.screenshot_url, p.source_uuid, p.captured_at,\n      p.license_status, p.rights_known, p.evidence_scope_json\n    FROM styles s\n    JOIN style_provenance p ON p.style_rowid = s.style_rowid\n    WHERE s.lifecycle_state = 'active'\n    ORDER BY s.style_id ASC\n  `).all();\n  loadSpan?.end(rows.length);\n  if (rows.length === 0) {\n    return { eligible: [], rejectedCount: 0, activeCount: 0 };\n  }\n  const ids = rows.map((row) => row.style_rowid);\n  const bindings = placeholders(ids.length);\n  const facetsLoadSpan = telemetry?.span('eligibility.facets.load', RESIDENCY.NATIVE);\n  const termRows = database.prepare(`\n    SELECT style_rowid, term FROM style_terms WHERE style_rowid IN (${bindings})\n  `).all(...ids);\n  const axisRows = database.prepare(`\n    SELECT style_rowid, axis FROM style_token_axes WHERE style_rowid IN (${bindings})\n  `).all(...ids);\n  const sectionRows = database.prepare(`\n    SELECT style_rowid, name FROM style_sections WHERE style_rowid IN (${bindings})\n  `).all(...ids);\n  facetsLoadSpan?.end(termRows.length + axisRows.length + sectionRows.length);\n  const facetsAssembleSpan = telemetry?.span('eligibility.facets.assemble', RESIDENCY.JS_RESIDENT);\n  const facetsById = new Map(ids.map((id) => [Number(id), new Set()]));\n  for (const term of termRows) {\n    facetsById.get(Number(term.style_rowid)).add(normalizeFacet(term.term));\n  }\n  for (const axis of axisRows) {\n    facetsById.get(Number(axis.style_rowid)).add(normalizeFacet(axis.axis));\n  }\n  for (const section of sectionRows) {\n    facetsById.get(Number(section.style_rowid)).add(normalizeFacet(section.name));\n  }\n  facetsAssembleSpan?.end(rows.length);\n  const filterSpan = telemetry?.span('eligibility.filter', RESIDENCY.JS_RESIDENT);\n  const required = (request.requiredFacets ?? []).map(normalizeFacet).filter(Boolean);\n  const excluded = (request.exclusions ?? []).map(normalizeFacet).filter(Boolean);\n  const exactReuse = request.usage === 'exact-reuse' || request.exactReuse === true;\n  const eligible = rows.filter((row) => {\n    const facets = facetsById.get(Number(row.style_rowid));\n    if (row.theme) facets.add(normalizeFacet(row.theme));\n    if (row.license_status === 'restricted') facets.add('license-restricted');\n    return required.every((facet) => facets.has(facet))\n      && excluded.every((facet) => !facets.has(facet))\n      && row.provenance_status === 'known'\n      && (!exactReuse || (\n        Number(row.rights_known) === 1 && EXACT_REUSE_LICENSES.has(row.license_status)\n      ));\n  }).map((row) => ({\n    ...row,\n    facets: facetsById.get(Number(row.style_rowid)),\n    matchedRequiredFacets: required,\n  }));\n  filterSpan?.end(eligible.length);\n  return { eligible, rejectedCount: rows.length - eligible.length, activeCount: rows.length };\n}\n\nfunction structuredLane(database, eligible, request, candidateK, telemetry) {\n  const axes = new Set((request.axes ?? []).map(normalizeFacet));\n  const needs = new Set((request.needs ?? []).map(normalizeFacet));\n  const ids = eligible.map((row) => row.style_rowid);\n  if (ids.length === 0) return [];\n  const loadSpan = telemetry?.span('lane.structured.load', RESIDENCY.NATIVE);\n  const axisRows = database.prepare(`\n    SELECT style_rowid, axis FROM style_token_axes\n    WHERE style_rowid IN (${placeholders(ids.length)})\n  `).all(...ids);\n  const capabilities = database.prepare(`\n    SELECT style_rowid, term FROM style_terms\n    WHERE term_type = 'capability' AND style_rowid IN (${placeholders(ids.length)})\n  `).all(...ids);\n  loadSpan?.end(axisRows.length + capabilities.length);\n  const rankSpan = telemetry?.span('lane.structured.rank', RESIDENCY.JS_RESIDENT);\n  const axisById = new Map(ids.map((id) => [Number(id), new Set()]));\n  const capabilitiesById = new Map(ids.map((id) => [Number(id), new Set()]));\n  for (const row of axisRows) axisById.get(Number(row.style_rowid)).add(normalizeFacet(row.axis));\n  for (const row of capabilities) {\n    capabilitiesById.get(Number(row.style_rowid)).add(normalizeFacet(row.term));\n  }\n  const ranked = eligible.map((row) => ({\n    id: row.style_id,\n    rawScore: row.matchedRequiredFacets.length * 10\n      + [...axes].filter((axis) => axisById.get(Number(row.style_rowid)).has(axis)).length * 2\n      + [...needs].filter((need) => capabilitiesById.get(Number(row.style_rowid)).has(need)).length,\n  })).sort((left, right) => right.rawScore - left.rawScore\n    || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n  rankSpan?.end(ranked.length);\n  return ranked;\n}\n\nfunction ftsLane(database, eligible, request, candidateK, telemetry) {\n  const terms = queryTerms(request.text ?? '');\n  if (terms.length === 0) return [];\n  const ids = eligible.map((row) => row.style_rowid);\n  if (ids.length === 0) return [];\n  const expression = terms.map((term) => `\"${term.replaceAll('\"', '\"\"')}\"`).join(' OR ');\n  const span = telemetry?.span('lane.fts', RESIDENCY.NATIVE);\n  const ranked = database.prepare(`\n    SELECT s.style_id AS id, bm25(style_fts, 5.0, 3.0, 2.0, 2.0, 1.0, 1.0) AS raw_score\n    FROM style_fts\n    JOIN styles s ON s.style_rowid = style_fts.rowid\n    WHERE style_fts MATCH ? AND s.style_rowid IN (${placeholders(ids.length)})\n    ORDER BY raw_score ASC, s.style_id ASC LIMIT ?\n  `).all(expression, ...ids, candidateK).map((row) => ({\n    id: row.id,\n    rawScore: Number(row.raw_score),\n  }));\n  span?.end(ranked.length);\n  return ranked;\n}\n\nfunction cosine(left, right) {\n  if (left.length !== right.length || left.length === 0) return null;\n  let dot = 0;\n  let leftNorm = 0;\n  let rightNorm = 0;\n  for (let index = 0; index < left.length; index += 1) {\n    dot += left[index] * right[index];\n    leftNorm += left[index] ** 2;\n    rightNorm += right[index] ** 2;\n  }\n  if (leftNorm === 0 || rightNorm === 0) return null;\n  return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n}\n\nfunction vectorLane(database, eligible, request, candidateK, telemetry) {\n  if (!Array.isArray(request.queryVector) || !request.vectorProfile) return [];\n  const queryVector = request.queryVector;\n  const ids = eligible.map((row) => row.style_rowid);\n  if (ids.length === 0) return [];\n  const fetchSpan = telemetry?.span('lane.vector.fetch', RESIDENCY.NATIVE);\n  const rows = database.prepare(`\n    SELECT s.style_id AS id, v.vector_json\n    FROM style_vectors v\n    JOIN styles s ON s.style_rowid = v.style_rowid\n      AND s.retrieval_hash = v.retrieval_hash\n      AND s.lifecycle_state = 'active'\n    WHERE v.profile_id = ? AND v.style_rowid IN (${placeholders(ids.length)})\n  `).all(request.vectorProfile, ...ids);\n  fetchSpan?.end(rows.length);\n  const computeSpan = telemetry?.span('lane.vector.cosine', RESIDENCY.JS_RESIDENT);\n  const ranked = rows.map((row) => ({\n    id: row.id,\n    rawScore: cosine(queryVector, JSON.parse(row.vector_json)),\n  })).filter((row) => row.rawScore !== null)\n    .sort((left, right) => right.rawScore - left.rawScore\n      || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n  computeSpan?.end(ranked.length);\n  return ranked;\n}\n\n/**\n * Fuse ranked channels with a versioned weighted reciprocal-rank formula.\n *\n * @param {Object<string,Object[]>} lanes - Ordered candidate lists by channel.\n * @param {Object} [profile=FUSION_PROFILE] - RRF k and channel weights.\n * @returns {Object[]} Deterministically fused candidates with attribution.\n */\nexport function weightedRrf(lanes, profile = FUSION_PROFILE) {\n  const fused = new Map();\n  for (const [channel, results] of Object.entries(lanes)) {\n    const weight = Number(profile.weights[channel] ?? 0);\n    if (!Number.isFinite(weight) || weight <= 0) continue;\n    for (const [index, result] of results.entries()) {\n      const rank = index + 1;\n      const contribution = weight / (profile.k + rank);\n      const existing = fused.get(result.id) ?? {\n        id: result.id,\n        fusedScore: 0,\n        sourceRanks: {},\n        channelContributions: {},\n        rawScores: {},\n      };\n      existing.fusedScore += contribution;\n      existing.sourceRanks[channel] = rank;\n      existing.channelContributions[channel] = contribution;\n      existing.rawScores[channel] = result.rawScore;\n      fused.set(result.id, existing);\n    }\n  }\n  return [...fused.values()].sort((left, right) => (\n    right.fusedScore - left.fusedScore || compareRawStrings(left.id, right.id)\n  ));\n}\n\nfunction validateGeneration(database, telemetry) {\n  const readSpan = telemetry?.span('generation.read', RESIDENCY.NATIVE);\n  const generation = database.prepare(`\n    SELECT g.* FROM current_corpus_generation p\n    JOIN corpus_generations g ON g.generation_hash = p.generation_hash\n    WHERE p.singleton = 1\n  `).get();\n  if (!generation || Number(generation.schema_version) !== STYLE_DB_SCHEMA_VERSION) {\n    throw retrievalError('generation-unavailable', 'No valid published style generation exists.');\n  }\n  const activeRows = database.prepare(`\n    SELECT style_id, aggregate_hash FROM styles\n    WHERE lifecycle_state = 'active' ORDER BY style_id ASC\n  `).all();\n  readSpan?.end(activeRows.length);\n  const verifySpan = telemetry?.span('generation.verify', RESIDENCY.JS_RESIDENT);\n  const aggregateHash = digest(\n    `style-corpus-aggregate-v1\\0${activeRows.map((row) => (\n      `${row.style_id}\\0${row.aggregate_hash}\\n`\n    )).join('')}`,\n  );\n  if (activeRows.length !== Number(generation.active_style_count)\n    || aggregateHash !== generation.aggregate_corpus_hash) {\n    throw retrievalError('generation-invalid', 'Published generation does not match indexed style state.');\n  }\n  verifySpan?.end(activeRows.length);\n  return generation;\n}\n\nfunction loadCardStyle(database, row) {\n  const axes = database.prepare(`\n    SELECT axis, token_count FROM style_token_axes\n    WHERE style_rowid = ? ORDER BY axis ASC\n  `).all(row.style_rowid).map((axis) => ({ axis: axis.axis, count: Number(axis.token_count) }));\n  const capabilities = database.prepare(`\n    SELECT term FROM style_terms WHERE style_rowid = ? AND term_type = 'capability'\n    ORDER BY term ASC\n  `).all(row.style_rowid).map((term) => term.term);\n  const sections = database.prepare(`\n    SELECT name FROM style_sections WHERE style_rowid = ? ORDER BY ordinal ASC\n  `).all(row.style_rowid).map((section) => section.name);\n  const estimatedHydrationBytes = Number(database.prepare(`\n    SELECT COALESCE(SUM(byte_length), 0) AS bytes FROM style_artifacts\n    WHERE style_rowid = ? AND role IN ('design', 'source', 'tokens')\n  `).get(row.style_rowid).bytes);\n  return {\n    id: row.style_id,\n    title: row.title,\n    thesis: row.thesis,\n    contentHash: row.aggregate_hash,\n    capabilities,\n    availableSections: sections,\n    tokenAxes: axes,\n    provenance: {\n      status: row.provenance_status,\n      sourceUrl: row.source_url,\n      originalUrl: row.original_url,\n      screenshotUrl: row.screenshot_url,\n      uuid: row.source_uuid,\n      capturedAt: row.captured_at,\n      licenseStatus: row.license_status,\n      rightsKnown: Number(row.rights_known) === 1,\n      evidenceScope: JSON.parse(row.evidence_scope_json),\n    },\n    estimatedHydrationBytes,\n  };\n}\n\n/**\n * Query one immutable generation snapshot without walking the source corpus.\n *\n * @param {Object} request - Eligibility, ranking, and paging request.\n * @param {Object} options - Database connection or path.\n * @returns {Object} Generation-stamped cards, cursor, and channel evidence.\n */\nexport function queryPersistentStyles(request = {}, options = {}) {\n  validateQueryVector(request.queryVector);\n  const database = options.database ?? openPublishedStyleDatabase(options.databasePath);\n  const ownsDatabase = !options.database;\n  const telemetry = options.telemetry;\n  const candidateK = Math.max(1, Math.min(MAX_CANDIDATE_K, request.candidateK ?? DEFAULT_CANDIDATE_K));\n  const fingerprintSpan = telemetry?.span('request.fingerprint', RESIDENCY.JS_RESIDENT);\n  const fingerprint = requestFingerprint(request, candidateK, FUSION_PROFILE);\n  fingerprintSpan?.end(1);\n  const beginSpan = telemetry?.span('transaction.begin', RESIDENCY.NATIVE);\n  database.exec('BEGIN');\n  beginSpan?.end(1);\n  try {\n    const generation = validateGeneration(database, telemetry);\n    if (request.generationHash !== undefined\n      && request.generationHash !== generation.generation_hash) {\n      throw retrievalError(\n        'generation-mismatch',\n        'Requested generation is not the published generation.',\n      );\n    }\n    const vectorRevisionSpan = telemetry?.span('generation.vector-revision', RESIDENCY.NATIVE);\n    const vectorRevision = request.vectorProfile ? Number(database.prepare(`\n      SELECT revision FROM vector_projection_revisions WHERE profile_id = ?\n    `).get(request.vectorProfile)?.revision ?? 0) : 0;\n    vectorRevisionSpan?.end(request.vectorProfile ? 1 : 0);\n    let cursor = null;\n    if (request.cursor) {\n      cursor = decodeOpaque(request.cursor, 'invalid-cursor');\n      if (cursor.generationHash !== generation.generation_hash) {\n        throw retrievalError('generation-mismatch', 'Cursor belongs to another generation.');\n      }\n      if (cursor.queryFingerprint !== fingerprint\n        || cursor.fusionProfile !== FUSION_PROFILE.id\n        || cursor.candidateK !== candidateK\n        || cursor.vectorRevision !== vectorRevision) {\n        throw retrievalError('invalid-cursor', 'Cursor does not match this retrieval request.');\n      }\n    }\n    const eligibility = loadEligibility(database, request, telemetry);\n    const channelHealth = {\n      structured: { state: 'healthy' },\n      fts: { state: request.disableFts === true ? 'disabled' : 'healthy' },\n      vector: { state: request.disableVector === true ? 'disabled' : 'healthy' },\n    };\n    const lanes = {\n      structured: structuredLane(database, eligibility.eligible, request, candidateK, telemetry),\n    };\n    if (!request.disableFts) {\n      try {\n        lanes.fts = ftsLane(database, eligibility.eligible, request, candidateK, telemetry);\n      } catch (error) {\n        if (error.code === 'invalid-query') throw error;\n        channelHealth.fts = { state: 'failed', reason: String(error.message ?? error) };\n      }\n    }\n    if (!request.disableVector) {\n      try {\n        lanes.vector = vectorLane(database, eligibility.eligible, request, candidateK, telemetry);\n      } catch (error) {\n        if (error.code === 'invalid-query-vector') throw error;\n        channelHealth.vector = { state: 'failed', reason: String(error.message ?? error) };\n      }\n    }\n    const hasFts = Array.isArray(lanes.fts) && lanes.fts.length > 0;\n    const hasVector = Array.isArray(lanes.vector) && lanes.vector.length > 0;\n    const rankingMode = hasFts && hasVector\n      ? 'hybrid'\n      : hasFts\n        ? 'structured+fts'\n        : hasVector\n          ? 'structured+vector'\n          : 'structured-only';\n    const fusionSpan = telemetry?.span('fusion.rrf', RESIDENCY.JS_RESIDENT);\n    let fused = weightedRrf(lanes);\n    if (cursor) {\n      fused = fused.filter((entry) => entry.fusedScore < cursor.lastScore\n        || (entry.fusedScore === cursor.lastScore\n          && compareRawStrings(entry.id, cursor.lastId) > 0));\n    }\n    fusionSpan?.end(fused.length);\n    const limit = Math.max(0, Math.min(5, Number.isInteger(request.limit) ? request.limit : 5));\n    const page = fused.slice(0, limit);\n    const rowById = new Map(eligibility.eligible.map((row) => [row.style_id, row]));\n    const hydrateSpan = telemetry?.span('cards.hydrate', RESIDENCY.NATIVE);\n    const ranked = page.map((entry) => ({\n      style: loadCardStyle(database, rowById.get(entry.id)),\n      score: {\n        deterministic: Number(entry.rawScores.structured ?? 0),\n        lexical: Number(entry.channelContributions.fts ?? 0),\n        total: Number(entry.fusedScore.toFixed(12)),\n      },\n    }));\n    hydrateSpan?.end(ranked.length);\n    const assembleSpan = telemetry?.span('cards.assemble', RESIDENCY.JS_RESIDENT);\n    const cards = assembleCandidateCards(ranked, generation.generation_hash, request);\n    assembleSpan?.end(cards.length);\n    const encodeSpan = telemetry?.span('cards.attribution.encode', RESIDENCY.JS_RESIDENT);\n    const attributions = Object.fromEntries(page.map((entry) => [entry.id, {\n      sourceRanks: entry.sourceRanks,\n      channelContributions: entry.channelContributions,\n      rawScores: entry.rawScores,\n      hydrationToken: encodeOpaque({\n        generationHash: generation.generation_hash,\n        id: entry.id,\n        contentHash: rowById.get(entry.id).aggregate_hash,\n      }),\n    }]));\n    const last = page.at(-1);\n    const nextCursor = last && fused.length > page.length ? encodeOpaque({\n      generationHash: generation.generation_hash,\n      queryFingerprint: fingerprint,\n      fusionProfile: FUSION_PROFILE.id,\n      candidateK,\n      vectorRevision,\n      lastScore: last.fusedScore,\n      lastId: last.id,\n    }) : null;\n    encodeSpan?.end(page.length);\n    const commitSpan = telemetry?.span('transaction.commit', RESIDENCY.NATIVE);\n    database.exec('COMMIT');\n    commitSpan?.end(1);\n    return {\n      ok: true,\n      generationHash: generation.generation_hash,\n      degraded: rankingMode !== 'hybrid',\n      rankingMode,\n      queryFingerprint: fingerprint,\n      fusionProfile: FUSION_PROFILE.id,\n      candidateK,\n      vectorRevision,\n      channelHealth,\n      eligibility: {\n        eligibleCount: eligibility.eligible.length,\n        rejectedCount: eligibility.rejectedCount,\n      },\n      cards,\n      attributions,\n      nextCursor,\n    };\n  } catch (error) {\n    database.exec('ROLLBACK');\n    throw error;\n  } finally {\n    if (ownsDatabase) database.close();\n  }\n}\n\nexport const retrievalInternals = Object.freeze({\n  decodeOpaque,\n  requestFingerprint,\n  validateQueryVector,\n  validateGeneration,\n});","lineStart":1,"lineEnd":524,"totalLines":524,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/retrieval.mjs","time":{"start":1784606353277,"end":1784606353285}},"id":"prt_f82d3e55c001gwNSKVJlLS33fL","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ccaa001KjjVqzLXb1VlKJ"}}
{"type":"tool_use","timestamp":1784606353887,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_03_AMf3snRMTZY31I3qt8ML2228","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/operator.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/operator.mjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ╔══════════════════════════════════════════════════════════════════════════╗\n3: // ║ Persistent Style Database Operator                                       ║\n4: // ╚══════════════════════════════════════════════════════════════════════════╝\n5: \n6: import { existsSync } from 'node:fs';\n7: import { readdir, rm, stat } from 'node:fs/promises';\n8: import path from 'node:path';\n9: import { pathToFileURL } from 'node:url';\n10: \n11: import {\n12:   buildStyleDatabase,\n13:   rollbackStyleDatabase,\n14: } from './indexer.mjs';\n15: import {\n16:   manifestArtifactFiles,\n17:   readManifest,\n18: } from './generation-manifest.mjs';\n19: import {\n20:   DEFAULT_STYLE_DATABASE_PATH,\n21:   STYLE_DATABASE_POINTER_SUFFIX,\n22:   openPublishedStyleDatabase,\n23:   resolvePublishedDatabasePath,\n24: } from './schema.mjs';\n25: import { rebuildVectorProjection } from './vectors.mjs';\n26: \n27: /**\n28:  * Read the published manifest's artifact roles and absolute file paths.\n29:  *\n30:  * @param {string} databasePath - Logical database path.\n31:  * @returns {Promise<{roles:string[], paths:string[]}>} Current-manifest artifacts.\n32:  */\n33: async function currentManifestArtifacts(databasePath) {\n34:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n35:   if (!existsSync(pointerPath)) return { roles: [], paths: [] };\n36:   try {\n37:     const manifest = await readManifest(pointerPath);\n38:     const directory = path.dirname(databasePath);\n39:     return {\n40:       roles: Object.keys(manifest.artifacts).sort(),\n41:       paths: manifestArtifactFiles({ artifacts: manifest.artifacts })\n42:         .map((file) => path.resolve(path.join(directory, file))),\n43:     };\n44:   } catch {\n45:     return { roles: [], paths: [] };\n46:   }\n47: }\n48: \n49: function optionValue(argumentsList, name) {\n50:   const index = argumentsList.indexOf(name);\n51:   return index === -1 ? null : argumentsList[index + 1] ?? null;\n52: }\n53: \n54: function writeJson(value, stream = process.stdout) {\n55:   stream.write(`${JSON.stringify(value, null, 2)}\\n`);\n56: }\n57: \n58: async function listGenerationPaths(databasePath) {\n59:   const directory = path.dirname(databasePath);\n60:   const prefix = `${path.basename(databasePath)}.sha256-`;\n61:   const entries = await readdir(directory, { withFileTypes: true });\n62:   const generations = [];\n63:   for (const entry of entries) {\n64:     if (!entry.isFile() || !entry.name.startsWith(prefix) || !entry.name.endsWith('.sqlite')) {\n65:       continue;\n66:     }\n67:     const generationPath = path.join(directory, entry.name);\n68:     const info = await stat(generationPath);\n69:     generations.push({ path: generationPath, modifiedAt: info.mtimeMs });\n70:   }\n71:   return generations.sort((left, right) => right.modifiedAt - left.modifiedAt\n72:     || left.path.localeCompare(right.path));\n73: }\n74: \n75: /**\n76:  * Report the published generation, rollback candidate, queues, and retained files.\n77:  *\n78:  * @param {Object} [options] - Logical database path.\n79:  * @returns {Promise<Object>} Persistent database status.\n80:  */\n81: export async function getStyleDatabaseStatus(options = {}) {\n82:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n83:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n84:   const generations = await listGenerationPaths(databasePath);\n85:   if (!existsSync(pointerPath)) {\n86:     return {\n87:       ok: true,\n88:       databasePath,\n89:       published: false,\n90:       currentGenerationPath: null,\n91:       rollbackGenerationPath: generations[0]?.path ?? null,\n92:       retainedGenerationPaths: generations.map((entry) => entry.path),\n93:       vectorJobs: {},\n94:     };\n95:   }\n96:   const currentGenerationPath = resolvePublishedDatabasePath(databasePath);\n97:   const manifestArtifacts = await currentManifestArtifacts(databasePath);\n98:   const database = openPublishedStyleDatabase(databasePath);\n99:   try {\n100:     const generationHash = database.prepare(`\n101:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n102:     `).get()?.generation_hash ?? null;\n103:     const vectorJobs = Object.fromEntries(database.prepare(`\n104:       SELECT status, COUNT(*) AS count FROM style_vector_jobs GROUP BY status ORDER BY status\n105:     `).all().map((row) => [row.status, Number(row.count)]));\n106:     return {\n107:       ok: true,\n108:       databasePath,\n109:       published: true,\n110:       generationHash,\n111:       currentGenerationPath,\n112:       manifestArtifacts: manifestArtifacts.roles,\n113:       rollbackGenerationPath: generations\n114:         .find((entry) => entry.path !== currentGenerationPath)?.path ?? null,\n115:       retainedGenerationPaths: generations.map((entry) => entry.path),\n116:       vectorJobs,\n117:     };\n118:   } finally {\n119:     database.close();\n120:   }\n121: }\n122: \n123: /**\n124:  * Remove generation files except the published file and one rollback target.\n125:  *\n126:  * @param {Object} options - Logical path and explicit retention set.\n127:  * @returns {Promise<Object>} Kept and removed generation paths.\n128:  */\n129: export async function pruneStyleDatabaseGenerations(options) {\n130:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n131:   const currentGenerationPath = options?.currentGenerationPath\n132:     ?? resolvePublishedDatabasePath(databasePath);\n133:   const rollbackGenerationPath = options?.rollbackGenerationPath ?? null;\n134:   const keep = new Set([currentGenerationPath, rollbackGenerationPath]\n135:     .filter(Boolean).map((value) => path.resolve(value)));\n136:   // Protect every artifact the published manifest references, so a generation is\n137:   // retained as a whole unit once it spans more than the SQLite file.\n138:   for (const artifactPath of (await currentManifestArtifacts(databasePath)).paths) {\n139:     keep.add(artifactPath);\n140:   }\n141:   const generations = await listGenerationPaths(databasePath);\n142:   const removed = [];\n143:   for (const generation of generations) {\n144:     if (keep.has(path.resolve(generation.path))) continue;\n145:     await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n146:       rm(`${generation.path}${suffix}`, { force: true })\n147:     )));\n148:     removed.push(generation.path);\n149:   }\n150:   return {\n151:     kept: generations.map((entry) => entry.path)\n152:       .filter((generationPath) => keep.has(path.resolve(generationPath))),\n153:     removed,\n154:   };\n155: }\n156: \n157: async function buildAndRetain(options) {\n158:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n159:   const before = await getStyleDatabaseStatus({ databasePath });\n160:   const result = await buildStyleDatabase({ ...options, databasePath });\n161:   const retention = await pruneStyleDatabaseGenerations({\n162:     databasePath,\n163:     currentGenerationPath: result.generationDatabasePath,\n164:     rollbackGenerationPath: before.currentGenerationPath,\n165:   });\n166:   return { ...result, action: 'build', retention };\n167: }\n168: \n169: async function switchGeneration(action, options) {\n170:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n171:   const before = await getStyleDatabaseStatus({ databasePath });\n172:   const generationDatabasePath = options.generationDatabasePath\n173:     ?? before.rollbackGenerationPath;\n174:   if (!generationDatabasePath) {\n175:     const error = new Error('No retained rollback generation is available.');\n176:     error.code = 'rollback-generation-unavailable';\n177:     throw error;\n178:   }\n179:   const result = await rollbackStyleDatabase({ databasePath, generationDatabasePath });\n180:   const retention = await pruneStyleDatabaseGenerations({\n181:     databasePath,\n182:     currentGenerationPath: generationDatabasePath,\n183:     rollbackGenerationPath: before.currentGenerationPath,\n184:   });\n185:   return { ...result, action, retention };\n186: }\n187: \n188: async function repairVectors(options) {\n189:   if (!options.profileId) {\n190:     const error = new Error('Vector repair requires an embedding profile.');\n191:     error.code = 'invalid-arguments';\n192:     throw error;\n193:   }\n194:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n195:   const database = openPublishedStyleDatabase(databasePath);\n196:   try {\n197:     return {\n198:       ok: true,\n199:       action: 'repair',\n200:       ...rebuildVectorProjection(database, options.profileId),\n201:     };\n202:   } finally {\n203:     database.close();\n204:   }\n205: }\n206: \n207: /**\n208:  * Dispatch the persistent style database operator command surface.\n209:  *\n210:  * @param {string[]} argumentsList - Command and flags.\n211:  * @returns {Promise<Object>} Structured operator result.\n212:  */\n213: export async function runStyleDatabaseOperator(argumentsList = process.argv.slice(2)) {\n214:   const [command, ...commandArguments] = argumentsList;\n215:   const databasePath = optionValue(commandArguments, '--database')\n216:     ?? DEFAULT_STYLE_DATABASE_PATH;\n217:   if (command === 'status') return getStyleDatabaseStatus({ databasePath });\n218:   if (command === 'build') {\n219:     const corpusRoot = optionValue(commandArguments, '--corpus');\n220:     if (!corpusRoot) {\n221:       const error = new Error('Build requires --corpus.');\n222:       error.code = 'invalid-arguments';\n223:       throw error;\n224:     }\n225:     return buildAndRetain({ corpusRoot, databasePath, corpusWalkMode: 'migration' });\n226:   }\n227:   if (command === 'cutover') {\n228:     const generationDatabasePath = optionValue(commandArguments, '--generation');\n229:     if (!generationDatabasePath) {\n230:       const error = new Error('Cutover requires --generation.');\n231:       error.code = 'invalid-arguments';\n232:       throw error;\n233:     }\n234:     return switchGeneration('cutover', { databasePath, generationDatabasePath });\n235:   }\n236:   if (command === 'rollback') {\n237:     return switchGeneration('rollback', {\n238:       databasePath,\n239:       generationDatabasePath: optionValue(commandArguments, '--generation'),\n240:     });\n241:   }\n242:   if (command === 'repair') {\n243:     return repairVectors({\n244:       databasePath,\n245:       profileId: optionValue(commandArguments, '--profile'),\n246:     });\n247:   }\n248:   const error = new Error(\n249:     'Usage: operator.mjs <status|build|cutover|rollback|repair> [options]',\n250:   );\n251:   error.code = 'invalid-arguments';\n252:   throw error;\n253: }\n254: \n255: const isDirectExecution = process.argv[1]\n256:   && import.meta.url === pathToFileURL(path.resolve(process.argv[1])).href;\n257: if (isDirectExecution) {\n258:   try {\n259:     writeJson(await runStyleDatabaseOperator());\n260:   } catch (error) {\n261:     writeJson({\n262:       ok: false,\n263:       error: error.code ?? 'internal-error',\n264:       message: error.message,\n265:     }, process.stderr);\n266:     process.exitCode = 1;\n267:   }\n268: }\n\n(End of file - total 268 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Operator                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { existsSync } from 'node:fs';\nimport { readdir, rm, stat } from 'node:fs/promises';\nimport path from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport {\n  buildStyleDatabase,\n  rollbackStyleDatabase,\n} from './indexer.mjs';\nimport {\n  manifestArtifactFiles,\n  readManifest,\n} from './generation-manifest.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/operator.mjs","text":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Operator                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { existsSync } from 'node:fs';\nimport { readdir, rm, stat } from 'node:fs/promises';\nimport path from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport {\n  buildStyleDatabase,\n  rollbackStyleDatabase,\n} from './indexer.mjs';\nimport {\n  manifestArtifactFiles,\n  readManifest,\n} from './generation-manifest.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  STYLE_DATABASE_POINTER_SUFFIX,\n  openPublishedStyleDatabase,\n  resolvePublishedDatabasePath,\n} from './schema.mjs';\nimport { rebuildVectorProjection } from './vectors.mjs';\n\n/**\n * Read the published manifest's artifact roles and absolute file paths.\n *\n * @param {string} databasePath - Logical database path.\n * @returns {Promise<{roles:string[], paths:string[]}>} Current-manifest artifacts.\n */\nasync function currentManifestArtifacts(databasePath) {\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  if (!existsSync(pointerPath)) return { roles: [], paths: [] };\n  try {\n    const manifest = await readManifest(pointerPath);\n    const directory = path.dirname(databasePath);\n    return {\n      roles: Object.keys(manifest.artifacts).sort(),\n      paths: manifestArtifactFiles({ artifacts: manifest.artifacts })\n        .map((file) => path.resolve(path.join(directory, file))),\n    };\n  } catch {\n    return { roles: [], paths: [] };\n  }\n}\n\nfunction optionValue(argumentsList, name) {\n  const index = argumentsList.indexOf(name);\n  return index === -1 ? null : argumentsList[index + 1] ?? null;\n}\n\nfunction writeJson(value, stream = process.stdout) {\n  stream.write(`${JSON.stringify(value, null, 2)}\\n`);\n}\n\nasync function listGenerationPaths(databasePath) {\n  const directory = path.dirname(databasePath);\n  const prefix = `${path.basename(databasePath)}.sha256-`;\n  const entries = await readdir(directory, { withFileTypes: true });\n  const generations = [];\n  for (const entry of entries) {\n    if (!entry.isFile() || !entry.name.startsWith(prefix) || !entry.name.endsWith('.sqlite')) {\n      continue;\n    }\n    const generationPath = path.join(directory, entry.name);\n    const info = await stat(generationPath);\n    generations.push({ path: generationPath, modifiedAt: info.mtimeMs });\n  }\n  return generations.sort((left, right) => right.modifiedAt - left.modifiedAt\n    || left.path.localeCompare(right.path));\n}\n\n/**\n * Report the published generation, rollback candidate, queues, and retained files.\n *\n * @param {Object} [options] - Logical database path.\n * @returns {Promise<Object>} Persistent database status.\n */\nexport async function getStyleDatabaseStatus(options = {}) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const generations = await listGenerationPaths(databasePath);\n  if (!existsSync(pointerPath)) {\n    return {\n      ok: true,\n      databasePath,\n      published: false,\n      currentGenerationPath: null,\n      rollbackGenerationPath: generations[0]?.path ?? null,\n      retainedGenerationPaths: generations.map((entry) => entry.path),\n      vectorJobs: {},\n    };\n  }\n  const currentGenerationPath = resolvePublishedDatabasePath(databasePath);\n  const manifestArtifacts = await currentManifestArtifacts(databasePath);\n  const database = openPublishedStyleDatabase(databasePath);\n  try {\n    const generationHash = database.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash ?? null;\n    const vectorJobs = Object.fromEntries(database.prepare(`\n      SELECT status, COUNT(*) AS count FROM style_vector_jobs GROUP BY status ORDER BY status\n    `).all().map((row) => [row.status, Number(row.count)]));\n    return {\n      ok: true,\n      databasePath,\n      published: true,\n      generationHash,\n      currentGenerationPath,\n      manifestArtifacts: manifestArtifacts.roles,\n      rollbackGenerationPath: generations\n        .find((entry) => entry.path !== currentGenerationPath)?.path ?? null,\n      retainedGenerationPaths: generations.map((entry) => entry.path),\n      vectorJobs,\n    };\n  } finally {\n    database.close();\n  }\n}\n\n/**\n * Remove generation files except the published file and one rollback target.\n *\n * @param {Object} options - Logical path and explicit retention set.\n * @returns {Promise<Object>} Kept and removed generation paths.\n */\nexport async function pruneStyleDatabaseGenerations(options) {\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const currentGenerationPath = options?.currentGenerationPath\n    ?? resolvePublishedDatabasePath(databasePath);\n  const rollbackGenerationPath = options?.rollbackGenerationPath ?? null;\n  const keep = new Set([currentGenerationPath, rollbackGenerationPath]\n    .filter(Boolean).map((value) => path.resolve(value)));\n  // Protect every artifact the published manifest references, so a generation is\n  // retained as a whole unit once it spans more than the SQLite file.\n  for (const artifactPath of (await currentManifestArtifacts(databasePath)).paths) {\n    keep.add(artifactPath);\n  }\n  const generations = await listGenerationPaths(databasePath);\n  const removed = [];\n  for (const generation of generations) {\n    if (keep.has(path.resolve(generation.path))) continue;\n    await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n      rm(`${generation.path}${suffix}`, { force: true })\n    )));\n    removed.push(generation.path);\n  }\n  return {\n    kept: generations.map((entry) => entry.path)\n      .filter((generationPath) => keep.has(path.resolve(generationPath))),\n    removed,\n  };\n}\n\nasync function buildAndRetain(options) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const before = await getStyleDatabaseStatus({ databasePath });\n  const result = await buildStyleDatabase({ ...options, databasePath });\n  const retention = await pruneStyleDatabaseGenerations({\n    databasePath,\n    currentGenerationPath: result.generationDatabasePath,\n    rollbackGenerationPath: before.currentGenerationPath,\n  });\n  return { ...result, action: 'build', retention };\n}\n\nasync function switchGeneration(action, options) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const before = await getStyleDatabaseStatus({ databasePath });\n  const generationDatabasePath = options.generationDatabasePath\n    ?? before.rollbackGenerationPath;\n  if (!generationDatabasePath) {\n    const error = new Error('No retained rollback generation is available.');\n    error.code = 'rollback-generation-unavailable';\n    throw error;\n  }\n  const result = await rollbackStyleDatabase({ databasePath, generationDatabasePath });\n  const retention = await pruneStyleDatabaseGenerations({\n    databasePath,\n    currentGenerationPath: generationDatabasePath,\n    rollbackGenerationPath: before.currentGenerationPath,\n  });\n  return { ...result, action, retention };\n}\n\nasync function repairVectors(options) {\n  if (!options.profileId) {\n    const error = new Error('Vector repair requires an embedding profile.');\n    error.code = 'invalid-arguments';\n    throw error;\n  }\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const database = openPublishedStyleDatabase(databasePath);\n  try {\n    return {\n      ok: true,\n      action: 'repair',\n      ...rebuildVectorProjection(database, options.profileId),\n    };\n  } finally {\n    database.close();\n  }\n}\n\n/**\n * Dispatch the persistent style database operator command surface.\n *\n * @param {string[]} argumentsList - Command and flags.\n * @returns {Promise<Object>} Structured operator result.\n */\nexport async function runStyleDatabaseOperator(argumentsList = process.argv.slice(2)) {\n  const [command, ...commandArguments] = argumentsList;\n  const databasePath = optionValue(commandArguments, '--database')\n    ?? DEFAULT_STYLE_DATABASE_PATH;\n  if (command === 'status') return getStyleDatabaseStatus({ databasePath });\n  if (command === 'build') {\n    const corpusRoot = optionValue(commandArguments, '--corpus');\n    if (!corpusRoot) {\n      const error = new Error('Build requires --corpus.');\n      error.code = 'invalid-arguments';\n      throw error;\n    }\n    return buildAndRetain({ corpusRoot, databasePath, corpusWalkMode: 'migration' });\n  }\n  if (command === 'cutover') {\n    const generationDatabasePath = optionValue(commandArguments, '--generation');\n    if (!generationDatabasePath) {\n      const error = new Error('Cutover requires --generation.');\n      error.code = 'invalid-arguments';\n      throw error;\n    }\n    return switchGeneration('cutover', { databasePath, generationDatabasePath });\n  }\n  if (command === 'rollback') {\n    return switchGeneration('rollback', {\n      databasePath,\n      generationDatabasePath: optionValue(commandArguments, '--generation'),\n    });\n  }\n  if (command === 'repair') {\n    return repairVectors({\n      databasePath,\n      profileId: optionValue(commandArguments, '--profile'),\n    });\n  }\n  const error = new Error(\n    'Usage: operator.mjs <status|build|cutover|rollback|repair> [options]',\n  );\n  error.code = 'invalid-arguments';\n  throw error;\n}\n\nconst isDirectExecution = process.argv[1]\n  && import.meta.url === pathToFileURL(path.resolve(process.argv[1])).href;\nif (isDirectExecution) {\n  try {\n    writeJson(await runStyleDatabaseOperator());\n  } catch (error) {\n    writeJson({\n      ok: false,\n      error: error.code ?? 'internal-error',\n      message: error.message,\n    }, process.stderr);\n    process.exitCode = 1;\n  }\n}","lineStart":1,"lineEnd":268,"totalLines":268,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/operator.mjs","time":{"start":1784606353880,"end":1784606353885}},"id":"prt_f82d3e7ad0016gb9h0bSzQ2Ye8","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ccaa001KjjVqzLXb1VlKJ"}}
