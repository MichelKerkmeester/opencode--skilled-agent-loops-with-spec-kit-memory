{"type":"step_start","timestamp":1784444179088,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"id":"prt_f7929528e001F1EqqKhwkPmL3r","messageID":"msg_f792942d4001wXTzhf9r6tCJK0","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","snapshot":"fe03b20dde9c4dbba7dc0e6f79ecce2c3c838fcc","type":"step-start"}}
{"type":"tool_use","timestamp":1784444180493,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"type":"tool","tool":"read","callID":"call_HCpeS0y6G94GroGvYRfLm6SM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-research-auto.yaml","offset":1529,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-research-auto.yaml</path>\n<type>file</type>\n<content>\n1529:       step_generate_dashboard:\n1530:         action: \"Generate or refresh the human-readable dashboard\"\n1531:         read:\n1532:           - \"{state_paths.state_log}\"\n1533:           - \"{state_paths.registry}\"\n1534:           - \"{state_paths.strategy}\"\n1535:         template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-dashboard.md\n1536:         output: \"{state_paths.dashboard}\"\n1537:         note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n1538: \n1539:       step_update_tracking:\n1540:         action: \"Update loop tracking variables\"\n1541:         set:\n1542:           current_iteration: \"{current_iteration + 1}\"\n1543:           stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n1544:         log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n1545: \n1546:       step_loop_decision:\n1547:         action: \"Return to step_read_state for next iteration\"\n1548:         goto: step_read_state\n1549: \n1550:   # ═══════════════════════════════════════════════════════════════\n1551:   # PHASE 3: SYNTHESIS\n1552:   # ═══════════════════════════════════════════════════════════════\n1553:   phase_synthesis:\n1554:     purpose: Compile all iteration findings into final research/research.md\n1555:     steps:\n1556: \n1557:       step_fanout_merge:\n1558:         description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n1559:         skip_when: \"config.fanout is absent\"\n1560:         command: |\n1561:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n1562:             --loop-type research \\\n1563:             --artifact-dir {artifact_dir}\n1564:         working_directory: \"{repo_root}\"\n1565:         wait_for_completion: true\n1566: \n1567:       step_hydrate_summary_metrics:\n1568:         action: \"Hydrate summary metrics before synthesis\"\n1569:         read:\n1570:           - \"{state_paths.config}\"\n1571:           - \"{state_paths.state_log}\"\n1572:           - \"{state_paths.registry}\"\n1573:           - \"{state_paths.strategy}\"\n1574:         extract:\n1575:           - iteration_count: \"Count lines where type === 'iteration'\"\n1576:           - current_iteration: \"iteration_count + 1\"\n1577:           - current_segment: \"Latest segment_start event segment, else 1\"\n1578:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n1579:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n1580:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n1581:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n1582:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n1583:           - answered_count: \"Count answered questions from strategy.md\"\n1584:           - total_questions: \"Count total questions tracked in strategy.md\"\n1585:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n1586:           - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n1587:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1588: \n1589:       step_read_all_iterations:\n1590:         action: \"Read all iteration files and strategy\"\n1591:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1592:         read_also: \"{state_paths.strategy}\"\n1593: \n1594:       step_emit_resource_map:\n1595:         action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n1596:         command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1597:         read:\n1598:           - \"{state_paths.config}\"\n1599:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1600:         write:\n1601:           - \"{state_paths.resource_map_output}\"\n1602:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1603: \n1604:       step_compile_research:\n1605:         action: \"Compile or finalize research/research.md\"\n1606:         instructions: |\n1607:           If research/research.md exists (progressive synthesis was active):\n1608:             1. Read current research/research.md\n1609:             2. Consolidate and deduplicate findings across all iterations\n1610:             3. Fill any empty sections with findings from iteration files\n1611:             4. Remove redundancy while preserving all unique findings\n1612:             5. Add convergence report as appendix\n1613:             6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1614:             7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n1615: \n1616:           If research/research.md does not exist:\n1617:             1. Create research/research.md following 17-section template\n1618:             2. Populate sections from iteration files\n1619:             3. Add citations from original sources\n1620:             4. Note unanswered questions in Open Questions section\n1621:             5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1622:             6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n1623:           Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n1624:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop-protocol.md §Lifecycle Branch Contract`.)\n1625:         output: \"{state_paths.research_output}\"\n1626: \n1627:       step_convergence_report:\n1628:         action: \"Generate and append convergence report\"\n1629:         report: |\n1630:           ## Convergence Report\n1631:           - Stop reason: {reason}\n1632:           - Total iterations: {iteration_count}\n1633:           - Questions answered: {answered_count} / {total_questions}\n1634:           - Remaining questions: {remaining_questions}\n1635:           - Last 3 iteration summaries: {last_3_summaries}\n1636:           - Convergence threshold: {convergence_threshold}\n1637:           - Divergence summary: {divergence_summary}\n1638:           - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n1639:         command: |\n1640:           node --input-type=module <<'EOF'\n1641:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1642: \n1643:           const paths = {\n1644:             stateLog: String.raw`{state_paths.state_log}`,\n1645:             registry: String.raw`{state_paths.registry}`,\n1646:             research: String.raw`{state_paths.research_output}`,\n1647:             dashboard: String.raw`{state_paths.dashboard}`,\n1648:           };\n1649: \n1650:           function hasFile(filePath) {\n1651:             try {\n1652:               return existsSync(filePath) && statSync(filePath).isFile();\n1653:             } catch {\n1654:               return false;\n1655:             }\n1656:           }\n1657: \n1658:           function readJson(filePath) {\n1659:             try {\n1660:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1661:             } catch {\n1662:               return null;\n1663:             }\n1664:           }\n1665: \n1666:           function readJsonl(filePath) {\n1667:             if (!hasFile(filePath)) return [];\n1668:             return readFileSync(filePath, 'utf8')\n1669:               .split(/\\r?\\n/)\n1670:               .map((line) => line.trim())\n1671:               .filter(Boolean)\n1672:               .flatMap((line) => {\n1673:                 try {\n1674:                   return [JSON.parse(line)];\n1675:                 } catch {\n1676:                   return [];\n1677:                 }\n1678:               });\n1679:           }\n1680: \n1681:           function countIterationFindings(record) {\n1682:             if (!record || record.type !== 'iteration') return 0;\n1683:             const numeric = Number(record.findingsCount);\n1684:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1685:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1686:             if (Array.isArray(record.findings)) return record.findings.length;\n1687:             return 0;\n1688:           }\n1689: \n1690:           function normalizeFindingKey(value) {\n1691:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1692:           }\n1693: \n1694:           function findingKeys(candidate) {\n1695:             if (typeof candidate === 'string') {\n1696:               const key = normalizeFindingKey(candidate);\n1697:               return key ? [key] : [];\n1698:             }\n1699:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1700:             return [...new Set([\n1701:               candidate.id,\n1702:               candidate.title,\n1703:               candidate.summary,\n1704:               candidate.text,\n1705:               candidate.finding,\n1706:               candidate.description,\n1707:             ].map(normalizeFindingKey).filter(Boolean))];\n1708:           }\n1709: \n1710:           function collectIterationFindingGroups(record) {\n1711:             if (!record || record.type !== 'iteration') return [];\n1712:             const structured = [record.keyFindings, record.findings]\n1713:               .find((value) => Array.isArray(value) && value.length > 0);\n1714:             if (!Array.isArray(structured)) return [];\n1715:             return structured\n1716:               .map(findingKeys)\n1717:               .filter((keys) => keys.length > 0);\n1718:           }\n1719: \n1720:           function collectRegistryFindingKeys(registry) {\n1721:             if (!Array.isArray(registry?.keyFindings)) return [];\n1722:             return registry.keyFindings\n1723:               .flatMap(findingKeys);\n1724:           }\n1725: \n1726:           function appendEvent(event) {\n1727:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1728:           }\n1729: \n1730:           const registry = readJson(paths.registry);\n1731:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1732:           const stateRecords = readJsonl(paths.stateLog);\n1733:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1734:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1735:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1736:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1737:           const identifiableFindingCount = identifiableFindingGroups.length;\n1738:           const missingArtifacts = [\n1739:             ['registry', paths.registry],\n1740:             ['research', paths.research],\n1741:             ['dashboard', paths.dashboard],\n1742:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1743:           const invariantFailures = [];\n1744:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1745:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1746:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1747:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1748:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1749: \n1750:           if (invariantFailures.length > 0) {\n1751:             appendEvent({\n1752:               type: 'event',\n1753:               event: 'synthesis_incomplete',\n1754:               mode: 'research',\n1755:               severity: 'warning',\n1756:               totalIterations: Number('{iteration_count}'),\n1757:               answeredCount: Number('{answered_count}'),\n1758:               totalQuestions: Number('{total_questions}'),\n1759:               stopReason: '{reason}',\n1760:               reason: 'synthesis_artifact_invariant_failed',\n1761:               invariantFailures,\n1762:               missingArtifacts,\n1763:               registryFindingCount,\n1764:               iterationFindingCount,\n1765:               identifiableFindingCount,\n1766:               missingStructuredFindingCount,\n1767:               timestamp: '{ISO_8601_NOW}',\n1768:             });\n1769:           } else {\n1770:             appendEvent({\n1771:               type: 'event',\n1772:               event: 'synthesis_complete',\n1773:               totalIterations: Number('{iteration_count}'),\n1774:               answeredCount: Number('{answered_count}'),\n1775:               totalQuestions: Number('{total_questions}'),\n1776:               stopReason: '{reason}',\n1777:               timestamp: '{ISO_8601_NOW}',\n1778:             });\n1779:           }\n1780:           EOF\n1781: \n1782:       step_writeback_spec_findings:\n1783:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1784:         edit: \"{spec_folder}/spec.md\"\n1785:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1786:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1787:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1788:         fail_closed_conflict_check:\n1789:           if_existing_generated_fence_present:\n1790:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1791:             on_manual_edit_conflict:\n1792:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1793:               halt: true\n1794:         instructions:\n1795:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1796:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1797:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1798:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1799:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1800:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1801: \n1802:       step_validate_post_synthesis_spec_doc:\n1803:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1804:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1805:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1806: \n1807:       step_update_config_status:\n1808:         action: \"Mark config as complete\"\n1809:         edit: \"{state_paths.config}\"\n1810:         set_field: { status: \"complete\" }\n1811: \n1812:       step_telemetry_heartbeat_terminal:\n1813:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1814:         skip_when: \"config.fanout is present\"\n1815:         terminal_events: [completed, failed, stopped]\n1816:         command: |\n1817:           node --experimental-strip-types --input-type=module <<'EOF'\n1818:           import { existsSync, readFileSync } from 'node:fs';\n1819: \n1820:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n1821:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n1822: \n1823:           const { appendObservabilityEvent } = observabilityEvents;\n1824:           const stateLogPath = '{state_paths.state_log}';\n1825:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1826:           const timestamp = '{ISO_8601_NOW}';\n1827:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1828:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1829:           const reason = '{reason}';\n1830:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1831: \n1832:           function readRecords(path) {\n1833:             if (!existsSync(path)) return [];\n1834:             return readFileSync(path, 'utf8')\n1835:               .split(/\\r?\\n/)\n1836:               .map((line) => line.trim())\n1837:               .filter(Boolean)\n1838:               .map((line) => JSON.parse(line));\n1839:           }\n1840: \n1841:           function elapsedSince(value) {\n1842:             const startedAtMs = Date.parse(String(value ?? ''));\n1843:             const nowMs = Date.parse(timestamp);\n1844:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1845:             return Math.max(0, nowMs - startedAtMs);\n1846:           }\n1847: \n1848:           function terminalEvent(stopReason) {\n1849:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1850:             if (stopReason === 'error') return 'failed';\n1851:             return 'completed';\n1852:           }\n1853: \n1854:           const records = readRecords(stateLogPath);\n1855:           const iterations = records.filter((record) => record.type === 'iteration');\n1856:           const latest = iterations.at(-1) ?? {};\n1857:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1858:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1859:             ?? timestamp;\n1860:           const elapsedMs = elapsedSince(startedAt);\n1861:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1862:           const event = terminalEvent(reason);\n1863:           const row = {\n1864:             event,\n1865:             label: 'single',\n1866:             terminal: true,\n1867:             reason,\n1868:             at: timestamp,\n1869:             duration_ms: elapsedMs,\n1870:             loop_type: 'research',\n1871:             sessionId,\n1872:             generation,\n1873:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1874:           };\n1875: \n1876:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1877:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1878:             diffField: 'state_hash',\n1879:           });\n1880:           if (appended) {\n1881:             try {\n1882:               appendObservabilityEvent(observabilityPath, row, {\n1883:                 producer: 'deep-research-auto',\n1884:                 stream: 'single-loop-telemetry',\n1885:                 subject: { label: row.label, sessionId, generation, reason },\n1886:                 event,\n1887:                 status: event,\n1888:               });\n1889:             } catch {}\n1890:           }\n1891:           EOF\n1892:         working_directory: \"{repo_root}\"\n1893:         outputs:\n1894:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1895: \n1896:       step_stage_artifact_dir:\n1897:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1898:         command: \"git add {state_paths.packet_dir}\"\n1899:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1900:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1901: \n1902:   # ═══════════════════════════════════════════════════════════════\n1903:   # PHASE 4: SAVE\n1904:   # ═══════════════════════════════════════════════════════════════\n1905:   phase_save:\n1906:     purpose: Preserve research context to memory system\n1907:     steps:\n1908: \n1909:       step_compose_save_payload:\n1910:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1911:         output: \"/tmp/save-context-data-<session-id>.json\"\n1912:         requirements:\n1913:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1914:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1915:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1916:         example_payload: |\n1917:           {\n1918:             \"specFolder\": \"{spec_folder}\",\n1919:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n1920:             \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n1921:             \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n1922:             \"exchanges\": [],\n1923:             \"toolCalls\": []\n1924:           }\n1925: \n1926:       step_generate_context:\n1927:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1928:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1929:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1930: \n1931:       step_index_memory:\n1932:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1933:         mcp_tool: memory_save\n1934:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1935:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1936: \n1937:       step_verify_save:\n1938:         action: \"Verify canonical save routed content into the correct spec document\"\n1939:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1940:         on_fail: \"Log warning but do not block completion\"\n1941: \n1942:       step_release_lock:\n1943:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1944:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1945:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1946: \n1947:   # ═══════════════════════════════════════════════════════════════\n1948:   # COMPLETION\n1949:   # ═══════════════════════════════════════════════════════════════\n1950:   completion:\n1951:     message: |\n1952:       Deep research complete.\n1953:       Iterations: {iteration_count} | Stop reason: {reason}\n1954:       Questions answered: {answered_count}/{total_questions}\n1955: \n1956:       Artifacts:\n1957:         - research/research.md (compiled from {iteration_count} iterations)\n1958:         - {iteration_count} iteration files in research/\n1959:         - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n1960:         - Memory context saved\n1961: \n1962:       STATUS=OK PATH={spec_folder}\n1963:     next_steps:\n1964:       - \"/speckit:plan [feature-description]\"\n1965:       - \"/deep:research [new-topic] (for related deep research)\"\n1966:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1967: \n1968: # ─────────────────────────────────────────────────────────────────\n1969: # ERROR RECOVERY\n1970: # ─────────────────────────────────────────────────────────────────\n1971: error_recovery:\n1972:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n1973:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1974:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1975:   memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n1976: \n1977: # ─────────────────────────────────────────────────────────────────\n1978: # RULES\n1979: # ─────────────────────────────────────────────────────────────────\n1980: rules:\n1981:   ALWAYS:\n1982:     - follow_workflow_phases_in_order\n1983:     - dispatch_deep_research_agent_per_iteration\n1984:     - check_convergence_before_each_iteration\n1985:     - write_all_state_to_files\n1986:     - upsert_iteration_memory_after_reducer\n1987:     - refresh_memory_context_before_next_prompt\n1988:     - save_memory_context_after_synthesis\n1989:     - respect_max_iterations_cap\n1990:   NEVER:\n1991:     - skip_convergence_check\n1992:     - dispatch_non_leaf_agents\n1993:     - hold_iteration_findings_in_memory_only\n1994:     - modify_config_after_initialization\n1995:     - overwrite_jsonl_state_log\n1996:     - proceed_without_state_file_verification\n1997: \n1998: # ─────────────────────────────────────────────────────────────────\n1999: # REFERENCE-ONLY APPENDIX\n2000: # ─────────────────────────────────────────────────────────────────\n2001: reference_only_appendix:\n2002:   checkpoint_commit:\n2003:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n2004:     commands:\n2005:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n2006:       - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n2007:   wave_orchestration:\n2008:     note: \"Wave execution is intentionally excluded from workflow.steps.\"\n2009:     summary:\n2010:       - \"Check whether 3+ independent unanswered questions justify a wave.\"\n2011:       - \"Dispatch up to 3 parallel agents on distinct questions.\"\n2012:       - \"Score wave results by median newInfoRatio and promote top branches.\"\n\n(End of file - total 2012 lines)\n</content>","metadata":{"preview":"      step_generate_dashboard:\n        action: \"Generate or refresh the human-readable dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-dashboard.md\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n        log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep-research-auto.yaml","text":"      step_generate_dashboard:\n        action: \"Generate or refresh the human-readable dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        template: .opencode/skills/system-deep-loop/deep-research/assets/deep-research-dashboard.md\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n        log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into final research/research.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n            --loop-type research \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_compile_research:\n        action: \"Compile or finalize research/research.md\"\n        instructions: |\n          If research/research.md exists (progressive synthesis was active):\n            1. Read current research/research.md\n            2. Consolidate and deduplicate findings across all iterations\n            3. Fill any empty sections with findings from iteration files\n            4. Remove redundancy while preserving all unique findings\n            5. Add convergence report as appendix\n            6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n\n          If research/research.md does not exist:\n            1. Create research/research.md following 17-section template\n            2. Populate sections from iteration files\n            3. Add citations from original sources\n            4. Note unanswered questions in Open Questions section\n            5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n          Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop-protocol.md §Lifecycle Branch Contract`.)\n        output: \"{state_paths.research_output}\"\n\n      step_convergence_report:\n        action: \"Generate and append convergence report\"\n        report: |\n          ## Convergence Report\n          - Stop reason: {reason}\n          - Total iterations: {iteration_count}\n          - Questions answered: {answered_count} / {total_questions}\n          - Remaining questions: {remaining_questions}\n          - Last 3 iteration summaries: {last_3_summaries}\n          - Convergence threshold: {convergence_threshold}\n          - Divergence summary: {divergence_summary}\n          - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.registry}`,\n            research: String.raw`{state_paths.research_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n            \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n            \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep research complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Questions answered: {answered_count}/{total_questions}\n\n      Artifacts:\n        - research/research.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in research/\n        - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [feature-description]\"\n      - \"/deep:research [new-topic] (for related deep research)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_research_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - upsert_iteration_memory_after_reducer\n    - refresh_memory_context_before_next_prompt\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n      - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n  wave_orchestration:\n    note: \"Wave execution is intentionally excluded from workflow.steps.\"\n    summary:\n      - \"Check whether 3+ independent unanswered questions justify a wave.\"\n      - \"Dispatch up to 3 parallel agents on distinct questions.\"\n      - \"Score wave results by median newInfoRatio and promote top branches.\"","lineStart":1529,"lineEnd":2012,"totalLines":2012,"truncated":false}},"title":".opencode/commands/deep/assets/deep-research-auto.yaml","time":{"start":1784444180480,"end":1784444180491}},"metadata":{"openai":{"itemId":"fc_01a1f34779897c6f016a5c75140c1081919c3efa57188cd699"}},"id":"prt_f79295666001yXn9bpWbbqli1I","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","messageID":"msg_f792942d4001wXTzhf9r6tCJK0"}}
{"type":"step_finish","timestamp":1784444181878,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"id":"prt_f79295d72001Tg1ab59BG7Fj1C","reason":"tool-calls","snapshot":"fe03b20dde9c4dbba7dc0e6f79ecce2c3c838fcc","messageID":"msg_f792942d4001wXTzhf9r6tCJK0","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","type":"step-finish","tokens":{"total":137647,"input":33642,"output":60,"reasoning":9,"cache":{"write":0,"read":103936}},"cost":0}}
{"type":"step_start","timestamp":1784444186245,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"id":"prt_f79296e82001Eka1UwWOLFg7aW","messageID":"msg_f792962b6001lv5629da5hf4ne","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","snapshot":"fe03b20dde9c4dbba7dc0e6f79ecce2c3c838fcc","type":"step-start"}}
{"type":"tool_use","timestamp":1784444196114,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"type":"tool","tool":"read","callID":"call_1M0gszk5IL55Bd0QXXA9R1CL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n7: // ║         --base-artifact-dir).                                            ║\n8: // ║ Output: JSON to stdout.                                                  ║\n9: // ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: \n12: 'use strict';\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 1. IMPORTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: const fs = require('node:fs');\n19: const os = require('node:os');\n20: const path = require('node:path');\n21: const { spawn, spawnSync } = require('node:child_process');\n22: \n23: const {\n24:   classifyExitCode,\n25:   maybeThrowTestFault,\n26:   validateNamespaceValue,\n27: } = require('./lib/cli-guards.cjs');\n28: \n29: const {\n30:   runCappedPool,\n31:   appendStatusLedger,\n32:   markOrphanedLineages,\n33:   readRetryCountsFromLedger,\n34:   createWavePlannerInterface,\n35:   writeOrchestrationSummary,\n36: } = require('./fanout-pool.cjs');\n37: \n38: const {\n39:   runSalvageSweep,\n40:   extractTextFromOpencodeJson,\n41: } = require('./fanout-salvage.cjs');\n42: \n43: const {\n44:   appendObservabilityEvent,\n45: } = require('../lib/deep-loop/observability-events.cjs');\n46: \n47: // ─────────────────────────────────────────────────────────────────────────────\n48: // 2. TSX BOOTSTRAP\n49: // ─────────────────────────────────────────────────────────────────────────────\n50: \n51: const TSX_LOADER = require.resolve('tsx');\n52: const isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n53: \n54: function runTsxBootstrap() {\n55:   const child = spawn(\n56:     process.execPath,\n57:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n58:     {\n59:       cwd: process.cwd(),\n60:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n61:       stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n62:     },\n63:   );\n64: \n65:   if (!process.stdin.isTTY && child.stdin) {\n66:     child.stdin.on('error', () => {});\n67:     process.stdin.pipe(child.stdin);\n68:   }\n69: \n70:   child.stdout?.pipe(process.stdout);\n71:   child.stderr?.pipe(process.stderr);\n72: \n73:   for (const signal of ['SIGINT', 'SIGTERM']) {\n74:     process.once(signal, () => {\n75:       child.kill(signal);\n76:     });\n77:   }\n78: \n79:   child.on('close', (status, signal) => {\n80:     if (status !== null) {\n81:       process.exit(status);\n82:     }\n83:     process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n84:   });\n85: }\n86: \n87: if (require.main === module && !isTsxLoaded) {\n88:   runTsxBootstrap();\n89: }\n90: \n91: // ─────────────────────────────────────────────────────────────────────────────\n92: // 3. HELPERS\n93: // ─────────────────────────────────────────────────────────────────────────────\n94: \n95: function parseArgs(argv = process.argv.slice(2)) {\n96:   const args = {};\n97:   for (let i = 0; i < argv.length; i += 1) {\n98:     const token = argv[i];\n99:     if (!token.startsWith('--')) {\n100:       throw inputError(`Unexpected positional argument: ${token}`);\n101:     }\n102:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n103:     const next = argv[i + 1];\n104:     if (next === undefined || next.startsWith('--')) {\n105:       args[key] = true;\n106:     } else {\n107:       args[key] = next;\n108:       i += 1;\n109:     }\n110:   }\n111:   return args;\n112: }\n113: \n114: function inputError(message) {\n115:   const err = new Error(message);\n116:   err.code = 'INPUT_VALIDATION';\n117:   return err;\n118: }\n119: \n120: function ensureString(args, key) {\n121:   if (!args[key] || typeof args[key] !== 'string') {\n122:     throw inputError(`${key} is required`);\n123:   }\n124:   return args[key];\n125: }\n126: \n127: function parseOptionalNumber(args, key) {\n128:   const raw = args[key];\n129:   if (raw === undefined || raw === false || raw === null || raw === '') {\n130:     return null;\n131:   }\n132:   if (raw === true || typeof raw !== 'string') {\n133:     throw inputError(`${key} must be a number`);\n134:   }\n135:   const value = Number(raw);\n136:   if (!Number.isFinite(value) || value < 0) {\n137:     throw inputError(`${key} must be a non-negative number`);\n138:   }\n139:   return value;\n140: }\n141: \n142: function readRawConfigNumber(rawConfig, names, fieldName) {\n143:   if (!isRecord(rawConfig)) return null;\n144:   for (const name of names) {\n145:     if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n146:     const raw = rawConfig[name];\n147:     if (raw === undefined || raw === null || raw === '') return null;\n148:     if (raw === true || raw === false) {\n149:       throw inputError(`${fieldName} must be a non-negative number`);\n150:     }\n151:     const value = Number(raw);\n152:     if (!Number.isFinite(value) || value < 0) {\n153:       throw inputError(`${fieldName} must be a non-negative number`);\n154:     }\n155:     return Math.floor(value);\n156:   }\n157:   return null;\n158: }\n159: \n160: function readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n161:   const value = readRawConfigNumber(rawConfig, names, fieldName);\n162:   if (value === null) return fallback;\n163:   if (value <= 0) {\n164:     throw inputError(`${fieldName} must be greater than 0`);\n165:   }\n166:   return value;\n167: }\n168: \n169: function rawConfigWithCliBudgetOverrides(rawConfig, args) {\n170:   const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n171:   const mappings = [\n172:     ['stallWatchdogMs', 'stallWatchdogMs'],\n173:     ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n174:     ['maxAggregateCostUnits', 'maxAggregateCostUnits'],\n175:     ['maxTokensPerLineage', 'maxTokensPerLineage'],\n176:     ['maxTokenBudget', 'maxTokenBudget'],\n177:     ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n178:     ['costUnitsPerIteration', 'costUnitsPerIteration'],\n179:     ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n180:   ];\n181:   for (const [targetKey, argKey] of mappings) {\n182:     if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n183:       merged[targetKey] = args[argKey];\n184:     }\n185:   }\n186:   return merged;\n187: }\n188: \n189: function normalizeStopPolicy(raw) {\n190:   if (raw === undefined || raw === false || raw === null || raw === '') {\n191:     return 'convergence';\n192:   }\n193:   if (raw === true || typeof raw !== 'string') {\n194:     throw inputError('stopPolicy must be convergence or max-iterations');\n195:   }\n196:   if (raw !== 'convergence' && raw !== 'max-iterations') {\n197:     throw inputError('stopPolicy must be convergence or max-iterations');\n198:   }\n199:   return raw;\n200: }\n201: \n202: function jsonOut(payload) {\n203:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n204: }\n205: \n206: function signalExitCode(signal) {\n207:   return signal === 'SIGINT' ? 130 : 143;\n208: }\n209: \n210: let fanoutSignalHandlersInstalled = false;\n211: \n212: function installFanoutSignalHandlers(onStop) {\n213:   if (fanoutSignalHandlersInstalled) return;\n214:   fanoutSignalHandlersInstalled = true;\n215: \n216:   for (const signal of ['SIGINT', 'SIGTERM']) {\n217:     process.once(signal, () => {\n218:       try {\n219:         onStop(signal);\n220:       } finally {\n221:         process.exit(signalExitCode(signal));\n222:       }\n223:     });\n224:   }\n225: }\n226: \n227: function updateLineageSnapshot(snapshots, event) {\n228:   if (!event || typeof event.label !== 'string') return;\n229:   const existing = snapshots.get(event.label) || { label: event.label };\n230: \n231:   if (event.event === 'started') {\n232:     snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n233:     return;\n234:   }\n235:   if (event.event === 'completed') {\n236:     snapshots.set(event.label, {\n237:       ...existing,\n238:       status: 'fulfilled',\n239:       completed_at_iso: event.at,\n240:       duration_ms: event.duration_ms,\n241:     });\n242:     return;\n243:   }\n244:   if (event.event === 'failed') {\n245:     snapshots.set(event.label, {\n246:       ...existing,\n247:       status: event.terminal === false ? 'retrying' : 'rejected',\n248:       completed_at_iso: event.at,\n249:       duration_ms: event.duration_ms,\n250:       error: event.error,\n251:     });\n252:     return;\n253:   }\n254:   if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n255:     snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n256:     return;\n257:   }\n258:   if (event.event === 'progress') {\n259:     snapshots.set(event.label, {\n260:       ...existing,\n261:       status: 'running',\n262:       updated_at_iso: event.at,\n263:       duration_ms: event.duration_ms,\n264:     });\n265:   }\n266: }\n267: \n268: function buildLineageSnapshots(lineages, snapshots) {\n269:   return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n270: }\n271: \n272: function summarizeSnapshots(lineages, snapshots) {\n273:   const results = buildLineageSnapshots(lineages, snapshots);\n274:   const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n275:   const failed = results.filter((result) => result.status === 'rejected').length;\n276:   return {\n277:     results,\n278:     summary: {\n279:       total: lineages.length,\n280:       succeeded,\n281:       failed,\n282:       all_failed: lineages.length > 0 && failed === lineages.length,\n283:     },\n284:   };\n285: }\n286: \n287: function observabilityPathForLedger(ledgerPath) {\n288:   return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n289: }\n290: \n291: function statusForLedgerEvent(entry) {\n292:   if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n293:     return entry.status;\n294:   }\n295:   if (!entry || typeof entry.event !== 'string') return 'unknown';\n296:   if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n297:   if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n298:   if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n299:   if (entry.event === 'stopped') return 'stopped';\n300:   if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n301:   // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n302:   // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n303:   if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n304:   if (entry.event === 'lag_ceiling_abort') return 'failed';\n305:   if (entry.event === 'stall_detected') return 'warning';\n306:   if (entry.event === 'budget_cap_exceeded') return 'failed';\n307:   if (entry.event === 'aggregate_budget_cap_exceeded') return 'failed';\n308:   return 'unknown';\n309: }\n310: \n311: function appendFanoutStatusLedger(ledgerPath, entry) {\n312:   appendStatusLedger(ledgerPath, entry);\n313:   try {\n314:     appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n315:       producer: 'fanout-run',\n316:       stream: 'orchestration-status',\n317:       subject: {\n318:         run_id: entry.run_id ?? null,\n319:         label: entry.label ?? null,\n320:         loop_type: entry.loop_type ?? null,\n321:         spec_folder: entry.spec_folder ?? null,\n322:       },\n323:       event: entry.event,\n324:       status: statusForLedgerEvent(entry),\n325:     });\n326:   } catch {\n327:     // Observability must not make the primary orchestration ledger fail.\n328:   }\n329: }\n330: \n331: const FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\n332: const WAVE_ASSIGNMENT_MODEL = 'wave';\n333: const WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\n334: const WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\n335: const STATE_LOG_BY_LOOP_TYPE = {\n336:   research: 'deep-research-state.jsonl',\n337:   review: 'deep-review-state.jsonl',\n338: };\n339: const ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\n340: const DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n341: \n342: function assertActiveFanoutLoopType(loopType) {\n343:   if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n344:     throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n345:   }\n346: }\n347: \n348: function hasNonEmptyArrayField(value) {\n349:   return Array.isArray(value) && value.length > 0;\n350: }\n351: \n352: function collectFlatPoolGuardRejections(fanoutConfig) {\n353:   const rejections = [];\n354:   if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n355:     rejections.push({\n356:       scope: 'fanout',\n357:       label: null,\n358:       field: 'assignment_model',\n359:       message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n360:     });\n361:   }\n362: \n363:   for (const lineage of fanoutConfig.executors) {\n364:     if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n365:       rejections.push({\n366:         scope: 'lineage',\n367:         label: lineage.label,\n368:         field: 'assignment_model',\n369:         message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n370:       });\n371:     }\n372: \n373:     const reservedFields = [];\n374:     if (hasNonEmptyArrayField(lineage.depends_on)) {\n375:       reservedFields.push('depends_on');\n376:     }\n377:     if (hasNonEmptyArrayField(lineage.touches)) {\n378:       reservedFields.push('touches');\n379:     }\n380:     if (reservedFields.length > 0) {\n381:       rejections.push({\n382:         scope: 'lineage',\n383:         label: lineage.label,\n384:         field: reservedFields.join(','),\n385:         message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n386:       });\n387:     }\n388:   }\n389: \n390:   return rejections;\n391: }\n392: \n393: /**\n394:  * Force fan-out execution onto the existing flat pool while wave planning is gated.\n395:  *\n396:  * @param {Object} fanoutConfig - Parsed fan-out config.\n397:  * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n398:  */\n399: function applyFlatPoolAssignmentGuard(fanoutConfig) {\n400:   const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n401:   return {\n402:     config: {\n403:       ...fanoutConfig,\n404:       assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n405:       executors: fanoutConfig.executors.map((lineage) => ({\n406:         ...lineage,\n407:         assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n408:       })),\n409:     },\n410:     rejections,\n411:   };\n412: }\n413: \n414: function logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n415:   if (rejections.length === 0) {\n416:     return;\n417:   }\n418:   const wavePlanner = createWavePlannerInterface();\n419:   for (const rejection of rejections) {\n420:     const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n421:     process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n422:     appendFanoutStatusLedger(ledgerPath, {\n423:       event: 'assignment_model_rejected',\n424:       severity: 'warning',\n425:       at: new Date().toISOString(),\n426:       run_id: runId,\n427:       loop_type: loopType,\n428:       spec_folder: specFolder,\n429:       planner_status: wavePlanner.status,\n430:       fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n431:       ...rejection,\n432:     });\n433:   }\n434: }\n435: \n436: // Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\n437: const SPECKIT_STATE_ENV_BY_KIND = {\n438:   'cli-codex': 'SPECKIT_CODEX_STATE_DIR',\n439:   'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n440:   'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n441: };\n442: \n443: const activeLineageProcesses = new Set();\n444: const WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\n445: const WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\n446: const WAIT_SLEEP_CHUNK_MS = 200;\n447: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n448: const DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n449: \n450: function stopActiveLineageProcesses(signal) {\n451:   for (const child of activeLineageProcesses) {\n452:     terminateLineageProcess(child, signal);\n453:   }\n454: }\n455: \n456: function expandHomeDir(inputPath) {\n457:   if (inputPath === '~') {\n458:     return os.homedir();\n459:   }\n460:   if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n461:     return path.join(os.homedir(), inputPath.slice(2));\n462:   }\n463:   return inputPath;\n464: }\n465: \n466: function isPathInside(childPath, parentPath) {\n467:   const relative = path.relative(parentPath, childPath);\n468:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n469: }\n470: \n471: function physicalPathForValidation(targetPath) {\n472:   try {\n473:     return fs.realpathSync.native(targetPath);\n474:   } catch {\n475:     const parentPath = path.dirname(targetPath);\n476:     try {\n477:       return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n478:     } catch {\n479:       return targetPath;\n480:     }\n481:   }\n482: }\n483: \n484: function validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n485:   if (baseArtifactDir.includes('\\0')) {\n486:     throw inputError('baseArtifactDir must not contain null bytes');\n487:   }\n488:   if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n489:     throw inputError('baseArtifactDir must not contain \"..\" path segments');\n490:   }\n491:   const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n492:   const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n493:   const expectedRoot = path.join(resolvedSpecFolder, loopType);\n494:   if (!isPathInside(resolvedBase, expectedRoot)) {\n495:     throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n496:   }\n497:   return baseArtifactDir;\n498: }\n499: \n500: function validateClaudeConfigDir(configDir) {\n501:   if (typeof configDir !== 'string' || configDir.trim() === '') {\n502:     throw inputError('configDir must be a non-empty string when set');\n503:   }\n504:   validateNamespaceValue(configDir, 'configDir', inputError);\n505: \n506:   const expanded = expandHomeDir(configDir);\n507:   const resolved = path.resolve(process.cwd(), expanded);\n508:   const homeDir = path.resolve(os.homedir());\n509:   const cwd = path.resolve(process.cwd());\n510:   const homeRelative = path.relative(homeDir, resolved);\n511:   const cwdRelative = path.relative(cwd, resolved);\n512:   const homeTop = homeRelative.split(path.sep)[0] || '';\n513:   const cwdTop = cwdRelative.split(path.sep)[0] || '';\n514:   const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n515: \n516:   if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n517:     return resolved;\n518:   }\n519:   if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n520:     return resolved;\n521:   }\n522:   throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n523: }\n524: \n525: function terminateLineageProcess(child, signal) {\n526:   if (!child || child.killed) return;\n527:   if (process.platform !== 'win32' && child.pid) {\n528:     try {\n529:       process.kill(-child.pid, signal);\n530:       return;\n531:     } catch (error) {\n532:       if (error && error.code !== 'ESRCH') {\n533:         try {\n534:           child.kill(signal);\n535:         } catch {\n536:           // The process may have already exited between the group and direct kill attempts.\n537:         }\n538:       }\n539:       return;\n540:     }\n541:   }\n542:   try {\n543:     child.kill(signal);\n544:   } catch {\n545:     // The process may have already exited.\n546:   }\n547: }\n548: \n549: function expectedLineageArtifactPaths(loopType, lineageDir) {\n550:   assertActiveFanoutLoopType(loopType);\n551:   if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n552:   return [path.join(lineageDir, 'research.md')];\n553: }\n554: \n555: function hasNonEmptyFile(filePath) {\n556:   try {\n557:     return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n558:   } catch {\n559:     return false;\n560:   }\n561: }\n562: \n563: function findMissingLineageArtifacts(loopType, lineageDir) {\n564:   return expectedLineageArtifactPaths(loopType, lineageDir)\n565:     .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n566: }\n567: \n568: function parseJsonlRecords(filePath) {\n569:   const text = fs.readFileSync(filePath, 'utf8');\n570:   return text\n571:     .split(/\\r?\\n/)\n572:     .filter((line) => line.trim() !== '')\n573:     .map((line) => JSON.parse(line));\n574: }\n575: \n576: function lineageStateLogName(loopType) {\n577:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n578: }\n579: \n580: function readLineageStateRecords(loopType, lineageDir) {\n581:   const stateLogName = lineageStateLogName(loopType);\n582:   if (!stateLogName) {\n583:     return { statePath: null, records: [], missing: true, parseError: null };\n584:   }\n585:   const statePath = path.join(lineageDir, stateLogName);\n586:   if (!hasNonEmptyFile(statePath)) {\n587:     return { statePath, records: [], missing: true, parseError: null };\n588:   }\n589:   try {\n590:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n591:   } catch (error) {\n592:     return {\n593:       statePath,\n594:       records: [],\n595:       missing: false,\n596:       parseError: error instanceof Error ? error.message : String(error),\n597:     };\n598:   }\n599: }\n600: \n601: // A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n602: // spelling. The iteration-count check above already proves the lineage ran every iteration,\n603: // so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n604: // \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n605: // such as convergence, a manual stop, or an error.\n606: function isMaxIterationsStopReason(stopReason) {\n607:   if (typeof stopReason !== 'string') return false;\n608:   return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n609: }\n610: \n611: function findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n612:   if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n613:   if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n614:     return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n615:   }\n616: \n617:   if (!stateRead || stateRead.missing) {\n618:     return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n619:   }\n620:   if (stateRead.parseError) {\n621:     return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n622:   }\n623: \n624:   const records = stateRead.records;\n625:   const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n626:   const synthesis = [...records]\n627:     .reverse()\n628:     .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n629:   if (!synthesis) {\n630:     return 'missing synthesis_complete event for max-iterations stop-policy validation';\n631:   }\n632: \n633:   const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n634:     ? Number(synthesis.totalIterations)\n635:     : iterationCount;\n636:   if (totalIterations !== lineage.iterations) {\n637:     return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n638:   }\n639:   if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n640:     return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n641:   }\n642:   return null;\n643: }\n644: \n645: function isRecord(value) {\n646:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n647: }\n648: \n649: function normalizeStallWatchdogMs(rawConfig) {\n650:   // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n651:   // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n652:   // because this knob is intentionally outside fanoutConfigSchema. Non-disableable while\n653:   // running autonomously: an explicit 0 no longer opts out, it is rejected.\n654:   const value = readRawConfigNumber(rawConfig, [\n655:     'stallWatchdogMs',\n656:     'stall_watchdog_ms',\n657:     'stallWatchdogMillis',\n658:     'stall_watchdog_millis',\n659:   ], 'stallWatchdogMs');\n660:   if (value === 0) {\n661:     throw inputError('stallWatchdogMs must be greater than 0; stall detection cannot be disabled for autonomous fan-out runs');\n662:   }\n663:   return value ?? 300000;\n664: }\n665: \n666: const DEFAULT_MAX_COST_UNITS_PER_LINEAGE = 72;\n667: \n668: function normalizeLineageBudgetGuards(rawConfig = {}) {\n669:   return {\n670:     max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n671:       'maxCostUnitsPerLineage',\n672:       'max_cost_units_per_lineage',\n673:       'maxLineageCostUnits',\n674:       'max_lineage_cost_units',\n675:       'maxTokensPerLineage',\n676:       'max_tokens_per_lineage',\n677:       'maxTokenBudget',\n678:       'max_token_budget',\n679:       'maxTokenBudgetPerLineage',\n680:       'max_token_budget_per_lineage',\n681:     ], 'maxCostUnitsPerLineage') ?? DEFAULT_MAX_COST_UNITS_PER_LINEAGE,\n682:     cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n683:       'costUnitsPerIteration',\n684:       'cost_units_per_iteration',\n685:       'estimatedTokensPerIteration',\n686:       'estimated_tokens_per_iteration',\n687:     ], 'costUnitsPerIteration', 1),\n688:   };\n689: }\n690: \n691: function computeLineageBudgetUpperBound(lineage, guardsInput = {}, maxRetries = 0) {\n692:   const guards = normalizeLineageBudgetGuards(guardsInput);\n693:   const rawIterations = Number(lineage && lineage.iterations);\n694:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n695:   const normalizedRetries = Number.isFinite(Number(maxRetries)) && Number(maxRetries) >= 0\n696:     ? Math.floor(Number(maxRetries))\n697:     : 0;\n698:   const totalAttempts = normalizedRetries + 1;\n699:   return {\n700:     ...guards,\n701:     iterations,\n702:     total_attempts: totalAttempts,\n703:     estimated_cost_units: iterations * guards.cost_units_per_iteration * totalAttempts,\n704:   };\n705: }\n706: \n707: function evaluateLineageBudgetCap(input = {}) {\n708:   const upperBound = computeLineageBudgetUpperBound(\n709:     input.lineage || {},\n710:     input.guards || input,\n711:     input.maxRetries,\n712:   );\n713:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n714:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n715:   return {\n716:     continue_allowed: !exceeded,\n717:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n718:     upper_bound: upperBound,\n719:   };\n720: }\n721: \n722: // Aggregate budget across every expanded lineage in a run. This is a SEPARATE ceiling\n723: // from DEFAULT_MAX_COST_UNITS_PER_LINEAGE above: the per-lineage cap bounds any single\n724: // lineage, this bounds the whole fan-out submission, and both are enforced independently\n725: // (a run may pass one and still fail the other).\n726: const DEFAULT_MAX_AGGREGATE_COST_UNITS = 288;\n727: \n728: function normalizeAggregateBudgetGuards(rawConfig = {}) {\n729:   return {\n730:     max_aggregate_cost_units: readRawConfigNumber(rawConfig, [\n731:       'maxAggregateCostUnits',\n732:       'max_aggregate_cost_units',\n733:       'maxTotalCostUnits',\n734:       'max_total_cost_units',\n735:     ], 'maxAggregateCostUnits') ?? DEFAULT_MAX_AGGREGATE_COST_UNITS,\n736:   };\n737: }\n738: \n739: function computeAggregateBudgetUpperBound(lineages, guardsInput = {}, maxRetries = 0) {\n740:   const aggregateGuards = normalizeAggregateBudgetGuards(guardsInput);\n741:   const lineageGuards = normalizeLineageBudgetGuards(guardsInput);\n742:   const perLineage = (lineages || []).map((lineage) => {\n743:     const upperBound = computeLineageBudgetUpperBound(lineage, lineageGuards, maxRetries);\n744:     return { label: lineage && lineage.label, estimated_cost_units: upperBound.estimated_cost_units };\n745:   });\n746:   const estimatedCostUnits = perLineage.reduce((sum, entry) => sum + entry.estimated_cost_units, 0);\n747:   return {\n748:     max_aggregate_cost_units: aggregateGuards.max_aggregate_cost_units,\n749:     estimated_cost_units: estimatedCostUnits,\n750:     lineage_count: perLineage.length,\n751:     per_lineage: perLineage,\n752:   };\n753: }\n754: \n755: function evaluateAggregateBudgetCap(input = {}) {\n756:   const upperBound = computeAggregateBudgetUpperBound(\n757:     input.lineages || [],\n758:     input.guards || input,\n759:     input.maxRetries,\n760:   );\n761:   const exceeded = upperBound.max_aggregate_cost_units > 0\n762:     && upperBound.estimated_cost_units > upperBound.max_aggregate_cost_units;\n763:   return {\n764:     continue_allowed: !exceeded,\n765:     stop_reasons: exceeded ? ['max_aggregate_cost_units'] : [],\n766:     upper_bound: upperBound,\n767:   };\n768: }\n769: \n770: function buildTimestampAnomalyCounts(check) {\n771:   return {\n772:     anomalous: check.anomalous,\n773:     untimestamped: check.untimestamped,\n774:     unparseable: check.unparseable,\n775:     total: check.total,\n776:   };\n777: }\n778: \n779: function buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n780:   return {\n781:     label: lineage.label,\n782:     state_log: statePath,\n783:     window: {\n784:       start_at_iso: check.windowStart,\n785:       end_at_iso: check.windowEnd,\n786:       tolerance_ms: check.toleranceMs,\n787:     },\n788:     counts: buildTimestampAnomalyCounts(check),\n789:     sample: check.sample,\n790:   };\n791: }\n792: \n793: function collectTimestampAnomalies(results) {\n794:   return results\n795:     .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n796:     .map((result) => result.output.timestamp_anomaly);\n797: }\n798: \n799: function normalizeNonNegativeDelayMs(value) {\n800:   if (value === undefined || value === null) return null;\n801:   const n = Number(value);\n802:   if (!Number.isFinite(n) || n < 0) return null;\n803:   return Math.floor(n);\n804: }\n805: \n806: function normalizeWaitDurationMs(value) {\n807:   return normalizeNonNegativeDelayMs(value) ?? 0;\n808: }\n809: \n810: function waitCheckpointPath(baseArtifactDir) {\n811:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n812: }\n813: \n814: function atomicWriteJson(filePath, payload) {\n815:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n816:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n817:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n818:   fs.renameSync(tmpPath, filePath);\n819: }\n820: \n821: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n822:   const durationMs = normalizeWaitDurationMs(waitMs);\n823:   const updatedAt = new Date(nowMs).toISOString();\n824:   if (durationMs <= 0) {\n825:     return {\n826:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n827:       status: 'idle',\n828:       nextRunAt: null,\n829:       remainingDelayMs: null,\n830:       updatedAt,\n831:       runId,\n832:       loopType,\n833:       specFolder,\n834:     };\n835:   }\n836: \n837:   return {\n838:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n839:     status: 'waiting',\n840:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n841:     remainingDelayMs: durationMs,\n842:     updatedAt,\n843:     runId,\n844:     loopType,\n845:     specFolder,\n846:   };\n847: }\n848: \n849: function normalizeWaitCheckpoint(raw, context) {\n850:   if (!isRecord(raw)) {\n851:     throw inputError('wait checkpoint must be a JSON object');\n852:   }\n853: \n854:   const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n855:   const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n856:   const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n857:   const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n858:     ? raw.nextRunAt\n859:     : null;\n860:   const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n861:   const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n862:   const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n863:   const base = {\n864:     runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n865:     loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n866:     specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n867:   };\n868: \n869:   const checkpoint = waiting\n870:     ? {\n871:         schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n872:         status: 'waiting',\n873:         nextRunAt,\n874:         remainingDelayMs,\n875:         updatedAt: new Date(nowMs).toISOString(),\n876:         ...base,\n877:       }\n878:     : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n879:   const staleWaitingFields = !waiting\n880:     && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n881:   const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n882: \n883:   return {\n884:     checkpoint,\n885:     migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n886:   };\n887: }\n888: \n889: function readWaitCheckpoint(checkpointPath, context) {\n890:   if (!fs.existsSync(checkpointPath)) {\n891:     return { exists: false, checkpoint: null, migrated: false };\n892:   }\n893: \n894:   let raw;\n895:   try {\n896:     raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n897:   } catch (error) {\n898:     throw inputError(\n899:       `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n900:     );\n901:   }\n902: \n903:   const normalized = normalizeWaitCheckpoint(raw, context);\n904:   if (normalized.migrated) {\n905:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n906:   }\n907:   return { exists: true, ...normalized };\n908: }\n909: \n910: function sleepWaitChunk(ms) {\n911:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n912: }\n913: \n914: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n915:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n916:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n917: \n918:   while (remainingDelayMs > 0) {\n919:     atomicWriteJson(checkpointPath, {\n920:       ...checkpoint,\n921:       remainingDelayMs,\n922:       updatedAt: new Date().toISOString(),\n923:     });\n924:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n925:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n926:   }\n927: \n928:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n929: }\n930: \n931: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n932:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n933:   const loaded = readWaitCheckpoint(checkpointPath, context);\n934:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n935:     return { didWait: false, migrated: loaded.migrated };\n936:   }\n937: \n938:   appendFanoutStatusLedger(ledgerPath, {\n939:     event: 'resume_waiting',\n940:     at: new Date().toISOString(),\n941:     run_id: runId,\n942:     loop_type: loopType,\n943:     spec_folder: specFolder,\n944:     nextRunAt: loaded.checkpoint.nextRunAt,\n945:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n946:   });\n947: \n948:   await waitUntilCheckpointExpires({\n949:     checkpointPath,\n950:     checkpoint: loaded.checkpoint,\n951:     context: { runId, loopType, specFolder },\n952:   });\n953: \n954:   appendFanoutStatusLedger(ledgerPath, {\n955:     event: 'resume_waiting_complete',\n956:     at: new Date().toISOString(),\n957:     run_id: runId,\n958:     loop_type: loopType,\n959:     spec_folder: specFolder,\n960:   });\n961: \n962:   return { didWait: true, migrated: loaded.migrated };\n963: }\n964: \n965: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n966:   const durationMs = normalizeWaitDurationMs(waitMs);\n967:   if (durationMs <= 0) {\n968:     return { didWait: false };\n969:   }\n970: \n971:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n972:   atomicWriteJson(checkpointPath, checkpoint);\n973:   appendFanoutStatusLedger(ledgerPath, {\n974:     event: 'wait_checkpoint_persisted',\n975:     at: checkpoint.updatedAt,\n976:     run_id: runId,\n977:     loop_type: loopType,\n978:     spec_folder: specFolder,\n979:     nextRunAt: checkpoint.nextRunAt,\n980:     remainingDelayMs: checkpoint.remainingDelayMs,\n981:   });\n982: \n983:   await waitUntilCheckpointExpires({\n984:     checkpointPath,\n985:     checkpoint,\n986:     context: { runId, loopType, specFolder },\n987:   });\n988: \n989:   appendFanoutStatusLedger(ledgerPath, {\n990:     event: 'wait_checkpoint_cleared',\n991:     at: new Date().toISOString(),\n992:     run_id: runId,\n993:     loop_type: loopType,\n994:     spec_folder: specFolder,\n995:   });\n996: \n997:   return { didWait: true };\n998: }\n999: \n1000: /**\n1001:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1002:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1003:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1004:  */\n1005: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1006:   assertActiveFanoutLoopType(loopType);\n1007:   const skillFile =\n1008:     loopType === 'review'\n1009:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1010:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1011:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1012:   const detachedIntro = lineage.kind === 'cli-opencode'\n1013:     ? [\n1014:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1015:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1016:         ``,\n1017:       ]\n1018:     : lineage.kind === 'native'\n1019:       ? [\n1020:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1021:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1022:           ``,\n1023:         ]\n1024:       : [];\n1025:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1026:   const stopPolicy = options.stopPolicy || 'convergence';\n1027:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1028:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1029:     : hasIterationCap\n1030:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1031:       : 'to legal convergence';\n1032:   const params = [\n1033:     `  spec_folder: ${specFolder}`,\n1034:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1035:     `  session_id: ${sessionId}`,\n1036:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1037:     `  loop_type: ${loopType}`,\n1038:     `  config.stopPolicy: ${stopPolicy}`,\n1039:   ];\n1040:   if (researchTopic) {\n1041:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1042:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1043:     // Review loops scope by spec_folder and intentionally pass no topic.\n1044:     params.push(`  research_topic: ${researchTopic}`);\n1045:   }\n1046:   if (hasIterationCap) {\n1047:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1048:   }\n1049:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1050:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1051:   }\n1052:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1053:   // still requires the same review setup bindings the native command path pre-binds.\n1054:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1055:   // different setup contract than native lineages.\n1056:   const setupBindings =\n1057:     loopType === 'review'\n1058:       ? [\n1059:           ``,\n1060:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1061:           `review_target: ${specFolder}`,\n1062:           `review_target_type: spec-folder`,\n1063:           `review_dimensions: all`,\n1064:           `spec_folder: ${specFolder}`,\n1065:           `execution_mode: AUTONOMOUS`,\n1066:           `lineage_mode: auto`,\n1067:           ``,\n1068:         ]\n1069:       : [];\n1070:   return [\n1071:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1072:     ...detachedIntro,\n1073:     ``,\n1074:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1075:     ...params,\n1076:     ...setupBindings,\n1077:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1078:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1079:     `command; bind artifact_dir directly to the override value.`,\n1080:     ``,\n1081:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1082:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1083:     ``,\n1084:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1085:   ].join('\\n');\n1086: }\n1087: \n1088: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1089:   assertActiveFanoutLoopType(loopType);\n1090:   const maxIterations = lineage.iterations || 12;\n1091:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1092:   const stopPolicy = options.stopPolicy || 'convergence';\n1093:   const sessionId = options.sessionId || '';\n1094:   const args = [\n1095:     ':auto',\n1096:     JSON.stringify(specFolder),\n1097:     `--spec-folder=${specFolder}`,\n1098:     `--max-iterations=${maxIterations}`,\n1099:     `--convergence=${convergenceThreshold}`,\n1100:     `--stop-policy=${stopPolicy}`,\n1101:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1102:     '--lineage-mode=auto',\n1103:   ];\n1104:   if (loopType === 'research' && options.researchTopic) {\n1105:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1106:   }\n1107: \n1108:   return [\n1109:     args.join(' '),\n1110:     '',\n1111:     'PRE-BOUND SETUP ANSWERS:',\n1112:     `review_target: ${specFolder}`,\n1113:     'review_target_type: spec-folder',\n1114:     'review_dimensions: all',\n1115:     `spec_folder: ${specFolder}`,\n1116:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1117:     'execution_mode: AUTONOMOUS',\n1118:     'lineage_mode: auto',\n1119:     `maxIterations: ${maxIterations}`,\n1120:     `convergenceThreshold: ${convergenceThreshold}`,\n1121:     `stop_policy: ${stopPolicy}`,\n1122:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1123:   ].join('\\n');\n1124: }\n1125: \n1126: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1127: // ceiling and a positive override may only narrow it, never widen past it.\n1128: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1129: \n1130: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1131:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1132:     throw inputError(\n1133:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1134:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1135:     );\n1136:   }\n1137: }\n1138: \n1139: /**\n1140:  * Compute a generous timeout for a full lineage loop run.\n1141:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1142:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1143:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1144:  */\n1145: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1146:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1147:   const iters = lineage.iterations || 12;\n1148:   const perIterSecs = lineage.timeoutSeconds || 900;\n1149:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1150:     ? ceilingHoursOverride * 60 * 60 * 1000\n1151:     : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n1152:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1153: }\n1154: \n1155: function normalizeProgressHeartbeatMs(seconds) {\n1156:   const value = Number(seconds);\n1157:   if (!Number.isFinite(value) || value <= 0) return 0;\n1158:   return Math.max(1, Math.floor(value * 1000));\n1159: }\n1160: \n1161: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1162:   const explicit = readRawConfigNumber(rawConfig, [\n1163:     'postExitGraceMs',\n1164:     'post_exit_grace_ms',\n1165:     'postSubprocessExitGraceMs',\n1166:     'post_subprocess_exit_grace_ms',\n1167:     'orchestratorPostExitGraceMs',\n1168:     'orchestrator_post_exit_grace_ms',\n1169:   ], 'postExitGraceMs');\n1170:   if (explicit !== null) return explicit;\n1171: \n1172:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1173:     ? progressHeartbeatMs * 2\n1174:     : 0;\n1175:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1176: }\n1177: \n1178: function slotDurationMsFromHrtime(hrStart) {\n1179:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1180:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1181: }\n1182: \n1183: function computeSkippedCount(slotDurationMs, intervalMs) {\n1184:   const elapsed = Number(slotDurationMs);\n1185:   const interval = Number(intervalMs);\n1186:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1187:     return 0;\n1188:   }\n1189:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1190: }\n1191: \n1192: function buildSlotAccounting(hrStart, intervalMs) {\n1193:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1194:   return {\n1195:     slotDurationMs,\n1196:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1197:   };\n1198: }\n1199: \n1200: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1201:   if (!event || typeof event.label !== 'string') return event;\n1202:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1203: \n1204:   const accounting = accountingByLabel.get(event.label);\n1205:   if (!accounting) return event;\n1206:   return {\n1207:     ...event,\n1208:     skippedCount: accounting.skippedCount,\n1209:     slotDurationMs: accounting.slotDurationMs,\n1210:   };\n1211: }\n1212: \n1213: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1214:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1215:     return () => {};\n1216:   }\n1217:   const startedAtMs = Date.now();\n1218:   const timer = setInterval(() => {\n1219:     appendFanoutStatusLedger(ledgerPath, {\n1220:       event: 'progress',\n1221:       label,\n1222:       at: new Date().toISOString(),\n1223:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1224:         gauges: getGauges(),\n1225:       });\n1226:       if (typeof onProgress === 'function') onProgress();\n1227:     }, cadenceMs);\n1228:   timer.unref?.();\n1229:   return () => clearInterval(timer);\n1230: }\n1231: \n1232: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1233:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1234:     return () => {};\n1235:   }\n1236: \n1237:   let timer = null;\n1238:   let fired = false;\n1239:   const schedule = () => {\n1240:     if (fired) return;\n1241:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1242:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1243:     timer = setTimeout(() => {\n1244:       timer = null;\n1245:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1246:       if (latestQuietMs >= thresholdMs) {\n1247:         fired = true;\n1248:         appendFanoutStatusLedger(ledgerPath, {\n1249:           event: 'stall_detected',\n1250:           label,\n1251:           at: new Date().toISOString(),\n1252:           severity: 'warning',\n1253:           metric: 'time_since_last_lineage_event',\n1254:           stall_watchdog_ms: thresholdMs,\n1255:           quiet_ms: Math.floor(latestQuietMs),\n1256:           gauges: getGauges(),\n1257:         });\n1258:         return;\n1259:       }\n1260:       schedule();\n1261:     }, delayMs);\n1262:     timer.unref?.();\n1263:   };\n1264: \n1265:   schedule();\n1266:   return () => {\n1267:     fired = true;\n1268:     if (timer) clearTimeout(timer);\n1269:   };\n1270: }\n1271: \n1272: /**\n1273:  * Run a lineage subprocess without blocking the Node event loop.\n1274:  *\n1275:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1276:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1277:  * thread until each child exited, serializing every lineage regardless of the\n1278:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1279:  *\n1280:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1281:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1282:  *\n1283:  * @param {string} command - Executable to run.\n1284:  * @param {string[]} cmdArgs - Arguments for the executable.\n1285:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1286:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1287:  */\n1288: function runLineageProcess(command, cmdArgs, opts) {\n1289:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1290:   const hasInput = typeof opts.input === 'string';\n1291: \n1292:   return new Promise((resolvePromise) => {\n1293:     let child;\n1294:     try {\n1295:       child = spawn(command, cmdArgs, {\n1296:         cwd,\n1297:         env,\n1298:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1299:         detached: process.platform !== 'win32',\n1300:       });\n1301:     } catch (error) {\n1302:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1303:       return;\n1304:     }\n1305:     activeLineageProcesses.add(child);\n1306:     if (typeof opts.onSpawn === 'function') {\n1307:       opts.onSpawn({ pid: child.pid });\n1308:     }\n1309: \n1310:     let stdout = '';\n1311:     let stdoutBytes = 0;\n1312:     let truncated = false;\n1313:     let timedOut = false;\n1314:     let settled = false;\n1315:     let spawnError;\n1316: \n1317:     const timer = setTimeout(() => {\n1318:       timedOut = true;\n1319:       terminateLineageProcess(child, 'SIGTERM');\n1320:     }, timeoutMs);\n1321:     timer.unref?.();\n1322: \n1323:     const abortHandler = () => {\n1324:       terminateLineageProcess(child, 'SIGTERM');\n1325:     };\n1326:     if (opts.abortSignal) {\n1327:       if (opts.abortSignal.aborted) {\n1328:         abortHandler();\n1329:       } else {\n1330:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1331:       }\n1332:     }\n1333: \n1334:     child.stdout?.setEncoding('utf8');\n1335:     child.stdout?.on('data', (chunk) => {\n1336:       if (typeof opts.onOutput === 'function') opts.onOutput();\n1337:       if (truncated) return;\n1338:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1339:       if (stdoutBytes > maxBuffer) {\n1340:         truncated = true;\n1341:         terminateLineageProcess(child, 'SIGTERM');\n1342:         return;\n1343:       }\n1344:       stdout += chunk;\n1345:     });\n1346:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1347:     child.stderr?.resume();\n1348: \n1349:     child.on('error', (error) => {\n1350:       spawnError = error;\n1351:     });\n1352: \n1353:     child.on('close', (code, signal) => {\n1354:       if (settled) return;\n1355:       settled = true;\n1356:       activeLineageProcesses.delete(child);\n1357:       clearTimeout(timer);\n1358:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1359:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1360:       if (typeof opts.onExit === 'function') {\n1361:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1362:       }\n1363:       resolvePromise({\n1364:         status: timedOut ? null : code,\n1365:         signal: effectiveSignal,\n1366:         stdout,\n1367:         ...(spawnError ? { error: spawnError } : {}),\n1368:       });\n1369:     });\n1370: \n1371:     if (hasInput) {\n1372:       child.stdin?.on('error', () => {});\n1373:       child.stdin?.end(opts.input);\n1374:     }\n1375:   });\n1376: }\n1377: \n1378: /**\n1379:  * Build the subprocess command for a fan-out lineage.\n1380:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1381:  */\n1382: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1383:   const kind = lineage.kind;\n1384: \n1385:   if (kind === 'cli-codex') {\n1386:     if (!isCodexBinaryAvailable(options.env || process.env)) {\n1387:       throw inputError('cli-codex executor unavailable: command -v codex failed');\n1388:     }\n1389:     const args = [\n1390:       'exec',\n1391:       '--model',\n1392:       lineage.model || 'o4-mini',\n1393:       '-c',\n1394:       `model_reasoning_effort=${lineage.reasoningEffort || 'medium'}`,\n1395:     ];\n1396:     if (lineage.serviceTier) {\n1397:       args.push('-c', `service_tier=${lineage.serviceTier}`);\n1398:     }\n1399:     args.push('-c', 'approval_policy=never', '--sandbox', resolvedSandbox, '-');\n1400:     return { command: 'codex', args, input: prompt };\n1401:   }\n1402: \n1403:   if (kind === 'cli-claude-code') {\n1404:     const args = [\n1405:       '-p',\n1406:       prompt,\n1407:       '--model',\n1408:       lineage.model || 'claude-opus-4-8',\n1409:       '--permission-mode',\n1410:       resolvedPermission,\n1411:       '--output-format',\n1412:       'text',\n1413:     ];\n1414:     if (lineage.reasoningEffort) {\n1415:       args.push('--effort', lineage.reasoningEffort);\n1416:     }\n1417:     return { command: 'claude', args };\n1418:   }\n1419: \n1420:   if (kind === 'native') {\n1421:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1422:     // For review runs this is the real deep/review command surface with a lineage\n1423:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1424:     const args = [\n1425:       'run',\n1426:       '--format',\n1427:       'json',\n1428:       '--dangerously-skip-permissions',\n1429:       '--dir',\n1430:       process.cwd(),\n1431:       '--command',\n1432:       `deep/${options.loopType || 'review'}`,\n1433:     ];\n1434:     args.push(buildNativeCommandInput(\n1435:       options.loopType || 'review',\n1436:       options.specFolder || '',\n1437:       options.lineageDir || '',\n1438:       lineage,\n1439:       options,\n1440:     ));\n1441:     return { command: 'opencode', args, input: '' };\n1442:   }\n1443: \n1444:   if (kind === 'cli-opencode') {\n1445:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1446:     // on a top-level `run`. The default agent runs when none is named, and a\n1447:     // specific agent profile can be requested in the prompt body instead.\n1448:     const args = [\n1449:       'run',\n\n(Output capped at 50 KB. Showing lines 1-1449. Use offset=1450 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\nconst { spawn, spawnSync } = require('node:child_process');\n\nconst {\n  classifyExitCode,\n  maybeThrowTestFault,\n  validateNamespaceValue,\n} = require('./lib/cli-guards.cjs');\n\nconst {\n  runCappedPool,\n  appendStatusLedger,\n  markOrphanedLineages,\n  readRetryCountsFromLedger,\n  createWavePlannerInterface,\n  writeOrchestrationSummary,\n} = require('./fanout-pool.cjs');\n\nconst {\n  runSalvageSweep,\n  extractTextFromOpencodeJson,\n} = require('./fanout-salvage.cjs');\n\nconst {\n  appendObservabilityEvent,\n} = require('../lib/deep-loop/observability-events.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\nconst isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n\nfunction runTsxBootstrap() {\n  const child = spawn(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n    },\n  );\n\n  if (!process.stdin.isTTY && child.stdin) {\n    child.stdin.on('error', () => {});\n    process.stdin.pipe(child.stdin);\n  }\n\n  child.stdout?.pipe(process.stdout);\n  child.stderr?.pipe(process.stderr);\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      child.kill(signal);\n    });\n  }\n\n  child.on('close', (status, signal) => {\n    if (status !== null) {\n      process.exit(status);\n    }\n    process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n  });\n}\n\nif (require.main === module && !isTsxLoaded) {\n  runTsxBootstrap();\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction parseOptionalNumber(args, key) {\n  const raw = args[key];\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return null;\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError(`${key} must be a number`);\n  }\n  const value = Number(raw);\n  if (!Number.isFinite(value) || value < 0) {\n    throw inputError(`${key} must be a non-negative number`);\n  }\n  return value;\n}\n\nfunction readRawConfigNumber(rawConfig, names, fieldName) {\n  if (!isRecord(rawConfig)) return null;\n  for (const name of names) {\n    if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n    const raw = rawConfig[name];\n    if (raw === undefined || raw === null || raw === '') return null;\n    if (raw === true || raw === false) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    const value = Number(raw);\n    if (!Number.isFinite(value) || value < 0) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    return Math.floor(value);\n  }\n  return null;\n}\n\nfunction readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n  const value = readRawConfigNumber(rawConfig, names, fieldName);\n  if (value === null) return fallback;\n  if (value <= 0) {\n    throw inputError(`${fieldName} must be greater than 0`);\n  }\n  return value;\n}\n\nfunction rawConfigWithCliBudgetOverrides(rawConfig, args) {\n  const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n  const mappings = [\n    ['stallWatchdogMs', 'stallWatchdogMs'],\n    ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n    ['maxAggregateCostUnits', 'maxAggregateCostUnits'],\n    ['maxTokensPerLineage', 'maxTokensPerLineage'],\n    ['maxTokenBudget', 'maxTokenBudget'],\n    ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n    ['costUnitsPerIteration', 'costUnitsPerIteration'],\n    ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n  ];\n  for (const [targetKey, argKey] of mappings) {\n    if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n      merged[targetKey] = args[argKey];\n    }\n  }\n  return merged;\n}\n\nfunction normalizeStopPolicy(raw) {\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return 'convergence';\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  if (raw !== 'convergence' && raw !== 'max-iterations') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  return raw;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\nfunction signalExitCode(signal) {\n  return signal === 'SIGINT' ? 130 : 143;\n}\n\nlet fanoutSignalHandlersInstalled = false;\n\nfunction installFanoutSignalHandlers(onStop) {\n  if (fanoutSignalHandlersInstalled) return;\n  fanoutSignalHandlersInstalled = true;\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      try {\n        onStop(signal);\n      } finally {\n        process.exit(signalExitCode(signal));\n      }\n    });\n  }\n}\n\nfunction updateLineageSnapshot(snapshots, event) {\n  if (!event || typeof event.label !== 'string') return;\n  const existing = snapshots.get(event.label) || { label: event.label };\n\n  if (event.event === 'started') {\n    snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'completed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'fulfilled',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n    return;\n  }\n  if (event.event === 'failed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: event.terminal === false ? 'retrying' : 'rejected',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n      error: event.error,\n    });\n    return;\n  }\n  if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n    snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'progress') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'running',\n      updated_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n  }\n}\n\nfunction buildLineageSnapshots(lineages, snapshots) {\n  return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n}\n\nfunction summarizeSnapshots(lineages, snapshots) {\n  const results = buildLineageSnapshots(lineages, snapshots);\n  const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n  const failed = results.filter((result) => result.status === 'rejected').length;\n  return {\n    results,\n    summary: {\n      total: lineages.length,\n      succeeded,\n      failed,\n      all_failed: lineages.length > 0 && failed === lineages.length,\n    },\n  };\n}\n\nfunction observabilityPathForLedger(ledgerPath) {\n  return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n}\n\nfunction statusForLedgerEvent(entry) {\n  if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n    return entry.status;\n  }\n  if (!entry || typeof entry.event !== 'string') return 'unknown';\n  if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n  if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n  if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n  if (entry.event === 'stopped') return 'stopped';\n  if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n  // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n  // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n  if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n  if (entry.event === 'lag_ceiling_abort') return 'failed';\n  if (entry.event === 'stall_detected') return 'warning';\n  if (entry.event === 'budget_cap_exceeded') return 'failed';\n  if (entry.event === 'aggregate_budget_cap_exceeded') return 'failed';\n  return 'unknown';\n}\n\nfunction appendFanoutStatusLedger(ledgerPath, entry) {\n  appendStatusLedger(ledgerPath, entry);\n  try {\n    appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n      producer: 'fanout-run',\n      stream: 'orchestration-status',\n      subject: {\n        run_id: entry.run_id ?? null,\n        label: entry.label ?? null,\n        loop_type: entry.loop_type ?? null,\n        spec_folder: entry.spec_folder ?? null,\n      },\n      event: entry.event,\n      status: statusForLedgerEvent(entry),\n    });\n  } catch {\n    // Observability must not make the primary orchestration ledger fail.\n  }\n}\n\nconst FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\nconst WAVE_ASSIGNMENT_MODEL = 'wave';\nconst WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\nconst WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\nconst STATE_LOG_BY_LOOP_TYPE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n};\nconst ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\nconst DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n\nfunction assertActiveFanoutLoopType(loopType) {\n  if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n    throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n  }\n}\n\nfunction hasNonEmptyArrayField(value) {\n  return Array.isArray(value) && value.length > 0;\n}\n\nfunction collectFlatPoolGuardRejections(fanoutConfig) {\n  const rejections = [];\n  if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n    rejections.push({\n      scope: 'fanout',\n      label: null,\n      field: 'assignment_model',\n      message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n    });\n  }\n\n  for (const lineage of fanoutConfig.executors) {\n    if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: 'assignment_model',\n        message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n      });\n    }\n\n    const reservedFields = [];\n    if (hasNonEmptyArrayField(lineage.depends_on)) {\n      reservedFields.push('depends_on');\n    }\n    if (hasNonEmptyArrayField(lineage.touches)) {\n      reservedFields.push('touches');\n    }\n    if (reservedFields.length > 0) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: reservedFields.join(','),\n        message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n      });\n    }\n  }\n\n  return rejections;\n}\n\n/**\n * Force fan-out execution onto the existing flat pool while wave planning is gated.\n *\n * @param {Object} fanoutConfig - Parsed fan-out config.\n * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n */\nfunction applyFlatPoolAssignmentGuard(fanoutConfig) {\n  const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n  return {\n    config: {\n      ...fanoutConfig,\n      assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      executors: fanoutConfig.executors.map((lineage) => ({\n        ...lineage,\n        assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      })),\n    },\n    rejections,\n  };\n}\n\nfunction logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n  if (rejections.length === 0) {\n    return;\n  }\n  const wavePlanner = createWavePlannerInterface();\n  for (const rejection of rejections) {\n    const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n    process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'assignment_model_rejected',\n      severity: 'warning',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      planner_status: wavePlanner.status,\n      fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      ...rejection,\n    });\n  }\n}\n\n// Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\nconst SPECKIT_STATE_ENV_BY_KIND = {\n  'cli-codex': 'SPECKIT_CODEX_STATE_DIR',\n  'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n  'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n};\n\nconst activeLineageProcesses = new Set();\nconst WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\nconst WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\nconst WAIT_SLEEP_CHUNK_MS = 200;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\nconst DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n\nfunction stopActiveLineageProcesses(signal) {\n  for (const child of activeLineageProcesses) {\n    terminateLineageProcess(child, signal);\n  }\n}\n\nfunction expandHomeDir(inputPath) {\n  if (inputPath === '~') {\n    return os.homedir();\n  }\n  if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n    return path.join(os.homedir(), inputPath.slice(2));\n  }\n  return inputPath;\n}\n\nfunction isPathInside(childPath, parentPath) {\n  const relative = path.relative(parentPath, childPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction physicalPathForValidation(targetPath) {\n  try {\n    return fs.realpathSync.native(targetPath);\n  } catch {\n    const parentPath = path.dirname(targetPath);\n    try {\n      return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n    } catch {\n      return targetPath;\n    }\n  }\n}\n\nfunction validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n  if (baseArtifactDir.includes('\\0')) {\n    throw inputError('baseArtifactDir must not contain null bytes');\n  }\n  if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n    throw inputError('baseArtifactDir must not contain \"..\" path segments');\n  }\n  const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n  const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n  const expectedRoot = path.join(resolvedSpecFolder, loopType);\n  if (!isPathInside(resolvedBase, expectedRoot)) {\n    throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n  }\n  return baseArtifactDir;\n}\n\nfunction validateClaudeConfigDir(configDir) {\n  if (typeof configDir !== 'string' || configDir.trim() === '') {\n    throw inputError('configDir must be a non-empty string when set');\n  }\n  validateNamespaceValue(configDir, 'configDir', inputError);\n\n  const expanded = expandHomeDir(configDir);\n  const resolved = path.resolve(process.cwd(), expanded);\n  const homeDir = path.resolve(os.homedir());\n  const cwd = path.resolve(process.cwd());\n  const homeRelative = path.relative(homeDir, resolved);\n  const cwdRelative = path.relative(cwd, resolved);\n  const homeTop = homeRelative.split(path.sep)[0] || '';\n  const cwdTop = cwdRelative.split(path.sep)[0] || '';\n  const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n\n  if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n    return resolved;\n  }\n  if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n    return resolved;\n  }\n  throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {\n    child.kill(signal);\n  } catch {\n    // The process may have already exited.\n  }\n}\n\nfunction expectedLineageArtifactPaths(loopType, lineageDir) {\n  assertActiveFanoutLoopType(loopType);\n  if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n  return [path.join(lineageDir, 'research.md')];\n}\n\nfunction hasNonEmptyFile(filePath) {\n  try {\n    return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n  } catch {\n    return false;\n  }\n}\n\nfunction findMissingLineageArtifacts(loopType, lineageDir) {\n  return expectedLineageArtifactPaths(loopType, lineageDir)\n    .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n}\n\nfunction parseJsonlRecords(filePath) {\n  const text = fs.readFileSync(filePath, 'utf8');\n  return text\n    .split(/\\r?\\n/)\n    .filter((line) => line.trim() !== '')\n    .map((line) => JSON.parse(line));\n}\n\nfunction lineageStateLogName(loopType) {\n  return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n}\n\nfunction readLineageStateRecords(loopType, lineageDir) {\n  const stateLogName = lineageStateLogName(loopType);\n  if (!stateLogName) {\n    return { statePath: null, records: [], missing: true, parseError: null };\n  }\n  const statePath = path.join(lineageDir, stateLogName);\n  if (!hasNonEmptyFile(statePath)) {\n    return { statePath, records: [], missing: true, parseError: null };\n  }\n  try {\n    return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n  } catch (error) {\n    return {\n      statePath,\n      records: [],\n      missing: false,\n      parseError: error instanceof Error ? error.message : String(error),\n    };\n  }\n}\n\n// A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n// spelling. The iteration-count check above already proves the lineage ran every iteration,\n// so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n// \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n// such as convergence, a manual stop, or an error.\nfunction isMaxIterationsStopReason(stopReason) {\n  if (typeof stopReason !== 'string') return false;\n  return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n}\n\nfunction findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n  if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n  if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n    return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n  }\n\n  if (!stateRead || stateRead.missing) {\n    return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n  }\n  if (stateRead.parseError) {\n    return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n  }\n\n  const records = stateRead.records;\n  const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n  const synthesis = [...records]\n    .reverse()\n    .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n  if (!synthesis) {\n    return 'missing synthesis_complete event for max-iterations stop-policy validation';\n  }\n\n  const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n    ? Number(synthesis.totalIterations)\n    : iterationCount;\n  if (totalIterations !== lineage.iterations) {\n    return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n  }\n  if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n    return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n  }\n  return null;\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n  // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n  // because this knob is intentionally outside fanoutConfigSchema. Non-disableable while\n  // running autonomously: an explicit 0 no longer opts out, it is rejected.\n  const value = readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs');\n  if (value === 0) {\n    throw inputError('stallWatchdogMs must be greater than 0; stall detection cannot be disabled for autonomous fan-out runs');\n  }\n  return value ?? 300000;\n}\n\nconst DEFAULT_MAX_COST_UNITS_PER_LINEAGE = 72;\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? DEFAULT_MAX_COST_UNITS_PER_LINEAGE,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}, maxRetries = 0) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  const normalizedRetries = Number.isFinite(Number(maxRetries)) && Number(maxRetries) >= 0\n    ? Math.floor(Number(maxRetries))\n    : 0;\n  const totalAttempts = normalizedRetries + 1;\n  return {\n    ...guards,\n    iterations,\n    total_attempts: totalAttempts,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration * totalAttempts,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(\n    input.lineage || {},\n    input.guards || input,\n    input.maxRetries,\n  );\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\n// Aggregate budget across every expanded lineage in a run. This is a SEPARATE ceiling\n// from DEFAULT_MAX_COST_UNITS_PER_LINEAGE above: the per-lineage cap bounds any single\n// lineage, this bounds the whole fan-out submission, and both are enforced independently\n// (a run may pass one and still fail the other).\nconst DEFAULT_MAX_AGGREGATE_COST_UNITS = 288;\n\nfunction normalizeAggregateBudgetGuards(rawConfig = {}) {\n  return {\n    max_aggregate_cost_units: readRawConfigNumber(rawConfig, [\n      'maxAggregateCostUnits',\n      'max_aggregate_cost_units',\n      'maxTotalCostUnits',\n      'max_total_cost_units',\n    ], 'maxAggregateCostUnits') ?? DEFAULT_MAX_AGGREGATE_COST_UNITS,\n  };\n}\n\nfunction computeAggregateBudgetUpperBound(lineages, guardsInput = {}, maxRetries = 0) {\n  const aggregateGuards = normalizeAggregateBudgetGuards(guardsInput);\n  const lineageGuards = normalizeLineageBudgetGuards(guardsInput);\n  const perLineage = (lineages || []).map((lineage) => {\n    const upperBound = computeLineageBudgetUpperBound(lineage, lineageGuards, maxRetries);\n    return { label: lineage && lineage.label, estimated_cost_units: upperBound.estimated_cost_units };\n  });\n  const estimatedCostUnits = perLineage.reduce((sum, entry) => sum + entry.estimated_cost_units, 0);\n  return {\n    max_aggregate_cost_units: aggregateGuards.max_aggregate_cost_units,\n    estimated_cost_units: estimatedCostUnits,\n    lineage_count: perLineage.length,\n    per_lineage: perLineage,\n  };\n}\n\nfunction evaluateAggregateBudgetCap(input = {}) {\n  const upperBound = computeAggregateBudgetUpperBound(\n    input.lineages || [],\n    input.guards || input,\n    input.maxRetries,\n  );\n  const exceeded = upperBound.max_aggregate_cost_units > 0\n    && upperBound.estimated_cost_units > upperBound.max_aggregate_cost_units;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_aggregate_cost_units'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction buildTimestampAnomalyCounts(check) {\n  return {\n    anomalous: check.anomalous,\n    untimestamped: check.untimestamped,\n    unparseable: check.unparseable,\n    total: check.total,\n  };\n}\n\nfunction buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n  return {\n    label: lineage.label,\n    state_log: statePath,\n    window: {\n      start_at_iso: check.windowStart,\n      end_at_iso: check.windowEnd,\n      tolerance_ms: check.toleranceMs,\n    },\n    counts: buildTimestampAnomalyCounts(check),\n    sample: check.sample,\n  };\n}\n\nfunction collectTimestampAnomalies(results) {\n  return results\n    .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n    .map((result) => result.output.timestamp_anomaly);\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };\n}\n\nfunction normalizeWaitCheckpoint(raw, context) {\n  if (!isRecord(raw)) {\n    throw inputError('wait checkpoint must be a JSON object');\n  }\n\n  const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n  const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n  const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n  const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n    ? raw.nextRunAt\n    : null;\n  const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n  const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n  const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n  const base = {\n    runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n    loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n    specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n  };\n\n  const checkpoint = waiting\n    ? {\n        schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n        status: 'waiting',\n        nextRunAt,\n        remainingDelayMs,\n        updatedAt: new Date(nowMs).toISOString(),\n        ...base,\n      }\n    : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n  const staleWaitingFields = !waiting\n    && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n  const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n\n  return {\n    checkpoint,\n    migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n  };\n}\n\nfunction readWaitCheckpoint(checkpointPath, context) {\n  if (!fs.existsSync(checkpointPath)) {\n    return { exists: false, checkpoint: null, migrated: false };\n  }\n\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n  } catch (error) {\n    throw inputError(\n      `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n\n  const normalized = normalizeWaitCheckpoint(raw, context);\n  if (normalized.migrated) {\n    atomicWriteJson(checkpointPath, normalized.checkpoint);\n  }\n  return { exists: true, ...normalized };\n}\n\nfunction sleepWaitChunk(ms) {\n  return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n}\n\nasync function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n  const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n  let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n\n  while (remainingDelayMs > 0) {\n    atomicWriteJson(checkpointPath, {\n      ...checkpoint,\n      remainingDelayMs,\n      updatedAt: new Date().toISOString(),\n    });\n    await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n    remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n  }\n\n  atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n}\n\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n      : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n// Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n// ceiling and a positive override may only narrow it, never widen past it.\nconst LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n\nfunction assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n  if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n    throw inputError(\n      `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n        + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n    );\n  }\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (typeof opts.onOutput === 'function') opts.onOutput();\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-codex') {\n    if (!isCodexBinaryAvailable(options.env || process.env)) {\n      throw inputError('cli-codex executor unavailable: command -v codex failed');\n    }\n    const args = [\n      'exec',\n      '--model',\n      lineage.model || 'o4-mini',\n      '-c',\n      `model_reasoning_effort=${lineage.reasoningEffort || 'medium'}`,\n    ];\n    if (lineage.serviceTier) {\n      args.push('-c', `service_tier=${lineage.serviceTier}`);\n    }\n    args.push('-c', 'approval_policy=never', '--sandbox', resolvedSandbox, '-');\n    return { command: 'codex', args, input: prompt };\n  }\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',","lineStart":1,"lineEnd":1449,"totalLines":1450,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784444196093,"end":1784444196109}},"metadata":{"openai":{"itemId":"fc_0c97c41fcaedd3b3016a5c7523fad0819182ca414718ed5ada"}},"id":"prt_f792994f8001eFkYa2M6MAYLBa","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","messageID":"msg_f792962b6001lv5629da5hf4ne"}}
{"type":"tool_use","timestamp":1784444196136,"sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","part":{"type":"tool","tool":"grep","callID":"call_PEXTOtf4ZBIvbyv9vIenZOOr","state":{"status":"completed","input":{"pattern":"fanout_lineage_artifact_dir|FANOUT_LINEAGE_COMPLETE","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime"},"output":"Found 8 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs:\n  Line 1003:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n\n  Line 1034:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n  Line 1078:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n\n  Line 1084:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n\n  Line 1122:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/compile-command-contracts.cjs:\n  Line 312:         'config.fanout_lineage_artifact_dir',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/manual-testing-playbook/fanout/artifact-dir-override-parity.md:\n  Line 16: that the `config.fanout_lineage_artifact_dir` override correctly bypasses `resolveArtifactRoot`\n\n  Line 45: 1. `bash: grep -n \"if_absent\\|skip_when\\|fanout_lineage_artifact_dir\" .opencode/commands/deep/assets/deep-research-auto.yaml | head -20`\n","metadata":{"matches":8,"truncated":false},"title":"fanout_lineage_artifact_dir|FANOUT_LINEAGE_COMPLETE","time":{"start":1784444196086,"end":1784444196134}},"metadata":{"openai":{"itemId":"fc_0c97c41fcaedd3b3016a5c7523fac88191b09e23527b2d2d85"}},"id":"prt_f792994f2001zddCjo9ny2SkOd","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","messageID":"msg