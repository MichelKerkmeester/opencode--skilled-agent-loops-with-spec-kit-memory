\": \"deep-improvement\",\n105:       \"loopHostMode\": \"model-benchmark\",\n106:       \"command\": \"/deep:model-benchmark\",\n107:       \"agent\": \"deep-improvement\",\n108:       \"artifactRoot\": \"improvement/\",\n109:       \"aliases\": [\"model benchmark\", \"benchmark a model\", \"prompt framework benchmark\", \"benchmark-harness\"],\n110:       \"advisorRouting\": {\n111:         \"routingClass\": \"command-bridge\",\n112:         \"packetSkillName\": \"deep-improvement\"\n113:       }\n114:     },\n115:     {\n116:       \"workflowMode\": \"skill-benchmark\",\n117:       \"runtimeLoopType\": null,\n118:       \"backendKind\": \"improvement-host\",\n119:       \"packet\": \"deep-improvement\",\n120:       \"loopHostMode\": \"skill-benchmark\",\n121:       \"command\": \"/deep:skill-benchmark\",\n122:       \"agent\": \"deep-improvement\",\n123:       \"artifactRoot\": \"improvement/\",\n124:       \"aliases\": [\"skill benchmark\", \"benchmark a skill\", \"skill routing benchmark\"],\n125:       \"advisorRouting\": {\n126:         \"routingClass\": \"command-bridge\",\n127:         \"packetSkillName\": \"deep-improvement\"\n128:       }\n129:     },\n130:     {\n131:       \"workflowMode\": \"ai-system-improvement\",\n132:       \"runtimeLoopType\": null,\n133:       \"backendKind\": \"external-adapter\",\n134:       \"packet\": \"deep-improvement\",\n135:       \"loopHostMode\": \"non-dev-ai-system-refine\",\n136:       \"command\": \"/deep:ai-system-improvement\",\n137:       \"agent\": \"deep-improvement\",\n138:       \"artifactRoot\": \"improvement/\",\n139:       \"externalLoopOwner\": \"external packaging (e.g. Barter Copywriter) owns the Python loop, gates, scoring, and kill-switches\",\n140:       \"aliases\": [\"non-dev ai system\", \"non-dev-ai-system\", \"package ai system benchmark\"],\n141:       \"advisorRouting\": {\n142:         \"routingClass\": \"command-bridge\",\n143:         \"packetSkillName\": \"deep-improvement\"\n144:       }\n145:     }\n146:   ]\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"{\n  \"skill\": \"deep-loop-workflows\",\n  \"version\": \"1.1.0\",\n  \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n  \"discriminator\": {\n    \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n    \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council|context. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n    \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n  },\n  \"advisorRoutingContract\": {\n    \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n    \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n    \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n    \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n    \"packetSkillName\": \"The packet's SKILL.md name. Standard for all parent skills: folder == packetSkillName == deep-<mode>; deep-ai-council follows this (folder 'deep-ai-council', packetSkillName 'deep-ai-council'). The legacy public key 'ai-council' is preserved only on the command/agent surfaces, not on the packet folder/name.\",\n    \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts asserts the hardcoded Python + TS maps equal this registry's projection.\"\n  },\n  \"modes\": [\n    {\n      \"workflowMode\": \"context\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json","text":"{\n  \"skill\": \"deep-loop-workflows\",\n  \"version\": \"1.1.0\",\n  \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n  \"discriminator\": {\n    \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n    \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council|context. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n    \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n  },\n  \"advisorRoutingContract\": {\n    \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n    \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n    \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n    \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n    \"packetSkillName\": \"The packet's SKILL.md name. Standard for all parent skills: folder == packetSkillName == deep-<mode>; deep-ai-council follows this (folder 'deep-ai-council', packetSkillName 'deep-ai-council'). The legacy public key 'ai-council' is preserved only on the command/agent 