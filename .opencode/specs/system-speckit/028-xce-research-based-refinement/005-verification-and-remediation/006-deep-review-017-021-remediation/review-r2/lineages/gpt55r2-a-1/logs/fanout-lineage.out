keywordWeight,\n231:     });\n232:   }\n233: \n234:   if (graphResults.length > 0 && typeof weights.graphWeight === 'number' && weights.graphWeight > 0) {\n235:     lists.push({\n236:       source: 'graph',\n237:       results: graphResults,\n238:       weight: weights.graphWeight,\n239:     });\n240:   }\n241: \n242:   for (const list of additionalLists) {\n243:     if (!list || !Array.isArray(list.results) || list.results.length === 0) {\n244:       continue;\n245:     }\n246:     const weight = typeof list.weight === 'number' && Number.isFinite(list.weight)\n247:       ? list.weight\n248:       : 1;\n249:     if (weight <= 0) {\n250:       continue;\n251:     }\n252:     lists.push({\n253:       ...list,\n254:       weight,\n255:     });\n256:   }\n257: \n258:   if (lists.length === 0) {\n259:     // AI: Fix F3 — return empty on all-zero weights.\n260:     return [];\n261:   }\n262: \n263:   const fused = fuseResultsMulti(lists);\n264: \n265:   // Apply recency boost if recencyWeight > 0, then re-normalize to [0,1]\n266:   // Boost MUST be followed by normalization to keep scores in [0,1]\n267:   if (weights.recencyWeight > 0) {\n268:     applyRecencyBoost(fused, weights.recencyWeight);\n269: \n270:     const maxScore = fused.reduce((mx, r) => Math.max(mx, r.rrfScore), 0);\n271:     if (maxScore > 1.0) {\n272:       for (const r of fused) {\n273:         r.rrfScore /= maxScore;\n274:       }\n275:     }\n276:   }\n277: \n278:   // Re-sort after recency boost\n279:   fused.sort((a, b) => b.rrfScore - a.rrfScore);\n280: \n281:   return fused;\n282: }\n283: \n284: /**\n285:  * Apply a recency boost to fused results. Items with a `created_at`\n286:  * timestamp receive a bonus proportional to how recent they are.\n287:  * Falls back gracefully when no timestamps are present.\n288:  */\n289: function applyRecencyBoost(results: FusionResult[], recencyWeight: number): void {\n290:   const now = Date.now();\n291:   const ONE_DAY_MS = 86_400_000;\n292:   const MAX_AGE_DAYS = 365;\n293: \n294:   for (const r of results) {\n295:     const createdAt = r.created_at as string | undefined;\n296:     if (!createdAt) continue;\n297: \n298:     try {\n299:       const ts = new Date(createdAt).getTime();\n300:       if (Number.isNaN(ts)) continue;\n301: \n302:       const ageDays = Math.max(0, (now - ts) / ONE_DAY_MS);\n303:       // Exponential decay: recent items get higher boost\n304:       const freshness = Math.exp(-ageDays / MAX_AGE_DAYS);\n305:       r.rrfScore += freshness * recencyWeight * RECENCY_BOOST_SCALE;\n306:     } catch (_err: unknown) {\n307:       if (_err instanceof Error) {\n308:         void _err.message;\n309:       }\n310:       /* AI-GUARD: Skip items with invalid dates — never fail the fusion pipeline */\n311:     }\n312:   }\n313: }\n314: \n315: /* --- 6. STANDARD FALLBACK --- */\n316: \n317: /**\n318:  * Standard RRF fusion without adaptive weighting (deterministic fallback).\n319:  * Uses equal weights for all sources.\n320:  *\n321:  * @param semanticResults - Results from vector/semantic search\n322:  * @param keywordResults - Results from keyword/lexical search\n323:  * @returns Fused results with equal-weight RRF scores\n324:  */\n325: export function standardFuse(\n326:   semanticResults: RrfItem[],\n327:   keywordResults: RrfItem[]\n328: ): FusionResult[] {\n329:   const lists: RankedList[] = [];\n330: \n331:   if (semanticResults.length > 0) {\n332:     lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n333:   }\n334: \n335:   if (keywordResults.length > 0) {\n336:     lists.push({ source: 'keyword', results: keywordResults, weight: 1.0 });\n337:   }\n338: \n339:   if (lists.length === 0) return [];\n340: \n341:   return fuseResultsMulti(lists);\n342: }\n343: \n344: /* --- 7. DARK-RUN MODE --- */\n345: \n346: function computeDarkRunDiff(\n347:   standardResults: FusionResult[],\n348:   adaptiveResults: FusionResult[]\n349: ): DarkRunDiff {\n\n(Showing lines 190-349 of 470. Use offset=350 to continue.)\n</content>","metadata":{"preview":"    }\n  }\n\n  return weights;\n}\n\n/* --- 5. ADAPTIVE FUSION --- */\n\n/**\n * Weighted RRF fusion. Applies FusionWeights to source lists before\n * passing to `fuseResultsMulti`. The semanticWeight/keywordWeight map\n * to vector/lexical list weights; recencyWeight is applied as a\n * post-fusion boost based on item timestamps.\n *\n * @param semanticResults - Results from vector/semantic search\n * @param keywordResults - Results from keyword/lexical search\n * @param weights - Fusion weights for each channel\n * @returns Fused and scored results sorted by RRF score\n */\nexport function adaptiveFuse(","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","text":"    }\n  }\n\n  return weights;\n}\n\n/* --- 5. ADAPTIVE FUSION --- */\n\n/**\n * Weighted RRF fusion. Applies FusionWeights to source lists before\n * passing to `fuseResultsMulti`. The semanticWeight/keywordWeight map\n * to vector/lexical list weights; recencyWeight is applied as a\n * post-fusion boost based on item timestamps.\n *\n * @param semanticResults - Results from vector/semantic search\n * @param keywordResults - Results from keyword/lexical search\n * @param weights - Fusion weights for each channel\n * @returns Fused and scored results sorted by RRF score\n */\nexport function adaptiveFuse(\n  semanticResults: RrfItem[],\n  keywordResults: RrfItem[],\n  weights: FusionWeights,\n  options: AdaptiveFuseOptions = {},\n): FusionResult[] {\n  const { graphResults = [], additionalLists = [] } = options;\n  const lists: RankedList[] = [];\n\n  if (semanticResults.length > 0 && weights.semanticWeight > 0) {\n    lists.push({\n      source: 'vector',\n      results: semanticResults,\n      weight: weights.semanticWeight,\n    });\n  }\n\n  if (keywordResults.length > 0 && weights.keywordWeight > 0) {\n    lists.push({\n      source: 'keyword',\n      results: keywordResults,\n      weight: weights.keywordWeight,\n    });\n  }\n\n  if (graphResults.length > 0 && typeof weights.graphWeight === 'number' && weights.graphWeight > 0) {\n    lists.push({\n      source: 'graph',\n      results: graphResults,\n      weight: weights.graphWeight,\n    });\n  }\n\n  for (const list of additionalLists) {\n    if (!list || !Array.isArray(list.results) || list.results.length === 0) {\n      continue;\n    }\n    const weight = typeof list.weight === 'number' && Number.isFinite(list.weight)\n      ? list.weight\n      : 1;\n    if (weight <= 0) {\n      continue;\n    }\n    lists.push({\n      ...list,\n      weight,\n    });\n  }\n\n  if (lists.length === 0) {\n    // AI: Fix F3 — return empty on all-zero weights.\n    return [];\n  }\n\n  const fused = fuseResultsMulti(lists);\n\n  // Apply recency boost if recencyWeight > 0, then re-normalize to [0,1]\n  // Boost MUST be followed by normalization to keep scores in [0,1]\n  if (weights.recencyWeight > 0) {\n    applyRecencyBoost(fused, weights.recencyWeight);\n\n    const maxScore = fused.reduce((mx, r) => Math.max(mx, r.rrfScore), 0);\n    if (maxScore > 1.0) {\n      for (const r of fused) {\n        r.rrfScore /= maxScore;\n      }\n    }\n  }\n\n  // Re-sort after recency boost\n  fused.sort((a, b) => b.rrfScore - a.rrfScore);\n\n  return fused;\n}\n\n/**\n * Apply a recency boost to fused results. Items with a `created_at`\n * timestamp receive a bonus proportional to how recent they are.\n * Falls back gracefully when no timestamps are present.\n */\nfunction applyRecencyBoost(results: FusionResult[], recencyWeight: number): void {\n  const now = Date.now();\n  const ONE_DAY_MS = 86_400_000;\n  const MAX_AGE_DAYS = 365;\n\n  for (const r of results) {\n    const createdAt = r.created_at as string | undefined;\n    if (!createdAt) continue;\n\n    try {\n      const ts = new Date(createdAt).getTime();\n      if (Number.isNaN(ts)) continue;\n\n      const ageDays = Math.max(0, (now - ts) / ONE_DAY_MS);\n      // Exponential decay: recent items get higher boost\n      const freshness = Math.exp(-ageDays / MAX_AGE_DAYS);\n      r.rrfScore += freshness * recencyWeight * RECENCY_BOOST_SCALE;\n    } catch (_err: unknown) {\n      if (_err instanceof Error) {\n        void _err.message;\n      }\n      /* AI-GUARD: Skip items with invalid dates — never fail the fusion pipeline */\n    }\n  }\n}\n\n/* --- 6. STANDARD FALLBACK --- */\n\n/**\n * Standard RRF fusion without adaptive weighting (deterministic fallback).\n * Uses equal weights for all sources.\n *\n * @param semanticResults - Results from vector/semantic search\n * @param keywordResults - Results from keyword/lexical search\n * @returns Fused results with equal-weight RRF scores\n */\nexport function standardFuse(\n  semanticResults: RrfItem[],\n  keywordResults: RrfItem[]\n): FusionResult[] {\n  const lists: RankedList[] = [];\n\n  if (semanticResults.length > 0) {\n    lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n  }\n\n  if (keywordResults.length > 0) {\n    lists.push({ source: 'keyword', results: keywordResults, weight: 1.0 });\n  }\n\n  if (lists.length === 0) return [];\n\n  return fuseResultsMulti(lists);\n}\n\n/* --- 7. DARK-RUN MODE --- */\n\nfunction computeDarkRunDiff(\n  standardResults: FusionResult[],\n  adaptiveResults: FusionResult[]\n): DarkRunDiff {","lineStart":190,"lineEnd":349,"totalLines":470,"truncated":true}},"title":".opencode/skills/system-spec-kit/shared/algorithms/adaptive-fusion.ts","time":{"start":1781761512756,"end":1781761512759}},"metadata":{"openai":{"itemId":"fc_095485368f6c903d016a3385e8b5a08191821c308833d56306"}},"id":"prt_ed9431511001JIOKkdGZR7CWvz","sessionID":"ses_126bff004ffeidXJpk4781In70","messageID":"msg_ed94302100011kQsW2qtmc8Btf"}}
