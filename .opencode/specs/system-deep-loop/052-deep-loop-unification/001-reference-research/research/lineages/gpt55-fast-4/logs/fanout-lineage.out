y\",\n172:         \"kind\": \"proper_noun\",\n173:         \"path\": \"checklist.md\",\n174:         \"source\": \"derived\"\n175:       }\n176:     ],\n177:     \"causal_summary\": \"Three parallel sonnet-5 Plan agents already produced a concrete, file:line-grounded mechanical design for merging `deep-loop-workflows` + `deep-loop-runtime` into `system-deep-loop` (structural layout, reference migration, and the research-fanout invocation itself)\",\n178:     \"created_at\": \"2026-07-08T04:36:15.360Z\",\n179:     \"last_save_at\": \"2026-07-08T04:43:08.681Z\",\n180:     \"save_lineage\": \"graph_only\",\n181:     \"last_accessed_at\": null,\n182:     \"source_docs\": [\n183:       \"spec.md\",\n184:       \"plan.md\",\n185:       \"tasks.md\",\n186:       \"checklist.md\"\n187:     ],\n188:     \"source_fingerprint\": \"sha256:ec1680fa14f2ae16f7ed7253f0f5025b6c89349f4e8bff6ed95bb30515ae61dc\",\n189:     \"source_doc_hashes\": {\n190:       \"spec.md\": \"4867c206f708c00c1d561f73e95e8e7bc11d7dfb9e95991ed957594ea9748c4f\",\n191:       \"plan.md\": \"79395d4355bd292b5d665effae342852c27c745c33b94125657979f4db73430c\",\n192:       \"tasks.md\": \"296e11b608cfe677a5181158fb3be4281ce6f28a452ba7dd16252dd752cc67fa\",\n193:       \"checklist.md\": \"93256c4994ff5068894a15351f7bf14115c6b9df18c81ec9e10542daf1699c7a\"\n194:     },\n195:     \"last_active_child_id\": null,\n196:     \"last_active_at\": null\n197:   }\n198: }\n\n(End of file - total 198 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-deep-loop/052-deep-loop-unification/001-reference-research\",\n  \"spec_folder\": \"system-deep-loop/052-deep-loop-unification/001-reference-research\",\n  \"parent_id\": \"system-deep-loop/052-deep-loop-unification\",\n  \"children_ids\": [],\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"deep loop unification research\",\n      \