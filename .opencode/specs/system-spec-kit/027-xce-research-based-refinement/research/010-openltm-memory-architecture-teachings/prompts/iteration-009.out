{"type":"tool_use","timestamp":1780925697518,"sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","part":{"type":"tool","tool":"read","callID":"call_0rGh486YI1qVdnrRIZgc1knU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/migrations.ts","offset":1,"limit":430},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/migrations.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: /**\n3:  * migrations.ts — Versioned schema migration runner for openltm.db\n4:  * Uses bun:sqlite and Bun file APIs exclusively.\n5:  *\n6:  * CLI: bun migrations.ts [--status | --up | --down | --reset]\n7:  */\n8: import { Database } from \"bun:sqlite\";\n9: import { readdirSync, existsSync, statSync, unlinkSync } from \"fs\";\n10: import { join, dirname } from \"path\";\n11: import { createHash } from \"crypto\";\n12: import { getDbPath, getMigrationsDir } from \"./paths.js\";\n13: \n14: const DB_PATH = getDbPath();\n15: const MIGRATIONS_DIR = getMigrationsDir();\n16: \n17: function openDb(): Database {\n18:   const db = new Database(DB_PATH, { create: true });\n19:   db.exec(\"PRAGMA journal_mode=WAL; PRAGMA foreign_keys=ON;\");\n20:   return db;\n21: }\n22: \n23: // ── Helpers ────────────────────────────────────────────────────────────────────\n24: \n25: export function ensureMigrationsTable(db: Database): void {\n26:   db.exec(`\n27:     CREATE TABLE IF NOT EXISTS _schema_version (\n28:       id          INTEGER PRIMARY KEY AUTOINCREMENT,\n29:       version     INTEGER NOT NULL UNIQUE,\n30:       name        TEXT NOT NULL,\n31:       applied_at  TEXT NOT NULL DEFAULT (datetime('now')),\n32:       checksum    TEXT NOT NULL\n33:     )\n34:   `);\n35: }\n36: \n37: export interface MigrationFile {\n38:   version: number;\n39:   name: string;\n40:   path: string;\n41:   content: string;\n42: }\n43: \n44: export async function getMigrationFiles(): Promise<MigrationFile[]> {\n45:   if (!existsSync(MIGRATIONS_DIR)) return [];\n46: \n47:   const files = readdirSync(MIGRATIONS_DIR)\n48:     .filter((f) => f.endsWith(\".sql\"))\n49:     .sort();\n50: \n51:   const results: MigrationFile[] = [];\n52:   for (const file of files) {\n53:     const match = file.match(/^(\\d+)_(.+)\\.sql$/);\n54:     if (!match) throw new Error(`Migration filename must match NNN_name.sql: ${file}`);\n55:     const version = parseInt(match[1]!, 10);\n56:     const name = match[2]!;\n57:     const filePath = join(MIGRATIONS_DIR, file);\n58:     const content = await Bun.file(filePath).text();\n59:     results.push({ version, name, path: filePath, content });\n60:   }\n61:   return results;\n62: }\n63: \n64: export function getAppliedVersions(db: Database): Set<number> {\n65:   ensureMigrationsTable(db);\n66:   const rows = db\n67:     .query<{ version: number }, []>(\"SELECT version FROM _schema_version ORDER BY version\")\n68:     .all();\n69:   return new Set(rows.map((r) => r.version));\n70: }\n71: \n72: export function computeChecksum(content: string): string {\n73:   return createHash(\"sha256\").update(content).digest(\"hex\");\n74: }\n75: \n76: export async function backupDb(): Promise<string> {\n77:   const timestamp = new Date().toISOString().replace(/[:.]/g, \"-\");\n78:   const backupPath = `${DB_PATH}.bak-${timestamp}`;\n79:   // Skip backup when the source DB doesn't exist (e.g. in-process test DBs\n80:   // that were created on a different path than the module-level DB_PATH).\n81:   if (!existsSync(DB_PATH)) return backupPath;\n82:   const bytes = await Bun.file(DB_PATH).arrayBuffer();\n83:   await Bun.write(backupPath, bytes);\n84:   return backupPath;\n85: }\n86: \n87: /**\n88:  * Read the default backup retention count from `LTM_BACKUP_RETENTION` env var.\n89:  * Falls back to 1. Negative or non-numeric values also default to 1.\n90:  */\n91: export function getRetentionDefault(): number {\n92:   const env = process.env[\"LTM_BACKUP_RETENTION\"];\n93:   if (!env) return 1;\n94:   const n = parseInt(env, 10);\n95:   if (Number.isNaN(n) || n < 0) return 1;\n96:   return n;\n97: }\n98: \n99: export interface EnforceRetentionOptions {\n100:   /** Override the db path (defaults to getDbPath() result). */\n101:   dbPath?: string;\n102:   /** Path of a .bak file just created by backupDb() — never delete it. */\n103:   currentBackupPath?: string;\n104:   /** Skip files whose mtime is newer than this many ms (default 60_000 = 60s). */\n105:   gracePeriodMs?: number;\n106: }\n107: \n108: export interface EnforceRetentionResult {\n109:   /** Absolute paths of files successfully deleted. */\n110:   deleted: string[];\n111:   /** Absolute paths of files that remain (within the retention window). */\n112:   kept: string[];\n113:   /** Non-fatal issues encountered (e.g. stat/unlink permission errors). */\n114:   warnings: string[];\n115: }\n116: \n117: /**\n118:  * Enforce a maximum number of .bak files alongside the database.\n119:  *\n120:  * Filenames are `openltm.db.bak-<ISO-timestamp>`. ISO timestamps sort lexically,\n121:  * so sorting by filename = sorting by creation time. We keep the newest N\n122:  * and delete the rest. Files newer than `gracePeriodMs` (default 60s) are\n123:  * skipped to avoid racing with a concurrent writer.\n124:  *\n125:  * The function is idempotent and never throws — every error becomes a\n126:  * warning in the result.\n127:  */\n128: export async function enforceRetention(\n129:   maxBackups: number,\n130:   options: EnforceRetentionOptions = {},\n131: ): Promise<EnforceRetentionResult> {\n132:   const dbPath = options.dbPath ?? getDbPath();\n133:   const gracePeriodMs = options.gracePeriodMs ?? 60_000;\n134:   const result: EnforceRetentionResult = { deleted: [], kept: [], warnings: [] };\n135: \n136:   const dir = dirname(dbPath);\n137:   if (!existsSync(dir)) {\n138:     result.warnings.push(`Directory does not exist: ${dir}`);\n139:     return result;\n140:   }\n141: \n142:   const files = readdirSync(dir).filter((f) => f.startsWith(\"openltm.db.bak-\"));\n143:   if (files.length === 0) return result;\n144: \n145:   const now = Date.now();\n146:   const eligible: string[] = [];\n147:   const excluded: string[] = [];\n148:   for (const f of files) {\n149:     const fullPath = join(dir, f);\n150:     try {\n151:       const mtime = statSync(fullPath).mtimeMs;\n152:       if (now - mtime < gracePeriodMs) {\n153:         excluded.push(fullPath);\n154:         continue;\n155:       }\n156:     } catch (err: unknown) {\n157:       const code = (err as NodeJS.ErrnoException).code;\n158:       if (code === \"ENOENT\") continue;\n159:       result.warnings.push(`stat failed for ${fullPath}: ${(err as Error).message}`);\n160:       continue;\n161:     }\n162:     if (options.currentBackupPath && fullPath === options.currentBackupPath) {\n163:       excluded.push(fullPath);\n164:       continue;\n165:     }\n166:     eligible.push(fullPath);\n167:   }\n168: \n169:   if (eligible.length === 0) {\n170:     result.kept = excluded;\n171:     return result;\n172:   }\n173: \n174:   eligible.sort();\n175: \n176:   const toDelete = eligible.slice(0, Math.max(0, eligible.length - maxBackups));\n177:   const toKeep = eligible.slice(toDelete.length);\n178: \n179:   for (const file of toDelete) {\n180:     try {\n181:       unlinkSync(file);\n182:       result.deleted.push(file);\n183:     } catch (err: unknown) {\n184:       const code = (err as NodeJS.ErrnoException).code;\n185:       if (code === \"ENOENT\") {\n186:         result.deleted.push(file);\n187:       } else {\n188:         result.warnings.push(`unlink failed for ${file}: ${(err as Error).message}`);\n189:       }\n190:     }\n191:   }\n192: \n193:   result.kept = [...excluded, ...toKeep];\n194:   return result;\n195: }\n196: \n197: export interface ParsedMigration {\n198:   up: string;\n199:   down: string;\n200: }\n201: \n202: export function parseMigration(content: string): ParsedMigration {\n203:   const parts = content.split(/^--\\s*DOWN\\s*$/m);\n204:   const up = (parts[0] ?? \"\")\n205:     .replace(/^--.*$/gm, \"\")\n206:     .trim();\n207:   const down = (parts[1] ?? \"\")\n208:     .replace(/^--.*$/gm, \"\")\n209:     .trim();\n210:   return { up, down };\n211: }\n212: \n213: // ── Core migration actions ─────────────────────────────────────────────────────\n214: \n215: export interface MigrationResult {\n216:   version: number;\n217:   name: string;\n218:   action: \"applied\" | \"skipped\" | \"rolled_back\";\n219: }\n220: \n221: export async function runPendingMigrations(db?: Database): Promise<MigrationResult[]> {\n222:   const _db = db ?? openDb();\n223:   ensureMigrationsTable(_db);\n224: \n225:   const files = await getMigrationFiles();\n226:   const applied = getAppliedVersions(_db);\n227:   const pending = files.filter((f) => !applied.has(f.version));\n228: \n229:   if (pending.length === 0) return [];\n230: \n231:   const newBackupPath = await backupDb();\n232: \n233:   const results: MigrationResult[] = [];\n234:   for (const file of pending) {\n235:     const { up } = parseMigration(file.content);\n236:     const checksum = computeChecksum(file.content);\n237: \n238:     try {\n239:       _db.transaction(() => {\n240:         // Skip exec for marker migrations that have no DDL (e.g. 001_baseline).\n241:         if (up) _db.exec(up);\n242:         _db.run(\n243:           `INSERT INTO _schema_version (version, name, checksum) VALUES (?, ?, ?)`,\n244:           [file.version, file.name, checksum],\n245:         );\n246:       })();\n247:     } catch (err: unknown) {\n248:       const msg = (err as { message?: string }).message ?? \"\";\n249:       // Column was already added by shared-db.ts runMigrations() — self-heal by recording as applied\n250:       if (msg.includes(\"duplicate column name\") || msg.includes(\"already exists\")) {\n251:         _db.run(\n252:           `INSERT OR IGNORE INTO _schema_version (version, name, checksum) VALUES (?, ?, ?)`,\n253:           [file.version, file.name, checksum],\n254:         );\n255:       } else {\n256:         throw err;\n257:       }\n258:     }\n259: \n260:     results.push({ version: file.version, name: file.name, action: \"applied\" });\n261:   }\n262: \n263:   try {\n264:     await enforceRetention(getRetentionDefault(), { currentBackupPath: newBackupPath });\n265:   } catch (err: unknown) {\n266:     console.warn(`[migrations] retention enforcement failed: ${(err as Error).message}`);\n267:   }\n268: \n269:   return results;\n270: }\n271: \n272: export interface MigrationStatus {\n273:   version: number;\n274:   name: string;\n275:   status: \"applied\" | \"pending\";\n276:   applied_at?: string;\n277: }\n278: \n279: export async function getMigrationStatus(db?: Database): Promise<MigrationStatus[]> {\n280:   const _db = db ?? openDb();\n281:   ensureMigrationsTable(_db);\n282: \n283:   const files = await getMigrationFiles();\n284:   const rows = _db\n285:     .query<{ version: number; applied_at: string }, []>(\n286:       \"SELECT version, applied_at FROM _schema_version ORDER BY version\",\n287:     )\n288:     .all();\n289:   const appliedMap = new Map(rows.map((r) => [r.version, r.applied_at]));\n290: \n291:   return files.map((f) => {\n292:     const applied_at = appliedMap.get(f.version);\n293:     return {\n294:       version: f.version,\n295:       name: f.name,\n296:       status: (applied_at ? \"applied\" : \"pending\") as \"applied\" | \"pending\",\n297:       ...(applied_at ? { applied_at } : {}),\n298:     };\n299:   });\n300: }\n301: \n302: export async function rollbackLast(db?: Database): Promise<MigrationResult | null> {\n303:   const _db = db ?? openDb();\n304:   ensureMigrationsTable(_db);\n305: \n306:   const last = _db\n307:     .query<{ version: number; name: string }, []>(\n308:       \"SELECT version, name FROM _schema_version ORDER BY version DESC LIMIT 1\",\n309:     )\n310:     .get();\n311: \n312:   if (!last) return null;\n313: \n314:   const files = await getMigrationFiles();\n315:   const file = files.find((f) => f.version === last.version);\n316:   if (!file) throw new Error(`Migration file for version ${last.version} not found`);\n317: \n318:   const { down } = parseMigration(file.content);\n319:   if (!down) throw new Error(`Migration ${last.version} has no DOWN section`);\n320: \n321:   _db.transaction(() => {\n322:     _db.exec(down);\n323:     _db.run(\"DELETE FROM _schema_version WHERE version = ?\", [last.version]);\n324:   })();\n325: \n326:   return { version: last.version, name: last.name, action: \"rolled_back\" };\n327: }\n328: \n329: export async function resetAll(db?: Database): Promise<MigrationResult[]> {\n330:   const _db = db ?? openDb();\n331:   ensureMigrationsTable(_db);\n332: \n333:   // Read files once, then roll back in reverse order without repeated disk reads\n334:   const files = await getMigrationFiles();\n335:   const fileMap = new Map(files.map((f) => [f.version, f]));\n336: \n337:   const applied = _db\n338:     .query<{ version: number; name: string }, []>(\n339:       \"SELECT version, name FROM _schema_version ORDER BY version DESC\",\n340:     )\n341:     .all();\n342: \n343:   const results: MigrationResult[] = [];\n344:   for (const row of applied) {\n345:     const file = fileMap.get(row.version);\n346:     if (!file) throw new Error(`Migration file for version ${row.version} not found`);\n347:     const { down } = parseMigration(file.content);\n348:     if (!down) throw new Error(`Migration ${row.version} has no DOWN section`);\n349:     _db.transaction(() => {\n350:       _db.exec(down);\n351:       _db.run(\"DELETE FROM _schema_version WHERE version = ?\", [row.version]);\n352:     })();\n353:     results.push({ version: row.version, name: row.name, action: \"rolled_back\" });\n354:   }\n355:   return results;\n356: }\n357: \n358: // ── CLI entry point ────────────────────────────────────────────────────────────\n359: \n360: if (import.meta.main) {\n361:   void (async () => {\n362:     const arg = process.argv[2] ?? \"--status\";\n363:     const db = openDb();\n364: \n365:     try {\n366:       if (arg === \"--status\") {\n367:         const statuses = await getMigrationStatus(db);\n368:         if (statuses.length === 0) {\n369:           console.error(\"No migration files found in migrations/\");\n370:         } else {\n371:           console.error(\"\\nMigration Status:\");\n372:           console.error(\"─\".repeat(60));\n373:           for (const s of statuses) {\n374:             const tag = s.status === \"applied\" ? \"[applied]\" : \"[pending]\";\n375:             const date = s.applied_at ? `  (${s.applied_at})` : \"\";\n376:             console.error(`  ${tag.padEnd(10)} v${String(s.version).padStart(3, \"0\")} ${s.name}${date}`);\n377:           }\n378:           console.error(\"\");\n379:         }\n380:       } else if (arg === \"--up\") {\n381:         const results = await runPendingMigrations(db);\n382:         if (results.length === 0) {\n383:           console.error(\"No pending migrations.\");\n384:         } else {\n385:           for (const r of results) {\n386:             console.error(`Applied: v${String(r.version).padStart(3, \"0\")} ${r.name}`);\n387:           }\n388:         }\n389:       } else if (arg === \"--down\") {\n390:         const result = await rollbackLast(db);\n391:         if (!result) {\n392:           console.error(\"No applied migrations to roll back.\");\n393:         } else {\n394:           console.error(`Rolled back: v${String(result.version).padStart(3, \"0\")} ${result.name}`);\n395:         }\n396:       } else if (arg === \"--reset\") {\n397:         const results = await resetAll(db);\n398:         if (results.length === 0) {\n399:           console.error(\"Nothing to reset.\");\n400:         } else {\n401:           for (const r of results) {\n402:             console.error(`Rolled back: v${String(r.version).padStart(3, \"0\")} ${r.name}`);\n403:           }\n404:         }\n405:       } else {\n406:         console.error(`Unknown argument: ${arg}`);\n407:         console.error(\"Usage: bun migrations.ts [--status | --up | --down | --reset]\");\n408:         process.exit(1);\n409:       }\n410:     } catch (err) {\n411:       console.error(\"Migration error:\", err);\n412:       process.exit(1);\n413:     }\n414:   })();\n415: }\n\n(End of file - total 415 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * migrations.ts — Versioned schema migration runner for openltm.db\n * Uses bun:sqlite and Bun file APIs exclusively.\n *\n * CLI: bun migrations.ts [--status | --up | --down | --reset]\n */\nimport { Database } from \"bun:sqlite\";\nimport { readdirSync, existsSync, statSync, unlinkSync } from \"fs\";\nimport { join, dirname } from \"path\";\nimport { createHash } from \"crypto\";\nimport { getDbPath, getMigrationsDir } from \"./paths.js\";\n\nconst DB_PATH = getDbPath();\nconst MIGRATIONS_DIR = getMigrationsDir();\n\nfunction openDb(): Database {\n  const db = new Database(DB_PATH, { create: true });\n  db.exec(\"PRAGMA journal_mode=WAL; PRAGMA foreign_keys=ON;\");\n  return db;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/migrations.ts","text":"#!/usr/bin/env bun\n/**\n * migrations.ts — Versioned schema migration runner for openltm.db\n * Uses bun:sqlite and Bun file APIs exclusively.\n *\n * CLI: bun migrations.ts [--status | --up | --down | --reset]\n */\nimport { Database } from \"bun:sqlite\";\nimport { readdirSync, existsSync, statSync, unlinkSync } from \"fs\";\nimport { join, dirname } from \"path\";\nimport { createHash } from \"crypto\";\nimport { getDbPath, getMigrationsDir } from \"./paths.js\";\n\nconst DB_PATH = getDbPath();\nconst MIGRATIONS_DIR = getMigrationsDir();\n\nfunction openDb(): Database {\n  const db = new Database(DB_PATH, { create: true });\n  db.exec(\"PRAGMA journal_mode=WAL; PRAGMA foreign_keys=ON;\");\n  return db;\n}\n\n// ── Helpers ────────────────────────────────────────────────────────────────────\n\nexport function ensureMigrationsTable(db: Database): void {\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS _schema_version (\n      id          INTEGER PRIMARY KEY AUTOINCREMENT,\n      version     INTEGER NOT NULL UNIQUE,\n      name        TEXT NOT NULL,\n      applied_at  TEXT NOT NULL DEFAULT (datetime('now')),\n      checksum    TEXT NOT NULL\n    )\n  `);\n}\n\nexport interface MigrationFile {\n  version: number;\n  name: string;\n  path: string;\n  content: string;\n}\n\nexport async function getMigrationFiles(): Promise<MigrationFile[]> {\n  if (!existsSync(MIGRATIONS_DIR)) return [];\n\n  const files = readdirSync(MIGRATIONS_DIR)\n    .filter((f) => f.endsWith(\".sql\"))\n    .sort();\n\n  const results: MigrationFile[] = [];\n  for (const file of files) {\n    const match = file.match(/^(\\d+)_(.+)\\.sql$/);\n    if (!match) throw new Error(`Migration filename must match NNN_name.sql: ${file}`);\n    const version = parseInt(match[1]!, 10);\n    const name = match[2]!;\n    const filePath = join(MIGRATIONS_DIR, file);\n    const content = await Bun.file(filePath).text();\n    results.push({ version, name, path: filePath, content });\n  }\n  return results;\n}\n\nexport function getAppliedVersions(db: Database): Set<number> {\n  ensureMigrationsTable(db);\n  const rows = db\n    .query<{ version: number }, []>(\"SELECT version FROM _schema_version ORDER BY version\")\n    .all();\n  return new Set(rows.map((r) => r.version));\n}\n\nexport function computeChecksum(content: string): string {\n  return createHash(\"sha256\").update(content).digest(\"hex\");\n}\n\nexport async function backupDb(): Promise<string> {\n  const timestamp = new Date().toISOString().replace(/[:.]/g, \"-\");\n  const backupPath = `${DB_PATH}.bak-${timestamp}`;\n  // Skip backup when the source DB doesn't exist (e.g. in-process test DBs\n  // that were created on a different path than the module-level DB_PATH).\n  if (!existsSync(DB_PATH)) return backupPath;\n  const bytes = await Bun.file(DB_PATH).arrayBuffer();\n  await Bun.write(backupPath, bytes);\n  return backupPath;\n}\n\n/**\n * Read the default backup retention count from `LTM_BACKUP_RETENTION` env var.\n * Falls back to 1. Negative or non-numeric values also default to 1.\n */\nexport function getRetentionDefault(): number {\n  const env = process.env[\"LTM_BACKUP_RETENTION\"];\n  if (!env) return 1;\n  const n = parseInt(env, 10);\n  if (Number.isNaN(n) || n < 0) return 1;\n  return n;\n}\n\nexport interface EnforceRetentionOptions {\n  /** Override the db path (defaults to getDbPath() result). */\n  dbPath?: string;\n  /** Path of a .bak file just created by backupDb() — never delete it. */\n  currentBackupPath?: string;\n  /** Skip files whose mtime is newer than this many ms (default 60_000 = 60s). */\n  gracePeriodMs?: number;\n}\n\nexport interface EnforceRetentionResult {\n  /** Absolute paths of files successfully deleted. */\n  deleted: string[];\n  /** Absolute paths of files that remain (within the retention window). */\n  kept: string[];\n  /** Non-fatal issues encountered (e.g. stat/unlink permission errors). */\n  warnings: string[];\n}\n\n/**\n * Enforce a maximum number of .bak files alongside the database.\n *\n * Filenames are `openltm.db.bak-<ISO-timestamp>`. ISO timestamps sort lexically,\n * so sorting by filename = sorting by creation time. We keep the newest N\n * and delete the rest. Files newer than `gracePeriodMs` (default 60s) are\n * skipped to avoid racing with a concurrent writer.\n *\n * The function is idempotent and never throws — every error becomes a\n * warning in the result.\n */\nexport async function enforceRetention(\n  maxBackups: number,\n  options: EnforceRetentionOptions = {},\n): Promise<EnforceRetentionResult> {\n  const dbPath = options.dbPath ?? getDbPath();\n  const gracePeriodMs = options.gracePeriodMs ?? 60_000;\n  const result: EnforceRetentionResult = { deleted: [], kept: [], warnings: [] };\n\n  const dir = dirname(dbPath);\n  if (!existsSync(dir)) {\n    result.warnings.push(`Directory does not exist: ${dir}`);\n    return result;\n  }\n\n  const files = readdirSync(dir).filter((f) => f.startsWith(\"openltm.db.bak-\"));\n  if (files.length === 0) return result;\n\n  const now = Date.now();\n  const eligible: string[] = [];\n  const excluded: string[] = [];\n  for (const f of files) {\n    const fullPath = join(dir, f);\n    try {\n      const mtime = statSync(fullPath).mtimeMs;\n      if (now - mtime < gracePeriodMs) {\n        excluded.push(fullPath);\n        continue;\n      }\n    } catch (err: unknown) {\n      const code = (err as NodeJS.ErrnoException).code;\n      if (code === \"ENOENT\") continue;\n      result.warnings.push(`stat failed for ${fullPath}: ${(err as Error).message}`);\n      continue;\n    }\n    if (options.currentBackupPath && fullPath === options.currentBackupPath) {\n      excluded.push(fullPath);\n      continue;\n    }\n    eligible.push(fullPath);\n  }\n\n  if (eligible.length === 0) {\n    result.kept = excluded;\n    return result;\n  }\n\n  eligible.sort();\n\n  const toDelete = eligible.slice(0, Math.max(0, eligible.length - maxBackups));\n  const toKeep = eligible.slice(toDelete.length);\n\n  for (const file of toDelete) {\n    try {\n      unlinkSync(file);\n      result.deleted.push(file);\n    } catch (err: unknown) {\n      const code = (err as NodeJS.ErrnoException).code;\n      if (code === \"ENOENT\") {\n        result.deleted.push(file);\n      } else {\n        result.warnings.push(`unlink failed for ${file}: ${(err as Error).message}`);\n      }\n    }\n  }\n\n  result.kept = [...excluded, ...toKeep];\n  return result;\n}\n\nexport interface ParsedMigration {\n  up: string;\n  down: string;\n}\n\nexport function parseMigration(content: string): ParsedMigration {\n  const parts = content.split(/^--\\s*DOWN\\s*$/m);\n  const up = (parts[0] ?? \"\")\n    .replace(/^--.*$/gm, \"\")\n    .trim();\n  const down = (parts[1] ?? \"\")\n    .replace(/^--.*$/gm, \"\")\n    .trim();\n  return { up, down };\n}\n\n// ── Core migration actions ─────────────────────────────────────────────────────\n\nexport interface MigrationResult {\n  version: number;\n  name: string;\n  action: \"applied\" | \"skipped\" | \"rolled_back\";\n}\n\nexport async function runPendingMigrations(db?: Database): Promise<MigrationResult[]> {\n  const _db = db ?? openDb();\n  ensureMigrationsTable(_db);\n\n  const files = await getMigrationFiles();\n  const applied = getAppliedVersions(_db);\n  const pending = files.filter((f) => !applied.has(f.version));\n\n  if (pending.length === 0) return [];\n\n  const newBackupPath = await backupDb();\n\n  const results: MigrationResult[] = [];\n  for (const file of pending) {\n    const { up } = parseMigration(file.content);\n    const checksum = computeChecksum(file.content);\n\n    try {\n      _db.transaction(() => {\n        // Skip exec for marker migrations that have no DDL (e.g. 001_baseline).\n        if (up) _db.exec(up);\n        _db.run(\n          `INSERT INTO _schema_version (version, name, checksum) VALUES (?, ?, ?)`,\n          [file.version, file.name, checksum],\n        );\n      })();\n    } catch (err: unknown) {\n      const msg = (err as { message?: string }).message ?? \"\";\n      // Column was already added by shared-db.ts runMigrations() — self-heal by recording as applied\n      if (msg.includes(\"duplicate column name\") || msg.includes(\"already exists\")) {\n        _db.run(\n          `INSERT OR IGNORE INTO _schema_version (version, name, checksum) VALUES (?, ?, ?)`,\n          [file.version, file.name, checksum],\n        );\n      } else {\n        throw err;\n      }\n    }\n\n    results.push({ version: file.version, name: file.name, action: \"applied\" });\n  }\n\n  try {\n    await enforceRetention(getRetentionDefault(), { currentBackupPath: newBackupPath });\n  } catch (err: unknown) {\n    console.warn(`[migrations] retention enforcement failed: ${(err as Error).message}`);\n  }\n\n  return results;\n}\n\nexport interface MigrationStatus {\n  version: number;\n  name: string;\n  status: \"applied\" | \"pending\";\n  applied_at?: string;\n}\n\nexport async function getMigrationStatus(db?: Database): Promise<MigrationStatus[]> {\n  const _db = db ?? openDb();\n  ensureMigrationsTable(_db);\n\n  const files = await getMigrationFiles();\n  const rows = _db\n    .query<{ version: number; applied_at: string }, []>(\n      \"SELECT version, applied_at FROM _schema_version ORDER BY version\",\n    )\n    .all();\n  const appliedMap = new Map(rows.map((r) => [r.version, r.applied_at]));\n\n  return files.map((f) => {\n    const applied_at = appliedMap.get(f.version);\n    return {\n      version: f.version,\n      name: f.name,\n      status: (applied_at ? \"applied\" : \"pending\") as \"applied\" | \"pending\",\n      ...(applied_at ? { applied_at } : {}),\n    };\n  });\n}\n\nexport async function rollbackLast(db?: Database): Promise<MigrationResult | null> {\n  const _db = db ?? openDb();\n  ensureMigrationsTable(_db);\n\n  const last = _db\n    .query<{ version: number; name: string }, []>(\n      \"SELECT version, name FROM _schema_version ORDER BY version DESC LIMIT 1\",\n    )\n    .get();\n\n  if (!last) return null;\n\n  const files = await getMigrationFiles();\n  const file = files.find((f) => f.version === last.version);\n  if (!file) throw new Error(`Migration file for version ${last.version} not found`);\n\n  const { down } = parseMigration(file.content);\n  if (!down) throw new Error(`Migration ${last.version} has no DOWN section`);\n\n  _db.transaction(() => {\n    _db.exec(down);\n    _db.run(\"DELETE FROM _schema_version WHERE version = ?\", [last.version]);\n  })();\n\n  return { version: last.version, name: last.name, action: \"rolled_back\" };\n}\n\nexport async function resetAll(db?: Database): Promise<MigrationResult[]> {\n  const _db = db ?? openDb();\n  ensureMigrationsTable(_db);\n\n  // Read files once, then roll back in reverse order without repeated disk reads\n  const files = await getMigrationFiles();\n  const fileMap = new Map(files.map((f) => [f.version, f]));\n\n  const applied = _db\n    .query<{ version: number; name: string }, []>(\n      \"SELECT version, name FROM _schema_version ORDER BY version DESC\",\n    )\n    .all();\n\n  const results: MigrationResult[] = [];\n  for (const row of applied) {\n    const file = fileMap.get(row.version);\n    if (!file) throw new Error(`Migration file for version ${row.version} not found`);\n    const { down } = parseMigration(file.content);\n    if (!down) throw new Error(`Migration ${row.version} has no DOWN section`);\n    _db.transaction(() => {\n      _db.exec(down);\n      _db.run(\"DELETE FROM _schema_version WHERE version = ?\", [row.version]);\n    })();\n    results.push({ version: row.version, name: row.name, action: \"rolled_back\" });\n  }\n  return results;\n}\n\n// ── CLI entry point ────────────────────────────────────────────────────────────\n\nif (import.meta.main) {\n  void (async () => {\n    const arg = process.argv[2] ?? \"--status\";\n    const db = openDb();\n\n    try {\n      if (arg === \"--status\") {\n        const statuses = await getMigrationStatus(db);\n        if (statuses.length === 0) {\n          console.error(\"No migration files found in migrations/\");\n        } else {\n          console.error(\"\\nMigration Status:\");\n          console.error(\"─\".repeat(60));\n          for (const s of statuses) {\n            const tag = s.status === \"applied\" ? \"[applied]\" : \"[pending]\";\n            const date = s.applied_at ? `  (${s.applied_at})` : \"\";\n            console.error(`  ${tag.padEnd(10)} v${String(s.version).padStart(3, \"0\")} ${s.name}${date}`);\n          }\n          console.error(\"\");\n        }\n      } else if (arg === \"--up\") {\n        const results = await runPendingMigrations(db);\n        if (results.length === 0) {\n          console.error(\"No pending migrations.\");\n        } else {\n          for (const r of results) {\n            console.error(`Applied: v${String(r.version).padStart(3, \"0\")} ${r.name}`);\n          }\n        }\n      } else if (arg === \"--down\") {\n        const result = await rollbackLast(db);\n        if (!result) {\n          console.error(\"No applied migrations to roll back.\");\n        } else {\n          console.error(`Rolled back: v${String(result.version).padStart(3, \"0\")} ${result.name}`);\n        }\n      } else if (arg === \"--reset\") {\n        const results = await resetAll(db);\n        if (results.length === 0) {\n          console.error(\"Nothing to reset.\");\n        } else {\n          for (const r of results) {\n            console.error(`Rolled back: v${String(r.version).padStart(3, \"0\")} ${r.name}`);\n          }\n        }\n      } else {\n        console.error(`Unknown argument: ${arg}`);\n        console.error(\"Usage: bun migrations.ts [--status | --up | --down | --reset]\");\n        process.exit(1);\n      }\n    } catch (err) {\n      console.error(\"Migration error:\", err);\n      process.exit(1);\n    }\n  })();\n}","lineStart":1,"lineEnd":415,"totalLines":415,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/migrations.ts","time":{"start":1780925697502,"end":1780925697513}},"metadata":{"openai":{"itemId":"fc_07686a430191f0e3016a26c5003964819193e9837c2d18f419"}},"id":"prt_ea77188f30014zv1w6N12efYkb","sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","messageID":"msg_ea7717ca5001zuMi0Y5ChcqCzE"}}
