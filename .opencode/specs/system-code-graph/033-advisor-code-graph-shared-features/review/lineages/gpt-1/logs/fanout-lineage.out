olvedSubject.symbolId;\n  if (!symbolId) {\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify(buildUnresolvedSubjectError(subject, resolvedSubject.suggestions ?? [])),\n      }],\n    };\n  }\n\n  // If includeTransitive, use BFS traversal instead of 1-hop\n  if (args.includeTransitive) {\n    const direction = operation.endsWith('from') ? 'from' : 'to';\n    // Wrap the BFS multi-SELECT traversal in a snapshot-stable read\n    // transaction so a concurrent index pass cannot shift the result set\n    // between the per-depth queries. better-sqlite3 transactions in WAL mode\n    // observe a consistent snapshot for the lifetime of the transaction.\n    const transitive = graphDb.getDb().transaction(() => transitiveTraversal(\n      symbolId,\n      requestedEdgeType ?? 'CALLS',\n      direction,\n      maxDepth,\n      limit,\n      operation,\n    ))();\n    const warnings = mergeWarnings(resolvedSubject.warnings, transitive.warnings);\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify({\n          status: 'ok',\n          data: buildGraphQueryPayload({\n            operation,\n            symbolId,\n            ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n            edgeType: requestedEdgeType,\n            transitive: true,\n            maxDepth,\n            ...(warnings ? { warnings } : {}),\n            nodes: transitive.nodes,\n          }, readiness, `code_graph_query ${operation} payload`),\n        }, null, 2),\n      }],\n    };\n  }\n\n  let result;\n  switch (operation) {\n    // 4 near-duplicate switch branches collapsed via the shared\n    // `mapOutboundRelationshipEdge` / `mapInboundRelationshipEdge` helpers.\n    // Variation surface: (1) direction (outbound / inbound), (2) whether the\n    // start line is included (calls_*) or omitted (imports_*).\n    case 'calls_from':\n    case 'imports_from': {\n      const includeLine = operation === 'calls_from';\n      // Snapshot-stable read transaction. queryEdgesFrom issues the edge\n      // lookup AND a per-edge node lookup; wrapping in a transaction\n      // ensures both observe a consistent snapshot under concurrent writers.\n      const edges = graphDb.getDb().transaction(\n        () => graphDb.queryEdgesFrom(symbolId, requestedEdgeType),\n      )();\n      const { resolvedEntries, warnings } = excludeDanglingEdges(\n        edges,\n        limit,\n        operation,\n        'target',\n        (entry: OutboundEdgeEntry) => entry.targetNode != null,\n        (entry: OutboundEdgeEntry) => entry.edge.targetId,\n      );\n      result = {\n        operation,\n        symbolId,\n        ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n        edgeType: requestedEdgeType,\n        edges: resolvedEntries.map((entry) => mapOutboundRelationshipEdge(entry, { includeLine })),\n        ...(warnings ? { warnings } : {}),\n        hotFileBreadcrumbs: buildHotFileBreadcrumbs(extractOutboundFilePaths(resolvedEntries)),\n      };\n      break;\n    }\n    case 'calls_to':\n    case 'imports_to': {\n      const includeLine = operation === 'calls_to';\n      // Snapshot-stable read transaction (see calls_from above).\n      const edges = graphDb.getDb().transaction(\n        () => graphDb.queryEdgesTo(symbolId, requestedEdgeType),\n      )();\n      const { resolvedEntries, warnings } = excludeDanglingEdges(","lineStart":1640,"lineEnd":1729,"totalLines":1766,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781128856809,"end":1781128856812}},"metadata":{"openai":{"itemId":"fc_058a63936a7aba6a016a29de98bd988191a68c1ca06eaf52d1"}},"id":"prt_eb38d84e1001GOY0Wz75K7rCgR","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d5ab90010oj5ax5ezt1Mr1"}}
{"type":"tool_use","timestamp":1781128856841,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_wVcTaSw32mQni7ZqdzoC2YNJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Packed BM25F Lexical Shadow Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorProjection, SkillProjection } from '../types.js';\n6: import { tokenize } from '../text.js';\n7: \n8: export const ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID = 'bm25_lexical_shadow' as const;\n9: \n10: const BM25_K1 = 1.2;\n11: const BM25_B = 0.75;\n12: const DEFAULT_LIMIT = 20;\n13: \n14: const BM25F_FIELD_NAMES = [\n15:   'name',\n16:   'keywords',\n17:   'domains',\n18:   'intentSignals',\n19:   'derivedTriggers',\n20:   'description',\n21: ] as const;\n22: \n23: export type AdvisorBm25FieldName = typeof BM25F_FIELD_NAMES[number];\n24: export type AdvisorBm25FieldWeights = Record<AdvisorBm25FieldName, number>;\n25: \n26: export const ADVISOR_BM25_FIELD_WEIGHTS: AdvisorBm25FieldWeights = {\n27:   name: 4.0,\n28:   keywords: 3.0,\n29:   domains: 2.2,\n30:   intentSignals: 2.4,\n31:   derivedTriggers: 1.8,\n32:   description: 1.0,\n33: };\n34: \n35: export interface AdvisorBm25SearchOptions {\n36:   readonly fieldWeights?: Partial<AdvisorBm25FieldWeights>;\n37:   readonly limit?: number;\n38: }\n39: \n40: export interface AdvisorBm25Match {\n41:   readonly skillId: string;\n42:   readonly lane: typeof ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID;\n43:   readonly score: number;\n44:   readonly rawScore: number;\n45:   readonly evidence: readonly string[];\n46:   readonly shadowOnly: true;\n47: }\n48: \n49: export interface AdvisorBm25FootprintStats {\n50:   readonly documentCount: number;\n51:   readonly termCount: number;\n52:   readonly postingCount: number;\n53:   readonly typedArrayBytes: number;\n54:   readonly mutablePostingCount: number;\n55: }\n56: \n57: interface FieldTermFrequency {\n58:   total: number;\n59:   fields: Record<AdvisorBm25FieldName, number>;\n60: }\n61: \n62: interface PackedSkillDocument {\n63:   numericId: number;\n64:   skillId: string;\n65:   length: number;\n66:   terms: readonly string[];\n67: }\n68: \n69: interface PackedPostingMutable {\n70:   docIds: number[];\n71:   totalTfs: number[];\n72:   nameTfs: number[];\n73:   keywordTfs: number[];\n74:   domainTfs: number[];\n75:   intentSignalTfs: number[];\n76:   derivedTriggerTfs: number[];\n77:   descriptionTfs: number[];\n78: }\n79: \n80: interface PackedPostingList {\n81:   docIds: Uint32Array;\n82:   totalTfs: Uint32Array;\n83:   nameTfs: Uint32Array;\n84:   keywordTfs: Uint32Array;\n85:   domainTfs: Uint32Array;\n86:   intentSignalTfs: Uint32Array;\n87:   derivedTriggerTfs: Uint32Array;\n88:   descriptionTfs: Uint32Array;\n89: }\n90: \n91: function emptyFieldFrequency(): FieldTermFrequency {\n92:   return {\n93:     total: 0,\n94:     fields: {\n95:       name: 0,\n96:       keywords: 0,\n97:       domains: 0,\n98:       intentSignals: 0,\n99:       derivedTriggers: 0,\n100:       description: 0,\n101:     },\n102:   };\n103: }\n104: \n105: function resolveFieldWeights(overrides: Partial<AdvisorBm25FieldWeights> = {}): AdvisorBm25FieldWeights {\n106:   return {\n107:     name: overrides.name ?? ADVISOR_BM25_FIELD_WEIGHTS.name,\n108:     keywords: overrides.keywords ?? ADVISOR_BM25_FIELD_WEIGHTS.keywords,\n109:     domains: overrides.domains ?? ADVISOR_BM25_FIELD_WEIGHTS.domains,\n110:     intentSignals: overrides.intentSignals ?? ADVISOR_BM25_FIELD_WEIGHTS.intentSignals,\n111:     derivedTriggers: overrides.derivedTriggers ?? ADVISOR_BM25_FIELD_WEIGHTS.derivedTriggers,\n112:     description: overrides.description ?? ADVISOR_BM25_FIELD_WEIGHTS.description,\n113:   };\n114: }\n115: \n116: function skillFields(skill: SkillProjection): Record<AdvisorBm25FieldName, readonly string[]> {\n117:   return {\n118:     name: [skill.id.replace(/-/g, ' '), skill.name],\n119:     keywords: skill.keywords,\n120:     domains: skill.domains,\n121:     intentSignals: skill.intentSignals,\n122:     derivedTriggers: skill.derivedTriggers,\n123:     description: [skill.description],\n124:   };\n125: }\n126: \n127: function fieldTermFrequencies(skill: SkillProjection): Map<string, FieldTermFrequency> {\n128:   const frequencies = new Map<string, FieldTermFrequency>();\n129:   for (const fieldName of BM25F_FIELD_NAMES) {\n130:     for (const value of skillFields(skill)[fieldName]) {\n131:       for (const token of tokenize(value)) {\n132:         let frequency = frequencies.get(token);\n133:         if (!frequency) {\n134:           frequency = emptyFieldFrequency();\n135:           frequencies.set(token, frequency);\n136:         }\n137:         frequency.total += 1;\n138:         frequency.fields[fieldName] += 1;\n139:       }\n140:     }\n141:   }\n142:   return frequencies;\n143: }\n144: \n145: function weightedFrequency(\n146:   postings: PackedPostingList,\n147:   index: number,\n148:   weights: AdvisorBm25FieldWeights,\n149: ): number {\n150:   return postings.nameTfs[index] * weights.name\n151:     + postings.keywordTfs[index] * weights.keywords\n152:     + postings.domainTfs[index] * weights.domains\n153:     + postings.intentSignalTfs[index] * weights.intentSignals\n154:     + postings.derivedTriggerTfs[index] * weights.derivedTriggers\n155:     + postings.descriptionTfs[index] * weights.description;\n156: }\n157: \n158: function topWeightedFields(\n159:   postings: PackedPostingList,\n160:   index: number,\n161:   weights: AdvisorBm25FieldWeights,\n162: ): AdvisorBm25FieldName[] {\n163:   return [\n164:     { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n165:     { field: 'keywords' as const, value: postings.keywordTfs[index] * weights.keywords },\n166:     { field: 'domains' as const, value: postings.domainTfs[index] * weights.domains },\n167:     { field: 'intentSignals' as const, value: postings.intentSignalTfs[index] * weights.intentSignals },\n168:     { field: 'derivedTriggers' as const, value: postings.derivedTriggerTfs[index] * weights.derivedTriggers },\n169:     { field: 'description' as const, value: postings.descriptionTfs[index] * weights.description },\n170:   ]\n171:     .filter((entry) => entry.value > 0)\n172:     .sort((left, right) => right.value - left.value)\n173:     .map((entry) => entry.field)\n174:     .slice(0, 3);\n175: }\n176: \n177: export class AdvisorPackedBm25Index {\n178:   private readonly skillIds: string[] = [];\n179:   private readonly skillNumbersById = new Map<string, number>();\n180:   private readonly documents = new Map<string, PackedSkillDocument>();\n181:   private readonly documentFreq = new Map<string, number>();\n182:   private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n183:   private readonly packedPostings = new Map<string, PackedPostingList>();\n184:   private totalDocumentLength = 0;\n185: \n186:   constructor(skills: readonly SkillProjection[] = []) {\n187:     for (const skill of skills) {\n188:       this.addSkill(skill);\n189:     }\n190:     this.finalize();\n191:   }\n192: \n193:   addSkill(skill: SkillProjection): void {\n194:     const frequencies = fieldTermFrequencies(skill);\n195:     const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n196:     if (length === 0) return;\n197: \n198:     const numericId = this.nextNumericId(skill.id);\n199:     const terms = [...frequencies.keys()].sort();\n200:     this.documents.set(skill.id, { numericId, skillId: skill.id, length, terms });\n201:     this.totalDocumentLength += length;\n202: \n203:     for (const term of terms) {\n204:       const frequency = frequencies.get(term);\n205:       if (!frequency) continue;\n206:       this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n207:       const postings = this.ensureMutablePostings(term);\n208:       postings.docIds.push(numericId);\n209:       postings.totalTfs.push(frequency.total);\n210:       postings.nameTfs.push(frequency.fields.name);\n211:       postings.keywordTfs.push(frequency.fields.keywords);\n212:       postings.domainTfs.push(frequency.fields.domains);\n213:       postings.intentSignalTfs.push(frequency.fields.intentSignals);\n214:       postings.derivedTriggerTfs.push(frequency.fields.derivedTriggers);\n215:       postings.descriptionTfs.push(frequency.fields.description);\n216:     }\n217:   }\n218: \n219:   finalize(): void {\n220:     for (const [term, postings] of this.mutablePostings.entries()) {\n221:       const order = postings.docIds.map((docId, index) => ({ docId, index }))\n222:         .sort((left, right) => left.docId - right.docId);\n223:       this.packedPostings.set(term, {\n224:         docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n225:         totalTfs: Uint32Array.from(order.map((entry) => postings.totalTfs[entry.index])),\n226:         nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n227:         keywordTfs: Uint32Array.from(order.map((entry) => postings.keywordTfs[entry.index])),\n228:         domainTfs: Uint32Array.from(order.map((entry) => postings.domainTfs[entry.index])),\n229:         intentSignalTfs: Uint32Array.from(order.map((entry) => postings.intentSignalTfs[entry.index])),\n230:         derivedTriggerTfs: Uint32Array.from(order.map((entry) => postings.derivedTriggerTfs[entry.index])),\n231:         descriptionTfs: Uint32Array.from(order.map((entry) => postings.descriptionTfs[entry.index])),\n232:       });\n233:     }\n234:     this.mutablePostings.clear();\n235:   }\n236: \n237:   search(prompt: string, options: AdvisorBm25SearchOptions = {}): AdvisorBm25Match[] {\n238:     const queryTerms = [...new Set(tokenize(prompt))];\n239:     if (queryTerms.length === 0 || this.documents.size === 0) return [];\n240: \n241:     const weights = resolveFieldWeights(options.fieldWeights);\n242:     const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n243:     const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n244: \n245:     for (const term of queryTerms) {\n246:       const postings = this.packedPostings.get(term);\n247:       if (!postings) continue;\n248:       const idf = this.idf(term);\n249:       for (let i = 0; i < postings.docIds.length; i += 1) {\n250:         const numericId = postings.docIds[i];\n251:         const skillId = this.skillIds[numericId];\n252:         const doc = skillId ? this.documents.get(skillId) : undefined;\n253:         if (!doc) continue;\n254:         const weightedTf = weightedFrequency(postings, i, weights);\n255:         if (weightedTf <= 0) continue;\n256: \n257:         const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n258:           / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (doc.length / averageLength))));\n259:         const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n260:         existing.rawScore += termScore;\n261:         if (existing.evidence.length < 6) {\n262:           existing.evidence.push(`bm25:${term}`);\n263:           for (const field of topWeightedFields(postings, i, weights)) {\n264:             if (existing.evidence.length >= 6) break;\n265:             existing.evidence.push(`field:${field}`);\n266:           }\n267:         }\n268:         scores.set(numericId, existing);\n269:       }\n270:     }\n271: \n272:     return [...scores.entries()]\n273:       .map(([numericId, result]) => ({\n274:         skillId: this.skillIds[numericId],\n275:         lane: ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID,\n276:         rawScore: Number(result.rawScore.toFixed(6)),\n277:         score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n278:         evidence: result.evidence,\n279:         shadowOnly: true,\n280:       } satisfies AdvisorBm25Match))\n281:       .filter((match) => typeof match.skillId === 'string' && match.score > 0)\n282:       .sort((left, right) => right.score - left.score || left.skillId.localeCompare(right.skillId))\n283:       .slice(0, options.limit ?? DEFAULT_LIMIT);\n284:   }\n285: \n286:   getFootprintStats(): AdvisorBm25FootprintStats {\n287:     let postingCount = 0;\n288:     let typedArrayBytes = 0;\n289:     for (const postings of this.packedPostings.values()) {\n290:       postingCount += postings.docIds.length;\n291:       typedArrayBytes += postings.docIds.byteLength\n292:         + postings.totalTfs.byteLength\n293:         + postings.nameTfs.byteLength\n294:         + postings.keywordTfs.byteLength\n295:         + postings.domainTfs.byteLength\n296:         + postings.intentSignalTfs.byteLength\n297:         + postings.derivedTriggerTfs.byteLength\n298:         + postings.descriptionTfs.byteLength;\n299:     }\n300:     return {\n301:       documentCount: this.documents.size,\n302:       termCount: this.packedPostings.size,\n303:       postingCount,\n304:       typedArrayBytes,\n305:       mutablePostingCount: this.mutablePostings.size,\n306:     };\n307:   }\n308: \n309:   private nextNumericId(skillId: string): number {\n310:     const existing = this.skillNumbersById.get(skillId);\n311:     if (existing !== undefined) return existing;\n312:     const numericId = this.skillIds.length;\n313:     this.skillIds.push(skillId);\n314:     this.skillNumbersById.set(skillId, numericId);\n315:     return numericId;\n316:   }\n317: \n318:   private ensureMutablePostings(term: string): PackedPostingMutable {\n319:     const existing = this.mutablePostings.get(term);\n320:     if (existing) return existing;\n321:     const postings: PackedPostingMutable = {\n322:       docIds: [],\n323:       totalTfs: [],\n324:       nameTfs: [],\n325:       keywordTfs: [],\n326:       domainTfs: [],\n327:       intentSignalTfs: [],\n328:       derivedTriggerTfs: [],\n329:       descriptionTfs: [],\n330:     };\n331:     this.mutablePostings.set(term, postings);\n332:     return postings;\n333:   }\n334: \n335:   private idf(term: string): number {\n336:     const docFreq = this.documentFreq.get(term) ?? 0;\n337:     return Math.log(1 + (this.documents.size - docFreq + 0.5) / (docFreq + 0.5));\n338:   }\n339: }\n340: \n341: export function buildAdvisorBm25Index(projection: AdvisorProjection): AdvisorPackedBm25Index {\n342:   return new AdvisorPackedBm25Index(projection.skills);\n343: }\n344: \n345: export function scoreBm25LexicalShadowLane(\n346:   prompt: string,\n347:   projection: AdvisorProjection,\n348:   options: AdvisorBm25SearchOptions = {},\n349: ): AdvisorBm25Match[] {\n350:   return buildAdvisorBm25Index(projection).search(prompt, options);\n351: }\n\n(End of file - total 351 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Packed BM25F Lexical Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, SkillProjection } from '../types.js';\nimport { tokenize } from '../text.js';\n\nexport const ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID = 'bm25_lexical_shadow' as const;\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 20;\n\nconst BM25F_FIELD_NAMES = [\n  'name',\n  'keywords',\n  'domains',\n  'intentSignals',\n  'derivedTriggers',\n  'description',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Packed BM25F Lexical Shadow Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, SkillProjection } from '../types.js';\nimport { tokenize } from '../text.js';\n\nexport const ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID = 'bm25_lexical_shadow' as const;\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 20;\n\nconst BM25F_FIELD_NAMES = [\n  'name',\n  'keywords',\n  'domains',\n  'intentSignals',\n  'derivedTriggers',\n  'description',\n] as const;\n\nexport type AdvisorBm25FieldName = typeof BM25F_FIELD_NAMES[number];\nexport type AdvisorBm25FieldWeights = Record<AdvisorBm25FieldName, number>;\n\nexport const ADVISOR_BM25_FIELD_WEIGHTS: AdvisorBm25FieldWeights = {\n  name: 4.0,\n  keywords: 3.0,\n  domains: 2.2,\n  intentSignals: 2.4,\n  derivedTriggers: 1.8,\n  description: 1.0,\n};\n\nexport interface AdvisorBm25SearchOptions {\n  readonly fieldWeights?: Partial<AdvisorBm25FieldWeights>;\n  readonly limit?: number;\n}\n\nexport interface AdvisorBm25Match {\n  readonly skillId: string;\n  readonly lane: typeof ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID;\n  readonly score: number;\n  readonly rawScore: number;\n  readonly evidence: readonly string[];\n  readonly shadowOnly: true;\n}\n\nexport interface AdvisorBm25FootprintStats {\n  readonly documentCount: number;\n  readonly termCount: number;\n  readonly postingCount: number;\n  readonly typedArrayBytes: number;\n  readonly mutablePostingCount: number;\n}\n\ninterface FieldTermFrequency {\n  total: number;\n  fields: Record<AdvisorBm25FieldName, number>;\n}\n\ninterface PackedSkillDocument {\n  numericId: number;\n  skillId: string;\n  length: number;\n  terms: readonly string[];\n}\n\ninterface PackedPostingMutable {\n  docIds: number[];\n  totalTfs: number[];\n  nameTfs: number[];\n  keywordTfs: number[];\n  domainTfs: number[];\n  intentSignalTfs: number[];\n  derivedTriggerTfs: number[];\n  descriptionTfs: number[];\n}\n\ninterface PackedPostingList {\n  docIds: Uint32Array;\n  totalTfs: Uint32Array;\n  nameTfs: Uint32Array;\n  keywordTfs: Uint32Array;\n  domainTfs: Uint32Array;\n  intentSignalTfs: Uint32Array;\n  derivedTriggerTfs: Uint32Array;\n  descriptionTfs: Uint32Array;\n}\n\nfunction emptyFieldFrequency(): FieldTermFrequency {\n  return {\n    total: 0,\n    fields: {\n      name: 0,\n      keywords: 0,\n      domains: 0,\n      intentSignals: 0,\n      derivedTriggers: 0,\n      description: 0,\n    },\n  };\n}\n\nfunction resolveFieldWeights(overrides: Partial<AdvisorBm25FieldWeights> = {}): AdvisorBm25FieldWeights {\n  return {\n    name: overrides.name ?? ADVISOR_BM25_FIELD_WEIGHTS.name,\n    keywords: overrides.keywords ?? ADVISOR_BM25_FIELD_WEIGHTS.keywords,\n    domains: overrides.domains ?? ADVISOR_BM25_FIELD_WEIGHTS.domains,\n    intentSignals: overrides.intentSignals ?? ADVISOR_BM25_FIELD_WEIGHTS.intentSignals,\n    derivedTriggers: overrides.derivedTriggers ?? ADVISOR_BM25_FIELD_WEIGHTS.derivedTriggers,\n    description: overrides.description ?? ADVISOR_BM25_FIELD_WEIGHTS.description,\n  };\n}\n\nfunction skillFields(skill: SkillProjection): Record<AdvisorBm25FieldName, readonly string[]> {\n  return {\n    name: [skill.id.replace(/-/g, ' '), skill.name],\n    keywords: skill.keywords,\n    domains: skill.domains,\n    intentSignals: skill.intentSignals,\n    derivedTriggers: skill.derivedTriggers,\n    description: [skill.description],\n  };\n}\n\nfunction fieldTermFrequencies(skill: SkillProjection): Map<string, FieldTermFrequency> {\n  const frequencies = new Map<string, FieldTermFrequency>();\n  for (const fieldName of BM25F_FIELD_NAMES) {\n    for (const value of skillFields(skill)[fieldName]) {\n      for (const token of tokenize(value)) {\n        let frequency = frequencies.get(token);\n        if (!frequency) {\n          frequency = emptyFieldFrequency();\n          frequencies.set(token, frequency);\n        }\n        frequency.total += 1;\n        frequency.fields[fieldName] += 1;\n      }\n    }\n  }\n  return frequencies;\n}\n\nfunction weightedFrequency(\n  postings: PackedPostingList,\n  index: number,\n  weights: AdvisorBm25FieldWeights,\n): number {\n  return postings.nameTfs[index] * weights.name\n    + postings.keywordTfs[index] * weights.keywords\n    + postings.domainTfs[index] * weights.domains\n    + postings.intentSignalTfs[index] * weights.intentSignals\n    + postings.derivedTriggerTfs[index] * weights.derivedTriggers\n    + postings.descriptionTfs[index] * weights.description;\n}\n\nfunction topWeightedFields(\n  postings: PackedPostingList,\n  index: number,\n  weights: AdvisorBm25FieldWeights,\n): AdvisorBm25FieldName[] {\n  return [\n    { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n    { field: 'keywords' as const, value: postings.keywordTfs[index] * weights.keywords },\n    { field: 'domains' as const, value: postings.domainTfs[index] * weights.domains },\n    { field: 'intentSignals' as const, value: postings.intentSignalTfs[index] * weights.intentSignals },\n    { field: 'derivedTriggers' as const, value: postings.derivedTriggerTfs[index] * weights.derivedTriggers },\n    { field: 'description' as const, value: postings.descriptionTfs[index] * weights.description },\n  ]\n    .filter((entry) => entry.value > 0)\n    .sort((left, right) => right.value - left.value)\n    .map((entry) => entry.field)\n    .slice(0, 3);\n}\n\nexport class AdvisorPackedBm25Index {\n  private readonly skillIds: string[] = [];\n  private readonly skillNumbersById = new Map<string, number>();\n  private readonly documents = new Map<string, PackedSkillDocument>();\n  private readonly documentFreq = new Map<string, number>();\n  private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n  private readonly packedPostings = new Map<string, PackedPostingList>();\n  private totalDocumentLength = 0;\n\n  constructor(skills: readonly SkillProjection[] = []) {\n    for (const skill of skills) {\n      this.addSkill(skill);\n    }\n    this.finalize();\n  }\n\n  addSkill(skill: SkillProjection): void {\n    const frequencies = fieldTermFrequencies(skill);\n    const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n    if (length === 0) return;\n\n    const numericId = this.nextNumericId(skill.id);\n    const terms = [...frequencies.keys()].sort();\n    this.documents.set(skill.id, { numericId, skillId: skill.id, length, terms });\n    this.totalDocumentLength += length;\n\n    for (const term of terms) {\n      const frequency = frequencies.get(term);\n      if (!frequency) continue;\n      this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n      const postings = this.ensureMutablePostings(term);\n      postings.docIds.push(numericId);\n      postings.totalTfs.push(frequency.total);\n      postings.nameTfs.push(frequency.fields.name);\n      postings.keywordTfs.push(frequency.fields.keywords);\n      postings.domainTfs.push(frequency.fields.domains);\n      postings.intentSignalTfs.push(frequency.fields.intentSignals);\n      postings.derivedTriggerTfs.push(frequency.fields.derivedTriggers);\n      postings.descriptionTfs.push(frequency.fields.description);\n    }\n  }\n\n  finalize(): void {\n    for (const [term, postings] of this.mutablePostings.entries()) {\n      const order = postings.docIds.map((docId, index) => ({ docId, index }))\n        .sort((left, right) => left.docId - right.docId);\n      this.packedPostings.set(term, {\n        docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n        totalTfs: Uint32Array.from(order.map((entry) => postings.totalTfs[entry.index])),\n        nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n        keywordTfs: Uint32Array.from(order.map((entry) => postings.keywordTfs[entry.index])),\n        domainTfs: Uint32Array.from(order.map((entry) => postings.domainTfs[entry.index])),\n        intentSignalTfs: Uint32Array.from(order.map((entry) => postings.intentSignalTfs[entry.index])),\n        derivedTriggerTfs: Uint32Array.from(order.map((entry) => postings.derivedTriggerTfs[entry.index])),\n        descriptionTfs: Uint32Array.from(order.map((entry) => postings.descriptionTfs[entry.index])),\n      });\n    }\n    this.mutablePostings.clear();\n  }\n\n  search(prompt: string, options: AdvisorBm25SearchOptions = {}): AdvisorBm25Match[] {\n    const queryTerms = [...new Set(tokenize(prompt))];\n    if (queryTerms.length === 0 || this.documents.size === 0) return [];\n\n    const weights = resolveFieldWeights(options.fieldWeights);\n    const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n    const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n\n    for (const term of queryTerms) {\n      const postings = this.packedPostings.get(term);\n      if (!postings) continue;\n      const idf = this.idf(term);\n      for (let i = 0; i < postings.docIds.length; i += 1) {\n        const numericId = postings.docIds[i];\n        const skillId = this.skillIds[numericId];\n        const doc = skillId ? this.documents.get(skillId) : undefined;\n        if (!doc) continue;\n        const weightedTf = weightedFrequency(postings, i, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n          / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (doc.length / averageLength))));\n        const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n        existing.rawScore += termScore;\n        if (existing.evidence.length < 6) {\n          existing.evidence.push(`bm25:${term}`);\n          for (const field of topWeightedFields(postings, i, weights)) {\n            if (existing.evidence.length >= 6) break;\n            existing.evidence.push(`field:${field}`);\n          }\n        }\n        scores.set(numericId, existing);\n      }\n    }\n\n    return [...scores.entries()]\n      .map(([numericId, result]) => ({\n        skillId: this.skillIds[numericId],\n        lane: ADVISOR_BM25_LEXICAL_SHADOW_LANE_ID,\n        rawScore: Number(result.rawScore.toFixed(6)),\n        score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n        evidence: result.evidence,\n        shadowOnly: true,\n      } satisfies AdvisorBm25Match))\n      .filter((match) => typeof match.skillId === 'string' && match.score > 0)\n      .sort((left, right) => right.score - left.score || left.skillId.localeCompare(right.skillId))\n      .slice(0, options.limit ?? DEFAULT_LIMIT);\n  }\n\n  getFootprintStats(): AdvisorBm25FootprintStats {\n    let postingCount = 0;\n    let typedArrayBytes = 0;\n    for (const postings of this.packedPostings.values()) {\n      postingCount += postings.docIds.length;\n      typedArrayBytes += postings.docIds.byteLength\n        + postings.totalTfs.byteLength\n        + postings.nameTfs.byteLength\n        + postings.keywordTfs.byteLength\n        + postings.domainTfs.byteLength\n        + postings.intentSignalTfs.byteLength\n        + postings.derivedTriggerTfs.byteLength\n        + postings.descriptionTfs.byteLength;\n    }\n    return {\n      documentCount: this.documents.size,\n      termCount: this.packedPostings.size,\n      postingCount,\n      typedArrayBytes,\n      mutablePostingCount: this.mutablePostings.size,\n    };\n  }\n\n  private nextNumericId(skillId: string): number {\n    const existing = this.skillNumbersById.get(skillId);\n    if (existing !== undefined) return existing;\n    const numericId = this.skillIds.length;\n    this.skillIds.push(skillId);\n    this.skillNumbersById.set(skillId, numericId);\n    return numericId;\n  }\n\n  private ensureMutablePostings(term: string): PackedPostingMutable {\n    const existing = this.mutablePostings.get(term);\n    if (existing) return existing;\n    const postings: PackedPostingMutable = {\n      docIds: [],\n      totalTfs: [],\n      nameTfs: [],\n      keywordTfs: [],\n      domainTfs: [],\n      intentSignalTfs: [],\n      derivedTriggerTfs: [],\n      descriptionTfs: [],\n    };\n    this.mutablePostings.set(term, postings);\n    return postings;\n  }\n\n  private idf(term: string): number {\n    const docFreq = this.documentFreq.get(term) ?? 0;\n    return Math.log(1 + (this.documents.size - docFreq + 0.5) / (docFreq + 0.5));\n  }\n}\n\nexport function buildAdvisorBm25Index(projection: AdvisorProjection): AdvisorPackedBm25Index {\n  return new AdvisorPackedBm25Index(projection.skills);\n}\n\nexport function scoreBm25LexicalShadowLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  options: AdvisorBm25SearchOptions = {},\n): AdvisorBm25Match[] {\n  return buildAdvisorBm25Index(projection).search(prompt, options);\n}","lineStart":1,"lineEnd":351,"totalLines":351,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/bm25.ts","time":{"start":1781128856834,"end":1781128856840}},"metadata":{"openai":{"itemId":"fc_058a63936a7aba6a016a29de98bda48191a4cc001d090afe26"}},"id":"prt_eb38d84f7001AyGkwSjsjk3by8","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d5ab90010oj5ax5ezt1Mr1"}}
{"type":"tool_use","timestamp":1781128856938,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_aNdgQglKSEVule3DCwXOMrpw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Lexical Lane\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorProjection, LaneMatch } from '../types.js';\n6: import { matchesPhraseBoundary, scoreTokenOverlap, tokenize } from '../text.js';\n7: import { scoreBm25LexicalShadowLane, type AdvisorBm25Match } from './bm25.js';\n8: \n9: const SYNONYMS: Readonly<Record<string, readonly string[]>> = {\n10:   branch: ['git', 'worktree', 'merge'],\n11:   commit: ['git', 'changes'],\n12:   context: ['memory', 'session', 'save'],\n13:   docs: ['documentation', 'readme', 'markdown'],\n14:   document: ['documentation', 'markdown'],\n15:   find: ['search', 'locate'],\n16:   fix: ['debug', 'correct', 'patch'],\n17:   prompt: ['improve', 'enhance', 'optimize'],\n18:   review: ['audit', 'findings', 'regression'],\n19:   save: ['memory', 'context', 'preserve'],\n20:   search: ['find', 'locate', 'semantic'],\n21:   spec: ['plan', 'packet', 'tasks', 'checklist'],\n22:   test: ['vitest', 'verify'],\n23:   write: ['create', 'generate', 'documentation'],\n24: };\n25: \n26: const CATEGORY_HINTS: Readonly<Record<string, readonly string[]>> = {\n27:   'sk-doc': ['readme', 'feature catalog', 'playbook', 'taxonomy', 'documentation', 'docs', 'manual testing'],\n28:   'system-spec-kit': ['spec folder', 'packet', 'plan', 'tasks', 'checklist', 'memory save', 'handover', 'implementation summary', 'corpus'],\n29:   'sk-code-review': ['review', 'audit', 'findings', 'regression', 'drift', 'readiness', 'false positives'],\n30:   'system-code-graph': ['code graph', 'structural search', 'grep not enough', 'find code', 'where logic'],\n31:   'deep-research': ['deep research', 'research loop', 'overnight research', 'delta record', 'state log', 'lineage'],\n32:   'deep-review': ['deep review', 'review loop', 'release readiness', 'canonical jsonl', 'convergence tracked', 'iterative review', 'iterative review loop', 'spec folder audit', 'iterative audit', 'multi-pass review', 'review iteration', 'convergence detection', 'review packet', 'spec folder review'],\n33:   'deep-ai-council': ['deep ai council', 'ai council', 'planning council', 'council deliberation', 'multi-seat planning', 'ai-council artifacts', 'persist council artifacts', 'multi-ai-council'],\n34:   'mcp-chrome-devtools': ['chrome devtools', 'har', 'console errors', 'staging'],\n35:   'sk-prompt': ['better prompt', 'cleaner prompt', 'prompt package', 'system prompt', 'prompt variant'],\n36:   'sk-git': ['git worktree', 'experiment branch', 'clean branch'],\n37:   'sk-code': ['css', 'html', 'javascript', 'browser', 'frontend', 'layout', 'viewport', 'responsive', 'mobile', 'cdn', 'opencode', 'classifier', 'helper', 'fixture', 'vitest', 'commonjs', 'typescript', 'python', 'script', 'mcp json', 'gate3 baseline'],\n38: };\n39: \n40: const BM25_SHADOW_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'shadow', 'experimental']);\n41: \n42: export function isBm25LexicalShadowEnabled(): boolean {\n43:   const value = process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW?.trim().toLowerCase();\n44:   return value ? BM25_SHADOW_ENABLED_VALUES.has(value) : false;\n45: }\n46: \n47: function expandedTokens(prompt: string): string[] {\n48:   const tokens = tokenize(prompt);\n49:   const expanded = new Set(tokens);\n50:   for (const token of tokens) {\n51:     for (const synonym of SYNONYMS[token] ?? []) {\n52:       expanded.add(synonym);\n53:     }\n54:   }\n55:   return [...expanded];\n56: }\n57: \n58: export function scoreLexicalLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n59:   const lower = prompt.toLowerCase();\n60:   const tokens = expandedTokens(prompt);\n61:   const matches: LaneMatch[] = [];\n62: \n63:   for (const skill of projection.skills) {\n64:     const evidence: string[] = [];\n65:     let score = scoreTokenOverlap(tokens, [\n66:       skill.id.replace(/-/g, ' '),\n67:       skill.name,\n68:       skill.description,\n69:       ...skill.domains,\n70:       ...skill.intentSignals,\n71:       ...skill.keywords,\n72:     ]);\n73: \n74:     for (const hint of CATEGORY_HINTS[skill.id] ?? []) {\n75:       if (matchesPhraseBoundary(lower, hint)) {\n76:         score += 0.38;\n77:         evidence.push(`hint:${hint}`);\n78:       }\n79:     }\n80: \n81:     const tokenHits = tokens.filter((token) => {\n82:       const haystack = `${skill.id} ${skill.name} ${skill.description} ${skill.domains.join(' ')}`.toLowerCase();\n83:       return haystack.includes(token);\n84:     }).slice(0, 5);\n85:     evidence.push(...tokenHits.map((token) => `token:${token}`));\n86: \n87:     if (score <= 0.05) continue;\n88:     matches.push({\n89:       skillId: skill.id,\n90:       lane: 'lexical',\n91:       score: Math.min(score, 1),\n92:       evidence: evidence.slice(0, 6),\n93:     });\n94:   }\n95: \n96:   return matches;\n97: }\n98: \n99: export function scoreLexicalShadowLanes(\n100:   prompt: string,\n101:   projection: AdvisorProjection,\n102: ): { lexical: LaneMatch[]; bm25: AdvisorBm25Match[] } {\n103:   const lexical = scoreLexicalLane(prompt, projection);\n104:   return {\n105:     lexical,\n106:     bm25: isBm25LexicalShadowEnabled() ? scoreBm25LexicalShadowLane(prompt, projection) : [],\n107:   };\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Lexical Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, scoreTokenOverlap, tokenize } from '../text.js';\nimport { scoreBm25LexicalShadowLane, type AdvisorBm25Match } from './bm25.js';\n\nconst SYNONYMS: Readonly<Record<string, readonly string[]>> = {\n  branch: ['git', 'worktree', 'merge'],\n  commit: ['git', 'changes'],\n  context: ['memory', 'session', 'save'],\n  docs: ['documentation', 'readme', 'markdown'],\n  document: ['documentation', 'markdown'],\n  find: ['search', 'locate'],\n  fix: ['debug', 'correct', 'patch'],\n  prompt: ['improve', 'enhance', 'optimize'],\n  review: ['audit', 'findings', 'regression'],\n  save: ['memory', 'context', 'preserve'],\n  search: ['find', 'locate', 'semantic'],","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Lexical Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, scoreTokenOverlap, tokenize } from '../text.js';\nimport { scoreBm25LexicalShadowLane, type AdvisorBm25Match } from './bm25.js';\n\nconst SYNONYMS: Readonly<Record<string, readonly string[]>> = {\n  branch: ['git', 'worktree', 'merge'],\n  commit: ['git', 'changes'],\n  context: ['memory', 'session', 'save'],\n  docs: ['documentation', 'readme', 'markdown'],\n  document: ['documentation', 'markdown'],\n  find: ['search', 'locate'],\n  fix: ['debug', 'correct', 'patch'],\n  prompt: ['improve', 'enhance', 'optimize'],\n  review: ['audit', 'findings', 'regression'],\n  save: ['memory', 'context', 'preserve'],\n  search: ['find', 'locate', 'semantic'],\n  spec: ['plan', 'packet', 'tasks', 'checklist'],\n  test: ['vitest', 'verify'],\n  write: ['create', 'generate', 'documentation'],\n};\n\nconst CATEGORY_HINTS: Readonly<Record<string, readonly string[]>> = {\n  'sk-doc': ['readme', 'feature catalog', 'playbook', 'taxonomy', 'documentation', 'docs', 'manual testing'],\n  'system-spec-kit': ['spec folder', 'packet', 'plan', 'tasks', 'checklist', 'memory save', 'handover', 'implementation summary', 'corpus'],\n  'sk-code-review': ['review', 'audit', 'findings', 'regression', 'drift', 'readiness', 'false positives'],\n  'system-code-graph': ['code graph', 'structural search', 'grep not enough', 'find code', 'where logic'],\n  'deep-research': ['deep research', 'research loop', 'overnight research', 'delta record', 'state log', 'lineage'],\n  'deep-review': ['deep review', 'review loop', 'release readiness', 'canonical jsonl', 'convergence tracked', 'iterative review', 'iterative review loop', 'spec folder audit', 'iterative audit', 'multi-pass review', 'review iteration', 'convergence detection', 'review packet', 'spec folder review'],\n  'deep-ai-council': ['deep ai council', 'ai council', 'planning council', 'council deliberation', 'multi-seat planning', 'ai-council artifacts', 'persist council artifacts', 'multi-ai-council'],\n  'mcp-chrome-devtools': ['chrome devtools', 'har', 'console errors', 'staging'],\n  'sk-prompt': ['better prompt', 'cleaner prompt', 'prompt package', 'system prompt', 'prompt variant'],\n  'sk-git': ['git worktree', 'experiment branch', 'clean branch'],\n  'sk-code': ['css', 'html', 'javascript', 'browser', 'frontend', 'layout', 'viewport', 'responsive', 'mobile', 'cdn', 'opencode', 'classifier', 'helper', 'fixture', 'vitest', 'commonjs', 'typescript', 'python', 'script', 'mcp json', 'gate3 baseline'],\n};\n\nconst BM25_SHADOW_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'shadow', 'experimental']);\n\nexport function isBm25LexicalShadowEnabled(): boolean {\n  const value = process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW?.trim().toLowerCase();\n  return value ? BM25_SHADOW_ENABLED_VALUES.has(value) : false;\n}\n\nfunction expandedTokens(prompt: string): string[] {\n  const tokens = tokenize(prompt);\n  const expanded = new Set(tokens);\n  for (const token of tokens) {\n    for (const synonym of SYNONYMS[token] ?? []) {\n      expanded.add(synonym);\n    }\n  }\n  return [...expanded];\n}\n\nexport function scoreLexicalLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {\n  const lower = prompt.toLowerCase();\n  const tokens = expandedTokens(prompt);\n  const matches: LaneMatch[] = [];\n\n  for (const skill of projection.skills) {\n    const evidence: string[] = [];\n    let score = scoreTokenOverlap(tokens, [\n      skill.id.replace(/-/g, ' '),\n      skill.name,\n      skill.description,\n      ...skill.domains,\n      ...skill.intentSignals,\n      ...skill.keywords,\n    ]);\n\n    for (const hint of CATEGORY_HINTS[skill.id] ?? []) {\n      if (matchesPhraseBoundary(lower, hint)) {\n        score += 0.38;\n        evidence.push(`hint:${hint}`);\n      }\n    }\n\n    const tokenHits = tokens.filter((token) => {\n      const haystack = `${skill.id} ${skill.name} ${skill.description} ${skill.domains.join(' ')}`.toLowerCase();\n      return haystack.includes(token);\n    }).slice(0, 5);\n    evidence.push(...tokenHits.map((token) => `token:${token}`));\n\n    if (score <= 0.05) continue;\n    matches.push({\n      skillId: skill.id,\n      lane: 'lexical',\n      score: Math.min(score, 1),\n      evidence: evidence.slice(0, 6),\n    });\n  }\n\n  return matches;\n}\n\nexport function scoreLexicalShadowLanes(\n  prompt: string,\n  projection: AdvisorProjection,\n): { lexical: LaneMatch[]; bm25: AdvisorBm25Match[] } {\n  const lexical = scoreLexicalLane(prompt, projection);\n  return {\n    lexical,\n    bm25: isBm25LexicalShadowEnabled() ? scoreBm25LexicalShadowLane(prompt, projection) : [],\n  };\n}","lineStart":1,"lineEnd":108,"totalLines":108,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/lexical.ts","time":{"start":1781128856933,"end":1781128856937}},"metadata":{"openai":{"itemId":"fc_058a63936a7aba6a016a29de98bda881919e149fce2799ad61"}},"id":"prt_eb38d8526001PEOxj2vqDSk8wC","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d5ab90010oj5ax5ezt1Mr1"}}
