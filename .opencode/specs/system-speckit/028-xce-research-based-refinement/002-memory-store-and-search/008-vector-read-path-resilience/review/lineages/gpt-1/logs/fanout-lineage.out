/sqlite-to-turso context-report.md and 004 - gap-alternatives.md section 2.\",\n    \"created_at\": \"2026-06-10T17:48:33Z\",\n    \"last_save_at\": \"2026-06-10T19:22:14.994Z\",\n    \"save_lineage\": \"graph_only\",\n    \"last_accessed_at\": null,\n    \"source_docs\": [\n      \"spec.md\",\n      \"plan.md\",\n      \"tasks.md\",\n      \"implementation-summary.md\"\n    ],\n    \"last_active_child_id\": null,\n    \"last_active_at\": null\n  }\n}","lineStart":1,"lineEnd":218,"totalLines":218,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/013-vector-read-path-resilience/graph-metadata.json","time":{"start":1781151284297,"end":1781151284306}},"metadata":{"openai":{"itemId":"fc_0b67ae4b62178722016a2a36343bec8191abafe250b65bae08"}},"id":"prt_eb4e3bc43001EVzdmgLgYQfD53","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3931d001UDRBzJeOHH19oH"}}
