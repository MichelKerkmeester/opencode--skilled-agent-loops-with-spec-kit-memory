.vitest.ts\",\n30:     \"test:council\": \"vitest run tests/multi-ai-council-runtime-parity.vitest.ts tests/multi-ai-council-permission-scope.vitest.ts tests/multi-ai-council-audit-trail.vitest.ts tests/multi-ai-council-rollback.vitest.ts ../../deep-loop-runtime/tests/integration/council-graph-script.vitest.ts ../../deep-loop-runtime/tests/integration/council-graph-value-scenarios.vitest.ts tests/council-playbook-anchor-integrity.vitest.ts tests/council-helpers-smoke.vitest.ts ../scripts/tests/multi-ai-council-persist-artifacts.vitest.ts skill_advisor/tests/scorer/native-scorer.vitest.ts\",\n31:     \"test:council:full\": \"bash ../scripts/test-council-matrix.sh\",\n32:     \"hook-tests\": \"node --import ../scripts/node_modules/tsx/dist/loader.mjs ../../../../specs/system-spec-kit/026-graph-and-context-optimization/000-release-and-program-cleanup/003-cross-cutting-cleanup-pass/016-runtime-hook-plugin-testing/runners/run-all-runtime-hooks.ts\",\n33:     \"stress\": \"vitest run --config vitest.stress.config.ts\",\n34:     \"stress:harness\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/search-quality\",\n35:     \"stress:matrix\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/matrix\",\n36:     \"stress:substrate\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/substrate\",\n37:     \"stress:durability\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/durability\",\n38:     \"test:task-enrichment\": \"echo 'Task-enrichment tests run in @spec-kit/scripts workspace'\",\n39:     \"test:hydra:phase1\": \"vitest run tests/memory-roadmap-flags.vitest.ts tests/memory-state-baseline.vitest.ts tests/migration-checkpoint-scripts.vitest.ts tests/vector-index-schema-compatibility.vitest.ts\",\n40:     \"test:watch\": \"vitest\",\n41:     \"bench:watcher\": \"node dist/skill_advisor/bench/watcher-benchmark.js\",\n42:     \"setup:codex-policy\": \"node dist/hooks/codex/setup.js\"\n43:   },