{
  "color": {
    "void": {
      "$value": "#0b0c0e",
      "$type": "color",
      "$description": "Void — Deepest page canvas, terminal background, behind everything"
    },
    "graphite": {
      "$value": "#131416",
      "$type": "color",
      "$description": "Graphite — Primary card surface, panels, elevated containers, table rows"
    },
    "charcoal": {
      "$value": "#1f1f21",
      "$type": "color",
      "$description": "Charcoal — Secondary surface, borders, dividers, rail backgrounds"
    },
    "smoke": {
      "$value": "#3c3d3e",
      "$type": "color",
      "$description": "Smoke — Button borders, subtle separators"
    },
    "steel": {
      "$value": "#71717a",
      "$type": "color",
      "$description": "Steel — Muted body text, captions, helper text, dimmed labels"
    },
    "fog": {
      "$value": "#858687",
      "$type": "color",
      "$description": "Fog — Secondary text, icon strokes, inactive nav items"
    },
    "ash": {
      "$value": "#9d9e9f",
      "$type": "color",
      "$description": "Ash — Tertiary text, placeholder text, disabled states"
    },
    "chalk": {
      "$value": "#cececf",
      "$type": "color",
      "$description": "Chalk — Body text secondary, table cell text"
    },
    "snow": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Snow — Primary headings, body text, icon fills, active states — the dominant ink at 413 occurrences"
    },
    "bone": {
      "$value": "#f2f2f2",
      "$type": "color",
      "$description": "Bone — Primary action button fill — off-white pill against dark creates the highest-contrast CTA without introducing a chromatic brand color"
    },
    "ink": {
      "$value": "#333333",
      "$type": "color",
      "$description": "Ink — Secondary body text, navigation labels, and subdued headings. Do not promote it to the primary CTA color"
    },
    "signal-blue": {
      "$value": "#3b82f6",
      "$type": "color",
      "$description": "Signal Blue — Brand accent — active nav indicators, link highlights, icon fills, active card borders. The one true chromatic color; used 21 times as fills, borders, and background tints"
    },
    "arc-blue": {
      "$value": "#60a5fa",
      "$type": "color",
      "$description": "Arc Blue — Light blue text accent, informational highlights, node icons in workflow diagrams"
    },
    "ring-blue": {
      "$value": "#93c5fd",
      "$type": "color",
      "$description": "Ring Blue — Focus rings, active card outline borders, selection state outlines at low alpha"
    },
    "mint": {
      "$value": "#4ade80",
      "$type": "color",
      "$description": "Mint — Green outline accent for tags, dividers, and focused UI edges. Use as a supporting accent, not as a status color"
    },
    "fern": {
      "$value": "#22c55e",
      "$type": "color",
      "$description": "Fern — Green wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Use as a supporting accent, not as a status color"
    },
    "coral": {
      "$value": "#f87171",
      "$type": "color",
      "$description": "Coral — Red text accent for links, tags, and emphasized short phrases. Use as a supporting accent, not as a status color"
    },
    "ember": {
      "$value": "#ea580c",
      "$type": "color",
      "$description": "Ember — Decorative icon accent — orange chromatic chip in product mockups"
    },
    "iris": {
      "$value": "#314ef0",
      "$type": "color",
      "$description": "Iris — Brand chip background tint in embedded mockups and product screenshots"
    }
  },
  "font": {
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Used for everything — display, body, UI, labels. The distinctive choice is weight 400 at 52–64px for headlines: most SaaS sites use 600–700, but Default's whisper-weight headlines feel more like a technical document or terminal readout than a marketing page. Fractional weights (420, 440, 450) are deployed at the 15–18px body range for fine-grained text density control. Font features ss01 and ss03 are enabled — these are Inter's stylistic alternates (single-storey 'a' and 'g' with closed tails) that give the type a more geometric, engineered feel."
    }
  },
