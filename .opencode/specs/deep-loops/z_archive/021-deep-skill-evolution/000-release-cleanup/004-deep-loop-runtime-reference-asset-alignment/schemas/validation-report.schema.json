{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validation-report.schema.json",
  "title": "Deep Skill Alignment Validation Report Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "phase",
    "target",
    "command",
    "status",
    "severity",
    "summary",
    "evidence",
    "recommended_fix"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^VAL-[0-9]{3}$" },
    "phase": { "type": "integer", "minimum": 1, "maximum": 9 },
    "target": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["pass", "fail", "blocked", "not_run"] },
    "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "none"] },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "string" },
    "recommended_fix": { "type": "string" }
  }
}
