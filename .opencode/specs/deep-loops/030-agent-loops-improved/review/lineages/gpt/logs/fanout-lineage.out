d ] && mv {spec_folder}/scratch/deep-review-strategy.md {state_paths.strategy}; [ -e {spec_folder}/scratch/deep-review-dashboard.md ] && mv {spec_folder}/scratch/deep-review-dashboard.md {state_paths.dashboard}; find {spec_folder}/scratch -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; ; [ -e {spec_folder}/scratch/.deep-research-pause ] && mv {spec_folder}/scratch/.deep-research-pause {state_paths.pause_sentinel}; [ -e {state_paths.legacy_root_report} ] && mv {state_paths.legacy_root_report} {state_paths.review_output}; if [ -e {state_paths.state_log} ]; then printf '%s\\n' '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"migration\\\",\\\"mode\\\":\\\"review\\\",\\\"legacyArtifacts\\\":[\\\"deep-research-config.json\\\",\\\"deep-research-state.jsonl\\\",\\\".deep-research-pause\\\"],\\\"canonicalArtifacts\\\":[\\\"deep-review-config.json\\\",\\\"deep-review-state.jsonl\\\",\\\".deep-review-pause\\\"],\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\"}' >> {state_paths.state_log}; fi; fi; find {state_paths.local_packet_dir} -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; 2>/dev/null || true\"\n\n  Line 274:           - \"{state_paths.findings_registry}\"\n\n  Line 287:           log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n\n  Line 288:           append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  Line 291:           action: \"Archive the current review packet under the root-level review_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n\n  Line 297:           append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  Line 359:           - review_dimensions_normalized: \"Canonical string[] for deep-review-config.json\"\n\n  Line 373:             session_id_init: \"{session_id}\"\n\n  Line 376:             session_id_init: \"{ISO_8601_NOW}\"\n\n  Line 379:         action: \"Create deep-review-config.json from template with review-specific fields\"\n\n  Line 384:           sessionId: \"{session_id_init}\"\n\n  Line 409:           createdAt: \"{ISO_8601_NOW}\"\n\n  Line 419:         content: '{\"type\":\"config\",\"mode\":\"review\",\"reviewTarget\":\"{review_target}\",\"reviewTargetType\":\"{review_target_type}\",\"reviewDimensions\":{review_dimensions_json},\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"sessionId\":\"{session_id_init}\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":{max_iterations},\"convergenceThreshold\":{convergence_threshold},\"stopPolicy\":\"{stop_policy}\",\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\"}'\n\n  Line 422:       step_create_findings_registry:\n\n  Line 424:         content: '{\"sessionId\":\"{session_id_init}\",\"generation\":1,\"lineageMode\":\"new\",\"openFindings\":[],\"resolvedFindings\":[],\"repeatedFindings\":[],\"dimensionCoverage\":{\"correctness\":false,\"security\":false,\"traceability\":false,\"maintainability\":false},\"findingsBySeverity\":{\"P0\":0,\"P1\":0,\"P2\":0},\"openFindingsCount\":0,\"resolvedFindingsCount\":0,\"convergenceScore\":0.0}'\n\n  Line 425:         output: \"{state_paths.findings_registry}\"\n\n  Line 451:         bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"revie