{"type":"tool_use","timestamp":1780373146175,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_g31cV5Nqo83oVJOW50vmFCAR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d4-ablation.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d4-ablation.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * d4-ablation.cjs — D4 usefulness ablation (APPROXIMATE).\n6:  *\n7:  * \"Does the skill actually help?\" measured as the quality delta between a\n8:  * skill-ON run and a skill-OFF run of the same scenario, graded by the existing\n9:  * Lane B grader (gradeD4).\n10:  *\n11:  * Honest constraint (validated in the Phase 0 spike): opencode has no clean\n12:  * single-skill suppression. Skill-OFF is APPROXIMATED with\n13:  * MK_SKILL_ADVISOR_HOOK_DISABLED=1 + a \"do not load any skill\" preamble, then\n14:  * verified by checking the skill was NOT loaded/read (else the pair is dropped\n15:  * as contaminated). D4 scores are stamped attribution:\"approximate\".\n16:  */\n17: \n18: const path = require('path');\n19: const { runDispatch, parseLiveResult, buildLiveDispatchPrompt } = require('./live-executor.cjs');\n20: const grader = require('../model-benchmark/scorer/grader/harness.cjs');\n21: \n22: function clamp01(x) { return Math.max(0, Math.min(1, Number.isFinite(x) ? x : 0)); }\n23: \n24: // skill-OFF prompt: answer from the model's own knowledge, no skill, no project\n25: // skill-file reads. Pairs with MK_SKILL_ADVISOR_HOOK_DISABLED=1.\n26: function buildSkillOffPrompt(scenario) {\n27:   return [\n28:     'Answer ONLY from your own knowledge. Do NOT load any skill and do NOT read project skill files.',\n29:     `Task: ${scenario.prompt || ''}`,\n30:     'Emit ONLY a fenced ```json code block: {\"surface\": \"...\", \"resources\": [\"...\"], \"assets\": [\"...\"], \"agent\": \"none\"}',\n31:   ].join('\\n');\n32: }\n33: \n34: /**\n35:  * Grade the on/off output pair into a normalized D4 usefulness score.\n36:  * Deterministic when graderMode is a mock mode. score in [0,1]: 0.5 = no delta,\n37:  * 1 = skill-on fully better, 0 = skill-off better (skill hurt).\n38:  */\n39: async function gradeAblation({ scenario, onText, offText, graderMode = 'mock', cacheDir }) {\n40:   const base = {\n41:     variant_hash: 'live', rubric_version: 'v1.0.0', grader_model_build_hash: 'na',\n42:     mode: graderMode,\n43:     mock_mode: graderMode.startsWith('mock-') ? graderMode.slice('mock-'.length) : 'default',\n44:     cache_dir: cacheDir,\n45:   };\n46:   const rubric = scenario.passCriteria || scenario.prompt || '';\n47:   const onG = await grader.gradeD4({ fixture: { id: `${scenario.scenarioId}#on`, rubric }, swe16_output_text: onText || '', ...base });\n48:   const offG = await grader.gradeD4({ fixture: { id: `${scenario.scenarioId}#off`, rubric }, swe16_output_text: offText || '', ...base });\n49:   const onScore = clamp01(onG.score);\n50:   const offScore = clamp01(offG.score);\n51:   const score = clamp01(0.5 + (onScore - offScore) / 2);\n52:   return { d4: { score, onScore, offScore, attribution: 'approximate', graderMode }, raw: { onG, offG } };\n53: }\n54: \n55: /**\n56:  * Full live ablation: two real dispatches (on/off) + grade. Spends API.\n57:  */\n58: async function runD4Ablation({ scenario, skillRoot, model, variant, graderMode = 'mock', cacheDir }) {\n59:   const dir = path.resolve(skillRoot, '..', '..', '..');\n60:   const skillId = path.basename(skillRoot || '');\n61: \n62:   const on = runDispatch({ prompt: buildLiveDispatchPrompt(scenario), dir, model, variant });\n63:   const off = runDispatch({ prompt: buildSkillOffPrompt(scenario), dir, model, variant, extraEnv: { MK_SKILL_ADVISOR_HOOK_DISABLED: '1' } });\n64:   if (on.status !== 0 || off.status !== 0) {\n65:     return { d4: { score: null, unscored: 'ablation dispatch failed', attribution: 'approximate' } };\n66:   }\n67:   const onParsed = parseLiveResult(on.stdout, { skillId });\n68:   const offParsed = parseLiveResult(off.stdout, { skillId });\n69: \n70:   // Contamination guard: skill-OFF must NOT have loaded/read the skill.\n71:   const offTouched = (offParsed.activation && offParsed.activation.activated)\n72:     || (offParsed.raw.observedReads || []).length > 0;\n73:   if (offTouched) {\n74:     return { d4: { score: null, unscored: 'skill-off contaminated (skill was loaded)', attribution: 'approximate' }, contaminated: true };\n75:   }\n76: \n77:   const graded = await gradeAblation({\n78:     scenario, onText: onParsed.raw.responseText, offText: offParsed.raw.responseText, graderMode, cacheDir,\n79:   });\n80:   return { ...graded, onActivated: !!(onParsed.activation && onParsed.activation.activated) };\n81: }\n82: \n83: module.exports = { runD4Ablation, gradeAblation, buildSkillOffPrompt, clamp01 };\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * d4-ablation.cjs — D4 usefulness ablation (APPROXIMATE).\n *\n * \"Does the skill actually help?\" measured as the quality delta between a\n * skill-ON run and a skill-OFF run of the same scenario, graded by the existing\n * Lane B grader (gradeD4).\n *\n * Honest constraint (validated in the Phase 0 spike): opencode has no clean\n * single-skill suppression. Skill-OFF is APPROXIMATED with\n * MK_SKILL_ADVISOR_HOOK_DISABLED=1 + a \"do not load any skill\" preamble, then\n * verified by checking the skill was NOT loaded/read (else the pair is dropped\n * as contaminated). D4 scores are stamped attribution:\"approximate\".\n */\n\nconst path = require('path');\nconst { runDispatch, parseLiveResult, buildLiveDispatchPrompt } = require('./live-executor.cjs');\nconst grader = require('../model-benchmark/scorer/grader/harness.cjs');","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/d4-ablation.cjs","time":{"start":1780373146156,"end":1780373146172}},"metadata":{"openai":{"itemId":"fc_044bb146de650edd016a1e569a18e08191b4e01a7e67d348d7"}},"id":"prt_e86824a03001etWzAlLFkktm8D","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e8681f487001mOVybiSFd3ZVfD"}}
{"type":"tool_use","timestamp":1780373146176,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_4aFCYaWfWFxf2vbM6IdJvxcO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * load-playbook-scenarios.cjs — corpus loader for Lane C.\n6:  *\n7:  * A skill's manual_testing_playbook is its authored, live-execution contract\n8:  * (\"Every scenario MUST be executed against the live skill — no mocks\"). It is\n9:  * a far better benchmark corpus than synthetic decontaminated fixtures: real\n10:  * prompts with real expected-routing gold. This module parses that playbook\n11:  * into one normalized scenario shape the orchestrator scores against.\n12:  *\n13:  * Two source shapes are supported:\n14:  *   1. The sk-code shape: a root index table (§ \"FEATURE CATALOG CROSS-REFERENCE\n15:  *      INDEX\") enumerating {id, per-feature file, critical}, plus per-feature\n16:  *      files carrying the exact prompt + expected references/assets + pass rules.\n17:  *   2. The sk-doc shape: per-scenario files whose YAML frontmatter carries\n18:  *      expected_intent / expected_resources (no root index table).\n19:  *\n20:  * Gold is captured AS AUTHORED. We deliberately do NOT assert that an expected\n21:  * path exists on disk — a stale expectation (e.g. a renamed reference) is a real\n22:  * finding the scorer should surface as router↔gold drift, not silently drop.\n23:  */\n24: \n25: const fs = require('fs');\n26: const path = require('path');\n27: \n28: const ID_RE = /\\b([A-Z]{2})-(\\d{3})\\b/;\n29: \n30: // classKind selects the executor: routing/advisor run via router-replay or live\n31: // cli-opencode; browser scenarios need a real browser (bdg) and are routed out\n32: // of the text executors.\n33: function classifyKind(scenarioId, category, expectedSurface, passCriteria) {\n34:   const cat = (category || '').toLowerCase();\n35:   const prefix = (ID_RE.exec(scenarioId || '') || [])[1] || '';\n36:   if (/motion|animation|browser|performance|visual|compositing|cross-browser/.test(cat)\n37:       || prefix === 'MR' || prefix === 'CB') {\n38:     return 'browser';\n39:   }\n40:   // A scenario that asserts an in-skill SURFACE is a routing test (the advisor\n41:   // check is just its precondition). Advisor-class is reserved for scenarios\n42:   // whose WHOLE test is skill selection — no surface — run as a skill_advisor.py\n43:   // probe (SA-*, and the sk-code-vs-sk-doc anti-pattern).\n44:   if (expectedSurface) return 'routing';\n45:   const pass = (passCriteria || '').toLowerCase();\n46:   if (prefix === 'SA' || /top-1\\s*(!=|==)|routes? .* to sk-doc|advisor (top-1|wins)/.test(pass)) {\n47:     return 'advisor';\n48:   }\n49:   return 'routing';\n50: }\n51: \n52: function readFileSafe(p) {\n53:   try { return fs.readFileSync(p, 'utf8'); } catch { return null; }\n54: }\n55: \n56: // Pull every `references/...` / `assets/...` markdown-ish path token out of a\n57: // text block, deduped, order-preserving. Tolerates backticks, bullets, and\n58: // trailing parentheticals like \"(when intent is X)\".\n59: function extractPaths(block) {\n60:   if (!block) return [];\n61:   const out = [];\n62:   const seen = new Set();\n63:   const re = /(?:references|assets)\\/[A-Za-z0-9_./-]+\\.[a-z]{1,4}/g;\n64:   let m;\n65:   while ((m = re.exec(block)) !== null) {\n66:     const p = m[0];\n67:     if (!seen.has(p)) { seen.add(p); out.push(p); }\n68:   }\n69:   return out;\n70: }\n71: \n72: // Grab the text between a `**Label**` marker and the next bold marker / heading.\n73: function sectionAfter(text, labelRe) {\n74:   const start = text.search(labelRe);\n75:   if (start === -1) return '';\n76:   const rest = text.slice(start);\n77:   const endRel = rest.slice(1).search(/\\n\\s*(?:\\*\\*[A-Z]|#{1,3}\\s|\\d+\\.\\s+[A-Z])/);\n78:   return endRel === -1 ? rest : rest.slice(0, endRel + 1);\n79: }\n80: \n81: function parsePromptBlock(text) {\n82:   // ```[lang]\\n<prompt>\\n``` after the prompt marker. Per-feature files vary:\n83:   // SD/LS/RD use \"**Exact prompt**\", CS use \"**Realistic user prompt**\".\n84:   const m = /\\*\\*(?:Exact prompt|Realistic user prompt)\\*\\*:?\\s*\\n+```[a-z]*\\n([\\s\\S]*?)\\n```/i.exec(text);\n85:   if (m) return m[1].trim();\n86:   // sk-doc / inline shape: \"Prompt: ...\" line.\n87:   const inline = /(?:^|\\n)\\s*(?:\\*\\*)?Prompt(?:\\*\\*)?:\\s*(.+)/i.exec(text);\n88:   return inline ? inline[1].trim() : null;\n89: }\n90: \n91: // The root §7-13 tables carry the \"Exact Prompt\" column for every scenario in a\n92: // uniform 9-column shape — the authoritative prompt source when a per-feature\n93: // file uses a non-standard marker or omits the fenced block.\n94: function parseRootScenarioTables(rootText) {\n95:   const map = {};\n96:   for (const line of rootText.split('\\n')) {\n97:     if (!/^\\|/.test(line)) continue;\n98:     const cells = line.split('|').map((c) => c.trim());\n99:     // Leading/trailing empties from the bounding pipes -> cells[1] is Feature ID.\n100:     const idCell = (cells[1] || '').replace(/`/g, '');\n101:     if (!/^[A-Z]{2}-\\d{3}$/.test(idCell)) continue;\n102:     if (cells.length < 9) continue; // not a §7-13 scenario row\n103:     const prompt = (cells[4] || '').replace(/^`|`$/g, '').trim();\n104:     map[idCell] = {\n105:       prompt: /multi-prompt battery|see per-feature/i.test(prompt) ? null : (prompt || null),\n106:       expectedSignals: cells[6] || null,\n107:       passCriteria: cells[8] || null,\n108:     };\n109:   }\n110:   return map;\n111: }\n112: \n113: function parseFeatureFile(absPath, scenarioId, category, critical, rootEntry) {\n114:   const text = readFileSafe(absPath);\n115:   if (!text) return null;\n116: \n117:   const fmId = (/title:\\s*[\"']?([A-Z]{2}-\\d{3})/.exec(text) || [])[1];\n118:   const id = scenarioId || fmId;\n119:   if (!id) return null;\n120: \n121:   const prompt = parsePromptBlock(text) || (rootEntry && rootEntry.prompt) || null;\n122:   // Per-feature files vary: \"- Surface: `WEBFLOW`\" (SD/LS) vs \"**Expected surface**: `WEBFLOW`\" (CS).\n123:   const surfaceM = /(?:Expected\\s+)?Surface\\*{0,2}:\\s*`?([A-Za-z_]+)`?/i.exec(text);\n124:   const subLangM = /Sub-language:\\s*`?([A-Za-z]+)`?/i.exec(text);\n125:   const refBlock = sectionAfter(text, /\\*\\*Expected references loaded\\*\\*/i);\n126:   const assetBlock = sectionAfter(text, /\\*\\*Expected assets loaded\\*\\*/i);\n127:   const passM = /###?\\s*Pass\\/Fail Criteria\\s*([\\s\\S]*?)(?:\\n###?\\s|\\n##\\s|$)/i.exec(text);\n128:   const passCriteria = (passM ? passM[1].trim() : null) || (rootEntry && rootEntry.passCriteria) || null;\n129: \n130:   const KNOWN_SURFACES = new Set(['WEBFLOW', 'OPENCODE', 'UNKNOWN', 'MOTION_DEV', 'NONE']);\n131:   const surfaceRaw = surfaceM ? surfaceM[1].toUpperCase() : null;\n132:   const expectedSurface = KNOWN_SURFACES.has(surfaceRaw) ? surfaceRaw : null;\n133:   const expectedResources = extractPaths(refBlock);\n134:   const expectedAssets = extractPaths(assetBlock);\n135: \n136:   // Negative activation: the skill should NOT route here (UNKNOWN surface,\n137:   // disambiguation expected, or advisor must pick another skill).\n138:   const lowerPass = (passCriteria || '').toLowerCase();\n139:   const negativeActivation = expectedSurface === 'UNKNOWN'\n140:     || /disambiguation|must not|asks? for clarification|top-1\\s*!=\\s*sk-code|routes? .* to sk-doc/.test(lowerPass)\n141:     || /\\bUNKNOWN\\b/.test(text.split('\\n').slice(0, 30).join('\\n'));\n142: \n143:   const classKind = classifyKind(id, category, expectedSurface, passCriteria);\n144: \n145:   return {\n146:     scenarioId: id,\n147:     category: category || null,\n148:     prompt: prompt || null,\n149:     classKind,\n150:     expectedSurface,\n151:     expectedSubLanguage: subLangM ? subLangM[1].toUpperCase() : null,\n152:     expectedIntent: null,\n153:     expectedResources,\n154:     expectedAssets,\n155:     passCriteria,\n156:     critical: !!critical,\n157:     negativeActivation,\n158:     source: { featureFile: path.relative(path.dirname(path.dirname(absPath)), absPath), shape: 'sk-code' },\n159:     parseWarnings: prompt ? [] : ['missing-exact-prompt'],\n160:   };\n161: }\n162: \n163: // Parse the root index table mapping id -> {category, featureFile, critical}.\n164: function parseRootIndex(rootText) {\n165:   const idx = [];\n166:   const secStart = rootText.search(/##\\s+\\d+\\.\\s+FEATURE CATALOG CROSS-REFERENCE INDEX/i);\n167:   const scope = secStart === -1 ? rootText : rootText.slice(secStart);\n168:   for (const line of scope.split('\\n')) {\n169:     // Row shape parsed below: | <category> | <AA-000> | `<feature-file>.md` | <Yes|No> |\n170:     const m = /^\\|\\s*([^|]+?)\\s*\\|\\s*([A-Z]{2}-\\d{3})\\s*\\|\\s*`?([^|`]+?\\.md)`?\\s*\\|\\s*(Yes|No)\\s*\\|/.exec(line);\n171:     if (m) {\n172:       idx.push({\n173:         categoryLabel: m[1].trim(),\n174:         scenarioId: m[2],\n175:         featureFile: m[3].trim(),\n176:         critical: /yes/i.test(m[4]),\n177:       });\n178:     }\n179:   }\n180:   return idx;\n181: }\n182: \n183: // sk-doc shape: walk per-scenario files, read YAML frontmatter gold.\n184: function loadYamlFrontmatterScenarios(playbookDir) {\n185:   const out = [];\n186:   const stack = [playbookDir];\n187:   while (stack.length) {\n188:     const cur = stack.pop();\n189:     let entries;\n190:     try { entries = fs.readdirSync(cur, { withFileTypes: true }); } catch { continue; }\n191:     for (const e of entries) {\n192:       const full = path.join(cur, e.name);\n193:       if (e.isDirectory()) { stack.push(full); continue; }\n194:       if (!e.isFile() || !/^\\d{3}-.*\\.md$/.test(e.name)) continue;\n195:       const text = readFileSafe(full);\n196:       if (!text) continue;\n197:       const fm = /^---\\n([\\s\\S]*?)\\n---/.exec(text);\n198:       if (!fm) continue;\n199:       const block = fm[1];\n200:       const idM = /(?:^|\\n)id:\\s*[\"']?([A-Za-z0-9-]+)/.exec(block);\n201:       const intentM = /expected_intent:\\s*[\"']?([A-Za-z_]+)/.exec(block);\n202:       const resM = /expected_resources:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/.exec(block);\n203:       const resources = resM ? extractPaths(resM[1]) : [];\n204:       const category = path.basename(cur);\n205:       const prompt = parsePromptBlock(text);\n206:       const id = idM ? idM[1] : e.name.replace(/\\.md$/, '');\n207:       out.push({\n208:         scenarioId: id,\n209:         category,\n210:         prompt: prompt || null,\n211:         classKind: classifyKind(id, category, null, intentM ? intentM[1] : ''),\n212:         expectedSurface: null,\n213:         expectedSubLanguage: null,\n214:         expectedIntent: intentM ? intentM[1] : null,\n215:         expectedResources: resources,\n216:         expectedAssets: [],\n217:         passCriteria: null,\n218:         critical: false,\n219:         negativeActivation: false,\n220:         source: { featureFile: path.relative(playbookDir, full), shape: 'sk-doc' },\n\n(Showing lines 1-220 of 271. Use offset=221 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * load-playbook-scenarios.cjs — corpus loader for Lane C.\n *\n * A skill's manual_testing_playbook is its authored, live-execution contract\n * (\"Every scenario MUST be executed against the live skill — no mocks\"). It is\n * a far better benchmark corpus than synthetic decontaminated fixtures: real\n * prompts with real expected-routing gold. This module parses that playbook\n * into one normalized scenario shape the orchestrator scores against.\n *\n * Two source shapes are supported:\n *   1. The sk-code shape: a root index table (§ \"FEATURE CATALOG CROSS-REFERENCE\n *      INDEX\") enumerating {id, per-feature file, critical}, plus per-feature\n *      files carrying the exact prompt + expected references/assets + pass rules.\n *   2. The sk-doc shape: per-scenario files whose YAML frontmatter carries\n *      expected_intent / expected_resources (no root index table).\n *\n * Gold is captured AS AUTHORED. We deliberately do NOT assert that an expected","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","time":{"start":1780373146160,"end":1780373146173}},"metadata":{"openai":{"itemId":"fc_044bb146de650edd016a1e569a18f0819193cd126d4bc8e0c1"}},"id":"prt_e86824a2d001spYepvQm3EUPAS","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e8681f487001mOVybiSFd3ZVfD"}}
{"type":"tool_use","timestamp":1780373146176,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_70yEa1J6WEMMTgn6Fd7aYofP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * score-skill-benchmark.cjs — compute Lane C dimensions for one scenario and\n6:  * aggregate across a scenario set.\n7:  *\n8:  * Mode A (router-replay, deterministic) scores the dimensions that need no live\n9:  * model: D1-intra (in-skill routing), D2 (unprompted discovery proxy), D3\n10:  * (efficiency proxy), D5 (structural connectivity, hard gate). D1-inter (advisor\n11:  * selection) and D4 (usefulness ablation) require live dispatch / the advisor\n12:  * scorer and are reported as unscored in Mode A rather than faked — the\n13:  * aggregate is normalized over the dimensions actually measured so a Mode A\n14:  * score is honest about its coverage.\n15:  *\n16:  * Converged point weights (for reference / live mode): D1=25 (inter12+intra13),\n17:  * D2=20, D3=15, D4=25, D5=15 (gate).\n18:  */\n19: \n20: const { scoreD1Inter } = require('./advisor-probe.cjs');\n21: \n22: const WEIGHTS = { d1inter: 12, d1intra: 13, d2: 20, d3: 15, d4: 25, d5: 15 };\n23: \n24: function setRecall(expected, actual) {\n25:   if (!expected || expected.length === 0) return null; // not applicable\n26:   const have = new Set(actual || []);\n27:   const hit = expected.filter((e) => have.has(e)).length;\n28:   return hit / expected.length;\n29: }\n30: \n31: /**\n32:  * Score a single scenario from its router-replay result joined with private gold.\n33:  * @returns {{ scenarioId, dims, firstFailingStage, modeAScore, applicable }}\n34:  */\n35: function scoreScenario(arg) {\n36:   let { scenarioId, tier, routerResult, expected, advisorResult } = arg;\n37:   // Back-compat adapter. Legacy callers pass {routerResult, expected}; the\n38:   // playbook/live path passes {scenario, observed, traceMode}. Normalize the new\n39:   // shape onto the legacy locals so the scoring body stays shared (and the\n40:   // existing unit tests keep exercising it unchanged).\n41:   let scenario = arg.scenario || null;\n42:   if (scenario && arg.observed) {\n43:     const obs = arg.observed;\n44:     scenarioId = scenario.scenarioId;\n45:     tier = scenario.tier || tier || (obs.mode === 'live' ? 'live' : 'playbook');\n46:     routerResult = {\n47:       parseable: obs.parseable !== false,\n48:       intents: obs.observedIntents || [],\n49:       resources: obs.observedResources || [],\n50:       missingResources: obs.missingResources || [],\n51:     };\n52:     expected = {\n53:       skillId: scenario.expectedSkillId || scenario.skillId || arg.skillId,\n54:       // Playbook gold is SURFACE + RESOURCES. Router intent keys are a different\n55:       // vocabulary, so intent-key recall applies only to intent-gold skills\n56:       // (sk-doc's expectedIntent); surface correctness is scored separately.\n57:       intentKeys: scenario.expectedIntent ? [scenario.expectedIntent] : [],\n58:       resources: scenario.expectedResources || [],\n59:       negativeActivation: scenario.negativeActivation === true,\n60:     };\n61:   }\n62:   // Surface correctness is meaningful only when an executor observed a surface\n63:   // (live mode); router mode leaves observedSurface null. Computed up front so a\n64:   // wrong observed surface can fail routing rather than passing on incidental\n65:   // resource overlap.\n66:   const obs = arg.observed || null;\n67:   const expectedSurface = scenario ? scenario.expectedSurface : undefined;\n68:   const observedSurface = obs ? (obs.observedSurface || null) : undefined;\n69:   const surfaceMatch = (expectedSurface && observedSurface)\n70:     ? (observedSurface === expectedSurface) : null;\n71: \n72:   const dims = {};\n73:   const negative = expected && expected.negativeActivation === true;\n74: \n75:   // D1-intra: did the in-skill router select the expected intents + resources?\n76:   const intentRecall = setRecall(expected && expected.intentKeys, routerResult.intents);\n77:   const resourceRecall = setRecall(expected && expected.resources, routerResult.resources);\n78:   if (negative) {\n79:     // For a should-not-activate scenario, routing nothing relevant is success.\n80:     const leakedExpected = (expected.resources || []).some((r) => routerResult.resources.includes(r));\n81:     dims.d1intra = { score: leakedExpected ? 0 : 1, intentRecall, resourceRecall, negative: true };\n82:   } else {\n83:     const ir = intentRecall == null ? 1 : intentRecall;\n84:     const rr = resourceRecall == null ? 1 : resourceRecall;\n85:     dims.d1intra = { score: 0.4 * ir + 0.6 * rr, intentRecall, resourceRecall, negative: false };\n86:   }\n87:   // Live-only: a wrong observed surface is a routing failure regardless of any\n88:   // incidental resource overlap, so cap D1-intra below the pass line.\n89:   if (surfaceMatch === false && !negative) {\n90:     dims.d1intra.surfaceMismatch = true;\n91:     dims.d1intra.score = Math.min(dims.d1intra.score, 0.25);\n92:   }\n93: \n94:   // D2 proxy (Mode A): recall of expected resources in the routed set. In live\n95:   // mode this is replaced by Hit@k/Recall@k/MRR over the observed load trace.\n96:   dims.d2 = {\n97:     score: negative ? (dims.d1intra.score) : (resourceRecall == null ? 1 : resourceRecall),\n98:     proxy: 'router-replay-recall',\n99:     note: 'Mode A proxy; live-mode replaces with observed-load Hit@k/Recall@k/MRR',\n100:   };\n101: \n102:   // D3 efficiency proxy (Mode A): penalize over-routing — resources routed that\n103:   // are not in the expected set are \"wasted loads\". Live mode uses tool-call /\n104:   // token cost to first expected resource.\n105:   const routed = routerResult.resources.length;\n106:   const wasted = expected && expected.resources\n107:     ? routerResult.resources.filter((r) => !expected.resources.includes(r)).length\n108:     : 0;\n109:   // For a negative scenario the \"expected\" resources are the ones that must NOT\n110:   // be routed, so the over-routing math inverts (routing them reads as zero\n111:   // waste). Couple D3 to the suppression outcome instead, mirroring D2.\n112:   dims.d3 = negative\n113:     ? { score: dims.d1intra.score, routedCount: routed, wastedCount: routed, proxy: 'negative-activation', note: 'negative scenario: D3 tracks the suppression outcome, not over-routing' }\n114:     : {\n115:         score: routed === 0 ? 1 : Math.max(0, 1 - wasted / routed),\n116:         routedCount: routed, wastedCount: wasted,\n117:         proxy: 'router-overload', note: 'Mode A proxy; live-mode replaces with calls/tokens-to-first-expected',\n118:       };\n119: \n120:   // D1-inter: scored deterministically when an advisor probe is supplied (the\n121:   // Python advisor reads the SQLite graph, no LLM), else left unscored.\n122:   if (advisorResult) {\n123:     const inter = scoreD1Inter({ advisorResult, expectedSkillId: expected && expected.skillId, negative });\n124:     dims.d1inter = inter.ok\n125:       ? { score: inter.score, rank: inter.rank, topSkill: inter.topSkill }\n126:       : { score: null, unscored: 'advisor probe failed', error: advisorResult.error };\n127:   } else {\n128:     dims.d1inter = { score: null, unscored: 'no advisor probe (run with --advisor-mode=python)' };\n129:   }\n130:   // D4 usefulness ablation: still needs live skill-on/off dispatch (follow-on).\n131:   dims.d4 = { score: null, unscored: 'requires skill-on/off ablation (live mode)' };\n132: \n133:   // First failing stage (funnel): advisor activate -> router parse -> intra -> discovery.\n134:   let firstFailingStage = null;\n135:   if (dims.d1inter.score !== null && dims.d1inter.score < 0.5) firstFailingStage = 'activated-inter';\n136:   else if (!routerResult.parseable) firstFailingStage = 'router-unparseable';\n137:   else if (surfaceMatch === false) firstFailingStage = 'surface-mismatch';\n138:   else if (dims.d1intra.score < 0.5) firstFailingStage = 'routed-intra';\n139:   else if (dims.d2.score < 0.5) firstFailingStage = 'discovered';\n140: \n141:   // Mode A scenario score: weight the measured dims, normalize over their weights.\n142:   // D1-inter joins the measured set only when an advisor probe produced a score.\n143:   const measured = [\n144:     [dims.d1intra.score, WEIGHTS.d1intra],\n145:     [dims.d2.score, WEIGHTS.d2],\n146:     [dims.d3.score, WEIGHTS.d3],\n147:   ];\n148:   if (dims.d1inter.score !== null) measured.push([dims.d1inter.score, WEIGHTS.d1inter]);\n149:   const wsum = measured.reduce((a, [, w]) => a + w, 0);\n150:   const modeAScore = Math.round((measured.reduce((a, [s, w]) => a + s * w, 0) / wsum) * 100);\n151: \n152:   // Trimmed live evidence so a live report is inspectable (what the model\n153:   // actually did) without bloating the JSON with full transcripts.\n154:   const liveEvidence = (obs && obs.raw) ? {\n155:     eventCount: obs.raw.eventCount,\n156:     activated: obs.activation ? obs.activation.activated : undefined,\n157:     toolCalls: (obs.raw.toolCalls || []).map((t) => t.tool),\n158:     observedReads: obs.raw.observedReads,\n159:     statedRoutingParsed: !!(obs.raw.stated && Object.keys(obs.raw.stated).length),\n160:     responseHead: (obs.raw.responseText || '').slice(0, 300),\n161:   } : undefined;\n162: \n163:   return {\n164:     scenarioId, tier, dims, firstFailingStage, modeAScore, applicable: true,\n165:     classKind: scenario ? scenario.classKind : undefined,\n166:     expectedSurface, observedSurface, surfaceMatch,\n167:     traceMode: arg.traceMode || (obs ? obs.mode : undefined),\n168:     liveEvidence,\n169:   };\n170: }\n171: \n172: /**\n173:  * A↔B divergence: the 122-research finding class — the router can reach a\n174:  * resource but the live model doesn't (the skill doesn't signpost it inline),\n175:  * or vice versa. Compared per scenario from a router observation and a live\n176:  * observation of the SAME scenario.\n177:  * @returns {{ scenarioId, resourceDelta:{onlyRouter:string[],onlyLive:string[]}, surfaceAgree:boolean|null, severity:string }}\n178:  */\n179: function computeDivergence({ scenarioId, routerObserved, liveObserved }) {\n180:   const rRefs = new Set((routerObserved && routerObserved.observedResources) || []);\n181:   const lRefs = new Set((liveObserved && liveObserved.observedResources) || []);\n182:   const onlyRouter = [...rRefs].filter((r) => !lRefs.has(r));\n183:   const onlyLive = [...lRefs].filter((r) => !rRefs.has(r));\n184:   const rSurface = routerObserved && routerObserved.observedSurface;\n185:   const lSurface = liveObserved && liveObserved.observedSurface;\n186:   const surfaceAgree = (rSurface && lSurface) ? (rSurface === lSurface) : null;\n187:   const delta = onlyRouter.length + onlyLive.length;\n188:   const severity = delta === 0 && surfaceAgree !== false ? 'none' : (delta > 4 || surfaceAgree === false ? 'high' : 'low');\n189:   return { scenarioId, resourceDelta: { onlyRouter, onlyLive }, surfaceAgree, severity };\n190: }\n191: \n192: /**\n193:  * Aggregate scenario rows + the D5 connectivity result into a report object.\n194:  */\n195: function aggregate({ skillId, skillRoot, scenarioRows, connectivity, traceMode, lintFindings, divergence }) {\n196:   const rows = scenarioRows.filter(Boolean);\n197:   const avg = (sel) => {\n198:     const vals = rows.map(sel).filter((v) => typeof v === 'number');\n199:     return vals.length ? Math.round(vals.reduce((a, b) => a + b, 0) / vals.length) : null;\n200:   };\n201:   // Per-classKind coverage. Browser scenarios are routed out of the text\n202:   // executors; routed-out rows enter neither the funnel nor the score average.\n203:   const coverage = { routing: 0, advisor: 0, browser: 0, routedOut: 0, scored: 0 };\n204:   for (const r of rows) {\n205:     const k = r.classKind || 'routing';\n206:     if (coverage[k] !== undefined) coverage[k] += 1;\n207:     if (r.routedOut) coverage.routedOut += 1;\n208:     else if (typeof r.modeAScore === 'number') coverage.scored += 1;\n209:   }\n210:   // Funnel attrition: count first-failing-stage occurrences (scored rows only).\n211:   const funnel = {};\n212:   for (const r of rows) {\n213:     if (r.routedOut) continue;\n214:     const stage = r.firstFailingStage || 'passed';\n215:     funnel[stage] = (funnel[stage] || 0) + 1;\n216:   }\n217:   const headlineBottleneck = Object.entries(funnel)\n218:     .filter(([k]) => k !== 'passed')\n219:     .sort((a, b) => b[1] - a[1])[0] || null;\n220: \n221:   const d5 = connectivity.score;\n222:   const aggregateScore = avg((r) => r.modeAScore);\n223:   // D1-inter is scored only when advisor probes ran; avg() returns null if no row\n224:   // carried a numeric D1-inter score, so the dimension self-reports its coverage.\n225:   const d1interAvg = avg((r) => (r.dims && r.dims.d1inter && typeof r.dims.d1inter.score === 'number'\n226:     ? Math.round(r.dims.d1inter.score * 100) : null));\n227:   const gateFailed = connectivity.gateFailed;\n228:   let verdict;\n229:   if (gateFailed) verdict = 'BLOCKED-BY-STRUCTURE';\n230:   else if (aggregateScore == null) verdict = 'NO-SCENARIOS';\n231:   else if (aggregateScore >= 80) verdict = 'PASS';\n232:   else if (aggregateScore >= 50) verdict = 'CONDITIONAL';\n233:   else verdict = 'FAIL';\n234: \n235:   // Bottlenecks: D5 findings + any scenario stage failures, ranked by severity.\n236:   const bottlenecks = [...connectivity.findings];\n237:   if (headlineBottleneck) {\n238:     bottlenecks.unshift({\n239:       class: 'funnel_attrition', severity: 'P1', stage: headlineBottleneck[0],\n240:       detail: `${headlineBottleneck[1]} scenario(s) first fail at stage '${headlineBottleneck[0]}'`,\n241:     });\n242:   }\n243: \n244:   return {\n245:     schemaVersion: 'skill-benchmark-report.v1',\n246:     status: 'skill-benchmark-complete',\n247:     mode: 'skill-benchmark',\n248:     scoringMethod: (traceMode || 'router') === 'live' ? 'mode-b-live' : 'mode-a-router-replay',\n249:     traceMode: traceMode || 'router',\n250:     targetSkill: { id: skillId, root: skillRoot },\n251:     verdict,\n252:     aggregateScore,\n253:     gate: { d5Score: d5, gateFailed, reason: gateFailed ? 'D5 structural hard-gate failure' : null },\n254:     dimensionScores: {\n255:       D1inter: d1interAvg === null\n256:         ? { points: WEIGHTS.d1inter, score: null, status: 'unscored-mode-a' }\n257:         : { points: WEIGHTS.d1inter, score: d1interAvg },\n258:       D1intra: { points: WEIGHTS.d1intra, score: avg((r) => (r.dims && r.dims.d1intra ? Math.round(r.dims.d1intra.score * 100) : null)) },\n259:       D2: { points: WEIGHTS.d2, score: avg((r) => (r.dims && r.dims.d2 ? Math.round(r.dims.d2.score * 100) : null)) },\n260:       D3: { points: WEIGHTS.d3, score: avg((r) => (r.dims && r.dims.d3 ? Math.round(r.dims.d3.score * 100) : null)) },\n\n(Showing lines 1-260 of 280. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * score-skill-benchmark.cjs — compute Lane C dimensions for one scenario and\n * aggregate across a scenario set.\n *\n * Mode A (router-replay, deterministic) scores the dimensions that need no live\n * model: D1-intra (in-skill routing), D2 (unprompted discovery proxy), D3\n * (efficiency proxy), D5 (structural connectivity, hard gate). D1-inter (advisor\n * selection) and D4 (usefulness ablation) require live dispatch / the advisor\n * scorer and are reported as unscored in Mode A rather than faked — the\n * aggregate is normalized over the dimensions actually measured so a Mode A\n * score is honest about its coverage.\n *\n * Converged point weights (for reference / live mode): D1=25 (inter12+intra13),\n * D2=20, D3=15, D4=25, D5=15 (gate).\n */\n\nconst { scoreD1Inter } = require('./advisor-probe.cjs');","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs","time":{"start":1780373146163,"end":1780373146175}},"metadata":{"openai":{"itemId":"fc_044bb146de650edd016a1e569a18f88191855b08d45f55950a"}},"id":"prt_e86824a310027Z8uiiffx4HaAc","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e8681f487001mOVybiSFd3ZVfD"}}
{"type":"tool_use","timestamp":1780373146244,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"glob","callID":"call_tDs7t9TpEWcYUAmA4dHg246I","state":{"status":"completed","input":{"pattern":".opencode/skills/sk-code/benchmark/**/*","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/router-final/skill-benchmark-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/router-final/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live-remediated/skill-benchmark-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live-remediated/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/README.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live-final/d4-ablation.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live-final/skill-benchmark-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live-final/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/live/skill-benchmark-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/full/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/full/skill-benchmark-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/after/skill-benchmark-report.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/after/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/fixtures/sk-code/sk-code-motion-002.private.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/fixtures/sk-code/sk-code-loadspeed-001.private.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/fixtures/sk-code/sk-code-motion-002.public.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/fixtures/sk-code/sk-code-loadspeed-001.public.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/baseline/d5-connectivity-detail.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/baseline/skill-benchmark-report.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/benchmark/baseline/skill-benchmark-report.md","metadata":{"count":21,"truncated":false},"title":"","time":{"start":1780373146166,"end":1780373146244}},"metadata":{"openai":{"itemId":"fc_044bb146de650edd016a1e569a18fc8191977ab1cf72405d4d"}},"id":"prt_e86824a34001cUMESqukcDspk6","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e8681f487001mOVybiSFd3ZVfD"}}
