 const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n959:   const stopPolicy = options.stopPolicy || 'convergence';\n960:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n961:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n962:     : hasIterationCap\n963:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n964:       : 'to legal convergence';\n965:   const params = [\n966:     `  spec_folder: ${specFolder}`,\n967:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n968:     `  session_id: ${sessionId}`,\n969:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n970:     `  loop_type: ${loopType}`,\n971:     `  config.stopPolicy: ${stopPolicy}`,\n972:   ];\n973:   if (researchTopic) {\n974:     // A research lineage's phase_init binds research_topic from this line. Without it a\n975:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n976:     // Review loops scope by spec_folder and intentionally pass no topic.\n977:     params.push(`  research_topic: ${researchTopic}`);\n978:   }\n979:   if (hasIterationCap) {\n980:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n981:   }\n982:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n983:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n984:   }\n985:   // Review lineages scope by spec_folder but the auto-workflow preflight\n986:   // still requires the same review setup bindings the native command path pre-binds.\n987:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n988:   // different setup contract than native lineages.\n989:   const setupBindings =\n990:     loopType === 'review'\n991:       ? [\n992:           ``,\n993:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n994:           `review_target: ${specFolder}`,\n995:           `review_target_type: spec-folder`,\n996:           `review_dimensions: all`,\n997:           `spec_folder: ${specFolder}`,\n998:           `execution_mode: AUTONOMOUS`,\n999:           `lineage_mode: auto`,\n1000:           ``,\n1001:         ]\n1002:       : [];\n1003:   return [\n1004:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1005:     ...detachedIntro,\n1006:     ``,\n1007:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1008:     ...params,\n1009:     ...setupBindings,\n1010:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1011:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1012:     `command; bind artifact_dir directly to the override value.`,\n1013:     ``,\n1014:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1015:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1016:     ``,\n1017:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1018:   ].join('\\n');\n1019: }\n1020: \n1021: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1022:   assertActiveFanoutLoopType(loopType);\n1023:   const maxIterations = lineage.iterations || 12;\n1024:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1025:   const stopPolicy = options.stopPolicy || 'convergence';\n1026:   const sessionId = options.sessionId || '';\n1027:   const args = [\n1028:     ':auto',\n1029:     JSON.stringify(specFolder),\n1030:     `--spec-folder=${specFolder}`,\n1031:     `--max-iterations=${maxIterations}`,\n1032:     `--convergence=${convergenceThreshold}`,\n1033:     `--stop-policy=${stopPolicy}`,\n1034:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1035:     '--lineage-mode=auto',\n1036:   ];\n1037:   if (loopType === 'research' && options.researchTopic) {\n1038:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1039:   }\n1040: \n1041:   return [\n1042:     args.join(' '),\n1043:     '',\n1044:     'PRE-BOUND SETUP ANSWERS:',\n1045:     `review_target: ${specFolder}`,\n1046:     'review_target_type: spec-folder',\n1047:     'review_dimensions: all',\n1048:     `spec_folder: ${specFolder}`,\n1049:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1050:     'execution_mode: AUTONOMOUS',\n1051:     'lineage_mode: auto',\n1052:     `maxIterations: ${maxIterations}`,\n1053:     `convergenceThreshold: ${convergenceThreshold}`,\n1054:     `stop_policy: ${stopPolicy}`,\n1055:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1056:   ].join('\\n');\n1057: }\n1058: \n1059: /**\n1060:  * Compute a generous timeout for a full lineage loop run.\n1061:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1062:  * We double it for safety and cap at 4 hours.\n1063:  */\n1064: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1065:   const iters = lineage.iterations || 12;\n1066:   const perIterSecs = lineage.timeoutSeconds || 900;\n1067:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1068:     ? ceilingHoursOverride * 60 * 60 * 1000\n1069:     : 4 * 60 * 60 * 1000;\n1070:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1071: }\n1072: \n1073: function normalizeProgressHeartbeatMs(seconds) {\n1074:   const value = Number(seconds);\n1075:   if (!Number.isFinite(value) || value <= 0) return 0;\n1076:   return Math.max(1, Math.floor(value * 1000));\n1077: }\n1078: \n1079: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n\n(Showing lines 930-1079 of 1871. Use offset=1080 to continue.)\n</content>","metadata":{"preview":"  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : 4 * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {","lineStart":930,"lineEnd":1079,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783487392026,"e