e || 0.5,\n1496:     ageString: format_age_string(memory.created_at ?? null),\n1497:     lastAccessString: format_age_string(\n1498:       typeof memory.last_accessed === 'number' ? new Date(memory.last_accessed).toISOString() : null\n1499:     ),\n1500:     content\n1501:   };\n1502: }\n1503: \n1504: /* ───────────────────────────────────────────────────────────────\n1505:    DATABASE INTEGRITY\n1506: ----------------------------------------------------------------*/\n1507: \n1508: // BUG-013 FIX: Added autoClean option for automatic orphan cleanup\n1509: /**\n1510:  * Verifies vector-index consistency and optional cleanup results.\n1511:  * @param options - Integrity verification options.\n1512:  * @returns The integrity summary.\n1513:  */\n1514: export function verify_integrity(\n1515:   options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n1516:   database: Database.Database = initialize_db(),\n1517: ): { totalMemories: number; totalVectors: number; orphanedVectors: number; missingVectors: number; orphanedFiles: Array<{ id: number; file_path: string; reason: string }>; orphanedChunks: number; isConsistent: boolean; cleaned?: { vectors: number; chunks: number; files: number } } {\n1518:   const { autoClean = false, cleanFiles = false } = options;\n1519:   const sqlite_vec = get_sqlite_vec_available();\n1520: \n1521:   const find_orphaned_vector_ids = () => {\n1522:     if (!sqlite_vec) {\n1523:       console.warn('[vector-index] find_orphaned_vector_ids: sqlite-vec not available');\n1524:       return [];\n1525:     }\n1526:     try {\n1527:       return (database.prepare(`\n1528: \t        SELECT v.rowid FROM ${activeVectorSchema('vec_memories')} v\n1529:         WHERE NOT EXISTS (SELECT 1 FROM memory_index m WHERE m.id = v.rowid)\n1530:       `).all() as Array<{ rowid: number }>).map((r) => r.rowid);\n1531:     } catch (e: unknown) {\n1532:       console.warn('[vector-index] Could not query orphaned vectors:', get_error_message(e));\n1533:       return [];\n1534:     }\n1535:   };\n1536: \n1537:   const orphaned_vector_ids = find_orphaned_vector_ids();\n1538:   const orphaned_vectors = orphaned_vector_ids.length;\n1539: \n1540:   let cleaned_vectors = 0;\n1541:   if (autoClean && orphaned_vectors > 0 && sqlite_vec) {\n1542:     logger.info(`Auto-cleaning ${orphaned_vectors} orphaned vectors...`);\n1543:     const delete_stmt = database.prepare(`DELETE FROM ${activeVectorSchema('vec_memories')} WHERE rowid = ?`);\n1544:     for (const rowid of orphaned_vector_ids) {\n1545:       try {\n1546:         delete_stmt.run(BigInt(rowid));\n1547:         cleaned_vectors++;\n1548:       } catch (e: unknown) {\n1549:         console.warn(`[vector-index] Failed to clean orphaned vector ${rowid}: ${get_error_message(e)}`);\n1550:       }\n1551:     }\n1552:     logger.info(`Cleaned ${cleaned_vectors} orphaned vectors`);\n1553:   }\n1554: \n1555:   // Guard vec_memories queries with sqlite_vec availability check.\n1556:   // When sqlite-vec is not loaded, the vec_memories table does not exist.\n1557:   const missing_vectors = sqlite_vec\n1558:     ? (database.prepare(`\n1559:         SELECT COUNT(*) as count FROM memory_index m\n1560:         WHERE m.embedding_status = 'success'\n1561: \t        AND NOT EXISTS (SELECT 1 FROM ${activeVectorSchema('vec_memories')} v WHERE v.rowid = m.id)\n1562:       `).get() as { count: number }).count\n1563:     : 0;\n1564: \n1565:   const total_memories = (database.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number }).count;\n1566:   const total_vectors = sqlite_vec\n1567:     ? (database.prepare(`SELECT COUNT(*) as count FROM ${activeVectorSchema('vec_memories')}`).get() as { count: number }).count\n1568:     : 0;\n1569: \n1570:   const check_orphaned_files = () => {\n1571:     const memories = database.prepare('SELECT id, file_path FROM memory_index').all() as Array<{ id: number; file_path?: string | null }>;\n1572:     const orphaned: Array<{ id: number; file_path: string; reason: string }> = [];\n1573: \n1574:     for (const memory of memories) {\n1575:       if (memory.file_path && !fs.existsSync(memory.file_path)) {\n1576:         orphaned.push({\n1577:           id: memory.id,\n1578:           file_path: memory.file_path,\n1579:           reason: 'File no longer exists on filesystem'\n1580:         });\n1581:       }\n1582:     }\n1583: \n1584:     return orphaned;\n1585:   };\n1586: \n1587:   const orphaned_files_pre = check_orphaned_files();\n1588:   let cleaned_files = 0;\n1589:   const cleaned_file_ids = new Set<number>();\n1590: \n1591:   if (autoClean && cleanFiles && orphaned_files_pre.length > 0) {\n1592:     logger.info(`Auto-cleaning ${orphaned_files_pre.length} orphaned file rows...`);\n1593:     for (const orphan of orphaned_files_pre) {\n1594:       try {\n1595:         const spec_folder = (database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?')\n1596:           .get(orphan.id) as { spec_folder: string | null } | undefined)?.spec_folder ?? null;\n1597:         const deleted = delete_memory_from_database(database, orphan.id);\n1598:         if (deleted) {\n1599:           cleaned_files++;\n1600:           cleaned_file_ids.add(orphan.id);\n1601:           try {\n1602:             recordHistory(orphan.id, 'DELETE', null, null, 'mcp:integrity_check_files', spec_folder);\n1603:           } catch (error: unknown) {\n1604:             logger.warn('Failed to record integrity-check-files delete history', {\n1605:               error: error instanceof Error ? error.message : String(error),\n1606:             });\n1607:           }\n1608:         }\n1609:       } catch (e: unknown) {\n\n(Showing lines 1460-1609 of 1706. Use offset=1610 to continue.)\n</content>","metadata":{"preview":"\n  if (!memory) return null;\n\n  let content = '';\n  try {\n    // Validate DB-stored file paths before reading\n    if (memory.file_path) {\n      const valid_path = validate_file_path_local(memory.file_path);\n      if