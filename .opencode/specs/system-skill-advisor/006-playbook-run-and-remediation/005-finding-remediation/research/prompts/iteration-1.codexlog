   247	    parser.add_argument("--max-command-bridge-fp-rate", type=float, default=0.05, help="Maximum command bridge FP rate on non-slash prompts.")
   248	    parser.add_argument("--min-p0-pass-rate", type=float, default=1.0, help="Minimum P0 pass rate.")
   249	    parser.add_argument("--mode", choices=["both", "default", "confidence-only"], default="both", help="Which dataset cases to execute by mode.")
   250	    parser.add_argument("--runner", choices=["both", "inprocess", "subprocess"], default="both", help="Advisor execution path to exercise.")
