2:       }\n23:     ],\n24:     \"argumentGrammar\": {\n25:       \"positional\": [\n26:         { \"name\": \"target\", \"required\": true, \"kind\": \"design-target\" }\n27:       ],\n28:       \"flags\": [\n29:         { \"name\": \"--scope\", \"required\": false, \"takesValue\": true, \"valueName\": \"scope\", \"kind\": \"scope-filter\" },\n30:         { \"name\": \"--score\", \"required\": false, \"takesValue\": false, \"kind\": \"boolean\" }\n31:       ],\n32:       \"render\": \"<target> [--scope] [--score]\"\n33:     },\n34:     \"choreography\": [\n35:       {\n36:         \"order\": 1,\n37:         \"skill\": \"sk-design\",\n38:         \"resource\": \".opencode/skills/sk-design/SKILL.md\",\n39:         \"action\": \"load the parent hub routing table and shared references\"\n40:       },\n41:       {\n42:         \"order\": 2,\n43:         \"skill\": \"design-audit\",\n44:         \"resource\": \".opencode/skills/sk-design/design-audit/SKILL.md\",\n45:         \"action\": \"load the audit mode contract\"\n46:       },\n47:       {\n48:         \"order\": 3,\n49:         \"skill\": \"design-audit\",\n50:         \"resource\": \".opencode/skills/sk-design/design-audit/references/\",\n51:         \"action\": \"load mode references and assets as the work requires, then apply the audit workflow to $ARGUMENTS\"\n52:       },\n53:       {\n54:         \"order\": 4,\n55:         \"skill\": \"sk-code\",\n56:         \"resource\": \".opencode/skills/sk-design/shared/sk_code_handoff.md\",\n57:         \"action\": \"prepare implementation handoff only when accepted design output moves to code\"\n58:       }\n59:     ],\n60:     \"next\": [\"/design:foundations\", \"/design:interface\", \"/design:motion\"],\n61:     \"handoff\": {\n62:       \"nextOptions\": [\n63:         {\n64:           \"command\": \"/design:foundations\",\n65:           \"when\": \"audit findings need static token, contrast, or system decisions before another pass\"\n66:         },\n67:         {\n68:           \"command\": \"/design:interface\",\n69:           \"when\": \"findings point to a changed interface direction rather than local fixes\"\n70:         },\n71:         {\n72:           \"command\": \"/design:motion\",\n73:           \"when\": \"findings involve animation, timing, state feedback, or reduced-motion behavior\"\n74:         }\n75:       ],\n76:       \"handoffRequired\": false,\n77:       \"handoffReason\": \"recommend-only; the user or the sk-design hub chooses the next step, never an automatic chain\"\n78:     },\n79:     \"proofFields\": [\"target\", \"evidenceInventory\", \"severityFindings\", \"qualityScore\"],\n80:     \"taskProjections\": [\n\n(Showing lines 1-80 of 841. Use offset=81 to continue.)\n</content>","metadata":{"preview":"[\n  {\n    \"command\": \"/design:audit\",\n    \"ownerMode\": \"audit\",\n    \"description\": \"Design QA report: accessibility, performance, responsive, anti-slop, scoring, hardening. sk-design audit mode.\",\n    \"descriptionRole\": \"hub-keyword-projection\",\n    \"autoTriggerEligible\": false,\n    \"hubKeywordProjection\": [\"accessibility\", \"performance\", \"responsive\", \"anti-slop\", \"scoring\", \"hardening\"],\n    \"argumentHint\": \"<target> [--scope] [--score]\",\n    \"aliases\": [\"audit design quality\", \"critique ui surface\", \"score design readiness\"],\n    \"userIntent\": {\n      \"job\": \"I want to review, score, and harden the quality of a design surface I already have.\",\n      \"ownedSignals\": [\"audit design quality\", \"critique ui surface\", \"score design readiness\"]\n    },\n    \"copyGuard\": [\"Thin bridge\", \"Pin the\", \"parent skill's\", \"parent hub to\", \"loads the\", \"mode directly\"],\n    \"accepts\": \"a design target plus optional scope and scoring flags\",\n    \"returns\": \"a findings-first design quality report with evidence, scores, owners, and verification notes\",\n    \"examples\": [\n      {\n        \"invocation\": \"/design:audit src/components/Checkout.tsx --scope a11y --score\",","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/command-metadata.json","text":"[\n  {\n    \"command\": \"/design:audit\",\n    \"ownerMode\": \"audit\",\n    \"description\": \"Design QA report: accessibility, performance, responsive, anti-slop, scoring, hardening. sk-design audit mode.\",\n    \"descriptionRole\": \"hub-keyword-projection\",\n    \"autoTriggerEligible\": false,\n    \"hubKeywordProjection\": [\"accessibility\", \"performance\", \"responsive\", \"anti-slop\", \"scoring\", \"hardening\"],\n    \"argumentHint\": \"<target> [--scope] [--score]\",\n    \"aliases\": [\"audit design quality\", \"critique ui surface\", \"score design readiness\"],\n    \"userIntent\": {\n      \"job\": \"I want to review, score, and harden the quality of a design surface I already have.\",\n      \"ownedSignals\": [\"audit design quality\", \"critique ui surface\", \"score design readiness\"]\n    },\n    \"copyGuard\": [\"Thin bridge\", \"Pin the\", \"parent skill's\", \"parent hub to\", \"loads the\", \"mode directly\"],\n    \"accepts\": \"a design target plus optional scope and scoring flags\",\n    \"returns\": \"a findings-first design quality report with evidence, scores, owners, and verification notes\",\n    \"examples\": [\n      {\n        \"invocation\": \"/design:audit src/components/Checkout.tsx --scope a11y --score\",\n        \"returnsArtifact\": \"a findings-first design quality report with evidence, scores, owners, and verification notes\"\n      }\n    ],\n    \"argumentGrammar\": {\n      \"positional\": [\n        { \"name\": \"target\", \"required\": true, \"kind\": \"design-target\" }\n      ],\n      \"flags\": [\n        { \"name\": \"--scope\", \"required\": false, \"takesValue\": true, \"valueName\": \"scope\", \"kind\": \"scope-filter\" },\n        { \"name\": \"--score\", \"required\": false, \"takesValue\": false, \"kind\": \"boolean\" }\n      ],\n      \"render\": \"<target> [--scope] [--score]\"\n    },\n    \"choreography\": [\n      {\n        \"order\": 1,\n        \"skill\": \"sk-design\",\n        \"resource\": \".opencode/skills/sk-design/SKILL.md\",\n        \"action\": \"load the parent hub routing table and shared references\"\n      },\n      {\n        \"order\": 2,\n        \"skill\": \"design-audit\",\n        \"resource\": \".opencode/skills/sk-design/design-audit/SKILL.md\",\n        \"action\": \"load the audit mode contract\"\n      },\n      {\n        \"order\": 3,\n        \"skill\": \"design-audit\",\n        \"resource\": \".opencode/skills/sk-design/design-audit/references/\",\n        \"action\": \"load mode references and assets as the work requires, then apply the audit workflow to $ARGUMENTS\"\n      },\n      {\n        \"order\": 4,\n        \"skill\": \"sk-code\",\n        \"resource\": \".opencode/skills/sk-design/shared/sk_code_handoff.md\",\n        \"action\": \"prepare implementation handoff only when accepted design output moves to code\"\n      }\n    ],\n    \"next\": [\"/design:foundations\", \"/design:interface\", \"/design:motion\"],\n    \"handoff\": {\n      \"nextOptions\": [\n        {\n          \"command\": \"/design:foundations\",\n          \"when\": \"audit findings need static token, contrast, or system decisions before another pass\"\n        },\n        {\n          \"command\": \"/design:interface\",\n          \"when\": \"findings point to a changed interface direction rather than local fixes\"\n        },\n        {\n          \"command\": \"/design:motion\",\n          \"when\": \"findings involve animation, timing, state feedback, or reduced-motion behavior\"\n        }\n      ],\n      \"handoffRequired\": false,\n      \"handoffReason\": \"recommend-only; the user or the sk-design hub chooses the next step, never an automatic chain\"\n    },\n    \"proofFields\": [\"target\", \"evidenceInventory\", \"severityFindings\", \"qualityScore\"],\n    \"taskProjections\": [","lineStart":1,"lineEnd":80,"totalLines":841,"truncated":true}},"title":".opencode/skills/sk-design/command-metadata.json","time":{"start":1782750855818,"end":1782750855823}},"id":"prt_f143b42890011xfTVpWO0dTxfa","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f143aeeef001C2PjdkQg7ec5Zv"}}
{"type":"tool_use","timestamp":1782750855851,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_c8ec881aa5294b85ab363dc4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/ai-fingerprint-registry-check.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/ai-fingerprint-registry-check.mjs</path>\n<type>file</type>\n<content>\n1: // ============================================================================\n2: // AI Fingerprint Registry Check\n3: // ============================================================================\n4: \n5: import { readFile, stat } from \"node:fs/promises\";\n6: import { resolve } from \"node:path\";\n7: import { pathToFileURL } from \"node:url\";\n8: \n9: const REQUIRED_FIELDS = [\n10:   \"tell_id\",\n11:   \"model_family\",\n12:   \"self_defect_prompt\",\n13:   \"deterministic_check\",\n14:   \"fixture_id\",\n15:   \"severity_floor\",\n16:   \"owner\"\n17: ];\n18: \n19: const MODEL_FAMILIES = new Set([\"codex\", \"gemini\", \"general\"]);\n20: const SEVERITY_FLOORS = new Set([\"P0\", \"P1\", \"P2\", \"P3\"]);\n21: const OWNERS = new Set([\"foundations\", \"interface\", \"motion\", \"sk-code\"]);\n22: const SLUG_PATTERN = /^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$/;\n23: \n24: const scriptUrl = new URL(import.meta.url);\n25: const skillRootUrl = new URL(\"../../\", scriptUrl);\n26: const catalogUrl = new URL(\"design-audit/references/ai_fingerprint_tells.md\", skillRootUrl);\n27: const registryUrl = new URL(\"design-audit/assets/ai_fingerprint_registry.json\", skillRootUrl);\n28: const fixtureRootUrl = new URL(\"design-audit/assets/ai_fingerprint_fixtures/\", skillRootUrl);\n29: \n30: const options = parseArgs(process.argv.slice(2));\n31: const jsonMode = options.json;\n32: \n33: if (options.errors.length > 0) {\n34:   emitAndExit(\n35:     {\n36:       status: \"invalid\",\n37:       stage: \"usage\",\n38:       errors: options.errors,\n39:       failures: []\n40:     },\n41:     2\n42:   );\n43: }\n44: \n45: main().catch((error) => {\n46:   emitAndExit(\n47:     {\n48:       status: \"invalid\",\n49:       stage: \"runtime\",\n50:       errors: [error instanceof Error ? error.message : String(error)],\n51:       failures: []\n52:     },\n53:     2\n54:   );\n55: });\n56: \n57: async function main() {\n58:   const [catalogSource, registry] = await Promise.all([\n59:     readFile(options.catalog ?? catalogUrl, \"utf8\"),\n60:     readJson(options.registry ?? registryUrl)\n61:   ]);\n62: \n63:   const catalogTells = parseCatalogTells(catalogSource);\n64:   const validation = validateRegistry(registry, catalogTells);\n65:   const fixtureFailures = await validateFixtureFiles(\n66:     validation.rows,\n67:     directoryUrl(options.fixturesRoot ?? fixtureRootUrl)\n68:   );\n69:   const failures = [...validateCatalog(catalogTells), ...validation.errors, ...fixtureFailures];\n70:   const status = failures.length > 0 ? \"fail\" : \"pass\";\n71: \n72:   emitAndExit(\n73:     {\n74:       status,\n75:       stage: status === \"pass\" ? \"complete\" : \"parity\",\n76:       metadata: {\n77:         catalogTellCount: catalogTells.length,\n78:         registryRowCount: validation.rows.length,\n79:         requiredFieldCount: REQUIRED_FIELDS.length,\n80:         fixtureRoot: directoryUrl(options.fixturesRoot ?? fixtureRootUrl).href\n81:       },\n82:       failures\n83:     },\n84:     status === \"pass\" ? 0 : 1\n85:   );\n86: }\n87: \n88: function parseArgs(args) {\n89:   const parsed = {\n90:     catalog: null,\n91:     registry: null,\n92:     fixturesRoot: null,\n93:     json: false,\n94:     errors: []\n95:   };\n96: \n97:   for (let index = 0; index < args.length; index += 1) {\n98:     const arg = args[index];\n99: \n100:     if (arg === \"--json\") {\n101:       parsed.json = true;\n102:       continue;\n103:     }\n104: \n105:     if (arg === \"--catalog\" || arg === \"--registry\" || arg === \"--fixtures-root\") {\n106:       const value = args[index + 1];\n107:       if (!value || value.startsWith(\"--\")) {\n108:         parsed.errors.push(`${arg} requires a path value`);\n109:       } else if (arg === \"--catalog\") {\n110:         parsed.catalog = value;\n111:         index += 1;\n112:       } else if (arg === \"--registry\") {\n113:         parsed.registry = value;\n114:         index += 1;\n115:       } else {\n116:         parsed.fixturesRoot = value;\n117:         index += 1;\n118:       }\n119:       continue;\n120:     }\n121: \n122:     parsed.errors.push(`unknown argument: ${arg}`);\n123:   }\n124: \n125:   return parsed;\n126: }\n127: \n128: async function readJson(source) {\n129:   const raw = await readFile(source, \"utf8\");\n130:   return JSON.parse(raw);\n131: }\n132: \n133: function parseCatalogTells(source) {\n134:   const tells = [];\n135:   let currentFamily = null;\n136: \n137:   for (const line of source.split(/\\r?\\n/)) {\n138:     const familyMatch = line.match(/^##\\s+\\d+\\.\\s+(.+?)\\s*$/);\n139:     if (familyMatch) {\n140:       currentFamily = familyFromHeading(familyMatch[1]);\n141:       continue;\n142:     }\n143: \n144:     if (!currentFamily) {\n145:       continue;\n146:     }\n147: \n148:     const tellMatch = line.match(/^###\\s+(?:\\d+(?:\\.\\d+)*\\s+)?(.+?)\\s*$/);\n149:     if (!tellMatch) {\n150:       continue;\n151:     }\n152: \n153:     const title = tellMatch[1].trim();\n154:     tells.push({\n155:       tell_id: slugify(title),\n156:       title,\n157:       model_family: currentFamily\n158:     });\n159:   }\n160: \n161:   return tells;\n162: }\n163: \n164: function familyFromHeading(heading) {\n165:   const normalized = heading.toLowerCase();\n166: \n167:   if (normalized.includes(\"codex tells\")) {\n168:     return \"codex\";\n169:   }\n170: \n171:   if (normalized.includes(\"gemini tells\")) {\n172:     return \"gemini\";\n173:   }\n174: \n175:   if (normalized.includes(\"2026-general tells\")) {\n176:     return \"general\";\n177:   }\n178: \n179:   return null;\n180: }\n181: \n182: function slugify(value) {\n183:   return value\n184:     .toLowerCase()\n185:     .replace(/&/g, \" and \")\n186:     .replace(/[^a-z0-9]+/g, \"-\")\n187:     .replace(/^-+|-+$/g, \"\");\n188: }\n189: \n190: function validateCatalog(catalogTells) {\n191:   const errors = [];\n192:   const seen = new Set();\n193: \n194:   if (catalogTells.length === 0) {\n195:     errors.push(\"catalog: no AI fingerprint tells found\");\n196:   }\n197: \n198:   for (const tell of catalogTells) {\n199:     if (!SLUG_PATTERN.test(tell.tell_id)) {\n200:       errors.push(`catalog tell ${tell.title}: tell_id ${tell.tell_id} is malformed`);\n201:     }\n202: \n203:     if (seen.has(tell.tell_id)) {\n204:       errors.push(`catalog tell ${tell.tell_id}: duplicate catalog slug`);\n205:     } else {\n206:       seen.add(tell.tell_id);\n207:     }\n208:   }\n209: \n210:   return errors;\n211: }\n212: \n213: function validateRegistry(registry, catalogTells) {\n214:   const errors = [];\n215: \n216:   if (!Array.isArray(registry)) {\n217:     return {\n218:       rows: [],\n219:       errors: [\"registry root must be an array\"]\n220:     };\n221:   }\n222: \n223:   const rows = registry;\n224:   const rowByTellId = new Map();\n225:   const catalogByTellId = new Map(catalogTells.map((tell) => [tell.tell_id, tell]));\n226: \n227:   rows.forEach((row, index) => {\n228:     const label = rowLabel(row, index);\n229: \n230:     if (!isPlainObject(row)) {\n231:       errors.push(`${label}: row must be an object`);\n232:       return;\n233:     }\n234: \n235:     for (const field of REQUIRED_FIELDS) {\n236:       if (!Object.hasOwn(row, field)) {\n237:         errors.push(`${label}: missing required field ${field}`);\n238:       } else if (typeof row[field] !== \"string\" || row[field].trim().length === 0) {\n239:         errors.push(`${label}: ${field} must be a non-empty string`);\n240:       }\n241:     }\n242: \n243:     for (const field of Object.keys(row)) {\n244:       if (!REQUIRED_FIELDS.includes(field)) {\n245:         errors.push(`${label}: unknown field ${field}`);\n246:       }\n247:     }\n248: \n249:     if (typeof row.tell_id === \"string\" && row.tell_id.trim().length > 0) {\n250:       if (!SLUG_PATTERN.test(row.tell_id)) {\n251:         errors.push(`${label}: tell_id must be a lowercase hyphen slug`);\n252:       }\n253: \n254:       if (rowByTellId.has(row.tell_id)) {\n255:         errors.push(`${label}: duplicate tell_id also used by ${rowByTellId.get(row.tell_id)}`);\n256:       } else {\n257:         rowByTellId.set(row.tell_id, label);\n258:       }\n259:     }\n260: \n261:     if (typeof row.model_family === \"string\" && !MODEL_FAMILIES.has(row.model_family)) {\n262:       errors.push(`${label}: model_family must be one of ${[...MODEL_FAMILIES].join(\", \")}`);\n263:     }\n264: \n265:     if (typeof row.severity_floor === \"string\" && !SEVERITY_FLOORS.has(row.severity_floor)) {\n266:       errors.push(`${label}: severity_floor must be one of ${[...SEVERITY_FLOORS].join(\", \")}`);\n267:     }\n268: \n269:     if (typeof row.owner === \"string\" && !OWNERS.has(row.owner)) {\n270:       errors.push(`${label}: owner must be one of ${[...OWNERS].join(\", \")}`);\n271:     }\n272: \n273:     if (typeof row.fixture_id === \"string\" && !SLUG_PATTERN.test(row.fixture_id)) {\n274:       errors.push(`${label}: fixture_id must be a lowercase hyphen slug`);\n275:     }\n276:   });\n277: \n278:   for (const tell of catalogTells) {\n279:     const row = rows.find((candidate) => candidate?.tell_id === tell.tell_id);\n280:     if (!row) {\n281:       errors.push(`catalog tell ${tell.tell_id}: missing registry row`);\n282:       continue;\n283:     }\n284: \n285:     if (row.model_family !== tell.model_family) {\n286:       errors.push(\n287:         `registry row ${tell.tell_id}: model_family ${row.model_family} does not match catalog ${tell.model_family}`\n288:       );\n289:     }\n290:   }\n291: \n292:   for (const row of rows) {\n293:     if (typeof row?.tell_id === \"string\" && row.tell_id.length > 0 && !catalogByTellId.has(row.tell_id)) {\n294:       errors.push(`registry row ${row.tell_id}: no matching catalog tell`);\n295:     }\n296:   }\n297: \n298:   return {\n299:     rows,\n300:     errors: errors.sort()\n301:   };\n302: }\n303: \n304: async function validateFixtureFiles(rows, rootUrl) {\n305:   const errors = [];\n306: \n307:   await Promise.all(rows.map(async (row, index) => {\n308:     if (typeof row?.fixture_id !== \"string\" || row.fixture_id.trim().length === 0) {\n309:       return;\n310:     }\n311: \n312:     if (!SLUG_PATTERN.test(row.fixture_id)) {\n313:       return;\n314:     }\n315: \n316:     const label = rowLabel(row, index);\n317:     const dirUrl = new URL(`${row.fixture_id}/`, rootUrl);\n318:     const cleanUrl = new URL(`${row.fixture_id}/clean.html`, rootUrl);\n319:     const tellUrl = new URL(`${row.fixture_id}/tell.html`, rootUrl);\n320: \n321:     if (!(await existsAs(dirUrl, \"directory\"))) {\n322:       errors.push(`${label}: fixture directory ${row.fixture_id}/ is missing`);\n323:       return;\n324:     }\n325: \n326:     if (!(await existsAs(cleanUrl, \"file\"))) {\n327:       errors.push(`${label}: fixture ${row.fixture_id}/clean.html is missing`);\n328:     }\n329: \n330:     if (!(await existsAs(tellUrl, \"file\"))) {\n331:       errors.push(`${label}: fixture ${row.fixture_id}/tell.html is missing`);\n332:     }\n333:   }));\n334: \n335:   return errors.sort();\n336: }\n337: \n338: async function existsAs(url, kind) {\n339:   try {\n340:     const entry = await stat(url);\n341:     return kind === \"directory\" ? entry.isDirectory() : entry.isFile();\n342:   } catch {\n343:     return false;\n344:   }\n345: }\n346: \n347: function rowLabel(row, index) {\n348:   if (typeof row?.tell_id === \"string\" && row.tell_id.length > 0) {\n349:     return `registry row ${row.tell_id}`;\n350:   }\n351: \n352:   return `registry row [${index}]`;\n353: }\n354: \n355: function isPlainObject(value) {\n356:   return Boolean(value) && typeof value === \"object\" && !Array.isArray(value);\n357: }\n358: \n359: function directoryUrl(value) {\n360:   const url = value instanceof URL ? value : pathToFileURL(resolve(value));\n361:   const text = url.href.endsWith(\"/\") ? url.href : `${url.href}/`;\n362:   return new URL(text);\n363: }\n364: \n365: function emitAndExit(report, exitCode) {\n366:   if (jsonMode) {\n367:     console.log(JSON.stringify(report, null, 2));\n368:     process.exit(exitCode);\n369:   }\n370: \n371:   if (report.status === \"pass\") {\n372:     console.log(\n373:       `PASS ai-fingerprint-registry-check: catalogTells=${report.metadata.catalogTellCount} registryRows=${report.metadata.registryRowCount}`\n374:     );\n375:   } else {\n376:     console.error(`FAIL ai-fingerprint-registry-check: ${report.stage}`);\n377:     for (const error of report.errors ?? report.failures ?? []) {\n378:       console.error(`- ${error}`);\n379:     }\n380:   }\n381: \n382:   process.exit(exitCode);\n383: }\n\n(End of file - total 383 lines)\n</content>","metadata":{"preview":"// ============================================================================\n// AI Fingerprint Registry Check\n// ============================================================================\n\nimport { readFile, stat } from \"node:fs/promises\";\nimport { resolve } from \"node:path\";\nimport { pathToFileURL } from \"node:url\";\n\nconst REQUIRED_FIELDS = [\n  \"tell_id\",\n  \"model_family\",\n  \"self_defect_prompt\",\n  \"deterministic_check\",\n  \"fixture_id\",\n  \"severity_floor\",\n  \"owner\"\n];\n\nconst MODEL_FAMILIES = new Set([\"codex\", \"gemini\", \"general\"]);\nconst SEVERITY_FLOORS = new Set([\"P0\", \"P1\", \"P2\", \"P3\"]);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/ai-fingerprint-registry-check.mjs","text":"// ============================================================================\n// AI Fingerprint Registry Check\n// ============================================================================\n\nimport { readFile, stat } from \"node:fs/promises\";\nimport { resolve } from \"node:path\";\nimport { pathToFileURL } from \"node:url\";\n\nconst REQUIRED_FIELDS = [\n  \"tell_id\",\n  \"model_family\",\n  \"self_defect_prompt\",\n  \"deterministic_check\",\n  \"fixture_id\",\n  \"severity_floor\",\n  \"owner\"\n];\n\nconst MODEL_FAMILIES = new Set([\"codex\", \"gemini\", \"general\"]);\nconst SEVERITY_FLOORS = new Set([\"P0\", \"P1\", \"P2\", \"P3\"]);\nconst OWNERS = new Set([\"foundations\", \"interface\", \"motion\", \"sk-code\"]);\nconst SLUG_PATTERN = /^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$/;\n\nconst scriptUrl = new URL(import.meta.url);\nconst skillRootUrl = new URL(\"../../\", scriptUrl);\nconst catalogUrl = new URL(\"design-audit/references/ai_fingerprint_tells.md\", skillRootUrl);\nconst registryUrl = new URL(\"design-audit/assets/ai_fingerprint_registry.json\", skillRootUrl);\nconst fixtureRootUrl = new URL(\"design-audit/assets/ai_fingerprint_fixtures/\", skillRootUrl);\n\nconst options = parseArgs(process.argv.slice(2));\nconst jsonMode = options.json;\n\nif (options.errors.length > 0) {\n  emitAndExit(\n    {\n      status: \"invalid\",\n      stage: \"usage\",\n      errors: options.errors,\n      failures: []\n    },\n    2\n  );\n}\n\nmain().catch((error) => {\n  emitAndExit(\n    {\n      status: \"invalid\",\n      stage: \"runtime\",\n      errors: [error instanceof Error ? error.message : String(error)],\n      failures: []\n    },\n    2\n  );\n});\n\nasync function main() {\n  const [catalogSource, registry] = await Promise.all([\n    readFile(options.catalog ?? catalogUrl, \"utf8\"),\n    readJson(options.registry ?? registryUrl)\n  ]);\n\n  const catalogTells = parseCatalogTells(catalogSource);\n  const validation = validateRegistry(registry, catalogTells);\n  const fixtureFailures = await validateFixtureFiles(\n    validation.rows,\n    directoryUrl(options.fixturesRoot ?? fixtureRootUrl)\n  );\n  const failures = [...validateCatalog(catalogTells), ...validation.errors, ...fixtureFailures];\n  const status = failures.length > 0 ? \"fail\" : \"pass\";\n\n  emitAndExit(\n    {\n      status,\n      stage: status === \"pass\" ? \"complete\" : \"parity\",\n      metadata: {\n        catalogTellCount: catalogTells.length,\n        registryRowCount: validation.rows.length,\n        requiredFieldCount: REQUIRED_FIELDS.length,\n        fixtureRoot: directoryUrl(options.fixturesRoot ?? fixtureRootUrl).href\n      },\n      failures\n    },\n    status === \"pass\" ? 0 : 1\n  );\n}\n\nfunction parseArgs(args) {\n  const parsed = {\n    catalog: null,\n    registry: null,\n    fixturesRoot: null,\n    json: false,\n    errors: []\n  };\n\n  for (let index = 0; index < args.length; index += 1) {\n    const arg = args[index];\n\n    if (arg === \"--json\") {\n      parsed.json = true;\n      continue;\n    }\n\n    if (arg === \"--catalog\" || arg === \"--registry\" || arg === \"--fixtures-root\") {\n      const value = args[index + 1];\n      if (!value || value.startsWith(\"--\")) {\n        parsed.errors.push(`${arg} requires a path value`);\n      } else if (arg === \"--catalog\") {\n        parsed.catalog = value;\n        index += 1;\n      } else if (arg === \"--registry\") {\n        parsed.registry = value;\n        index += 1;\n      } else {\n        parsed.fixturesRoot = value;\n        index += 1;\n      }\n      continue;\n    }\n\n    parsed.errors.push(`unknown argument: ${arg}`);\n  }\n\n  return parsed;\n}\n\nasync function readJson(source) {\n  const raw = await readFile(source, \"utf8\");\n  return JSON.parse(raw);\n}\n\nfunction parseCatalogTells(source) {\n  const tells = [];\n  let currentFamily = null;\n\n  for (const line of source.split(/\\r?\\n/)) {\n    const familyMatch = line.match(/^##\\s+\\d+\\.\\s+(.+?)\\s*$/);\n    if (familyMatch) {\n      currentFamily = familyFromHeading(familyMatch[1]);\n      continue;\n    }\n\n    if (!currentFamily) {\n      continue;\n    }\n\n    const tellMatch = line.match(/^###\\s+(?:\\d+(?:\\.\\d+)*\\s+)?(.+?)\\s*$/);\n    if (!tellMatch) {\n      continue;\n    }\n\n    const title = tellMatch[1].trim();\n    tells.push({\n      tell_id: slugify(title),\n      title,\n      model_family: currentFamily\n    });\n  }\n\n  return tells;\n}\n\nfunction familyFromHeading(heading) {\n  const normalized = heading.toLowerCase();\n\n  if (normalized.includes(\"codex tells\")) {\n    return \"codex\";\n  }\n\n  if (normalized.includes(\"gemini tells\")) {\n    return \"gemini\";\n  }\n\n  if (normalized.includes(\"2026-general tells\")) {\n    return \"general\";\n  }\n\n  return null;\n}\n\nfunction slugify(value) {\n  return value\n    .toLowerCase()\n    .replace(/&/g, \" and \")\n    .replace(/[^a-z0-9]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\");\n}\n\nfunction validateCatalog(catalogTells) {\n  const errors = [];\n  const seen = new Set();\n\n  if (catalogTells.length === 0) {\n    errors.push(\"catalog: no AI fingerprint tells found\");\n  }\n\n  for (const tell of catalogTells) {\n    if (!SLUG_PATTERN.test(tell.tell_id)) {\n      errors.push(`catalog tell ${tell.title}: tell_id ${tell.tell_id} is malformed`);\n    }\n\n    if (seen.has(tell.tell_id)) {\n      errors.push(`catalog tell ${tell.tell_id}: duplicate catalog slug`);\n    } else {\n      seen.add(tell.tell_id);\n    }\n  }\n\n  return errors;\n}\n\nfunction validateRegistry(registry, catalogTells) {\n  const errors = [];\n\n  if (!Array.isArray(registry)) {\n    return {\n      rows: [],\n      errors: [\"registry root must be an array\"]\n    };\n  }\n\n  const rows = registry;\n  const rowByTellId = new Map();\n  const catalogByTellId = new Map(catalogTells.map((tell) => [tell.tell_id, tell]));\n\n  rows.forEach((row, index) => {\n    const label = rowLabel(row, index);\n\n    if (!isPlainObject(row)) {\n      errors.push(`${label}: row must be an object`);\n      return;\n    }\n\n    for (const field of REQUIRED_FIELDS) {\n      if (!Object.hasOwn(row, field)) {\n        errors.push(`${label}: missing required field ${field}`);\n      } else if (typeof row[field] !== \"string\" || row[field].trim().length === 0) {\n        errors.push(`${label}: ${field} must be a non-empty string`);\n      }\n    }\n\n    for (const field of Object.keys(row)) {\n      if (!REQUIRED_FIELDS.includes(field)) {\n        errors.push(`${label}: unknown field ${field}`);\n      }\n    }\n\n    if (typeof row.tell_id === \"string\" && row.tell_id.trim().length > 0) {\n      if (!SLUG_PATTERN.test(row.tell_id)) {\n        errors.push(`${label}: tell_id must be a lowercase hyphen slug`);\n      }\n\n      if (rowByTellId.has(row.tell_id)) {\n        errors.push(`${label}: duplicate tell_id also used by ${rowByTellId.get(row.tell_id)}`);\n      } else {\n        rowByTellId.set(row.tell_id, label);\n      }\n    }\n\n    if (typeof row.model_family === \"string\" && !MODEL_FAMILIES.has(row.model_family)) {\n      errors.push(`${label}: model_family must be one of ${[...MODEL_FAMILIES].join(\", \")}`);\n    }\n\n    if (typeof row.severity_floor === \"string\" && !SEVERITY_FLOORS.has(row.severity_floor)) {\n      errors.push(`${label}: severity_floor must be one of ${[...SEVERITY_FLOORS].join(\", \")}`);\n    }\n\n    if (typeof row.owner === \"string\" && !OWNERS.has(row.owner)) {\n      errors.push(`${label}: owner must be one of ${[...OWNERS].join(\", \")}`);\n    }\n\n    if (typeof row.fixture_id === \"string\" && !SLUG_PATTERN.test(row.fixture_id)) {\n      errors.push(`${label}: fixture_id must be a lowercase hyphen slug`);\n    }\n  });\n\n  for (const tell of catalogTells) {\n    const row = rows.find((candidate) => candidate?.tell_id === tell.tell_id);\n    if (!row) {\n      errors.push(`catalog tell ${tell.tell_id}: missing registry row`);\n      continue;\n    }\n\n    if (row.model_family !== tell.model_family) {\n      errors.push(\n        `registry row ${tell.tell_id}: model_family ${row.model_family} does not match catalog ${tell.model_family}`\n      );\n    }\n  }\n\n  for (const row of rows) {\n    if (typeof row?.tell_id === \"string\" && row.tell_id.length > 0 && !catalogByTellId.has(row.tell_id)) {\n      errors.push(`registry row ${row.tell_id}: no matching catalog tell`);\n    }\n  }\n\n  return {\n    rows,\n    errors: errors.sort()\n  };\n}\n\nasync function validateFixtureFiles(rows, rootUrl) {\n  const errors = [];\n\n  await Promise.all(rows.map(async (row, index) => {\n    if (typeof row?.fixture_id !== \"string\" || row.fixture_id.trim().length === 0) {\n      return;\n    }\n\n    if (!SLUG_PATTERN.test(row.fixture_id)) {\n      return;\n    }\n\n    const label = rowLabel(row, index);\n    const dirUrl = new URL(`${row.fixture_id}/`, rootUrl);\n    const cleanUrl = new URL(`${row.fixture_id}/clean.html`, rootUrl);\n    const tellUrl = new URL(`${row.fixture_id}/tell.html`, rootUrl);\n\n    if (!(await existsAs(dirUrl, \"directory\"))) {\n      errors.push(`${label}: fixture directory ${row.fixture_id}/ is missing`);\n      return;\n    }\n\n    if (!(await existsAs(cleanUrl, \"file\"))) {\n      errors.push(`${label}: fixture ${row.fixture_id}/clean.html is missing`);\n    }\n\n    if (!(await existsAs(tellUrl, \"file\"))) {\n      errors.push(`${label}: fixture ${row.fixture_id}/tell.html is missing`);\n    }\n  }));\n\n  return errors.sort();\n}\n\nasync function existsAs(url, kind) {\n  try {\n    const entry = await stat(url);\n    return kind === \"directory\" ? entry.isDirectory() : entry.isFile();\n  } catch {\n    return false;\n  }\n}\n\nfunction rowLabel(row, index) {\n  if (typeof row?.tell_id === \"string\" && row.tell_id.length > 0) {\n    return `registry row ${row.tell_id}`;\n  }\n\n  return `registry row [${index}]`;\n}\n\nfunction isPlainObject(value) {\n  return Boolean(value) && typeof value === \"object\" && !Array.isArray(value);\n}\n\nfunction directoryUrl(value) {\n  const url = value instanceof URL ? value : pathToFileURL(resolve(value));\n  const text = url.href.endsWith(\"/\") ? url.href : `${url.href}/`;\n  return new URL(text);\n}\n\nfunction emitAndExit(report, exitCode) {\n  if (jsonMode) {\n    console.log(JSON.stringify(report, null, 2));\n    process.exit(exitCode);\n  }\n\n  if (report.status === \"pass\") {\n    console.log(\n      `PASS ai-fingerprint-registry-check: catalogTells=${report.metadata.catalogTellCount} registryRows=${report.metadata.registryRowCount}`\n    );\n  } else {\n    console.error(`FAIL ai-fingerprint-registry-check: ${report.stage}`);\n    for (const error of report.errors ?? report.failures ?? []) {\n      console.error(`- ${error}`);\n    }\n  }\n\n  process.exit(exitCode);\n}","lineStart":1,"lineEnd":383,"totalLines":383,"truncated":false}},"title":".opencode/skills/sk-design/shared/scripts/ai-fingerprint-registry-check.mjs","time":{"start":1782750855820,"end":1782750855849}},"id":"prt_f143b428b001nA1f0R9u7FO3zW","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f143aeeef001C2PjdkQg7ec5Zv"}}
