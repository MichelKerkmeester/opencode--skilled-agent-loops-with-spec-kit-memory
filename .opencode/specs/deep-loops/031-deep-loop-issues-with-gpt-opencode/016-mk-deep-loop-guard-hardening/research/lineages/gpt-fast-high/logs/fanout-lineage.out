rent,\n1326:       continuationSuppressed: suppress ? true : current.continuationSuppressed,\n1327:       continuationSuppressedReason: sanitizeInlineText(reason, DEFAULT_MAX_REASON_CHARS),\n1328:       lastContinuationError: errorText\n1329:         ? sanitizeInlineText(errorText, DEFAULT_MAX_REASON_CHARS)\n1330:         : current.lastContinuationError,\n1331:       updatedAtMs: timestamp,\n1332:       updatedAt: isoFromMs(timestamp),\n1333:     };\n1334:   }, rawOptions);\n1335: }\n1336: \n1337: async function recordContinuationBudgetStop(sessionID, goalID, rawOptions = {}) {\n1338:   const normalizedGoalID = sanitizeInlineText(goalID, 160).replace(/\\s+/g, '-');\n1339:   if (!normalizedGoalID) return null;\n1340:   return mutateGoal(sessionID, (current) => {\n1341:     if (!current || current.goalId !== normalizedGoalID) return current;\n1342:     const timestamp = nowMs(rawOptions);\n1343:     return {\n1344:       ...current,\n1345:       status: 'budget_limited',\n1346:       continuationSuppressed: true,\n1347:       continuationSuppressedReason: 'budget_exhausted',\n1348:       updatedAtMs: timestamp,\n1349:       updatedAt: isoFromMs(timestamp),\n1350:     };\n1351:   }, rawOptions);\n1352: }\n1353: \n1354: async function recordProviderUsageLimit(sessionID, goalID, rawOptions = {}) {\n1355:   const normalizedGoalID = sanitizeInlineText(goalID, 160).replace(/\\s+/g, '-');\n1356:   if (!normalizedGoalID) return null;\n1357:   return mutateGoal(sessionID, (current) => {\n1358:     if (!current || current.goalId !== normalizedGoalID) return current;\n1359:     const timestamp = nowMs(rawOptions);\n1360:     return {\n1361:       ...current,\n1362:       status: 'usage_limited',\n1363:       continuationSuppressed: true,\n1364:       continuationSuppressedReason: 'usage_limited',\n1365:       updatedAtMs: timestamp,\n1366:       updatedAt: isoFromMs(timestamp),\n1367:     };\n1368:   }, rawOptions);\n1369: }\n1370: \n1371: async function reserveContinuationTurn(sessionID, goalID, rawOptions = {}) {\n1372:   const normalizedGoalID = sanitizeInlineText(goalID, 160).replace(/\\s+/g, '-');\n1373:   const messageID = `goal-continuation-${randomUUID()}`;\n1374:   let didReserve = false;\n1375:   const goal = await mutateGoal(sessionID, (current) => {\n1376:     if (!current || current.goalId !== normalizedGoalID || current.status !== 'active') return current;\n1377:     const maxAutoTurns = Math.min(current.maxAutoTurns || DEFAULT_MAX_AUTO_TURNS, DEFAULT_MAX_AUTO_TURNS);\n1378:     if (current.autoTurnsUsed >= maxAutoTurns) return current;\n1379:     const timestamp = nowMs(rawOptions);\n1380:     didReserve = true;\n1381:     return {\n1382:       ...current,\n1383:       autoTurnsUsed: current.autoTurnsUsed + 1,\n1384:       lastContinuationAtMs: timestamp,\n1385:       lastContinuationMessageId: messageID,\n1386:       lastContinuationError: null,\n1387:       continuationSuppressedReason: null,\n1388:       updatedAtMs: timestamp,\n1389:       updatedAt: isoFromMs(timestamp),\n1390:     };\n1391:   }, rawOptions);\n1392: \n1393:   return { didReserve, goal, messageID };\n1394: }\n1395: \n1396: function buildPromptAsyncOptions(sessionID, goal, messageID, rawOptions = {}) {\n1397:   const directory = sanitizeInlineText(rawOptions.directory || '', 1000);\n1398:   return {\n1399:     path: { id: sessionID },\n1400:     query: directory ? { directory } : undefined,\n1401:     body: {\n1402:       messageID,\n1403:       parts: [{\n1404:         type: 'text',\n1405:         text: renderContinuationPrompt(goal, rawOptions),\n1406:       }],\n1407:     },\n1408:   };\n1409: }\n1410: \n1411: /**\n1412:  * Continue an active goal once all autonomy gates pass.\n1413:  *\n1414:  * @param {string} sessionID - OpenCode session id\n1415:  * @param {Object} [rawOptions] - Continuation options\n1416:  * @returns {Promise<Object>} Decision envelope\n1417:  */\n1418: async function maybeContinueGoal(sessionID, rawOptions = {}) {\n1419:   const