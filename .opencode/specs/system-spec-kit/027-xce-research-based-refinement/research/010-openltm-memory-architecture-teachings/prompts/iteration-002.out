 provenance_source TEXT,\n2618:       provenance_actor TEXT,\n2619:       governed_at TEXT,\n2620:       retention_policy TEXT DEFAULT 'keep',\n2621:       delete_after TEXT,\n2622:       governance_metadata TEXT,\n2623:       expires_at DATETIME,\n2624:       confidence REAL DEFAULT 0.5,\n2625:       validation_count INTEGER DEFAULT 0,\n2626:       -- FSRS (Free Spaced Repetition Scheduler) columns for cognitive memory\n2627:       stability REAL DEFAULT 1.0,\n2628:       difficulty REAL DEFAULT 5.0,\n2629:       last_review TEXT,\n2630:       review_count INTEGER DEFAULT 0,\n2631:       file_mtime_ms INTEGER,\n2632:       -- DEPRECATED post-026.018 cleanup: archived-tier removed. Column kept to\n2633:       -- DEPRECATED schema stability: new rows always have is_archived = 0 and\n2634:       -- query paths must not branch on this column.\n2635:       is_archived INTEGER DEFAULT 0, -- DEPRECATED schema stability\n2636:       document_type TEXT DEFAULT 'memory',\n2637:       spec_level INTEGER,\n\n(Showing lines 2588-2637 of 2784. Use offset=2638 to continue.)\n</content>","metadata":{"preview":"      id INTEGER PRIMARY KEY,\n      spec_folder TEXT NOT NULL,\n      file_path TEXT NOT NULL,\n      canonical_file_path TEXT,\n      anchor_id TEXT,\n      title TEXT,\n      trigger_phrases TEXT,\n      importance_weight REAL DEFAULT 0.5,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL,\n      embedding_model TEXT,\n      embedding_generated_at TEXT,\n      embedding_status TEXT DEFAULT 'pending' CHECK(embedding_status IN ('pending', 'success', 'failed', 'retry', 'partial')),\n      retry_count INTEGER DEFAULT 0,\n      last_retry_at TEXT,\n      failure_reason TEXT,\n      base_importance REAL DEFAULT 0.5,\n      decay_half_life_days REAL DEFAULT 90.0,\n      is_pinned INTEGER DEFAULT 0,\n      access_count INTEGER DEFAULT 0,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","text":"      id INTEGER PRIMARY KEY,\n      spec_folder TEXT NOT NULL,\n      file_path TEXT NOT NULL,\n      canonical_file_path TEXT,\n      anchor_id TEXT,\n      title TEXT,\n      trigger_phrases TEXT,\n      importance_weight REAL DEFAULT 0.5,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL,\n      embedding_model TEXT,\n      embedding_generated_at TEXT,\n      embedding_status TEXT DEFAULT 'pending' CHECK(embedding_status IN ('pending', 'success', 'failed', 'retry', 'partial')),\n      retry_count INTEGER DEFAULT 0,\n      last_retry_at TEXT,\n      failure_reason TEXT,\n      base_importance REAL DEFAULT 0.5,\n      decay_half_life_days REAL DEFAULT 90.0,\n      is_pinned INTEGER DEFAULT 0,\n      access_count INTEGER DEFAULT 0,\n      last_accessed INTEGER DEFAULT 0,\n      importance_tier TEXT DEFAULT 'normal' CHECK(importance_tier IN ('constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated')),\n      tenant_id TEXT,\n      user_id TEXT,\n      agent_id TEXT,\n      session_id TEXT,\n      context_type TEXT DEFAULT 'general' CHECK(context_type IN ('research', 'implementation', 'planning', 'general')),\n      channel TEXT DEFAULT 'default',\n      content_hash TEXT,\n      provenance_source TEXT,\n      provenance_actor TEXT,\n      governed_at TEXT,\n      retention_policy TEXT DEFAULT 'keep',\n      delete_after TEXT,\n      governance_metadata TEXT,\n      expires_at DATETIME,\n      confidence REAL DEFAULT 0.5,\n      validation_count INTEGER DEFAULT 0,\n      -- FSRS (Free Spaced Repetition Scheduler) columns for cognitive memory\n      stability REAL DEFAULT 1.0,\n      difficulty REAL DEFAULT 5.0,\n      last_review TEXT,\n      review_count INTEGER DEFAULT 0,\n      file_mtime_ms INTEGER,\n      -- DEPRECATED post-026.018 cleanup: archived-tier removed. Column kept to\n      -- DEPRECATED schema stability: new rows always have is_archived = 0 and\n      -- query paths must not branch on this column.\n      is_archived INTEGER DEFAULT 0, -- DEPRECATED schema stability\n      document_type TEXT DEFAULT 'memory',\n      spec_level INTEGER,","lineStart":2588,"lineEnd":2637,"totalLines":2784,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","time":{"start":1780925412490,"end":1780925412499}},"metadata":{"openai":{"itemId":"fc_0b649874a9002717016a26c3e424d08198bc3421ac62882f95"}},"id":"prt_ea76d33c60011ApdSZyI6gk6Ii","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76d1ba2001xBCDdsfaz2sYYx"}}
{"type":"step_finish","timestamp":1780925413004,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"id":"prt_ea76d3683001F3HiejTlnTS3PL","reason":"tool-calls","snapshot":"1f0f1569428ad58b635d1241fe1830c17a06666e","messageID":"msg_ea76d1ba2001xBCDdsfaz2sYYx","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","type":"step-finish","tokens":{"total":88153,"input":2978,"output":114,"reasoning":69,"cache":{"write":0,"read":84992}},"cost":0}}
{"type":"step_start","timestamp":1780925415705,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"id":"prt_ea76d4117001blaFMFrr2g57v2","messageID":"msg_ea76d37bd001umR0gXB5iA95zu","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","snapshot":"db24f8aa890550737813c70b5f5395778a2b47bf","type":"step-start"}}
{"type":"text","timestamp":1780925471680,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"id":"prt_ea76dc50b001o0M06zNrynj6Qy","messageID":"msg_ea76d37bd001umR0gXB5iA95zu","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","type":"text","text":"## Mechanism\nOpenLTM stores a materialized `decay_score` on `memories`, defaults it to `1.0`, and indexes it descending for relevance-order reads (`migrations/011_add_decay_score_and_archive.sql:4`, `migrations/011_add_decay_score_and_archive.sql:6`). Its janitor refresh is two SQL `UPDATE`s in one transaction: first recompute active-memory scores, then mark low scores deprecated (`packages/openltm-core/src/janitor/decay.ts:14`, `packages/openltm-core/src/janitor/decay.ts:31`, `packages/openltm-core/src/janitor/decay.ts:40`). The score is `importance × confidence × 0.5^(age/halfLife)`, where `importance=5` and `confirm_count>=10` are non-decaying, importance 4/3/2/else use 180/90/30/14 days, and age is based on `COALESCE(last_used_at, last_confirmed_at, created_at)` (`packages/openltm-core/src/janitor/decay.ts:16`, `packages/openltm-core/src/janitor/decay.ts:20`, `packages/openltm-core/src/janitor/decay.ts:26`). The docs expose the same half-life table and formula, and say scores below `0.25` are soft-deprecated and not session-start injected (`docs/02-how-it-works.md:58`, `docs/02-how-it-works.md:70`, `docs/02-how-it-works.md:76`). The deprecation SQL enforces `status='active'`, `importance<5`, `confirm_count<10`, and `decay_score<0.25` (`packages/openltm-core/src/janitor/decay.ts:31`). Recall/query speed is helped because default recall omits the large embedding blob and can `ORDER BY decay_score DESC` in SQL (`packages/openltm-core/src/db.ts:522`, `packages/openltm-core/src/db.ts:524`). Access refreshes recency: recall updates `last_used_at`, `last_recalled_at`, and `recall_count`, and the temporal metadata migration adds recall timestamps/counts plus supersession fields (`packages/openltm-core/src/db.ts:552`, `migrations/006_temporal_metadata.sql:3`). Tests exercise the exported formula, including immortal importance 5, decreasing score with age, 180-day half-life for importance 4, and positive nonzero scores (`src/__tests__/decay.test.ts:52`, `src/__tests__/decay.test.ts:76`, `src/__tests__/decay.test.ts:94`, `src/__tests__/decay.test.ts:108`). Retention is staged: deprecated low-importance, rarely recalled memories with `decay_score<0.10` are copied as JSON into `memory_archive` before deletion, max 100 per run (`packages/openltm-core/src/janitor/archive.ts:4`, `packages/openltm-core/src/janitor/archive.ts:49`). UNKNOWN: docs claim deprecated memories can still be recalled explicitly, but the core recall query I read unconditionally adds `status = 'active'` (`docs/02-how-it-works.md:76`, `packages/openltm-core/src/db.ts:510`).\n\n## Teachings for system-spec-kit\n- **Claim** · Materialize a retrieval-decay scalar for hot default paths instead of recomputing every query. · **Evidence** · `migrations/011_add_decay_score_and_archive.sql:5`, `packages/openltm-core/src/db.ts:524` · **Maps-to** · `memory_search` / vector-index maintenance · **Verdict** · ADAPT · **Risk** · MED · **Confidence** · 0.86 · **Why it transfers (or not)** · Our FSRS SQL is richer, but a maintained `effective_retrievability` cache could speed common ranking if invalidated on access/review/index updates.\n- **Claim** · Multiply decay/retrievability by confidence, not only importance. · **Evidence** · `packages/openltm-core/src/janitor/decay.ts:17`, `docs/02-how-it-works.md:70` · **Maps-to** · ranking calibration / validation confidence · **Verdict** · ADAPT · **Risk** · MED · **Confidence** · 0.78 · **Why it transfers (or not)** · We already store confidence, but current vector decay uses importance-weighted FSRS; confidence weighting could demote unvalidated memories if not double-counted with quality/feedback scores.\n- **Claim** · Add a decay-threshold maintenance action that hides, but does not immediately delete, stale low-value memories. · **Evidence** · `packages/openltm-core/src/janitor/decay.ts:31`, `packages/openltm-core/src/janitor/archive.ts:4` · **Maps-to** · deprecated tier / retention sweep / `minState` filters · **Verdict** · DEFER · **Risk** · MED · **Confidence** · 0.74 · **Why it transfers (or not)** · Our HOT/WARM/COLD/ARCHIVED and deprecated filters partly cover this; an automatic FSRS-to-deprecated transition needs careful review to avoid hiding valid old decisions.\n- **Claim** · Preserve per-memory archive snapshots before janitor deletion. · **Evidence** · `migrations/011_add_decay_score_and_archive.sql:8`, `packages/openltm-core/src/janitor/archive.ts:49` · **Maps-to** · retention/audit subsystem · **Verdict** · ADAPT · **Risk** · LOW · **Confidence** · 0.82 · **Why it transfers (or not)** · Single-user scale makes this cheap, and it complements checkpoints by making auto-deletion reversible at memory granularity.\n- **Claim** · Do not replace FSRS with fixed importance half-lives. · **Evidence** · `packages/openltm-core/src/janitor/decay.ts:20`, `src/__tests__/decay.test.ts:94` · **Maps-to** · FSRS scheduler · **Verdict** · REJECT · **Risk** · HIGH · **Confidence** · 0.91 · **Why it transfers (or not)** · FSRS already adapts stability from access/review behavior; fixed 14/30/90/180-day buckets are simpler but less personalized.\n\n## Negative knowledge\nDo not copy hard `confirm_count>=10` immortality; repeated access should increase FSRS stability, not make stale facts permanent.\n\nDo not copy the apparent deprecated-recall ambiguity; define explicit `includeDeprecated` or `tier=deprecated` semantics.\n\nDo not copy the parallel JS/SQL threshold drift: exported JS deprecation protects `confirm_count>=5`, while SQL janitor uses `>=10`.\n\n## Open questions\nShould system-spec-kit materialize `effective_retrievability` only for default/top-level search, or for every retrieval channel?\n\nShould confidence weighting use `confidence`, `quality_score`, validation count, or learned feedback reducers?\n\nShould stale FSRS memories become `deprecated`, `DORMANT`, or merely receive lower ranking?","time":{"start":1780925449483,"end":1780925471675},"metadata":{"openai":{"itemId":"msg_0644697e076952bc016a26c409673c819bbf9b705f338423d4","phase":"final_answer"}}}}
