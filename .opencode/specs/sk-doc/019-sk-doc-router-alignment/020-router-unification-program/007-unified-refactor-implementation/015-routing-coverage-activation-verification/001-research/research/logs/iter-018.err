   430	  const expectedAssets = extractPaths(assetBlock);
   431	  const notLoadedBlock = sectionAfter(text, /\*\*Expected NOT loaded\*\*/i);
   432	  const forbiddenResources = extractForbiddenPrefixes(notLoadedBlock);
   433	  const expectedRankBelowSkillIds = parseExpectedRankBelowSkillIds(text);
