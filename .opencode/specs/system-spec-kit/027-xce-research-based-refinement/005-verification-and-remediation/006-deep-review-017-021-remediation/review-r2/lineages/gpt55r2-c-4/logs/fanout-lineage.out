{"type":"tool_use","timestamp":1781762519977,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_IES4QqQ23tXQzN4rGZNBADqv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Backward-compatible export surface across split modules.\n6: \n7: export {\n8:   BetterSqliteVectorStore,\n9:   BetterSqliteVectorStore as SQLiteVectorStore,\n10: } from '../storage/ports/vector-store.js';\n11: export {\n12:   MAX_TRIGGERS_PER_MEMORY,\n13:   to_embedding_buffer,\n14:   parse_trigger_phrases,\n15:   get_error_message,\n16:   get_error_code,\n17: } from './vector-index-types.js';\n18: export type {\n19:   MemoryIndexRow,\n20:   MemoryScopeParams,\n21:   IndexMemoryParams,\n22:   UpdateMemoryParams,\n23:   VectorSearchOptions,\n24:   EnrichedSearchResult,\n25: } from './vector-index-types.js';\n26: export {\n27:   SCHEMA_VERSION,\n28:   run_migrations,\n29:   ensure_schema_version,\n30:   migrate_confidence_columns,\n31:   ensure_canonical_file_path_support,\n32:   migrate_constitutional_tier,\n33:   create_common_indexes,\n34:   ensureCompanionTables,\n35:   create_schema,\n36:   ensureSchemaVersion,\n37:   runMigrations,\n38:   createSchema,\n39:   createCommonIndexes,\n40:   migrateConfidenceColumns,\n41:   ensureCanonicalFilePathSupport,\n42:   migrateConstitutionalTier,\n43: } from './vector-index-schema.js';\n44: export {\n45:   index_memory,\n46:   index_memory_deferred,\n47:   update_memory,\n48:   delete_memory,\n49:   delete_memory_by_path,\n50:   delete_memories,\n51:   update_embedding_status,\n52:   update_confidence,\n53:   indexMemory,\n54:   indexMemoryDeferred,\n55:   updateMemory,\n56:   deleteMemory,\n57:   deleteMemoryByPath,\n58:   deleteMemories,\n59:   updateEmbeddingStatus,\n60:   updateConfidence,\n61: } from './vector-index-mutations.js';\n62: export {\n63:   get_memory,\n64:   get_memories_by_folder,\n65:   get_memory_count,\n66:   get_status_counts,\n67:   get_stats,\n68:   vector_search,\n69:   get_constitutional_memories_public,\n70:   multi_concept_search,\n71:   extract_title,\n72:   extract_snippet,\n73:   extract_tags,\n74:   extract_date,\n75:   generate_query_embedding,\n76:   keyword_search,\n77:   vector_search_enriched,\n78:   multi_concept_search_enriched,\n79:   multi_concept_keyword_search,\n80:   parse_quoted_terms,\n81:   apply_smart_ranking,\n82:   apply_diversity,\n83:   get_related_memories,\n84:   get_usage_stats,\n85:   find_cleanup_candidates,\n86:   get_memory_preview,\n87:   verify_integrity,\n88:   getMemory,\n89:   getMemoriesByFolder,\n90:   getMemoryCount,\n91:   getStatusCounts,\n92:   getStats,\n93:   vectorSearch,\n94:   getConstitutionalMemories,\n95:   multiConceptSearch,\n96:   extractTitle,\n97:   extractSnippet,\n98:   extractTags,\n99:   extractDate,\n100:   generateQueryEmbedding,\n101:   keywordSearch,\n102:   vectorSearchEnriched,\n103:   multiConceptSearchEnriched,\n104:   multiConceptKeywordSearch,\n105:   parseQuotedTerms,\n106:   applySmartRanking,\n107:   applyDiversity,\n108:   getRelatedMemories,\n109:   getUsageStats,\n110:   findCleanupCandidates,\n111:   getMemoryPreview,\n112:   verifyIntegrity,\n113: } from './vector-index-queries.js';\n114: export {\n115:   LRUCache,\n116:   get_query_cache,\n117:   get_cache_key,\n118:   cached_search,\n119:   clear_search_cache,\n120:   learn_from_selection,\n121:   link_related_on_save,\n122:   record_access,\n123:   enhanced_search,\n124:   cachedSearch,\n125:   clearSearchCache,\n126:   learnFromSelection,\n127:   linkRelatedOnSave,\n128:   recordAccess,\n129:   enhancedSearch,\n130:   getCacheKey,\n131: } from './vector-index-aliases.js';\n132: \n133: // Re-export store items that aren't re-exported by other modules\n134: export {\n135:   initializeDb,\n136:   initialize_db,\n137:   checkpointAllWal,\n138:   closeDb,\n139:   close_db,\n140:   getDb,\n141:   get_db,\n142:   tryGetDb,\n143:   try_get_db,\n144:   getDbPath,\n145:   get_db_path,\n146:   clearConstitutionalCache,\n147:   validateFilePath,\n148:   isVectorSearchAvailable,\n149:   getConfirmedEmbeddingDimension,\n150:   getEmbeddingDim,\n151:   validateEmbeddingDimension,\n152:   EMBEDDING_DIM,\n153:   DEFAULT_DB_PATH,\n154:   search_weights,\n155:   safe_read_file_async,\n156:   safe_parse_json,\n157:   validate_file_path_local,\n158:   get_embedding_dim,\n159:   get_confirmed_embedding_dimension,\n160:   validate_embedding_dimension,\n161:   is_vector_search_available,\n162:   clear_constitutional_cache,\n163:   get_constitutional_memories,\n164:   init_prepared_statements,\n165:   clear_prepared_statements,\n166:   refresh_interference_scores_for_folder,\n167:   sqlite_vec_available,\n168:   activeVectorSource,\n169:   getActiveVectorSource,\n170:   attachActiveVectorShard,\n171:   detachActiveVectorShard,\n172:   attachActiveVectorShardForActiveProfile,\n173: } from './vector-index-store.js';\n174: \n175: // Snake_case aliases for store exports used by legacy callers\n176: export {\n177:   isVectorSearchAvailable as is_vector_search_available_alias,\n178: } from './vector-index-store.js';\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,\n  IndexMemoryParams,\n  UpdateMemoryParams,\n  VectorSearchOptions,\n  EnrichedSearchResult,\n} from './vector-index-types.js';\nexport {\n  SCHEMA_VERSION,\n  run_migrations,\n  ensure_schema_version,\n  migrate_confidence_columns,\n  ensure_canonical_file_path_support,\n  migrate_constitutional_tier,\n  create_common_indexes,\n  ensureCompanionTables,\n  create_schema,\n  ensureSchemaVersion,\n  runMigrations,\n  createSchema,\n  createCommonIndexes,\n  migrateConfidenceColumns,\n  ensureCanonicalFilePathSupport,\n  migrateConstitutionalTier,\n} from './vector-index-schema.js';\nexport {\n  index_memory,\n  index_memory_deferred,\n  update_memory,\n  delete_memory,\n  delete_memory_by_path,\n  delete_memories,\n  update_embedding_status,\n  update_confidence,\n  indexMemory,\n  indexMemoryDeferred,\n  updateMemory,\n  deleteMemory,\n  deleteMemoryByPath,\n  deleteMemories,\n  updateEmbeddingStatus,\n  updateConfidence,\n} from './vector-index-mutations.js';\nexport {\n  get_memory,\n  get_memories_by_folder,\n  get_memory_count,\n  get_status_counts,\n  get_stats,\n  vector_search,\n  get_constitutional_memories_public,\n  multi_concept_search,\n  extract_title,\n  extract_snippet,\n  extract_tags,\n  extract_date,\n  generate_query_embedding,\n  keyword_search,\n  vector_search_enriched,\n  multi_concept_search_enriched,\n  multi_concept_keyword_search,\n  parse_quoted_terms,\n  apply_smart_ranking,\n  apply_diversity,\n  get_related_memories,\n  get_usage_stats,\n  find_cleanup_candidates,\n  get_memory_preview,\n  verify_integrity,\n  getMemory,\n  getMemoriesByFolder,\n  getMemoryCount,\n  getStatusCounts,\n  getStats,\n  vectorSearch,\n  getConstitutionalMemories,\n  multiConceptSearch,\n  extractTitle,\n  extractSnippet,\n  extractTags,\n  extractDate,\n  generateQueryEmbedding,\n  keywordSearch,\n  vectorSearchEnriched,\n  multiConceptSearchEnriched,\n  multiConceptKeywordSearch,\n  parseQuotedTerms,\n  applySmartRanking,\n  applyDiversity,\n  getRelatedMemories,\n  getUsageStats,\n  findCleanupCandidates,\n  getMemoryPreview,\n  verifyIntegrity,\n} from './vector-index-queries.js';\nexport {\n  LRUCache,\n  get_query_cache,\n  get_cache_key,\n  cached_search,\n  clear_search_cache,\n  learn_from_selection,\n  link_related_on_save,\n  record_access,\n  enhanced_search,\n  cachedSearch,\n  clearSearchCache,\n  learnFromSelection,\n  linkRelatedOnSave,\n  recordAccess,\n  enhancedSearch,\n  getCacheKey,\n} from './vector-index-aliases.js';\n\n// Re-export store items that aren't re-exported by other modules\nexport {\n  initializeDb,\n  initialize_db,\n  checkpointAllWal,\n  closeDb,\n  close_db,\n  getDb,\n  get_db,\n  tryGetDb,\n  try_get_db,\n  getDbPath,\n  get_db_path,\n  clearConstitutionalCache,\n  validateFilePath,\n  isVectorSearchAvailable,\n  getConfirmedEmbeddingDimension,\n  getEmbeddingDim,\n  validateEmbeddingDimension,\n  EMBEDDING_DIM,\n  DEFAULT_DB_PATH,\n  search_weights,\n  safe_read_file_async,\n  safe_parse_json,\n  validate_file_path_local,\n  get_embedding_dim,\n  get_confirmed_embedding_dimension,\n  validate_embedding_dimension,\n  is_vector_search_available,\n  clear_constitutional_cache,\n  get_constitutional_memories,\n  init_prepared_statements,\n  clear_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available,\n  activeVectorSource,\n  getActiveVectorSource,\n  attachActiveVectorShard,\n  detachActiveVectorShard,\n  attachActiveVectorShardForActiveProfile,\n} from './vector-index-store.js';\n\n// Snake_case aliases for store exports used by legacy callers\nexport {\n  isVectorSearchAvailable as is_vector_search_available_alias,\n} from './vector-index-store.js';","lineStart":1,"lineEnd":178,"totalLines":178,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","time":{"start":1781762519972,"end":1781762519976}},"metadata":{"openai":{"itemId":"fc_09d2c26a45bfb896016a3389d6e7d0819187f08383365e0a75"}},"id":"prt_ed9526f9d001ddz1bRgfny4Vr0","sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","messageID":"msg_ed9525c2e0013rj44GioA0aeLI"}}
