gn integration\"\n    ],\n    \"intent_signals\": [\n      \"open design\",\n      \"od mcp\",\n      \"od cli\",\n      \"design system\",\n      \"terminal design\",\n      \"headless run\",\n      \"start_run\",\n      \"local-first design\"\n    ],\n    \"key_files\": [\n      \".opencode/skills/mcp-open-design/SKILL.md\",\n      \".opencode/skills/mcp-open-design/README.md\",\n      \".opencode/skills/mcp-open-design/references/od_cli_reference.md\",\n      \".opencode/skills/mcp-open-design/references/mcp_wiring.md\",\n      \".opencode/skills/mcp-open-design/references/tool_surface.md\",\n      \".opencode/skills/mcp-open-design/feature_catalog/feature_catalog.md\",\n      \".opencode/skills/mcp-open-design/manual_testing_playbook/manual_testing_playbook.md\",\n      \".opencode/skills/mcp-open-design/changelog/v1.0.0.0.md\",\n      \".opencode/skills/mcp-open-design/changelog/v1.1.0.0.md\",\n      \".opencode/skills/mcp-open-design/changelog/v1.2.0.0.md\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"mcp-open-design\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/mcp-open-design/SKILL.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"README\",\n        \"kind\": \"reference\",\n        \"path\": \".opencode/skills/mcp-open-design/README.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"od_cli_reference\",\n        \"kind\": \"reference\",\n        \"path\": \".opencode/skills/mcp-open-design/references/od_cli_reference.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"mcp_wiring\",\n        \"kind\": \"reference\",\n        \"path\": \".opencode/skills/mcp-open-design/references/mcp_wiring.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"tool_surface\",\n        \"kind\": \"reference\",\n        \"path\": \".opencode/skills/mcp-open-design/references/tool_surface.md\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"mcp-open-design teaches a terminal agent (opencode or Claude Code) to drive the installed Open Design desktop app through its od CLI and stdio MCP server instead of the in-app chat. Wire with od mcp install, then read local projects and design-systems, reuse them, or commission gated headless runs. Generation is multi-turn: start_run (or od run start) fires turn 1, which returns a discovery question-form with zero files, and the design is built only after od ui respond answers the form. od artifacts create only adds a file, never a rendered design. The od CLI is daemon-cli.mjs run under Node (not the bundled vela auth client) and the daemon is socket-discovered on an ephemeral port (not a fixed 7456), hosted by the desktop app, which also exposes an HTTP API whose port rotates on restart (rediscover via /api/mcp/install-info). Pairs with sk-interface-design (the design judgment) over the shared claude_design_parity loop, and never vendors Open Design content.\",\n    \"source_docs\": [\n      \"SKILL.md\",\n      \"README.md\",\n      \"references/od_cli_reference.md\",\n      \"references/mcp_wiring.md\",\n      \"references/tool_surface.md\",\n      \"feature_catalog/feature_catalog.md\",\n      \"manual_testing_playbook/manual_testing_playbook.md\",\n      \"changelog/v1.0.0.0.md\",\n      \"changelog/v1.1.0.0.md\",\n      \"changelog/v1.2.0.0.md\"\n    ],\n    \"created_at\": \"2026-06-14T12:30:00Z\",\n    \"last_updated_at\": \"2026-06-14T16:50:00Z\"\n  }\n}","lineStart":1,"lineEnd":148,"totalLines":148,"truncated":false}},"title":".opencode/skills/mcp-open-design/graph-metadata.json","time":{"start":1781458539026,"end":1781458539029}},"id":"prt_ec73410af001g3g2jn7FNi5FBM","sessionID":"ses_138ce4b7fffegpX9L4tC4pzcvD","messageID":"msg_ec7335871001x9rBSUM64CXs02"}}
