248-function parseExpectedIntentGold(block) {
249:  const keyM = /(?:^|\n)[ \t]*expected_intent[ \t]*:(.*)/.exec(block);
250-  if (!keyM) return { present: false, intent: null, intents: [], parseError: null };
251-  const value = cleanListItem(keyM[1]);
