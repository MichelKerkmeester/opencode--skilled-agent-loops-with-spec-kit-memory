(l).type==='iteration'); if(iterations.length!==20) throw new Error('expected 20 state iterations, got '+iterations.length); for(let i=1;i<=20;i++){ const n=String(i).padStart(3,'0'); const mdLines=fs.readFileSync(base+'/iterations/iteration-'+n+'.md','utf8').trimEnd().split(/\\n/); const verdict=mdLines[mdLines.length-1]; if(!/^Review verdict: (PASS|CONDITIONAL|FAIL)$/.test(verdict)) throw new Error('bad verdict line iteration '+n+': '+verdict); const d=fs.readFileSync(base+'/deltas/iter-'+n+'.jsonl','utf8').trim().split(/\\n/); if(!d.some(line=>JSON.parse(line).type==='iteration')) throw new Error('missing delta iteration '+n); } JSON.parse(fs.readFileSync(base+'/deep-review-config.json','utf8')); JSON.parse(fs.readFileSync(base+'/deep-review-findings-registry.json','utf8')); console.log('artifact sanity passed: 20 iterations, 20 deltas, JSON parse ok');\"","time":{"start":1783433846691,"end":1783433846694}},"metadata":{"openai":{"itemId":"fc_01552f632f8ad02b016a4d0a6fe6f481978b6776d36898476a"}},"id":"prt_f3cf0c54c001r1zUcfuRyTtIb3","sessionID":"ses_0c31ab9faffeAPI3afU5RCGgAK","messageID":"msg_f3cf0b1b30012pLIOLav2Xt16Z"}}
