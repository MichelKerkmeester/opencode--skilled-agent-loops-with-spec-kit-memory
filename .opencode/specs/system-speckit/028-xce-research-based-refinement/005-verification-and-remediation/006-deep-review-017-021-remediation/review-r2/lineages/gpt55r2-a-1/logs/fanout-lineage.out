e\":\"SQLite lexical engine runs FTS twice and double-counts keyword evidence as BM25\",\"file\":\".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts\",\"line\":436,\"lineRange\":\"435-453\",\"finding_class\":\"retrieval_rank_bias\",\"content_hash\":\"sha256:49a5712c7c7052af85d2fd2305cf5c0c8170a544fc499b973387210df9d24343\",\"evidence\":[\".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts:1479-1491\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:435-453\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:1401-1418\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:1497-1584\"],\"claim\":\"In auto/sqlite lexical mode, bm25Search delegates to ftsSearch while collectAndFuseHybridResults still runs ftsSearch and bm25Search and merges both into the keyword list, overweighting lexical matches and doing duplicate SQL on the read path.\"},{\"findingId\":\"F002\",\"severity\":\"P1\",\"category\":\"correctness\",\"status\":\"active\",\"dimension\":\"correctness\",\"title\":\"Summary embedding channel limits globally before applying scope and only exact-matches spec folders\",\"file\":\".opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts\",\"line\":167,\"lineRange\":\"167-192\",\"finding_class\":\"scope_then_limit_violation\",\"content_hash\":\"sha256:5811cf6bc4c360bbf3ede42c8fad2b183bbd72a77df4c2448112569d21e44ab1\",\"evidence\":[\".opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts:167-175\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/memory-summaries.ts:190-192\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts:139-147\",\".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts:1309-1343\"],\"claim\":\"The summary-embedding channel computes an unscoped top-K first, then applies an exact spec-folder filter in Stage 1, so scoped searches can lose valid in-scope or child-folder summary hits before ranking.\"}],\"newFindingsRatio\":1,\"traceabilityChecks\":{\"results\":[{\"protocolId\":\"spec_code\",\"status\":\"partial\",\"gateClass\":\"hard\",\"applicable\":true,\"counts\":{\"pass\":2,\"partial\":1,\"fail\":0,\"skipped\":0},\"evidence\":[\".opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/scopes/A-search-retrieval/spec.md:6-13\"],\"findingRefs\":[\"F001\",\"F002\"],\"summary\":\"Review scope resolved to shipped search/retrieval code; two defects found in scope/limit and lexical fusion behavior.\"},{\"protocolId\":\"checklist_evidence\",\"status\":\"partial\",\"gateClass\":\"hard\",\"applicable\":true,\"counts\":{\"pass\":0,\"partial\":1,\"fail\":0,\"skipped\":0},\"evidence\":[\".opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/scopes/A-search-retrieval/spec.md:1-18\"],\"findingRefs\":[],\"summary\":\"Scope folder has spec.md only; no checklist.md was present to validate completion marks.\"}]},\"coverage\":{\"dimensionsCovered\":[\"correctness\",\"performance\",\"traceability\"],\"dimensionCoverage\":0.5,\"requiredProtocolsCovered\":false},\"noveltyJustification\":\"Both findings are new in this lineage and affect read-path ranking or scoped recall.\",\"ruledOut\":[\"No P0 recorded: defects degrade ranking/recall but do not demonstrate data loss, security breach, or hard release gate failure in the inspected code.\"],\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.5-fast\"},\"sessionId\":\"fanout-gpt55r2-a-1-1781761314338-6u1ztm\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"timestamp\":\"2026-06-18T05:46:20Z\",\"durationMs\":0}\n+{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":1,\"passed\":true,\"activeP0P1\":2,\"packets\":[{\"findingId\":\"F001\",\"finalSeverity\":\"P1\",\"confidence\":0.88},{\"findingId\":\"F002\",\"finalSeverity\":\"P1\",\"confidence\":0.9}],\"sessionId\":\"fanout-gpt55r2-a-1-1781761314338-6u1ztm\",\"generation\":1,\"timestamp\":\"2026-06-18T05:46:20Z\"}\n+{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":1,\"verdict\":\"CONDITIONAL\",\"activeP0\":0,\"activeP1\":2,\"activeP2\":0,\"dimensionCoverage\":0.5,\"stopReason\":\"maxIterationsReached\",\"releaseReadinessState\":\"in-progress\",\"sessionId\":\"fanout-gpt55r2-a-1-1781761314338-6u1ztm\",\"generation\":1,\"timestamp\":\"2026-06-18T05:46:20Z\"}\n*** Add File: .opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-a-1/deep-review-findings-registry.json\n+{\n+  \"sessionId\": \"fanout-gpt55r2-a-1-1781761314338-6u1ztm\",\n+  \"generation\": 1,\n+  \"lineageMode\": \"new\",\n+  \"openFindings\": [\n+    {\n+      \"findingId\": \"F001\",\n+      \"severity\": \"P1\",\n+      \"category\": \"performance\",\n+      \"status\": \"active\",\n+      \"dimension\": \"correctness\",\n+      \"title\": \"SQLite lexical engine runs FTS twice and double-counts keyword evidence as BM25\",\n+      \"file\": \".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts\",\n+      \"line\": 436,\n+      \"lineRange\": \"435-453\",\n+      \"finding_class\": \"retrieval_rank_bias\",\n+      \"content_hash\": \"sha256:49a5712c7c7052af85d2fd2305cf5c0c8170a544fc499b973387210df9d24343\",\n+      \"firstSeen\": 1,\n+      \"lastSeen\": 1,\n+      \"evidence\": [\n+        \".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts:1479-1491\",\n+        \".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:435-453\",\n+        \".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts:1401-1418\",\n+        \".openco