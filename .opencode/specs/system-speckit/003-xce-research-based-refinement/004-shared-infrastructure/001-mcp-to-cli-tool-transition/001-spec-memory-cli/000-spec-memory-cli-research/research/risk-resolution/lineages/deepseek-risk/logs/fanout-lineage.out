nst staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n1175:           fs.renameSync(lockDir, staleClaim);\n1176:           fs.rmSync(staleClaim, { recursive: true, force: true });\n1177:           continue;\n1178:         }\n1179:       } catch (statErr) {\n1180:         // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n1181:         if (statErr.code === 'ENOENT') continue;\n1182:         if (statErr.code === 'ENOTEMPTY') continue;\n1183:         throw statErr;\n1184:       }\n1185:       if (artifactsReady() && !requireLock) {\n1186:         return false;\n1187:       }\n1188:       if (Date.now() > deadline) {\n1189:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n1190:       }\n1191:       await sleep(1000);\n1192:     }\n1193:   }\n1194: }\n1195: \n1196: function launchServer() {\n1197:   if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n1198:     log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n1199:     return false;\n1200:   }\n1201:   if (shouldSkipLaunch(childProcess)) {\n1202:     log('launchServer skipped: a context-server child is already running in this launcher process');\n1203:     return false;\n1204:   }\n1205:   if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n1206:   if (supervisorRelaunchTimer) {\n1207:     clearTimeout(supervisorRelaunchTimer);\n1208:     supervisorRelaunchTimer = null;\n1209:   }\n1210:   const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n1211:   const nodeArgs = getContextServerNodeArgs();\n1212:   childProcess = spawn(process.execPath, [...nodeArgs, server], {\n1213:     cwd: root,\n1214:     env: {\n1215:       ...process.env,\n1216:       SPECKIT_BACKEND_ONLY: '1',\n1217:     },\n1218:     stdio: ['ignore', 'ignore', 'inherit'],\n1219:   });\n1220:   const childPid = childProcess.pid;\n1221:   const refreshed = refreshOwnerLea