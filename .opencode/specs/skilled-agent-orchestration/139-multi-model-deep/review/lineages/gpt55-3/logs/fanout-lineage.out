  \"_shadow\": {\n      \"model\": \"advisor-shadow-learned-weights-v1\",\n      \"liveWeightsFrozen\": true,\n      \"recommendations\": [\n        {\n          \"skillId\": \"sk-code\",\n          \"liveScore\": 0.694783,\n          \"shadowScore\": 0.681737,\n          \"delta\": -0.013046,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"sk-code-review\",\n          \"liveScore\": 0.666447,\n          \"shadowScore\": 0.664864,\n          \"delta\": -0.001583,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"deep-review\",\n          \"liveScore\": 0.64869,\n          \"shadowScore\": 0.628883,\n          \"delta\": -0.019807,\n          \"dominantShadowLane\": \"explicit_author\"\n        }\n      ]\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1780907551621,"end":1780907552452}},"metadata":{"openai":{"itemId":"fc_01e94e5e6bb327ef016a267e1ee1748191816a96f47dcba98d"}},"id":"prt_ea65ca8a3001dmYaR2Fn8QqpU7","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea65c88950018xB6D5Z1lpG0cI"}}
