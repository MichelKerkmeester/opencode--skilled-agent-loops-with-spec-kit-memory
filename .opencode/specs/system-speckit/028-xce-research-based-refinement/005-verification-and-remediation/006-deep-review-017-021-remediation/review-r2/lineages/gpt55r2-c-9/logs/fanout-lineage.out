{"type":"tool_use","timestamp":1781764140846,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_uVAZN65TfYPFZ2dERQ8Q1GSm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Index\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import { createHash } from 'node:crypto';\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. CORE AND UTILS IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\n13: import { beginMaintenance } from '../lib/storage/maintenance-marker.js';\n14: import { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\n15: import { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\n16: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* ───────────────────────────────────────────────────────────────\n24:    2. LIB MODULE IMPORTS\n25: ──────────────────────────────────────────────────────────────── */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* ───────────────────────────────────────────────────────────────\n82:    4. TYPES\n83: ──────────────────────────────────────────────────────────────── */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   nearDuplicateRepaired: number;\n161:   orphanSwept: number;\n162:   orphanSweepFailed: number;\n163:   orphanSweepScanned: number;\n164:   orphanSweepNextCursor: number | null;\n165:   moveReconciled?: number;\n166:   files: ScanFileEntry[];\n167:   constitutional: {\n168:     found: number;\n169:     indexed: number;\n170:     alreadyIndexed: number;\n171:   };\n172:   incremental: {\n173:     enabled: boolean;\n174:     fast_path_skips: number;\n175:     mtime_changed: number;\n176:     metadataPromoter: {\n177:       processed: number;\n178:       resolved: number;\n179:       inserted: number;\n180:       skippedManual: number;\n181:       staleTombstoned: number;\n182:       staleDeleted: number;\n183:       warnings: number;\n184:     };\n185:   };\n186:   dedup: {\n187:     inputTotal: number;\n188:     uniqueTotal: number;\n189:     duplicatesSkipped: number;\n190:   };\n191:   aliasConflicts: AliasConflictSummary;\n192:   divergenceReconcile: DivergenceReconcileSummary;\n193:   checkpointRepair: CheckpointRepairReport;\n194:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n195:   warnings: string[];\n196:   capExceeded: DiscoveryCapExceeded;\n197: }\n198: \n199: interface CategorizedFiles {\n200:   toIndex: string[];\n201:   toUpdate: string[];\n202:   toSkip: string[];\n203:   toDelete: string[];\n204: }\n205: \n206: interface ScanKeyOptions {\n207:   spec_folder: string | null;\n208:   force: boolean;\n209:   incremental: boolean;\n210:   include_constitutional: boolean;\n211:   include_spec_docs: boolean;\n212: }\n213: \n214: interface RecordDeleteResult {\n215:   deleted: number;\n216:   failed: number;\n217:   actions: StatediffAction[];\n218: }\n219: \n220: interface OrphanSweepDeleteResult {\n221:   swept: number;\n222:   failed: number;\n223:   scannedRows: number;\n224:   nextCursor: number | null;\n225:   actions: StatediffAction[];\n226: }\n227: \n228: interface OrphanSweepCandidates {\n229:   swept: number;\n230:   nextCursor: number | null;\n231:   scannedRows: number;\n232:   orphanRecordIds?: number[];\n233: }\n234: \n235: const ORPHAN_SWEEP_LIMIT = 200;\n236: \n237: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n238: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n239: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n240: // event-loop block from a phase that is merely slow but yields — the two need\n241: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n242: const LOOP_LAG_SAMPLE_MS = 250;\n243: const LOOP_LAG_WARN_MS = 1000;\n244: \n245: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n246:   return {\n247:     sentinelPresent: false,\n248:     attempted: false,\n249:     completed: 0,\n250:     failed: 0,\n251:     skipped: 0,\n252:     cleared: false,\n253:     error: null,\n254:   };\n255: }\n256: \n257: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n258:   try {\n259:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n260:       source: 'memory_index_scan',\n261:       actor: 'mcp:memory_index_scan',\n262:     });\n263:     return {\n264:       sentinelPresent: repair.sentinelPresent,\n265:       attempted: repair.attempted,\n266:       completed: repair.summary?.completed.length ?? 0,\n267:       failed: repair.summary?.failed.length ?? 0,\n268:       skipped: repair.summary?.skipped.length ?? 0,\n269:       cleared: repair.cleared,\n270:       error: repair.error,\n271:     };\n272:   } catch (error: unknown) {\n273:     return {\n274:       ...emptyCheckpointRepairReport(),\n275:       sentinelPresent: true,\n276:       attempted: true,\n277:       error: toErrorMessage(error),\n278:     };\n279:   }\n280: }\n281: \n282: function createScanKey(options: ScanKeyOptions): string {\n283:   const normalized = {\n284:     spec_folder: options.spec_folder ?? null,\n285:     force: !!options.force,\n286:     incremental: !!options.incremental,\n287:     include_constitutional: !!options.include_constitutional,\n288:     include_spec_docs: !!options.include_spec_docs,\n289:   };\n290: \n291:   return createHash('sha256')\n292:     .update(JSON.stringify(normalized))\n293:     .digest('hex')\n294:     .slice(0, 16);\n295: }\n296: \n297: interface ScanArgs {\n298:   specFolder?: string | null;\n299:   force?: boolean;\n300:   includeConstitutional?: boolean;\n301:   includeSpecDocs?: boolean;\n302:   incremental?: boolean;\n303:   // Opt-in: run the scan as a background job and return a jobId immediately.\n304:   background?: boolean;\n305:   tenantId?: string;\n306:   userId?: string;\n307:   agentId?: string;\n308:   sessionId?: string;\n309:   provenanceSource?: string;\n310:   provenanceActor?: string;\n311:   governedAt?: string;\n312:   retentionPolicy?: 'keep' | 'ephemeral';\n313:   deleteAfter?: string;\n314: }\n315: \n316: /* ───────────────────────────────────────────────────────────────\n317:    5. SHARED INDEXING LOGIC\n318: ──────────────────────────────────────────────────────────────── */\n319: \n320: import { indexMemoryFile } from './memory-save.js';\n\n(Showing lines 1-320 of 1598. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* ───────────────────────────────────────────────────────────────\n   4. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  nearDuplicateRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields — the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. SHARED INDEXING LOGIC\n──────────────────────────────────────────────────────────────── */\n\nimport { indexMemoryFile } from './memory-save.js';","lineStart":1,"lineEnd":320,"totalLines":1598,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781764140822,"end":1781764140845}},"metadata":{"openai":{"itemId":"fc_0d6ae382ff28249e016a33902cb63c8191b510bbd422c032b8"}},"id":"prt_ed96b2f12001rMuXAhpTtysi67","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed96afb7e001W3qLsQ87QsFGNb"}}
