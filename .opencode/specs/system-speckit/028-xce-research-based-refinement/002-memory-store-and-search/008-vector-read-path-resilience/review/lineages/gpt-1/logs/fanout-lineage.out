!= null) {\n1801:         const msg = canonicalDimCheck.warning ||\n1802:           `Embedding dimension mismatch: DB=${canonicalDimCheck.stored}, provider=${canonicalDimCheck.current}`;\n1803:         console.error(`[vector-index] FATAL: ${msg}`);\n1804:         try { new_db.close(); } catch (_: unknown) { /* best-effort */ }\n1805:         throw new VectorIndexError(msg, VectorIndexErrorCode.INTEGRITY_ERROR);\n1806:       }\n1807:     }\n1808:   }\n1809: \n1810:   attachActiveVectorShard(new_db, startupProfile);\n1811: \n1812:   const preBootstrapDimCheck = validate_embedding_dimension_for_connection(new_db, vec_available);\n1813:   if (!preBootstrapDimCheck.valid && preBootstrapDimCheck.stored != null) {\n1814:     const msg = preBootstrapDimCheck.warning ||\n1815:       `Embedding dimension mismatch: DB=${preBootstrapDimCheck.stored}, provider=${preBootstrapDimCheck.current}`;\n1816:     console.error(`[vector-index] FATAL: ${msg}`);\n1817:     try { new_db.close(); } catch (_: unknown) { /* best-effort */ }\n1818:     throw new VectorIndexError(msg, VectorIndexErrorCode.INTEGRITY_ERROR);\n1819:   }\n\n(Showing lines 1740-1819 of 1989. Use offset=1820 to continue.)\n</content>","metadata":{"preview":"      }\n      console.error('[vector-index] This usually means Node.js was updated without rebuilding native modules.');\n      console.error('[vector-index] Fix: Run \\'bash scripts/setup/rebuild-native-modules.sh\\' from the spec-kit root');\n      console.error('[vector-index] Or manually: npm rebuild better-sqlite3');\n    }\n    throw db_error;\n  }\n\n  let vec_available = true;\n  try {\n    sqliteVec.load(new_db);\n  } catch (vec_error: unknown) {\n    vec_available = false;\n    console.warn(`[vector-index] sqlite-vec extension not available: ${get_error_message(vec_error)}`);\n    console.warn('[vector-index] Falling back to anchor-only mode (no vector search)');\n    console.warn('[vector-index] Install sqlite-vec: brew install sqlite-vec (macOS)');\n  }