{"type":"tool_use","timestamp":1784691903473,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_KDBvCPNlhiErHwtTswAEMHqC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":1800,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1800:     const gauges = {\n1801:       lag: latestGauges.lag,\n1802:       pending: latestGauges.pending,\n1803:       failed: Math.max(latestGauges.failed, partial.summary.failed),\n1804:     };\n1805:     appendFanoutStatusLedger(ledgerPath, {\n1806:       event: 'stopped',\n1807:       signal,\n1808:       at: stoppedAtIso,\n1809:       gauges,\n1810:     });\n1811:     writeOrchestrationSummary(summaryPath, {\n1812:       run_id: runId,\n1813:       loop_type: loopType,\n1814:       spec_folder: specFolder,\n1815:       base_artifact_dir: baseArtifactDir,\n1816:       total_cli_lineages: cliLineages.length,\n1817:       stopped: true,\n1818:       stopped_signal: signal,\n1819:       stopped_at_iso: stoppedAtIso,\n1820:       status: 'partial',\n1821:       ...partial.summary,\n1822:       gauges,\n1823:       results: partial.results,\n1824:     });\n1825:   };\n1826: \n1827:   installFanoutSignalHandlers(writeStoppedSummary);\n1828: \n1829:   const { results, summary } = await runCappedPool({\n1830:     items: cliLineages,\n1831:     concurrency: fanoutConfig.concurrency,\n1832:     maxRetries: fanoutConfig.maxRetries,\n1833:     lagCeilingMs: fanoutConfig.lagCeilingMs,\n1834:     postExitGraceMs,\n1835:     initialRetryCounts,\n1836:     getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n1837:     onEvent: (event) => {\n1838:       const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n1839:       updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n1840:       if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n1841:       appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n1842:     },\n1843:     worker: async (lineage, context) => {\n1844:       const slotWindowStartIso = new Date().toISOString();\n1845:       const hrStart = process.hrtime();\n1846:       const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n1847:       const livenessKey = `${lineage.label}:${attempt}`;\n1848:       const lineageDir = path.join(lineagesDir, lineage.label);\n1849:       const stateDir = path.join(lineageDir, '.executor-state');\n1850:       fs.mkdirSync(lineageDir, { recursive: true });\n1851:       fs.mkdirSync(stateDir, { recursive: true });\n1852: \n1853:       const budgetDecision = evaluateLineageBudgetCap({\n1854:         lineage,\n1855:         guards: lineageBudgetGuards,\n1856:         maxRetries: fanoutConfig.maxRetries,\n1857:       });\n1858:       if (!budgetDecision.continue_allowed) {\n1859:         appendFanoutStatusLedger(ledgerPath, {\n1860:           event: 'budget_cap_exceeded',\n1861:           label: lineage.label,\n1862:           at: new Date().toISOString(),\n1863:           severity: 'error',\n1864:           stop_reasons: budgetDecision.stop_reasons,\n1865:           upper_bound: budgetDecision.upper_bound,\n1866:           gauges: latestGauges,\n1867:         });\n1868:         const failure = new Error(\n1869:           `lineage ${lineage.label} exceeds configured budget cap: `\n1870:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1871:         );\n1872:         failure.label = lineage.label;\n1873:         failure.exitCode = null;\n1874:         failure.timedOut = false;\n1875:         failure.budgetCap = budgetDecision;\n1876:         throw failure;\n1877:       }\n1878: \n1879:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1880:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1881:         convergenceThreshold,\n1882:         stopPolicy,\n1883:       });\n1884: \n1885:       // Sandbox resolution stays write-capable by default even for review lineages:\n1886:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1887:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1888:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1889:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1890:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1891:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1892:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1893:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1894: \n1895:       const effectiveSandbox = resolvedSandbox;\n1896:       const effectivePermission = resolvedPermission;\n1897: \n1898:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1899:         lineage,\n1900:         prompt,\n1901:         effectiveSandbox,\n1902:         effectivePermission,\n1903:         {\n1904:           loopType,\n1905:           specFolder,\n1906:           lineageDir,\n1907:           sessionId,\n1908:           convergenceThreshold,\n1909:           stopPolicy,\n1910:           researchTopic,\n1911:         },\n1912:       );\n1913: \n1914:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1915:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1916:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1917:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1918:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1919:       // is deliberately avoided here because relocating the home breaks credential/auth\n1920:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1921:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1922:       const extraEnv = {\n1923:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1924:         // A fan-out lineage is an orchestrated sub-session running an autonomous\n1925:         // workflow: it has no user turn to answer Gate 3, so the spec-gate must be\n1926:         // fully inert. ENFORCE=0 alone is NOT enough — that only stops the deny, while\n1927:         // the classify step still injects the Gate-3 question, which a cli-opencode\n1928:         // child then answers instead of doing its work. DISABLED makes both classify\n1929:         // and enforce no-ops; AI_SESSION_CHILD lets the worktree wrapper exec in place.\n1930:         // buildExecutorDispatchEnv filters these keys (outside the per-kind allowlist),\n1931:         // so they are re-injected here to reach the child. Harmless for the codex path.\n1932:         MK_SPEC_GATE_DISABLED: '1',\n1933:         AI_SESSION_CHILD: '1',\n1934:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1935:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1936:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1937:           : {}),\n1938:       };\n1939: \n1940:       // Recursion guard (fail closed): the executor stack can already name the hosting\n1941:       // runtime before the first detached fan-out spawn. The lineage marker is added only\n1942:       // to a spawned seat, so both signals are required to prove that a seat is trying to\n1943:       // fan out its own executor kind again.\n1944:       const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n1945:       const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n1946:         && inheritedLineageId.trim() !== '';\n1947:       if (\n1948:         isInsideFanoutLineage\n1949:         && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n1950:       ) {\n1951:         throw new Error(\n1952:           `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n1953:         );\n1954:       }\n1955: \n1956:       // Stamp the dispatch stack with this lineage's executor kind so a seat that\n1957:       // tries to recursively launch the same kind is detectable by the runtime\n1958:       // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n1959:       // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n1960:       // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n1961:       // preserve the per-replica lockfile isolation they provide.\n1962:       const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n1963: \n1964:       const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n1965:       let lastLineageEventAtMs = Date.now();\n1966:       const markLineageEvent = () => {\n1967:         lastLineageEventAtMs = Date.now();\n1968:       };\n1969:       const stopStallWatchdog = startLineageStallWatchdog({\n1970:         thresholdMs: stallWatchdogMs,\n1971:         label: lineage.label,\n1972:         ledgerPath,\n1973:         getLastEventAtMs: () => lastLineageEventAtMs,\n1974:         getGauges: () => latestGauges,\n1975:       });\n1976: \n1977:       const stopProgressHeartbeat = startLineageProgressHeartbeat({\n1978:         cadenceMs: progressHeartbeatMs,\n1979:         label: lineage.label,\n1980:         ledgerPath,\n1981:         getGauges: () => latestGauges,\n1982:       });\n1983:       let result;\n1984:       try {\n1985:         result = await runLineageProcess(command, cmdArgs, {\n1986:           cwd: process.cwd(),\n1987:           timeoutMs,\n1988:           env: dispatchEnv,\n1989:           maxBuffer: 20 * 1024 * 1024,\n1990:           abortSignal: context.signal,\n1991:           onOutput: markLineageEvent,\n1992:           onSpawn: ({ pid }) => {\n1993:             lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n1994:           },\n1995:           onExit: ({ pid, exitedAtMs }) => {\n1996:             lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n1997:           },\n1998:           ...(typeof input === 'string' ? { input } : {}),\n1999:         });\n2000:       } finally {\n2001:         stopProgressHeartbeat();\n2002:         stopStallWatchdog();\n2003:       }\n2004: \n2005:       // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n2006:       const logsDir = path.join(lineageDir, 'logs');\n2007:       fs.mkdirSync(logsDir, { recursive: true });\n2008:       const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n2009:       fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n2010: \n2011:       // Recover missing iteration files from captured stdout when possible. Runs\n2012:       // BEFORE the failure throw below so iteration recovery is never lost.\n2013:       const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n2014:       const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n2015:       lineageSlotAccounting.set(lineage.label, slotAccounting);\n2016: \n2017:       const exitCode = result.status ?? (result.error ? 1 : 0);\n2018:       const timedOut = result.signal === 'SIGTERM';\n2019:       // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n2020:       // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n2021:       // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n2022:       const killedBySignal = result.signal != null;\n2023:       const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n2024:       const stateRead = readLineageStateRecords(loopType, lineageDir);\n2025:       const stopPolicyViolation = findMaxIterationsPolicyViolation({\n2026:         loopType,\n2027:         stateRead,\n2028:         lineage,\n2029:         stopPolicy,\n2030:       });\n2031: \n2032:       // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n2033:       // not a success. Throw so the pool settles this item as rejected and counts it\n2034:       // in summary.failed/all_failed, which drives the process exit code. Returning a\n2035:       // plain object here would let the pool record any completed worker as fulfilled\n2036:       // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n2037:       if (timedOut || killedBySignal || exitCode !== 0) {\n2038:         const reason = timedOut\n2039:           ? 'timed out'\n2040:           : killedBySignal\n2041:             ? `killed by signal ${result.signal}`\n2042:             : `exited with code ${exitCode}`;\n2043:         const failure = new Error(`lineage ${lineage.label} ${reason}`);\n2044:         failure.label = lineage.label;\n2045:         failure.exitCode = exitCode;\n2046:         failure.timedOut = timedOut;\n2047:         failure.killedBySignal = killedBySignal;\n2048:         failure.salvage = salvage;\n2049:         throw failure;\n2050:       }\n2051: \n2052:       if (missingArtifacts.length > 0) {\n2053:         const failure = new Error(\n2054:           `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n2055:         );\n2056:         failure.label = lineage.label;\n2057:         failure.exitCode = exitCode;\n2058:         failure.timedOut = false;\n2059:         failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n2060:         failure.missingArtifacts = missingArtifacts;\n2061:         throw failure;\n2062:       }\n2063: \n2064:       if (stopPolicyViolation) {\n2065:         const failure = new Error(\n2066:           `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n2067:         );\n2068:         failure.label = lineage.label;\n2069:         failure.exitCode = exitCode;\n2070:         failure.timedOut = false;\n2071:         failure.salvage = salvage;\n2072:         failure.stopPolicyViolation = stopPolicyViolation;\n2073:         throw failure;\n2074:       }\n2075: \n2076:       // An exit-0 lineage whose salvage sweep could not recover every iteration\n2077:       // markdown is NOT fulfilled, even when the top-level report exists. Returning\n2078:       // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n2079:       // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n2080:       // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n2081:       if (salvage && salvage.failed > 0) {\n2082:         const failure = new Error(\n2083:           `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n2084:         );\n2085:         failure.label = lineage.label;\n2086:         failure.exitCode = exitCode;\n2087:         failure.timedOut = false;\n2088:         failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n2089:         failure.missingArtifacts = [];\n2090:         throw failure;\n2091:       }\n2092: \n2093:       const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n2094:       if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n2095:         const slotWindowEndIso = new Date().toISOString();\n2096:         try {\n2097:           const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n2098:             windowStart: slotWindowStartIso,\n2099:             windowEnd: slotWindowEndIso,\n2100:             toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n2101:           });\n2102:           if (timestampCheck.anomalous > 0) {\n2103:             const timestampAnomaly = buildTimestampAnomalyPayload({\n2104:               lineage,\n2105:               statePath: stateRead.statePath,\n2106:               check: timestampCheck,\n2107:             });\n2108:             appendFanoutStatusLedger(ledgerPath, {\n2109:               event: 'timestamp_anomaly',\n2110:               status: 'warning',\n2111:               severity: 'warning',\n2112:               label: lineage.label,\n2113:               at: new Date().toISOString(),\n2114:               ...timestampAnomaly,\n2115:             });\n2116:             output.timestamp_anomaly = timestampAnomaly;\n2117:           }\n2118:         } catch {\n2119:           // Timestamp telemetry is advisory and cannot affect lineage fulfillment.\n2120:         }\n2121:       }\n2122: \n2123:       return output;\n2124:     },\n2125:   });\n2126: \n2127:   const timestampAnomalies = collectTimestampAnomalies(results);\n2128:   const finalSummary = timestampAnomalies.length > 0\n2129:     ? { ...summary, timestamp_anomalies: timestampAnomalies }\n2130:     : summary;\n2131: \n2132:   writeOrchestrationSummary(summaryPath, {\n2133:     run_id: runId,\n2134:     loop_type: loopType,\n2135:     spec_folder: specFolder,\n2136:     base_artifact_dir: baseArtifactDir,\n2137:     total_cli_lineages: cliLineages.length,\n2138:     orphaned_lineages: orphanedLineages,\n2139:     ...finalSummary,\n2140:   });\n2141: \n2142:   const exitCode = finalSummary.all_failed ? 3 : finalSummary.failed > 0 ? 2 : 0;\n2143:   jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary: finalSummary });\n2144:   process.exit(exitCode);\n2145: }\n2146: \n2147: if (require.main === module && isTsxLoaded) {\n2148:   main().catch((err) => {\n2149:     const code = classifyExitCode(err);\n2150:     jsonOut({\n2151:       status: 'error',\n2152:       error: err instanceof Error ? err.message : String(err),\n2153:       code: err && err.code ? err.code : 'SCRIPT_ERROR',\n2154:     });\n2155:     if (code === 1) {\n2156:       process.stderr.write(\n2157:         JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n2158:       );\n2159:     }\n2160:     process.exit(code);\n2161:   });\n2162: }\n2163: \n2164: module.exports = {\n2165:   buildLineageCommand,\n2166:   buildInvocationFingerprintPayload,\n2167:   isCodexBinaryAvailable,\n2168:   buildLoopPrompt,\n2169:   findMaxIterationsPolicyViolation,\n2170:   isMaxIterationsStopReason,\n2171:   computeLineageTimeoutMs,\n2172:   assertLineageTimeoutHoursOverrideWithinCeiling,\n2173:   computeLineageBudgetUpperBound,\n2174:   evaluateLineageBudgetCap,\n2175:   computeAggregateBudgetUpperBound,\n2176:   evaluateAggregateBudgetCap,\n2177:   normalizeAggregateBudgetGuards,\n2178:   normalizeProgressHeartbeatMs,\n2179:   normalizePostExitGraceMs,\n2180:   normalizeLineageBudgetGuards,\n2181:   normalizeStallWatchdogMs,\n2182:   computeSkippedCount,\n2183:   decorateSlotAccountingEvent,\n2184:   startLineageProgressHeartbeat,\n2185:   startLineageStallWatchdog,\n2186:   statusForLedgerEvent,\n2187:   updateLineageSnapshot,\n2188:   applyFlatPoolAssignmentGuard,\n2189: };\n\n(End of file - total 2189 lines)\n</content>","metadata":{"preview":"    const gauges = {\n      lag: latestGauges.lag,\n      pending: latestGauges.pending,\n      failed: Math.max(latestGauges.failed, partial.summary.failed),\n    };\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'stopped',\n      signal,\n      at: stoppedAtIso,\n      gauges,\n    });\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: cliLineages.length,\n      stopped: true,\n      stopped_signal: signal,\n      stopped_at_iso: stoppedAtIso,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"    const gauges = {\n      lag: latestGauges.lag,\n      pending: latestGauges.pending,\n      failed: Math.max(latestGauges.failed, partial.summary.failed),\n    };\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'stopped',\n      signal,\n      at: stoppedAtIso,\n      gauges,\n    });\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: cliLineages.length,\n      stopped: true,\n      stopped_signal: signal,\n      stopped_at_iso: stoppedAtIso,\n      status: 'partial',\n      ...partial.summary,\n      gauges,\n      results: partial.results,\n    });\n  };\n\n  installFanoutSignalHandlers(writeStoppedSummary);\n\n  const { results, summary } = await runCappedPool({\n    items: cliLineages,\n    concurrency: fanoutConfig.concurrency,\n    maxRetries: fanoutConfig.maxRetries,\n    lagCeilingMs: fanoutConfig.lagCeilingMs,\n    postExitGraceMs,\n    initialRetryCounts,\n    getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n    onEvent: (event) => {\n      const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n      updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n      if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n      appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n    },\n    worker: async (lineage, context) => {\n      const slotWindowStartIso = new Date().toISOString();\n      const hrStart = process.hrtime();\n      const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n      const livenessKey = `${lineage.label}:${attempt}`;\n      const lineageDir = path.join(lineagesDir, lineage.label);\n      const stateDir = path.join(lineageDir, '.executor-state');\n      fs.mkdirSync(lineageDir, { recursive: true });\n      fs.mkdirSync(stateDir, { recursive: true });\n\n      const budgetDecision = evaluateLineageBudgetCap({\n        lineage,\n        guards: lineageBudgetGuards,\n        maxRetries: fanoutConfig.maxRetries,\n      });\n      if (!budgetDecision.continue_allowed) {\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'budget_cap_exceeded',\n          label: lineage.label,\n          at: new Date().toISOString(),\n          severity: 'error',\n          stop_reasons: budgetDecision.stop_reasons,\n          upper_bound: budgetDecision.upper_bound,\n          gauges: latestGauges,\n        });\n        const failure = new Error(\n          `lineage ${lineage.label} exceeds configured budget cap: `\n            + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = null;\n        failure.timedOut = false;\n        failure.budgetCap = budgetDecision;\n        throw failure;\n      }\n\n      const sessionId = `fanout-${lineage.label}-${runId}`;\n      const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n        convergenceThreshold,\n        stopPolicy,\n      });\n\n      // Sandbox resolution stays write-capable by default even for review lineages:\n      // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n      // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n      // blanket read-only default would break those writes. The lineageDir-only write boundary\n      // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n      // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n      // exposed one. Callers can still pass an explicit sandboxMode to override.\n      const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n      const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n\n      const effectiveSandbox = resolvedSandbox;\n      const effectivePermission = resolvedPermission;\n\n      const { command, args: cmdArgs, input } = buildLineageCommand(\n        lineage,\n        prompt,\n        effectiveSandbox,\n        effectivePermission,\n        {\n          loopType,\n          specFolder,\n          lineageDir,\n          sessionId,\n          convergenceThreshold,\n          stopPolicy,\n          researchTopic,\n        },\n      );\n\n      // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n      // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n      // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n      // native lockfile. Real same-kind-replica isolation comes from each lineage's\n      // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n      // is deliberately avoided here because relocating the home breaks credential/auth\n      // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n      const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n      const extraEnv = {\n        SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n        // A fan-out lineage is an orchestrated sub-session running an autonomous\n        // workflow: it has no user turn to answer Gate 3, so the spec-gate must be\n        // fully inert. ENFORCE=0 alone is NOT enough — that only stops the deny, while\n        // the classify step still injects the Gate-3 question, which a cli-opencode\n        // child then answers instead of doing its work. DISABLED makes both classify\n        // and enforce no-ops; AI_SESSION_CHILD lets the worktree wrapper exec in place.\n        // buildExecutorDispatchEnv filters these keys (outside the per-kind allowlist),\n        // so they are re-injected here to reach the child. Harmless for the codex path.\n        MK_SPEC_GATE_DISABLED: '1',\n        AI_SESSION_CHILD: '1',\n        ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n        ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n          ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n          : {}),\n      };\n\n      // Recursion guard (fail closed): the executor stack can already name the hosting\n      // runtime before the first detached fan-out spawn. The lineage marker is added only\n      // to a spawned seat, so both signals are required to prove that a seat is trying to\n      // fan out its own executor kind again.\n      const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n      const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n        && inheritedLineageId.trim() !== '';\n      if (\n        isInsideFanoutLineage\n        && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n      ) {\n        throw new Error(\n          `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n        );\n      }\n\n      // Stamp the dispatch stack with this lineage's executor kind so a seat that\n      // tries to recursively launch the same kind is detectable by the runtime\n      // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n      // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n      // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n      // preserve the per-replica lockfile isolation they provide.\n      const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n\n      const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n      let lastLineageEventAtMs = Date.now();\n      const markLineageEvent = () => {\n        lastLineageEventAtMs = Date.now();\n      };\n      const stopStallWatchdog = startLineageStallWatchdog({\n        thresholdMs: stallWatchdogMs,\n        label: lineage.label,\n        ledgerPath,\n        getLastEventAtMs: () => lastLineageEventAtMs,\n        getGauges: () => latestGauges,\n      });\n\n      const stopProgressHeartbeat = startLineageProgressHeartbeat({\n        cadenceMs: progressHeartbeatMs,\n        label: lineage.label,\n        ledgerPath,\n        getGauges: () => latestGauges,\n      });\n      let result;\n      try {\n        result = await runLineageProcess(command, cmdArgs, {\n          cwd: process.cwd(),\n          timeoutMs,\n          env: dispatchEnv,\n          maxBuffer: 20 * 1024 * 1024,\n          abortSignal: context.signal,\n          onOutput: markLineageEvent,\n          onSpawn: ({ pid }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n          },\n          onExit: ({ pid, exitedAtMs }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n          },\n          ...(typeof input === 'string' ? { input } : {}),\n        });\n      } finally {\n        stopProgressHeartbeat();\n        stopStallWatchdog();\n      }\n\n      // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n      const logsDir = path.join(lineageDir, 'logs');\n      fs.mkdirSync(logsDir, { recursive: true });\n      const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n      fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n\n      // Recover missing iteration files from captured stdout when possible. Runs\n      // BEFORE the failure throw below so iteration recovery is never lost.\n      const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n      const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n      lineageSlotAccounting.set(lineage.label, slotAccounting);\n\n      const exitCode = result.status ?? (result.error ? 1 : 0);\n      const timedOut = result.signal === 'SIGTERM';\n      // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n      // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n      // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n      const killedBySignal = result.signal != null;\n      const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n      const stateRead = readLineageStateRecords(loopType, lineageDir);\n      const stopPolicyViolation = findMaxIterationsPolicyViolation({\n        loopType,\n        stateRead,\n        lineage,\n        stopPolicy,\n      });\n\n      // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n      // not a success. Throw so the pool settles this item as rejected and counts it\n      // in summary.failed/all_failed, which drives the process exit code. Returning a\n      // plain object here would let the pool record any completed worker as fulfilled\n      // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n      if (timedOut || killedBySignal || exitCode !== 0) {\n        const reason = timedOut\n          ? 'timed out'\n          : killedBySignal\n            ? `killed by signal ${result.signal}`\n            : `exited with code ${exitCode}`;\n        const failure = new Error(`lineage ${lineage.label} ${reason}`);\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = timedOut;\n        failure.killedBySignal = killedBySignal;\n        failure.salvage = salvage;\n        throw failure;\n      }\n\n      if (missingArtifacts.length > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n        failure.missingArtifacts = missingArtifacts;\n        throw failure;\n      }\n\n      if (stopPolicyViolation) {\n        const failure = new Error(\n          `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = salvage;\n        failure.stopPolicyViolation = stopPolicyViolation;\n        throw failure;\n      }\n\n      // An exit-0 lineage whose salvage sweep could not recover every iteration\n      // markdown is NOT fulfilled, even when the top-level report exists. Returning\n      // here would let a lineage with a fanout_salvage_failed marker pass as complete,\n      // dropping durable per-iteration evidence from merge/synthesis. Throw so the\n      // pool retries it (the classifier maps salvage.failed > 0 to artifact_miss).\n      if (salvage && salvage.failed > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but ${salvage.failed} iteration markdown file(s) were unrecoverable`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: salvage.failed };\n        failure.missingArtifacts = [];\n        throw failure;\n      }\n\n      const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n      if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n        const slotWindowEndIso = new Date().toISOString();\n        try {\n          const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n            windowStart: slotWindowStartIso,\n            windowEnd: slotWindowEndIso,\n            toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n          });\n          if (timestampCheck.anomalous > 0) {\n            const timestampAnomaly = buildTimestampAnomalyPayload({\n              lineage,\n              statePath: stateRead.statePath,\n              check: timestampCheck,\n            });\n            appendFanoutStatusLedger(ledgerPath, {\n              event: 'timestamp_anomaly',\n              status: 'warning',\n              severity: 'warning',\n              label: lineage.label,\n              at: new Date().toISOString(),\n              ...timestampAnomaly,\n            });\n            output.timestamp_anomaly = timestampAnomaly;\n          }\n        } catch {\n          // Timestamp telemetry is advisory and cannot affect lineage fulfillment.\n        }\n      }\n\n      return output;\n    },\n  });\n\n  const timestampAnomalies = collectTimestampAnomalies(results);\n  const finalSummary = timestampAnomalies.length > 0\n    ? { ...summary, timestamp_anomalies: timestampAnomalies }\n    : summary;\n\n  writeOrchestrationSummary(summaryPath, {\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    base_artifact_dir: baseArtifactDir,\n    total_cli_lineages: cliLineages.length,\n    orphaned_lineages: orphanedLineages,\n    ...finalSummary,\n  });\n\n  const exitCode = finalSummary.all_failed ? 3 : finalSummary.failed > 0 ? 2 : 0;\n  jsonOut({ status: exitCode === 0 ? 'ok' : 'partial', run_id: runId, results, summary: finalSummary });\n  process.exit(exitCode);\n}\n\nif (require.main === module && isTsxLoaded) {\n  main().catch((err) => {\n    const code = classifyExitCode(err);\n    jsonOut({\n      status: 'error',\n      error: err instanceof Error ? err.message : String(err),\n      code: err && err.code ? err.code : 'SCRIPT_ERROR',\n    });\n    if (code === 1) {\n      process.stderr.write(\n        JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n      );\n    }\n    process.exit(code);\n  });\n}\n\nmodule.exports = {\n  buildLineageCommand,\n  buildInvocationFingerprintPayload,\n  isCodexBinaryAvailable,\n  buildLoopPrompt,\n  findMaxIterationsPolicyViolation,\n  isMaxIterationsStopReason,\n  computeLineageTimeoutMs,\n  assertLineageTimeoutHoursOverrideWithinCeiling,\n  computeLineageBudgetUpperBound,\n  evaluateLineageBudgetCap,\n  computeAggregateBudgetUpperBound,\n  evaluateAggregateBudgetCap,\n  normalizeAggregateBudgetGuards,\n  normalizeProgressHeartbeatMs,\n  normalizePostExitGraceMs,\n  normalizeLineageBudgetGuards,\n  normalizeStallWatchdogMs,\n  computeSkippedCount,\n  decorateSlotAccountingEvent,\n  startLineageProgressHeartbeat,\n  startLineageStallWatchdog,\n  statusForLedgerEvent,\n  updateLineageSnapshot,\n  applyFlatPoolAssignmentGuard,\n};","lineStart":1800,"lineEnd":2189,"totalLines":2189,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784691903461,"end":1784691903470}},"metadata":{"openai":{"itemId":"fc_0b2dab001a726f60016a603cbf686c81919e397ebd1a082d91"}},"id":"prt_f87ed4be3001p0KB69GBg3jnlJ","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87ed24f7001u3ydhOZ0IX5WT3"}}
