       \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Research Phase Index This\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"research/research.md\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"Spec Kit has coordinated refinement work across memory correctness, indexing, causal graph hygiene, trigger matching, learning feedback, and documentation/process quality. These topics share operational surfaces but have independent delivery risks, so they need a parent control document that points to child phase folders without duplicating implementation detail.\",\n    \"created_at\": \"2026-05-08T00:00:00Z\",\n    \"last_save_at\": \"2026-06-12T11:12:59.453Z\",\n    \"save_lineage\": \"graph_only\",\n    \"last_accessed_at\": \"2026-05-10T10:05:44.449Z\",\n    \"source_docs\": [\n      \"spec.md\",\n      \"research/research.md\",\n      \"handover.md\",\n      \"resource-map.md\"\n    ],\n    \"last_active_child_id\": \"system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation\",\n    \"last_active_at\": \"2026-06-14T00:00:00Z\"\n  }\n}","lineStart":1,"lineEnd":234,"totalLines":234,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/graph-metadata.json","time":{"start":1781422722802,"end":1781422722805}},"id":"prt_ec5118ef0001vs0RHgfsF2PjGe","sessionID":"ses_13aef63ccffel7tpaI1Dzxs3uq","messageID":"msg_ec5117fe7001504hdU4s3YKtSf"}}
