{"type":"tool_use","timestamp":1780925362224,"sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","part":{"type":"tool","tool":"read","callID":"call_ys4IaiBqn1SeSs87XHgSbcrZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-prime.ts","offset":261,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-prime.ts</path>\n<type>file</type>\n<content>\n261:     });\n262:   }\n263: \n264:   if (sessionContinuity) {\n265:     sections.push({\n266:       title: 'Session Continuity',\n267:       content: sessionContinuity,\n268:     });\n269:   }\n270: \n271:   if (startupBrief?.graphState === 'stale') {\n272:     sections.push({\n273:       title: 'Stale Code Graph Warning',\n274:       content: 'Code graph freshness is stale. The first structural read may refresh inline when safe; run `code_graph_scan` for broader stale states.',\n275:     });\n276:   }\n277: \n278:   return sections;\n279: }\n280: \n281: /** Handle source=resume: load resume context for continued session */\n282: function handleResume(sessionId: string): OutputSection[] {\n283:   const stateResult = loadState(sessionId);\n284:   const state = stateResult.ok ? stateResult.state : null;\n285:   const sections: OutputSection[] = [];\n286: \n287:   if (state?.lastSpecFolder) {\n288:     sections.push({\n289:       title: 'Session Continuity',\n290:       content: `Last active spec folder: ${state.lastSpecFolder}\\nCall \\`memory_context({ input: \"resume previous work\", mode: \"resume\", profile: \"resume\" })\\` for full context.`,\n291:     });\n292:   } else {\n293:     sections.push({\n294:       title: 'Session Resume',\n295:       content: 'Call `memory_context({ input: \"resume previous work\", mode: \"resume\", profile: \"resume\" })` to restore session state.',\n296:     });\n297:   }\n298: \n299:   return sections;\n300: }\n301: \n302: /** Handle source=clear: minimal output after /clear */\n303: function handleClear(): OutputSection[] {\n304:   return [\n305:     {\n306:       title: 'Fresh Context',\n307:       content: 'Session cleared. Spec Kit Memory is active. Use `memory_context` or `memory_match_triggers` to load relevant context.',\n308:     },\n309:   ];\n310: }\n311: \n312: function writeHookOutput(output: string): Promise<void> {\n313:   return new Promise<void>((resolvePromise, rejectPromise) => {\n314:     process.stdout.write(output, (error) => {\n315:       if (error) {\n316:         rejectPromise(error);\n317:         return;\n318:       }\n319: \n320:       resolvePromise();\n321:     });\n322:   });\n323: }\n324: \n325: async function main(): Promise<void> {\n326:   ensureStateDir();\n327: \n328:   const input = await withTimeout(parseHookStdin(), HOOK_TIMEOUT_MS, null);\n329:   if (!input) {\n330:     hookLog('warn', 'session-prime', 'No stdin input received');\n331:     return;\n332:   }\n333: \n334:   const sessionId = getRequiredSessionId(input.session_id, 'session-prime');\n335:   const source = input.source ?? 'startup';\n336:   hookLog('info', 'session-prime', `SessionStart triggered (source: ${source}, session: ${sessionId})`);\n337: \n338:   let sections: OutputSection[];\n339:   let budget: number;\n340:   let compactIdentity: { cachedAt: string; opaqueId?: string | null } | null = null;\n341: \n342:   switch (source) {\n343:     case 'compact':\n344:       compactIdentity = readCompactPrimeIdentity(sessionId);\n345:       sections = handleCompact(sessionId);\n346:       budget = COMPACTION_TOKEN_BUDGET;\n347:       break;\n348:     case 'startup':\n349:       sections = handleStartup(input);\n350:       budget = SESSION_PRIME_TOKEN_BUDGET;\n351:       break;\n352:     case 'resume':\n353:       sections = handleResume(sessionId);\n354:       budget = SESSION_PRIME_TOKEN_BUDGET;\n355:       break;\n356:     case 'clear':\n357:       sections = handleClear();\n358:       budget = SESSION_PRIME_TOKEN_BUDGET;\n359:       break;\n360:     default:\n361:       sections = handleStartup(input);\n362:       budget = SESSION_PRIME_TOKEN_BUDGET;\n363:   }\n364: \n365:   // Apply token pressure awareness — reduce budget when context window is filling up\n366:   const adjustedBudget = calculatePressureAdjustedBudget(\n367:     input.context_window_tokens as number | undefined,\n368:     input.context_window_max as number | undefined,\n369:     budget,\n370:   );\n371:   if (adjustedBudget !== budget) {\n372:     hookLog('info', 'session-prime', `Token pressure: budget ${budget} → ${adjustedBudget} (window ${input.context_window_tokens}/${input.context_window_max})`);\n373:   }\n374: \n375:   const output = truncateToTokenBudget(formatHookOutput(sections), adjustedBudget);\n376: \n377:   // Write to stdout for Claude Code to inject into conversation.\n378:   // Clear compact payload only after the write callback confirms the\n379:   // output was handed off, so compact recovery cannot be dropped early.\n380:   await writeHookOutput(output);\n381:   if (source === 'compact') {\n382:     clearCompactPrime(sessionId, compactIdentity ?? undefined);\n383:   }\n384:   hookLog('info', 'session-prime', `Output ${output.length} chars for source=${source}`);\n385: }\n386: \n387: // Run — exit cleanly even on error\n388: if (IS_CLI_ENTRY) {\n389:   main().catch((err: unknown) => {\n390:     hookLog('error', 'session-prime', `Unhandled error: ${err instanceof Error ? err.message : String(err)}`);\n391:   }).finally(() => {\n392:     process.exit(0);\n393:   });\n394: }\n\n(End of file - total 394 lines)\n</content>","metadata":{"preview":"    });\n  }\n\n  if (sessionContinuity) {\n    sections.push({\n      title: 'Session Continuity',\n      content: sessionContinuity,\n    });\n  }\n\n  if (startupBrief?.graphState === 'stale') {\n    sections.push({\n      title: 'Stale Code Graph Warning',\n      content: 'Code graph freshness is stale. The first structural read may refresh inline when safe; run `code_graph_scan` for broader stale states.',\n    });\n  }\n\n  return sections;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-prime.ts","text":"    });\n  }\n\n  if (sessionContinuity) {\n    sections.push({\n      title: 'Session Continuity',\n      content: sessionContinuity,\n    });\n  }\n\n  if (startupBrief?.graphState === 'stale') {\n    sections.push({\n      title: 'Stale Code Graph Warning',\n      content: 'Code graph freshness is stale. The first structural read may refresh inline when safe; run `code_graph_scan` for broader stale states.',\n    });\n  }\n\n  return sections;\n}\n\n/** Handle source=resume: load resume context for continued session */\nfunction handleResume(sessionId: string): OutputSection[] {\n  const stateResult = loadState(sessionId);\n  const state = stateResult.ok ? stateResult.state : null;\n  const sections: OutputSection[] = [];\n\n  if (state?.lastSpecFolder) {\n    sections.push({\n      title: 'Session Continuity',\n      content: `Last active spec folder: ${state.lastSpecFolder}\\nCall \\`memory_context({ input: \"resume previous work\", mode: \"resume\", profile: \"resume\" })\\` for full context.`,\n    });\n  } else {\n    sections.push({\n      title: 'Session Resume',\n      content: 'Call `memory_context({ input: \"resume previous work\", mode: \"resume\", profile: \"resume\" })` to restore session state.',\n    });\n  }\n\n  return sections;\n}\n\n/** Handle source=clear: minimal output after /clear */\nfunction handleClear(): OutputSection[] {\n  return [\n    {\n      title: 'Fresh Context',\n      content: 'Session cleared. Spec Kit Memory is active. Use `memory_context` or `memory_match_triggers` to load relevant context.',\n    },\n  ];\n}\n\nfunction writeHookOutput(output: string): Promise<void> {\n  return new Promise<void>((resolvePromise, rejectPromise) => {\n    process.stdout.write(output, (error) => {\n      if (error) {\n        rejectPromise(error);\n        return;\n      }\n\n      resolvePromise();\n    });\n  });\n}\n\nasync function main(): Promise<void> {\n  ensureStateDir();\n\n  const input = await withTimeout(parseHookStdin(), HOOK_TIMEOUT_MS, null);\n  if (!input) {\n    hookLog('warn', 'session-prime', 'No stdin input received');\n    return;\n  }\n\n  const sessionId = getRequiredSessionId(input.session_id, 'session-prime');\n  const source = input.source ?? 'startup';\n  hookLog('info', 'session-prime', `SessionStart triggered (source: ${source}, session: ${sessionId})`);\n\n  let sections: OutputSection[];\n  let budget: number;\n  let compactIdentity: { cachedAt: string; opaqueId?: string | null } | null = null;\n\n  switch (source) {\n    case 'compact':\n      compactIdentity = readCompactPrimeIdentity(sessionId);\n      sections = handleCompact(sessionId);\n      budget = COMPACTION_TOKEN_BUDGET;\n      break;\n    case 'startup':\n      sections = handleStartup(input);\n      budget = SESSION_PRIME_TOKEN_BUDGET;\n      break;\n    case 'resume':\n      sections = handleResume(sessionId);\n      budget = SESSION_PRIME_TOKEN_BUDGET;\n      break;\n    case 'clear':\n      sections = handleClear();\n      budget = SESSION_PRIME_TOKEN_BUDGET;\n      break;\n    default:\n      sections = handleStartup(input);\n      budget = SESSION_PRIME_TOKEN_BUDGET;\n  }\n\n  // Apply token pressure awareness — reduce budget when context window is filling up\n  const adjustedBudget = calculatePressureAdjustedBudget(\n    input.context_window_tokens as number | undefined,\n    input.context_window_max as number | undefined,\n    budget,\n  );\n  if (adjustedBudget !== budget) {\n    hookLog('info', 'session-prime', `Token pressure: budget ${budget} → ${adjustedBudget} (window ${input.context_window_tokens}/${input.context_window_max})`);\n  }\n\n  const output = truncateToTokenBudget(formatHookOutput(sections), adjustedBudget);\n\n  // Write to stdout for Claude Code to inject into conversation.\n  // Clear compact payload only after the write callback confirms the\n  // output was handed off, so compact recovery cannot be dropped early.\n  await writeHookOutput(output);\n  if (source === 'compact') {\n    clearCompactPrime(sessionId, compactIdentity ?? undefined);\n  }\n  hookLog('info', 'session-prime', `Output ${output.length} chars for source=${source}`);\n}\n\n// Run — exit cleanly even on error\nif (IS_CLI_ENTRY) {\n  main().catch((err: unknown) => {\n    hookLog('error', 'session-prime', `Unhandled error: ${err instanceof Error ? err.message : String(err)}`);\n  }).finally(() => {\n    process.exit(0);\n  });\n}","lineStart":261,"lineEnd":394,"totalLines":394,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-prime.ts","time":{"start":1780925362217,"end":1780925362223}},"metadata":{"openai":{"itemId":"fc_0af58c7fe06e7d49016a26c3b123ec8191b2a91ac668e6e151"}},"id":"prt_ea76c6c5c001ULMGPbyyRCsP4z","sessionID":"ses_158954ac7ffeX00Y2fH37dXkNJ","messageID":"msg_ea76c618b0016yxHBHKQTJv4Do"}}
