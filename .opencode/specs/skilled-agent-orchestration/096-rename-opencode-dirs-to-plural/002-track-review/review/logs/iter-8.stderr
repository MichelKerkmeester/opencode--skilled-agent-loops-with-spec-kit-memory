    DESCRIPTION_HARD_CAP = 1536
    DESCRIPTION_SOFT_TARGET_SKILL = 130
    DESCRIPTION_SOFT_TARGET_COMMAND = 110

    def strip_matching_quotes(value: str) -> str:
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ('"', "'"):
            return value[1:-1]
        return value


