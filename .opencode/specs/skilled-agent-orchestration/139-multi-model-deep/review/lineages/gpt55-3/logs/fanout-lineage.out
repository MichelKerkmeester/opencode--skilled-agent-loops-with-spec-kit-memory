{"type":"step_start","timestamp":1780906977822,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"id":"prt_ea653ea19001yarfjermK5l2id","messageID":"msg_ea653e373001s3WicIAjm4qipO","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","snapshot":"d5ef4db07cf2cf64620921516ba04f13c90f15f6","type":"step-start"}}
{"type":"text","timestamp":1780906985446,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"id":"prt_ea653f1a9001a3qAoVYg8XO51y","messageID":"msg_ea653e373001s3WicIAjm4qipO","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","type":"text","text":"The workflow contract confirms the override should bind `artifact_dir` directly and that max-iterations is a terminal stop, so this lineage can synthesize after one iteration even without full dimension coverage.","time":{"start":1780906979753,"end":1780906985433},"metadata":{"openai":{"itemId":"msg_06766d70ffa8e198016a267be3c0b08191909f32929e151809","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780906985608,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_v7LU4AX9mVjEllMAuAlP8Pck","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_start-review-loop_auto.yaml","offset":636,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_start-review-loop_auto.yaml</path>\n<type>file</type>\n<content>\n636:           append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n637:           log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n638:         if_not_blocked:\n639:           proceed: true\n640: \n641:       step_handle_convergence:\n642:         action: \"Act on convergence decision\"\n643:         if_stop:\n644:           log: \"Loop stopping. Reason: {reason}\"\n645:           skip_to: phase_synthesis\n646:         if_blocked:\n647:           log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n648:         if_stuck_recovery:\n649:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n650:           recovery_strategies:\n651:             - \"Change granularity: file-level → function-level → line-level review\"\n652:             - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n653:             - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n654:           pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n655:           set:\n656:             next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n657:             pending_stop_event: \"stuck_recovery\"\n658:             pending_stop_reason: \"stuckRecovery\"\n659:             pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n660:           reset: { stuck_count: 0 }\n661:         if_continue:\n662:           log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n663: \n664:       step_normalize_pause_events:\n665:         action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n666:         if_pending_pause_event:\n667:           append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n668:           message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n669:           reset:\n670:             pending_stop_event: null\n671:             pending_stop_reason: null\n672:             pending_stop_detail: null\n673:           halt: true\n674:         if_pending_stuck_recovery:\n675:           append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n676:           reset:\n677:             pending_stop_event: null\n678:             pending_stop_reason: null\n679:             pending_stop_detail: null\n680:         if_no_pending_event:\n681:           proceed: true\n682: \n683:       step_generate_state_summary:\n684:         action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n685:         generate: |\n686:           STATE SUMMARY (auto-generated):\n687:           Iteration: {current_iteration} of {max_iterations}\n688:           Dimension: {next_dimension}\n689:           Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n690:           Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n691:           Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n692:           {resource_map_prompt_line}\n693:           Coverage Age: {coverage_age}\n694:           Last 2 ratios: {ratio_prev} -> {ratio_latest}\n695:           Stuck count: {stuck_count}\n696:           Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n697: \n698:       step_marker_scan:\n699:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n700:         algorithm: |\n701:           if current_iteration > 1:\n702:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n703:             if file_exists(PREV_PROMPT_PATH):\n704:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n705:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n706:                 log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n707:                 halt with exit code 2\n708:         note: |\n709:           False-positive prevention: only matches when the first line is exactly one of the\n710:           three canonical markers. Markers appearing in comments or body text are ignored.\n711:           True-positive triggers only when a previous iteration's rendered prompt literally\n712:           starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n713: \n714:       step_dispatch_iteration:\n715:         action: \"Dispatch @deep-review agent for one review iteration\"\n716:         resolve_executor:\n717:           source: \"config.executor\"\n718:           loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n719:         pre_dispatch:\n720:           generate_summary: |\n721:             STATE SUMMARY (auto-generated):\n722:             Iteration: {current_iteration} of {max_iterations}\n723:             Dimension: {next_dimension}\n724:             Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n725:             Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n726:             Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n727:             {resource_map_prompt_line}\n728:             Coverage Age: {coverage_age}\n729:             Last 2 ratios: {ratio_prev} -> {ratio_latest}\n730:             Stuck count: {stuck_count}\n731:             Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n732:           render_prompt_pack:\n733:             template_path: \".opencode/skills/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n734:             renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n735:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n736:             variables:\n737:               state_summary: \"{state_summary}\"\n738:               current_iteration: \"{current_iteration}\"\n739:               max_iterations: \"{max_iterations}\"\n740:               next_dimension: \"{next_dimension}\"\n741:               review_target: \"{review_target}\"\n742:               review_scope_files: \"{review_scope_files}\"\n743:               p0_count: \"{p0_count}\"\n744:               p1_count: \"{p1_count}\"\n745:               p2_count: \"{p2_count}\"\n746:               state_paths_config: \"{state_paths.config}\"\n747:               state_paths_state_log: \"{state_paths.state_log}\"\n748:               state_paths_findings_registry: \"{state_paths.findings_registry}\"\n749:               state_paths_strategy: \"{state_paths.strategy}\"\n750:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n751:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n752:         pre_dispatch_audit:\n753:           skip_when: \"config.executor.kind == 'native'\"\n754:           call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n755:           args:\n756:             stateLogPath: \"{state_paths.state_log}\"\n757:             executor: \"{config.executor}\"\n758:             iteration: \"{current_iteration}\"\n759:         branch_on: \"config.executor.kind\"\n760:         if_native:\n761:           dispatch:\n762:             agent: deep-review\n763:             model: opus\n764:             context_source: \"rendered_prompt_pack\"\n765:           wait_for_completion: true\n766:         if_cli_codex:\n767:           command: |\n768:             node --experimental-strip-types --input-type=module <<'EOF'\n769:             import { readFileSync } from 'node:fs';\n770: \n771:             import { runAuditedExecutorCommandAsync } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n772:             import { resolveCodexSandboxMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n773: \n774:             const executor = {\n775:               kind: 'cli-codex',\n776:               model: '{config.executor.model}',\n777:               reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n778:               serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n779:               sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n780:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n781:             };\n782: \n783:             process.exit(await runAuditedExecutorCommandAsync({\n784:               command: 'codex',\n785:               args: [\n786:                 'exec',\n787:                 '--model',\n788:                 executor.model,\n789:                 '-c',\n790:                 `model_reasoning_effort=${executor.reasoningEffort}`,\n791:                 '-c',\n792:                 `service_tier=${executor.serviceTier}`,\n793:                 '-c',\n794:                 'approval_policy=never',\n795:                 '--sandbox',\n796:                 resolveCodexSandboxMode(executor.sandboxMode),\n797:                 '-',\n798:               ],\n799:               cwd: '{repo_root}',\n800:               timeoutSeconds: executor.timeoutSeconds,\n801:               stateLogPath: '{state_paths.state_log}',\n802:               executor,\n803:               iteration: Number('{current_iteration}'),\n804:               input: readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n805:             }));\n806:             EOF\n807:           working_directory: \"{repo_root}\"\n808:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n809:           wait_for_completion: true\n810:         if_cli_copilot:\n811:           command: |\n812:             node --experimental-strip-types --input-type=module <<'EOF'\n813:             import { readFileSync, writeFileSync } from 'node:fs';\n814:             import { spawnSync } from 'node:child_process';\n815: \n816:             import { buildCopilotPromptArg } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n817: \n818:             const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n819:             const prompt = readFileSync(promptPath, 'utf8');\n820: \n821:             // Workflow-resolved spec folder is the only legal write authority.\n822:             // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n823:             // is the single source of truth for rejecting empty / unresolved\n824:             // template / whitespace-only / string-coerced empty values. The\n825:             // YAML hands the raw `{spec_folder}` directly; on rejection the\n826:             // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n827:             // enforcement, --allow-all-tools stripped).\n828:             const specFolderRaw = '{spec_folder}';\n829:             const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n830: \n831:             const baseArgs = [\n832:               '-p',\n833:               prompt,\n834:               '--model',\n835:               '{config.executor.model}',\n836:               '--allow-all-tools',\n837:               '--no-ask-user',\n838:             ];\n839: \n840:             const built = buildCopilotPromptArg({\n841:               promptPath,\n842:               prompt,\n843:               targetAuthority,\n844:               baseArgv: baseArgs,\n845:             });\n846: \n847:             // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n848:             // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n849:             // Write it to disk so the file Copilot reads via @path opens with\n850:             // the authority block. Without this, recovered/bootstrap folder\n851:             // mentions inside the file could still anchor the model.\n852:             if (built.promptFileBody !== undefined) {\n853:               writeFileSync(promptPath, built.promptFileBody, 'utf8');\n854:             }\n855: \n856:             const result = spawnSync('copilot', built.argv, {\n857:               cwd: '{repo_root}',\n858:               stdio: 'inherit',\n859:               timeout: Number('{config.executor.timeoutSeconds}') * 1000,\n860:             });\n861:             process.exit(result.status ?? 1);\n862:             EOF\n863:           working_directory: \"{repo_root}\"\n864:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n865:           wait_for_completion: true\n866:           notes:\n867:             - \"copilot has no stdin support; prompt is positional\"\n868:             - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n869:             - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n870:             - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n871:             - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n872:             - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n873:         if_cli_gemini:\n874:           command: |\n875:             gemini \\\n876:               \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n877:               -m \"{config.executor.model}\" \\\n878:               -s none \\\n879:               -y \\\n880:               -o text\n881:           working_directory: \"{repo_root}\"\n882:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n883:           wait_for_completion: true\n884:           notes:\n885:             - \"gemini accepts positional prompt or stdin; we use positional via command substitution\"\n886:             - \"gemini has no reasoningEffort or serviceTier flags; model is the only lever\"\n887:             - \"gemini model whitelist enforced at config parse (currently only gemini-3.1-pro-preview)\"\n888:         if_cli_claude_code:\n889:           command: |\n890:             claude \\\n891:               -p \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n892:               --model \"{config.executor.model}\" \\\n893:               --permission-mode acceptEdits \\\n894:               --output-format text \\\n895:               {optional_effort_flag}\n896:           working_directory: \"{repo_root}\"\n897:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n898:           wait_for_completion: true\n899:           render_hint:\n900:             optional_effort_flag: |\n901:               If config.executor.reasoningEffort is set and non-null, expand to: --effort {config.executor.reasoningEffort}\n902:               Otherwise expand to empty string.\n903:           notes:\n904:             - \"claude-code default permission-mode is 'plan' (read-only); we override to 'acceptEdits' for iteration writes\"\n905:             - \"claude-code has no serviceTier flag\"\n906:             - \"claude-code supports --effort for reasoning depth\"\n907:         if_cli_opencode:\n908:           command: |\n909:             opencode run \\\n910:               --model \"{config.executor.model}\" \\\n911:               --format json \\\n912:               --dangerously-skip-permissions \\\n913:               --pure \\\n914:               --dir \"{repo_root}\" \\\n915:               {optional_variant_flag} \\\n916:               \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n917:               </dev/null\n918:           working_directory: \"{repo_root}\"\n919:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n920:           wait_for_completion: true\n921:           render_hint:\n922:             optional_variant_flag: |\n923:               If config.executor.reasoningEffort is set and non-null, expand to: --variant {config.executor.reasoningEffort}\n924:               Otherwise expand to empty string.\n925:           notes:\n926:             - \"opencode run takes a positional message; prompt is fed via command substitution\"\n927:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n928:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n929:             - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude/Codex/Gemini/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n930:             - \"</dev/null required: opencode v1.14.39 reads stdin at startup before session creation. Without explicit closed stdin, automation that redirects stdout/stderr hangs at 0% CPU after `+60s snapshot prune cleanup`. See cli-opencode SKILL.md §4 ALWAYS rule + memory feedback_opencode_run_requires_dev_null_stdin.md.\"\n931:         if_cli_devin:\n932:           command: |\n933:             AGENT_CONFIG_SRC=\"{repo_root}/.opencode/skills/cli-devin/assets/agent-config-deep-review-iter.json\"\n934:             AGENT_CONFIG_TMP=\"{state_paths.prompt_dir}/agent-config-iter-{current_iteration}.json\"\n935:             DEVIN_STDERR_TMP=\"{state_paths.prompt_dir}/devin-stderr-iter-{current_iteration}.log\"\n936:             DEVIN_STDOUT_TMP=\"{state_paths.prompt_dir}/devin-stdout-iter-{current_iteration}.log\"\n937:             sed -e \"s|<repo-root>|{repo_root}|g\" -e \"s|<packet-root>|{spec_folder}|g\" \"$AGENT_CONFIG_SRC\" > \"$AGENT_CONFIG_TMP\"\n938:             gtimeout 900 devin --print \\\n939:               --prompt-file \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\" \\\n940:               --model \"{config.executor.model}\" \\\n941:               --permission-mode \"{resolved_permission_mode}\" \\\n942:               --agent-config \"$AGENT_CONFIG_TMP\" \\\n943:               </dev/null \\\n944:               > \"$DEVIN_STDOUT_TMP\" 2> \"$DEVIN_STDERR_TMP\"\n945:             DEVIN_EXIT=$?\n946:             cat \"$DEVIN_STDOUT_TMP\"\n947:             cat \"$DEVIN_STDERR_TMP\" >&2\n948:             if [ $DEVIN_EXIT -eq 124 ]; then\n949:               echo \"ITER_OUTCOME=timeout\" >&2\n950:             elif grep -q \"A tool was rejected by the user\" \"$DEVIN_STDERR_TMP\" 2>/dev/null; then\n951:               echo \"ITER_OUTCOME=tool_rejected\" >&2\n952:             elif grep -qE \"(I cannot write|read-only mode|permission errors when attempting to write)\" \"$DEVIN_STDOUT_TMP\" 2>/dev/null; then\n953:               echo \"ITER_OUTCOME=degraded_stdout_fallback\" >&2\n954:             else\n955:               echo \"ITER_OUTCOME=clean\" >&2\n956:             fi\n957:             exit $DEVIN_EXIT\n958:           working_directory: \"{repo_root}\"\n959:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n960:           wait_for_completion: true\n961:           render_hint:\n962:             resolved_permission_mode: |\n963:               Resolve via resolveDevinPermissionMode(config.executor.sandboxMode) — defined in\n964:               .opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts.\n965:               Mapping: sandboxMode='danger-full-access' → 'dangerous', everything else → 'auto'.\n966:               Default (sandboxMode unset): 'auto'.\n967:             agent_config_recipe: |\n968:               The review-iter recipe at .opencode/skills/cli-devin/assets/agent-config-deep-review-iter.json\n969:               ships with literal \"<repo-root>\" and \"<packet-root>\" placeholders. The command block substitutes\n970:               them via sed at dispatch time and writes the result to {state_paths.prompt_dir}/agent-config-iter-NNN.json,\n971:               then passes that path to devin --agent-config. The recipe pins the narrower allowed_tools\n972:               (Read+Grep+Glob, no Bash) and Read-only permissions.allow at Devin's strict parser. The narrow\n973:               Write scope (v1.0.4.0) is anchored at <packet-root> = {spec_folder} so iterations may only persist\n974:               artifacts inside the current packet directory.\n975:               Contract: .opencode/skills/cli-devin/references/deep-loop-iter-contract.md.\n976:               Recipe authoring: .opencode/skills/cli-devin/references/agent-config-recipes.md.\n977:           notes:\n978:             - \"devin --prompt-file accepts a path to the rendered iteration prompt (the SKILL.md skill_reference dispatch shape)\"\n979:             - \"Supported models: swe-1.6 (default), deepseek-v4, glm-5.1, kimi-k2.6 (per DEVIN_SUPPORTED_MODELS in executor-config.ts)\"\n980:             - \"--permission-mode auto auto-approves read-only ops and prompts on write; dangerous auto-approves all (only for sandboxed runs)\"\n981:             - \"--agent-config pins the review-iter profile (narrower than research-iter — Read+Grep+Glob only, no Bash) at Devin's strict parser. The recipe at cli-devin/assets/agent-config-deep-review-iter.json is substituted via sed at dispatch time to resolve the <repo-root> and <packet-root> placeholders per the recipe authoring contract.\"\n982:             - \"cli-devin self-invocation guard: this branch must only run from a non-Devin dispatch surface (Claude/Codex/Gemini/OpenCode/raw shell). The cli-devin skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate.\"\n983:             - \"</dev/null required: family convention for non-interactive dispatch to avoid stdin-blocking edge cases across CLI versions\"\n984:             - \"Cloud handoff is NOT used here — each iteration runs locally with convergence detection. See cli-devin references/cloud_handoff.md for the separate cloud-handoff route.\"\n985:             - \"Reasoning effort is NOT exposed by Devin's CLI surface; reasoning depth is fixed per model (e.g., swe-1.6 vs deepseek-v4). serviceTier is also N/A.\"\n986:             - \"v1.0.4.0: dispatch wrapped in gtimeout 900 (15 min cap per iter) to prevent silent hangs; exit code 124 is gtimeout's signal and surfaces as ITER_OUTCOME=timeout on stderr\"\n987:             - \"v1.0.4.0: stderr captured to {state_paths.prompt_dir}/devin-stderr-iter-NNN.log and scanned for 'A tool was rejected by the user' (Devin runtime approval gate firing inside --permission-mode auto); ITER_OUTCOME=tool_rejected flagged so the post_dispatch_validate / reducer can skip the iter cleanly without inheriting a stuck-style failure\"\n988:             - \"v1.0.4.0: stdout captured to {state_paths.prompt_dir}/devin-stdout-iter-NNN.log and scanned for stdout-fallback boilerplate ('I cannot write', 'read-only mode', 'permission errors when attempting to write'); ITER_OUTCOME=degraded_stdout_fallback flagged so the JSONL row can be tagged dispatch_quality=degraded for the synthesis phase\"\n989:             - \"v1.0.4.0: <packet-root> substitution added to the agent-config sed pipeline so the review-iter recipe's narrow Write scope resolves to {spec_folder} at dispatch time\"\n990:         post_dispatch_validate:\n991:           validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n992:           assert_exists: \"{state_paths.iteration_pattern}\"\n993:           assert_appended: \"{state_paths.state_log}\"\n994:           assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n995:           assert_canonical_type: \"iteration\"\n996:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n997:           assert_delta_file_has_iteration_record: true\n998:           failure_reasons:\n999:             - iteration_file_missing\n1000:             - iteration_file_empty\n1001:             - jsonl_not_appended\n1002:             - jsonl_missing_fields\n1003:             - jsonl_parse_error\n1004:             - jsonl_wrong_type\n1005:             - delta_file_missing\n1006:             - delta_file_empty\n1007:             - delta_file_missing_iteration_record\n1008:             - executor_missing\n1009:             - dispatch_failure_logged\n1010:             - v2_missing_ledger\n1011:             - v2_uncited_ledger_row\n1012:             - v2_broken_linked_finding\n1013:             - v2_shallow_finding_details\n1014:             - delta_iteration_id_mismatch\n1015:             - state_delta_iteration_mismatch\n1016:           warning_surface:\n1017:             source: \"result.warnings\"\n1018:             action: \"emit schema_advisory canonical conflict event\"\n1019:             severity: \"advisory\"\n1020:             event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1021:             note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n1022:           on_failure:\n1023:             action: \"emit schema_mismatch canonical conflict event\"\n1024:             escalation: \"After 3 consecutive failures, trigger stuck_recovery event with diagnostic context\"\n1025:         record_executor_audit:\n1026:           skip_when: \"config.executor.kind == 'native'\"\n1027:           target: \"{state_paths.state_log}\"\n1028:           field: \"executor\"\n1029:           value:\n1030:             kind: \"{config.executor.kind}\"\n1031:             model: \"{config.executor.model}\"\n1032:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1033:             serviceTier: \"{config.executor.serviceTier}\"\n1034: \n1035:       step_evaluate_results:\n1036:         action: \"Verify iteration outputs and extract metrics\"\n1037:         verify:\n1038:           - file_exists: \"{state_paths.iteration_pattern}\"\n1039:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1040:           - strategy_updated: \"Strategy.md has been modified\"\n1041:         extract:\n1042:           - newFindingsRatio: \"From latest JSONL iteration record\"\n1043:           - findings_count: \"From latest JSONL iteration record\"\n1044:           - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n1045:           - dimensions: \"From latest JSONL iteration record\"\n1046:           - files_reviewed: \"From latest JSONL iteration record\"\n1047:           - status: \"From latest JSONL iteration record\"\n1048:           - reviewed_artifacts: \"From latest JSONL iteration record\"\n1049:           - traceability_checks: \"From latest JSONL iteration record when present\"\n1050:         on_missing_outputs:\n1051:           action: \"Mark iteration as 'error', continue to next\"\n1052:           # <!-- F-010-B5-03 -->\n1053:           # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n1054:           # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1055:           append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n1056: \n1057:       step_post_iteration_claim_adjudication:\n1058:         action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n1059:         verify:\n1060:           - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n1061:           - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n1062:           - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n1063:         on_pass:\n1064:           set:\n1065:             claim_adjudication_passed: true\n1066:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1067:           log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n1068:         on_fail:\n1069:           action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n1070:           set:\n1071:             claim_adjudication_passed: false\n1072:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1073:           log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n1074: \n1075:       step_reduce_review_state:\n1076:         action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n1077:         command: \"node .opencode/skills/deep-review/scripts/reduce-state.cjs {spec_folder}\"\n1078:         read:\n1079:           - \"{state_paths.state_log}\"\n1080:           - \"{state_paths.iteration_pattern}\"\n1081:           - \"{state_paths.findings_registry}\"\n1082:           - \"{state_paths.strategy}\"\n1083:         write:\n1084:           - \"{state_paths.findings_registry}\"\n1085:           - \"{state_paths.dashboard}\"\n1086:           - \"{state_paths.strategy}\"\n1087:         failure_modes:\n1088:           malformed_delta: \"skip + warn\"\n1089:           missing_iteration_file: \"no-op + error\"\n1090:           schema_mismatch: \"reject + conflict event\"\n1091:         guarantee: \"Idempotent for identical inputs\"\n1092:         note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n1093: \n1094:       step_graph_upsert:\n1095:         action: \"Transform the latest iteration graphEvents delta into review graph nodes and edges, then upsert it\"\n1096:         read:\n1097:           - \"{state_paths.state_log}\"\n1098:           - \"{state_paths.findings_registry}\"\n1099:         transform: |\n1100:           1. Read the latest iteration JSONL record after reducer completion.\n1101:           2. If graphEvents is absent or empty, set graph_nodes_json = [] and graph_edges_json = [] and skip the upsert.\n1102:           3. For each graph event without relation/source/target, normalize type = uppercase(event.type || event.nodeKind || event.type) and keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n1103:           4. Emit nodes as { id, type, name, iteration, metadata } using the event label (or id fallback) and review metadata for run/current focus.\n1104:           5. For each graph event with relation + source + target, normalize relation = uppercase(event.relation) and keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n1105:           6. Emit edges as { id, relation, sourceId, targetId, metadata } and deduplicate the batch by id.\n1106:           7. Discard malformed or unknown graph events instead of failing the review iteration.\n1107:         bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n1108:         note: \"Invoke the runtime script directly. Upsert only the latest iteration graph delta.\"\n1109:         outputs:\n1110:           - graph_nodes_json: \"JSON array of normalized review graph nodes for the latest iteration\"\n1111:           - graph_edges_json: \"JSON array of normalized review graph edges for the latest iteration\"\n1112:         skip_conditions:\n1113:           - \"Latest iteration record has no graphEvents array\"\n1114: \n1115:       step_generate_dashboard:\n1116:         action: \"Generate or refresh the review dashboard\"\n1117:         read:\n1118:           - \"{state_paths.state_log}\"\n1119:           - \"{state_paths.findings_registry}\"\n1120:           - \"{state_paths.strategy}\"\n1121:         content: |\n1122:           # Deep Review Dashboard - Session Overview\n1123: \n1124:           Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n1125: \n1126:           ## Status\n1127:           - Review Target: {review_target} ({review_target_type})\n1128:           - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n1129:           - Iteration: {current_iteration} of {max_iterations}\n1130:           - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n1131:           - hasAdvisories: {has_advisories}\n1132: \n1133:           ## Findings Summary\n1134:           | Severity | Count | Trend |\n1135:           |----------|------:|-------|\n1136:           | P0 (Blockers) | {p0_count} | {p0_trend} |\n1137:           | P1 (Required) | {p1_count} | {p1_trend} |\n1138:           | P2 (Suggestions) | {p2_count} | {p2_trend} |\n1139: \n1140:           ## Dimension Coverage\n1141:           | Dimension | Status | Iteration | Findings |\n1142:           |-----------|--------|-----------|----------|\n1143:           | [per dimension from strategy + JSONL] |\n1144: \n1145:           ## Traceability Coverage\n1146:           | Protocol | Level | Status | Findings |\n1147:           |----------|-------|--------|----------|\n1148:           | [per protocol from traceabilityChecks] |\n1149: \n1150:           ## Progress\n1151:           | # | Dimension | Ratio | P0/P1/P2 | Status |\n1152:           |---|-----------|-------|----------|--------|\n1153:           | [per iteration from JSONL] |\n1154: \n1155:           ## Trend\n1156:           - Last 3 ratios: [{ratios}] [{trend}]\n1157:           - Stuck count: {stuck_count}\n1158:           - Gate violations: {guard_violations}\n1159: \n1160:           ## Next Focus\n1161:           {next_dimension}\n1162:         output: \"{state_paths.dashboard}\"\n1163:         note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n1164: \n1165:       step_update_tracking:\n1166:         action: \"Update loop tracking variables\"\n1167:         set:\n1168:           current_iteration: \"{current_iteration + 1}\"\n1169:           p0_count: \"Accumulate from severity_counts\"\n1170:           p1_count: \"Accumulate from severity_counts\"\n1171:           p2_count: \"Accumulate from severity_counts\"\n1172:           stuck_count: |\n1173:             if status == 'thought': unchanged (skip)\n1174:             if status == 'insight': 0 (reset)\n1175:             if newFindingsRatio <= 0.05: stuck_count + 1\n1176:             else: 0\n1177:         log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n1178: \n1179:       step_loop_decision:\n1180:         action: \"Return to step_read_state for next iteration\"\n1181:         goto: step_read_state\n1182: \n1183:   # ═══════════════════════════════════════════════════════════════\n1184:   # PHASE 3: SYNTHESIS\n1185:   # ═══════════════════════════════════════════════════════════════\n1186:   phase_synthesis:\n1187:     purpose: Compile all iteration findings into review/review-report.md\n1188:     steps:\n1189: \n1190:       step_fanout_merge:\n1191:         description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n1192:         skip_when: \"config.fanout is absent\"\n1193:         command: |\n1194:           node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n1195:             --loop-type review \\\n1196:             --artifact-dir {artifact_dir}\n1197:         working_directory: \"{repo_root}\"\n1198:         wait_for_completion: true\n1199:         bind_from_output:\n1200:           p0_count: \"active_p0\"\n1201:           p1_count: \"active_p1\"\n1202:           p2_count: \"active_p2\"\n1203: \n1204:       step_hydrate_summary_metrics:\n1205:         action: \"Hydrate summary metrics before synthesis\"\n1206:         read:\n1207:           - \"{state_paths.config}\"\n1208:           - \"{state_paths.state_log}\"\n1209:           - \"{state_paths.findings_registry}\"\n1210:           - \"{state_paths.strategy}\"\n1211:         extract:\n1212:           - iteration_count: \"Count lines where type === 'iteration'\"\n1213:           - p0_count: \"Total P0 findings across all iterations (deduped)\"\n1214:           - p1_count: \"Total P1 findings across all iterations (deduped)\"\n1215:           - p2_count: \"Total P2 findings across all iterations (deduped)\"\n1216:           - dimensions_covered: \"List of reviewed dimensions\"\n1217:           - dimension_coverage: \"covered / total\"\n1218:           - last_3_summaries: \"Summarize the latest 3 iteration records\"\n1219:           - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1220: \n1221:       # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n1222:       # - PASS: no P0 or P1 findings (P2-only or clean)\n1223:       # - CONDITIONAL: any P1 findings (no P0)\n1224:       # - FAIL: any P0 findings\n1225:       # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n1226:       step_derive_verdict:\n1227:         action: \"Derive review verdict from accumulated findings\"\n1228:         algorithm: |\n1229:           if p0_count > 0:\n1230:             verdict = \"FAIL\"\n1231:           elif p1_count > 0:\n1232:             verdict = \"CONDITIONAL\"\n1233:           else:\n1234:             verdict = \"PASS\"\n1235:           has_advisories = (verdict == \"PASS\" and p2_count > 0)\n1236:         outputs:\n1237:           - verdict: \"PASS | CONDITIONAL | FAIL\"\n1238:           - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n1239:         contract: |\n1240:           Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n1241:           Downstream automation parses this final line via exact string match — do not vary the format.\n1242: \n1243:       step_read_all_iterations:\n1244:         action: \"Read all iteration files and strategy\"\n1245:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1246:         read_also: \"{state_paths.strategy}\"\n1247: \n1248:       step_build_finding_registry:\n1249:         action: \"Build deduplicated finding registry from all iterations\"\n1250:         algorithm: |\n1251:           1. Extract all findings from iteration JSONL delta files\n1252:           2. Compute content_hash for each finding (emission requirement):\n1253:              content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n1254:              Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n1255:           3. Two-tier dedup:\n1256:              PRIMARY: group by content_hash field\n1257:                - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n1258:                - Keep highest severity on duplicates\n1259:              FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n1260:                - Same file:line, multiple dimensions → single finding, multiple dimension tags\n1261:                - Keep highest severity on duplicates\n1262:           4. Track finding lifecycle:\n1263:              - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n1264:              - Record first_seen, upgraded_in, previous_severity for severity changes\n1265:              - Record dimensions array reflecting all dimensions that emitted this finding\n1266:           5. Resolve contradictions:\n1267:              - Findings marked contested across iterations → referee pass\n1268:              - Determine final severity and status\n1269:           6. Count only 'active' findings for totals\n1270:         outputs:\n1271:           - finding_registry: \"Deduplicated list of all findings with metadata\"\n1272:           - active_p0: \"Count of active P0 findings\"\n1273:           - active_p1: \"Count of active P1 findings\"\n1274:           - active_p2: \"Count of active P2 findings\"\n1275: \n1276:       step_adversarial_selfcheck:\n1277:         action: \"Final adversarial self-check on all P0 and P1 findings\"\n1278:         algorithm: |\n1279:           For each active P0/P1 finding:\n1280:             1. Hunter: Re-verify finding against source code (re-read file:line)\n1281:             2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n1282:             3. Referee: Final call — confirm, downgrade, or mark false_positive\n1283:           Update finding_registry with adjudicated results.\n1284: \n1285:       step_emit_resource_map:\n1286:         action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n1287:         command: \"node .opencode/skills/deep-review/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1288:         read:\n1289:           - \"{state_paths.config}\"\n1290:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1291:         write:\n1292:           - \"{state_paths.resource_map_output}\"\n1293:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1294: \n1295:       step_resource_map_coverage_gate:\n1296:         action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n1297:         note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n1298: \n1299:       step_compile_review_report:\n1300:         action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n1301:         instructions: |\n1302:           Create review/review-report.md with the following sections:\n1303: \n1304:           1. **Executive Summary**\n1305:              - Overall verdict: PASS | CONDITIONAL | FAIL\n1306:              - hasAdvisories: true when PASS carries active P2 items\n1307:              - P0/P1/P2 counts (active only)\n1308:              - Review scope summary\n1309: \n1310:           2. **Planning Trigger**\n1311:              - State whether `/speckit:plan` is required\n1312:              - Include a fenced `json` block labeled `Planning Packet`\n1313:              - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n1314:              - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n1315: \n1316:           3. **Active Finding Registry**\n1317:              - Unified registry for active P0/P1/P2 findings\n1318:              - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n1319: \n1320:           4. **Remediation Workstreams**\n1321:              - Ordered action groups: P0 first, then P1, with P2 advisories separated\n1322: \n1323:           5. **Spec Seed**\n1324:              - Concrete seed bullets for follow-on spec updates\n1325: \n1326:           6. **Plan Seed**\n1327:              - Concrete starter tasks for `/speckit:plan`\n1328: \n1329:           7. **Traceability Status**\n1330:              - Summarize required core protocols first, then applicable overlay protocols\n1331:              - Include status, evidence, and any unresolved drift per protocol\n1332: \n1333:           If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n1334:              - `Entries touched`: count of resource-map paths that appear in applied reports\n1335:              - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n1336:              - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n1337: \n1338:           8. **Deferred Items**\n1339:              - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n1340: \n1341:           9. **Search Ledger**\n1342:              - Always include this section before the appendix.\n1343:              - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n1344:              - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n1345:              - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n1346: \n1347:           10. **Audit Appendix**\n1348:              - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n1349:              - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n1350: \n1351:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n1352:         output: \"{state_paths.review_output}\"\n1353: \n1354:       step_convergence_report:\n1355:         action: \"Append convergence report to JSONL\"\n1356:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":{iteration_count},\"activeP0\":{active_p0},\"activeP1\":{active_p1},\"activeP2\":{active_p2},\"dimensionCoverage\":{dimension_coverage},\"verdict\":\"{verdict}\",\"releaseReadinessState\":\"{release_readiness_state}\",\"stopReason\":\"{reason}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1357:         note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n1358: \n1359:       step_update_config_status:\n1360:         action: \"Mark config as complete\"\n1361:         edit: \"{state_paths.config}\"\n1362:         set_field: { status: \"complete\" }\n1363: \n1364:       step_stage_artifact_dir:\n1365:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1366:         command: \"git add {state_paths.artifact_dir}\"\n1367:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add review-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, findings-registry, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1368:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1369: \n1370:   # ═══════════════════════════════════════════════════════════════\n1371:   # PHASE 4: SAVE\n1372:   # ═══════════════════════════════════════════════════════════════\n1373:   phase_save:\n1374:     purpose: Preserve review context to memory system\n1375:     steps:\n1376: \n1377:       step_generate_context:\n1378:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1379:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1380:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1381: \n1382:       step_index_memory:\n1383:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1384:         mcp_tool: memory_save\n1385:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1386:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1387: \n1388:       step_verify_save:\n1389:         action: \"Verify canonical save routed content into the correct spec document\"\n1390:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1391:         on_fail: \"Log warning but do not block completion\"\n1392: \n1393:       step_release_lock:\n1394:         action: \"Release the advisory lock after save, skip-save, or cancellation cleanup has resolved\"\n1395:         command: \"Close or unlock {state_paths.lock_file} using advisory semantics only.\"\n1396:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1397: \n1398:   # ═══════════════════════════════════════════════════════════════\n1399:   # COMPLETION\n1400:   # ═══════════════════════════════════════════════════════════════\n1401:   completion:\n1402:     message: |\n1403:       Deep review complete.\n1404:       Iterations: {iteration_count} | Stop reason: {reason}\n1405:       Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n1406:       Verdict: {verdict} | hasAdvisories={has_advisories}\n1407: \n1408:       Artifacts:\n1409:         - review/review-report.md (compiled from {iteration_count} iterations)\n1410:         - {iteration_count} iteration files in review/iterations/\n1411:         - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n1412:         - Memory context saved\n1413: \n1414:       STATUS=OK PATH={spec_folder}\n1415:     next_steps:\n1416:       - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n1417:       - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n1418:       - \"/deep:start-review-loop [target] (for another review)\"\n1419:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1420: \n1421: # ─────────────────────────────────────────────────────────────────\n1422: # ERROR RECOVERY\n1423: # ─────────────────────────────────────────────────────────────────\n1424: error_recovery:\n\n(Output capped at 50 KB. Showing lines 636-1424. Use offset=1425 to continue.)\n</content>","metadata":{"preview":"          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          log: \"Loop stopping. Reason: {reason}\"\n          skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_start-review-loop_auto.yaml","text":"          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          log: \"Loop stopping. Reason: {reason}\"\n          skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:\n            next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n            pending_stop_event: \"stuck_recovery\"\n            pending_stop_reason: \"stuckRecovery\"\n            pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n\n      step_normalize_pause_events:\n        action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n        if_pending_pause_event:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n          halt: true\n        if_pending_stuck_recovery:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n        if_no_pending_event:\n          proceed: true\n\n      step_generate_state_summary:\n        action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n        generate: |\n          STATE SUMMARY (auto-generated):\n          Iteration: {current_iteration} of {max_iterations}\n          Dimension: {next_dimension}\n          Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n          Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n          Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n          {resource_map_prompt_line}\n          Coverage Age: {coverage_age}\n          Last 2 ratios: {ratio_prev} -> {ratio_latest}\n          Stuck count: {stuck_count}\n          Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch @deep-review agent for one review iteration\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Iteration: {current_iteration} of {max_iterations}\n            Dimension: {next_dimension}\n            Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n            Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n            Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n            {resource_map_prompt_line}\n            Coverage Age: {coverage_age}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest}\n            Stuck count: {stuck_count}\n            Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n          render_prompt_pack:\n            template_path: \".opencode/skills/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_dimension: \"{next_dimension}\"\n              review_target: \"{review_target}\"\n              review_scope_files: \"{review_scope_files}\"\n              p0_count: \"{p0_count}\"\n              p1_count: \"{p1_count}\"\n              p2_count: \"{p2_count}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_findings_registry: \"{state_paths.findings_registry}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.kind\"\n        if_native:\n          dispatch:\n            agent: deep-review\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n\n            import { runAuditedExecutorCommandAsync } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n            import { resolveCodexSandboxMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const executor = {\n              kind: 'cli-codex',\n              model: '{config.executor.model}',\n              reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n              serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n              sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n            };\n\n            process.exit(await runAuditedExecutorCommandAsync({\n              command: 'codex',\n              args: [\n                'exec',\n                '--model',\n                executor.model,\n                '-c',\n                `model_reasoning_effort=${executor.reasoningEffort}`,\n                '-c',\n                `service_tier=${executor.serviceTier}`,\n                '-c',\n                'approval_policy=never',\n                '--sandbox',\n                resolveCodexSandboxMode(executor.sandboxMode),\n                '-',\n              ],\n              cwd: '{repo_root}',\n              timeoutSeconds: executor.timeoutSeconds,\n              stateLogPath: '{state_paths.state_log}',\n              executor,\n              iteration: Number('{current_iteration}'),\n              input: readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n            }));\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n        if_cli_copilot:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync, writeFileSync } from 'node:fs';\n            import { spawnSync } from 'node:child_process';\n\n            import { buildCopilotPromptArg } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n            const prompt = readFileSync(promptPath, 'utf8');\n\n            // Workflow-resolved spec folder is the only legal write authority.\n            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n            // is the single source of truth for rejecting empty / unresolved\n            // template / whitespace-only / string-coerced empty values. The\n            // YAML hands the raw `{spec_folder}` directly; on rejection the\n            // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n            // enforcement, --allow-all-tools stripped).\n            const specFolderRaw = '{spec_folder}';\n            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n\n            const baseArgs = [\n              '-p',\n              prompt,\n              '--model',\n              '{config.executor.model}',\n              '--allow-all-tools',\n              '--no-ask-user',\n            ];\n\n            const built = buildCopilotPromptArg({\n              promptPath,\n              prompt,\n              targetAuthority,\n              baseArgv: baseArgs,\n            });\n\n            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n            // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n            // Write it to disk so the file Copilot reads via @path opens with\n            // the authority block. Without this, recovered/bootstrap folder\n            // mentions inside the file could still anchor the model.\n            if (built.promptFileBody !== undefined) {\n              writeFileSync(promptPath, built.promptFileBody, 'utf8');\n            }\n\n            const result = spawnSync('copilot', built.argv, {\n              cwd: '{repo_root}',\n              stdio: 'inherit',\n              timeout: Number('{config.executor.timeoutSeconds}') * 1000,\n            });\n            process.exit(result.status ?? 1);\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"copilot has no stdin support; prompt is positional\"\n            - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n            - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n            - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n            - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n            - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n        if_cli_gemini:\n          command: |\n            gemini \\\n              \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n              -m \"{config.executor.model}\" \\\n              -s none \\\n              -y \\\n              -o text\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"gemini accepts positional prompt or stdin; we use positional via command substitution\"\n            - \"gemini has no reasoningEffort or serviceTier flags; model is the only lever\"\n            - \"gemini model whitelist enforced at config parse (currently only gemini-3.1-pro-preview)\"\n        if_cli_claude_code:\n          command: |\n            claude \\\n              -p \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n              --model \"{config.executor.model}\" \\\n              --permission-mode acceptEdits \\\n              --output-format text \\\n              {optional_effort_flag}\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_effort_flag: |\n              If config.executor.reasoningEffort is set and non-null, expand to: --effort {config.executor.reasoningEffort}\n              Otherwise expand to empty string.\n          notes:\n            - \"claude-code default permission-mode is 'plan' (read-only); we override to 'acceptEdits' for iteration writes\"\n            - \"claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        if_cli_opencode:\n          command: |\n            opencode run \\\n              --model \"{config.executor.model}\" \\\n              --format json \\\n              --dangerously-skip-permissions \\\n              --pure \\\n              --dir \"{repo_root}\" \\\n              {optional_variant_flag} \\\n              \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n              </dev/null\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_variant_flag: |\n              If config.executor.reasoningEffort is set and non-null, expand to: --variant {config.executor.reasoningEffort}\n              Otherwise expand to empty string.\n          notes:\n            - \"opencode run takes a positional message; prompt is fed via command substitution\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude/Codex/Gemini/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n            - \"</dev/null required: opencode v1.14.39 reads stdin at startup before session creation. Without explicit closed stdin, automation that redirects stdout/stderr hangs at 0% CPU after `+60s snapshot prune cleanup`. See cli-opencode SKILL.md §4 ALWAYS rule + memory feedback_opencode_run_requires_dev_null_stdin.md.\"\n        if_cli_devin:\n          command: |\n            AGENT_CONFIG_SRC=\"{repo_root}/.opencode/skills/cli-devin/assets/agent-config-deep-review-iter.json\"\n            AGENT_CONFIG_TMP=\"{state_paths.prompt_dir}/agent-config-iter-{current_iteration}.json\"\n            DEVIN_STDERR_TMP=\"{state_paths.prompt_dir}/devin-stderr-iter-{current_iteration}.log\"\n            DEVIN_STDOUT_TMP=\"{state_paths.prompt_dir}/devin-stdout-iter-{current_iteration}.log\"\n            sed -e \"s|<repo-root>|{repo_root}|g\" -e \"s|<packet-root>|{spec_folder}|g\" \"$AGENT_CONFIG_SRC\" > \"$AGENT_CONFIG_TMP\"\n            gtimeout 900 devin --print \\\n              --prompt-file \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\" \\\n              --model \"{config.executor.model}\" \\\n              --permission-mode \"{resolved_permission_mode}\" \\\n              --agent-config \"$AGENT_CONFIG_TMP\" \\\n              </dev/null \\\n              > \"$DEVIN_STDOUT_TMP\" 2> \"$DEVIN_STDERR_TMP\"\n            DEVIN_EXIT=$?\n            cat \"$DEVIN_STDOUT_TMP\"\n            cat \"$DEVIN_STDERR_TMP\" >&2\n            if [ $DEVIN_EXIT -eq 124 ]; then\n              echo \"ITER_OUTCOME=timeout\" >&2\n            elif grep -q \"A tool was rejected by the user\" \"$DEVIN_STDERR_TMP\" 2>/dev/null; then\n              echo \"ITER_OUTCOME=tool_rejected\" >&2\n            elif grep -qE \"(I cannot write|read-only mode|permission errors when attempting to write)\" \"$DEVIN_STDOUT_TMP\" 2>/dev/null; then\n              echo \"ITER_OUTCOME=degraded_stdout_fallback\" >&2\n            else\n              echo \"ITER_OUTCOME=clean\" >&2\n            fi\n            exit $DEVIN_EXIT\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            resolved_permission_mode: |\n              Resolve via resolveDevinPermissionMode(config.executor.sandboxMode) — defined in\n              .opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts.\n              Mapping: sandboxMode='danger-full-access' → 'dangerous', everything else → 'auto'.\n              Default (sandboxMode unset): 'auto'.\n            agent_config_recipe: |\n              The review-iter recipe at .opencode/skills/cli-devin/assets/agent-config-deep-review-iter.json\n              ships with literal \"<repo-root>\" and \"<packet-root>\" placeholders. The command block substitutes\n              them via sed at dispatch time and writes the result to {state_paths.prompt_dir}/agent-config-iter-NNN.json,\n              then passes that path to devin --agent-config. The recipe pins the narrower allowed_tools\n              (Read+Grep+Glob, no Bash) and Read-only permissions.allow at Devin's strict parser. The narrow\n              Write scope (v1.0.4.0) is anchored at <packet-root> = {spec_folder} so iterations may only persist\n              artifacts inside the current packet directory.\n              Contract: .opencode/skills/cli-devin/references/deep-loop-iter-contract.md.\n              Recipe authoring: .opencode/skills/cli-devin/references/agent-config-recipes.md.\n          notes:\n            - \"devin --prompt-file accepts a path to the rendered iteration prompt (the SKILL.md skill_reference dispatch shape)\"\n            - \"Supported models: swe-1.6 (default), deepseek-v4, glm-5.1, kimi-k2.6 (per DEVIN_SUPPORTED_MODELS in executor-config.ts)\"\n            - \"--permission-mode auto auto-approves read-only ops and prompts on write; dangerous auto-approves all (only for sandboxed runs)\"\n            - \"--agent-config pins the review-iter profile (narrower than research-iter — Read+Grep+Glob only, no Bash) at Devin's strict parser. The recipe at cli-devin/assets/agent-config-deep-review-iter.json is substituted via sed at dispatch time to resolve the <repo-root> and <packet-root> placeholders per the recipe authoring contract.\"\n            - \"cli-devin self-invocation guard: this branch must only run from a non-Devin dispatch surface (Claude/Codex/Gemini/OpenCode/raw shell). The cli-devin skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate.\"\n            - \"</dev/null required: family convention for non-interactive dispatch to avoid stdin-blocking edge cases across CLI versions\"\n            - \"Cloud handoff is NOT used here — each iteration runs locally with convergence detection. See cli-devin references/cloud_handoff.md for the separate cloud-handoff route.\"\n            - \"Reasoning effort is NOT exposed by Devin's CLI surface; reasoning depth is fixed per model (e.g., swe-1.6 vs deepseek-v4). serviceTier is also N/A.\"\n            - \"v1.0.4.0: dispatch wrapped in gtimeout 900 (15 min cap per iter) to prevent silent hangs; exit code 124 is gtimeout's signal and surfaces as ITER_OUTCOME=timeout on stderr\"\n            - \"v1.0.4.0: stderr captured to {state_paths.prompt_dir}/devin-stderr-iter-NNN.log and scanned for 'A tool was rejected by the user' (Devin runtime approval gate firing inside --permission-mode auto); ITER_OUTCOME=tool_rejected flagged so the post_dispatch_validate / reducer can skip the iter cleanly without inheriting a stuck-style failure\"\n            - \"v1.0.4.0: stdout captured to {state_paths.prompt_dir}/devin-stdout-iter-NNN.log and scanned for stdout-fallback boilerplate ('I cannot write', 'read-only mode', 'permission errors when attempting to write'); ITER_OUTCOME=degraded_stdout_fallback flagged so the JSONL row can be tagged dispatch_quality=degraded for the synthesis phase\"\n            - \"v1.0.4.0: <packet-root> substitution added to the agent-config sed pipeline so the review-iter recipe's narrow Write scope resolves to {spec_folder} at dispatch time\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:\n            - iteration_file_missing\n            - iteration_file_empty\n            - jsonl_not_appended\n            - jsonl_missing_fields\n            - jsonl_parse_error\n            - jsonl_wrong_type\n            - delta_file_missing\n            - delta_file_empty\n            - delta_file_missing_iteration_record\n            - executor_missing\n            - dispatch_failure_logged\n            - v2_missing_ledger\n            - v2_uncited_ledger_row\n            - v2_broken_linked_finding\n            - v2_shallow_finding_details\n            - delta_iteration_id_mismatch\n            - state_delta_iteration_mismatch\n          warning_surface:\n            source: \"result.warnings\"\n            action: \"emit schema_advisory canonical conflict event\"\n            severity: \"advisory\"\n            event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            escalation: \"After 3 consecutive failures, trigger stuck_recovery event with diagnostic context\"\n        record_executor_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.kind}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Strategy.md has been modified\"\n        extract:\n          - newFindingsRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n          - dimensions: \"From latest JSONL iteration record\"\n          - files_reviewed: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - reviewed_artifacts: \"From latest JSONL iteration record\"\n          - traceability_checks: \"From latest JSONL iteration record when present\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # <!-- F-010-B5-03 -->\n          # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n          # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n\n      step_post_iteration_claim_adjudication:\n        action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n        verify:\n          - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n          - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n          - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n        on_pass:\n          set:\n            claim_adjudication_passed: true\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n        on_fail:\n          action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n          set:\n            claim_adjudication_passed: false\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n\n      step_reduce_review_state:\n        action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n        command: \"node .opencode/skills/deep-review/scripts/reduce-state.cjs {spec_folder}\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.iteration_pattern}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        write:\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n        guarantee: \"Idempotent for identical inputs\"\n        note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n\n      step_graph_upsert:\n        action: \"Transform the latest iteration graphEvents delta into review graph nodes and edges, then upsert it\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Read the latest iteration JSONL record after reducer completion.\n          2. If graphEvents is absent or empty, set graph_nodes_json = [] and graph_edges_json = [] and skip the upsert.\n          3. For each graph event without relation/source/target, normalize type = uppercase(event.type || event.nodeKind || event.type) and keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n          4. Emit nodes as { id, type, name, iteration, metadata } using the event label (or id fallback) and review metadata for run/current focus.\n          5. For each graph event with relation + source + target, normalize relation = uppercase(event.relation) and keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n          6. Emit edges as { id, relation, sourceId, targetId, metadata } and deduplicate the batch by id.\n          7. Discard malformed or unknown graph events instead of failing the review iteration.\n        bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n        note: \"Invoke the runtime script directly. Upsert only the latest iteration graph delta.\"\n        outputs:\n          - graph_nodes_json: \"JSON array of normalized review graph nodes for the latest iteration\"\n          - graph_edges_json: \"JSON array of normalized review graph edges for the latest iteration\"\n        skip_conditions:\n          - \"Latest iteration record has no graphEvents array\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the review dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        content: |\n          # Deep Review Dashboard - Session Overview\n\n          Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n\n          ## Status\n          - Review Target: {review_target} ({review_target_type})\n          - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n          - Iteration: {current_iteration} of {max_iterations}\n          - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n          - hasAdvisories: {has_advisories}\n\n          ## Findings Summary\n          | Severity | Count | Trend |\n          |----------|------:|-------|\n          | P0 (Blockers) | {p0_count} | {p0_trend} |\n          | P1 (Required) | {p1_count} | {p1_trend} |\n          | P2 (Suggestions) | {p2_count} | {p2_trend} |\n\n          ## Dimension Coverage\n          | Dimension | Status | Iteration | Findings |\n          |-----------|--------|-----------|----------|\n          | [per dimension from strategy + JSONL] |\n\n          ## Traceability Coverage\n          | Protocol | Level | Status | Findings |\n          |----------|-------|--------|----------|\n          | [per protocol from traceabilityChecks] |\n\n          ## Progress\n          | # | Dimension | Ratio | P0/P1/P2 | Status |\n          |---|-----------|-------|----------|--------|\n          | [per iteration from JSONL] |\n\n          ## Trend\n          - Last 3 ratios: [{ratios}] [{trend}]\n          - Stuck count: {stuck_count}\n          - Gate violations: {guard_violations}\n\n          ## Next Focus\n          {next_dimension}\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          p0_count: \"Accumulate from severity_counts\"\n          p1_count: \"Accumulate from severity_counts\"\n          p2_count: \"Accumulate from severity_counts\"\n          stuck_count: |\n            if status == 'thought': unchanged (skip)\n            if status == 'insight': 0 (reset)\n            if newFindingsRatio <= 0.05: stuck_count + 1\n            else: 0\n        log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into review/review-report.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n            --loop-type review \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n        bind_from_output:\n          p0_count: \"active_p0\"\n          p1_count: \"active_p1\"\n          p2_count: \"active_p2\"\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - p0_count: \"Total P0 findings across all iterations (deduped)\"\n          - p1_count: \"Total P1 findings across all iterations (deduped)\"\n          - p2_count: \"Total P2 findings across all iterations (deduped)\"\n          - dimensions_covered: \"List of reviewed dimensions\"\n          - dimension_coverage: \"covered / total\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records\"\n          - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n      # - PASS: no P0 or P1 findings (P2-only or clean)\n      # - CONDITIONAL: any P1 findings (no P0)\n      # - FAIL: any P0 findings\n      # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n      step_derive_verdict:\n        action: \"Derive review verdict from accumulated findings\"\n        algorithm: |\n          if p0_count > 0:\n            verdict = \"FAIL\"\n          elif p1_count > 0:\n            verdict = \"CONDITIONAL\"\n          else:\n            verdict = \"PASS\"\n          has_advisories = (verdict == \"PASS\" and p2_count > 0)\n        outputs:\n          - verdict: \"PASS | CONDITIONAL | FAIL\"\n          - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n        contract: |\n          Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n          Downstream automation parses this final line via exact string match — do not vary the format.\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_build_finding_registry:\n        action: \"Build deduplicated finding registry from all iterations\"\n        algorithm: |\n          1. Extract all findings from iteration JSONL delta files\n          2. Compute content_hash for each finding (emission requirement):\n             content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n             Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n          3. Two-tier dedup:\n             PRIMARY: group by content_hash field\n               - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n               - Keep highest severity on duplicates\n             FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n               - Same file:line, multiple dimensions → single finding, multiple dimension tags\n               - Keep highest severity on duplicates\n          4. Track finding lifecycle:\n             - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n             - Record first_seen, upgraded_in, previous_severity for severity changes\n             - Record dimensions array reflecting all dimensions that emitted this finding\n          5. Resolve contradictions:\n             - Findings marked contested across iterations → referee pass\n             - Determine final severity and status\n          6. Count only 'active' findings for totals\n        outputs:\n          - finding_registry: \"Deduplicated list of all findings with metadata\"\n          - active_p0: \"Count of active P0 findings\"\n          - active_p1: \"Count of active P1 findings\"\n          - active_p2: \"Count of active P2 findings\"\n\n      step_adversarial_selfcheck:\n        action: \"Final adversarial self-check on all P0 and P1 findings\"\n        algorithm: |\n          For each active P0/P1 finding:\n            1. Hunter: Re-verify finding against source code (re-read file:line)\n            2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n            3. Referee: Final call — confirm, downgrade, or mark false_positive\n          Update finding_registry with adjudicated results.\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/deep-review/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_resource_map_coverage_gate:\n        action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n        note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n\n      step_compile_review_report:\n        action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n        instructions: |\n          Create review/review-report.md with the following sections:\n\n          1. **Executive Summary**\n             - Overall verdict: PASS | CONDITIONAL | FAIL\n             - hasAdvisories: true when PASS carries active P2 items\n             - P0/P1/P2 counts (active only)\n             - Review scope summary\n\n          2. **Planning Trigger**\n             - State whether `/speckit:plan` is required\n             - Include a fenced `json` block labeled `Planning Packet`\n             - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n             - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n\n          3. **Active Finding Registry**\n             - Unified registry for active P0/P1/P2 findings\n             - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n\n          4. **Remediation Workstreams**\n             - Ordered action groups: P0 first, then P1, with P2 advisories separated\n\n          5. **Spec Seed**\n             - Concrete seed bullets for follow-on spec updates\n\n          6. **Plan Seed**\n             - Concrete starter tasks for `/speckit:plan`\n\n          7. **Traceability Status**\n             - Summarize required core protocols first, then applicable overlay protocols\n             - Include status, evidence, and any unresolved drift per protocol\n\n          If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n             - `Entries touched`: count of resource-map paths that appear in applied reports\n             - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n             - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n\n          8. **Deferred Items**\n             - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n\n          9. **Search Ledger**\n             - Always include this section before the appendix.\n             - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n             - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n             - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n\n          10. **Audit Appendix**\n             - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n             - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n        output: \"{state_paths.review_output}\"\n\n      step_convergence_report:\n        action: \"Append convergence report to JSONL\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":{iteration_count},\"activeP0\":{active_p0},\"activeP1\":{active_p1},\"activeP2\":{active_p2},\"dimensionCoverage\":{dimension_coverage},\"verdict\":\"{verdict}\",\"releaseReadinessState\":\"{release_readiness_state}\",\"stopReason\":\"{reason}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n        note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.artifact_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add review-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, findings-registry, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve review context to memory system\n    steps:\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the advisory lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"Close or unlock {state_paths.lock_file} using advisory semantics only.\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep review complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n      Verdict: {verdict} | hasAdvisories={has_advisories}\n\n      Artifacts:\n        - review/review-report.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in review/iterations/\n        - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n      - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n      - \"/deep:start-review-loop [target] (for another review)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:","lineStart":636,"lineEnd":1424,"totalLines":1425,"truncated":true}},"title":".opencode/commands/deep/assets/deep_start-review-loop_auto.yaml","time":{"start":1780906985591,"end":1780906985603}},"metadata":{"openai":{"itemId":"fc_06766d70ffa8e198016a267be960c481919750148ffba183f2"}},"id":"prt_ea65407e0001O2wCUASJ45UuhO","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea653e373001s3WicIAjm4qipO"}}
{"type":"tool_use","timestamp":1780906985689,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_YlHFfabS2wXA2fDuCFmDaSge","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/deep_review_config.json","offset":1,"limit":800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/deep_review_config.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"topic\": \"\",\n3:   \"sessionId\": \"\",\n4:   \"parentSessionId\": null,\n5:   \"lineageMode\": \"new\",\n6:   \"generation\": 1,\n7:   \"continuedFromRun\": null,\n8:   \"migrationWindowEndsAt\": \"\",\n9:   \"maxIterations\": 7,\n10:   \"convergenceThreshold\": 0.10,\n11:   \"stuckThreshold\": 2,\n12:   \"maxDurationMinutes\": 120,\n13:   \"maxToolCallsPerIteration\": 12,\n14:   \"maxMinutesPerIteration\": 10,\n15:   \"progressiveSynthesis\": false,\n16:   \"specFolder\": \"\",\n17:   \"createdAt\": \"\",\n18:   \"status\": \"initialized\",\n19:   \"releaseReadinessState\": \"in-progress\",\n20:   \"executionMode\": \"auto\",\n21:   \"executor\": {\n22:     \"kind\": \"native\",\n23:     \"model\": null,\n24:     \"reasoningEffort\": null,\n25:     \"serviceTier\": null,\n26:     \"sandboxMode\": null,\n27:     \"timeoutSeconds\": 900\n28:   },\n29:   \"mode\": \"review\",\n30:   \"reviewTarget\": \"\",\n31:   \"reviewTargetType\": \"spec-folder\",\n32:   \"reviewDimensions\": [\n33:     \"correctness\",\n34:     \"security\",\n35:     \"traceability\",\n36:     \"maintainability\"\n37:   ],\n38:   \"severityThreshold\": \"P2\",\n39:   \"crossReference\": {\n40:     \"core\": [\n41:       \"spec_code\",\n42:       \"checklist_evidence\"\n43:     ],\n44:     \"overlay\": [\n45:       \"skill_agent\",\n46:       \"agent_cross_runtime\",\n47:       \"feature_catalog_code\",\n48:       \"playbook_capability\"\n49:     ]\n50:   },\n51:   \"qualityGateThreshold\": true,\n52:   \"runtimeCapabilityResolver\": \".opencode/skills/deep-review/scripts/runtime-capabilities.cjs\",\n53:   \"reducerScriptPath\": \".opencode/skills/deep-review/scripts/reduce-state.cjs\",\n54:   \"fileProtection\": {\n55:     \"deep-review-config.json\": \"immutable\",\n56:     \"deep-review-state.jsonl\": \"append-only\",\n57:     \"deep-review-findings-registry.json\": \"auto-generated\",\n58:     \"deep-review-strategy.md\": \"mutable\",\n59:     \"deep-review-dashboard.md\": \"auto-generated\",\n60:     \".deep-review-pause\": \"operator-controlled\",\n61:     \"review-report.md\": \"mutable\",\n62:     \"review-report-v*.md\": \"write-once\",\n63:     \"iteration-*.md\": \"write-once\"\n64:   },\n65:   \"reducer\": {\n66:     \"enabled\": true,\n67:     \"inputs\": [\n68:       \"latestJSONLDelta\",\n69:       \"newIterationFile\",\n70:       \"priorReducedState\"\n71:     ],\n72:     \"outputs\": [\n73:       \"findingsRegistry\",\n74:       \"dashboardMetrics\",\n75:       \"strategyUpdates\"\n76:     ],\n77:     \"metrics\": [\n78:       \"dimensionsCovered\",\n79:       \"findingsBySeverity\",\n80:       \"openFindings\",\n81:       \"resolvedFindings\",\n82:       \"convergenceScore\"\n83:     ]\n84:   },\n85:   \"_optimizerManaged\": {\n86:     \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n87:     \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n88:     \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n89:     \"lockedFields\": [\"lineageMode\", \"reducer\", \"fileProtection\", \"sessionId\", \"mode\", \"reviewDimensions\"],\n90:     \"promotionMode\": \"advisory-only\"\n91:   }\n92: }\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"{\n  \"topic\": \"\",\n  \"sessionId\": \"\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"migrationWindowEndsAt\": \"\",\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"stuckThreshold\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"releaseReadinessState\": \"in-progress\",\n  \"executionMode\": \"auto\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/deep_review_config.json","text":"{\n  \"topic\": \"\",\n  \"sessionId\": \"\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"migrationWindowEndsAt\": \"\",\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"stuckThreshold\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"releaseReadinessState\": \"in-progress\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",\n    \"model\": null,\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900\n  },\n  \"mode\": \"review\",\n  \"reviewTarget\": \"\",\n  \"reviewTargetType\": \"spec-folder\",\n  \"reviewDimensions\": [\n    \"correctness\",\n    \"security\",\n    \"traceability\",\n    \"maintainability\"\n  ],\n  \"severityThreshold\": \"P2\",\n  \"crossReference\": {\n    \"core\": [\n      \"spec_code\",\n      \"checklist_evidence\"\n    ],\n    \"overlay\": [\n      \"skill_agent\",\n      \"agent_cross_runtime\",\n      \"feature_catalog_code\",\n      \"playbook_capability\"\n    ]\n  },\n  \"qualityGateThreshold\": true,\n  \"runtimeCapabilityResolver\": \".opencode/skills/deep-review/scripts/runtime-capabilities.cjs\",\n  \"reducerScriptPath\": \".opencode/skills/deep-review/scripts/reduce-state.cjs\",\n  \"fileProtection\": {\n    \"deep-review-config.json\": \"immutable\",\n    \"deep-review-state.jsonl\": \"append-only\",\n    \"deep-review-findings-registry.json\": \"auto-generated\",\n    \"deep-review-strategy.md\": \"mutable\",\n    \"deep-review-dashboard.md\": \"auto-generated\",\n    \".deep-review-pause\": \"operator-controlled\",\n    \"review-report.md\": \"mutable\",\n    \"review-report-v*.md\": \"write-once\",\n    \"iteration-*.md\": \"write-once\"\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"inputs\": [\n      \"latestJSONLDelta\",\n      \"newIterationFile\",\n      \"priorReducedState\"\n    ],\n    \"outputs\": [\n      \"findingsRegistry\",\n      \"dashboardMetrics\",\n      \"strategyUpdates\"\n    ],\n    \"metrics\": [\n      \"dimensionsCovered\",\n      \"findingsBySeverity\",\n      \"openFindings\",\n      \"resolvedFindings\",\n      \"convergenceScore\"\n    ]\n  },\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n    \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n    \"lockedFields\": [\"lineageMode\", \"reducer\", \"fileProtection\", \"sessionId\", \"mode\", \"reviewDimensions\"],\n    \"promotionMode\": \"advisory-only\"\n  }\n}","lineStart":1,"lineEnd":92,"totalLines":92,"truncated":false}},"title":".opencode/skills/deep-review/assets/deep_review_config.json","time":{"start":1780906985683,"end":1780906985688}},"metadata":{"openai":{"itemId":"fc_06766d70ffa8e198016a267be960dc8191b0d6379af4b4fcec"}},"id":"prt_ea65408940014czAyGCfa0PdJd","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea653e373001s3WicIAjm4qipO"}}
{"type":"tool_use","timestamp":1780906985807,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_IsNoGjb7PtTauitfAvPddDVL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/deep_review_strategy.md","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/deep_review_strategy.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Strategy Template\n3: description: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\n4: ---\n5: \n6: # Deep Review Strategy - Session Tracking Template\n7: \n8: Runtime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n9: \n10: ## 1. OVERVIEW\n11: \n12: ### Purpose\n13: \n14: Serves as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n15: \n16: ### Usage\n17: \n18: - **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n19: - **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n20: - **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.\n21: - **Protection:** None (shared mutable state). Orchestrator validates consistency on resume.\n22: - **Ownership:** Machine-managed metrics and coverage blocks are wrapped in explicit ownership markers. Human commentary and operator overrides live outside those markers.\n23: \n24: ---\n25: \n26: ## 2. TOPIC\n27: [Review target description from config -- set during initialization]\n28: \n29: ---\n30: \n31: ## 3. REVIEW DIMENSIONS (remaining)\n32: <!-- MACHINE-OWNED: START -->\n33: - [ ] D1 Correctness, Logic errors, off-by-one, wrong return types, broken invariants\n34: - [ ] D2 Security, Injection, auth bypass, secrets exposure, unsafe deserialization\n35: - [ ] D3 Traceability, Spec/code alignment, checklist evidence, cross-reference integrity\n36: - [ ] D4 Maintainability, Patterns, clarity, documentation quality, safe follow-on change cost\n37: <!-- MACHINE-OWNED: END -->\n38: \n39: ---\n40: \n41: ## 4. NON-GOALS\n42: [What this review session is NOT trying to assess -- populated during initialization]\n43: \n44: ---\n45: \n46: ## 5. STOP CONDITIONS\n47: [Explicit conditions beyond convergence that should end the session -- populated during initialization]\n48: \n49: ---\n50: \n51: ## 6. COMPLETED DIMENSIONS\n52: <!-- MACHINE-OWNED: START -->\n53: [None yet -- populated as iterations complete dimension reviews]\n54: \n55: | Dimension | Verdict | Iteration | Summary |\n56: |-----------|---------|-----------|---------|\n57: | [D1 Correctness] | [PASS/CONDITIONAL/FAIL] | [N] | [1-sentence result] |\n58: <!-- MACHINE-OWNED: END -->\n59: \n60: ---\n61: \n62: ## 7. RUNNING FINDINGS\n63: <!-- MACHINE-OWNED: START -->\n64: - **P0 (Critical):** 0 active\n65: - **P1 (Major):** 0 active\n66: - **P2 (Minor):** 0 active\n67: - **Delta this iteration:** +0 P0, +0 P1, +0 P2\n68: \n69: [Findings are tracked in `deep-review-findings-registry.json`. This section provides a running count summary updated after each iteration.]\n70: <!-- MACHINE-OWNED: END -->\n71: \n72: ---\n73: \n74: ## 8. WHAT WORKED\n75: [First iteration -- populated after iteration 1 completes]\n76: - [Approach]: [Why it worked] (iteration N)\n77: \n78: ---\n79: \n80: ## 9. WHAT FAILED\n81: [First iteration -- populated after iteration 1 completes]\n82: - [Approach]: [Why it failed] (iteration N)\n83: \n84: ---\n85: \n86: ## 10. EXHAUSTED APPROACHES (do not retry)\n87: [Populated when a review approach has been tried from multiple angles without yielding new findings]\n88: \n89: ### [Category Name] -- BLOCKED (iteration N, N attempts)\n90: - What was tried: [specific review approaches attempted]\n91: - Why blocked: [root cause of exhaustion]\n92: - Do NOT retry: [explicit prohibition]\n93: \n94: ### [Category Name] -- PRODUCTIVE (iteration N)\n95: - What worked: [successful review approaches in this category]\n96: - Prefer for: [related dimensions where this category may help]\n97: \n98: ---\n99: \n100: ## 11. RULED OUT DIRECTIONS\n101: [Review angles that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n102: - [Approach]: [Why ruled out] (iteration N, evidence: [source])\n103: \n104: ---\n105: \n106: ## 12. NEXT FOCUS\n107: <!-- MACHINE-OWNED: START -->\n108: [Recommended focus area for the next iteration -- updated at end of each iteration. Includes target dimension and/or specific files to review.]\n109: <!-- MACHINE-OWNED: END -->\n110: \n111: ---\n112: \n113: ## 13. KNOWN CONTEXT\n114: [Populated during initialization from memory_context() results, if any prior work exists]\n115: \n116: ---\n117: \n118: ## 14. CROSS-REFERENCE STATUS\n119: <!-- MACHINE-OWNED: START -->\n120: [Alignment checks completed across core and overlay protocols]\n121: \n122: | Protocol | Level | Status | Iteration | Notes |\n123: |----------|-------|--------|-----------|-------|\n124: | `spec_code` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n125: | `checklist_evidence` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n126: | `skill_agent` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n127: | `agent_cross_runtime` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n128: | `feature_catalog_code` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n129: | `playbook_capability` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n130: <!-- MACHINE-OWNED: END -->\n131: \n132: ---\n133: \n134: ## 15. FILES UNDER REVIEW\n135: <!-- MACHINE-OWNED: START -->\n136: [Per-file coverage state table -- populated during initialization from scope discovery]\n137: \n138: | File | Dimensions Reviewed | Last Iteration | Findings | Status |\n139: |------|-------------------|----------------|----------|--------|\n140: | [path/to/file] | [D1, D3] | [N] | [0 P0, 1 P1, 2 P2] | [partial/complete] |\n141: <!-- MACHINE-OWNED: END -->\n142: \n143: ---\n144: \n145: ## 16. REVIEW BOUNDARIES\n146: <!-- MACHINE-OWNED: START -->\n147: - Max iterations: [from config]\n148: - Convergence threshold: [from config]\n149: - Rolling STOP threshold: 0.08\n150: - No-progress threshold: 0.05\n151: - Coverage stabilization passes required: 1\n152: - Session lineage: sessionId=[from config.sessionId], parentSessionId=[from config.parentSessionId], generation=[from config.generation], lineageMode=[from config.lineageMode]\n153: - Findings registry: `deep-review-findings-registry.json`\n154: - Release-readiness states: in-progress | converged | release-blocking\n155: - Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n156: - Severity threshold: [from config.severityThreshold]\n157: - Review target type: [from config.reviewTargetType]\n158: - Cross-reference checks: core=[from config.crossReference.core], overlay=[from config.crossReference.overlay]\n159: - Started: [timestamp]\n160: <!-- MACHINE-OWNED: END -->\n161: \n162: ---\n163: \n164: ## 17. EXAMPLE (POPULATED)\n165: \n166: Reference snippet showing a partially populated strategy file mid-review. Use this as a visual anchor when opening a live strategy doc.\n167: \n168: ```markdown\n169: ## 1. REVIEW CHARTER\n170: - Target: .opencode/skills/deep-research (skill, v1.4.0)\n171: - Dimensions: correctness, test-coverage, cross-runtime-parity, observability\n172: - Stop conditions: rolling newInfoRatio < 0.08 for 2 iterations OR all dimensions converged OR max=7 reached\n173: - Success criteria: zero P0 in correctness; test-coverage P0 resolved or deferred with rationale\n174: \n175: ## 4. NEXT FOCUS\n176: - Dimension: test-coverage\n177: - Files: .opencode/skills/deep-research/scripts/reduce-state.cjs, .opencode/skills/system-spec-kit/scripts/tests/deep-research-contract-parity.vitest.ts\n178: - Why: Iteration 2 surfaced a P0 (convergence-path coverage gap); needs a focused follow-up before correctness can terminate PASS.\n179: \n180: ## 9. COVERAGE MATRIX\n181: | Dimension            | Status     | Iterations touched |\n182: |----------------------|------------|--------------------|\n183: | correctness          | converged  | 1                  |\n184: | test-coverage        | converging | 2, 4               |\n185: | cross-runtime-parity | converging | 3                  |\n186: | observability        | converging | 4                  |\n187: ```\n\n(End of file - total 187 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Strategy Template\ndescription: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\n---\n\n# Deep Review Strategy - Session Tracking Template\n\nRuntime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose\n\nServes as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n\n### Usage\n\n- **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n- **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n- **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/deep_review_strategy.md","text":"---\ntitle: Deep Review Strategy Template\ndescription: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\n---\n\n# Deep Review Strategy - Session Tracking Template\n\nRuntime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose\n\nServes as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n\n### Usage\n\n- **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n- **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n- **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.\n- **Protection:** None (shared mutable state). Orchestrator validates consistency on resume.\n- **Ownership:** Machine-managed metrics and coverage blocks are wrapped in explicit ownership markers. Human commentary and operator overrides live outside those markers.\n\n---\n\n## 2. TOPIC\n[Review target description from config -- set during initialization]\n\n---\n\n## 3. REVIEW DIMENSIONS (remaining)\n<!-- MACHINE-OWNED: START -->\n- [ ] D1 Correctness, Logic errors, off-by-one, wrong return types, broken invariants\n- [ ] D2 Security, Injection, auth bypass, secrets exposure, unsafe deserialization\n- [ ] D3 Traceability, Spec/code alignment, checklist evidence, cross-reference integrity\n- [ ] D4 Maintainability, Patterns, clarity, documentation quality, safe follow-on change cost\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 4. NON-GOALS\n[What this review session is NOT trying to assess -- populated during initialization]\n\n---\n\n## 5. STOP CONDITIONS\n[Explicit conditions beyond convergence that should end the session -- populated during initialization]\n\n---\n\n## 6. COMPLETED DIMENSIONS\n<!-- MACHINE-OWNED: START -->\n[None yet -- populated as iterations complete dimension reviews]\n\n| Dimension | Verdict | Iteration | Summary |\n|-----------|---------|-----------|---------|\n| [D1 Correctness] | [PASS/CONDITIONAL/FAIL] | [N] | [1-sentence result] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 7. RUNNING FINDINGS\n<!-- MACHINE-OWNED: START -->\n- **P0 (Critical):** 0 active\n- **P1 (Major):** 0 active\n- **P2 (Minor):** 0 active\n- **Delta this iteration:** +0 P0, +0 P1, +0 P2\n\n[Findings are tracked in `deep-review-findings-registry.json`. This section provides a running count summary updated after each iteration.]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 8. WHAT WORKED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it worked] (iteration N)\n\n---\n\n## 9. WHAT FAILED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it failed] (iteration N)\n\n---\n\n## 10. EXHAUSTED APPROACHES (do not retry)\n[Populated when a review approach has been tried from multiple angles without yielding new findings]\n\n### [Category Name] -- BLOCKED (iteration N, N attempts)\n- What was tried: [specific review approaches attempted]\n- Why blocked: [root cause of exhaustion]\n- Do NOT retry: [explicit prohibition]\n\n### [Category Name] -- PRODUCTIVE (iteration N)\n- What worked: [successful review approaches in this category]\n- Prefer for: [related dimensions where this category may help]\n\n---\n\n## 11. RULED OUT DIRECTIONS\n[Review angles that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n- [Approach]: [Why ruled out] (iteration N, evidence: [source])\n\n---\n\n## 12. NEXT FOCUS\n<!-- MACHINE-OWNED: START -->\n[Recommended focus area for the next iteration -- updated at end of each iteration. Includes target dimension and/or specific files to review.]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 13. KNOWN CONTEXT\n[Populated during initialization from memory_context() results, if any prior work exists]\n\n---\n\n## 14. CROSS-REFERENCE STATUS\n<!-- MACHINE-OWNED: START -->\n[Alignment checks completed across core and overlay protocols]\n\n| Protocol | Level | Status | Iteration | Notes |\n|----------|-------|--------|-----------|-------|\n| `spec_code` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n| `checklist_evidence` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n| `skill_agent` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `agent_cross_runtime` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `feature_catalog_code` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `playbook_capability` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 15. FILES UNDER REVIEW\n<!-- MACHINE-OWNED: START -->\n[Per-file coverage state table -- populated during initialization from scope discovery]\n\n| File | Dimensions Reviewed | Last Iteration | Findings | Status |\n|------|-------------------|----------------|----------|--------|\n| [path/to/file] | [D1, D3] | [N] | [0 P0, 1 P1, 2 P2] | [partial/complete] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 16. REVIEW BOUNDARIES\n<!-- MACHINE-OWNED: START -->\n- Max iterations: [from config]\n- Convergence threshold: [from config]\n- Rolling STOP threshold: 0.08\n- No-progress threshold: 0.05\n- Coverage stabilization passes required: 1\n- Session lineage: sessionId=[from config.sessionId], parentSessionId=[from config.parentSessionId], generation=[from config.generation], lineageMode=[from config.lineageMode]\n- Findings registry: `deep-review-findings-registry.json`\n- Release-readiness states: in-progress | converged | release-blocking\n- Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n- Severity threshold: [from config.severityThreshold]\n- Review target type: [from config.reviewTargetType]\n- Cross-reference checks: core=[from config.crossReference.core], overlay=[from config.crossReference.overlay]\n- Started: [timestamp]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 17. EXAMPLE (POPULATED)\n\nReference snippet showing a partially populated strategy file mid-review. Use this as a visual anchor when opening a live strategy doc.\n\n```markdown\n## 1. REVIEW CHARTER\n- Target: .opencode/skills/deep-research (skill, v1.4.0)\n- Dimensions: correctness, test-coverage, cross-runtime-parity, observability\n- Stop conditions: rolling newInfoRatio < 0.08 for 2 iterations OR all dimensions converged OR max=7 reached\n- Success criteria: zero P0 in correctness; test-coverage P0 resolved or deferred with rationale\n\n## 4. NEXT FOCUS\n- Dimension: test-coverage\n- Files: .opencode/skills/deep-research/scripts/reduce-state.cjs, .opencode/skills/system-spec-kit/scripts/tests/deep-research-contract-parity.vitest.ts\n- Why: Iteration 2 surfaced a P0 (convergence-path coverage gap); needs a focused follow-up before correctness can terminate PASS.\n\n## 9. COVERAGE MATRIX\n| Dimension            | Status     | Iterations touched |\n|----------------------|------------|--------------------|\n| correctness          | converged  | 1                  |\n| test-coverage        | converging | 2, 4               |\n| cross-runtime-parity | converging | 3                  |\n| observability        | converging | 4                  |\n```","lineStart":1,"lineEnd":187,"totalLines":187,"truncated":false}},"title":".opencode/skills/deep-review/assets/deep_review_strategy.md","time":{"start":1780906985792,"end":1780906985804}},"metadata":{"openai":{"itemId":"fc_06766d70ffa8e198016a267be960e88191aa89e573d3f6a9f0"}},"id":"prt_ea65408fb00162w7DMo1cFJyHd","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea653e373001s3WicIAjm4qipO"}}
{"type":"tool_use","timestamp":1780906985808,"sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","part":{"type":"tool","tool":"read","callID":"call_zAP8ckuRDcMqaYhaGfdYu2EG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/review_mode_contract.yaml","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/review_mode_contract.yaml</path>\n<type>file</type>\n<content>\n1: # Canonical review-mode contract for deep-review.\n2: # This file is the single source of truth for review-mode taxonomy,\n3: # convergence settings, cross-reference protocols, downstream render targets,\n4: # and validation expectations.\n5: \n6: meta:\n7:   ownerSkill: deep-review\n8:   reviewModeVersion: 2\n9:   generatedNotice:\n10:     warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n11:     beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n12:     endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n13:   sourceOfTruth: .opencode/skills/deep-review/assets/review_mode_contract.yaml\n14: \n15: # Core contract definitions consumed by workflows, agents, docs, and validators.\n16: contract:\n17:   defaultTargetType: spec-folder\n18: \n19:   # Review target taxonomy.\n20:   targetTypes:\n21:     - id: spec-folder\n22:       cliValue: spec-folder\n23:       label: Spec Folder\n24:       description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n25:     - id: skill\n26:       cliValue: skill\n27:       label: Skill\n28:       description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n29:     - id: agent\n30:       cliValue: agent\n31:       label: Agent\n32:       description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n33:     - id: track\n34:       cliValue: track\n35:       label: Track\n36:       description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n37:     - id: files\n38:       cliValue: files\n39:       label: Files\n40:       description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n41: \n42:   # Simplified review dimensions. Traceability and maintainability absorb the\n43:   # prior seven-dimension model's overlap.\n44:   dimensions:\n45:     - id: correctness\n46:       priority: 1\n47:       label: Correctness\n48:       checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n49:       requiredForSeverityCoverage: true\n50:     - id: security\n51:       priority: 2\n52:       label: Security\n53:       checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n54:       requiredForSeverityCoverage: true\n55:     - id: traceability\n56:       priority: 3\n57:       label: Traceability\n58:       checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n59:       requiredForSeverityCoverage: false\n60:     - id: maintainability\n61:       priority: 4\n62:       label: Maintainability\n63:       checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n64:       requiredForSeverityCoverage: false\n65: \n66:   # Severity contract stays stable across review outputs.\n67:   severities:\n68:     - id: P0\n69:       weight: 10.0\n70:       label: Blocker\n71:       requiresFileLineEvidence: true\n72:     - id: P1\n73:       weight: 5.0\n74:       label: Required\n75:       requiresFileLineEvidence: true\n76:     - id: P2\n77:       weight: 1.0\n78:       label: Suggestion\n79:       requiresFileLineEvidence: true\n80: \n81:   # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n82:   verdicts:\n83:     - id: FAIL\n84:       label: Fail\n85:       condition: \"activeP0 > 0 OR any required quality gate fails\"\n86:       nextCommand: /speckit:plan\n87:     - id: CONDITIONAL\n88:       label: Conditional\n89:       condition: \"activeP0 == 0 AND activeP1 > 0\"\n90:       nextCommand: /speckit:plan\n91:     - id: PASS\n92:       label: Pass\n93:       condition: \"activeP0 == 0 AND activeP1 == 0\"\n94:       hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n95:       nextCommand: /create:changelog\n96: \n97:   # Binary gates applied after convergence math votes STOP.\n98:   qualityGates:\n99:     - id: evidence\n100:       label: Evidence\n101:       binary: true\n102:       combines:\n103:         - evidence-completeness\n104:         - no-inference-only\n105:       rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n106:     - id: scope\n107:       label: Scope\n108:       binary: true\n109:       combines:\n110:         - scope-alignment\n111:       rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n112:     - id: coverage\n113:       label: Coverage\n114:       binary: true\n115:       combines:\n116:         - severity-coverage\n117:         - cross-reference\n118:       rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n119: \n120:   # Review-specific convergence settings calibrated from the v2 research.\n121:   convergence:\n122:     defaults:\n123:       maxIterations: 7\n124:       convergenceThreshold: 0.10\n125:       stuckThreshold: 2\n126:     signals:\n127:       - id: rolling-average\n128:         weight: 0.30\n129:         description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n130:       - id: mad-noise-floor\n131:         weight: 0.25\n132:         description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n133:       - id: dimension-coverage\n134:         weight: 0.45\n135:         description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n136:     severityMath:\n137:       refinementMultiplier: 0.5\n138:       p0OverrideMinRatio: 0.50\n139:       noFindingsRatio: 0.0\n140:     coverageAge:\n141:       minStabilizationPasses: 1\n142:     thresholds:\n143:       rollingStopThreshold: 0.08\n144:       noProgressThreshold: 0.05\n145:       compositeStopScore: 0.60\n146: \n147:   lifecycleModes:\n148:     - id: new\n149:       description: Create a brand-new review lineage with generation 1 and no parent session.\n150:     - id: resume\n151:       description: Continue the current review lineage without changing generation.\n152:     - id: restart\n153:       description: Start a new generation for the same target and archive the prior review packet state.\n154:     - id: fork\n155:       status: deferred\n156:       description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n157:     - id: completed-continue\n158:       status: deferred\n159:       description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n160: \n161:   lineageFields:\n162:     - sessionId\n163:     - parentSessionId\n164:     - lineageMode\n165:     - generation\n166:     - continuedFromRun\n167: \n168:   reducer:\n169:     enabled: true\n170:     inputs:\n171:       - latestJSONLDelta\n172:       - newIterationFile\n173:       - priorReducedState\n174:     outputs:\n175:       - findingsRegistry\n176:       - dashboardMetrics\n177:       - strategyUpdates\n178:     failureModes:\n179:       malformedDelta: skip-and-warn\n180:       missingIterationFile: no-op-with-error\n181:       schemaMismatch: reject-with-conflict-event\n182:     idempotent: true\n183: \n184:   releaseReadinessStates:\n185:     - id: in-progress\n186:       description: Review is ongoing or coverage is incomplete.\n187:     - id: converged\n188:       description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n189:     - id: release-blocking\n190:       description: At least one unresolved P0 finding is present.\n191: \n192:   # Cross-reference protocols are typed traceability checks. Core protocols are\n193:   # hard gates; overlay protocols apply only to matching target types.\n194:   crossReferenceProtocols:\n195:     - id: spec_code\n196:       dimension: traceability\n197:       level: core\n198:       appliesTo: [spec-folder, skill, agent, track, files]\n199:       gateClass: hard\n200:       passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n201:       partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n202:       failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n203:     - id: checklist_evidence\n204:       dimension: traceability\n205:       level: core\n206:       appliesTo: [spec-folder, skill, agent, track, files]\n207:       gateClass: hard\n208:       passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n209:       partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n210:       failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n211:     - id: skill_agent\n212:       dimension: traceability\n213:       level: overlay\n214:       appliesTo: [skill]\n215:       gateClass: advisory\n216:       passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n217:       partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n218:       failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n219:     - id: agent_cross_runtime\n220:       dimension: traceability\n221:       level: overlay\n222:       appliesTo: [agent]\n223:       gateClass: advisory\n224:       passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n225:       partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n226:       failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n227:     - id: feature_catalog_code\n228:       dimension: traceability\n229:       level: overlay\n230:       appliesTo: [skill, spec-folder, track, files]\n231:       gateClass: advisory\n232:       passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n233:       partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n234:       failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n235:     - id: playbook_capability\n236:       dimension: traceability\n237:       level: overlay\n238:       appliesTo: [skill, agent, spec-folder]\n239:       gateClass: advisory\n240:       passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n241:       partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n242:       failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n243: \n244:   # Output contracts consumed by synthesis and replay tooling.\n245:   outputs:\n246:     config:\n247:       pathPattern: \"{artifact_dir}/deep-review-config.json\"\n248:       machineOwned: false\n249:       fields:\n250:         - sessionId\n251:         - parentSessionId\n252:         - lineageMode\n253:         - generation\n254:         - continuedFromRun\n255:         - releaseReadinessState\n256:     findingsRegistry:\n257:       pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n258:       machineOwned: true\n259:       sections:\n260:         - openFindings\n261:         - resolvedFindings\n262:         - repeatedFindings\n263:         - dimensionCoverage\n264:         - findingsBySeverity\n265:         - convergenceScore\n266:     reviewReport:\n267:       pathPattern: \"{artifact_dir}/review-report.md\"\n268:       sections:\n269:         - executive-summary\n270:         - planning-trigger\n271:         - active-finding-registry\n272:         - remediation-workstreams\n273:         - spec-seed\n274:         - plan-seed\n275:         - traceability-status\n276:         - deferred-items\n277:         - audit-appendix\n278:     strategy:\n279:       pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n280:       requiredSections:\n281:         - topic\n282:         - review-dimensions\n283:         - completed-dimensions\n284:         - running-findings\n285:         - what-worked\n286:         - what-failed\n287:         - exhausted-approaches\n288:         - ruled-out-directions\n289:         - next-focus\n290:         - known-context\n291:         - cross-reference-status\n292:         - files-under-review\n293:         - review-boundaries\n294:     dashboard:\n295:       pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n296:       machineOwned: true\n297:       sections:\n298:         - status\n299:         - findings-summary\n300:         - dimension-coverage\n301:         - progress\n302:         - next-focus\n303:     pauseSentinel:\n304:       pathPattern: \"{artifact_dir}/.deep-review-pause\"\n305:       machineOwned: false\n306:       description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n307:     jsonl:\n308:       pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n309:       iterationRecord:\n310:         required:\n311:           - type\n312:           - mode\n313:           - run\n314:           - status\n315:           - focus\n316:           - dimensions\n317:           - filesReviewed\n318:           - findingsCount\n319:           - findingsSummary\n320:           - findingsNew\n321:           - findingDetails\n322:           - newFindingsRatio\n323:           - sessionId\n324:           - generation\n325:           - lineageMode\n326:           - timestamp\n327:           - durationMs\n328:         optional:\n329:           - parentSessionId\n330:           - continuedFromRun\n331:           - findingsRefined\n332:           - findingRefs\n333:           - traceabilityChecks\n334:           - coverage\n335:           - noveltyJustification\n336:           - ruledOut\n337:           - focusTrack\n338:           - scoreEstimate\n339:           - segment\n340:           - convergenceSignals\n341:           - graphEvents\n342:       synthesisEvent:\n343:         required:\n344:           - type\n345:           - event\n346:           - mode\n347:           - totalIterations\n348:           - verdict\n349:           - activeP0\n350:           - activeP1\n351:           - activeP2\n352:           - dimensionCoverage\n353:           - stopReason\n354:           - timestamp\n355: \n356: # Render targets define where generated or mixed-authored contract fragments land.\n357: render:\n358:   artifacts:\n359:     - id: workflow-auto\n360:       path: .opencode/commands/deep/assets/deep_start-review-loop_auto.yaml\n361:       ownership: mixed\n362:       format: yaml\n363:       markers:\n364:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-auto -->\"\n365:         end: \"<!-- END GENERATED: review-mode-contract/workflow-auto -->\"\n366:       sections:\n367:         - target-types\n368:         - dimensions\n369:         - verdicts\n370:         - quality-gates\n371:         - convergence\n372:         - cross-reference-protocols\n373:     - id: workflow-confirm\n374:       path: .opencode/commands/deep/assets/deep_start-review-loop_confirm.yaml\n375:       ownership: mixed\n376:       format: yaml\n377:       markers:\n378:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-confirm -->\"\n379:         end: \"<!-- END GENERATED: review-mode-contract/workflow-confirm -->\"\n380:       sections:\n381:         - target-types\n382:         - dimensions\n383:         - verdicts\n384:         - quality-gates\n385:         - convergence\n386:         - cross-reference-protocols\n387:     - id: agent-opencode\n388:       path: .opencode/agents/deep-review.md\n389:       ownership: mixed\n390:       format: markdown\n391:       markers:\n392:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-opencode -->\"\n393:         end: \"<!-- END GENERATED: review-mode-contract/agent-opencode -->\"\n394:       sections:\n395:         - dimensions\n396:         - severities\n397:         - quality-gates\n398:         - cross-reference-protocols\n399:         - outputs\n400:     - id: agent-claude\n401:       path: .claude/agents/deep-review.md\n402:       ownership: mixed\n403:       format: markdown\n404:       markers:\n405:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-claude -->\"\n406:         end: \"<!-- END GENERATED: review-mode-contract/agent-claude -->\"\n407:       sections:\n408:         - dimensions\n409:         - severities\n410:         - quality-gates\n411:         - cross-reference-protocols\n412:         - outputs\n413:     - id: agent-codex\n414:       path: .codex/agents/deep-review.toml\n415:       ownership: mixed\n416:       format: toml\n417:       markers:\n418:         begin: \"# BEGIN GENERATED: review-mode-contract/agent-codex\"\n419:         end: \"# END GENERATED: review-mode-contract/agent-codex\"\n420:       sections:\n421:         - dimensions\n422:         - severities\n423:         - quality-gates\n424:         - cross-reference-protocols\n425:         - outputs\n426:     - id: quick-reference-review-mode\n427:       path: .opencode/skills/deep-review/references/protocol/quick_reference.md\n428:       ownership: mixed\n429:       format: markdown\n430:       markers:\n431:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n432:         end: \"<!-- END GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n433:       sections:\n434:         - target-types\n435:         - dimensions\n436:         - verdicts\n437:         - quality-gates\n438:         - outputs\n439:     - id: review-contract-snapshot\n440:       path: .opencode/skills/deep-review/assets/review_mode_contract_snapshot.md\n441:       ownership: generated\n442:       format: markdown\n443:       markers:\n444:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n445:         end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n446:       sections:\n447:         - meta\n448:         - target-types\n449:         - dimensions\n450:         - severities\n451:         - verdicts\n452:         - quality-gates\n453:         - convergence\n454:         - cross-reference-protocols\n455:         - outputs\n456:         - validation\n457: \n458: # Validator contract for CI, render verification, and drift detection.\n459: validation:\n460:   schemaVersion: 1\n461:   checks:\n462:     - id: schema\n463:       description: Validate this manifest against the canonical review-mode contract schema.\n464:     - id: render-verify\n465:       description: Re-render downstream artifacts in verify mode and fail on drift.\n466:     - id: marker-integrity\n467:       description: Ensure every render target contains intact begin/end markers with no overlapping generated blocks.\n468:     - id: enum-parity\n469:       description: Ensure target types, dimensions, severities, verdicts, and quality gates match across rendered artifacts.\n470:     - id: jsonl-parity\n471:       description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n472:     - id: lifecycle-parity\n473:       description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n474:     - id: reducer-contract\n475:       description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n476:     - id: duplicate-literal-lint\n477:       description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n478:     - id: runtime-coverage\n479:       description: Ensure every supported runtime deep-review agent has a declared render artifact and parity coverage.\n480:     - id: playbook-assertions\n481:       description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.\n\n(End of file - total 481 lines)\n</content>","metadata":{"preview":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n    beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n    endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n  sourceOfTruth: .opencode/skills/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  # Review target taxonomy.\n  targetTypes:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-review/assets/review_mode_contract.yaml","text":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n    beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n    endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n  sourceOfTruth: .opencode/skills/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  # Review target taxonomy.\n  targetTypes:\n    - id: spec-folder\n      cliValue: spec-folder\n      label: Spec Folder\n      description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n    - id: skill\n      cliValue: skill\n      label: Skill\n      description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n    - id: agent\n      cliValue: agent\n      label: Agent\n      description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n    - id: track\n      cliValue: track\n      label: Track\n      description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n    - id: files\n      cliValue: files\n      label: Files\n      description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n\n  # Simplified review dimensions. Traceability and maintainability absorb the\n  # prior seven-dimension model's overlap.\n  dimensions:\n    - id: correctness\n      priority: 1\n      label: Correctness\n      checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n      requiredForSeverityCoverage: true\n    - id: security\n      priority: 2\n      label: Security\n      checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n      requiredForSeverityCoverage: true\n    - id: traceability\n      priority: 3\n      label: Traceability\n      checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n      requiredForSeverityCoverage: false\n    - id: maintainability\n      priority: 4\n      label: Maintainability\n      checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n      requiredForSeverityCoverage: false\n\n  # Severity contract stays stable across review outputs.\n  severities:\n    - id: P0\n      weight: 10.0\n      label: Blocker\n      requiresFileLineEvidence: true\n    - id: P1\n      weight: 5.0\n      label: Required\n      requiresFileLineEvidence: true\n    - id: P2\n      weight: 1.0\n      label: Suggestion\n      requiresFileLineEvidence: true\n\n  # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n  verdicts:\n    - id: FAIL\n      label: Fail\n      condition: \"activeP0 > 0 OR any required quality gate fails\"\n      nextCommand: /speckit:plan\n    - id: CONDITIONAL\n      label: Conditional\n      condition: \"activeP0 == 0 AND activeP1 > 0\"\n      nextCommand: /speckit:plan\n    - id: PASS\n      label: Pass\n      condition: \"activeP0 == 0 AND activeP1 == 0\"\n      hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n      nextCommand: /create:changelog\n\n  # Binary gates applied after convergence math votes STOP.\n  qualityGates:\n    - id: evidence\n      label: Evidence\n      binary: true\n      combines:\n        - evidence-completeness\n        - no-inference-only\n      rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n    - id: scope\n      label: Scope\n      binary: true\n      combines:\n        - scope-alignment\n      rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n    - id: coverage\n      label: Coverage\n      binary: true\n      combines:\n        - severity-coverage\n        - cross-reference\n      rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n\n  # Review-specific convergence settings calibrated from the v2 research.\n  convergence:\n    defaults:\n      maxIterations: 7\n      convergenceThreshold: 0.10\n      stuckThreshold: 2\n    signals:\n      - id: rolling-average\n        weight: 0.30\n        description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n      - id: mad-noise-floor\n        weight: 0.25\n        description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n      - id: dimension-coverage\n        weight: 0.45\n        description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n    severityMath:\n      refinementMultiplier: 0.5\n      p0OverrideMinRatio: 0.50\n      noFindingsRatio: 0.0\n    coverageAge:\n      minStabilizationPasses: 1\n    thresholds:\n      rollingStopThreshold: 0.08\n      noProgressThreshold: 0.05\n      compositeStopScore: 0.60\n\n  lifecycleModes:\n    - id: new\n      description: Create a brand-new review lineage with generation 1 and no parent session.\n    - id: resume\n      description: Continue the current review lineage without changing generation.\n    - id: restart\n      description: Start a new generation for the same target and archive the prior review packet state.\n    - id: fork\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n    - id: completed-continue\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n\n  lineageFields:\n    - sessionId\n    - parentSessionId\n    - lineageMode\n    - generation\n    - continuedFromRun\n\n  reducer:\n    enabled: true\n    inputs:\n      - latestJSONLDelta\n      - newIterationFile\n      - priorReducedState\n    outputs:\n      - findingsRegistry\n      - dashboardMetrics\n      - strategyUpdates\n    failureModes:\n      malformedDelta: skip-and-warn\n      missingIterationFile: no-op-with-error\n      schemaMismatch: reject-with-conflict-event\n    idempotent: true\n\n  releaseReadinessStates:\n    - id: in-progress\n      description: Review is ongoing or coverage is incomplete.\n    - id: converged\n      description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n    - id: release-blocking\n      description: At least one unresolved P0 finding is present.\n\n  # Cross-reference protocols are typed traceability checks. Core protocols are\n  # hard gates; overlay protocols apply only to matching target types.\n  crossReferenceProtocols:\n    - id: spec_code\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n      partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n      failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n    - id: checklist_evidence\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n      partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n      failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n    - id: skill_agent\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill]\n      gateClass: advisory\n      passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n      partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n      failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n    - id: agent_cross_runtime\n      dimension: traceability\n      level: overlay\n      appliesTo: [agent]\n      gateClass: advisory\n      passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n      partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n      failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n    - id: feature_catalog_code\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, spec-folder, track, files]\n      gateClass: advisory\n      passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n      partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n      failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n    - id: playbook_capability\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, agent, spec-folder]\n      gateClass: advisory\n      passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n      partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n      failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n\n  # Output contracts consumed by synthesis and replay tooling.\n  outputs:\n    config:\n      pathPattern: \"{artifact_dir}/deep-review-config.json\"\n      machineOwned: false\n      fields:\n        - sessionId\n        - parentSessionId\n        - lineageMode\n        - generation\n        - continuedFromRun\n        - releaseReadinessState\n    findingsRegistry:\n      pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n      machineOwned: true\n      sections:\n        - openFindings\n        - resolvedFindings\n        - repeatedFindings\n        - dimensionCoverage\n        - findingsBySeverity\n        - convergenceScore\n    reviewReport:\n      pathPattern: \"{artifact_dir}/review-report.md\"\n      sections:\n        - executive-summary\n        - planning-trigger\n        - active-finding-registry\n        - remediation-workstreams\n        - spec-seed\n        - plan-seed\n        - traceability-status\n        - deferred-items\n        - audit-appendix\n    strategy:\n      pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n      requiredSections:\n        - topic\n        - review-dimensions\n        - completed-dimensions\n        - running-findings\n        - what-worked\n        - what-failed\n        - exhausted-approaches\n        - ruled-out-directions\n        - next-focus\n        - known-context\n        - cross-reference-status\n        - files-under-review\n        - review-boundaries\n    dashboard:\n      pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n      machineOwned: true\n      sections:\n        - status\n        - findings-summary\n        - dimension-coverage\n        - progress\n        - next-focus\n    pauseSentinel:\n      pathPattern: \"{artifact_dir}/.deep-review-pause\"\n      machineOwned: false\n      description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n    jsonl:\n      pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n      iterationRecord:\n        required:\n          - type\n          - mode\n          - run\n          - status\n          - focus\n          - dimensions\n          - filesReviewed\n          - findingsCount\n          - findingsSummary\n          - findingsNew\n          - findingDetails\n          - newFindingsRatio\n          - sessionId\n          - generation\n          - lineageMode\n          - timestamp\n          - durationMs\n        optional:\n          - parentSessionId\n          - continuedFromRun\n          - findingsRefined\n          - findingRefs\n          - traceabilityChecks\n          - coverage\n          - noveltyJustification\n          - ruledOut\n          - focusTrack\n          - scoreEstimate\n          - segment\n          - convergenceSignals\n          - graphEvents\n      synthesisEvent:\n        required:\n          - type\n          - event\n          - mode\n          - totalIterations\n          - verdict\n          - activeP0\n          - activeP1\n          - activeP2\n          - dimensionCoverage\n          - stopReason\n          - timestamp\n\n# Render targets define where generated or mixed-authored contract fragments land.\nrender:\n  artifacts:\n    - id: workflow-auto\n      path: .opencode/commands/deep/assets/deep_start-review-loop_auto.yaml\n      ownership: mixed\n      format: yaml\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-auto -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/workflow-auto -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n    - id: workflow-confirm\n      path: .opencode/commands/deep/assets/deep_start-review-loop_confirm.yaml\n      ownership: mixed\n      format: yaml\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-confirm -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/workflow-confirm -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n    - id: agent-opencode\n      path: .opencode/agents/deep-review.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-opencode -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/agent-opencode -->\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: agent-claude\n      path: .claude/agents/deep-review.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-claude -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/agent-claude -->\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: agent-codex\n      path: .codex/agents/deep-review.toml\n      ownership: mixed\n      format: toml\n      markers:\n        begin: \"# BEGIN GENERATED: review-mode-contract/agent-codex\"\n        end: \"# END GENERATED: review-mode-contract/agent-codex\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: quick-reference-review-mode\n      path: .opencode/skills/deep-review/references/protocol/quick_reference.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - outputs\n    - id: review-contract-snapshot\n      path: .opencode/skills/deep-review/assets/review_mode_contract_snapshot.md\n      ownership: generated\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n      sections:\n        - meta\n        - target-types\n        - dimensions\n        - severities\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n        - outputs\n        - validation\n\n# Validator contract for CI, render verification, and drift detection.\nvalidation:\n  schemaVersion: 1\n  checks:\n    - id: schema\n      description: Validate this manifest against the canonical review-mode contract schema.\n    - id: render-verify\n      description: Re-render downstream artifacts in verify mode and fail on drift.\n    - id: marker-integrity\n      description: Ensure every render target contains intact begin/end markers with no overlapping generated blocks.\n    - id: enum-parity\n      description: Ensure target types, dimensions, severities, verdicts, and quality gates match across rendered artifacts.\n    - id: jsonl-parity\n      description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n    - id: lifecycle-parity\n      description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n    - id: reducer-contract\n      description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n    - id: duplicate-literal-lint\n      description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n    - id: runtime-coverage\n      description: Ensure every supported runtime deep-review agent has a declared render artifact and parity coverage.\n    - id: playbook-assertions\n      description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.","lineStart":1,"lineEnd":481,"totalLines":481,"truncated":false}},"title":".opencode/skills/deep-review/assets/review_mode_contract.yaml","time":{"start":1780906985798,"end":1780906985806}},"metadata":{"openai":{"itemId":"fc_06766d70ffa8e198016a267be961348191a02a93a0a074af0e"}},"id":"prt_ea6540943001N5yYy9IIBNE5CE","sessionID":"ses_159adeef9ffepPqSo0MVC5zQx7","messageID":"msg_ea653e373001s3WicIAjm4qipO"}}
