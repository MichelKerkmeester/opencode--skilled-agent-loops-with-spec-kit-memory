{"type":"tool_use","timestamp":1782750700482,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_225a8868b7b744ad8d284de5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/design-command-surface-check.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/design-command-surface-check.mjs</path>\n<type>file</type>\n<content>\n1: // ============================================================================\n2: // Design Command Surface Check\n3: // ============================================================================\n4: \n5: import { readFile, readdir } from \"node:fs/promises\";\n6: \n7: const REQUIRED_FIELDS = [\n8:   \"command\",\n9:   \"ownerMode\",\n10:   \"description\",\n11:   \"descriptionRole\",\n12:   \"autoTriggerEligible\",\n13:   \"hubKeywordProjection\",\n14:   \"argumentHint\",\n15:   \"argumentGrammar\",\n16:   \"choreography\",\n17:   \"aliases\",\n18:   \"userIntent\",\n19:   \"copyGuard\",\n20:   \"accepts\",\n21:   \"returns\",\n22:   \"examples\",\n23:   \"next\",\n24:   \"handoff\",\n25:   \"proofFields\",\n26:   \"taskProjections\",\n27:   \"pipeline\",\n28:   \"registerPolicy\",\n29:   \"deferToHubWhen\",\n30:   \"preconditions\",\n31:   \"discriminator\",\n32:   \"toolPolicy\",\n33:   \"outputContract\"\n34: ];\n35: \n36: const COMMANDS = [\n37:   \"/design:audit\",\n38:   \"/design:foundations\",\n39:   \"/design:interface\",\n40:   \"/design:md-generator\",\n41:   \"/design:motion\"\n42: ];\n43: \n44: const FRONTMATTER_DRIFT_FIELDS = [\"description\", \"argument-hint\", \"allowed-tools\"];\n45: const DRIFT_FIELDS = [\n46:   ...FRONTMATTER_DRIFT_FIELDS,\n47:   \"emit-deliverable\",\n48:   \"example\",\n49:   \"example-invocation\",\n50:   \"example-prefix\",\n51:   \"returns\",\n52:   \"user-intent\",\n53:   \"sibling-discriminator\",\n54:   \"task-lanes\",\n55:   \"taskProjections\",\n56:   \"preconditions\",\n57:   \"pipeline\",\n58:   \"handoff\",\n59:   \"choreography\",\n60:   \"register\",\n61:   \"roster\",\n62:   \"wrapper\"\n63: ];\n64: const GENERIC_ARGUMENT_HINT = \"<design request>\";\n65: const READ_ONLY_TOOLS = [\"Read\", \"Glob\", \"Grep\"];\n66: const MUTATING_TOOLS = [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Glob\", \"Grep\"];\n67: const DRIFT_SORT_FIELDS = [...DRIFT_FIELDS];\n68: const PRECONDITION_FIELDS = [\n69:   \"requiredInputKind\",\n70:   \"missingInputQuestion\",\n71:   \"cannotRunWhen\",\n72:   \"escalateIf\",\n73:   \"routeInstead\"\n74: ];\n75: const REGISTER_POLICY_FIELDS = [\"accepted\", \"default\", \"resolutionOrder\", \"askWhen\", \"proofFields\"];\n76: const PRECONDITION_SECTION_MARKERS = [\"Requires:\", \"Ask-first:\", \"Cannot-run:\", \"Escalate:\"];\n77: const PIPELINE_FIELDS = [\"stage\", \"acceptsFrom\", \"produces\", \"nextCommands\", \"proofRequired\"];\n78: const PIPELINE_SECTION_MARKERS = [\n79:   \"Stage:\",\n80:   \"Accepts from:\",\n81:   \"Produces:\",\n82:   \"Hands to next\",\n83:   \"Hands to build:\",\n84:   \"Recommend-only:\"\n85: ];\n86: const PIPELINE_STATUS_TOKENS = [\"PRODUCES=\", \"NEXT=\", \"PROOF=\"];\n87: const HANDOFF_OPTION_FIELDS = [\"command\", \"when\"];\n88: const HANDOFF_STATUS_TOKENS = [\"NEXT_OPTIONS=\", \"HANDOFF_REQUIRED=\", \"HANDOFF_REASON=\"];\n89: const REQUIRED_RETURN_STATUS_TOKENS = [\n90:   \"STATUS=OK\",\n91:   \"STATUS=ASK MISSING=<input>\",\n92:   \"STATUS=FAIL ERROR=<named-cause>\",\n93:   \"STATUS=DEFER ROUTE=\"\n94: ];\n95: const STATUS_ONLY_FAILURE_PATTERN = /STATUS=FAIL\\s+ERROR=\"<message>\"/;\n96: const ARTIFACT_KINDS = new Set([\"report\", \"plan\", \"spec\", \"reference-doc\"]);\n97: const INTERFACE_COMMAND = \"/design:interface\";\n98: const INTERFACE_AUDIT_ROUTE = \"/design:audit\";\n99: const INTERFACE_TASK_CLASSES = new Set([\"sibling-command\", \"argument\", \"internal\", \"hidden\"]);\n100: const TASK_PROJECTION_STRICTNESS = new Set([\"advisory\"]);\n101: const TASK_PROJECTION_FIELDS = [\"verb\", \"ownerMode\", \"strictness\", \"referenceSources\", \"requires\", \"fixtures\"];\n102: const TASK_PROJECTIONS_NEGATIVE_CORPUS_MARKER = \"Negative corpus:\";\n103: const ARGUMENT_GRAMMAR_POSITIONAL_FIELDS = [\"name\", \"required\", \"kind\"];\n104: const ARGUMENT_GRAMMAR_FLAG_FIELDS = [\"name\", \"required\", \"takesValue\", \"kind\"];\n105: const CHOREOGRAPHY_FIELDS = [\"order\", \"skill\", \"resource\", \"action\"];\n106: const DESIGN_COMMAND_PATTERN = /\\/design:[a-z-]+/;\n107: const DESCRIPTION_ROLES = new Set([\"hub-keyword-projection\"]);\n108: const GENERIC_ARTIFACT_NAMES = new Set([\n109:   \"output\",\n110:   \"result\",\n111:   \"artifact\",\n112:   \"deliverable\",\n113:   \"data\",\n114:   \"response\",\n115:   \"file\",\n116:   \"document\",\n117:   \"thing\",\n118:   \"stuff\"\n119: ]);\n120: \n121: const scriptUrl = new URL(import.meta.url);\n122: const skillRootUrl = new URL(\"../../\", scriptUrl);\n123: const opencodeRootUrl = new URL(\"../../\", skillRootUrl);\n124: const metadataUrl = new URL(\"command-metadata.json\", skillRootUrl);\n125: const registryUrl = new URL(\"mode-registry.json\", skillRootUrl);\n126: const hubRouterUrl = new URL(\"hub-router.json\", skillRootUrl);\n127: const interfaceSkillUrl = new URL(\"design-interface/SKILL.md\", skillRootUrl);\n128: const commandsRootUrl = new URL(\"commands/design/\", opencodeRootUrl);\n129: const SIBLING_DISCRIMINATOR_START = \"<!-- ANCHOR:sibling-discriminator -->\";\n130: const SIBLING_DISCRIMINATOR_END = \"<!-- /ANCHOR:sibling-discriminator -->\";\n131: const REGISTER_SECTION_START = \"<!-- ANCHOR:register -->\";\n132: const REGISTER_SECTION_END = \"<!-- /ANCHOR:register -->\";\n133: \n134: const args = new Set(process.argv.slice(2));\n135: const jsonMode = args.has(\"--json\");\n136: const unknownArgs = [...args].filter((arg) => arg !== \"--json\");\n137: \n138: if (unknownArgs.length > 0) {\n139:   emitAndExit(\n140:     {\n141:       status: \"invalid\",\n142:       stage: \"usage\",\n143:       errors: unknownArgs.map((arg) => `unknown argument: ${arg}`),\n144:       drift: []\n145:     },\n146:     2\n147:   );\n148: }\n149: \n150: main().catch((error) => {\n151:   emitAndExit(\n152:     {\n153:       status: \"invalid\",\n154:       stage: \"runtime\",\n155:       errors: [error instanceof Error ? error.message : String(error)],\n156:       drift: []\n157:     },\n158:     2\n159:   );\n160: });\n161: \n162: async function main() {\n163:   const [metadata, registry, hubRouter, interfaceSkillSource, wrapperRoster] = await Promise.all([\n164:     readJson(metadataUrl),\n165:     readJson(registryUrl),\n166:     readJson(hubRouterUrl),\n167:     readFile(interfaceSkillUrl, \"utf8\"),\n168:     readWrapperRoster()\n169:   ]);\n170:   const workflowModes = readWorkflowModes(registry);\n171:   const registryAliasesByMode = readRegistryAliasesByMode(registry);\n172:   const interfaceIntentLanes = parseInterfaceIntentSignalKeys(interfaceSkillSource);\n173:   const metadataErrors = [\n174:     ...validateInterfaceIntentSignalKeys(interfaceIntentLanes),\n175:     ...validateMetadata(metadata, workflowModes, interfaceIntentLanes, registryAliasesByMode)\n176:   ];\n177: \n178:   if (metadataErrors.length > 0) {\n179:     emitAndExit(\n180:       {\n181:         status: \"invalid\",\n182:         stage: \"metadata\",\n183:         errors: metadataErrors,\n184:         drift: []\n185:       },\n186:       2\n187:     );\n188:   }\n189: \n190:   const records = [...metadata].sort((a, b) => a.command.localeCompare(b.command));\n191:   const drift = [\n192:     ...(await collectSurfaceDrift(records)),\n193:     ...collectRosterReconciliationDrift(records, workflowModes, hubRouter, wrapperRoster)\n194:   ].sort(compareDrift);\n195: \n196:   emitAndExit(\n197:     {\n198:       status: drift.length > 0 ? \"drift\" : \"pass\",\n199:       stage: drift.length > 0 ? \"surface\" : \"complete\",\n200:       metadata: {\n201:         commandCount: records.length,\n202:         workflowModes: [...workflowModes].sort(),\n203:         aliasCount: records.reduce((count, record) => count + record.aliases.length, 0)\n204:       },\n205:       drift\n206:     },\n207:     drift.length > 0 ? 1 : 0\n208:   );\n209: }\n210: \n211: async function readJson(url) {\n212:   const raw = await readFile(url, \"utf8\");\n213:   return JSON.parse(raw);\n214: }\n215: \n216: async function readWrapperRoster() {\n217:   const entries = await readdir(commandsRootUrl, { withFileTypes: true });\n218:   const wrappers = await Promise.all(\n219:     entries\n220:       .filter((entry) => entry.isFile() && entry.name.endsWith(\".md\"))\n221:       .map(async (entry) => {\n222:         const command = `/design:${entry.name.slice(0, -3)}`;\n223:         const relativePath = `.opencode/commands/design/${entry.name}`;\n224:         const markdown = await readFile(new URL(entry.name, commandsRootUrl), \"utf8\");\n225:         let frontmatter = null;\n226:         let frontmatterError = null;\n227: \n228:         try {\n229:           frontmatter = parseFrontmatter(markdown);\n230:         } catch (error) {\n231:           frontmatterError = error instanceof Error ? error.message : String(error);\n232:         }\n233: \n234:         return {\n235:           command,\n236:           relativePath,\n237:           markdown,\n238:           frontmatter,\n239:           frontmatterError\n240:         };\n241:       })\n242:   );\n243: \n244:   return wrappers.sort((a, b) => a.command.localeCompare(b.command));\n245: }\n246: \n247: function readWorkflowModes(registry) {\n248:   if (!registry || !Array.isArray(registry.modes)) {\n249:     return new Set();\n250:   }\n251: \n252:   return new Set(\n253:     registry.modes\n254:       .map((mode) => mode && mode.workflowMode)\n255:       .filter((workflowMode) => typeof workflowMode === \"string\" && workflowMode.length > 0)\n256:   );\n257: }\n258: \n259: function readRegistryAliasesByMode(registry) {\n260:   const aliasesByMode = new Map();\n261: \n262:   if (!registry || !Array.isArray(registry.modes)) {\n263:     return aliasesByMode;\n264:   }\n265: \n266:   for (const mode of registry.modes) {\n267:     if (typeof mode?.workflowMode !== \"string\" || mode.workflowMode.length === 0) {\n268:       continue;\n269:     }\n270: \n271:     aliasesByMode.set(\n272:       mode.workflowMode,\n273:       Array.isArray(mode.aliases) ? mode.aliases.filter((alias) => typeof alias === \"string\") : []\n274:     );\n275:   }\n276: \n277:   return aliasesByMode;\n278: }\n279: \n280: function readHubRouterModes(hubRouter) {\n281:   if (!isPlainObject(hubRouter?.routerSignals)) {\n282:     return new Set();\n283:   }\n284: \n285:   return new Set(\n286:     Object.keys(hubRouter.routerSignals)\n287:       .filter((workflowMode) => workflowMode.length > 0)\n288:   );\n289: }\n290: \n291: function validateMetadata(metadata, workflowModes, interfaceIntentLanes, registryAliasesByMode) {\n292:   const errors = [];\n293: \n294:   if (!Array.isArray(metadata)) {\n295:     return [\"metadata root must be an array\"];\n296:   }\n297: \n298:   const seenCommands = new Map();\n299:   const expectedCommands = new Set(COMMANDS);\n300:   const seenAliases = new Map();\n301:   const seenTaskProjectionVerbs = new Map();\n302:   const workflowCommandSet = commandSetForModes(workflowModes);\n303: \n304:   for (const record of metadata) {\n305:     const command = typeof record?.command === \"string\" ? record.command : \"<missing command>\";\n306: \n307:     for (const field of REQUIRED_FIELDS) {\n308:       if (!Object.hasOwn(record ?? {}, field)) {\n309:         errors.push(`${command}: missing required field ${field}`);\n310:       }\n311:     }\n312: \n313:     if (!expectedCommands.has(command)) {\n314:       errors.push(`${command}: command is not in the expected /design:* command set`);\n315:     }\n316: \n317:     if (seenCommands.has(command)) {\n318:       errors.push(`${command}: command is duplicated`);\n319:     } else {\n320:       seenCommands.set(command, record);\n321:     }\n322: \n323:     if (typeof record?.ownerMode !== \"string\" || !workflowModes.has(record.ownerMode)) {\n324:       errors.push(`${command}: ownerMode must match a workflowMode`);\n325:     }\n326: \n327:     for (const field of [\"description\", \"argumentHint\", \"accepts\", \"returns\", \"deferToHubWhen\"]) {\n328:       if (typeof record?.[field] !== \"string\" || record[field].length === 0) {\n329:         errors.push(`${command}: ${field} must be a non-empty string`);\n330:       }\n331:     }\n332: \n333:     for (const field of [\"aliases\", \"next\", \"proofFields\"]) {\n334:       if (!isNonEmptyStringArray(record?.[field])) {\n335:         errors.push(`${command}: ${field} must be a non-empty string array`);\n336:       }\n337:     }\n338: \n339:     errors.push(...validateDescriptionRoleProjection(record, command));\n340:     errors.push(...validateArgumentGrammar(record, command));\n341:     errors.push(...validateChoreography(record, command));\n342:     errors.push(...validateUserIntent(record, command));\n343: \n344:     if (typeof record?.toolPolicy?.mutatesWorkspace !== \"boolean\") {\n345:       errors.push(`${command}: toolPolicy.mutatesWorkspace must be a boolean`);\n346:     }\n347: \n348:     errors.push(...validatePreconditions(record, command));\n349:     errors.push(...validateRegisterPolicy(record, command));\n350:     errors.push(...validateExamples(record, command));\n351:     errors.push(...validateOutputContract(record, command));\n352:     errors.push(...validateDiscriminator(record, command, workflowModes));\n353:     errors.push(...validatePipeline(record, command, expectedCommands));\n354:     errors.push(...validateHandoff(record, command, expectedCommands));\n355:     errors.push(\n356:       ...validateTaskProjections(\n357:         record,\n358:         command,\n359:         workflowModes,\n360:         expectedCommands,\n361:         workflowCommandSet,\n362:         seenTaskProjectionVerbs,\n363:         registryAliasesByMode\n364:       )\n365:     );\n366: \n367:     if (command === INTERFACE_COMMAND) {\n368:       errors.push(...validateInterfaceTasks(record, command, interfaceIntentLanes, expectedCommands));\n369:     }\n370: \n371:     if (Array.isArray(record?.aliases)) {\n372:       for (const alias of record.aliases) {\n373:         const owner = seenAliases.get(alias);\n374:         if (owner && owner !== command) {\n375:           errors.push(`${command}: alias \"${alias}\" is already owned by ${owner}`);\n376:         } else {\n377:           seenAliases.set(alias, command);\n378:         }\n379:       }\n380:     }\n381:   }\n382: \n383:   for (const command of COMMANDS) {\n384:     if (!seenCommands.has(command)) {\n385:       errors.push(`${command}: missing metadata record`);\n386:     }\n387:   }\n388: \n389:   errors.push(...validatePipelineGraph(seenCommands));\n390: \n391:   return errors.sort();\n392: }\n393: \n394: function validateDescriptionRoleProjection(record, command) {\n395:   const errors = [];\n396: \n397:   if (typeof record?.descriptionRole !== \"string\" || record.descriptionRole.trim().length === 0) {\n398:     errors.push(`${command}: descriptionRole must be a non-empty string`);\n399:   } else if (!DESCRIPTION_ROLES.has(record.descriptionRole)) {\n400:     errors.push(`${command}: descriptionRole must be one of ${[...DESCRIPTION_ROLES].join(\",\")}`);\n401:   }\n402: \n403:   if (record?.autoTriggerEligible !== false) {\n404:     errors.push(`${command}: autoTriggerEligible must be the boolean false`);\n405:   }\n406: \n407:   if (!isNonEmptyStringArray(record?.hubKeywordProjection)) {\n408:     errors.push(`${command}: hubKeywordProjection must be a non-empty string array`);\n409:   } else {\n410:     const description = typeof record?.description === \"string\" ? record.description : \"\";\n411: \n412:     for (const token of record.hubKeywordProjection) {\n413:       if (!containsPhrase(description, token)) {\n414:         errors.push(`${command}: hubKeywordProjection token \"${token}\" must be a substring of description`);\n415:       }\n416:     }\n417:   }\n418: \n419:   const ownerMode = typeof record?.ownerMode === \"string\" ? record.ownerMode : \"<missing>\";\n420:   const expectedSuffix = `sk-design ${ownerMode} mode.`;\n421: \n422:   if (typeof record?.description !== \"string\" || !record.description.endsWith(expectedSuffix)) {\n423:     errors.push(`${command}: description must end with ${expectedSuffix}`);\n424:   }\n425: \n426:   return errors;\n427: }\n428: \n429: function validateArgumentGrammar(record, command) {\n430:   const errors = [];\n431:   const grammar = record?.argumentGrammar;\n432: \n433:   if (!isPlainObject(grammar)) {\n434:     return [`${command}: argumentGrammar must be an object`];\n435:   }\n436: \n437:   if (typeof grammar.render !== \"string\" || grammar.render.trim().length === 0) {\n438:     errors.push(`${command}: argumentGrammar.render must be a non-empty string`);\n439:   } else if (grammar.render !== record?.argumentHint) {\n440:     errors.push(`${command}: argumentGrammar.render must match argumentHint`);\n441:   }\n442: \n443:   if (!Array.isArray(grammar.positional) || grammar.positional.length === 0) {\n444:     errors.push(`${command}: argumentGrammar.positional must be a non-empty array`);\n445:   } else {\n446:     grammar.positional.forEach((token, index) => {\n447:       const label = `${command}: argumentGrammar.positional[${index}]`;\n448: \n449:       if (!isPlainObject(token)) {\n450:         errors.push(`${label} must be an object`);\n451:         return;\n452:       }\n453: \n454:       for (const field of ARGUMENT_GRAMMAR_POSITIONAL_FIELDS) {\n455:         if (!Object.hasOwn(token, field)) {\n456:           errors.push(`${label}.${field} is required`);\n457:         }\n458:       }\n459: \n460:       if (typeof token.name !== \"string\" || !/^[a-z][a-z0-9-]*$/.test(token.name)) {\n461:         errors.push(`${label}.name must use lowercase letters, numbers, and hyphens`);\n462:       }\n463: \n464:       if (token.required !== true && token.required !== false) {\n465:         errors.push(`${label}.required must be a boolean`);\n466:       }\n467: \n468:       if (typeof token.kind !== \"string\" || token.kind.trim().length === 0) {\n469:         errors.push(`${label}.kind must be a non-empty string`);\n470:       }\n471:     });\n472:   }\n473: \n474:   if (!Array.isArray(grammar.flags)) {\n475:     errors.push(`${command}: argumentGrammar.flags must be an array`);\n476:   } else {\n477:     grammar.flags.forEach((flag, index) => {\n478:       const label = `${command}: argumentGrammar.flags[${index}]`;\n479: \n480:       if (!isPlainObject(flag)) {\n481:         errors.push(`${label} must be an object`);\n482:         return;\n483:       }\n484: \n485:       for (const field of ARGUMENT_GRAMMAR_FLAG_FIELDS) {\n486:         if (!Object.hasOwn(flag, field)) {\n487:           errors.push(`${label}.${field} is required`);\n488:         }\n489:       }\n490: \n491:       if (typeof flag.name !== \"string\" || !/^--[a-z][a-z0-9-]*$/.test(flag.name)) {\n492:         errors.push(`${label}.name must be a long flag such as --scope`);\n493:       }\n494: \n495:       if (flag.required !== true && flag.required !== false) {\n496:         errors.push(`${label}.required must be a boolean`);\n497:       }\n498: \n499:       if (flag.takesValue !== true && flag.takesValue !== false) {\n500:         errors.push(`${label}.takesValue must be a boolean`);\n501:       }\n502: \n503:       if (typeof flag.kind !== \"string\" || flag.kind.trim().length === 0) {\n504:         errors.push(`${label}.kind must be a non-empty string`);\n505:       }\n506: \n507:       if (flag.takesValue === true && (typeof flag.valueName !== \"string\" || flag.valueName.trim().length === 0)) {\n508:         errors.push(`${label}.valueName must be a non-empty string when takesValue is true`);\n509:       }\n510:     });\n511:   }\n512: \n513:   return errors;\n514: }\n515: \n516: function validateChoreography(record, command) {\n517:   const errors = [];\n518:   const choreography = record?.choreography;\n519: \n520:   if (!Array.isArray(choreography) || choreography.length === 0) {\n521:     return [`${command}: choreography must be a non-empty array`];\n522:   }\n523: \n524:   const orders = [];\n525:   const seenOrders = new Set();\n526: \n527:   choreography.forEach((step, index) => {\n528:     const label = `${command}: choreography[${index}]`;\n529: \n530:     if (!isPlainObject(step)) {\n531:       errors.push(`${label} must be an object`);\n532:       return;\n533:     }\n534: \n535:     for (const field of CHOREOGRAPHY_FIELDS) {\n536:       if (!Object.hasOwn(step, field)) {\n537:         errors.push(`${label}.${field} is required`);\n538:       }\n539:     }\n540: \n541:     if (!Number.isInteger(step.order) || step.order < 1) {\n542:       errors.push(`${label}.order must be a positive integer`);\n543:     } else {\n544:       orders.push(step.order);\n545: \n546:       if (seenOrders.has(step.order)) {\n547:         errors.push(`${label}.order ${step.order} is duplicated`);\n548:       }\n549: \n550:       seenOrders.add(step.order);\n551:     }\n552: \n553:     for (const field of [\"skill\", \"resource\", \"action\"]) {\n554:       if (typeof step[field] !== \"string\" || step[field].trim().length === 0) {\n555:         errors.push(`${label}.${field} must be a non-empty string`);\n556:       }\n557:     }\n558:   });\n559: \n560:   const sortedOrders = [...orders].sort((left, right) => left - right);\n561:   sortedOrders.forEach((order, index) => {\n562:     const expectedOrder = index + 1;\n563:     if (order !== expectedOrder) {\n564:       errors.push(`${command}: choreography orders must be contiguous from 1`);\n565:     }\n566:   });\n567: \n568:   return errors;\n569: }\n570: \n571: function parseInterfaceIntentSignalKeys(source) {\n572:   const blockMatch = source.match(/^INTENT_SIGNALS\\s*=\\s*\\{([\\s\\S]*?)^}\\s*$/m);\n573:   if (!blockMatch) {\n574:     return [];\n575:   }\n576: \n577:   return [...blockMatch[1].matchAll(/^\\s+\"([A-Z_]+)\"\\s*:/gm)].map((match) => match[1]);\n578: }\n579: \n580: function validateInterfaceIntentSignalKeys(keys) {\n581:   if (keys.length === 0) {\n582:     return [`${INTERFACE_COMMAND}: interface router INTENT_SIGNALS block must expose at least one lane`];\n583:   }\n584: \n585:   const duplicates = duplicateValues(keys);\n586:   if (duplicates.length > 0) {\n587:     return [`${INTERFACE_COMMAND}: interface router INTENT_SIGNALS contains duplicate lanes [${duplicates.join(\",\")}]`];\n588:   }\n589: \n590:   return [];\n591: }\n592: \n593: function validateInterfaceTasks(record, command, interfaceIntentLanes, commandSet) {\n594:   const errors = [];\n595:   const tasks = record?.tasks;\n596: \n597:   if (!Array.isArray(tasks) || tasks.length === 0) {\n598:     return [`${command}: tasks must be a non-empty array`];\n599:   }\n600: \n601:   const expectedLanes = interfaceIntentLanes;\n602:   const expectedLaneSet = new Set(expectedLanes);\n603:   const actualLanes = [];\n604: \n605:   tasks.forEach((task, index) => {\n606:     const label = `${command}: tasks[${index}]`;\n607: \n608:     if (!isPlainObject(task)) {\n609:       errors.push(`${label} must be an object`);\n610:       return;\n611:     }\n612: \n613:     for (const field of [\"lane\", \"label\", \"class\", \"surface\"]) {\n614:       if (typeof task[field] !== \"string\" || task[field].trim().length === 0) {\n615:         errors.push(`${label}.${field} must be a non-empty string`);\n616:       }\n617:     }\n618: \n619:     if (typeof task.lane === \"string\" && task.lane.trim().length > 0) {\n620:       actualLanes.push(task.lane);\n621: \n622:       if (commandSet.has(task.lane)) {\n623:         errors.push(`${label}.lane must not be promoted into the /design:* command set`);\n624:       }\n625:     }\n626: \n627:     if (typeof task.class === \"string\" && !INTERFACE_TASK_CLASSES.has(task.class)) {\n628:       errors.push(`${label}.class must be one of ${[...INTERFACE_TASK_CLASSES].join(\",\")}`);\n629:     }\n630: \n631:     if (\n632:       typeof task.class === \"string\"\n633:       && task.class !== \"argument\"\n634:       && typeof task.surface === \"string\"\n635:       && DESIGN_COMMAND_PATTERN.test(task.surface)\n636:     ) {\n637:       errors.push(`${label}.surface must not name a /design:* command unless class is argument`);\n638:     }\n639:   });\n640: \n641:   const duplicateLanes = duplicateValues(actualLanes);\n642:   for (const lane of duplicateLanes) {\n643:     errors.push(`${command}: tasks lane ${lane} is duplicated`);\n644:   }\n645: \n646:   const actualLaneSet = new Set(actualLanes);\n647:   const missingLanes = expectedLanes.filter((lane) => !actualLaneSet.has(lane));\n648:   const extraLanes = [...actualLaneSet].filter((lane) => !expectedLaneSet.has(lane)).sort();\n649: \n650:   if (missingLanes.length > 0 || extraLanes.length > 0) {\n651:     errors.push(\n652:       `${command}: tasks lane set must match interface INTENT_SIGNALS missing=[${missingLanes.join(\",\")}] extra=[${extraLanes.join(\",\")}]`\n653:     );\n654:   }\n655: \n656:   return errors;\n657: }\n658: \n659: function validateTaskProjections(\n660:   record,\n661:   command,\n662:   workflowModes,\n663:   expectedCommands,\n664:   workflowCommandSet,\n665:   seenVerbs,\n666:   registryAliasesByMode\n667: ) {\n668:   const errors = [];\n669:   const projections = record?.taskProjections;\n670: \n671:   if (!Array.isArray(projections)) {\n672:     return [`${command}: taskProjections must be an array`];\n673:   }\n674: \n675:   projections.forEach((projection, index) => {\n676:     const label = `${command}: taskProjections[${index}]`;\n677: \n678:     if (!isPlainObject(projection)) {\n679:       errors.push(`${label} must be an object`);\n680:       return;\n681:     }\n682: \n683:     for (const field of TASK_PROJECTION_FIELDS) {\n684:       if (!Object.hasOwn(projection, field)) {\n685:         errors.push(`${label}.${field} is required`);\n686:       }\n687:     }\n688: \n689:     const verb = typeof projection.verb === \"string\" ? projection.verb.trim() : \"\";\n690:     if (verb.length === 0) {\n691:       errors.push(`${label}.verb must be a non-empty string`);\n692:     } else {\n693:       if (projection.verb !== verb || !/^[a-z][a-z-]*$/.test(verb)) {\n694:         errors.push(`${label}.verb must use lowercase letters and hyphens`);\n695:       }\n696: \n697:       const priorOwner = seenVerbs.get(verb);\n698:       if (priorOwner) {\n699:         errors.push(`${label}.verb ${verb} is already owned by ${priorOwner}`);\n700:       } else {\n701:         seenVerbs.set(verb, command);\n702:       }\n703: \n704:       const projectedCommand = `/design:${verb}`;\n705:       if (expectedCommands.has(projectedCommand) || workflowCommandSet.has(projectedCommand)) {\n706:         errors.push(`${label}.verb ${verb} must not be minted as ${projectedCommand}`);\n707:       }\n708: \n709:       errors.push(...validateTaskProjectionAliasCollisions(label, record?.ownerMode, verb, registryAliasesByMode));\n710:     }\n711: \n712:     if (typeof projection.ownerMode !== \"string\" || projection.ownerMode.trim().length === 0) {\n713:       errors.push(`${label}.ownerMode must be a non-empty string`);\n714:     } else {\n715:       if (projection.ownerMode !== record?.ownerMode) {\n716:         errors.push(`${label}.ownerMode must match record ownerMode ${record?.ownerMode ?? \"<missing>\"}`);\n717:       }\n718: \n719:       if (!workflowModes.has(projection.ownerMode)) {\n720:         errors.push(`${label}.ownerMode must match a workflowMode`);\n721:       }\n722:     }\n723: \n724:     if (typeof projection.strictness !== \"string\" || !TASK_PROJECTION_STRICTNESS.has(projection.strictness)) {\n725:       errors.push(`${label}.strictness must be one of ${[...TASK_PROJECTION_STRICTNESS].join(\",\")}`);\n726:     }\n727: \n728:     for (const field of [\"referenceSources\", \"fixtures\"]) {\n729:       if (!isNonEmptyStringArray(projection[field])) {\n730:         errors.push(`${label}.${field} must be a non-empty string array`);\n731:       } else {\n732:         errors.push(...validateUniqueArray(label, field, projection[field]));\n733:       }\n734:     }\n735: \n736:     if (typeof projection.requires !== \"string\" || projection.requires.trim().length === 0) {\n737:       errors.push(`${label}.requires must be a non-empty string`);\n738:     }\n739:   });\n740: \n741:   return errors;\n742: }\n743: \n744: function validateTaskProjectionAliasCollisions(label, ownerMode, verb, registryAliasesByMode) {\n745:   const errors = [];\n746: \n747:   if (typeof ownerMode !== \"string\" || ownerMode.length === 0) {\n748:     return errors;\n749:   }\n750: \n751:   for (const [workflowMode, aliases] of registryAliasesByMode) {\n752:     if (workflowMode === ownerMode) {\n753:       continue;\n754:     }\n755: \n756:     for (const alias of aliases) {\n757:       if (containsWholeWord(alias, verb)) {\n758:         errors.push(`${label}.verb ${verb} collides with ${workflowMode} alias \"${alias}\"`);\n759:       }\n760:     }\n761:   }\n762: \n763:   return errors;\n764: }\n765: \n766: function validatePreconditions(record, command) {\n767:   const errors = [];\n768:   const preconditions = record?.preconditions;\n769: \n770:   if (!isPlainObject(preconditions)) {\n771:     return [`${command}: preconditions must be an object`];\n772:   }\n773: \n774:   for (const field of PRECONDITION_FIELDS) {\n775:     if (typeof preconditions[field] !== \"string\" || preconditions[field].trim().length === 0) {\n776:       errors.push(`${command}: preconditions.${field} must be a non-empty string`);\n777:     }\n778:   }\n779: \n780:   return errors;\n781: }\n782: \n783: function validateRegisterPolicy(record, command) {\n784:   const errors = [];\n785:   const policy = record?.registerPolicy;\n786: \n787:   if (!isPlainObject(policy)) {\n788:     return [`${command}: registerPolicy must be an object`];\n789:   }\n790: \n791:   for (const field of REGISTER_POLICY_FIELDS) {\n792:     if (!Object.hasOwn(policy, field)) {\n793:       errors.push(`${command}: registerPolicy.${field} is required`);\n794:     }\n795:   }\n796: \n797:   if (!isNonEmptyStringArray(policy.accepted)) {\n798:     errors.push(`${command}: registerPolicy.accepted must be a non-empty string array`);\n799:   } else {\n800:     const accepted = new Set(policy.accepted);\n801:     for (const posture of [\"brand\", \"product\"]) {\n802:       if (!accepted.has(posture)) {\n803:         errors.push(`${command}: registerPolicy.accepted must include ${posture}`);\n804:       }\n805:     }\n806:   }\n807: \n808:   if (typeof policy.default !== \"string\" || policy.default.trim().length === 0) {\n809:     errors.push(`${command}: registerPolicy.default must be a non-empty string`);\n810:   } else if (policy.default !== \"auto\") {\n811:     errors.push(`${command}: registerPolicy.default must be auto`);\n812:   }\n813: \n814:   if (!isNonEmptyStringArray(policy.resolutionOrder)) {\n815:     errors.push(`${command}: registerPolicy.resolutionOrder must be a non-empty string array`);\n816:   }\n817: \n818:   if (typeof policy.askWhen !== \"string\" || policy.askWhen.trim().length === 0) {\n819:     errors.push(`${command}: registerPolicy.askWhen must be a non-empty string`);\n820:   }\n821: \n822:   if (!isNonEmptyStringArray(policy.proofFields)) {\n823:     errors.push(`${command}: registerPolicy.proofFields must be a non-empty string array`);\n824:   } else if (!policy.proofFields.includes(\"register\")) {\n825:     errors.push(`${command}: registerPolicy.proofFields must include register`);\n826:   }\n827: \n828:   return errors;\n829: }\n830: \n831: function validateDiscriminator(record, command, workflowModes) {\n832:   const errors = [];\n833:   const discriminator = record?.discriminator;\n834:   const commandSet = commandSetForModes(workflowModes);\n835:   const expectedSiblings = new Set([...commandSet].filter((sibling) => sibling !== command));\n836: \n837:   if (!isPlainObject(discriminator)) {\n838:     return [`${command}: discriminator must be an object`];\n839:   }\n840: \n841:   if (typeof discriminator.whenToUse !== \"string\" || discriminator.whenToUse.trim().length === 0) {\n842:     errors.push(`${command}: discriminator.whenToUse must be a non-empty string`);\n843:   }\n844: \n845:   if (typeof discriminator.pairWithHubWhen !== \"string\" || discriminator.pairWithHubWhen.trim().length === 0) {\n846:     errors.push(`${command}: discriminator.pairWithHubWhen must be a non-empty string`);\n847:   } else if (discriminator.pairWithHubWhen !== record?.deferToHubWhen) {\n848:     errors.push(`${command}: discriminator.pairWithHubWhen must match deferToHubWhen`);\n849:   }\n850: \n851:   if (!Array.isArray(discriminator.preferSiblingWhen) || discriminator.preferSiblingWhen.length === 0) {\n852:     errors.push(`${command}: discriminator.preferSiblingWhen must be a non-empty array`);\n853:   } else {\n854:     const seenSiblings = new Set();\n855: \n856:     discriminator.preferSiblingWhen.forEach((entry, index) => {\n857:       const label = `${command}: discriminator.preferSiblingWhen[${index}]`;\n858: \n859:       if (!isPlainObject(entry)) {\n860:         errors.push(`${label} must be an object`);\n861:         return;\n862:       }\n863: \n864:       if (typeof entry.sibling !== \"string\" || entry.sibling.trim().length === 0) {\n865:         errors.push(`${label}.sibling must be a non-empty string`);\n866:       } else {\n867:         if (!commandSet.has(entry.sibling)) {\n868:           errors.push(`${label}.sibling must be one of ${[...commandSet].sort().join(\",\")}`);\n869:         }\n870: \n871:         if (entry.sibling === command) {\n872:           errors.push(`${label}.sibling must not reference its own command`);\n873:         }\n874: \n875:         if (seenSiblings.has(entry.sibling)) {\n876:           errors.push(`${label}.sibling is duplicated`);\n877:         }\n878: \n879:         seenSiblings.add(entry.sibling);\n880:       }\n881: \n882:       if (typeof entry.when !== \"string\" || entry.when.trim().length === 0) {\n883:         errors.push(`${label}.when must be a non-empty string`);\n884:       }\n885:     });\n886: \n887:     if (!sameSet(seenSiblings, expectedSiblings)) {\n888:       errors.push(`${command}: discriminator.preferSiblingWhen must cover exactly ${[...expectedSiblings].sort().join(\",\")}`);\n889:     }\n890:   }\n891: \n892:   errors.push(...validateDiscriminatorSequence(record, command, discriminator.sequence, commandSet));\n893: \n894:   return errors;\n895: }\n896: \n897: function validateDiscriminatorSequence(record, command, sequence, commandSet) {\n898:   const errors = [];\n899: \n900:   if (!isPlainObject(sequence)) {\n901:     return [`${command}: discriminator.sequence must be an object`];\n902:   }\n903: \n904:   for (const field of [\"typicallyAfter\", \"typicallyBefore\"]) {\n905:     if (!isStringArray(sequence[field])) {\n906:       errors.push(`${command}: discriminator.sequence.${field} must be a string array`);\n907:       continue;\n908:     }\n909: \n910:     for (const item of sequence[field]) {\n911:       if (!commandSet.has(item)) {\n912:         errors.push(`${command}: discriminator.sequence.${field} contains unknown command ${item}`);\n913:       }\n914: \n915:       if (item === command) {\n916:         errors.push(`${command}: discriminator.sequence.${field} must not reference its own command`);\n917:       }\n918:     }\n919:   }\n920: \n921:   if (isStringArray(sequence.typicallyBefore) && Array.isArray(record?.next)) {\n922:     const nextSet = new Set(record.next);\n923:     for (const item of sequence.typicallyBefore) {\n924:       if (!nextSet.has(item)) {\n925:         errors.push(`${command}: discriminator.sequence.typicallyBefore must be a subset of next`);\n926:       }\n927:     }\n928:   }\n929: \n930:   return errors;\n931: }\n932: \n933: function validateExamples(record, command) {\n934:   const errors = [];\n935: \n936:   if (!Array.isArray(record?.examples) || record.examples.length === 0) {\n937:     return [`${command}: examples must be a non-empty array`];\n938:   }\n939: \n940:   record.examples.forEach((example, index) => {\n941:     const label = `${command}: examples[${index}]`;\n942: \n943:     if (!isPlainObject(example)) {\n944:       errors.push(`${label} must be an object`);\n945:       return;\n946:     }\n947: \n948:     if (typeof example.invocation !== \"string\" || example.invocation.trim().length === 0) {\n949:       errors.push(`${label}.invocation must be a non-empty string`);\n950:     } else if (firstToken(example.invocation) !== command) {\n951:       errors.push(`${label}.invocation must start with ${command}`);\n952:     }\n953: \n954:     if (typeof example.returnsArtifact !== \"string\" || example.returnsArtifact.trim().length === 0) {\n955:       errors.push(`${label}.returnsArtifact must be a non-empty string`);\n956:     }\n957:   });\n958: \n959:   return errors;\n960: }\n961: \n962: function validateOutputContract(record, command) {\n963:   const errors = [];\n964:   const contract = record?.outputContract;\n965: \n966:   if (!isPlainObject(contract)) {\n967:     return [`${command}: outputContract must be an object`];\n968:   }\n969: \n970:   if (typeof contract.primaryArtifactName !== \"string\" || contract.primaryArtifactName.trim().length === 0) {\n971:     errors.push(`${command}: outputContract.primaryArtifactName must be a non-empty string`);\n972:   } else if (isGenericArtifactName(contract.primaryArtifactName)) {\n973:     errors.push(`${command}: outputContract.primaryArtifactName must name a concrete artifact`);\n974:   }\n975: \n976:   if (typeof contract.artifactKind !== \"string\" || !ARTIFACT_KINDS.has(contract.artifactKind)) {\n977:     errors.push(`${command}: outputContract.artifactKind must be one of ${[...ARTIFACT_KINDS].join(\",\")}`);\n978:   }\n979: \n980:   if (!isNonEmptyStringArray(contract.requiredFields)) {\n981:     errors.push(`${command}: outputContract.requiredFields must be a non-empty string array`);\n982:   }\n983: \n984:   if (!isStringArray(contract.fileOutputs)) {\n985:     errors.push(`${command}: outputContract.fileOutputs must be a string array`);\n986:   }\n987: \n988:   if (Array.isArray(record?.proofFields) && Array.isArray(contract.requiredFields) && !sameValue(record.proofFields, contract.requiredFields)) {\n989:     errors.push(`${command}: outputContract.requiredFields must match proofFields`);\n990:   }\n991: \n992:   if (typeof record?.toolPolicy?.mutatesWorkspace === \"boolean\" && Array.isArray(contract.fileOutputs)) {\n993:     const hasFileOutputs = contract.fileOutputs.length > 0;\n994: \n995:     if (record.toolPolicy.mutatesWorkspace && !hasFileOutputs) {\n996:       errors.push(`${command}: outputContract.fileOutputs must be non-empty when toolPolicy.mutatesWorkspace is true`);\n997:     }\n998: \n999:     if (!record.toolPolicy.mutatesWorkspace && hasFileOutputs) {\n1000:       errors.push(`${command}: outputContract.fileOutputs must be empty when toolPolicy.mutatesWorkspace is false`);\n1001:     }\n1002:   }\n1003: \n1004:   return errors;\n1005: }\n1006: \n1007: function validatePipeline(record, command, commandSet) {\n1008:   const errors = [];\n1009:   const pipeline = record?.pipeline;\n1010: \n1011:   if (!isPlainObject(pipeline)) {\n1012:     return [`${command}: pipeline must be an object`];\n1013:   }\n1014: \n1015:   for (const field of PIPELINE_FIELDS) {\n1016:     if (!Object.hasOwn(pipeline, field)) {\n1017:       errors.push(`${command}: pipeline.${field} is required`);\n1018:     }\n1019:   }\n1020: \n1021:   if (typeof pipeline.stage !== \"string\" || pipeline.stage.trim().length === 0) {\n1022:     errors.push(`${command}: pipeline.stage must be a non-empty string`);\n1023:   }\n1024: \n1025:   if (typeof pipeline.produces !== \"string\" || pipeline.produces.trim().length === 0) {\n1026:     errors.push(`${command}: pipeline.produces must be a non-empty string`);\n1027:   } else if (pipeline.produces !== record?.outputContract?.primaryArtifactName) {\n1028:     errors.push(`${command}: pipeline.produces must match outputContract.primaryArtifactName`);\n1029:   }\n1030: \n1031:   errors.push(...validatePipelineCommandList(record, command, \"acceptsFrom\", commandSet, true));\n1032:   errors.push(...validatePipelineCommandList(record, command, \"nextCommands\", commandSet, false));\n1033: \n1034:   if (!isNonEmptyStringArray(pipeline.proofRequired)) {\n1035:     errors.push(`${command}: pipeline.proofRequired must be a non-empty string array`);\n1036:   } else {\n1037:     errors.push(...validateUniqueArray(command, \"pipeline.proofRequired\", pipeline.proofRequired));\n1038: \n1039:     if (Array.isArray(record?.proofFields) && !sameValue(pipeline.proofRequired, record.proofFields)) {\n1040:       errors.push(`${command}: pipeline.proofRequired must match proofFields`);\n1041:     }\n1042:   }\n1043: \n1044:   if (Array.isArray(pipeline.nextCommands) && Array.isArray(record?.next)) {\n1045:     const nextSet = new Set(record.next);\n1046:     for (const nextCommand of pipeline.nextCommands) {\n1047:       if (!nextSet.has(nextCommand)) {\n1048:         errors.push(`${command}: pipeline.nextCommands must be a subset of next`);\n1049:       }\n1050:     }\n1051:   }\n1052: \n1053:   return errors;\n1054: }\n1055: \n1056: function validatePipelineCommandList(record, command, field, commandSet, allowEmpty) {\n1057:   const errors = [];\n1058:   const value = record?.pipeline?.[field];\n1059:   const validArray = allowEmpty ? isStringArray(value) : isNonEmptyStringArray(value);\n1060: \n1061:   if (!validArray) {\n1062:     errors.push(`${command}: pipeline.${field} must be a ${allowEmpty ? \"\" : \"non-empty \"}string array`);\n1063:     return errors;\n1064:   }\n1065: \n1066:   errors.push(...validateUniqueArray(command, `pipeline.${field}`, value));\n1067: \n1068:   for (const item of value) {\n1069:     if (!commandSet.has(item)) {\n1070:       errors.push(`${command}: pipeline.${field} contains unknown command ${item}`);\n1071:     }\n1072: \n1073:     if (item === command) {\n1074:       errors.push(`${command}: pipeline.${field} must not reference its own command`);\n1075:     }\n1076:   }\n1077: \n1078:   return errors;\n1079: }\n1080: \n1081: function validatePipelineGraph(recordsByCommand) {\n1082:   const errors = [];\n1083:   const records = [...recordsByCommand.values()].filter((record) => isPlainObject(record?.pipeline));\n1084:   const stageOwners = new Map();\n1085: \n1086:   for (const record of records) {\n1087:     const stage = record.pipeline.stage;\n1088:     if (typeof stage !== \"string\" || stage.trim().length === 0) {\n1089:       continue;\n1090:     }\n1091: \n1092:     const owner = stageOwners.get(stage);\n1093:     if (owner) {\n1094:       errors.push(`${record.command}: pipeline.stage \"${stage}\" is already owned by ${owner}`);\n1095:     } else {\n1096:       stageOwners.set(stage, record.command);\n1097:     }\n1098:   }\n1099: \n1100:   for (const record of records) {\n1101:     if (!isStringArray(record.pipeline.acceptsFrom)) {\n1102:       continue;\n1103:     }\n1104: \n1105:     const expected = new Set();\n1106:     for (const upstream of records) {\n1107:       if (\n1108:         upstream.command !== record.command\n1109:         && Array.isArray(upstream.pipeline?.nextCommands)\n1110:         && upstream.pipeline.nextCommands.includes(record.command)\n1111:       ) {\n1112:         expected.add(upstream.command);\n1113:       }\n1114:     }\n1115: \n1116:     const actual = new Set(record.pipeline.acceptsFrom);\n1117:     if (!sameSet(actual, expected)) {\n1118:       errors.push(\n1119:         `${record.command}: pipeline.acceptsFrom must match inverse nextCommands expected [${[...expected].sort().join(\",\")}]`\n1120:       );\n1121:     }\n1122:   }\n1123: \n1124:   return errors;\n1125: }\n1126: \n1127: function validateHandoff(record, command, commandSet) {\n1128:   const errors = [];\n1129:   const handoff = record?.handoff;\n1130: \n1131:   if (!isPlainObject(handoff)) {\n1132:     return [`${command}: handoff must be an object`];\n1133:   }\n1134: \n1135:   for (const field of [\"nextOptions\", \"handoffRequired\", \"handoffReason\"]) {\n1136:     if (!Object.hasOwn(handoff, field)) {\n1137:       errors.push(`${command}: handoff.${field} is required`);\n1138:     }\n1139:   }\n1140: \n1141:   const optionCommands = [];\n1142: \n1143:   if (!Array.isArray(handoff.nextOptions) || handoff.nextOptions.length === 0) {\n1144:     errors.push(`${command}: handoff.nextOptions must be a non-empty array`);\n1145:   } else {\n1146:     const seenOptions = new Set();\n1147: \n1148:     handoff.nextOptions.forEach((option, index) => {\n1149:       const label = `${command}: handoff.nextOptions[${index}]`;\n1150: \n1151:       if (!isPlainObject(option)) {\n1152:         errors.push(`${label} must be an object`);\n1153:         return;\n1154:       }\n1155: \n1156:       for (const field of HANDOFF_OPTION_FIELDS) {\n1157:         if (!Object.hasOwn(option, field)) {\n1158:           errors.push(`${label}.${field} is required`);\n1159:         }\n1160:       }\n1161: \n1162:       if (typeof option.command !== \"string\" || option.command.trim().length === 0) {\n1163:         errors.push(`${label}.command must be a non-empty string`);\n1164:       } else {\n1165:         optionCommands.push(option.command);\n1166: \n1167:         if (!commandSet.has(option.command)) {\n1168:           errors.push(`${label}.command contains unknown command ${option.command}`);\n1169:         }\n1170: \n1171:         if (option.command === command) {\n1172:           errors.push(`${label}.command must not reference its own command`);\n1173:         }\n1174: \n1175:         if (seenOptions.has(option.command)) {\n1176:           errors.push(`${label}.command is duplicated`);\n1177:         }\n1178: \n1179:         seenOptions.add(option.command);\n1180:       }\n1181: \n1182:       if (typeof option.when !== \"string\" || option.when.trim().length === 0) {\n1183:         errors.push(`${label}.when must be a non-empty string`);\n1184:       }\n1185:     });\n1186:   }\n1187: \n1188:   if (!Array.isArray(record?.next)) {\n1189:     errors.push(`${command}: handoff.nextOptions cannot be checked until next is a string array`);\n1190:   } else if (!sameValue(optionCommands, record.next)) {\n1191:     errors.push(`${command}: handoff.nextOptions commands must match next exactly`);\n1192:   }\n1193: \n1194:   if (typeof handoff.handoffRequired !== \"boolean\") {\n1195:     errors.push(`${command}: handoff.handoffRequired must be a boolean`);\n1196:   } else if (handoff.handoffRequired !== false) {\n1197:     errors.push(`${command}: handoff.handoffRequired must be false for recommend-only command handoff`);\n1198:   }\n1199: \n1200:   if (typeof handoff.handoffReason !== \"string\" || handoff.handoffReason.trim().length === 0) {\n1201:     errors.push(`${command}: handoff.handoffReason must be a non-empty string`);\n1202:   }\n1203: \n1204:   return errors;\n1205: }\n1206: \n1207: function validateUserIntent(record, command) {\n1208:   const errors = [];\n1209:   const userIntent = record?.userIntent;\n1210: \n1211:   if (!isPlainObject(userIntent)) {\n1212:     errors.push(`${command}: userIntent must be an object`);\n1213:   } else {\n1214:     if (typeof userIntent.job !== \"string\" || userIntent.job.trim().length === 0) {\n1215:       errors.push(`${command}: userIntent.job must be a non-empty string`);\n1216:     }\n1217: \n1218:     if (!isNonEmptyStringArray(userIntent.ownedSignals)) {\n1219:       errors.push(`${command}: userIntent.ownedSignals must be a non-empty string array`);\n1220:     } else {\n1221:       errors.push(...validateUniqueArray(command, \"userIntent.ownedSignals\", userIntent.ownedSignals));\n1222: \n1223:       const aliases = new Set(Array.isArray(record?.aliases) ? record.aliases : []);\n1224:       for (const signal of userIntent.ownedSignals) {\n1225:         if (!aliases.has(signal)) {\n1226:           errors.push(`${command}: userIntent.ownedSignals contains non-alias signal ${signal}`);\n1227:         }\n1228:       }\n1229:     }\n1230:   }\n1231: \n1232:   if (!isNonEmptyStringArray(record?.copyGuard)) {\n1233:     errors.push(`${command}: copyGuard must be a non-empty string array`);\n1234:   } else {\n1235:     errors.push(...validateUniqueArray(command, \"copyGuard\", record.copyGuard));\n1236:   }\n1237: \n1238:   return errors;\n1239: }\n1240: \n1241: function validateUniqueArray(command, field, values) {\n1242:   const errors = [];\n1243:   const seen = new Set();\n1244: \n1245:   for (const value of values) {\n1246:     if (seen.has(value)) {\n1247:       errors.push(`${command}: ${field} contains duplicate value ${value}`);\n1248:     }\n1249:     seen.add(value);\n1250:   }\n1251: \n1252:   return errors;\n1253: }\n1254: \n1255: function duplicateValues(values) {\n1256:   const seen = new Set();\n1257:   const duplicates = new Set();\n1258: \n1259:   for (const value of values) {\n1260:     if (seen.has(value)) {\n1261:       duplicates.add(value);\n1262:     }\n1263:     seen.add(value);\n1264:   }\n1265: \n1266:   return [...duplicates].sort();\n1267: }\n1268: \n1269: function isPlainObject(value) {\n1270:   return Boolean(value) && typeof value === \"object\" && !Array.isArray(value);\n1271: }\n1272: \n1273: function isNonEmptyStringArray(value) {\n1274:   return Array.isArray(value) && value.length > 0 && value.every((item) => typeof item === \"string\" && item.length > 0);\n1275: }\n1276: \n1277: function isStringArray(value) {\n1278:   return Array.isArray(value) && value.every((item) => typeof item === \"string\" && item.length > 0);\n1279: }\n1280: \n1281: function isGenericArtifactName(value) {\n1282:   const normalized = value.trim().toLowerCase();\n1283: \n1284:   if (GENERIC_ARTIFACT_NAMES.has(normalized)) {\n1285:     return true;\n1286:   }\n1287: \n1288:   const words = normalized.split(/[^a-z0-9]+/).filter(Boolean);\n1289:   return words.length > 0 && words.every((word) => GENERIC_ARTIFACT_NAMES.has(word));\n1290: }\n1291: \n1292: async function collectSurfaceDrift(records) {\n1293:   const drift = [];\n1294: \n1295:   for (const record of records) {\n1296:     const wrapperPath = wrapperPathForCommand(record.command);\n1297:     let markdown;\n1298:     let frontmatter;\n1299: \n1300:     try {\n1301:       markdown = await readFile(wrapperPath.url, \"utf8\");\n1302:       frontmatter = parseFrontmatter(markdown);\n1303:     } catch (error) {\n1304:       drift.push({\n1305:         command: record.command,\n1306:         field: \"wrapper\",\n1307:         expected: wrapperPath.relativePath,\n1308:         actual: error instanceof Error ? error.message : String(error)\n1309:       });\n1310:       continue;\n1311:     }\n1312: \n1313:     for (const field of FRONTMATTER_DRIFT_FIELDS) {\n1314:       const expected = expectedFrontmatterValue(record, field);\n1315:       const actual = frontmatter[field];\n1316:       const isGenericArgumentHint = field === \"argument-hint\" && actual === GENERIC_ARGUMENT_HINT;\n1317: \n1318:       if (isGenericArgumentHint || !sameValue(expected, actual)) {\n1319:         drift.push({\n1320:           command: record.command,\n1321:           field,\n1322:           expected,\n1323:           actual: Object.hasOwn(frontmatter, field) ? actual : \"<missing>\"\n1324:         });\n1325:       }\n1326:     }\n1327: \n1328:     const deliverableDrift = expectedEmitDeliverableDrift(record, markdown);\n1329:     if (deliverableDrift) {\n1330:       drift.push(deliverableDrift);\n1331:     }\n1332: \n1333:     drift.push(...expectedUserIntentDrift(record, markdown));\n1334:     drift.push(...expectedExampleDrift(record, markdown, wrapperPath));\n1335:     drift.push(...expectedDiscriminatorDrift(record, markdown));\n1336:     drift.push(...expectedPreconditionsDrift(record, markdown));\n1337:     drift.push(...expectedPipelineDrift(record, markdown));\n1338:     drift.push(...expectedHandoffDrift(record, markdown));\n1339:     drift.push(...expectedChoreographyDrift(record, markdown));\n1340:     drift.push(...expectedRegisterDrift(record, markdown));\n1341:     drift.push(...expectedTaskProjectionsDrift(record, markdown));\n1342: \n1343:     if (record.command === INTERFACE_COMMAND) {\n1344:       drift.push(...expectedInterfaceTaskLanesDrift(record, markdown));\n1345:     }\n1346:   }\n1347: \n1348:   return drift.sort(compareDrift);\n1349: }\n1350: \n1351: function collectRosterReconciliationDrift(records, workflowModes, hubRouter, wrappers) {\n1352:   const drift = [];\n1353:   const metadataCommands = new Set(records.map((record) => record.command));\n1354:   const wrapperCommands = new Set(wrappers.map((wrapper) => wrapper.command));\n1355:   const hubModes = readHubRouterModes(hubRouter);\n1356:   const hubCommands = commandSetForModes(hubModes);\n1357:   const registryCommands = commandSetForModes(workflowModes);\n1358:   const reconciledCommands = intersectSets(metadataCommands, wrapperCommands, hubCommands, registryCommands);\n1359: \n1360:   for (const wrapper of wrappers) {\n1361:     if (!metadataCommands.has(wrapper.command)) {\n1362:       drift.push(rosterDrift(\"orphan-wrapper\", wrapper.command, \"metadata record\", wrapper.relativePath));\n1363:     }\n1364: \n1365:     if (wrapper.frontmatterError) {\n1366:       drift.push(rosterDrift(\"dead-wrapper\", wrapper.command, \"parseable frontmatter\", wrapper.frontmatterError));\n1367:     }\n1368: \n1369:     if (!hasCommandTitle(wrapper.markdown, wrapper.command)) {\n1370:       drift.push(rosterDrift(\"dead-wrapper\", wrapper.command, `# ${wrapper.command}`, \"<missing or mismatched title>\"));\n1371:     }\n1372: \n1373:     if (hasPlaceholderWrapper(wrapper)) {\n1374:       drift.push(rosterDrift(\"placeholder-wrapper\", wrapper.command, \"specific argument contract\", GENERIC_ARGUMENT_HINT));\n1375:     }\n1376:   }\n1377: \n1378:   for (const command of sortedSet(metadataCommands)) {\n1379:     if (!wrapperCommands.has(command)) {\n1380:       drift.push(rosterDrift(\"missing-wrapper\", command, wrapperPathForCommand(command).relativePath, \"<missing>\"));\n1381:     }\n1382: \n1383:     if (!hubCommands.has(command)) {\n1384:       drift.push(rosterDrift(\"route-fixture-drift\", command, \"hub-router routable command\", \"<missing router signal>\"));\n1385:     }\n1386:   }\n1387: \n1388:   for (const command of sortedSet(wrapperCommands)) {\n1389:     if (!hubCommands.has(command)) {\n1390:       drift.push(rosterDrift(\"route-fixture-drift\", command, \"hub-router routable command\", \"wrapper-only command\"));\n1391:     }\n1392:   }\n1393: \n1394:   for (const command of sortedSet(hubCommands)) {\n1395:     const workflowMode = command.replace(\"/design:\", \"\");\n1396: \n1397:     if (!registryCommands.has(command)) {\n1398:       drift.push(rosterDrift(\"route-fixture-drift\", command, \"mode-registry workflowMode\", `hub-router routerSignals.${workflowMode}`));\n1399:     }\n1400: \n1401:     if (!metadataCommands.has(command)) {\n1402:       drift.push(rosterDrift(\"route-fixture-drift\", command, \"metadata record\", `hub-router routerSignals.${workflowMode}`));\n1403:     }\n1404: \n1405:     if (!wrapperCommands.has(command) && !metadataCommands.has(command)) {\n1406:       drift.push(rosterDrift(\"missing-wrapper\", command, wrapperPathForCommand(command).relativePath, `hub-router routerSignals.${workflowMode}`));\n1407:     }\n1408:   }\n1409: \n1410:   for (const record of records) {\n1411:     drift.push(...collectDanglingHandoffDrift(record, reconciledCommands));\n1412:   }\n1413: \n1414:   return uniqueDrift(drift).sort(compareDrift);\n1415: }\n1416: \n1417: function collectDanglingHandoffDrift(record, commandSet) {\n1418:   const drift = [];\n1419: \n1420:   for (const command of Array.isArray(record.next) ? record.next : []) {\n1421:     if (!commandSet.has(command)) {\n1422:       drift.push(rosterDrift(\"dangling-handoff\", record.command, \"next command in reconciled roster\", command));\n1423:     }\n1424:   }\n1425: \n1426:   const nextOptions = Array.isArray(record.handoff?.nextOptions) ? record.handoff.nextOptions : [];\n1427:   for (const option of nextOptions) {\n1428:     const command = option?.command;\n1429:     if (typeof command === \"string\" && !commandSet.has(command)) {\n1430:       drift.push(rosterDrift(\"dangling-handoff\", record.command, \"nextOptions command in reconciled roster\", command));\n1431:     }\n1432:   }\n1433: \n1434:   return drift;\n1435: }\n1436: \n1437: function rosterDrift(kind, command, expected, actual) {\n1438:   return {\n1439:     kind,\n1440:     command,\n1441:     field: \"roster\",\n1442:     expected,\n1443:     actual\n1444:   };\n1445: }\n1446: \n1447: function hasCommandTitle(markdown, command) {\n1448:   return new RegExp(`^#\\\\s+${escapeRegExp(command)}\\\\s*$`, \"m\").test(markdown);\n1449: }\n1450: \n1451: function hasPlaceholderWrapper(wrapper) {\n1452:   return wrapper.markdown.includes(GENERIC_ARGUMENT_HINT)\n1453:     || wrapper.frontmatter?.[\"argument-hint\"] === GENERIC_ARGUMENT_HINT;\n1454: }\n1455: \n1456: function expectedHandoffDrift(record, markdown) {\n1457:   const section = extractHandoffGrammarSection(markdown);\n1458: \n1459:   if (!section) {\n1460:     return [\n1461:       {\n1462:         kind: \"handoff\",\n1463:         command: record.command,\n1464:         field: \"handoff\",\n1465:         expected: \"## HANDOFF GRAMMAR\",\n1466:         actual: \"<missing section>\"\n1467:       }\n1468:     ];\n1469:   }\n1470: \n1471:   const drift = [];\n1472:   const handoff = record.handoff;\n1473:   const nextOptionCommands = Array.isArray(handoff?.nextOptions)\n1474:     ? handoff.nextOptions.map((option) => option.command)\n1475:     : [];\n1476:   const expectedLines = [\n1477:     `NEXT_OPTIONS=${nextOptionCommands.join(\",\")}`,\n1478:     `HANDOFF_REQUIRED=${String(handoff?.handoffRequired)}`,\n1479:     `HANDOFF_REASON=\"${handoff?.handoffReason}\"`\n1480:   ];\n1481: \n1482:   for (const token of HANDOFF_STATUS_TOKENS) {\n1483:     if (!section.includes(token)) {\n1484:       drift.push({\n1485:         kind: \"handoff\",\n1486:         command: record.command,\n1487:         field: \"handoff\",\n1488:         expected: token,\n1489:         actual: \"<missing handoff token>\"\n1490:       });\n1491:     }\n1492:   }\n1493: \n1494:   for (const expectedLine of expectedLines) {\n1495:     if (!section.includes(expectedLine)) {\n1496:       drift.push({\n1497:         kind: \"handoff\",\n1498:         command: record.command,\n1499:         field: \"handoff\",\n1500:         expected: expectedLine,\n1501:         actual: \"<missing or mismatched handoff value>\"\n1502:       });\n1503:     }\n1504:   }\n1505: \n1506:   for (const option of handoff.nextOptions) {\n1507:     if (!section.includes(option.command)) {\n1508:       drift.push({\n1509:         kind: \"handoff\",\n1510:         command: record.command,\n1511:         field: \"handoff\",\n1512:         expected: option.command,\n1513:         actual: \"<missing next option command>\"\n1514:       });\n1515:     }\n1516: \n1517:     if (!containsPhrase(section, option.when)) {\n1518:       drift.push({\n1519:         kind: \"handoff\",\n1520:         command: record.command,\n1521:         field: \"handoff\",\n1522:         expected: option.when,\n1523:         actual: \"<missing next option rationale>\"\n1524:       });\n1525:     }\n1526:   }\n1527: \n1528:   if (handoff.handoffRequired === false && !section.includes(\"HANDOFF_REQUIRED=false\")) {\n1529:     drift.push({\n1530:       kind: \"handoff\",\n1531:       command: record.command,\n1532:       field: \"handoff\",\n1533:       expected: \"HANDOFF_REQUIRED=false\",\n1534:       actual: \"<missing recommend-only handoff flag>\"\n1535:     });\n1536:   }\n1537: \n1538:   if (!containsPhrase(section, \"never silently chains\")) {\n1539:     drift.push({\n1540:       kind: \"handoff\",\n1541:       command: record.command,\n1542:       field: \"handoff\",\n1543:       expected: \"never silently chains\",\n1544:       actual: \"<missing no-silent-chain assertion>\"\n1545:     });\n1546:   }\n1547: \n1548:   return drift;\n1549: }\n1550: \n1551: function expectedTaskProjectionsDrift(record, markdown) {\n1552:   const section = extractTaskProjectionsSection(markdown);\n1553: \n1554:   if (!section) {\n1555:     return [\n1556:       {\n1557:         kind: \"taskProjections\",\n1558:         command: record.command,\n1559:         field: \"taskProjections\",\n1560:         expected: \"## TASK PROJECTIONS\",\n1561:         actual: \"<missing section>\"\n1562:       }\n1563:     ];\n1564:   }\n1565: \n1566:   const drift = [];\n1567:   const projections = Array.isArray(record.taskProjections) ? record.taskProjections : [];\n1568: \n1569:   for (const projection of projections) {\n1570:     if (!isPlainObject(projection) || typeof projection.verb !== \"string\" || projection.verb.length === 0) {\n1571:       continue;\n1572:     }\n1573: \n1574:     if (!containsWholeWord(section, projection.verb)) {\n1575:       drift.push({\n1576:         kind: \"taskProjections\",\n1577:         command: record.command,\n1578:         field: \"taskProjections\",\n1579:         expected: projection.verb,\n1580:         actual: \"<missing projection verb>\"\n1581:       });\n1582:     }\n1583:   }\n1584: \n1585:   if (projections.length === 0 && !containsPhrase(section, \"No transform-verb projections\")) {\n1586:     drift.push({\n1587:       kind: \"taskProjections\",\n1588:       command: record.command,\n1589:       field: \"taskProjections\",\n1590:       expected: \"No transform-verb projections\",\n1591:       actual: \"<missing empty-projection notice>\"\n1592:     });\n1593:   }\n1594: \n\n(Output capped at 50 KB. Showing lines 1-1594. Use offset=1595 to continue.)\n</content>","metadata":{"preview":"// ============================================================================\n// Design Command Surface Check\n// ============================================================================\n\nimport { readFile, readdir } from \"node:fs/promises\";\n\nconst REQUIRED_FIELDS = [\n  \"command\",\n  \"ownerMode\",\n  \"description\",\n  \"descriptionRole\",\n  \"autoTriggerEligible\",\n  \"hubKeywordProjection\",\n  \"argumentHint\",\n  \"argumentGrammar\",\n  \"choreography\",\n  \"aliases\",\n  \"userIntent\",\n  \"copyGuard\",\n  \"accepts\",","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/design-command-surface-check.mjs","text":"// ============================================================================\n// Design Command Surface Check\n// ============================================================================\n\nimport { readFile, readdir } from \"node:fs/promises\";\n\nconst REQUIRED_FIELDS = [\n  \"command\",\n  \"ownerMode\",\n  \"description\",\n  \"descriptionRole\",\n  \"autoTriggerEligible\",\n  \"hubKeywordProjection\",\n  \"argumentHint\",\n  \"argumentGrammar\",\n  \"choreography\",\n  \"aliases\",\n  \"userIntent\",\n  \"copyGuard\",\n  \"accepts\",\n  \"returns\",\n  \"examples\",\n  \"next\",\n  \"handoff\",\n  \"proofFields\",\n  \"taskProjections\",\n  \"pipeline\",\n  \"registerPolicy\",\n  \"deferToHubWhen\",\n  \"preconditions\",\n  \"discriminator\",\n  \"toolPolicy\",\n  \"outputContract\"\n];\n\nconst COMMANDS = [\n  \"/design:audit\",\n  \"/design:foundations\",\n  \"/design:interface\",\n  \"/design:md-generator\",\n  \"/design:motion\"\n];\n\nconst FRONTMATTER_DRIFT_FIELDS = [\"description\", \"argument-hint\", \"allowed-tools\"];\nconst DRIFT_FIELDS = [\n  ...FRONTMATTER_DRIFT_FIELDS,\n  \"emit-deliverable\",\n  \"example\",\n  \"example-invocation\",\n  \"example-prefix\",\n  \"returns\",\n  \"user-intent\",\n  \"sibling-discriminator\",\n  \"task-lanes\",\n  \"taskProjections\",\n  \"preconditions\",\n  \"pipeline\",\n  \"handoff\",\n  \"choreography\",\n  \"register\",\n  \"roster\",\n  \"wrapper\"\n];\nconst GENERIC_ARGUMENT_HINT = \"<design request>\";\nconst READ_ONLY_TOOLS = [\"Read\", \"Glob\", \"Grep\"];\nconst MUTATING_TOOLS = [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Glob\", \"Grep\"];\nconst DRIFT_SORT_FIELDS = [...DRIFT_FIELDS];\nconst PRECONDITION_FIELDS = [\n  \"requiredInputKind\",\n  \"missingInputQuestion\",\n  \"cannotRunWhen\",\n  \"escalateIf\",\n  \"routeInstead\"\n];\nconst REGISTER_POLICY_FIELDS = [\"accepted\", \"default\", \"resolutionOrder\", \"askWhen\", \"proofFields\"];\nconst PRECONDITION_SECTION_MARKERS = [\"Requires:\", \"Ask-first:\", \"Cannot-run:\", \"Escalate:\"];\nconst PIPELINE_FIELDS = [\"stage\", \"acceptsFrom\", \"produces\", \"nextCommands\", \"proofRequired\"];\nconst PIPELINE_SECTION_MARKERS = [\n  \"Stage:\",\n  \"Accepts from:\",\n  \"Produces:\",\n  \"Hands to next\",\n  \"Hands to build:\",\n  \"Recommend-only:\"\n];\nconst PIPELINE_STATUS_TOKENS = [\"PRODUCES=\", \"NEXT=\", \"PROOF=\"];\nconst HANDOFF_OPTION_FIELDS = [\"command\", \"when\"];\nconst HANDOFF_STATUS_TOKENS = [\"NEXT_OPTIONS=\", \"HANDOFF_REQUIRED=\", \"HANDOFF_REASON=\"];\nconst REQUIRED_RETURN_STATUS_TOKENS = [\n  \"STATUS=OK\",\n  \"STATUS=ASK MISSING=<input>\",\n  \"STATUS=FAIL ERROR=<named-cause>\",\n  \"STATUS=DEFER ROUTE=\"\n];\nconst STATUS_ONLY_FAILURE_PATTERN = /STATUS=FAIL\\s+ERROR=\"<message>\"/;\nconst ARTIFACT_KINDS = new Set([\"report\", \"plan\", \"spec\", \"reference-doc\"]);\nconst INTERFACE_COMMAND = \"/design:interface\";\nconst INTERFACE_AUDIT_ROUTE = \"/design:audit\";\nconst INTERFACE_TASK_CLASSES = new Set([\"sibling-command\", \"argument\", \"internal\", \"hidden\"]);\nconst TASK_PROJECTION_STRICTNESS = new Set([\"advisory\"]);\nconst TASK_PROJECTION_FIELDS = [\"verb\", \"ownerMode\", \"strictness\", \"referenceSources\", \"requires\", \"fixtures\"];\nconst TASK_PROJECTIONS_NEGATIVE_CORPUS_MARKER = \"Negative corpus:\";\nconst ARGUMENT_GRAMMAR_POSITIONAL_FIELDS = [\"name\", \"required\", \"kind\"];\nconst ARGUMENT_GRAMMAR_FLAG_FIELDS = [\"name\", \"required\", \"takesValue\", \"kind\"];\nconst CHOREOGRAPHY_FIELDS = [\"order\", \"skill\", \"resource\", \"action\"];\nconst DESIGN_COMMAND_PATTERN = /\\/design:[a-z-]+/;\nconst DESCRIPTION_ROLES = new Set([\"hub-keyword-projection\"]);\nconst GENERIC_ARTIFACT_NAMES = new Set([\n  \"output\",\n  \"result\",\n  \"artifact\",\n  \"deliverable\",\n  \"data\",\n  \"response\",\n  \"file\",\n  \"document\",\n  \"thing\",\n  \"stuff\"\n]);\n\nconst scriptUrl = new URL(import.meta.url);\nconst skillRootUrl = new URL(\"../../\", scriptUrl);\nconst opencodeRootUrl = new URL(\"../../\", skillRootUrl);\nconst metadataUrl = new URL(\"command-metadata.json\", skillRootUrl);\nconst registryUrl = new URL(\"mode-registry.json\", skillRootUrl);\nconst hubRouterUrl = new URL(\"hub-router.json\", skillRootUrl);\nconst interfaceSkillUrl = new URL(\"design-interface/SKILL.md\", skillRootUrl);\nconst commandsRootUrl = new URL(\"commands/design/\", opencodeRootUrl);\nconst SIBLING_DISCRIMINATOR_START = \"<!-- ANCHOR:sibling-discriminator -->\";\nconst SIBLING_DISCRIMINATOR_END = \"<!-- /ANCHOR:sibling-discriminator -->\";\nconst REGISTER_SECTION_START = \"<!-- ANCHOR:register -->\";\nconst REGISTER_SECTION_END = \"<!-- /ANCHOR:register -->\";\n\nconst args = new Set(process.argv.slice(2));\nconst jsonMode = args.has(\"--json\");\nconst unknownArgs = [...args].filter((arg) => arg !== \"--json\");\n\nif (unknownArgs.length > 0) {\n  emitAndExit(\n    {\n      status: \"invalid\",\n      stage: \"usage\",\n      errors: unknownArgs.map((arg) => `unknown argument: ${arg}`),\n      drift: []\n    },\n    2\n  );\n}\n\nmain().catch((error) => {\n  emitAndExit(\n    {\n      status: \"invalid\",\n      stage: \"runtime\",\n      errors: [error instanceof Error ? error.message : String(error)],\n      drift: []\n    },\n    2\n  );\n});\n\nasync function main() {\n  const [metadata, registry, hubRouter, interfaceSkillSource, wrapperRoster] = await Promise.all([\n    readJson(metadataUrl),\n    readJson(registryUrl),\n    readJson(hubRouterUrl),\n    readFile(interfaceSkillUrl, \"utf8\"),\n    readWrapperRoster()\n  ]);\n  const workflowModes = readWorkflowModes(registry);\n  const registryAliasesByMode = readRegistryAliasesByMode(registry);\n  const interfaceIntentLanes = parseInterfaceIntentSignalKeys(interfaceSkillSource);\n  const metadataErrors = [\n    ...validateInterfaceIntentSignalKeys(interfaceIntentLanes),\n    ...validateMetadata(metadata, workflowModes, interfaceIntentLanes, registryAliasesByMode)\n  ];\n\n  if (metadataErrors.length > 0) {\n    emitAndExit(\n      {\n        status: \"invalid\",\n        stage: \"metadata\",\n        errors: metadataErrors,\n        drift: []\n      },\n      2\n    );\n  }\n\n  const records = [...metadata].sort((a, b) => a.command.localeCompare(b.command));\n  const drift = [\n    ...(await collectSurfaceDrift(records)),\n    ...collectRosterReconciliationDrift(records, workflowModes, hubRouter, wrapperRoster)\n  ].sort(compareDrift);\n\n  emitAndExit(\n    {\n      status: drift.length > 0 ? \"drift\" : \"pass\",\n      stage: drift.length > 0 ? \"surface\" : \"complete\",\n      metadata: {\n        commandCount: records.length,\n        workflowModes: [...workflowModes].sort(),\n        aliasCount: records.reduce((count, record) => count + record.aliases.length, 0)\n      },\n      drift\n    },\n    drift.length > 0 ? 1 : 0\n  );\n}\n\nasync function readJson(url) {\n  const raw = await readFile(url, \"utf8\");\n  return JSON.parse(raw);\n}\n\nasync function readWrapperRoster() {\n  const entries = await readdir(commandsRootUrl, { withFileTypes: true });\n  const wrappers = await Promise.all(\n    entries\n      .filter((entry) => entry.isFile() && entry.name.endsWith(\".md\"))\n      .map(async (entry) => {\n        const command = `/design:${entry.name.slice(0, -3)}`;\n        const relativePath = `.opencode/commands/design/${entry.name}`;\n        const markdown = await readFile(new URL(entry.name, commandsRootUrl), \"utf8\");\n        let frontmatter = null;\n        let frontmatterError = null;\n\n        try {\n          frontmatter = parseFrontmatter(markdown);\n        } catch (error) {\n          frontmatterError = error instanceof Error ? error.message : String(error);\n        }\n\n        return {\n          command,\n          relativePath,\n          markdown,\n          frontmatter,\n          frontmatterError\n        };\n      })\n  );\n\n  return wrappers.sort((a, b) => a.command.localeCompare(b.command));\n}\n\nfunction readWorkflowModes(registry) {\n  if (!registry || !Array.isArray(registry.modes)) {\n    return new Set();\n  }\n\n  return new Set(\n    registry.modes\n      .map((mode) => mode && mode.workflowMode)\n      .filter((workflowMode) => typeof workflowMode === \"string\" && workflowMode.length > 0)\n  );\n}\n\nfunction readRegistryAliasesByMode(registry) {\n  const aliasesByMode = new Map();\n\n  if (!registry || !Array.isArray(registry.modes)) {\n    return aliasesByMode;\n  }\n\n  for (const mode of registry.modes) {\n    if (typeof mode?.workflowMode !== \"string\" || mode.workflowMode.length === 0) {\n      continue;\n    }\n\n    aliasesByMode.set(\n      mode.workflowMode,\n      Array.isArray(mode.aliases) ? mode.aliases.filter((alias) => typeof alias === \"string\") : []\n    );\n  }\n\n  return aliasesByMode;\n}\n\nfunction readHubRouterModes(hubRouter) {\n  if (!isPlainObject(hubRouter?.routerSignals)) {\n    return new Set();\n  }\n\n  return new Set(\n    Object.keys(hubRouter.routerSignals)\n      .filter((workflowMode) => workflowMode.length > 0)\n  );\n}\n\nfunction validateMetadata(metadata, workflowModes, interfaceIntentLanes, registryAliasesByMode) {\n  const errors = [];\n\n  if (!Array.isArray(metadata)) {\n    return [\"metadata root must be an array\"];\n  }\n\n  const seenCommands = new Map();\n  const expectedCommands = new Set(COMMANDS);\n  const seenAliases = new Map();\n  const seenTaskProjectionVerbs = new Map();\n  const workflowCommandSet = commandSetForModes(workflowModes);\n\n  for (const record of metadata) {\n    const command = typeof record?.command === \"string\" ? record.command : \"<missing command>\";\n\n    for (const field of REQUIRED_FIELDS) {\n      if (!Object.hasOwn(record ?? {}, field)) {\n        errors.push(`${command}: missing required field ${field}`);\n      }\n    }\n\n    if (!expectedCommands.has(command)) {\n      errors.push(`${command}: command is not in the expected /design:* command set`);\n    }\n\n    if (seenCommands.has(command)) {\n      errors.push(`${command}: command is duplicated`);\n    } else {\n      seenCommands.set(command, record);\n    }\n\n    if (typeof record?.ownerMode !== \"string\" || !workflowModes.has(record.ownerMode)) {\n      errors.push(`${command}: ownerMode must match a workflowMode`);\n    }\n\n    for (const field of [\"description\", \"argumentHint\", \"accepts\", \"returns\", \"deferToHubWhen\"]) {\n      if (typeof record?.[field] !== \"string\" || record[field].length === 0) {\n        errors.push(`${command}: ${field} must be a non-empty string`);\n      }\n    }\n\n    for (const field of [\"aliases\", \"next\", \"proofFields\"]) {\n      if (!isNonEmptyStringArray(record?.[field])) {\n        errors.push(`${command}: ${field} must be a non-empty string array`);\n      }\n    }\n\n    errors.push(...validateDescriptionRoleProjection(record, command));\n    errors.push(...validateArgumentGrammar(record, command));\n    errors.push(...validateChoreography(record, command));\n    errors.push(...validateUserIntent(record, command));\n\n    if (typeof record?.toolPolicy?.mutatesWorkspace !== \"boolean\") {\n      errors.push(`${command}: toolPolicy.mutatesWorkspace must be a boolean`);\n    }\n\n    errors.push(...validatePreconditions(record, command));\n    errors.push(...validateRegisterPolicy(record, command));\n    errors.push(...validateExamples(record, command));\n    errors.push(...validateOutputContract(record, command));\n    errors.push(...validateDiscriminator(record, command, workflowModes));\n    errors.push(...validatePipeline(record, command, expectedCommands));\n    errors.push(...validateHandoff(record, command, expectedCommands));\n    errors.push(\n      ...validateTaskProjections(\n        record,\n        command,\n        workflowModes,\n        expectedCommands,\n        workflowCommandSet,\n        seenTaskProjectionVerbs,\n        registryAliasesByMode\n      )\n    );\n\n    if (command === INTERFACE_COMMAND) {\n      errors.push(...validateInterfaceTasks(record, command, interfaceIntentLanes, expectedCommands));\n    }\n\n    if (Array.isArray(record?.aliases)) {\n      for (const alias of record.aliases) {\n        const owner = seenAliases.get(alias);\n        if (owner && owner !== command) {\n          errors.push(`${command}: alias \"${alias}\" is already owned by ${owner}`);\n        } else {\n          seenAliases.set(alias, command);\n        }\n      }\n    }\n  }\n\n  for (const command of COMMANDS) {\n    if (!seenCommands.has(command)) {\n      errors.push(`${command}: missing metadata record`);\n    }\n  }\n\n  errors.push(...validatePipelineGraph(seenCommands));\n\n  return errors.sort();\n}\n\nfunction validateDescriptionRoleProjection(record, command) {\n  const errors = [];\n\n  if (typeof record?.descriptionRole !== \"string\" || record.descriptionRole.trim().length === 0) {\n    errors.push(`${command}: descriptionRole must be a non-empty string`);\n  } else if (!DESCRIPTION_ROLES.has(record.descriptionRole)) {\n    errors.push(`${command}: descriptionRole must be one of ${[...DESCRIPTION_ROLES].join(\",\")}`);\n  }\n\n  if (record?.autoTriggerEligible !== false) {\n    errors.push(`${command}: autoTriggerEligible must be the boolean false`);\n  }\n\n  if (!isNonEmptyStringArray(record?.hubKeywordProjection)) {\n    errors.push(`${command}: hubKeywordProjection must be a non-empty string array`);\n  } else {\n    const description = typeof record?.description === \"string\" ? record.description : \"\";\n\n    for (const token of record.hubKeywordProjection) {\n      if (!containsPhrase(description, token)) {\n        errors.push(`${command}: hubKeywordProjection token \"${token}\" must be a substring of description`);\n      }\n    }\n  }\n\n  const ownerMode = typeof record?.ownerMode === \"string\" ? record.ownerMode : \"<missing>\";\n  const expectedSuffix = `sk-design ${ownerMode} mode.`;\n\n  if (typeof record?.description !== \"string\" || !record.description.endsWith(expectedSuffix)) {\n    errors.push(`${command}: description must end with ${expectedSuffix}`);\n  }\n\n  return errors;\n}\n\nfunction validateArgumentGrammar(record, command) {\n  const errors = [];\n  const grammar = record?.argumentGrammar;\n\n  if (!isPlainObject(grammar)) {\n    return [`${command}: argumentGrammar must be an object`];\n  }\n\n  if (typeof grammar.render !== \"string\" || grammar.render.trim().length === 0) {\n    errors.push(`${command}: argumentGrammar.render must be a non-empty string`);\n  } else if (grammar.render !== record?.argumentHint) {\n    errors.push(`${command}: argumentGrammar.render must match argumentHint`);\n  }\n\n  if (!Array.isArray(grammar.positional) || grammar.positional.length === 0) {\n    errors.push(`${command}: argumentGrammar.positional must be a non-empty array`);\n  } else {\n    grammar.positional.forEach((token, index) => {\n      const label = `${command}: argumentGrammar.positional[${index}]`;\n\n      if (!isPlainObject(token)) {\n        errors.push(`${label} must be an object`);\n        return;\n      }\n\n      for (const field of ARGUMENT_GRAMMAR_POSITIONAL_FIELDS) {\n        if (!Object.hasOwn(token, field)) {\n          errors.push(`${label}.${field} is required`);\n        }\n      }\n\n      if (typeof token.name !== \"string\" || !/^[a-z][a-z0-9-]*$/.test(token.name)) {\n        errors.push(`${label}.name must use lowercase letters, numbers, and hyphens`);\n      }\n\n      if (token.required !== true && token.required !== false) {\n        errors.push(`${label}.required must be a boolean`);\n      }\n\n      if (typeof token.kind !== \"string\" || token.kind.trim().length === 0) {\n        errors.push(`${label}.kind must be a non-empty string`);\n      }\n    });\n  }\n\n  if (!Array.isArray(grammar.flags)) {\n    errors.push(`${command}: argumentGrammar.flags must be an array`);\n  } else {\n    grammar.flags.forEach((flag, index) => {\n      const label = `${command}: argumentGrammar.flags[${index}]`;\n\n      if (!isPlainObject(flag)) {\n        errors.push(`${label} must be an object`);\n        return;\n      }\n\n      for (const field of ARGUMENT_GRAMMAR_FLAG_FIELDS) {\n        if (!Object.hasOwn(flag, field)) {\n          errors.push(`${label}.${field} is required`);\n        }\n      }\n\n      if (typeof flag.name !== \"string\" || !/^--[a-z][a-z0-9-]*$/.test(flag.name)) {\n        errors.push(`${label}.name must be a long flag such as --scope`);\n      }\n\n      if (flag.required !== true && flag.required !== false) {\n        errors.push(`${label}.required must be a boolean`);\n      }\n\n      if (flag.takesValue !== true && flag.takesValue !== false) {\n        errors.push(`${label}.takesValue must be a boolean`);\n      }\n\n      if (typeof flag.kind !== \"string\" || flag.kind.trim().length === 0) {\n        errors.push(`${label}.kind must be a non-empty string`);\n      }\n\n      if (flag.takesValue === true && (typeof flag.valueName !== \"string\" || flag.valueName.trim().length === 0)) {\n        errors.push(`${label}.valueName must be a non-empty string when takesValue is true`);\n      }\n    });\n  }\n\n  return errors;\n}\n\nfunction validateChoreography(record, command) {\n  const errors = [];\n  const choreography = record?.choreography;\n\n  if (!Array.isArray(choreography) || choreography.length === 0) {\n    return [`${command}: choreography must be a non-empty array`];\n  }\n\n  const orders = [];\n  const seenOrders = new Set();\n\n  choreography.forEach((step, index) => {\n    const label = `${command}: choreography[${index}]`;\n\n    if (!isPlainObject(step)) {\n      errors.push(`${label} must be an object`);\n      return;\n    }\n\n    for (const field of CHOREOGRAPHY_FIELDS) {\n      if (!Object.hasOwn(step, field)) {\n        errors.push(`${label}.${field} is required`);\n      }\n    }\n\n    if (!Number.isInteger(step.order) || step.order < 1) {\n      errors.push(`${label}.order must be a positive integer`);\n    } else {\n      orders.push(step.order);\n\n      if (seenOrders.has(step.order)) {\n        errors.push(`${label}.order ${step.order} is duplicated`);\n      }\n\n      seenOrders.add(step.order);\n    }\n\n    for (const field of [\"skill\", \"resource\", \"action\"]) {\n      if (typeof step[field] !== \"string\" || step[field].trim().length === 0) {\n        errors.push(`${label}.${field} must be a non-empty string`);\n      }\n    }\n  });\n\n  const sortedOrders = [...orders].sort((left, right) => left - right);\n  sortedOrders.forEach((order, index) => {\n    const expectedOrder = index + 1;\n    if (order !== expectedOrder) {\n      errors.push(`${command}: choreography orders must be contiguous from 1`);\n    }\n  });\n\n  return errors;\n}\n\nfunction parseInterfaceIntentSignalKeys(source) {\n  const blockMatch = source.match(/^INTENT_SIGNALS\\s*=\\s*\\{([\\s\\S]*?)^}\\s*$/m);\n  if (!blockMatch) {\n    return [];\n  }\n\n  return [...blockMatch[1].matchAll(/^\\s+\"([A-Z_]+)\"\\s*:/gm)].map((match) => match[1]);\n}\n\nfunction validateInterfaceIntentSignalKeys(keys) {\n  if (keys.length === 0) {\n    return [`${INTERFACE_COMMAND}: interface router INTENT_SIGNALS block must expose at least one lane`];\n  }\n\n  const duplicates = duplicateValues(keys);\n  if (duplicates.length > 0) {\n    return [`${INTERFACE_COMMAND}: interface router INTENT_SIGNALS contains duplicate lanes [${duplicates.join(\",\")}]`];\n  }\n\n  return [];\n}\n\nfunction validateInterfaceTasks(record, command, interfaceIntentLanes, commandSet) {\n  const errors = [];\n  const tasks = record?.tasks;\n\n  if (!Array.isArray(tasks) || tasks.length === 0) {\n    return [`${command}: tasks must be a non-empty array`];\n  }\n\n  const expectedLanes = interfaceIntentLanes;\n  const expectedLaneSet = new Set(expectedLanes);\n  const actualLanes = [];\n\n  tasks.forEach((task, index) => {\n    const label = `${command}: tasks[${index}]`;\n\n    if (!isPlainObject(task)) {\n      errors.push(`${label} must be an object`);\n      return;\n    }\n\n    for (const field of [\"lane\", \"label\", \"class\", \"surface\"]) {\n      if (typeof task[field] !== \"string\" || task[field].trim().length === 0) {\n        errors.push(`${label}.${field} must be a non-empty string`);\n      }\n    }\n\n    if (typeof task.lane === \"string\" && task.lane.trim().length > 0) {\n      actualLanes.push(task.lane);\n\n      if (commandSet.has(task.lane)) {\n        errors.push(`${label}.lane must not be promoted into the /design:* command set`);\n      }\n    }\n\n    if (typeof task.class === \"string\" && !INTERFACE_TASK_CLASSES.has(task.class)) {\n      errors.push(`${label}.class must be one of ${[...INTERFACE_TASK_CLASSES].join(\",\")}`);\n    }\n\n    if (\n      typeof task.class === \"string\"\n      && task.class !== \"argument\"\n      && typeof task.surface === \"string\"\n      && DESIGN_COMMAND_PATTERN.test(task.surface)\n    ) {\n      errors.push(`${label}.surface must not name a /design:* command unless class is argument`);\n    }\n  });\n\n  const duplicateLanes = duplicateValues(actualLanes);\n  for (const lane of duplicateLanes) {\n    errors.push(`${command}: tasks lane ${lane} is duplicated`);\n  }\n\n  const actualLaneSet = new Set(actualLanes);\n  const missingLanes = expectedLanes.filter((lane) => !actualLaneSet.has(lane));\n  const extraLanes = [...actualLaneSet].filter((lane) => !expectedLaneSet.has(lane)).sort();\n\n  if (missingLanes.length > 0 || extraLanes.length > 0) {\n    errors.push(\n      `${command}: tasks lane set must match interface INTENT_SIGNALS missing=[${missingLanes.join(\",\")}] extra=[${extraLanes.join(\",\")}]`\n    );\n  }\n\n  return errors;\n}\n\nfunction validateTaskProjections(\n  record,\n  command,\n  workflowModes,\n  expectedCommands,\n  workflowCommandSet,\n  seenVerbs,\n  registryAliasesByMode\n) {\n  const errors = [];\n  const projections = record?.taskProjections;\n\n  if (!Array.isArray(projections)) {\n    return [`${command}: taskProjections must be an array`];\n  }\n\n  projections.forEach((projection, index) => {\n    const label = `${command}: taskProjections[${index}]`;\n\n    if (!isPlainObject(projection)) {\n      errors.push(`${label} must be an object`);\n      return;\n    }\n\n    for (const field of TASK_PROJECTION_FIELDS) {\n      if (!Object.hasOwn(projection, field)) {\n        errors.push(`${label}.${field} is required`);\n      }\n    }\n\n    const verb = typeof projection.verb === \"string\" ? projection.verb.trim() : \"\";\n    if (verb.length === 0) {\n      errors.push(`${label}.verb must be a non-empty string`);\n    } else {\n      if (projection.verb !== verb || !/^[a-z][a-z-]*$/.test(verb)) {\n        errors.push(`${label}.verb must use lowercase letters and hyphens`);\n      }\n\n      const priorOwner = seenVerbs.get(verb);\n      if (priorOwner) {\n        errors.push(`${label}.verb ${verb} is already owned by ${priorOwner}`);\n      } else {\n        seenVerbs.set(verb, command);\n      }\n\n      const projectedCommand = `/design:${verb}`;\n      if (expectedCommands.has(projectedCommand) || workflowCommandSet.has(projectedCommand)) {\n        errors.push(`${label}.verb ${verb} must not be minted as ${projectedCommand}`);\n      }\n\n      errors.push(...validateTaskProjectionAliasCollisions(label, record?.ownerMode, verb, registryAliasesByMode));\n    }\n\n    if (typeof projection.ownerMode !== \"string\" || projection.ownerMode.trim().length === 0) {\n      errors.push(`${label}.ownerMode must be a non-empty string`);\n    } else {\n      if (projection.ownerMode !== record?.ownerMode) {\n        errors.push(`${label}.ownerMode must match record ownerMode ${record?.ownerMode ?? \"<missing>\"}`);\n      }\n\n      if (!workflowModes.has(projection.ownerMode)) {\n        errors.push(`${label}.ownerMode must match a workflowMode`);\n      }\n    }\n\n    if (typeof projection.strictness !== \"string\" || !TASK_PROJECTION_STRICTNESS.has(projection.strictness)) {\n      errors.push(`${label}.strictness must be one of ${[...TASK_PROJECTION_STRICTNESS].join(\",\")}`);\n    }\n\n    for (const field of [\"referenceSources\", \"fixtures\"]) {\n      if (!isNonEmptyStringArray(projection[field])) {\n        errors.push(`${label}.${field} must be a non-empty string array`);\n      } else {\n        errors.push(...validateUniqueArray(label, field, projection[field]));\n      }\n    }\n\n    if (typeof projection.requires !== \"string\" || projection.requires.trim().length === 0) {\n      errors.push(`${label}.requires must be a non-empty string`);\n    }\n  });\n\n  return errors;\n}\n\nfunction validateTaskProjectionAliasCollisions(label, ownerMode, verb, registryAliasesByMode) {\n  const errors = [];\n\n  if (typeof ownerMode !== \"string\" || ownerMode.length === 0) {\n    return errors;\n  }\n\n  for (const [workflowMode, aliases] of registryAliasesByMode) {\n    if (workflowMode === ownerMode) {\n      continue;\n    }\n\n    for (const alias of aliases) {\n      if (containsWholeWord(alias, verb)) {\n        errors.push(`${label}.verb ${verb} collides with ${workflowMode} alias \"${alias}\"`);\n      }\n    }\n  }\n\n  return errors;\n}\n\nfunction validatePreconditions(record, command) {\n  const errors = [];\n  const preconditions = record?.preconditions;\n\n  if (!isPlainObject(preconditions)) {\n    return [`${command}: preconditions must be an object`];\n  }\n\n  for (const field of PRECONDITION_FIELDS) {\n    if (typeof preconditions[field] !== \"string\" || preconditions[field].trim().length === 0) {\n      errors.push(`${command}: preconditions.${field} must be a non-empty string`);\n    }\n  }\n\n  return errors;\n}\n\nfunction validateRegisterPolicy(record, command) {\n  const errors = [];\n  const policy = record?.registerPolicy;\n\n  if (!isPlainObject(policy)) {\n    return [`${command}: registerPolicy must be an object`];\n  }\n\n  for (const field of REGISTER_POLICY_FIELDS) {\n    if (!Object.hasOwn(policy, field)) {\n      errors.push(`${command}: registerPolicy.${field} is required`);\n    }\n  }\n\n  if (!isNonEmptyStringArray(policy.accepted)) {\n    errors.push(`${command}: registerPolicy.accepted must be a non-empty string array`);\n  } else {\n    const accepted = new Set(policy.accepted);\n    for (const posture of [\"brand\", \"product\"]) {\n      if (!accepted.has(posture)) {\n        errors.push(`${command}: registerPolicy.accepted must include ${posture}`);\n      }\n    }\n  }\n\n  if (typeof policy.default !== \"string\" || policy.default.trim().length === 0) {\n    errors.push(`${command}: registerPolicy.default must be a non-empty string`);\n  } else if (policy.default !== \"auto\") {\n    errors.push(`${command}: registerPolicy.default must be auto`);\n  }\n\n  if (!isNonEmptyStringArray(policy.resolutionOrder)) {\n    errors.push(`${command}: registerPolicy.resolutionOrder must be a non-empty string array`);\n  }\n\n  if (typeof policy.askWhen !== \"string\" || policy.askWhen.trim().length === 0) {\n    errors.push(`${command}: registerPolicy.askWhen must be a non-empty string`);\n  }\n\n  if (!isNonEmptyStringArray(policy.proofFields)) {\n    errors.push(`${command}: registerPolicy.proofFields must be a non-empty string array`);\n  } else if (!policy.proofFields.includes(\"register\")) {\n    errors.push(`${command}: registerPolicy.proofFields must include register`);\n  }\n\n  return errors;\n}\n\nfunction validateDiscriminator(record, command, workflowModes) {\n  const errors = [];\n  const discriminator = record?.discriminator;\n  const commandSet = commandSetForModes(workflowModes);\n  const expectedSiblings = new Set([...commandSet].filter((sibling) => sibling !== command));\n\n  if (!isPlainObject(discriminator)) {\n    return [`${command}: discriminator must be an object`];\n  }\n\n  if (typeof discriminator.whenToUse !== \"string\" || discriminator.whenToUse.trim().length === 0) {\n    errors.push(`${command}: discriminator.whenToUse must be a non-empty string`);\n  }\n\n  if (typeof discriminator.pairWithHubWhen !== \"string\" || discriminator.pairWithHubWhen.trim().length === 0) {\n    errors.push(`${command}: discriminator.pairWithHubWhen must be a non-empty string`);\n  } else if (discriminator.pairWithHubWhen !== record?.deferToHubWhen) {\n    errors.push(`${command}: discriminator.pairWithHubWhen must match deferToHubWhen`);\n  }\n\n  if (!Array.isArray(discriminator.preferSiblingWhen) || discriminator.preferSiblingWhen.length === 0) {\n    errors.push(`${command}: discriminator.preferSiblingWhen must be a non-empty array`);\n  } else {\n    const seenSiblings = new Set();\n\n    discriminator.preferSiblingWhen.forEach((entry, index) => {\n      const label = `${command}: discriminator.preferSiblingWhen[${index}]`;\n\n      if (!isPlainObject(entry)) {\n        errors.push(`${label} must be an object`);\n        return;\n      }\n\n      if (typeof entry.sibling !== \"string\" || entry.sibling.trim().length === 0) {\n        errors.push(`${label}.sibling must be a non-empty string`);\n      } else {\n        if (!commandSet.has(entry.sibling)) {\n          errors.push(`${label}.sibling must be one of ${[...commandSet].sort().join(\",\")}`);\n        }\n\n        if (entry.sibling === command) {\n          errors.push(`${label}.sibling must not reference its own command`);\n        }\n\n        if (seenSiblings.has(entry.sibling)) {\n          errors.push(`${label}.sibling is duplicated`);\n        }\n\n        seenSiblings.add(entry.sibling);\n      }\n\n      if (typeof entry.when !== \"string\" || entry.when.trim().length === 0) {\n        errors.push(`${label}.when must be a non-empty string`);\n      }\n    });\n\n    if (!sameSet(seenSiblings, expectedSiblings)) {\n      errors.push(`${command}: discriminator.preferSiblingWhen must cover exactly ${[...expectedSiblings].sort().join(\",\")}`);\n    }\n  }\n\n  errors.push(...validateDiscriminatorSequence(record, command, discriminator.sequence, commandSet));\n\n  return errors;\n}\n\nfunction validateDiscriminatorSequence(record, command, sequence, commandSet) {\n  const errors = [];\n\n  if (!isPlainObject(sequence)) {\n    return [`${command}: discriminator.sequence must be an object`];\n  }\n\n  for (const field of [\"typicallyAfter\", \"typicallyBefore\"]) {\n    if (!isStringArray(sequence[field])) {\n      errors.push(`${command}: discriminator.sequence.${field} must be a string array`);\n      continue;\n    }\n\n    for (const item of sequence[field]) {\n      if (!commandSet.has(item)) {\n        errors.push(`${command}: discriminator.sequence.${field} contains unknown command ${item}`);\n      }\n\n      if (item === command) {\n        errors.push(`${command}: discriminator.sequence.${field} must not reference its own command`);\n      }\n    }\n  }\n\n  if (isStringArray(sequence.typicallyBefore) && Array.isArray(record?.next)) {\n    const nextSet = new Set(record.next);\n    for (const item of sequence.typicallyBefore) {\n      if (!nextSet.has(item)) {\n        errors.push(`${command}: discriminator.sequence.typicallyBefore must be a subset of next`);\n      }\n    }\n  }\n\n  return errors;\n}\n\nfunction validateExamples(record, command) {\n  const errors = [];\n\n  if (!Array.isArray(record?.examples) || record.examples.length === 0) {\n    return [`${command}: examples must be a non-empty array`];\n  }\n\n  record.examples.forEach((example, index) => {\n    const label = `${command}: examples[${index}]`;\n\n    if (!isPlainObject(example)) {\n      errors.push(`${label} must be an object`);\n      return;\n    }\n\n    if (typeof example.invocation !== \"string\" || example.invocation.trim().length === 0) {\n      errors.push(`${label}.invocation must be a non-empty string`);\n    } else if (firstToken(example.invocation) !== command) {\n      errors.push(`${label}.invocation must start with ${command}`);\n    }\n\n    if (typeof example.returnsArtifact !== \"string\" || example.returnsArtifact.trim().length === 0) {\n      errors.push(`${label}.returnsArtifact must be a non-empty string`);\n    }\n  });\n\n  return errors;\n}\n\nfunction validateOutputContract(record, command) {\n  const errors = [];\n  const contract = record?.outputContract;\n\n  if (!isPlainObject(contract)) {\n    return [`${command}: outputContract must be an object`];\n  }\n\n  if (typeof contract.primaryArtifactName !== \"string\" || contract.primaryArtifactName.trim().length === 0) {\n    errors.push(`${command}: outputContract.primaryArtifactName must be a non-empty string`);\n  } else if (isGenericArtifactName(contract.primaryArtifactName)) {\n    errors.push(`${command}: outputContract.primaryArtifactName must name a concrete artifact`);\n  }\n\n  if (typeof contract.artifactKind !== \"string\" || !ARTIFACT_KINDS.has(contract.artifactKind)) {\n    errors.push(`${command}: outputContract.artifactKind must be one of ${[...ARTIFACT_KINDS].join(\",\")}`);\n  }\n\n  if (!isNonEmptyStringArray(contract.requiredFields)) {\n    errors.push(`${command}: outputContract.requiredFields must be a non-empty string array`);\n  }\n\n  if (!isStringArray(contract.fileOutputs)) {\n    errors.push(`${command}: outputContract.fileOutputs must be a string array`);\n  }\n\n  if (Array.isArray(record?.proofFields) && Array.isArray(contract.requiredFields) && !sameValue(record.proofFields, contract.requiredFields)) {\n    errors.push(`${command}: outputContract.requiredFields must match proofFields`);\n  }\n\n  if (typeof record?.toolPolicy?.mutatesWorkspace === \"boolean\" && Array.isArray(contract.fileOutputs)) {\n    const hasFileOutputs = contract.fileOutputs.length > 0;\n\n    if (record.toolPolicy.mutatesWorkspace && !hasFileOutputs) {\n      errors.push(`${command}: outputContract.fileOutputs must be non-empty when toolPolicy.mutatesWorkspace is true`);\n    }\n\n    if (!record.toolPolicy.mutatesWorkspace && hasFileOutputs) {\n      errors.push(`${command}: outputContract.fileOutputs must be empty when toolPolicy.mutatesWorkspace is false`);\n    }\n  }\n\n  return errors;\n}\n\nfunction validatePipeline(record, command, commandSet) {\n  const errors = [];\n  const pipeline = record?.pipeline;\n\n  if (!isPlainObject(pipeline)) {\n    return [`${command}: pipeline must be an object`];\n  }\n\n  for (const field of PIPELINE_FIELDS) {\n    if (!Object.hasOwn(pipeline, field)) {\n      errors.push(`${command}: pipeline.${field} is required`);\n    }\n  }\n\n  if (typeof pipeline.stage !== \"string\" || pipeline.stage.trim().length === 0) {\n    errors.push(`${command}: pipeline.stage must be a non-empty string`);\n  }\n\n  if (typeof pipeline.produces !== \"string\" || pipeline.produces.trim().length === 0) {\n    errors.push(`${command}: pipeline.produces must be a non-empty string`);\n  } else if (pipeline.produces !== record?.outputContract?.primaryArtifactName) {\n    errors.push(`${command}: pipeline.produces must match outputContract.primaryArtifactName`);\n  }\n\n  errors.push(...validatePipelineCommandList(record, command, \"acceptsFrom\", commandSet, true));\n  errors.push(...validatePipelineCommandList(record, command, \"nextCommands\", commandSet, false));\n\n  if (!isNonEmptyStringArray(pipeline.proofRequired)) {\n    errors.push(`${command}: pipeline.proofRequired must be a non-empty string array`);\n  } else {\n    errors.push(...validateUniqueArray(command, \"pipeline.proofRequired\", pipeline.proofRequired));\n\n    if (Array.isArray(record?.proofFields) && !sameValue(pipeline.proofRequired, record.proofFields)) {\n      errors.push(`${command}: pipeline.proofRequired must match proofFields`);\n    }\n  }\n\n  if (Array.isArray(pipeline.nextCommands) && Array.isArray(record?.next)) {\n    const nextSet = new Set(record.next);\n    for (const nextCommand of pipeline.nextCommands) {\n      if (!nextSet.has(nextCommand)) {\n        errors.push(`${command}: pipeline.nextCommands must be a subset of next`);\n      }\n    }\n  }\n\n  return errors;\n}\n\nfunction validatePipelineCommandList(record, command, field, commandSet, allowEmpty) {\n  const errors = [];\n  const value = record?.pipeline?.[field];\n  const validArray = allowEmpty ? isStringArray(value) : isNonEmptyStringArray(value);\n\n  if (!validArray) {\n    errors.push(`${command}: pipeline.${field} must be a ${allowEmpty ? \"\" : \"non-empty \"}string array`);\n    return errors;\n  }\n\n  errors.push(...validateUniqueArray(command, `pipeline.${field}`, value));\n\n  for (const item of value) {\n    if (!commandSet.has(item)) {\n      errors.push(`${command}: pipeline.${field} contains unknown command ${item}`);\n    }\n\n    if (item === command) {\n      errors.push(`${command}: pipeline.${field} must not reference its own command`);\n    }\n  }\n\n  return errors;\n}\n\nfunction validatePipelineGraph(recordsByCommand) {\n  const errors = [];\n  const records = [...recordsByCommand.values()].filter((record) => isPlainObject(record?.pipeline));\n  const stageOwners = new Map();\n\n  for (const record of records) {\n    const stage = record.pipeline.stage;\n    if (typeof stage !== \"string\" || stage.trim().length === 0) {\n      continue;\n    }\n\n    const owner = stageOwners.get(stage);\n    if (owner) {\n      errors.push(`${record.command}: pipeline.stage \"${stage}\" is already owned by ${owner}`);\n    } else {\n      stageOwners.set(stage, record.command);\n    }\n  }\n\n  for (const record of records) {\n    if (!isStringArray(record.pipeline.acceptsFrom)) {\n      continue;\n    }\n\n    const expected = new Set();\n    for (const upstream of records) {\n      if (\n        upstream.command !== record.command\n        && Array.isArray(upstream.pipeline?.nextCommands)\n        && upstream.pipeline.nextCommands.includes(record.command)\n      ) {\n        expected.add(upstream.command);\n      }\n    }\n\n    const actual = new Set(record.pipeline.acceptsFrom);\n    if (!sameSet(actual, expected)) {\n      errors.push(\n        `${record.command}: pipeline.acceptsFrom must match inverse nextCommands expected [${[...expected].sort().join(\",\")}]`\n      );\n    }\n  }\n\n  return errors;\n}\n\nfunction validateHandoff(record, command, commandSet) {\n  const errors = [];\n  const handoff = record?.handoff;\n\n  if (!isPlainObject(handoff)) {\n    return [`${command}: handoff must be an object`];\n  }\n\n  for (const field of [\"nextOptions\", \"handoffRequired\", \"handoffReason\"]) {\n    if (!Object.hasOwn(handoff, field)) {\n      errors.push(`${command}: handoff.${field} is required`);\n    }\n  }\n\n  const optionCommands = [];\n\n  if (!Array.isArray(handoff.nextOptions) || handoff.nextOptions.length === 0) {\n    errors.push(`${command}: handoff.nextOptions must be a non-empty array`);\n  } else {\n    const seenOptions = new Set();\n\n    handoff.nextOptions.forEach((option, index) => {\n      const label = `${command}: handoff.nextOptions[${index}]`;\n\n      if (!isPlainObject(option)) {\n        errors.push(`${label} must be an object`);\n        return;\n      }\n\n      for (const field of HANDOFF_OPTION_FIELDS) {\n        if (!Object.hasOwn(option, field)) {\n          errors.push(`${label}.${field} is required`);\n        }\n      }\n\n      if (typeof option.command !== \"string\" || option.command.trim().length === 0) {\n        errors.push(`${label}.command must be a non-empty string`);\n      } else {\n        optionCommands.push(option.command);\n\n        if (!commandSet.has(option.command)) {\n          errors.push(`${label}.command contains unknown command ${option.command}`);\n        }\n\n        if (option.command === command) {\n          errors.push(`${label}.command must not reference its own command`);\n        }\n\n        if (seenOptions.has(option.command)) {\n          errors.push(`${label}.command is duplicated`);\n        }\n\n        seenOptions.add(option.command);\n      }\n\n      if (typeof option.when !== \"string\" || option.when.trim().length === 0) {\n        errors.push(`${label}.when must be a non-empty string`);\n      }\n    });\n  }\n\n  if (!Array.isArray(record?.next)) {\n    errors.push(`${command}: handoff.nextOptions cannot be checked until next is a string array`);\n  } else if (!sameValue(optionCommands, record.next)) {\n    errors.push(`${command}: handoff.nextOptions commands must match next exactly`);\n  }\n\n  if (typeof handoff.handoffRequired !== \"boolean\") {\n    errors.push(`${command}: handoff.handoffRequired must be a boolean`);\n  } else if (handoff.handoffRequired !== false) {\n    errors.push(`${command}: handoff.handoffRequired must be false for recommend-only command handoff`);\n  }\n\n  if (typeof handoff.handoffReason !== \"string\" || handoff.handoffReason.trim().length === 0) {\n    errors.push(`${command}: handoff.handoffReason must be a non-empty string`);\n  }\n\n  return errors;\n}\n\nfunction validateUserIntent(record, command) {\n  const errors = [];\n  const userIntent = record?.userIntent;\n\n  if (!isPlainObject(userIntent)) {\n    errors.push(`${command}: userIntent must be an object`);\n  } else {\n    if (typeof userIntent.job !== \"string\" || userIntent.job.trim().length === 0) {\n      errors.push(`${command}: userIntent.job must be a non-empty string`);\n    }\n\n    if (!isNonEmptyStringArray(userIntent.ownedSignals)) {\n      errors.push(`${command}: userIntent.ownedSignals must be a non-empty string array`);\n    } else {\n      errors.push(...validateUniqueArray(command, \"userIntent.ownedSignals\", userIntent.ownedSignals));\n\n      const aliases = new Set(Array.isArray(record?.aliases) ? record.aliases : []);\n      for (const signal of userIntent.ownedSignals) {\n        if (!aliases.has(signal)) {\n          errors.push(`${command}: userIntent.ownedSignals contains non-alias signal ${signal}`);\n        }\n      }\n    }\n  }\n\n  if (!isNonEmptyStringArray(record?.copyGuard)) {\n    errors.push(`${command}: copyGuard must be a non-empty string array`);\n  } else {\n    errors.push(...validateUniqueArray(command, \"copyGuard\", record.copyGuard));\n  }\n\n  return errors;\n}\n\nfunction validateUniqueArray(command, field, values) {\n  const errors = [];\n  const seen = new Set();\n\n  for (const value of values) {\n    if (seen.has(value)) {\n      errors.push(`${command}: ${field} contains duplicate value ${value}`);\n    }\n    seen.add(value);\n  }\n\n  return errors;\n}\n\nfunction duplicateValues(values) {\n  const seen = new Set();\n  const duplicates = new Set();\n\n  for (const value of values) {\n    if (seen.has(value)) {\n      duplicates.add(value);\n    }\n    seen.add(value);\n  }\n\n  return [...duplicates].sort();\n}\n\nfunction isPlainObject(value) {\n  return Boolean(value) && typeof value === \"object\" && !Array.isArray(value);\n}\n\nfunction isNonEmptyStringArray(value) {\n  return Array.isArray(value) && value.length > 0 && value.every((item) => typeof item === \"string\" && item.length > 0);\n}\n\nfunction isStringArray(value) {\n  return Array.isArray(value) && value.every((item) => typeof item === \"string\" && item.length > 0);\n}\n\nfunction isGenericArtifactName(value) {\n  const normalized = value.trim().toLowerCase();\n\n  if (GENERIC_ARTIFACT_NAMES.has(normalized)) {\n    return true;\n  }\n\n  const words = normalized.split(/[^a-z0-9]+/).filter(Boolean);\n  return words.length > 0 && words.every((word) => GENERIC_ARTIFACT_NAMES.has(word));\n}\n\nasync function collectSurfaceDrift(records) {\n  const drift = [];\n\n  for (const record of records) {\n    const wrapperPath = wrapperPathForCommand(record.command);\n    let markdown;\n    let frontmatter;\n\n    try {\n      markdown = await readFile(wrapperPath.url, \"utf8\");\n      frontmatter = parseFrontmatter(markdown);\n    } catch (error) {\n      drift.push({\n        command: record.command,\n        field: \"wrapper\",\n        expected: wrapperPath.relativePath,\n        actual: error instanceof Error ? error.message : String(error)\n      });\n      continue;\n    }\n\n    for (const field of FRONTMATTER_DRIFT_FIELDS) {\n      const expected = expectedFrontmatterValue(record, field);\n      const actual = frontmatter[field];\n      const isGenericArgumentHint = field === \"argument-hint\" && actual === GENERIC_ARGUMENT_HINT;\n\n      if (isGenericArgumentHint || !sameValue(expected, actual)) {\n        drift.push({\n          command: record.command,\n          field,\n          expected,\n          actual: Object.hasOwn(frontmatter, field) ? actual : \"<missing>\"\n        });\n      }\n    }\n\n    const deliverableDrift = expectedEmitDeliverableDrift(record, markdown);\n    if (deliverableDrift) {\n      drift.push(deliverableDrift);\n    }\n\n    drift.push(...expectedUserIntentDrift(record, markdown));\n    drift.push(...expectedExampleDrift(record, markdown, wrapperPath));\n    drift.push(...expectedDiscriminatorDrift(record, markdown));\n    drift.push(...expectedPreconditionsDrift(record, markdown));\n    drift.push(...expectedPipelineDrift(record, markdown));\n    drift.push(...expectedHandoffDrift(record, markdown));\n    drift.push(...expectedChoreographyDrift(record, markdown));\n    drift.push(...expectedRegisterDrift(record, markdown));\n    drift.push(...expectedTaskProjectionsDrift(record, markdown));\n\n    if (record.command === INTERFACE_COMMAND) {\n      drift.push(...expectedInterfaceTaskLanesDrift(record, markdown));\n    }\n  }\n\n  return drift.sort(compareDrift);\n}\n\nfunction collectRosterReconciliationDrift(records, workflowModes, hubRouter, wrappers) {\n  const drift = [];\n  const metadataCommands = new Set(records.map((record) => record.command));\n  const wrapperCommands = new Set(wrappers.map((wrapper) => wrapper.command));\n  const hubModes = readHubRouterModes(hubRouter);\n  const hubCommands = commandSetForModes(hubModes);\n  const registryCommands = commandSetForModes(workflowModes);\n  const reconciledCommands = intersectSets(metadataCommands, wrapperCommands, hubCommands, registryCommands);\n\n  for (const wrapper of wrappers) {\n    if (!metadataCommands.has(wrapper.command)) {\n      drift.push(rosterDrift(\"orphan-wrapper\", wrapper.command, \"metadata record\", wrapper.relativePath));\n    }\n\n    if (wrapper.frontmatterError) {\n      drift.push(rosterDrift(\"dead-wrapper\", wrapper.command, \"parseable frontmatter\", wrapper.frontmatterError));\n    }\n\n    if (!hasCommandTitle(wrapper.markdown, wrapper.command)) {\n      drift.push(rosterDrift(\"dead-wrapper\", wrapper.command, `# ${wrapper.command}`, \"<missing or mismatched title>\"));\n    }\n\n    if (hasPlaceholderWrapper(wrapper)) {\n      drift.push(rosterDrift(\"placeholder-wrapper\", wrapper.command, \"specific argument contract\", GENERIC_ARGUMENT_HINT));\n    }\n  }\n\n  for (const command of sortedSet(metadataCommands)) {\n    if (!wrapperCommands.has(command)) {\n      drift.push(rosterDrift(\"missing-wrapper\", command, wrapperPathForCommand(command).relativePath, \"<missing>\"));\n    }\n\n    if (!hubCommands.has(command)) {\n      drift.push(rosterDrift(\"route-fixture-drift\", command, \"hub-router routable command\", \"<missing router signal>\"));\n    }\n  }\n\n  for (const command of sortedSet(wrapperCommands)) {\n    if (!hubCommands.has(command)) {\n      drift.push(rosterDrift(\"route-fixture-drift\", command, \"hub-router routable command\", \"wrapper-only command\"));\n    }\n  }\n\n  for (const command of sortedSet(hubCommands)) {\n    const workflowMode = command.replace(\"/design:\", \"\");\n\n    if (!registryCommands.has(command)) {\n      drift.push(rosterDrift(\"route-fixture-drift\", command, \"mode-registry workflowMode\", `hub-router routerSignals.${workflowMode}`));\n    }\n\n    if (!metadataCommands.has(command)) {\n      drift.push(rosterDrift(\"route-fixture-drift\", command, \"metadata record\", `hub-router routerSignals.${workflowMode}`));\n    }\n\n    if (!wrapperCommands.has(command) && !metadataCommands.has(command)) {\n      drift.push(rosterDrift(\"missing-wrapper\", command, wrapperPathForCommand(command).relativePath, `hub-router routerSignals.${workflowMode}`));\n    }\n  }\n\n  for (const record of records) {\n    drift.push(...collectDanglingHandoffDrift(record, reconciledCommands));\n  }\n\n  return uniqueDrift(drift).sort(compareDrift);\n}\n\nfunction collectDanglingHandoffDrift(record, commandSet) {\n  const drift = [];\n\n  for (const command of Array.isArray(record.next) ? record.next : []) {\n    if (!commandSet.has(command)) {\n      drift.push(rosterDrift(\"dangling-handoff\", record.command, \"next command in reconciled roster\", command));\n    }\n  }\n\n  const nextOptions = Array.isArray(record.handoff?.nextOptions) ? record.handoff.nextOptions : [];\n  for (const option of nextOptions) {\n    const command = option?.command;\n    if (typeof command === \"string\" && !commandSet.has(command)) {\n      drift.push(rosterDrift(\"dangling-handoff\", record.command, \"nextOptions command in reconciled roster\", command));\n    }\n  }\n\n  return drift;\n}\n\nfunction rosterDrift(kind, command, expected, actual) {\n  return {\n    kind,\n    command,\n    field: \"roster\",\n    expected,\n    actual\n  };\n}\n\nfunction hasCommandTitle(markdown, command) {\n  return new RegExp(`^#\\\\s+${escapeRegExp(command)}\\\\s*$`, \"m\").test(markdown);\n}\n\nfunction hasPlaceholderWrapper(wrapper) {\n  return wrapper.markdown.includes(GENERIC_ARGUMENT_HINT)\n    || wrapper.frontmatter?.[\"argument-hint\"] === GENERIC_ARGUMENT_HINT;\n}\n\nfunction expectedHandoffDrift(record, markdown) {\n  const section = extractHandoffGrammarSection(markdown);\n\n  if (!section) {\n    return [\n      {\n        kind: \"handoff\",\n        command: record.command,\n        field: \"handoff\",\n        expected: \"## HANDOFF GRAMMAR\",\n        actual: \"<missing section>\"\n      }\n    ];\n  }\n\n  const drift = [];\n  const handoff = record.handoff;\n  const nextOptionCommands = Array.isArray(handoff?.nextOptions)\n    ? handoff.nextOptions.map((option) => option.command)\n    : [];\n  const expectedLines = [\n    `NEXT_OPTIONS=${nextOptionCommands.join(\",\")}`,\n    `HANDOFF_REQUIRED=${String(handoff?.handoffRequired)}`,\n    `HANDOFF_REASON=\"${handoff?.handoffReason}\"`\n  ];\n\n  for (const token of HANDOFF_STATUS_TOKENS) {\n    if (!section.includes(token)) {\n      drift.push({\n        kind: \"handoff\",\n        command: record.command,\n        field: \"handoff\",\n        expected: token,\n        actual: \"<missing handoff token>\"\n      });\n    }\n  }\n\n  for (const expectedLine of expectedLines) {\n    if (!section.includes(expectedLine)) {\n      drift.push({\n        kind: \"handoff\",\n        command: record.command,\n        field: \"handoff\",\n        expected: expectedLine,\n        actual: \"<missing or mismatched handoff value>\"\n      });\n    }\n  }\n\n  for (const option of handoff.nextOptions) {\n    if (!section.includes(option.command)) {\n      drift.push({\n        kind: \"handoff\",\n        command: record.command,\n        field: \"handoff\",\n        expected: option.command,\n        actual: \"<missing next option command>\"\n      });\n    }\n\n    if (!containsPhrase(section, option.when)) {\n      drift.push({\n        kind: \"handoff\",\n        command: record.command,\n        field: \"handoff\",\n        expected: option.when,\n        actual: \"<missing next option rationale>\"\n      });\n    }\n  }\n\n  if (handoff.handoffRequired === false && !section.includes(\"HANDOFF_REQUIRED=false\")) {\n    drift.push({\n      kind: \"handoff\",\n      command: record.command,\n      field: \"handoff\",\n      expected: \"HANDOFF_REQUIRED=false\",\n      actual: \"<missing recommend-only handoff flag>\"\n    });\n  }\n\n  if (!containsPhrase(section, \"never silently chains\")) {\n    drift.push({\n      kind: \"handoff\",\n      command: record.command,\n      field: \"handoff\",\n      expected: \"never silently chains\",\n      actual: \"<missing no-silent-chain assertion>\"\n    });\n  }\n\n  return drift;\n}\n\nfunction expectedTaskProjectionsDrift(record, markdown) {\n  const section = extractTaskProjectionsSection(markdown);\n\n  if (!section) {\n    return [\n      {\n        kind: \"taskProjections\",\n        command: record.command,\n        field: \"taskProjections\",\n        expected: \"## TASK PROJECTIONS\",\n        actual: \"<missing section>\"\n      }\n    ];\n  }\n\n  const drift = [];\n  const projections = Array.isArray(record.taskProjections) ? record.taskProjections : [];\n\n  for (const projection of projections) {\n    if (!isPlainObject(projection) || typeof projection.verb !== \"string\" || projection.verb.length === 0) {\n      continue;\n    }\n\n    if (!containsWholeWord(section, projection.verb)) {\n      drift.push({\n        kind: \"taskProjections\",\n        command: record.command,\n        field: \"taskProjections\",\n        expected: projection.verb,\n        actual: \"<missing projection verb>\"\n      });\n    }\n  }\n\n  if (projections.length === 0 && !containsPhrase(section, \"No transform-verb projections\")) {\n    drift.push({\n      kind: \"taskProjections\",\n      command: record.command,\n      field: \"taskProjections\",\n      expected: \"No transform-verb projections\",\n      actual: \"<missing empty-projection notice>\"\n    });\n  }\n","lineStart":1,"lineEnd":1594,"totalLines":1595,"truncated":true}},"title":".opencode/skills/sk-design/shared/scripts/design-command-surface-check.mjs","time":{"start":1782750700475,"end":1782750700480}},"id":"prt_f1438e3b9001gOSLvG6v2HRGQf","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f1438be3e001rqpmLAiEblL3nq"}}
