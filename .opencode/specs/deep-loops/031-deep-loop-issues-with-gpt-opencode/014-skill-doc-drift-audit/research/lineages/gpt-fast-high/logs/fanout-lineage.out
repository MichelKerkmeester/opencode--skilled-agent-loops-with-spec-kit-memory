ieval_directive\": \"Always surface when: rule applies — never a grep narrowed to your own files — and report the delta in the form `baseline N failing {…} → now M: {…}`. | Prioritize when: never re-renders, a screenshot of the wrong screen, a fixture older than your work making a green result suspect. \\\"No r…\"\n        }\n      ],\n      \"triggered\": [\n        {\n          \"memory_id\": 7282,\n          \"spec_folder\": \"system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/002-skill-speckit-alignment\",\n          \"title\": \"Task [system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/task-02-skill-speckit-alignment/spec]\",\n          \"matched_phrases\": [\n            \"skill\",\n            \"references\",\n            \"audit\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 16994,\n          \"spec_folder\": \"system-spec-kit/026-graph-and-context-optimization/002-spec-kit-internals/002-skill-advisor/002-skill-advisor-scoring-engine/001-advisor-hook-brief-improvements/research/003-advisor-gap-investigation\",\n          \"title\": \"...9-hook-package/014-skill-advisor-hook-improvements/research/003-advisor-gap-investigation/research]\",\n          \"matched_phrases\": [\n            \"014\",\n            \"skill\",\n            \"research\",\n            \"031\"\n          ]\n        },\n        {\n          \"memory_id\": 6626,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/007-system-spec-kit-rename\",\n          \"title\": \"Skill Rename [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/007-system-spec-kit-rename/spec]\",\n          \"matched_phrases\": [\n            \"skill\",\n            \"workflows\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 1498,\n          \"spec_folder\": \"skilled-agent-orchestration/z_archive/024-sk-deep-research-refinement\",\n          \"title\": \"Feature Specification: sk-deep-research Refinement [skilled-agent-orchestration/024-sk-deep-research-refinement/spec]\",\n          \"matched_phrases\": [\n            \"deep\",\n            \"research\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 1371,\n          \"spec_folder\": \"skilled-agent-orchestration/z_archive/005-cli-codex-creation\",\n          \"title\": \"Feature Specification: cli-gemini Model Consolidation + [03--commands-and-skills/005-cli-codex-creation/spec]\",\n          \"matched_phrases\": [\n            \"cli\",\n            \"model\",\n            \"spec\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-07-01T15:16:12.555Z\",\n      \"latencyMs\": 213\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1782918972336,"end":1782918972581}},"metadata":{"openai":{"itemId":"fc_04f6f0cfd7fab63c016a452f3394e081918bdc0e9644e3dfe6"}},"id":"prt_f1e40616c001JYeFCTjP1Z16aF","sessionID":"ses_0e1c04adcffe04QJWsDQQqIgY4","messageID":"msg_f1e404962001sdNhclcu7D2DjZ"}}
