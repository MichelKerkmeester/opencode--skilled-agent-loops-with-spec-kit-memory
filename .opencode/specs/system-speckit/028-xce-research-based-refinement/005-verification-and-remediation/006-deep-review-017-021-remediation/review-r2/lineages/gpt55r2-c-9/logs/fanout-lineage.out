         {\n              \"lane\": \"derived_generated\",\n              \"feature\": \"derived_skill_signal\"\n            },\n            {\n              \"lane\": \"semantic_shadow\",\n              \"feature\": \"semantic_similarity\"\n            },\n            {\n              \"lane\": \"lexical\",\n              \"feature\": \"token_match\"\n            }\n          ]\n        },\n        \"status\": \"active\"\n      },\n      {\n        \"skillId\": \"sk-doc\",\n        \"score\": 0.08487,\n        \"confidence\": 0.82,\n        \"uncertainty\": 0.22,\n        \"dominantLane\": \"lexical\",\n        \"laneBreakdown\": [\n          {\n            \"lane\": \"explicit_author\",\n            \"rawScore\": 0,\n            \"weightedScore\": 0,\n            \"weight\": 0.42,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"lexical\",\n            \"rawScore\": 0.2041666666666667,\n            \"weightedScore\": 0.05716666666666668,\n            \"weight\": 0.28,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"graph_causal\",\n            \"rawScore\": 0,\n            \"weightedScore\": 0,\n            \"weight\": 0.13,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"derived_generated\",\n            \"rawScore\": 0,\n            \"weightedScore\": 0,\n            \"weight\": 0.12,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"semantic_shadow\",\n            \"rawScore\": 0.554075,\n            \"weightedScore\": 0.02770375,\n            \"weight\": 0.05,\n            \"shadowOnly\": false\n          }\n        ],\n        \"why_recommended\": {\n          \"reason\": \"Recommended from ranker signals: lexical contributed the strongest live score.\",\n          \"dominantLane\": \"lexical\",\n          \"topLanes\": [\n            {\n              \"lane\": \"lexical\",\n              \"rawScore\": 0.2041666666666667,\n              \"weightedScore\": 0.05716666666666668,\n              \"weight\": 0.28,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"token_match\"\n              ],\n              \"evidenceCount\": 2\n            },\n            {\n              \"lane\": \"semantic_shadow\",\n              \"rawScore\": 0.554075,\n              \"weightedScore\": 0.02770375,\n              \"weight\": 0.05,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"semantic_similarity\"\n              ],\n              \"evidenceCount\": 1\n            }\n          ],\n          \"matchedSkillFeatures\": [\n            {\n              \"lane\": \"lexical\",\n              \"feature\": \"token_match\"\n            },\n            {\n              \"lane\": \"semantic_shadow\",\n              \"feature\": \"semantic_similarity\"\n            }\n          ]\n        },\n        \"status\": \"active\"\n      }\n    ],\n    \"ambiguous\": true,\n    \"freshness\": \"live\",\n    \"trustState\": {\n      \"state\": \"live\",\n      \"reason\": null,\n      \"generation\": 7207,\n      \"checkedAt\": \"2026-06-18T06:30:40.447Z\",\n      \"lastLiveAt\": \"2026-06-18T05:51:36.972Z\"\n    },\n    \"generatedAt\": \"2026-06-18T06:30:40.497Z\",\n    \"cache\": {\n      \"hit\": false,\n      \"sourceSignaturePresent\": true\n    },\n    \"_shadow\": {\n      \"model\": \"advisor-shadow-learned-weights-v1\",\n      \"liveWeightsFrozen\": true,\n      \"recommendations\": [\n        {\n          \"skillId\": \"sk-code-review\",\n          \"liveScore\": 0.770344,\n          \"shadowScore\": 0.732047,\n          \"delta\": -0.038297,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"deep-loop-workflows\",\n          \"liveScore\": 0.728637,\n          \"shadowScore\": 0.694647,\n          \"delta\": -0.03399,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"sk-code\",\n          \"liveScore\": 0.515966,\n          \"shadowScore\": 0.521103,\n          \"delta\": 0.005137,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"mcp-code-mode\",\n          \"liveScore\": 0.511961,\n          \"shadowScore\": 0.482854,\n          \"delta\": -0.029107,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"sk-doc\",\n          \"liveScore\": 0.08487,\n          \"shadowScore\": 0.078745,\n          \"delta\": -0.006125,\n          \"dominantShadowLane\": \"lexical\"\n        }\n      ]\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781764240277,"end":1781764240500}},"metadata":{"openai":{"itemId":"fc_00a0b22784c1f490016a33908e869881919edda83be1047de2"}},"id":"prt_ed96caccf001X9npqfYSVGarAE","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed96c9e14001E4vkCEPLQsfehi"}}
