   107	          if (typeof a.expected_count === 'number') ok = count === a.expected_count;
   108	          else if (typeof a.expected_count === 'string' && a.expected_count.startsWith('>=')) {
   109	            ok = count >= parseInt(a.expected_count.slice(2).trim(), 10);
   110	          } else ok = count >= 1;
   111	          detail = `count=${count}`;
   112	        }
   113	      } else if (a.type === 'grep_absent') {
   114	        const file = resolveCriteriaFile(cwdAbs, a.file);
   115	        if (file === null) { ok = false; detail = 'file outside fixture cwd (rejected)'; }
   116	        else if (!fs.existsSync(file)) { ok = true; detail = 'file missing (treated as absent)'; }
   117	        else {
   118	          ok = !new RegExp(a.pattern).test(fs.readFileSync(file, 'utf8'));
