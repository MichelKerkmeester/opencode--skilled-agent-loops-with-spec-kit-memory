201-/**
202: * Parse an authored expected_resources gold block from YAML frontmatter into
203- * inert strings, loudly. Route gold is a contract, so a present-but-unparseable
204- * block must surface as a parse failure the gate can count — never a silent
205- * empty list (the historical silent-skip channel). Items are taken verbatim
206- * (cleaned of bullets/quotes/backticks) and NEVER interpreted or executed, so a
207- * command-shaped value is just a string that will fail to match any routed
208- * resource. An explicit empty list (`[]`, inline or on the following line) is a
209- * real assertion: "this route assembles nothing".
210- *
211: * @param {string} block - Full frontmatter block text.
212- * @returns {{present:boolean,resources:string[],parseError:(string|null)}} Parsed gold.
213- */
214-function parseExpectedResourcesGold(block) {
215:  const keyM = /(?:^|\n)[ \t]*expected_resources[ \t]*:(.*)/.exec(block);
216-  if (!keyM) return { present: false, resources: [], parseError: null };
217-
218-  const inlineRest = keyM[1].trim();
219-  if (inlineRest) {
220-    const inlineList = /^\[(.*)\]$/.exec(inlineRest);
221-    if (inlineList) return { present: true, resources: parseListText(inlineList[1]), parseError: null };
222:    // Inline scalar (`expected_resources: references/x.md`) — a single inert item.
223-    return { present: true, resources: parseListText(inlineRest), parseError: null };
224-  }
225-
226-  const after = block.slice(keyM.index + keyM[0].length).replace(/^\n/, '');
227-  if (/^[ \t]*\[\s*\]/.test(after)) return { present: true, resources: [], parseError: null };
228-  const dashList = /^((?:[ \t]*-[ \t]*.+\n?)+)/.exec(after);
229-  if (dashList) {
230-    const resources = [...new Set(parseListText(dashList[1]))];
231:    if (resources.length === 0) return { present: true, resources: [], parseError: 'expected_resources list items did not parse' };
232-    return { present: true, resources, parseError: null };
233-  }
234:  return { present: true, resources: [], parseError: 'expected_resources block is present but unparseable' };
235-}
