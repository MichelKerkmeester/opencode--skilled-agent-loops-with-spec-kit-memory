afterEach(() => {\n    vi.restoreAllMocks();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","text":"import Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { __testables } from '../lib/search/vector-index-store.js';\n\nfunction makeMemoryDb(): Database.Database {\n  const db = new Database(':memory:');\n  sqliteVec.load(db);\n  db.exec(`\n    CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n    CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n  `);\n  return db;\n}\n\ndescribe('vector dimension source precedence', () => {\n  afterEach(() => {\n    vi.restoreAllMocks();\n  });\n\n  it('uses the active embedder profile before vec_memories schema text', () => {\n    const db = makeMemoryDb();\n    try {\n      setActiveEmbedder(db, 'profile-model', 4, 'ollama');\n      db.exec(`CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[8])`);\n\n      const result = __testables.get_existing_embedding_dimension(db);\n\n      expect(result).toMatchObject({\n        existing_db: true,\n        stored_dim: 4,\n        source: 'active_embedder_profile',\n      });\n    } finally {\n      db.close();\n    }\n  });\n\n  it('demotes vec_memories schema parsing to a warning-only last resort', () => {\n    const db = new Database(':memory:');\n    sqliteVec.load(db);\n    const warn = vi.spyOn(console, 'warn').mockImplementation(() => {});\n    try {\n      db.exec(`\n        CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n        CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[6]);\n      `);\n\n      const result = __testables.get_existing_embedding_dimension(db, { allowProfileFallback: false });\n\n      expect(result).toMatchObject({\n        existing_db: true,\n        stored_dim: 6,\n        source: 'vec_memories',\n      });\n      expect(warn).toHaveBeenCalledWith(expect.stringContaining('Falling back to vec_memories schema text'));\n    } finally {\n      db.close();\n    }\n  });\n\n  it('reports absent schema without inventing a stored dimension', () => {\n    const db = new Database(':memory:');\n    try {\n      const result = __testables.get_existing_embedding_dimension(db);\n\n      expect(result).toMatchObject({\n        existing_db: false,\n        stored_dim: null,\n        source: null,\n      });\n    } finally {\n      db.close();\n    }\n  });\n});","lineStart":1,"lineEnd":78,"totalLines":78,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","time":{"start":1781151307402,"end":1781151307409}},"metadata":{"openai":{"itemId":"fc_094727126f7d43f3016a2a364b53848191a79a2e2e197fbffa"}},"id":"prt_eb4e41686001cUAjuf0aTNZ2wB","sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","messageID":"msg_eb4e3cc5a001rVj5YBDZfkHvXY"}}
{"type":"tool_use","timestamp":1781151307440,"sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","part":{"type":"tool","tool":"read","callID":"call_4EJILpmQeJ8iNqmVHsixbakV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts</path>\n<type>file</type>\n<content>\n1: import * as fs from 'node:fs';\n2: import * as os from 'node:os';\n3: import * as path from 'node:path';\n4: \n5: import Database from 'better-sqlite3';\n6: import * as sqliteVec from 'sqlite-vec';\n7: import { afterEach, beforeEach, describe, expect, it } from 'vitest';\n8: \n9: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n10: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n11: import { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\n12: import {\n13:   benchmarkKnnQueryShapes,\n14:   shouldAdoptMatchQueryShape,\n15: } from '../lib/search/vector-index-queries.js';\n16: \n17: const DIM = 4;\n18: \n19: function embedding(value: number): Float32Array {\n20:   return Float32Array.from([value, value / 2, value / 3, value / 4]);\n21: }\n22: \n23: function embeddingBuffer(value: number): Buffer {\n24:   const vector = embedding(value);\n25:   return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n26: }\n27: \n28: describe('vector KNN query-shape benchmark', () => {\n29:   let tempDir: string;\n30:   let db: Database.Database;\n31:   let profile: EmbeddingProfile;\n32: \n33:   beforeEach(() => {\n34:     tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-knn-benchmark-'));\n35:     db = new Database(path.join(tempDir, 'context-index.sqlite'));\n36:     sqliteVec.load(db);\n37:     profile = new EmbeddingProfile({ provider: 'ollama', model: 'knn-benchmark-model', dim: DIM, dtype: null, baseUrl: null });\n38:     setActiveEmbedder(db, profile.model, profile.dim, 'ollama');\n39:     attachActiveVectorShard(db, profile);\n40:     db.exec(`\n41:       CREATE TABLE memory_index (\n42:         id INTEGER PRIMARY KEY,\n43:         spec_folder TEXT,\n44:         file_path TEXT,\n45:         importance_tier TEXT DEFAULT 'normal',\n46:         importance_weight REAL DEFAULT 0.5,\n47:         embedding_status TEXT DEFAULT 'success',\n48:         expires_at TEXT,\n49:         is_pinned INTEGER DEFAULT 0,\n50:         last_review TEXT,\n51:         review_count INTEGER DEFAULT 0,\n52:         stability REAL,\n53:         updated_at TEXT DEFAULT (datetime('now'))\n54:       );\n55:       CREATE VIEW active_memory_projection AS SELECT id AS active_memory_id FROM memory_index;\n56:     `);\n57:     const memoryInsert = db.prepare(`\n58:       INSERT INTO memory_index (id, spec_folder, file_path, embedding_status)\n59:       VALUES (?, 'specs/knn', ?, 'success')\n60:     `);\n61:     const vecInsert = db.prepare(`INSERT INTO active_vec.vec_${DIM} (id, vec) VALUES (?, ?)`);\n62:     const knnInsert = db.prepare('INSERT INTO active_vec.vec_memories (rowid, embedding) VALUES (?, ?)');\n63:     const writeRows = db.transaction(() => {\n64:       for (let i = 1; i <= 32; i += 1) {\n65:         memoryInsert.run(i, `doc-${i}.md`);\n66:         vecInsert.run(i, embeddingBuffer(i));\n67:         knnInsert.run(BigInt(i), embeddingBuffer(i));\n68:       }\n69:     });\n70:     writeRows();\n71:   });\n72: \n73:   afterEach(() => {\n74:     try { detachActiveVectorShard(db); } catch { /* best-effort */ }\n75:     try { db.close(); } catch { /* best-effort */ }\n76:     fs.rmSync(tempDir, { recursive: true, force: true });\n77:   });\n78: \n79:   it('records scalar JOIN vs vec0 MATCH timings and gates adoption at >20 percent', () => {\n80:     const result = benchmarkKnnQueryShapes(embedding(1), { iterations: 2, limit: 8 }, db);\n81: \n82:     console.info(\n83:       `KNN query-shape benchmark: corpus=${result.corpusSize} scalar_ms=${result.scalarJoinAverageMs.toFixed(4)} ` +\n84:       `match_ms=${result.matchAverageMs?.toFixed(4) ?? 'n/a'} decision=${result.decision}`,\n85:     );\n86:     expect(result.corpusSize).toBe(32);\n87:     expect(result.scalarJoinAverageMs).toBeGreaterThanOrEqual(0);\n88:     expect(result.decision).toBe(\n89:       result.matchSupported && (result.matchImprovementPct ?? 0) > 20 ? 'adopt_match' : 'keep_scalar_join',\n90:     );\n91:     expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20 })).toBe(false);\n92:     expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20.1 })).toBe(true);\n93:   });\n94: });\n\n(End of file - total 94 lines)\n</content>","metadata":{"preview":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\nimport {\n  benchmarkKnnQueryShapes,\n  shouldAdoptMatchQueryShape,\n} from '../lib/search/vector-index-queries.js';\n\nconst DIM = 4;\n\nfunction embedding(value: number): Float32Array {\n  return Float32Array.from([value, value / 2, value / 3, value / 4]);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","text":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\nimport {\n  benchmarkKnnQueryShapes,\n  shouldAdoptMatchQueryShape,\n} from '../lib/search/vector-index-queries.js';\n\nconst DIM = 4;\n\nfunction embedding(value: number): Float32Array {\n  return Float32Array.from([value, value / 2, value / 3, value / 4]);\n}\n\nfunction embeddingBuffer(value: number): Buffer {\n  const vector = embedding(value);\n  return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n}\n\ndescribe('vector KNN query-shape benchmark', () => {\n  let tempDir: string;\n  let db: Database.Database;\n  let profile: EmbeddingProfile;\n\n  beforeEach(() => {\n    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-knn-benchmark-'));\n    db = new Database(path.join(tempDir, 'context-index.sqlite'));\n    sqliteVec.load(db);\n    profile = new EmbeddingProfile({ provider: 'ollama', model: 'knn-benchmark-model', dim: DIM, dtype: null, baseUrl: null });\n    setActiveEmbedder(db, profile.model, profile.dim, 'ollama');\n    attachActiveVectorShard(db, profile);\n    db.exec(`\n      CREATE TABLE memory_index (\n        id INTEGER PRIMARY KEY,\n        spec_folder TEXT,\n        file_path TEXT,\n        importance_tier TEXT DEFAULT 'normal',\n        importance_weight REAL DEFAULT 0.5,\n        embedding_status TEXT DEFAULT 'success',\n        expires_at TEXT,\n        is_pinned INTEGER DEFAULT 0,\n        last_review TEXT,\n        review_count INTEGER DEFAULT 0,\n        stability REAL,\n        updated_at TEXT DEFAULT (datetime('now'))\n      );\n      CREATE VIEW active_memory_projection AS SELECT id AS active_memory_id FROM memory_index;\n    `);\n    const memoryInsert = db.prepare(`\n      INSERT INTO memory_index (id, spec_folder, file_path, embedding_status)\n      VALUES (?, 'specs/knn', ?, 'success')\n    `);\n    const vecInsert = db.prepare(`INSERT INTO active_vec.vec_${DIM} (id, vec) VALUES (?, ?)`);\n    const knnInsert = db.prepare('INSERT INTO active_vec.vec_memories (rowid, embedding) VALUES (?, ?)');\n    const writeRows = db.transaction(() => {\n      for (let i = 1; i <= 32; i += 1) {\n        memoryInsert.run(i, `doc-${i}.md`);\n        vecInsert.run(i, embeddingBuffer(i));\n        knnInsert.run(BigInt(i), embeddingBuffer(i));\n      }\n    });\n    writeRows();\n  });\n\n  afterEach(() => {\n    try { detachActiveVectorShard(db); } catch { /* best-effort */ }\n    try { db.close(); } catch { /* best-effort */ }\n    fs.rmSync(tempDir, { recursive: true, force: true });\n  });\n\n  it('records scalar JOIN vs vec0 MATCH timings and gates adoption at >20 percent', () => {\n    const result = benchmarkKnnQueryShapes(embedding(1), { iterations: 2, limit: 8 }, db);\n\n    console.info(\n      `KNN query-shape benchmark: corpus=${result.corpusSize} scalar_ms=${result.scalarJoinAverageMs.toFixed(4)} ` +\n      `match_ms=${result.matchAverageMs?.toFixed(4) ?? 'n/a'} decision=${result.decision}`,\n    );\n    expect(result.corpusSize).toBe(32);\n    expect(result.scalarJoinAverageMs).toBeGreaterThanOrEqual(0);\n    expect(result.decision).toBe(\n      result.matchSupported && (result.matchImprovementPct ?? 0) > 20 ? 'adopt_match' : 'keep_scalar_join',\n    );\n    expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20 })).toBe(false);\n    expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20.1 })).toBe(true);\n  });\n});","lineStart":1,"lineEnd":94,"totalLines":94,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","time":{"start":1781151307437,"end":1781151307439}},"metadata":{"openai":{"itemId":"fc_094727126f7d43f3016a2a364b538c819186c2e508fc1890a0"}},"id":"prt_eb4e4168b001bhzFOIipW810qN","sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","messageID":"msg_eb4e3cc5a001rVj5YBDZfkHvXY"}}
