ode cost shows 0/0 (Token-Plan subscription). --variant maps to MiMo reasoning effort (low/medium/high) in opencode settings — always dispatch with --variant high (confirmed accepted on opencode 1.15.13). Best prompt framework (benchmark 004, 10/10 real runs): COSTAR or RACE + lean pre-planning — frame for format/brevity, not guardrails; TIDD-EC/dense ranked last; avoid CIDI (intermittent tool-only file-writes).\"\n201:         }\n202:       ],\n203:       \"primary_quota_pool\": \"xiaomi-token-plan\",\n204:       \"fallback_target\": null,\n205:       \"free_tier\": false,\n206:       \"capability\": {\n207:         \"model_slug\": \"xiaomi-token-plan-ams/mimo-v2.5-pro\",\n208:         \"default_variant\": \"high\",\n209:         \"variant_flag\": \"--variant\",\n210:         \"agent_policy\": \"omit-general\",\n211:         \"format_mode\": \"json\",\n212:         \"quota_pool\": \"xiaomi-token-plan\",\n213:         \"variant_status\": \"confirmed\",\n214:         \"notes\": \"Live slug `xiaomi-token-plan-ams/mimo-v2.5-pro` confirmed responsive on opencode 1.15.13 (2026-06-01). default_variant high: `--variant` maps to MiMo reasoning effort (low/medium/high) and `--variant high` is confirmed accepted — always dispatch with it. agent_policy omit-general: `--agent` warns and falls back on 1.15.13. format_mode json: OpenAI-compatible endpoint; dispatch via `opencode run --format json` for the normalized envelope. Manual direct-provider reroutes use `xiaomi/mimo-v2.5-pro` when configured; no automatic gateway fallback is defined.\",\n215:         \"modalities\": [\n216:           \"text\"\n217:         ]\n218:       },\n219:       \"strengths\": [\n220:         \"1,000,000-token context window (largest in the small-model rotation)\",\n221:         \"strongly agentic — sustains 1000+ sequential tool calls (SWE-bench Pro 57.2)\",\n222:         \"token-efficient — 40-60% fewer tokens/trajectory vs frontier models (Opus 4.6 / GPT-5.4)\",\n223:         \"Xiaomi Token Plan (Europe) subscription billing via provider xiaomi-token-plan-ams\",\n224:         \"separate quota pool (xiaomi-token-plan) independent of minimax / cognition pools\",\n225:         \"manual direct-provider reroute available at xiaomi/mimo-v2.5-pro when configured\"\n226:       ],\n227:       \"weaknesses\": [\n228:         \"long-context quality degrades past ~512k despite the 1M window\",\n229:         \"Token-Plan subscription request-window semantics unverified\",\n230:         \"prompt-framework benchmark 004 used 2 fixtures / single-sample — COSTAR vs RACE tie is within noise\",\n231:         \"visual/illustration tasks: over-accents — spreads orange/gold across most cards, weak color restraint despite clean shapes and a reserved-accent brief (informal bento bake-off, n=1 fixture, 2026-06-22; see references/models/mimo-v2.5-pro.md)\"\n232:       ],\n233:       \"avg_iter_wall_clock_min\": null,\n234:       \"status\": \"active\",\n235:       \"recommended_frameworks\": {\n236:         \"primary\": \"costar\",\n237:         \"fallback\": \"race\",\n238:         \"avoid\": [\n239:           \"tidd-ec\",\n240:           \"cidi\"\n241:         ],\n242:         \"preplanning_density\": \"lean\",\n243:         \"evidence\": {\n244:           \"benchmark\": \"004\",\n245:           \"primary_score\": 1.0,\n246:           \"fallback_score\": 0.9934,\n247:           \"sample\": \"10/10 real MiMo-V2.5-Pro runs at --variant high\",\n248:           \"confidence\": \"high\"\n249:         },\n250:         \"profile_ref\": \"sk-prompt-models/references/models/mimo-v2.5-pro.md\",\n251:         \"status\": \"empirical\"\n252:       }\n253:     },\n254:     {\n255:       \"id\": \"glm-5.2\",\n256:       \"context_length\": 1000000,\n257:       \"tool_calling\": \"native\",\n258:       \"chat_template\": \"default\",\n259:       \"executors\": [\n260:         {\n261:           \"executor\": \"cli-opencode\",\n262:           \"provider\": \"zai-coding-plan\",\n263:           \"quota_pool\": \"zai-coding-plan\",\n264:           \"status\": \"active\",\n265:           \"notes\": \"Z.AI GLM Coding Plan (subscription) via opencode provider `zai-coding-plan` (auth credential 'Z.AI Coding Plan'). Live slug `zai-coding-plan/glm-5.2`; confirmed present via `opencode models zai-coding-plan` 2026-06-28 → glm-4.5-air/glm-4.7/glm-5-turbo/glm-5.1/glm-5.2/glm-5v-turbo. Flagship long-horizon coding model (supersedes the gateway-only glm-5.1 removed in cli-opencode v1.3.15.0). context_length 1,000,000 / 131,072 output per Z.AI docs — opencode `models` did not expose limits, re-verify. Omit `--agent` at top level. GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it. Thinking is on by default and the Coding Plan endpoint preserves thinking. Re-verify the live slug before automation — Z.AI ids drift (provider also serves glm-4.7 / glm-5.1 / glm-5-turbo).\"\n266:         }\n267:       ],\n268:       \"primary_quota_pool\": \"zai-coding-plan\",\n269:       \"fallback_target\": null,\n270:       \"free_tier\": false,\n271:       \"capability\": {\n272:         \"model_slug\": \"zai-coding-plan/glm-5.2\",\n273:         \"default_variant\": \"high\",\n274:         \"variant_flag\": \"--variant\",\n275:         \"agent_policy\": \"omit-general\",\n276:         \"format_mode\": \"json\",\n277:         \"quota_pool\": \"zai-coding-plan\",\n278:         \"variant_status\": \"accepted-unverified\",\n279:         \"modalities\": [\n280:           \"text\",\n281:           \"image\"\n282:         ],\n283:         \"vision\": \"native vision-to-code; image input via the direct Z.AI Coding Plan multimodal API (base64 image_url block at https://api.z.ai/api/coding/paas/v4/chat/completions) — opencode `--file` does NOT deliver images to this provider per upstream #20802; confirmed live 2026-06-28; see references/models/glm-5.2.md §7\",\n284:         \"notes\": \"Live slug `zai-coding-plan/glm-5.2` confirmed present 2026-06-28 (`opencode models zai-coding-plan`). agent_policy omit-general: do not pass `--agent` at the top level. format_mode json: dispatch via `opencode run --format json` for the normalized token/cost/latency envelope. default_variant high + variant_status accepted-unverified: GLM's native `reasoning_effort` has high/max, but whether opencode `--variant high/max` forwards to it is not confirmed — smoke-test, do not depend on it. Subscription billing: confirm dispatch cost via smoke test. GLM dispatch quirks (Z.AI docs): thinking on by default + preserved thinking on the Coding Plan endpoint; function-calling `tool_choice` only `auto`; streaming tool calls need `tool_stream=true`. Re-verify slug before dispatch (Z.AI ids drift).\"\n285:       },\n286:       \"strengths\": [\n287:         \"dedicated Z.AI GLM Coding Plan subscription pool (`zai-coding-plan`), independent of kimi / minimax / xiaomi pools\",\n288:         \"flagship long-horizon coding model (Z.AI docs: Terminal-Bench 2.1 81.0, SWE-bench Pro 62.1 — both above GLM-5.1)\",\n289:         \"1,000,000-token context for long-file and multi-repo work (128K max output)\",\n290:         \"subscription billing via the Z.AI Coding Plan\",\n291:         \"native reasoning_effort (high/max) + thinking-by-default for complex multi-constraint coding\"\n292:       ],\n293:       \"weaknesses\": [\n294:         \"single executor path (no fallback if the zai-coding-plan pool is exhausted)\",\n295:         \"context_length / max-output recorded from Z.AI docs (1,000,000 / 131,072) — opencode `models` did not expose limits; re-verify on the install\",\n296:         \"--variant ↔ reasoning_effort mapping unverified (GLM has native high/max; opencode forwarding not confirmed)\",\n297:         \"best prompt framework is a TIE among the perfect tier (costar=tidd-ec=cidi=race at correctness 1.0); costar is best-of-tied (tersest + cross-model corroborated), not a decisive single winner — benchmark 008\",\n298:         \"thinking-on-by-default drives high latency variance — 6-161s observed over benchmark 008's 45 small code-gen cells (avg ~26s, ~27x spread); budget generous timeouts, a tight timeout kills the slow tail\",\n299:         \"~1/45 dispatches was a transient infra failure (exit -1, dispatch_failed) in benchmark 008 — expect occasional transient dispatch failures at scale; retry the cell rather than treating it as a model error\"\n300:       ],\n301:       \"avg_iter_wall_clock_min\": null,\n302:       \"status\": \"active\",\n303:       \"recommended_frameworks\": {\n304:         \"primary\": \"costar\",\n305:         \"fallback\": \"tidd-ec\",\n306:         \"avoid\": [\n307:           \"rcaf\"\n308:         ],\n309:         \"preplanning_density\": \"lean\",\n310:         \"evidence\": {\n311:           \"benchmark\": \"008-glm-5.2-prompt-framework\",\n312:           \"primary_score\": 1.0,\n313:           \"fallback_score\": 1.0,\n314:           \"sample\": \"5-framework bakeoff on invalid-dominant STRICT VALIDATORS (validate-ipv4 + validate-date + validate-semver), 3 samples/cell, real zai-coding-plan/glm-5.2 dispatches graded by the deterministic hidden-test oracle (grader noop, no LLM-judge bias). Run status SEPARABLE: per-framework correctness costar 1.0 = tidd-ec 1.0 = cidi 1.0 = race 1.0 (perfect tier) > rcaf 0.976 (the ONLY sub-perfect framework; also worst format adherence 0.889). Trust verdict TIE on correctness among the perfect tier (top-pair costar vs tidd-ec, margin 0, 90% CI [0,0]). costar is primary as best-of-tied: perfect correctness + tersest output (13 median words vs tidd-ec 38, cidi/race 94) + cross-model corroboration (also the empirical winner for kimi benchmark 007 and mimo benchmark 004). tidd-ec fallback (perfect, 2nd-tersest). rcaf avoided (only correctness misses + worst format). NOTE: CRAFT (the phase-1 doc-guided default) is NOT in the harness framework registry [rcaf,race,cidi,tidd-ec,costar] so it could not be benchmarked; the empirical winner among the 5 supported frameworks replaces it. 1/45 dispatches was a transient infra failure (exit -1, excluded from scoring).\",\n315:           \"confidence\": \"medium\"\n316:         },\n317:         \"profile_ref\": \"sk-prompt-models/references/models/glm-5.2.md\",\n318:         \"status\": \"empirical\"\n319:       }\n320:     },\n321:     {\n322:       \"id\": \"haiku\",\n323:       \"context_length\": null,\n324:       \"tool_calling\": \"native\",\n325:       \"chat_template\": \"default\",\n326:       \"executors\": [\n327:         {\n328:           \"executor\": \"cli-claude-code\",\n329:           \"provider\": \"anthropic\",\n330:           \"quota_pool\": \"anthropic\",\n331:           \"status\": \"optional-unverified\",\n332:           \"notes\": \"Future small-model fallback candidate. Adoption blocked until quota-pool semantics verified.\"\n333:         }\n334:       ],\n335:       \"primary_quota_pool\": \"anthropic\",\n336:       \"fallback_target\": null,\n337:       \"free_tier\": false,\n338:       \"strengths\": [\n339:         \"separate quota pool\",\n340:         \"fast natural-language synthesis\",\n341:         \"future fallback candidate\"\n342:       ],\n343:       \"weaknesses\": [\n344:         \"not in active rotation\",\n345:         \"unverified for this workflow\",\n346:         \"requires adoption before routing\"\n347:       ],\n348:       \"avg_iter_wall_clock_min\": null,\n349:       \"status\": \"optional-unverified\"\n\n(Showing lines 180-349 of 352. Use offset=350 to continue.)\n</content>","metadata":{"preview":"          \"primary_score\": 0.767,\n          \"fallback_score\": 0.742,\n          \"sample\": \"7-fixture rig, real MiniMax dispatches (benchmark run on M2.7; contract carried to M3)\",\n          \"confidence\": \"medium\"\n        },\n        \"profile_ref\": \"sk-prompt-models/references/models/minimax-m3.md\",\n        \"status\": \"empirical\"\n      }\n    },\n    {\n      \"id\": \"mimo-v2.5-pro\",\n      \"context_length\": 1000000,\n      \"tool_calling\": \"native\",\n      \"chat_template\": \"default\",\n      \"executors\": [\n        {\n          \"executor\": \"cli-opencode\",\n          \"provider\": \"xiaomi-token-plan-ams\",\n          \"quota_pool\": \"xiaomi-token-plan\",\n          \"status\": \"active\",","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-prompt-models/assets/model_profiles.json","text":"          \"primary_score\": 0.767,\n          \"fallback_score\": 0.742,\n          \"sample\": \"7-fixture rig, real MiniMax dispatches (benchmark run on M2.7; contract carried to M3)\",\n          \"confidence\": \"medium\"\n        },\n        \"profile_ref\": \"sk-prompt-models/references/models/minimax-m3.md\",\n        \"status\": \"empirical\"\n      }\n    },\n    {\n      \"id\": \"mimo-v2.5-pro\",\n      \"context_length\": 1000000,\n      \"tool_calling\": \"native\",\n      \"chat_template\": \"default\",\n      \"executors\": [\n        {\n          \"executor\": \"cli-opencode\",\n          \"provider\": \"xiaomi-token-plan-ams\",\n          \"quota_pool\": \"xiaomi-token-plan\",\n          \"status\": \"active\",\n          \"notes\": \"Xiaomi Token Plan (Europe) via opencode provider xiaomi-token-plan-ams (credential 'Xiaomi Token Plan (Europe)'). Live slug xiaomi-token-plan-ams/mimo-v2.5-pro (confirmed responsive on opencode 1.15.13, 2026-06-01); verify the full live list with 'opencode models xiaomi-token-plan-ams'. Omit --agent (warns + falls back on 1.15.13). Manual direct-provider reroute uses xiaomi/mimo-v2.5-pro when configured; no automatic gateway fallback is defined. Context window 1,000,000 tokens (released 2026-04-22). OpenAI-compatible endpoint https://token-plan-ams.xiaomimimo.com/v1; opencode cost shows 0/0 (Token-Plan subscription). --variant maps to MiMo reasoning effort (low/medium/high) in opencode settings — always dispatch with --variant high (confirmed accepted on opencode 1.15.13). Best prompt framework (benchmark 004, 10/10 real runs): COSTAR or RACE + lean pre-planning — frame for format/brevity, not guardrails; TIDD-EC/dense ranked last; avoid CIDI (intermittent tool-only file-writes).\"\n        }\n      ],\n      \"primary_quota_pool\": \"xiaomi-token-plan\",\n      \"fallback_target\": null,\n      \"free_tier\": false,\n      \"capability\": {\n        \"model_slug\": \"xiaomi-token-plan-ams/mimo-v2.5-pro\",\n        \"default_variant\": \"high\",\n        \"variant_flag\": \"--variant\",\n        \"agent_policy\": \"omit-general\",\n        \"format_mode\": \"json\",\n        \"quota_pool\": \"xiaomi-token-plan\",\n        \"variant_status\": \"confirmed\",\n        \"notes\": \"Live slug `xiaomi-token-plan-ams/mimo-v2.5-pro` confirmed responsive on opencode 1.15.13 (2026-06-01). default_variant high: `--variant` maps to MiMo reasoning effort (low/medium/high) and `--variant high` is confirmed accepted — always dispatch with it. agent_policy omit-general: `--agent` warns and falls back on 1.15.13. format_mode json: OpenAI-compatible endpoint; dispatch via `opencode run --format json` for the normalized envelope. Manual direct-provider reroutes use `xiaomi/mimo-v2.5-pro` when configured; no automatic gateway fallback is defined.\",\n        \"modalities\": [\n          \"text\"\n        ]\n      },\n      \"strengths\": [\n        \"1,000,000-token context window (largest in the small-model rotation)\",\n        \"strongly agentic — sustains 1000+ sequential tool calls (SWE-bench Pro 57.2)\",\n        \"token-efficient — 40-60% fewer tokens/trajectory vs frontier models (Opus 4.6 / GPT-5.4)\",\n        \"Xiaomi Token Plan (Europe) subscription billing via provider xiaomi-token-plan-ams\",\n        \"separate quota pool (xiaomi-token-plan) independent of minimax / cognition pools\",\n        \"manual direct-provider reroute available at xiaomi/mimo-v2.5-pro when configured\"\n      ],\n      \"weaknesses\": [\n        \"long-context quality degrades past ~512k despite the 1M window\",\n        \"Token-Plan subscription request-window semantics unverified\",\n        \"prompt-framework benchmark 004 used 2 fixtures / single-sample — COSTAR vs RACE tie is within noise\",\n        \"visual/illustration tasks: over-accents — spreads orange/gold across most cards, weak color restraint despite clean shapes and a reserved-accent brief (informal bento bake-off, n=1 fixture, 2026-06-22; see references/models/mimo-v2.5-pro.md)\"\n      ],\n      \"avg_iter_wall_clock_min\": null,\n      \"status\": \"active\",\n      \"recommended_frameworks\": {\n        \"primary\": \"costar\",\n        \"fallback\": \"race\",\n        \"avoid\": [\n          \"tidd-ec\",\n          \"cidi\"\n        ],\n        \"preplanning_density\": \"lean\",\n        \"evidence\": {\n          \"benchmark\": \"004\",\n          \"primary_score\": 1.0,\n          \"fallback_score\": 0.9934,\n          \"sample\": \"10/10 real MiMo-V2.5-Pro runs at --variant high\",\n          \"confidence\": \"high\"\n        },\n        \"profile_ref\": \"sk-prompt-models/references/models/mimo-v2.5-pro.md\",\n        \"status\": \"empirical\"\n      }\n    },\n    {\n      \"id\": \"glm-5.2\",\n      \"context_length\": 1000000,\n      \"tool_calling\": \"native\",\n      \"chat_template\": \"default\",\n      \"executors\": [\n        {\n          \"executor\": \"cli-opencode\",\n          \"provider\": \"zai-coding-plan\",\n          \"quota_pool\": \"zai-coding-plan\",\n          \"status\": \"active\",\n          \"notes\": \"Z.AI GLM Coding Plan (subscription) via opencode provider `zai-coding-plan` (auth credential 'Z.AI Coding Plan'). Live slug `zai-coding-plan/glm-5.2`; confirmed present via `opencode models zai-coding-plan` 2026-06-28 → glm-4.5-air/glm-4.7/glm-5-turbo/glm-5.1/glm-5.2/glm-5v-turbo. Flagship long-horizon coding model (supersedes the gateway-only glm-5.1 removed in cli-opencode v1.3.15.0). context_length 1,000,000 / 131,072 output per Z.AI docs — opencode `models` did not expose limits, re-verify. Omit `--agent` at top level. GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it. Thinking is on by default and the Coding Plan endpoint preserves thinking. Re-verify the live slug before automation — Z.AI ids drift (provider also serves glm-4.7 / glm-5.1 / glm-5-turbo).\"\n        }\n      ],\n      \"primary_quota_pool\": \"zai-coding-plan\",\n      \"fallback_target\": null,\n      \"free_tier\": false,\n      \"capability\": {\n        \"model_slug\": \"zai-coding-plan/glm-5.2\",\n        \"default_variant\": \"high\",\n        \"variant_flag\": \"--variant\",\n        \"agent_policy\": \"omit-general\",\n        \"format_mode\": \"json\",\n        \"quota_pool\": \"zai-coding-plan\",\n        \"variant_status\": \"accepted-unverified\",\n        \"modalities\": [\n          \"text\",\n          \"image\"\n        ],\n        \"vision\": \"native vision-to-code; image input via the direct Z.AI Coding Plan multimodal API (base64 image_url block at https://api.z.ai/api/coding/paas/v4/chat/completions) — opencode `--file` does NOT deliver images to this provider per upstream #20802; confirmed live 2026-06-28; see references/models/glm-5.2.md §7\",\n        \"notes\": \"Live slug `zai-coding-plan/glm-5.2` confirmed present 2026-06-28 (`opencode models zai-coding-plan`). agent_policy omit-general: do not pass `--agent` at the top level. format_mode json: dispatch via `opencode run --format json` for the normalized token/cost/latency envelope. default_variant high + variant_status accepted-unverified: GLM's native `reasoning_effort` has high/max, but whether opencode `--variant high/max` forwards to it is not confirmed — smoke-test, do not depend on it. Subscription billing: confirm dispatch cost via smoke test. GLM dispatch quirks (Z.AI docs): thinking on by default + preserved thinking on the Coding Plan endpoint; function-calling `tool_choice` only `auto`; streaming tool calls need `tool_stream=true`. Re-verify slug before dispatch (Z.AI ids drift).\"\n      },\n      \"strengths\": [\n        \"dedicated Z.AI GLM Coding Plan subscription pool (`zai-coding-plan`), independent of kimi / minimax / xiaomi pools\",\n        \"flagship long-horizon coding model (Z.AI docs: Terminal-Bench 2.1 81.0, SWE-bench Pro 62.1 — both above GLM-5.1)\",\n        \"1,000,000-token context for long-file and multi-repo work (128K max output)\",\n        \"subscription billing via the Z.AI Coding Plan\",\n        \"native reasoning_effort (high/max) + thinking-by-default for complex multi-constraint coding\"\n      ],\n      \"weaknesses\": [\n        \"single executor path (no fallback if the zai-coding-plan pool is exhausted)\",\n        \"context_length / max-output recorded from Z.AI docs (1,000,000 / 131,072) — opencode `models` did not expose limits; re-verify on the install\",\n        \"--variant ↔ reasoning_effort mapping unverified (GLM has native high/max; opencode forwarding not confirmed)\",\n        \"best prompt framework is a TIE among the perfect tier (costar=tidd-ec=cidi=race at correctness 1.0); costar is best-of-tied (tersest + cross-model corroborated), not a decisive single winner — benchmark 008\",\n        \"thinking-on-by-default drives high latency variance — 6-161s observed over benchmark 008's 45 small code-gen cells (avg ~26s, ~27x spread); budget generous timeouts, a tight timeout kills the slow tail\",\n        \"~1/45 dispatches was a transient infra failure (exit -1, dispatch_failed) in benchmark 008 — expect occasional transient dispatch failures at scale; retry the cell rather than treating it as a model error\"\n      ],\n      \"avg_iter_wall_clock_min\": null,\n      \"status\": \"active\",\n      \"recommended_frameworks\": {\n        \"primary\": \"costar\",\n        \"fallback\": \"tidd-ec\",\n        \"avoid\": [\n          \"rcaf\"\n        ],\n        \"preplanning_density\": \"lean\",\n        \"evidence\": {\n          \"benchmark\": \"008-glm-5.2-prompt-framework\",\n          \"primary_score\": 1.0,\n          \"fallback_score\": 1.0,\n          \"sample\": \"5-framework bakeoff on invalid-dominant STRICT VALIDATORS (validate-ipv4 + validate-date + validate-semver), 3 samples/cell, real zai-coding-plan/glm-5.2 dispatches graded by the deterministic hidden-test oracle (grader noop, no LLM-judge bias). Run status SEPARABLE: per-framework correctness costar 1.0 = tidd-ec 1.0 = cidi 1.0 = race 1.0 (perfect tier) > rcaf 0.976 (the ONLY sub-perfect framework; also worst format adherence 0.889). Trust verdict TIE on correctness among the perfect tier (top-pair costar vs tidd-ec, margin 0, 90% CI [0,0]). costar is primary as best-of-tied: perfect correctness + tersest output (13 median words vs tidd-ec 38, cidi/race 94) + cross-model corroboration (also the empirical winner for kimi benchmark 007 and mimo benchmark 004). tidd-ec fallback (perfect, 2nd-tersest). rcaf avoided (only correctness misses + worst format). NOTE: CRAFT (the phase-1 doc-guided default) is NOT in the harness framework registry [rcaf,race,cidi,tidd-ec,costar] so it could not be benchmarked; the empirical winner among the 5 supported frameworks replaces it. 1/45 dispatches was a transient infra failure (exit -1, excluded from scoring).\",\n          \"confidence\": \"medium\"\n        },\n        \"profile_ref\": \"sk-prompt-models/references/models/glm-5.2.md\",\n        \"status\": \"empirical\"\n      }\n    },\n    {\n      \"id\": \"haiku\",\n      \"context_length\": null,\n      \"tool_calling\": \"native\",\n      \"chat_template\": \"default\",\n      \"executors\": [\n        {\n          \"executor\": \"cli-claude-code\",\n          \"provider\": \"anthropic\",\n          \"quota_pool\": \"anthropic\",\n          \"status\": \"optional-unverified\",\n          \"notes\": \"Future small-model fallback candidate. Adoption blocked until quota-pool semantics verified.\"\n        }\n      ],\n      \"primary_quota_pool\": \"anthropic\",\n      \"fallback_target\": null,\n      \"free_tier\": false,\n      \"strengths\": [\n        \"separate quota pool\",\n        \"fast natural-language synthesis\",\n        \"future fallback candidate\"\n      ],\n      \"weaknesses\": [\n        \"not in active rotation\",\n        \"unverified for this workflow\",\n        \"requires adoption before routing\"\n      ],\n      \"avg_iter_wall_clock_min\": null,\n      \"status\": \"optional-unverified\"","lineStart":180,"lineEnd":349,"totalLines":352,"truncated":true}},"title":".opencode/skills/sk-prompt-models/assets/model_profiles.json","time":{"start":1783487488826,"end":1783487488829}},"metadata":{"openai":{"itemId":"fc_06ccffdfe16e3f8d016a4ddc00b2208193830cb609fe97d1b2"}},"id":"prt_f4023631b001qdWS4CyD87s2jp","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f40233fe7001z33DiuVDsuOhb1"}}
{"type":"tool_use","timestamp":1783487488836,"sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","part":{"type":"tool","tool":"read","callID":"call_fKUddNHZDRmlMLrJe7G3dWjg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/SKILL.md","offset":190,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/SKILL.md</path>\n<type>file</type>\n<content>\n190: \n191: # Self-invocation guard\n192: env | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n193: \n194: # Authentication — providers configured via opencode providers (alias auth)\n195: opencode providers\n196: ```\n197: \n198: **Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans) for OAuth and API key flows. Configured providers on a typical install: `deepseek` (api, DEFAULT), `minimax-coding-plan` (MiniMax Token Plan subscription — **DEFAULT MiniMax path**; `opencode auth login`; model `minimax-coding-plan/MiniMax-M3`), `minimax` (MiniMax Direct API, pay-per-token — `opencode providers login minimax`; model `minimax/MiniMax-M3`), `xiaomi` (Xiaomi Direct API, pay-per-token — `opencode providers login xiaomi`; models `xiaomi/mimo-v2.5-pro` and the low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe; `opencode auth login`; model `xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), `openai` (api, premium alternative for `gpt-5.5`/`gpt-5.5-pro`/`gpt-5.5-fast`).\n199: \n200: ### Provider Auth Pre-Flight (Smart Fallback)\n201: \n202: **MANDATORY before any first dispatch in a session.** The default provider may not be logged in on this machine — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run this check once per session, cache the result, and re-run it only if a dispatch fails with an auth error.\n203: \n204: ```bash\n205: # One-shot pre-flight: list configured providers, capture for routing\n206: PROVIDERS=$(opencode providers list 2>&1)\n207: echo \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\n208: echo \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\n209: echo \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\n210: echo \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\n211: echo \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\n212: echo \"$PROVIDERS\" | grep -q \"openai\"              && OPENAI_OK=1         || OPENAI_OK=0\n213: ```\n214: \n215: **Decision tree** (apply in order — first match wins):\n216: \n217: | State | DEEPSEEK_OK | OPENAI_OK | Action |\n218: |-------|-------------|-----------|--------|\n219: | Default available | 1 | * | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n220: | Default missing, openai ready | 0 | 1 | **ASK user** before substituting to OpenAI — surface options A/B/C/D below; OpenAI is a paid premium fallback. |\n221: | All missing | 0 | 0 | **ASK user** to configure a provider — surface the login commands, do NOT dispatch. |\n222: \n223: **MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative — first match wins):\n224: \n225: | State | Condition | Action |\n226: |-------|-----------|--------|\n227: | MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n228: | Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n229: | Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n230: | Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to run `opencode providers login minimax` (needs `MINIMAX_API_KEY`) — never substitute silently |\n231: \n232: **MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n233: \n234: | State | Condition | Action |\n235: |-------|-----------|--------|\n236: | MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro --variant high` (high reasoning is the standing default — opencode maps low/medium/high to MiMo's reasoning effort) — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13); confirm the live id via `opencode models xiaomi` |\n237: | MiMo speed variant requested (\"ultraspeed\", latency-sensitive checks/smokes) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed --variant high` — low-latency MiMo-V2.5-Pro serving tier, same COSTAR prompt contract as the standard model |\n238: | Direct API not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n239: | Token Plan explicitly requested | `XIAOMI_OK=1` | Proceed with `--model xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n240: | Token Plan requested, not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n241: \n242: **User prompt template — default missing, fallback configured:**\n243: \n244: ```\n245: The skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\n246: A configured fallback is available. Pick one:\n247:   A) Use `openai/gpt-5.5-pro --variant high` (OpenAI premium, configured now — paid)\n248:   B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n249:   C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n250:   D) Run `opencode providers login deepseek` first, then retry the original dispatch\n251:   E) Name a different model — paste the `--model <provider/model>` you want to use\n252: ```\n253: \n254: **User prompt template — all providers missing:**\n255: \n256: ```\n257: No supported providers are configured on this machine. Run one:\n258:   - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n259:   - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n260:   - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n261:   - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n262:   - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n263:   - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n264:   - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n265:   - `opencode providers login openai`       (OpenAI premium alternative — paid)\n266: Which would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n267: ```\n268: \n269: **Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n270: \n271: ### Default Invocation (Skill Default)\n272: \n273: **Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>`. The repo root pin avoids CWD ambiguity. Direct DeepSeek is the default provider — it gives elevated reasoning at low cost for routine cli-opencode dispatches.\n274: \n275: Use `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n276: \n277: > **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run`. Current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails the dispatch outright. When no `--agent` is given, the default agent runs — which is what you want for almost every dispatch. **To run as a specific agent profile, describe the role in the prompt body** (for example, open the prompt with \"Act as a code-review agent: …\"), not via `--agent`. Only pass `--agent <name>` if you have confirmed against `opencode run --help` on the installed version that it accepts that agent at the top level.\n278: \n279: Honor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n280: \n281: ### Core Invocation Pattern\n282: \n283: Core flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n284: \n285: > **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation. Without it, opencode can inherit parent-terminal stdin and trigger the reactive-EOF exit path when that stream closes. See `references/integration_patterns.md` §6.\n286: \n287: > **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text to the model as raw prose, and the command template (router contract, presentation assets, MUST-render envelopes) never enters the session. To execute a registered command non-interactively: `opencode run --command <family>/<name> [flags] \"<args>\"` — the message becomes `$ARGUMENTS`. Registry names are slash-namespaced: `memory/search` for `/memory:search` (a wrong `--command` name fails with the full registry list). Verified on opencode 1.17.4. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n288: \n289: ### Model Selection\n290: \n291: Run `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default to `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API); the MiniMax Token Plan default `minimax-coding-plan/MiniMax-M3` (omit `--agent`), the pay-per-token `minimax/MiniMax-M3` (Direct API), `xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` (Xiaomi Token Plan Europe — MiMo; high reasoning preset; omit `--agent`), `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API — MiMo; pay-per-token) and `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` (low-latency MiMo tier, same prompt contract) remain available. The Kimi For Coding plan model `kimi-for-coding/k2p7` (\"Kimi K2.7 Code\"; 256k / 262,144-token context; subscription billing — dispatch cost 0; omit `--agent`; `--variant high` accepted but effect benchmark-unverified) is the coding-optimized large-context Kimi path. **Operational caveat (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`. The Z.AI GLM Coding Plan model `zai-coding-plan/glm-5.2` (\"GLM-5.2\"; flagship long-horizon coding; 1,000,000-token context / 131,072 output per Z.AI docs; subscription billing; omit `--agent`; `--variant`↔`reasoning_effort` mapping unverified — GLM has native high/max, smoke-test before relying on it; thinking on by default + preserved on the Coding Plan endpoint) is the Z.AI direct-provider GLM path, superseding the gateway-only `glm-5.1` removed in v1.3.15.0; confirm the live slug via `opencode models zai-coding-plan`. **Operational (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45... (line truncated to 2000 chars)\n292: \n293: Shared small-model facts, context defaults, quota pools, and fallback targets live in `../sk-prompt-models/assets/model_profiles.json`.\n294: \n295: ### OpenCode Agent Delegation\n296: \n297: The calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n298: \n299: #### Primary agents — directly invokable via `--agent`\n300: \n301: OpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Caveat — never pass `--agent general`:** the current opencode treats `general` as a subagent and rejects it at the top level, and the default agent (used when no `--agent` is given) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` on the installed version confirms top-level acceptance; otherwise state the role in the prompt body.\n302: \n303: #### Subagents — dispatched as Task subagents from a primary\n304: \n305: These live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n306: \n307: 1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by a primary (`orchestrate`) using the Task tool. To exercise via the opencode CLI, route through `--agent orchestrate` and let it dispatch the relevant subagent.\n308: 2. **`ai-council`** — dispatched either via its own `/deep:ai-council` command or via `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`); route through `/deep:ai-council` or `--agent orchestrate` with an ai-council-shaped prompt.\n309: 3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>` from the CLI. `orchestrate` is an authorized **caller/coordinator only** for these agents (e.g. its registry-backed `/deep:review` Priority row) — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop (no iterating, no convergence checks, no continuity tracking); that remains the parent command's job.\n\n(Showing lines 190-309 of 459. Use offset=310 to continue.)\n</content>","metadata":{"preview":"\n# Self-invocation guard\nenv | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n\n# Authentication — providers configured via opencode providers (alias auth)\nopencode providers\n```\n\n**Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans) for OAuth and API key flows. Configured providers on a typical install: `deepseek` (api, DEFAULT), `minimax-coding-plan` (MiniMax Token Plan subscription — **DEFAULT MiniMax path**; `opencode auth login`; model `minimax-coding-plan/MiniMax-M3`), `minimax` (MiniMax Direct API, pay-per-token — `opencode providers login minimax`; model `minimax/MiniMax-M3`), `xiaomi` (Xiaomi Direct API, pay-per-token — `opencode providers login xiaomi`; models `xiaomi/mimo-v2.5-pro` and the low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe; `opencode auth login`; model `xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), `openai` (api, premium alternative for `gpt-5.5`/`gpt-5.5-pro`/`gpt-5.5-fast`).\n\n### Provider Auth Pre-Flight (Smart Fallback)\n\n**MANDATORY before any first dispatch in a session.** The default provider may not be logged in on this machine — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run this check once per session, cache the result, and re-run it only if a dispatch fails with an auth error.\n\n```bash\n# One-shot pre-flight: list configured providers, capture for routing\nPROVIDERS=$(opencode providers list 2>&1)\necho \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\necho \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\necho \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/SKILL.md","text":"\n# Self-invocation guard\nenv | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n\n# Authentication — providers configured via opencode providers (alias auth)\nopencode providers\n```\n\n**Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans) for OAuth and API key flows. Configured providers on a typical install: `deepseek` (api, DEFAULT), `minimax-coding-plan` (MiniMax Token Plan subscription — **DEFAULT MiniMax path**; `opencode auth login`; model `minimax-coding-plan/MiniMax-M3`), `minimax` (MiniMax Direct API, pay-per-token — `opencode providers login minimax`; model `minimax/MiniMax-M3`), `xiaomi` (Xiaomi Direct API, pay-per-token — `opencode providers login xiaomi`; models `xiaomi/mimo-v2.5-pro` and the low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe; `opencode auth login`; model `xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), `openai` (api, premium alternative for `gpt-5.5`/`gpt-5.5-pro`/`gpt-5.5-fast`).\n\n### Provider Auth Pre-Flight (Smart Fallback)\n\n**MANDATORY before any first dispatch in a session.** The default provider may not be logged in on this machine — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run this check once per session, cache the result, and re-run it only if a dispatch fails with an auth error.\n\n```bash\n# One-shot pre-flight: list configured providers, capture for routing\nPROVIDERS=$(opencode providers list 2>&1)\necho \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\necho \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\necho \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\necho \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\necho \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\necho \"$PROVIDERS\" | grep -q \"openai\"              && OPENAI_OK=1         || OPENAI_OK=0\n```\n\n**Decision tree** (apply in order — first match wins):\n\n| State | DEEPSEEK_OK | OPENAI_OK | Action |\n|-------|-------------|-----------|--------|\n| Default available | 1 | * | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n| Default missing, openai ready | 0 | 1 | **ASK user** before substituting to OpenAI — surface options A/B/C/D below; OpenAI is a paid premium fallback. |\n| All missing | 0 | 0 | **ASK user** to configure a provider — surface the login commands, do NOT dispatch. |\n\n**MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n| Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n| Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n| Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to run `opencode providers login minimax` (needs `MINIMAX_API_KEY`) — never substitute silently |\n\n**MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro --variant high` (high reasoning is the standing default — opencode maps low/medium/high to MiMo's reasoning effort) — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13); confirm the live id via `opencode models xiaomi` |\n| MiMo speed variant requested (\"ultraspeed\", latency-sensitive checks/smokes) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed --variant high` — low-latency MiMo-V2.5-Pro serving tier, same COSTAR prompt contract as the standard model |\n| Direct API not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n| Token Plan explicitly requested | `XIAOMI_OK=1` | Proceed with `--model xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n| Token Plan requested, not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n\n**User prompt template — default missing, fallback configured:**\n\n```\nThe skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\nA configured fallback is available. Pick one:\n  A) Use `openai/gpt-5.5-pro --variant high` (OpenAI premium, configured now — paid)\n  B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n  C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n  D) Run `opencode providers login deepseek` first, then retry the original dispatch\n  E) Name a different model — paste the `--model <provider/model>` you want to use\n```\n\n**User prompt template — all providers missing:**\n\n```\nNo supported providers are configured on this machine. Run one:\n  - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n  - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n  - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n  - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n  - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n  - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n  - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n  - `opencode providers login openai`       (OpenAI premium alternative — paid)\nWhich would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n```\n\n**Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n### Default Invocation (Skill Default)\n\n**Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>`. The repo root pin avoids CWD ambiguity. Direct DeepSeek is the default provider — it gives elevated reasoning at low cost for routine cli-opencode dispatches.\n\nUse `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n\n> **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run`. Current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails the dispatch outright. When no `--agent` is given, the default agent runs — which is what you want for almost every dispatch. **To run as a specific agent profile, describe the role in the prompt body** (for example, open the prompt with \"Act as a code-review agent: …\"), not via `--agent`. Only pass `--agent <name>` if you have confirmed against `opencode run --help` on the installed version that it accepts that agent at the top level.\n\nHonor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n\n### Core Invocation Pattern\n\nCore flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n\n> **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation. Without it, opencode can inherit parent-terminal stdin and trigger the reactive-EOF exit path when that stream closes. See `references/integration_patterns.md` §6.\n\n> **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text to the model as raw prose, and the command template (router contract, presentation assets, MUST-render envelopes) never enters the session. To execute a registered command non-interactively: `opencode run --command <family>/<name> [flags] \"<args>\"` — the message becomes `$ARGUMENTS`. Registry names are slash-namespaced: `memory/search` for `/memory:search` (a wrong `--command` name fails with the full registry list). Verified on opencode 1.17.4. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n\n### Model Selection\n\nRun `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default to `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API); the MiniMax Token Plan default `minimax-coding-plan/MiniMax-M3` (omit `--agent`), the pay-per-token `minimax/MiniMax-M3` (Direct API), `xiaomi-token-plan-ams/mimo-v2.5-pro --variant high` (Xiaomi Token Plan Europe — MiMo; high reasoning preset; omit `--agent`), `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API — MiMo; pay-per-token) and `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` (low-latency MiMo tier, same prompt contract) remain available. The Kimi For Coding plan model `kimi-for-coding/k2p7` (\"Kimi K2.7 Code\"; 256k / 262,144-token context; subscription billing — dispatch cost 0; omit `--agent`; `--variant high` accepted but effect benchmark-unverified) is the coding-optimized large-context Kimi path. **Operational caveat (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`. The Z.AI GLM Coding Plan model `zai-coding-plan/glm-5.2` (\"GLM-5.2\"; flagship long-horizon coding; 1,000,000-token context / 131,072 output per Z.AI docs; subscription billing; omit `--agent`; `--variant`↔`reasoning_effort` mapping unverified — GLM has native high/max, smoke-test before relying on it; thinking on by default + preserved on the Coding Plan endpoint) is the Z.AI direct-provider GLM path, superseding the gateway-only `glm-5.1` removed in v1.3.15.0; confirm the live slug via `opencode models zai-coding-plan`. **Operational (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45... (line truncated to 2000 chars)\n\nShared small-model facts, context defaults, quota pools, and fallback targets live in `../sk-prompt-models/assets/model_profiles.json`.\n\n### OpenCode Agent Delegation\n\nThe calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n\n#### Primary agents — directly invokable via `--agent`\n\nOpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Caveat — never pass `--agent general`:** the current opencode treats `general` as a subagent and rejects it at the top level, and the default agent (used when no `--agent` is given) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` on the installed version confirms top-level acceptance; otherwise state the role in the prompt body.\n\n#### Subagents — dispatched as Task subagents from a primary\n\nThese live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n\n1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by a primary (`orchestrate`) using the Task tool. To exercise via the opencode CLI, route through `--agent orchestrate` and let it dispatch the relevant subagent.\n2. **`ai-council`** — dispatched either via its own `/deep:ai-council` command or via `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`); route through `/deep:ai-council` or `--agent orchestrate` with an ai-council-shaped prompt.\n3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>` from the CLI. `orchestrate` is an authorized **caller/coordinator only** for these agents (e.g. its registry-backed `/deep:review` Priority row) — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop (no iterating, no convergence checks, no continuity tracking); that remains the parent command's job.","lineStart":190,"lineEnd":309,"totalLines":459,"truncated":true}},"title":".opencode/skills/cli-opencode/SKILL.md","time":{"start":1783487488831,"end":1783487488835}},"metadata":{"openai":{"itemId":"fc_06ccffdfe16e3f8d016a4ddc00b22c819387b3dc4c01dd1fab"}},"id":"prt_f4023633b001Gz5sXBhJLUcJB0","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f40233fe7001z33DiuVDsuOhb1"}}
{"type":"tool_use","timestamp":1783487488845,"sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","part":{"type":"tool","tool":"read","callID":"call_TPFGgBQZFtWJQ3IddxB7G0hs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/references/cli_reference.md","offset":190,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/references/cli_reference.md</path>\n<type>file</type>\n<content>\n190: |-------|-----------|--------|\n191: | MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n192: | Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n193: | Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n194: | Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n195: \n196: **MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n197: \n198: | State | Condition | Action |\n199: |-------|-----------|--------|\n200: | MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n201: | MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n202: | Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n203: | Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n204: | Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n205: | Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n206: \n207: **Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n208: \n209: ```bash\n210: # Recommended default — direct DeepSeek API\n211: opencode providers login deepseek\n212: \n213: # MiniMax Token Plan — DEFAULT MiniMax path (subscription). Interactive: pick \"MiniMax Token Plan (minimax.io)\".\n214: opencode auth login          # → provider minimax-coding-plan; Anthropic-compatible https://api.minimax.io/anthropic/v1 (China: api.minimaxi.com)\n215: \n216: # MiniMax Direct API — pay-per-token alternative (needs MINIMAX_API_KEY; platform endpoint https://api.minimax.io/v1)\n217: opencode providers login minimax\n218: \n219: # Xiaomi Token Plan (Europe) — provider-managed endpoint. Interactive: pick \"Xiaomi Token Plan (Europe)\".\n220: opencode auth login          # → provider xiaomi-token-plan-ams (Xiaomi Token Plan, Europe)\n221: \n222: # Xiaomi Direct API — pay-per-token alternative\n223: opencode providers login xiaomi\n224: \n225: # Z.AI GLM Coding Plan — GLM coding subscription. Interactive: pick \"Z.AI Coding Plan\".\n226: opencode auth login          # → provider zai-coding-plan; model zai-coding-plan/glm-5.2\n227: ```\n228: \n229: > Do not mix region endpoints (international `minimax.io` vs China `minimaxi.com`). Confirm live model ids with `opencode models minimax-coding-plan`. The Xiaomi endpoint is provider-managed (no documented base URL — do not invent one); confirm live model ids with `opencode models xiaomi-token-plan-ams` (Token Plan) or `opencode models xiaomi` (Direct API).\n230: \n231: **On auth-error mid-dispatch** (`401 Unauthorized`, `provider/model not found`): invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n232: \n233: ---\n234: \n235: ## 5. MODEL SELECTION\n236: \n237: OpenCode resolves models through configured providers. The cli-opencode skill supports `deepseek` (default), `minimax-coding-plan` (MiniMax Token Plan — default MiniMax path), `minimax` (MiniMax Direct API — pay-per-token alternative), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe — MiMo, explicitly-selectable; NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), and `xiaomi` (Xiaomi Direct API — MiMo: `xiaomi/mimo-v2.5-pro` + low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`, pay-per-token) — confirmed against `opencode providers list` and `opencode models`. Run `opencode models [provider]` for the full live list on a given install.\n238: \n239: | Provider | Example model id | Use case |\n240: |----------|------------------|----------|\n241: | `deepseek` (DEFAULT) | `deepseek/deepseek-v4-pro` | Default — deep reasoning at low cost via direct DeepSeek API |\n242: | `deepseek` | `deepseek/deepseek-v4-flash` | Latency-optimized direct-API sibling |\n243: | `kimi-for-coding` | `kimi-for-coding/k2p7` | Long-context Kimi K2.7 Code (256k; subscription plan) |\n244: | `zai-coding-plan` | `zai-coding-plan/glm-5.2` | Z.AI GLM Coding Plan — GLM-5.2 flagship long-horizon coding (1M context; subscription); omit `--agent`; verify with `opencode models zai-coding-plan` |\n245: | `minimax-coding-plan` (DEFAULT MiniMax) | `minimax-coding-plan/MiniMax-M3` | MiniMax Token Plan (subscription) — default MiniMax dispatch; omit `--agent`; verify with `opencode models minimax-coding-plan` |\n246: | `minimax` | `minimax/MiniMax-M3` | MiniMax Direct API — pay-per-token alternative; needs `MINIMAX_API_KEY`; confirm the live id via `opencode models minimax` |\n247: | `xiaomi-token-plan-ams` | `xiaomi-token-plan-ams/mimo-v2.5-pro` | Xiaomi Token Plan (Europe) — MiMo-V2.5-Pro: 1M-token context, strongly agentic (1000+ tool calls), token-efficient; omit `--agent`; verify with `opencode models xiaomi-token-plan-ams` |\n248: | `xiaomi` | `xiaomi/mimo-v2.5-pro` | Xiaomi Direct API — pay-per-token; MiMo-V2.5-Pro; confirm the live id via `opencode models xiaomi` |\n249: \n250: `opencode models <provider>` lists every model id the provider exposes. The model string passed to `--model` is always `provider/model-id`.\n251: \n252: ### Reasoning effort via `--variant`\n253: \n254: The `--variant` flag maps to provider-specific reasoning effort. Underlying-model conventions apply per provider routing.\n255: \n256: | Provider | Variant values |\n257: |----------|----------------|\n258: | `deepseek` (`deepseek-v4-pro`) | reasoning effort accepted |\n259: | `deepseek` (`deepseek-v4-flash`) | non-reasoning — `--variant` ignored |\n260: | `minimax-coding-plan` / `minimax` (MiniMax-M3) | `--variant` behavior unverified — omitted by default; confirm against the MiniMax API before relying on it |\n261: | `xiaomi-token-plan-ams` (mimo-v2.5-pro) | `--variant` maps to MiMo reasoning effort (low/medium/high); **always use `--variant high`** (confirmed accepted on opencode 1.15.13) |\n262: | `zai-coding-plan` (glm-5.2) | GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it |\n263: | `openai` (`gpt-5.5` / `gpt-5.5-fast` / `gpt-5.5-pro`) | `--variant` maps to OpenAI reasoning effort: `none`/`low`/`medium`/`high`/**`xhigh`** (`gpt-5.5-pro`: `medium`/`high`/`xhigh`). **`openai/gpt-5.5-fast`** is the low-latency **Fast** variant (OpenAI `priority` service tier) with the same effort range — e.g. `--model openai/gpt-5.5-fast --variant xhigh`. The cache lists it as `gpt-5.5` + `experimental.modes:['fast']`, but `opencode models openai` resolves the `openai/gpt-5.5-fast` slug directly. |\n264: \n265: Default skill behavior: pass `--variant high` for cross-AI dispatches. Operators may override via the prompt template's variant field.\n266: \n267: ---\n268: \n269: ## 6. AGENT FLAG\n270: \n271: `--agent <slug>` loads an agent definition from `.opencode/agents/<slug>.md` (project-local) or the user-level fallback. The agent definition's frontmatter pins the model, tool permissions, and system prompt that shape the dispatch.\n272: \n273: ### Discovering agents\n274: \n275: | Command | What it shows |\n276: |---------|---------------|\n277: | `opencode agent list` | All registered agent slugs across project + user scopes |\n278: | `opencode debug agent <slug>` | Resolved frontmatter and system prompt for a slug |\n279: | `opencode debug skill <slug>` | Skill resolution for a slug if the agent loads one |\n\n(Showing lines 190-279 of 379. Use offset=280 to continue.)\n</content>","metadata":{"preview":"|-------|-----------|--------|\n| MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n| Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n| Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n| Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n\n**MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n| MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n| Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n| Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n| Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n| Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n\n**Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n\n```bash","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-opencode/references/cli_reference.md","text":"|-------|-----------|--------|\n| MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n| Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n| Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n| Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n\n**MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n| MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n| Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n| Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n| Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n| Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n\n**Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n\n```bash\n# Recommended default — direct DeepSeek API\nopencode providers login deepseek\n\n# MiniMax Token Plan — DEFAULT MiniMax path (subscription). Interactive: pick \"MiniMax Token Plan (minimax.io)\".\nopencode auth login          # → provider minimax-coding-plan; Anthropic-compatible https://api.minimax.io/anthropic/v1 (China: api.minimaxi.com)\n\n# MiniMax Direct API — pay-per-token alternative (needs MINIMAX_API_KEY; platform endpoint https://api.minimax.io/v1)\nopencode providers login minimax\n\n# Xiaomi Token Plan (Europe) — provider-managed endpoint. Interactive: pick \"Xiaomi Token Plan (Europe)\".\nopencode auth login          # → provider xiaomi-token-plan-ams (Xiaomi Token Plan, Europe)\n\n# Xiaomi Direct API — pay-per-token alternative\nopencode providers login xiaomi\n\n# Z.AI GLM Coding Plan — GLM coding subscription. Interactive: pick \"Z.AI Coding Plan\".\nopencode auth login          # → provider zai-coding-plan; model zai-coding-plan/glm-5.2\n```\n\n> Do not mix region endpoints (international `minimax.io` vs China `minimaxi.com`). Confirm live model ids with `opencode models minimax-coding-plan`. The Xiaomi endpoint is provider-managed (no documented base URL — do not invent one); confirm live model ids with `opencode models xiaomi-token-plan-ams` (Token Plan) or `opencode models xiaomi` (Direct API).\n\n**On auth-error mid-dispatch** (`401 Unauthorized`, `provider/model not found`): invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n---\n\n## 5. MODEL SELECTION\n\nOpenCode resolves models through configured providers. The cli-opencode skill supports `deepseek` (default), `minimax-coding-plan` (MiniMax Token Plan — default MiniMax path), `minimax` (MiniMax Direct API — pay-per-token alternative), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe — MiMo, explicitly-selectable; NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), and `xiaomi` (Xiaomi Direct API — MiMo: `xiaomi/mimo-v2.5-pro` + low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`, pay-per-token) — confirmed against `opencode providers list` and `opencode models`. Run `opencode models [provider]` for the full live list on a given install.\n\n| Provider | Example model id | Use case |\n|----------|------------------|----------|\n| `deepseek` (DEFAULT) | `deepseek/deepseek-v4-pro` | Default — deep reasoning at low cost via direct DeepSeek API |\n| `deepseek` | `deepseek/deepseek-v4-flash` | Latency-optimized direct-API sibling |\n| `kimi-for-coding` | `kimi-for-coding/k2p7` | Long-context Kimi K2.7 Code (256k; subscription plan) |\n| `zai-coding-plan` | `zai-coding-plan/glm-5.2` | Z.AI GLM Coding Plan — GLM-5.2 flagship long-horizon coding (1M context; subscription); omit `--agent`; verify with `opencode models zai-coding-plan` |\n| `minimax-coding-plan` (DEFAULT MiniMax) | `minimax-coding-plan/MiniMax-M3` | MiniMax Token Plan (subscription) — default MiniMax dispatch; omit `--agent`; verify with `opencode models minimax-coding-plan` |\n| `minimax` | `minimax/MiniMax-M3` | MiniMax Direct API — pay-per-token alternative; needs `MINIMAX_API_KEY`; confirm the live id via `opencode models minimax` |\n| `xiaomi-token-plan-ams` | `xiaomi-token-plan-ams/mimo-v2.5-pro` | Xiaomi Token Plan (Europe) — MiMo-V2.5-Pro: 1M-token context, strongly agentic (1000+ tool calls), token-efficient; omit `--agent`; verify with `opencode models xiaomi-token-plan-ams` |\n| `xiaomi` | `xiaomi/mimo-v2.5-pro` | Xiaomi Direct API — pay-per-token; MiMo-V2.5-Pro; confirm the live id via `opencode models xiaomi` |\n\n`opencode models <provider>` lists every model id the provider exposes. The model string passed to `--model` is always `provider/model-id`.\n\n### Reasoning effort via `--variant`\n\nThe `--variant` flag maps to provider-specific reasoning effort. Underlying-model conventions apply per provider routing.\n\n| Provider | Variant values |\n|----------|----------------|\n| `deepseek` (`deepseek-v4-pro`) | reasoning effort accepted |\n| `deepseek` (`deepseek-v4-flash`) | non-reasoning — `--variant` ignored |\n| `minimax-coding-plan` / `minimax` (MiniMax-M3) | `--variant` behavior unverified — omitted by default; confirm against the MiniMax API before relying on it |\n| `xiaomi-token-plan-ams` (mimo-v2.5-pro) | `--variant` maps to MiMo reasoning effort (low/medium/high); **always use `--variant high`** (confirmed accepted on opencode 1.15.13) |\n| `zai-coding-plan` (glm-5.2) | GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it |\n| `openai` (`gpt-5.5` / `gpt-5.5-fast` / `gpt-5.5-pro`) | `--variant` maps to OpenAI reasoning effort: `none`/`low`/`medium`/`high`/**`xhigh`** (`gpt-5.5-pro`: `medium`/`high`/`xhigh`). **`openai/gpt-5.5-fast`** is the low-latency **Fast** variant (OpenAI `priority` service tier) with the same effort range — e.g. `--model openai/gpt-5.5-fast --variant xhigh`. The cache lists it as `gpt-5.5` + `experimental.modes:['fast']`, but `opencode models openai` resolves the `openai/gpt-5.5-fast` slug directly. |\n\nDefault skill behavior: pass `--variant high` for cross-AI dispatches. Operators may override via the prompt template's variant field.\n\n---\n\n## 6. AGENT FLAG\n\n`--agent <slug>` loads an agent definition from `.opencode/agents/<slug>.md` (project-local) or the user-level fallback. The agent definition's frontmatter pins the model, tool permissions, and system prompt that shape the dispatch.\n\n### Discovering agents\n\n| Command | What it shows |\n|---------|---------------|\n| `opencode agent list` | All registered agent slugs across project + user scopes |\n| `opencode debug agent <slug>` | Resolved frontmatter and system prompt for a slug |\n| `opencode debug skill <slug>` | Skill resolution for a slug if the agent loads one |","lineStart":190,"lineEnd":279,"totalLines":379,"truncated":true}},"title":".opencode/skills/cli-opencode/references/cli_reference.md","time":{"start":1783487488841,"end":1783487488844}},"metadata":{"openai":{"itemId":"fc_06ccffdfe16e3f8d016a4ddc00b2348193a556cea2f03d701d"}},"id":"prt_f40236340001BHvm6gp65Lu8Ck","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f40233fe7001z33DiuVDsuOhb1"}}
{"type":"tool_use","timestamp":1783487488864,"sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","part":{"type":"tool","tool":"read","callID":"call_q1Egu0obfKro4vVzJhJg1GBI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/references/integration_points.md","offset":90,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/references/integration_points.md</path>\n<type>file</type>\n<content>\n90: - `system-code-graph/feature_catalog/05--coverage-graph/deep-loop-graph-convergence.md` points to `scripts/convergence.cjs`.\n91: \n92: ---\n93: \n94: ## 6. SYSTEM-SPEC-KIT TEST DISCOVERY\n95: \n96: The runtime tests are discovered from the system-spec-kit MCP server Vitest config:\n97: \n98: ```text\n99: .opencode/skills/system-spec-kit/mcp_server/vitest.config.ts\n100:   '../deep-loop-runtime/tests/**/*.{vitest,test}.ts'\n101: ```\n102: \n103: Production imports resolve from this skill's own `node_modules` via bare specifiers — no reach-in to a sibling skill's installed packages:\n104: \n105: - `executor-config.ts` and `prompt-pack.ts` import `zod` (declared in this skill's `package.json`).\n106: - `coverage-graph-db.ts`, `coverage-graph-signals.ts`, and `council/council-graph-db.ts` import `better-sqlite3` (declared here; pinned to the same version `system-spec-kit` uses so the native binding stays ABI-compatible).\n107: - The `*.cjs` scripts boot the tsx loader through `require.resolve('tsx')`, which resolves from this skill's own `node_modules`.\n108: \n109: The dependency versions are kept in lockstep with `system-spec-kit` (see `package.json`), which is why graph metadata still lists `system-spec-kit` under `depends_on`. The standalone suite runs via `npm test` (local `vitest.config.ts`); the combined CI run still discovers these tests through the `system-spec-kit` MCP server config above.\n110: \n111: ---\n112: \n113: ## 7. DIRECT OPERATOR CALLS\n114: \n115: ### Status\n116: \n117: ```bash\n118: node .opencode/skills/deep-loop-runtime/scripts/status.cjs \\\n119:   --spec-folder \".opencode/specs/example\" \\\n120:   --loop-type review \\\n121:   --session-id example-session\n122: ```\n123: \n124: ### Query\n125: \n126: ```bash\n127: node .opencode/skills/deep-loop-runtime/scripts/query.cjs \\\n128:   --spec-folder \".opencode/specs/example\" \\\n129:   --loop-type review \\\n130:   --session-id example-session \\\n131:   --query-type coverage_gaps\n132: ```\n133: \n134: ### Upsert\n135: \n136: ```bash\n137: node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs \\\n138:   --spec-folder \".opencode/specs/example\" \\\n139:   --loop-type review \\\n140:   --session-id example-session \\\n141:   --nodes '[{\"id\":\"dim-correctness\",\"kind\":\"DIMENSION\",\"name\":\"Correctness\"}]' \\\n142:   --edges '[]'\n143: ```\n144: \n145: ### Convergence\n146: \n147: ```bash\n148: node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs \\\n149:   --spec-folder \".opencode/specs/example\" \\\n150:   --loop-type review \\\n151:   --session-id example-session \\\n152:   --iteration 3 \\\n153:   --persist-snapshot true\n154: ```\n155: \n156: ---\n157: \n158: ## 7.1 ADDITIONAL CONSUMERS\n159: \n160: The following consumers were surfaced by a deep-research audit and were absent from §2-§7 above:\n161: \n162: | # | Consumer | Path | Integration Shape |\n163: |---|----------|------|-------------------|\n164: | 1 | `/deep:ai-council` command | `.opencode/commands/deep/assets/deep_ai-council_{auto,confirm}.yaml` | Loads 3 `lib/council/*.cjs` modules via require() for multi-seat dispatch + round-state JSONL + adjudicator scoring |\n165: | 2 | `deep-ai-council` orchestration | `.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/orchestrate-{session,topic}.cjs` | 8 require() calls across all 5 `lib/council/*.cjs` modules |\n166: | 3 | `/doctor` route manifest | `.opencode/commands/doctor/_routes.yaml:88-104` | gate3_location + 4 script_invocations + 4 trigger_phrases routing operator commands to deep-loop-runtime scripts |\n167: | 4 | `/doctor` update command | `.opencode/commands/doctor/update.md:28, :220, :272` | References deep-loop scripts plus the `.pre-doctor-update.*.bak` backup-pattern reads |\n168: | 5 | `system-code-graph` playbook | `.opencode/skills/system-code-graph/manual_testing_playbook/05--coverage-graph/009-*.md` + `010-*.md` | Operator scenarios exercising the coverage-graph scripts end-to-end |\n169: | 6 | Legacy MCP server READMEs | `.opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/README.md:25-68` + `.../handlers/coverage-graph/README.md` | Original-location stubs documenting the runtime move |\n170: | 7 | Doctor + deep-improvement | `.opencode/commands/doctor/assets/doctor_deep-loop.yaml` + `doctor_update.yaml` + `.opencode/skills/deep-loop-workflows/deep-improvement/scripts/lib/README.md:26` | Cross-references to deep-loop runtime from doctor command assets and the deep-improvement script-lib documentation |\n171: \n172: ### Note: cross-package test discovery\n173: \n174: `.opencode/skills/system-spec-kit/mcp_server/tests/deep-loop/review-depth-reducer.vitest.ts:9` imports `'../../../../deep-review/scripts/reduce-state.cjs'` - the test file lives in `mcp_server` but exercises `deep-review` code, and is discovered via deep-loop-runtime's vitest glob in `vitest.config.ts:20`. Effective SC-007 boundary for any deep-loop-runtime change is therefore tighter than the literal directory listing: changes to `deep-review/scripts/reduce-state.cjs` ALSO re-validate through deep-loop-runtime's test surface.\n175: \n176: ---\n177: \n178: ## 8. INTEGRATION RISKS\n179: \n180: | Risk | Consequence | Guard |\n181: |---|---|---|\n182: | Script stdout stops being JSON-only | YAML output bindings break. | Preserve stdout contract. |\n183: | Session id omitted | Graph state can bleed across lineages. | All scripts require `--session-id`. |\n184: | MCP tools reintroduced | Runtime boundary regresses. | Follow `SKILL.md` NEVER rule. |\n185: | DB not closed | SQLite handles remain open. | Keep `closeDb()` in `finally`. |\n186: | Consumer YAML uses old MCP names | Graph integration fails. | Grep YAML for `deep-loop-runtime/scripts`. |\n187: \n188: ---\n189: \n190: ## 9. SOURCE ANCHORS\n191: \n192: | Path | Role |\n193: |---|---|\n194: | `SKILL.md` | Runtime boundary and rules. |\n195: | `README.md` | Human-facing layout and quick start. |\n196: | `scripts/*.cjs` | Direct integration entry points. |\n197: | `lib/deep-loop/*.ts` | Shared executor, validation, state, scoring, and permission primitives. |\n198: | `lib/coverage-graph/*.ts` | Graph storage, query, and signal primitives. |\n199: | `.opencode/commands/deep/assets/deep_review_auto.yaml` | Review auto consumer. |\n200: | `.opencode/commands/deep/assets/deep_research_auto.yaml` | Research auto consumer. |\n201: | `.opencode/commands/doctor/speckit.md` | Doctor route boundary. |\n202: | `.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts` | Runtime test discovery. |\n203: \n\n(End of file - total 203 lines)\n</content>","metadata":{"preview":"- `system-code-graph/feature_catalog/05--coverage-graph/deep-loop-graph-convergence.md` points to `scripts/convergence.cjs`.\n\n---\n\n## 6. SYSTEM-SPEC-KIT TEST DISCOVERY\n\nThe runtime tests are discovered from the system-spec-kit MCP server Vitest config:\n\n```text\n.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts\n  '../deep-loop-runtime/tests/**/*.{vitest,test}.ts'\n```\n\nProduction imports resolve from this skill's own `node_modules` via bare specifiers — no reach-in to a sibling skill's installed packages:\n\n- `executor-config.ts` and `prompt-pack.ts` import `zod` (declared in this skill's `package.json`).\n- `coverage-graph-db.ts`, `coverage-graph-signals.ts`, and `council/council-graph-db.ts` import `better-sqlite3` (declared here; pinned to the same version `system-spec-kit` uses so the native binding stays ABI-compatible).\n- The `*.cjs` scripts boot the tsx loader through `require.resolve('tsx')`, which resolves from this skill's own `node_modules`.\n\nThe dependency versions are kept in lockstep with `system-spec-kit` (see `package.json`), which is why graph metadata still lists `system-spec-kit` under `depends_on`. The standalone suite runs via `npm test` (local `vitest.config.ts`); the combined CI run still discovers these tests through the `system-spec-kit` MCP server config above.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/references/integration_points.md","text":"- `system-code-graph/feature_catalog/05--coverage-graph/deep-loop-graph-convergence.md` points to `scripts/convergence.cjs`.\n\n---\n\n## 6. SYSTEM-SPEC-KIT TEST DISCOVERY\n\nThe runtime tests are discovered from the system-spec-kit MCP server Vitest config:\n\n```text\n.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts\n  '../deep-loop-runtime/tests/**/*.{vitest,test}.ts'\n```\n\nProduction imports resolve from this skill's own `node_modules` via bare specifiers — no reach-in to a sibling skill's installed packages:\n\n- `executor-config.ts` and `prompt-pack.ts` import `zod` (declared in this skill's `package.json`).\n- `coverage-graph-db.ts`, `coverage-graph-signals.ts`, and `council/council-graph-db.ts` import `better-sqlite3` (declared here; pinned to the same version `system-spec-kit` uses so the native binding stays ABI-compatible).\n- The `*.cjs` scripts boot the tsx loader through `require.resolve('tsx')`, which resolves from this skill's own `node_modules`.\n\nThe dependency versions are kept in lockstep with `system-spec-kit` (see `package.json`), which is why graph metadata still lists `system-spec-kit` under `depends_on`. The standalone suite runs via `npm test` (local `vitest.config.ts`); the combined CI run still discovers these tests through the `system-spec-kit` MCP server config above.\n\n---\n\n## 7. DIRECT OPERATOR CALLS\n\n### Status\n\n```bash\nnode .opencode/skills/deep-loop-runtime/scripts/status.cjs \\\n  --spec-folder \".opencode/specs/example\" \\\n  --loop-type review \\\n  --session-id example-session\n```\n\n### Query\n\n```bash\nnode .opencode/skills/deep-loop-runtime/scripts/query.cjs \\\n  --spec-folder \".opencode/specs/example\" \\\n  --loop-type review \\\n  --session-id example-session \\\n  --query-type coverage_gaps\n```\n\n### Upsert\n\n```bash\nnode .opencode/skills/deep-loop-runtime/scripts/upsert.cjs \\\n  --spec-folder \".opencode/specs/example\" \\\n  --loop-type review \\\n  --session-id example-session \\\n  --nodes '[{\"id\":\"dim-correctness\",\"kind\":\"DIMENSION\",\"name\":\"Correctness\"}]' \\\n  --edges '[]'\n```\n\n### Convergence\n\n```bash\nnode .opencode/skills/deep-loop-runtime/scripts/convergence.cjs \\\n  --spec-folder \".opencode/specs/example\" \\\n  --loop-type review \\\n  --session-id example-session \\\n  --iteration 3 \\\n  --persist-snapshot true\n```\n\n---\n\n## 7.1 ADDITIONAL CONSUMERS\n\nThe following consumers were surfaced by a deep-research audit and were absent from §2-§7 above:\n\n| # | Consumer | Path | Integration Shape |\n|---|----------|------|-------------------|\n| 1 | `/deep:ai-council` command | `.opencode/commands/deep/assets/deep_ai-council_{auto,confirm}.yaml` | Loads 3 `lib/council/*.cjs` modules via require() for multi-seat dispatch + round-state JSONL + adjudicator scoring |\n| 2 | `deep-ai-council` orchestration | `.opencode/skills/deep-loop-workflows/deep-ai-council/scripts/orchestrate-{session,topic}.cjs` | 8 require() calls across all 5 `lib/council/*.cjs` modules |\n| 3 | `/doctor` route manifest | `.opencode/commands/doctor/_routes.yaml:88-104` | gate3_location + 4 script_invocations + 4 trigger_phrases routing operator commands to deep-loop-runtime scripts |\n| 4 | `/doctor` update command | `.opencode/commands/doctor/update.md:28, :220, :272` | References deep-loop scripts plus the `.pre-doctor-update.*.bak` backup-pattern reads |\n| 5 | `system-code-graph` playbook | `.opencode/skills/system-code-graph/manual_testing_playbook/05--coverage-graph/009-*.md` + `010-*.md` | Operator scenarios exercising the coverage-graph scripts end-to-end |\n| 6 | Legacy MCP server READMEs | `.opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/README.md:25-68` + `.../handlers/coverage-graph/README.md` | Original-location stubs documenting the runtime move |\n| 7 | Doctor + deep-improvement | `.opencode/commands/doctor/assets/doctor_deep-loop.yaml` + `doctor_update.yaml` + `.opencode/skills/deep-loop-workflows/deep-improvement/scripts/lib/README.md:26` | Cross-references to deep-loop runtime from doctor command assets and the deep-improvement script-lib documentation |\n\n### Note: cross-package test discovery\n\n`.opencode/skills/system-spec-kit/mcp_server/tests/deep-loop/review-depth-reducer.vitest.ts:9` imports `'../../../../deep-review/scripts/reduce-state.cjs'` - the test file lives in `mcp_server` but exercises `deep-review` code, and is discovered via deep-loop-runtime's vitest glob in `vitest.config.ts:20`. Effective SC-007 boundary for any deep-loop-runtime change is therefore tighter than the literal directory listing: changes to `deep-review/scripts/reduce-state.cjs` ALSO re-validate through deep-loop-runtime's test surface.\n\n---\n\n## 8. INTEGRATION RISKS\n\n| Risk | Consequence | Guard |\n|---|---|---|\n| Script stdout stops being JSON-only | YAML output bindings break. | Preserve stdout contract. |\n| Session id omitted | Graph state can bleed across lineages. | All scripts require `--session-id`. |\n| MCP tools reintroduced | Runtime boundary regresses. | Follow `SKILL.md` NEVER rule. |\n| DB not closed | SQLite handles remain open. | Keep `closeDb()` in `finally`. |\n| Consumer YAML uses old MCP names | Graph integration fails. | Grep YAML for `deep-loop-runtime/scripts`. |\n\n---\n\n## 9. SOURCE ANCHORS\n\n| Path | Role |\n|---|---|\n| `SKILL.md` | Runtime boundary and rules. |\n| `README.md` | Human-facing layout and quick start. |\n| `scripts/*.cjs` | Direct integration entry points. |\n| `lib/deep-loop/*.ts` | Shared executor, validation, state, scoring, and permission primitives. |\n| `lib/coverage-graph/*.ts` | Graph storage, query, and signal primitives. |\n| `.opencode/commands/deep/assets/deep_review_auto.yaml` | Review auto consumer. |\n| `.opencode/commands/deep/assets/deep_research_auto.yaml` | Research auto consumer. |\n| `.opencode/commands/doctor/speckit.md` | Doctor route boundary. |\n| `.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts` | Runtime test discovery. |\n","lineStart":90,"lineEnd":203,"totalLines":203,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/references/integration_points.md","time":{"start":1783487488855,"end":1783487488863}},"metadata":{"openai":{"itemId":"fc_06ccffdfe16e3f8d016a4ddc00b238819395d4a1f9d5d1e9b5"}},"id":"prt_f4023634a001wzeW6AyHyEMSQA","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f40233fe7001z33DiuVDsuOhb1"}}
{"type":"tool_use","timestamp":1783487488865,"sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","part":{"type":"tool","tool":"read","callID":"call_LNjOw0DcUmLpHiukyiL7CjgA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/dependency-seams.vitest.ts","offset":1,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/dependency-seams.vitest.ts</path>\n<type>file</type>\n<content>\n1: // MODULE: Deep-Loop Dependency Seams — Self-Containment Guard\n2: //\n3: // Guards that the runtime resolves its external dependencies (zod,\n4: // better-sqlite3, tsx) from this skill's OWN node_modules rather than reaching\n5: // into a sibling skill's installed packages. A regression here means a deep\n6: // reach-in path was reintroduced, which re-couples the runtime to\n7: // system-spec-kit's internal layout and risks a native-binding ABI mismatch.\n8: \n9: import { describe, expect, it } from 'vitest';\n10: \n11: import { createRequire } from 'node:module';\n12: import { readdirSync, readFileSync } from 'node:fs';\n13: import { dirname, resolve, sep } from 'node:path';\n14: import { fileURLToPath } from 'node:url';\n15: \n16: const testDir = dirname(fileURLToPath(import.meta.url));\n17: const runtimeRoot = resolve(testDir, '..', '..');\n18: const skillsRoot = resolve(runtimeRoot, '..');\n19: \n20: // Resolve bare specifiers as they resolve from inside the runtime's own lib/\n21: // directory — the same vantage point the production lib files import from.\n22: const runtimeRequire = createRequire(resolve(runtimeRoot, 'lib', 'index.cjs'));\n23: \n24: // Versions system-spec-kit pins. The runtime must install the SAME versions so a\n25: // process that loads both skills' native better-sqlite3 binding stays ABI-safe.\n26: const PINNED = {\n27:   'better-sqlite3': '12.10.0',\n28:   zod: '4.4.3',\n29:   tsx: '4.22.4',\n30: } as const;\n31: \n32: function packageVersionFor(specifier: string): string {\n33:   const pkgPath = runtimeRequire.resolve(`${specifier}/package.json`);\n34:   return JSON.parse(readFileSync(pkgPath, 'utf8')).version as string;\n35: }\n36: \n37: describe('runtime dependency self-containment', () => {\n38:   it('resolves zod, better-sqlite3, and tsx from the runtime\\'s own node_modules', () => {\n39:     const ownNodeModules = resolve(runtimeRoot, 'node_modules') + sep;\n40:     for (const specifier of Object.keys(PINNED)) {\n41:       const resolved = runtimeRequire.resolve(`${specifier}/package.json`);\n42:       expect(resolved.startsWith(ownNodeModules)).toBe(true);\n43:     }\n44:   });\n45: \n46:   it('never resolves an external dependency through a sibling skill', () => {\n47:     const siblingNodeModules = resolve(skillsRoot, 'system-spec-kit') + sep;\n48:     for (const specifier of Object.keys(PINNED)) {\n49:       const resolved = runtimeRequire.resolve(`${specifier}/package.json`);\n50:       expect(resolved.startsWith(siblingNodeModules)).toBe(false);\n51:     }\n52:   });\n53: \n54:   it('installs the same dependency versions system-spec-kit pins', () => {\n55:     for (const [specifier, version] of Object.entries(PINNED)) {\n56:       expect(packageVersionFor(specifier)).toBe(version);\n57:     }\n58:   });\n59: \n60:   it('bare-resolves the tsx loader the .cjs scripts boot from', () => {\n61:     const loader = runtimeRequire.resolve('tsx');\n62:     expect(loader.endsWith(`${sep}dist${sep}loader.mjs`)).toBe(true);\n63:     expect(loader.startsWith(resolve(runtimeRoot, 'node_modules') + sep)).toBe(true);\n64:   });\n65: \n66:   it('keeps every lib and script free of deep sibling-skill node_modules reach-ins', () => {\n67:     // Two reach-in shapes exist in this tree's history: the `.ts` import string\n68:     // (a contiguous path) and the `.cjs` tsx-loader built from a path.resolve()\n69:     // arg array split across lines. Both must be caught — the array form is how\n70:     // the loader scripts referenced a sibling skill before self-containment.\n71:     const REACH_IN = /system-spec-kit[\\\\/](?:mcp_server|scripts)[\\\\/]node_modules/;\n72:     const REACH_IN_ARRAY = /'system-spec-kit'\\s*,\\s*'(?:mcp_server|scripts)'\\s*,\\s*'node_modules'/;\n73:     const offenders: string[] = [];\n74:     for (const root of ['lib', 'scripts'] as const) {\n75:       for (const file of walk(resolve(runtimeRoot, root))) {\n76:         if (!/\\.(ts|cjs|mjs|js)$/.test(file)) continue;\n77:         const content = readFileSync(file, 'utf8');\n78:         if (REACH_IN.test(content) || REACH_IN_ARRAY.test(content)) offenders.push(file);\n79:       }\n80:     }\n81:     expect(offenders).toEqual([]);\n82:   });\n83: \n84:   it('loads the bare imports the lib production code depends on', async () => {\n85:     const { z } = await import('zod');\n86:     expect(typeof z.string).toBe('function');\n87: \n88:     const Database = (await import('better-sqlite3')).default;\n89:     const db = new Database(':memory:');\n90:     db.exec('CREATE TABLE seam_probe (value INTEGER)');\n91:     db.prepare('INSERT INTO seam_probe (value) VALUES (?)').run(7);\n92:     expect(db.prepare('SELECT value FROM seam_probe').get()).toEqual({ value: 7 });\n93:     db.close();\n94:   });\n95: });\n96: \n97: function walk(dir: string): string[] {\n98:   const out: string[] = [];\n99:   for (const entry of readdirSync(dir, { withFileTypes: true })) {\n100:     const full = resolve(dir, entry.name);\n101:     if (entry.isDirectory()) {\n102:       if (entry.name === 'node_modules') continue;\n103:       out.push(...walk(full));\n104:     } else {\n105:       out.push(full);\n106:     }\n107:   }\n108:   return out;\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"// MODULE: Deep-Loop Dependency Seams — Self-Containment Guard\n//\n// Guards that the runtime resolves its external dependencies (zod,\n// better-sqlite3, tsx) from this skill's OWN node_modules rather than reaching\n// into a sibling skill's installed packages. A regression here means a deep\n// reach-in path was reintroduced, which re-couples the runtime to\n// system-spec-kit's internal layout and risks a native-binding ABI mismatch.\n\nimport { describe, expect, it } from 'vitest';\n\nimport { createRequire } from 'node:module';\nimport { readdirSync, readFileSync } from 'node:fs';\nimport { dirname, resolve, sep } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nconst testDir = dirname(fileURLToPath(import.meta.url));\nconst runtimeRoot = resolve(testDir, '..', '..');\nconst skillsRoot = resolve(runtimeRoot, '..');\n\n// Resolve bare specifiers as they resolve from inside the runtime's own lib/","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/dependency-seams.vitest.ts","text":"// MODULE: Deep-Loop Dependency Seams — Self-Containment Guard\n//\n// Guards that the runtime resolves its external dependencies (zod,\n// better-sqlite3, tsx) from this skill's OWN node_modules rather than reaching\n// into a sibling skill's installed packages. A regression here means a deep\n// reach-in path was reintroduced, which re-couples the runtime to\n// system-spec-kit's internal layout and risks a native-binding ABI mismatch.\n\nimport { describe, expect, it } from 'vitest';\n\nimport { createRequire } from 'node:module';\nimport { readdirSync, readFileSync } from 'node:fs';\nimport { dirname, resolve, sep } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nconst testDir = dirname(fileURLToPath(import.meta.url));\nconst runtimeRoot = resolve(testDir, '..', '..');\nconst skillsRoot = resolve(runtimeRoot, '..');\n\n// Resolve bare specifiers as they resolve from inside the runtime's own lib/\n// directory — the same vantage point the production lib files import from.\nconst runtimeRequire = createRequire(resolve(runtimeRoot, 'lib', 'index.cjs'));\n\n// Versions system-spec-kit pins. The runtime must install the SAME versions so a\n// process that loads both skills' native better-sqlite3 binding stays ABI-safe.\nconst PINNED = {\n  'better-sqlite3': '12.10.0',\n  zod: '4.4.3',\n  tsx: '4.22.4',\n} as const;\n\nfunction packageVersionFor(specifier: string): string {\n  const pkgPath = runtimeRequire.resolve(`${specifier}/package.json`);\n  return JSON.parse(readFileSync(pkgPath, 'utf8')).version as string;\n}\n\ndescribe('runtime dependency self-containment', () => {\n  it('resolves zod, better-sqlite3, and tsx from the runtime\\'s own node_modules', () => {\n    const ownNodeModules = resolve(runtimeRoot, 'node_modules') + sep;\n    for (const specifier of Object.keys(PINNED)) {\n      const resolved = runtimeRequire.resolve(`${specifier}/package.json`);\n      expect(resolved.startsWith(ownNodeModules)).toBe(true);\n    }\n  });\n\n  it('never resolves an external dependency through a sibling skill', () => {\n    const siblingNodeModules = resolve(skillsRoot, 'system-spec-kit') + sep;\n    for (const specifier of Object.keys(PINNED)) {\n      const resolved = runtimeRequire.resolve(`${specifier}/package.json`);\n      expect(resolved.startsWith(siblingNodeModules)).toBe(false);\n    }\n  });\n\n  it('installs the same dependency versions system-spec-kit pins', () => {\n    for (const [specifier, version] of Object.entries(PINNED)) {\n      expect(packageVersionFor(specifier)).toBe(version);\n    }\n  });\n\n  it('bare-resolves the tsx loader the .cjs scripts boot from', () => {\n    const loader = runtimeRequire.resolve('tsx');\n    expect(loader.endsWith(`${sep}dist${sep}loader.mjs`)).toBe(true);\n    expect(loader.startsWith(resolve(runtimeRoot, 'node_modules') + sep)).toBe(true);\n  });\n\n  it('keeps every lib and script free of deep sibling-skill node_modules reach-ins', () => {\n    // Two reach-in shapes exist in this tree's history: the `.ts` import string\n    // (a contiguous path) and the `.cjs` tsx-loader built from a path.resolve()\n    // arg array split across lines. Both must be caught — the array form is how\n    // the loader scripts referenced a sibling skill before self-containment.\n    const REACH_IN = /system-spec-kit[\\\\/](?:mcp_server|scripts)[\\\\/]node_modules/;\n    const REACH_IN_ARRAY = /'system-spec-kit'\\s*,\\s*'(?:mcp_server|scripts)'\\s*,\\s*'node_modules'/;\n    const offenders: string[] = [];\n    for (const root of ['lib', 'scripts'] as const) {\n      for (const file of walk(resolve(runtimeRoot, root))) {\n        if (!/\\.(ts|cjs|mjs|js)$/.test(file)) continue;\n        const content = readFileSync(file, 'utf8');\n        if (REACH_IN.test(content) || REACH_IN_ARRAY.test(content)) offenders.push(file);\n      }\n    }\n    expect(offenders).toEqual([]);\n  });\n\n  it('loads the bare imports the lib production code depends on', async () => {\n    const { z } = await import('zod');\n    expect(typeof z.string).toBe('function');\n\n    const Database = (await import('better-sqlite3')).default;\n    const db = new Database(':memory:');\n    db.exec('CREATE TABLE seam_probe (value INTEGER)');\n    db.prepare('INSERT INTO seam_probe (value) VALUES (?)').run(7);\n    expect(db.prepare('SELECT value FROM seam_probe').get()).toEqual({ value: 7 });\n    db.close();\n  });\n});\n\nfunction walk(dir: string): string[] {\n  const out: string[] = [];\n  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    const full = resolve(dir, entry.name);\n    if (entry.isDirectory()) {\n      if (entry.name === 'node_modules') continue;\n      out.push(...walk(full));\n    } else {\n      out.push(full);\n    }\n  }\n  return out;\n}","lineStart":1,"lineEnd":109,"totalLines":109,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/tests/unit/dependency-seams.vitest.ts","time":{"start":1783487488857,"end":1783487488864}},"metadata":{"openai":{"itemId":"fc_06ccffdfe16e3f8d016a4ddc00b2408193a76e52fe8d3fb4f8"}},"id":"prt_f40236358001f0ptWDoc29hKzk","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f40233fe7001z33DiuVDsuOhb1"}}
