    89	async function main() {
    90	  const args = parseArgs();
    91	  const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);
    92	  const loopType = ensureString(args, 'loopType');
    93	  const sessionId = validateNamespaceValue(ensureString(args, 'sessionId'), 'sessionId', inputError);
    94	  if (loopType !== 'research' && loopType !== 'review' && loopType !== 'council') throw inputError('loopType must be "research", "review", or "council"');
    95	
    96	  const ns = { specFolder, loopType, sessionId };
    97	  let db = null;
    98	
    99	  try {
   100	    const isCouncil = loopType === 'council';
   101	    db = isCouncil
   102	      ? await import('../lib/council/council-graph-db.ts')
   103	      : await import('../lib/coverage-graph/coverage-graph-db.ts');
   104	    installSignalHandlers(() => db?.closeDb());
   105	    maybeThrowTestFault();
   106	    if (isCouncil) {
   107	      const convergence = require('../lib/council/convergence.cjs');
   108	      const councilNs = { specFolder, sessionId };
   109	      const stats = db.getStats(specFolder, sessionId);
   110	      const readiness = stats.totalNodes === 0 ? 'empty' : 'ready';
   111	      const data = {
   112	        namespace: ns,
   113	        scopeMode: 'session',
   114	        readiness,
   115	        sourceOfTruth: 'derived_from_ai_council_artifacts',
   116	        notes: [
   117	          'Council graph rows are derived from packet-local ai-council artifacts and may be rebuilt.',
   118	        ],
   119	        recovery: {
   120	          mode: 'derived_replay',
