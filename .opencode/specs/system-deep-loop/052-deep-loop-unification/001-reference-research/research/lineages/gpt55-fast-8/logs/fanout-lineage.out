.\nmodule.exports = require(\n  path.join(__dirname, '..', '..', '..', 'system-spec-kit', 'shared', 'review-research-paths.cjs'),\n);","lineStart":1,"lineEnd":19,"totalLines":19,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/artifact-root.cjs","time":{"start":1783487392019,"end":1783487392033}},"metadata":{"openai":{"itemId":"fc_080178a562e13358016a4ddb9ff08481918fe616412e2f568f"}},"id":"prt_f4021e8f40010QlgWmlrbfN6rn","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f4021cac40015yEMY3L3SCaP4Z"}}
