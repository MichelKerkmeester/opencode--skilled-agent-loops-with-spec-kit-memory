{"type":"tool_use","timestamp":1780728407362,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_dW6lb1DQmix8yeYRW6CMdqrO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","offset":1080,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py</path>\n<type>file</type>\n<content>\n1080:     try:\n1081:         uid = UUID(entity_id)\n1082:     except ValueError:\n1083:         return _with_latency(\n1084:             _error_response(\"INVALID_ARGUMENTS\", \"Invalid entity_id — must be a valid UUID.\"),\n1085:             t0,\n1086:         )\n1087: \n1088:     async with _mcp_session() as db:\n1089:         result = await get_entity(db, uid, _get_tenant(), caller_agent_id=_get_agent_id())\n1090:         text = \"Entity not found.\" if not result else _serialize(result)\n1091:         return _with_latency(text, t0)\n1092: \n1093: \n1094: async def memclaw_tune(\n1095:     agent_id: Annotated[str, Field(description=\"Caller agent.\")] = \"mcp-agent\",\n1096:     top_k: Annotated[int | None, Field(description=\"1-20.\")] = None,\n1097:     min_similarity: Annotated[float | None, Field(description=\"0.1-0.9.\")] = None,\n1098:     fts_weight: Annotated[float | None, Field(description=\"0=semantic, 1=keyword.\")] = None,\n1099:     freshness_floor: Annotated[float | None, Field(description=\"0-1.\")] = None,\n1100:     freshness_decay_days: Annotated[int | None, Field(description=\"7-730.\")] = None,\n1101:     recall_boost_cap: Annotated[float | None, Field(description=\"1-3.\")] = None,\n1102:     recall_decay_window_days: Annotated[int | None, Field(description=\"7-365.\")] = None,\n1103:     graph_max_hops: Annotated[int | None, Field(description=\"0-3.\")] = None,\n1104:     similarity_blend: Annotated[float | None, Field(description=\"0-1.\")] = None,\n1105: ) -> str:\n1106:     t0 = time.perf_counter()\n1107:     if err := _check_auth():\n1108:         return err\n1109:     if err := _check_write_scope():\n1110:         return err\n1111:     tenant_id = _get_tenant()\n1112:     agent_id = _get_agent_id() or agent_id\n1113:     if refuse := _refuse_default_agent_on_gateway(agent_id):\n1114:         return _with_latency(refuse, t0)\n1115: \n1116:     from core_api.schemas import SearchProfileUpdate\n1117: \n1118:     try:\n1119:         profile = SearchProfileUpdate(\n1120:             top_k=top_k,\n1121:             min_similarity=min_similarity,\n1122:             fts_weight=fts_weight,\n1123:             freshness_floor=freshness_floor,\n1124:             freshness_decay_days=freshness_decay_days,\n1125:             recall_boost_cap=recall_boost_cap,\n1126:             recall_decay_window_days=recall_decay_window_days,\n1127:             graph_max_hops=graph_max_hops,\n1128:             similarity_blend=similarity_blend,\n1129:         )\n1130:     except (ValidationError, ValueError) as e:\n1131:         return _with_latency(_error_response(\"INVALID_ARGUMENTS\", f\"{e}\"), t0)\n1132: \n1133:     updates = profile.model_dump(exclude_none=True)\n1134:     async with _mcp_session() as db:\n1135:         try:\n1136:             from core_api.repositories import agent_repo\n1137:             from core_api.services.agent_service import get_or_create_agent\n1138: \n1139:             agent = await get_or_create_agent(db, tenant_id, agent_id)\n1140:             current = (agent.get(\"search_profile\") if isinstance(agent, dict) else agent.search_profile) or {}\n1141:             if updates:\n1142:                 current.update(updates)\n1143:                 from core_api.services.organization_settings import validate_search_profile\n1144: \n1145:                 current = validate_search_profile(current)\n1146:                 await agent_repo.update_search_profile(db, agent.id, current)\n1147:                 await db.commit()\n1148:             return _with_latency(json.dumps({\"agent_id\": agent_id, \"search_profile\": current}, indent=2), t0)\n1149:         except HTTPException as e:\n\n(Showing lines 1080-1149 of 2542. Use offset=1150 to continue.)\n</content>","metadata":{"preview":"    try:\n        uid = UUID(entity_id)\n    except ValueError:\n        return _with_latency(\n            _error_response(\"INVALID_ARGUMENTS\", \"Invalid entity_id — must be a valid UUID.\"),\n            t0,\n        )\n\n    async with _mcp_session() as db:\n        result = await get_entity(db, uid, _get_tenant(), caller_agent_id=_get_agent_id())\n        text = \"Entity not found.\" if not result else _serialize(result)\n        return _with_latency(text, t0)\n\n\nasync def memclaw_tune(\n    agent_id: Annotated[str, Field(description=\"Caller agent.\")] = \"mcp-agent\",\n    top_k: Annotated[int | None, Field(description=\"1-20.\")] = None,\n    min_similarity: Annotated[float | None, Field(description=\"0.1-0.9.\")] = None,\n    fts_weight: Annotated[float | None, Field(description=\"0=semantic, 1=keyword.\")] = None,\n    freshness_floor: Annotated[float | None, Field(description=\"0-1.\")] = None,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","text":"    try:\n        uid = UUID(entity_id)\n    except ValueError:\n        return _with_latency(\n            _error_response(\"INVALID_ARGUMENTS\", \"Invalid entity_id — must be a valid UUID.\"),\n            t0,\n        )\n\n    async with _mcp_session() as db:\n        result = await get_entity(db, uid, _get_tenant(), caller_agent_id=_get_agent_id())\n        text = \"Entity not found.\" if not result else _serialize(result)\n        return _with_latency(text, t0)\n\n\nasync def memclaw_tune(\n    agent_id: Annotated[str, Field(description=\"Caller agent.\")] = \"mcp-agent\",\n    top_k: Annotated[int | None, Field(description=\"1-20.\")] = None,\n    min_similarity: Annotated[float | None, Field(description=\"0.1-0.9.\")] = None,\n    fts_weight: Annotated[float | None, Field(description=\"0=semantic, 1=keyword.\")] = None,\n    freshness_floor: Annotated[float | None, Field(description=\"0-1.\")] = None,\n    freshness_decay_days: Annotated[int | None, Field(description=\"7-730.\")] = None,\n    recall_boost_cap: Annotated[float | None, Field(description=\"1-3.\")] = None,\n    recall_decay_window_days: Annotated[int | None, Field(description=\"7-365.\")] = None,\n    graph_max_hops: Annotated[int | None, Field(description=\"0-3.\")] = None,\n    similarity_blend: Annotated[float | None, Field(description=\"0-1.\")] = None,\n) -> str:\n    t0 = time.perf_counter()\n    if err := _check_auth():\n        return err\n    if err := _check_write_scope():\n        return err\n    tenant_id = _get_tenant()\n    agent_id = _get_agent_id() or agent_id\n    if refuse := _refuse_default_agent_on_gateway(agent_id):\n        return _with_latency(refuse, t0)\n\n    from core_api.schemas import SearchProfileUpdate\n\n    try:\n        profile = SearchProfileUpdate(\n            top_k=top_k,\n            min_similarity=min_similarity,\n            fts_weight=fts_weight,\n            freshness_floor=freshness_floor,\n            freshness_decay_days=freshness_decay_days,\n            recall_boost_cap=recall_boost_cap,\n            recall_decay_window_days=recall_decay_window_days,\n            graph_max_hops=graph_max_hops,\n            similarity_blend=similarity_blend,\n        )\n    except (ValidationError, ValueError) as e:\n        return _with_latency(_error_response(\"INVALID_ARGUMENTS\", f\"{e}\"), t0)\n\n    updates = profile.model_dump(exclude_none=True)\n    async with _mcp_session() as db:\n        try:\n            from core_api.repositories import agent_repo\n            from core_api.services.agent_service import get_or_create_agent\n\n            agent = await get_or_create_agent(db, tenant_id, agent_id)\n            current = (agent.get(\"search_profile\") if isinstance(agent, dict) else agent.search_profile) or {}\n            if updates:\n                current.update(updates)\n                from core_api.services.organization_settings import validate_search_profile\n\n                current = validate_search_profile(current)\n                await agent_repo.update_search_profile(db, agent.id, current)\n                await db.commit()\n            return _with_latency(json.dumps({\"agent_id\": agent_id, \"search_profile\": current}, indent=2), t0)\n        except HTTPException as e:","lineStart":1080,"lineEnd":1149,"totalLines":2542,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","time":{"start":1780728407313,"end":1780728407361}},"metadata":{"openai":{"itemId":"fc_03a44880175beecf016a23c2573dac8191984863a196bdef74"}},"id":"prt_e9baf2510001lKezJLFnHOAehF","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baefa9a001pXMNwWs6YKQqh8"}}
{"type":"tool_use","timestamp":1780728407369,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_KF5QgrLeM4eZachm7akltkxs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":2500,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n2500:         for el in links_data.get(str(memory_id), [])\n2501:     ]\n2502: \n2503:     return _dict_to_memory_out(updated, entity_links=entity_links)\n2504: \n2505: \n2506: # Re-exported from EntityRepository for backward compatibility (tests, pipeline steps).\n2507: from core_api.repositories.entity_repository import _relation_weight  # noqa: F401\n2508: \n2509: \n2510: async def expand_graph(\n2511:     db: AsyncSession,\n2512:     seed_entity_ids: list[UUID],\n2513:     tenant_id: str,\n2514:     fleet_id: str | None,\n2515:     max_hops: int = GRAPH_MAX_HOPS,\n2516:     use_union: bool = False,\n2517: ) -> dict[UUID, tuple[int, float]]:\n2518:     \"\"\"Expand entity graph via storage client.\"\"\"\n2519:     sc = get_storage_client()\n2520:     result = await sc.expand_graph(\n2521:         {\n2522:             \"seed_entity_ids\": [str(eid) for eid in seed_entity_ids],\n2523:             \"tenant_id\": tenant_id,\n2524:             \"fleet_id\": fleet_id,\n2525:             \"max_hops\": max_hops,\n2526:             \"use_union\": use_union,\n2527:         }\n2528:     )\n2529:     # Convert dict keys back to UUIDs and values to (hop, weight) tuples\n2530:     return {\n2531:         UUID(k): (\n2532:             v.get(\"hop\", 0) if isinstance(v, dict) else v[0],\n2533:             v.get(\"weight\", 1.0) if isinstance(v, dict) else v[1],\n2534:         )\n2535:         for k, v in result.items()\n2536:     }\n2537: \n2538: \n2539: def _is_specific_token(token: str) -> bool:\n2540:     \"\"\"Check if a token looks like a proper noun, identifier, or ticker.\"\"\"\n2541:     if not token:\n2542:         return False\n2543:     # All-caps acronym (NEXAI, BTC, GPT) or CamelCase/PascalCase (CertiK, OpenAI)\n2544:     if token.isupper() or (token[0].isupper() and any(c.isupper() for c in token[1:])):\n2545:         return True\n2546:     # Contains digits (IDs, versions, codes): \"gpt-5\", \"1892347\"\n2547:     if any(c.isdigit() for c in token):\n2548:         return True\n2549:     # Starts with special chars (tickers, handles): \"$SOL\", \"@karpathy\", \"#trending\"\n2550:     if token[0] in (\"$\", \"@\", \"#\"):\n2551:         return True\n2552:     return False\n2553: \n2554: \n2555: def _adaptive_fts_weight(query: str) -> float:\n2556:     \"\"\"Return a boosted FTS weight for short, specific queries.\n2557: \n2558:     A27 — shares the canonical tokenizer with the entity-FTS gate so a\n2559:     hyphenated query like ``claude-opus-4-7`` no longer produces a\n2560:     1-token view here but a 4-token view at ``extract_entity_tokens``.\n2561:     Two behavioural details are preserved across the share:\n2562: \n2563:     1. ``MAX_TOKENS`` gates on RAW whitespace count, not on the\n2564:        post-filter token count. A 4+ word natural-language sentence\n2565:        should stay default-weight even when the shared filter would\n2566:        collapse it to a single meaningful token (``\"tell me about\n2567:        NEXAI\"`` → semantic-heavy, don't boost).\n2568:     2. Sigil tokens (``$BTC`` / ``@karpathy`` / ``#trending``) are\n2569:        detected on the RAW query before ``extract_entity_tokens``\n2570:        strips leading punctuation, so the handle / ticker / hashtag\n2571:        signal that ``_is_specific_token`` keys on still fires after\n2572:        the share.\n2573:     \"\"\"\n2574:     from core_api.services.entity_tokens import extract_entity_tokens\n2575: \n2576:     raw = query.split()\n2577:     if len(raw) > FTS_BOOST_MAX_TOKENS:\n2578:         return FTS_WEIGHT\n2579: \n2580:     tokens = extract_entity_tokens(query, preserve_case=True)\n2581:     sigil_count = sum(1 for t in raw if t and t[0] in (\"$\", \"@\", \"#\") and len(t) > 1)\n2582: \n2583:     if not tokens and sigil_count == 0:\n2584:         return FTS_WEIGHT\n2585: \n2586:     specific_count = sum(1 for t in tokens if _is_specific_token(t)) + sigil_count\n2587:     denom = len(tokens) or 1\n2588:     if specific_count / denom > FTS_BOOST_SPECIFICITY_RATIO:\n2589:         return FTS_WEIGHT_BOOSTED\n2590: \n2591:     return FTS_WEIGHT\n2592: \n2593: \n2594: def _normalize_query_for_cache(query: str) -> str:\n2595:     \"\"\"Normalize query for cache key: lowercase, strip, collapse whitespace.\"\"\"\n2596:     return re.sub(r\"\\s+\", \" \", query.strip().lower())\n2597: \n2598: \n2599: # Per-process stampede guard for cold-cache embed calls. Maps cache-key to\n2600: # the in-flight Future producing the embedding. When N concurrent callers\n2601: # miss the cache for the same key, the first arrival registers the Future\n2602: # and fires the embed call; subsequent arrivals find the Future and await\n2603: # its result instead of each issuing their own OpenAI round-trip.\n2604: #\n2605: # Scope is intentionally per-process: a Redis-side lock would coordinate\n2606: # across replicas but the latency floor of the read path is already a\n2607: # single embed call per cold key per replica, and the stampede pattern\n2608: # observed in production is dominated by the same client issuing N\n2609: # parallel recalls (e.g. fan-out probe, agent batch) hitting the same\n2610: # replica. Cache_set still happens, so once any replica completes the\n2611: # embed, the next request — local OR remote — finds it in Redis.\n2612: _inflight_embeddings: dict[str, asyncio.Future] = {}\n2613: \n2614: \n2615: async def _get_or_cache_embedding(query: str, tenant_id: str, tenant_config):\n2616:     \"\"\"Get embedding from cache or generate it.\n2617: \n2618:     The cache key includes ``VECTOR_DIM`` so that a schema-dimension\n2619:     migration doesn't surface stale cached embeddings to the new schema;\n2620:     old entries with a mismatched dim become unreachable under the new\n2621:     key and expire naturally via ``EMBEDDING_CACHE_TTL``.\n2622: \n2623:     The cache key also includes ``EMBEDDING_QUERY_INSTRUCTION`` (C9):\n2624:     instruction-aware models (Qwen3-Embedding, e5-instruct, KaLM) prepend\n2625:     the resolved instruction to the query before encoding, so the SAME\n2626:     raw query under TWO different instructions produces TWO different\n2627:     embeddings. Omitting the instruction from the key meant an env-var\n2628:     change (or set / unset) served stale embeddings until the TTL\n2629:     expired. The registry-level provider cache already keys on this —\n2630:     we mirror it at the search-cache layer.\n2631: \n2632:     Concurrent cold-cache callers for the same key share a single\n2633:     ``get_query_embedding`` round-trip via ``_inflight_embeddings`` —\n2634:     measured 3-second tail spread on 5 parallel novel-query recalls\n2635:     pre-fix; post-fix all callers join the leader's future.\n2636:     \"\"\"\n2637:     import os\n2638: \n2639:     from core_api.cache import cache_get, cache_set\n2640: \n2641:     _model = (\n2642:         getattr(tenant_config, \"embedding_model\", None) if tenant_config is not None else None\n2643:     ) or OPENAI_EMBEDDING_MODEL\n2644:     _normalized = _normalize_query_for_cache(query)\n2645:     # Resolved instruction — same env var the OpenAI provider reads at\n2646:     # registry-construction time (common/embedding/_registry.py:218). When\n2647:     # unset, we hash the empty string so the key stays stable across\n2648:     # never-set vs explicitly-empty (both behave identically downstream:\n2649:     # the provider's ``embed_query`` short-circuits the instruction\n2650:     # prefix).\n2651:     _instruction = os.environ.get(\"EMBEDDING_QUERY_INSTRUCTION\") or \"\"\n2652:     _qhash = hashlib.sha256(\n2653:         f\"{_model}:{VECTOR_DIM}:{_instruction}:{tenant_id}:{_normalized}\".encode()\n2654:     ).hexdigest()\n2655:     # Prefix bumped from ``qemb3:`` → ``qemb4:`` because the hash input\n2656:     # changed (added ``EMBEDDING_QUERY_INSTRUCTION``). The bump makes the\n2657:     # cache-generation boundary explicit in Redis key stats so an\n2658:     # operator can see the cold-start at deploy time and confirm the\n2659:     # embedding provider can absorb the working-set re-fetch. Old\n2660:     # ``qemb3:*`` entries expire naturally via ``EMBEDDING_CACHE_TTL``.\n2661:     _cache_key = f\"qemb4:{_qhash}\"\n2662:     _cached_raw = await cache_get(_cache_key)\n2663:     if _cached_raw is not None:\n2664:         try:\n2665:             return json.loads(_cached_raw)\n2666:         except (ValueError, TypeError):\n2667:             pass\n2668: \n2669:     # Cold cache: check whether another coroutine is already producing\n2670:     # this embedding. If so, await its result. Otherwise become the\n2671:     # leader, register the future, and fire the embed call.\n2672:     inflight = _inflight_embeddings.get(_cache_key)\n2673:     if inflight is not None:\n2674:         return await inflight\n2675: \n2676:     loop = asyncio.get_running_loop()\n2677:     fut: asyncio.Future = loop.create_future()\n2678:     _inflight_embeddings[_cache_key] = fut\n2679:     try:\n2680:         # Search-side embed uses the instruction-aware path. For symmetric\n2681:         # models (OpenAI, bge, snowflake-m, gte-en-v1.5) this is identical to\n2682:         # ``get_embedding(query, tenant_config)``. For instruction-aware models\n2683:         # (Qwen3-Embedding, e5-instruct), the provider prepends the configured\n2684:         # task instruction (env: ``EMBEDDING_QUERY_INSTRUCTION``) so the query\n2685:         # is encoded with the same instruction prefix the model was trained on.\n2686:         # Documents (writes) embed unmodified text.\n2687:         embedding = await asyncio.wait_for(get_query_embedding(query, tenant_config), timeout=10.0)\n2688:         if embedding is None:\n2689:             raise ValueError(\"Embedding service unavailable\")\n2690:         await cache_set(_cache_key, json.dumps(embedding), ttl=EMBEDDING_CACHE_TTL)\n2691:         fut.set_result(embedding)\n2692:         return embedding\n2693:     except BaseException as exc:\n2694:         # Propagate to every waiter so they raise consistently rather\n2695:         # than hanging forever on a fulfilled-never future. BaseException\n2696:         # catches CancelledError too — leaking a cancelled future would\n2697:         # otherwise strand every joiner. The leader re-raises after the\n2698:         # finally block.\n2699:         if not fut.done():\n2700:             fut.set_exception(exc)\n2701:         raise\n2702:     finally:\n2703:         # Drop the inflight slot only after the future has been resolved.\n2704:         # A late arrival that read the slot before this pop still gets\n2705:         # the cached future and awaits its already-resolved state.\n2706:         _inflight_embeddings.pop(_cache_key, None)\n2707: \n2708: \n2709: async def _entity_boost_pipeline(\n2710:     db: AsyncSession,\n2711:     query: str,\n2712:     tenant_id: str,\n2713:     fleet_ids: list[str] | None,\n2714:     graph_expand: bool,\n2715:     graph_max_hops: int,\n2716:     use_union: bool = False,\n2717:     precomputed_hops: dict[UUID, tuple[int, float]] | None = None,\n2718: ) -> tuple[set[UUID], dict[UUID, float]]:\n2719:     \"\"\"Run entity FTS matching -> graph expansion -> link collection.\n2720: \n2721:     Returns (boosted_memory_ids, memory_boost_factor).\n2722:     Independent of embedding -- can run in parallel.\n2723: \n2724:     When *precomputed_hops* is supplied (from ClassifyQuery fallthrough),\n2725:     entity FTS and graph expansion are skipped to avoid double DB roundtrips.\n2726:     \"\"\"\n2727:     sc = get_storage_client()\n2728:     boosted_memory_ids: set[UUID] = set()\n2729:     memory_boost_factor: dict[UUID, float] = {}\n2730: \n2731:     try:\n2732:         if precomputed_hops is not None:\n2733:             entity_hops = precomputed_hops\n2734:             matched_entity_ids = [eid for eid, (hop, _w) in entity_hops.items() if hop == 0]\n2735:         else:\n2736:             tokens = extract_entity_tokens(query)\n2737:             if not tokens:\n2738:                 return boosted_memory_ids, memory_boost_factor\n2739: \n2740:             # Entity FTS search via storage client\n2741:             matched_entity_ids_raw = await sc.fts_search_entities(\n2742:                 {\n2743:                     \"tenant_id\": tenant_id,\n2744:                     \"tokens\": tokens,\n2745:                     \"fleet_ids\": fleet_ids,\n2746:                 }\n2747:             )\n2748:             matched_entity_ids = [UUID(eid) for eid in matched_entity_ids_raw]\n2749: \n2750:             if not matched_entity_ids:\n2751:                 return boosted_memory_ids, memory_boost_factor\n2752: \n2753:             # Graph expansion\n2754:             if graph_expand and graph_max_hops > 0:\n2755:                 entity_hops = await expand_graph(\n2756:                     db,\n2757:                     matched_entity_ids,\n2758:                     tenant_id,\n2759:                     fleet_ids[0] if fleet_ids and len(fleet_ids) == 1 else None,\n2760:                     max_hops=graph_max_hops,\n2761:                     use_union=use_union,\n2762:                 )\n2763:             else:\n2764:                 entity_hops = dict.fromkeys(matched_entity_ids, (0, 1.0))\n2765: \n2766:         if matched_entity_ids:\n2767:             # Collect memories linked to discovered entities via storage client\n2768:             all_entity_ids = list(entity_hops.keys())\n2769:             all_links_raw = await sc.get_memory_ids_by_entity_ids([str(eid) for eid in all_entity_ids])\n2770: \n2771:             # Process links in hop order (closest entities first)\n2772:             all_links = [\n2773:                 (\n2774:                     UUID(item[\"memory_id\"]) if isinstance(item[\"memory_id\"], str) else item[\"memory_id\"],\n2775:                     UUID(item[\"entity_id\"]) if isinstance(item[\"entity_id\"], str) else item[\"entity_id\"],\n2776:                 )\n2777:                 for item in all_links_raw\n2778:             ]\n2779:             all_links.sort(key=lambda row: entity_hops.get(row[1], (999, 0.0))[0])\n2780: \n2781:             for mem_id, ent_id in all_links:\n2782:                 hop, rel_weight = entity_hops.get(ent_id, (0, 1.0))\n2783:                 hop_boost = GRAPH_HOP_BOOST.get(hop, GRAPH_HOP_BOOST[max(GRAPH_HOP_BOOST)])\n2784:                 boost = hop_boost * rel_weight\n2785:                 if mem_id not in memory_boost_factor or boost > memory_boost_factor[mem_id]:\n2786:                     memory_boost_factor[mem_id] = boost\n2787:                 if len(memory_boost_factor) >= GRAPH_MAX_BOOSTED_MEMORIES:\n2788:                     break\n2789: \n2790:             # Multi-entity boost\n2791:             if len(matched_entity_ids) > 1:\n2792:                 memory_entity_count: dict[UUID, int] = {}\n2793:                 matched_set = set(matched_entity_ids)\n2794:                 for mem_id, ent_id in all_links:\n2795:                     if ent_id in matched_set:\n2796:                         memory_entity_count[mem_id] = memory_entity_count.get(mem_id, 0) + 1\n2797:                 for mem_id in memory_boost_factor:\n2798:                     count = memory_entity_count.get(mem_id, 0)\n2799:                     if count > 1 and memory_boost_factor[mem_id] > 1.0:\n2800:                         extra = min(count - 1, 4) * 0.10\n2801:                         memory_boost_factor[mem_id] = min(\n2802:                             memory_boost_factor[mem_id] * (1.0 + extra),\n2803:                             RECALL_BOOST_CAP,\n2804:                         )\n2805: \n2806:             boosted_memory_ids = set(memory_boost_factor.keys())\n2807:     except (SQLAlchemyError, ValueError):\n2808:         logger.exception(\"Entity/graph boost lookup failed (falling back to pure vector search)\")\n2809: \n2810:     return boosted_memory_ids, memory_boost_factor\n2811: \n2812: \n2813: def _extract_temporal_hint(query: str) -> timedelta | None:\n2814:     \"\"\"Extract a temporal scope from query for freshness boosting.\"\"\"\n2815:     import re\n2816: \n2817:     q = query.lower()\n2818: \n2819:     if re.search(r\"\\b(today|this morning|tonight)\\b\", q):\n2820:         return timedelta(days=1)\n2821:     if re.search(r\"\\b(yesterday)\\b\", q):\n2822:         return timedelta(days=2)\n2823:     if re.search(r\"\\b(last few days)\\b\", q):\n2824:         return timedelta(days=5)\n2825:     if re.search(r\"\\b(this week|past week)\\b\", q):\n2826:         return timedelta(days=7)\n2827:     if re.search(r\"\\b(last week)\\b\", q):\n2828:         return timedelta(days=14)\n2829:     if re.search(r\"\\b(this month|past month)\\b\", q):\n2830:         return timedelta(days=30)\n2831:     if re.search(r\"\\b(last month)\\b\", q):\n2832:         return timedelta(days=60)\n2833:     if re.search(r\"\\b(this quarter)\\b\", q):\n2834:         return timedelta(days=90)\n2835:     if re.search(r\"\\b(this year)\\b\", q):\n2836:         return timedelta(days=365)\n2837:     if re.search(r\"\\b(last year)\\b\", q):\n2838:         return timedelta(days=730)\n2839: \n2840:     m = re.search(r\"\\blast\\s+(\\d+)\\s+(day|week|month)s?\\b\", q)\n2841:     if m:\n2842:         n = int(m.group(1))\n2843:         if n == 0:\n2844:             return None\n2845:         unit = m.group(2)\n2846:         if unit == \"day\":\n2847:             return timedelta(days=min(n, 365))\n2848:         if unit == \"week\":\n2849:             return timedelta(days=min(n * 7, 365))\n2850:         if unit == \"month\":\n2851:             return timedelta(days=min(n * 30, 365))\n2852: \n2853:     return None\n2854: \n2855: \n2856: # ---------------------------------------------------------------------------\n2857: # Hard date-range extraction (pipeline path → WHERE filter)\n2858: # ---------------------------------------------------------------------------\n2859: \n2860: _WORD_TO_NUMBER: dict[str, int] = {\n2861:     \"one\": 1,\n2862:     \"a\": 1,\n2863:     \"an\": 1,\n2864:     \"two\": 2,\n2865:     \"couple\": 2,\n2866:     \"three\": 3,\n2867:     \"few\": 3,\n2868:     \"four\": 4,\n2869:     \"five\": 5,\n2870:     \"six\": 6,\n2871:     \"seven\": 7,\n2872:     \"eight\": 8,\n2873:     \"nine\": 9,\n2874:     \"ten\": 10,\n2875:     \"eleven\": 11,\n2876:     \"twelve\": 12,\n2877: }\n2878: \n2879: _TEMPORAL_DATE_RANGE_PATTERNS: list[tuple[str, bool]] = [\n\n(Showing lines 2500-2879 of 3230. Use offset=2880 to continue.)\n</content>","metadata":{"preview":"        for el in links_data.get(str(memory_id), [])\n    ]\n\n    return _dict_to_memory_out(updated, entity_links=entity_links)\n\n\n# Re-exported from EntityRepository for backward compatibility (tests, pipeline steps).\nfrom core_api.repositories.entity_repository import _relation_weight  # noqa: F401\n\n\nasync def expand_graph(\n    db: AsyncSession,\n    seed_entity_ids: list[UUID],\n    tenant_id: str,\n    fleet_id: str | None,\n    max_hops: int = GRAPH_MAX_HOPS,\n    use_union: bool = False,\n) -> dict[UUID, tuple[int, float]]:\n    \"\"\"Expand entity graph via storage client.\"\"\"\n    sc = get_storage_client()","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"        for el in links_data.get(str(memory_id), [])\n    ]\n\n    return _dict_to_memory_out(updated, entity_links=entity_links)\n\n\n# Re-exported from EntityRepository for backward compatibility (tests, pipeline steps).\nfrom core_api.repositories.entity_repository import _relation_weight  # noqa: F401\n\n\nasync def expand_graph(\n    db: AsyncSession,\n    seed_entity_ids: list[UUID],\n    tenant_id: str,\n    fleet_id: str | None,\n    max_hops: int = GRAPH_MAX_HOPS,\n    use_union: bool = False,\n) -> dict[UUID, tuple[int, float]]:\n    \"\"\"Expand entity graph via storage client.\"\"\"\n    sc = get_storage_client()\n    result = await sc.expand_graph(\n        {\n            \"seed_entity_ids\": [str(eid) for eid in seed_entity_ids],\n            \"tenant_id\": tenant_id,\n            \"fleet_id\": fleet_id,\n            \"max_hops\": max_hops,\n            \"use_union\": use_union,\n        }\n    )\n    # Convert dict keys back to UUIDs and values to (hop, weight) tuples\n    return {\n        UUID(k): (\n            v.get(\"hop\", 0) if isinstance(v, dict) else v[0],\n            v.get(\"weight\", 1.0) if isinstance(v, dict) else v[1],\n        )\n        for k, v in result.items()\n    }\n\n\ndef _is_specific_token(token: str) -> bool:\n    \"\"\"Check if a token looks like a proper noun, identifier, or ticker.\"\"\"\n    if not token:\n        return False\n    # All-caps acronym (NEXAI, BTC, GPT) or CamelCase/PascalCase (CertiK, OpenAI)\n    if token.isupper() or (token[0].isupper() and any(c.isupper() for c in token[1:])):\n        return True\n    # Contains digits (IDs, versions, codes): \"gpt-5\", \"1892347\"\n    if any(c.isdigit() for c in token):\n        return True\n    # Starts with special chars (tickers, handles): \"$SOL\", \"@karpathy\", \"#trending\"\n    if token[0] in (\"$\", \"@\", \"#\"):\n        return True\n    return False\n\n\ndef _adaptive_fts_weight(query: str) -> float:\n    \"\"\"Return a boosted FTS weight for short, specific queries.\n\n    A27 — shares the canonical tokenizer with the entity-FTS gate so a\n    hyphenated query like ``claude-opus-4-7`` no longer produces a\n    1-token view here but a 4-token view at ``extract_entity_tokens``.\n    Two behavioural details are preserved across the share:\n\n    1. ``MAX_TOKENS`` gates on RAW whitespace count, not on the\n       post-filter token count. A 4+ word natural-language sentence\n       should stay default-weight even when the shared filter would\n       collapse it to a single meaningful token (``\"tell me about\n       NEXAI\"`` → semantic-heavy, don't boost).\n    2. Sigil tokens (``$BTC`` / ``@karpathy`` / ``#trending``) are\n       detected on the RAW query before ``extract_entity_tokens``\n       strips leading punctuation, so the handle / ticker / hashtag\n       signal that ``_is_specific_token`` keys on still fires after\n       the share.\n    \"\"\"\n    from core_api.services.entity_tokens import extract_entity_tokens\n\n    raw = query.split()\n    if len(raw) > FTS_BOOST_MAX_TOKENS:\n        return FTS_WEIGHT\n\n    tokens = extract_entity_tokens(query, preserve_case=True)\n    sigil_count = sum(1 for t in raw if t and t[0] in (\"$\", \"@\", \"#\") and len(t) > 1)\n\n    if not tokens and sigil_count == 0:\n        return FTS_WEIGHT\n\n    specific_count = sum(1 for t in tokens if _is_specific_token(t)) + sigil_count\n    denom = len(tokens) or 1\n    if specific_count / denom > FTS_BOOST_SPECIFICITY_RATIO:\n        return FTS_WEIGHT_BOOSTED\n\n    return FTS_WEIGHT\n\n\ndef _normalize_query_for_cache(query: str) -> str:\n    \"\"\"Normalize query for cache key: lowercase, strip, collapse whitespace.\"\"\"\n    return re.sub(r\"\\s+\", \" \", query.strip().lower())\n\n\n# Per-process stampede guard for cold-cache embed calls. Maps cache-key to\n# the in-flight Future producing the embedding. When N concurrent callers\n# miss the cache for the same key, the first arrival registers the Future\n# and fires the embed call; subsequent arrivals find the Future and await\n# its result instead of each issuing their own OpenAI round-trip.\n#\n# Scope is intentionally per-process: a Redis-side lock would coordinate\n# across replicas but the latency floor of the read path is already a\n# single embed call per cold key per replica, and the stampede pattern\n# observed in production is dominated by the same client issuing N\n# parallel recalls (e.g. fan-out probe, agent batch) hitting the same\n# replica. Cache_set still happens, so once any replica completes the\n# embed, the next request — local OR remote — finds it in Redis.\n_inflight_embeddings: dict[str, asyncio.Future] = {}\n\n\nasync def _get_or_cache_embedding(query: str, tenant_id: str, tenant_config):\n    \"\"\"Get embedding from cache or generate it.\n\n    The cache key includes ``VECTOR_DIM`` so that a schema-dimension\n    migration doesn't surface stale cached embeddings to the new schema;\n    old entries with a mismatched dim become unreachable under the new\n    key and expire naturally via ``EMBEDDING_CACHE_TTL``.\n\n    The cache key also includes ``EMBEDDING_QUERY_INSTRUCTION`` (C9):\n    instruction-aware models (Qwen3-Embedding, e5-instruct, KaLM) prepend\n    the resolved instruction to the query before encoding, so the SAME\n    raw query under TWO different instructions produces TWO different\n    embeddings. Omitting the instruction from the key meant an env-var\n    change (or set / unset) served stale embeddings until the TTL\n    expired. The registry-level provider cache already keys on this —\n    we mirror it at the search-cache layer.\n\n    Concurrent cold-cache callers for the same key share a single\n    ``get_query_embedding`` round-trip via ``_inflight_embeddings`` —\n    measured 3-second tail spread on 5 parallel novel-query recalls\n    pre-fix; post-fix all callers join the leader's future.\n    \"\"\"\n    import os\n\n    from core_api.cache import cache_get, cache_set\n\n    _model = (\n        getattr(tenant_config, \"embedding_model\", None) if tenant_config is not None else None\n    ) or OPENAI_EMBEDDING_MODEL\n    _normalized = _normalize_query_for_cache(query)\n    # Resolved instruction — same env var the OpenAI provider reads at\n    # registry-construction time (common/embedding/_registry.py:218). When\n    # unset, we hash the empty string so the key stays stable across\n    # never-set vs explicitly-empty (both behave identically downstream:\n    # the provider's ``embed_query`` short-circuits the instruction\n    # prefix).\n    _instruction = os.environ.get(\"EMBEDDING_QUERY_INSTRUCTION\") or \"\"\n    _qhash = hashlib.sha256(\n        f\"{_model}:{VECTOR_DIM}:{_instruction}:{tenant_id}:{_normalized}\".encode()\n    ).hexdigest()\n    # Prefix bumped from ``qemb3:`` → ``qemb4:`` because the hash input\n    # changed (added ``EMBEDDING_QUERY_INSTRUCTION``). The bump makes the\n    # cache-generation boundary explicit in Redis key stats so an\n    # operator can see the cold-start at deploy time and confirm the\n    # embedding provider can absorb the working-set re-fetch. Old\n    # ``qemb3:*`` entries expire naturally via ``EMBEDDING_CACHE_TTL``.\n    _cache_key = f\"qemb4:{_qhash}\"\n    _cached_raw = await cache_get(_cache_key)\n    if _cached_raw is not None:\n        try:\n            return json.loads(_cached_raw)\n        except (ValueError, TypeError):\n            pass\n\n    # Cold cache: check whether another coroutine is already producing\n    # this embedding. If so, await its result. Otherwise become the\n    # leader, register the future, and fire the embed call.\n    inflight = _inflight_embeddings.get(_cache_key)\n    if inflight is not None:\n        return await inflight\n\n    loop = asyncio.get_running_loop()\n    fut: asyncio.Future = loop.create_future()\n    _inflight_embeddings[_cache_key] = fut\n    try:\n        # Search-side embed uses the instruction-aware path. For symmetric\n        # models (OpenAI, bge, snowflake-m, gte-en-v1.5) this is identical to\n        # ``get_embedding(query, tenant_config)``. For instruction-aware models\n        # (Qwen3-Embedding, e5-instruct), the provider prepends the configured\n        # task instruction (env: ``EMBEDDING_QUERY_INSTRUCTION``) so the query\n        # is encoded with the same instruction prefix the model was trained on.\n        # Documents (writes) embed unmodified text.\n        embedding = await asyncio.wait_for(get_query_embedding(query, tenant_config), timeout=10.0)\n        if embedding is None:\n            raise ValueError(\"Embedding service unavailable\")\n        await cache_set(_cache_key, json.dumps(embedding), ttl=EMBEDDING_CACHE_TTL)\n        fut.set_result(embedding)\n        return embedding\n    except BaseException as exc:\n        # Propagate to every waiter so they raise consistently rather\n        # than hanging forever on a fulfilled-never future. BaseException\n        # catches CancelledError too — leaking a cancelled future would\n        # otherwise strand every joiner. The leader re-raises after the\n        # finally block.\n        if not fut.done():\n            fut.set_exception(exc)\n        raise\n    finally:\n        # Drop the inflight slot only after the future has been resolved.\n        # A late arrival that read the slot before this pop still gets\n        # the cached future and awaits its already-resolved state.\n        _inflight_embeddings.pop(_cache_key, None)\n\n\nasync def _entity_boost_pipeline(\n    db: AsyncSession,\n    query: str,\n    tenant_id: str,\n    fleet_ids: list[str] | None,\n    graph_expand: bool,\n    graph_max_hops: int,\n    use_union: bool = False,\n    precomputed_hops: dict[UUID, tuple[int, float]] | None = None,\n) -> tuple[set[UUID], dict[UUID, float]]:\n    \"\"\"Run entity FTS matching -> graph expansion -> link collection.\n\n    Returns (boosted_memory_ids, memory_boost_factor).\n    Independent of embedding -- can run in parallel.\n\n    When *precomputed_hops* is supplied (from ClassifyQuery fallthrough),\n    entity FTS and graph expansion are skipped to avoid double DB roundtrips.\n    \"\"\"\n    sc = get_storage_client()\n    boosted_memory_ids: set[UUID] = set()\n    memory_boost_factor: dict[UUID, float] = {}\n\n    try:\n        if precomputed_hops is not None:\n            entity_hops = precomputed_hops\n            matched_entity_ids = [eid for eid, (hop, _w) in entity_hops.items() if hop == 0]\n        else:\n            tokens = extract_entity_tokens(query)\n            if not tokens:\n                return boosted_memory_ids, memory_boost_factor\n\n            # Entity FTS search via storage client\n            matched_entity_ids_raw = await sc.fts_search_entities(\n                {\n                    \"tenant_id\": tenant_id,\n                    \"tokens\": tokens,\n                    \"fleet_ids\": fleet_ids,\n                }\n            )\n            matched_entity_ids = [UUID(eid) for eid in matched_entity_ids_raw]\n\n            if not matched_entity_ids:\n                return boosted_memory_ids, memory_boost_factor\n\n            # Graph expansion\n            if graph_expand and graph_max_hops > 0:\n                entity_hops = await expand_graph(\n                    db,\n                    matched_entity_ids,\n                    tenant_id,\n                    fleet_ids[0] if fleet_ids and len(fleet_ids) == 1 else None,\n                    max_hops=graph_max_hops,\n                    use_union=use_union,\n                )\n            else:\n                entity_hops = dict.fromkeys(matched_entity_ids, (0, 1.0))\n\n        if matched_entity_ids:\n            # Collect memories linked to discovered entities via storage client\n            all_entity_ids = list(entity_hops.keys())\n            all_links_raw = await sc.get_memory_ids_by_entity_ids([str(eid) for eid in all_entity_ids])\n\n            # Process links in hop order (closest entities first)\n            all_links = [\n                (\n                    UUID(item[\"memory_id\"]) if isinstance(item[\"memory_id\"], str) else item[\"memory_id\"],\n                    UUID(item[\"entity_id\"]) if isinstance(item[\"entity_id\"], str) else item[\"entity_id\"],\n                )\n                for item in all_links_raw\n            ]\n            all_links.sort(key=lambda row: entity_hops.get(row[1], (999, 0.0))[0])\n\n            for mem_id, ent_id in all_links:\n                hop, rel_weight = entity_hops.get(ent_id, (0, 1.0))\n                hop_boost = GRAPH_HOP_BOOST.get(hop, GRAPH_HOP_BOOST[max(GRAPH_HOP_BOOST)])\n                boost = hop_boost * rel_weight\n                if mem_id not in memory_boost_factor or boost > memory_boost_factor[mem_id]:\n                    memory_boost_factor[mem_id] = boost\n                if len(memory_boost_factor) >= GRAPH_MAX_BOOSTED_MEMORIES:\n                    break\n\n            # Multi-entity boost\n            if len(matched_entity_ids) > 1:\n                memory_entity_count: dict[UUID, int] = {}\n                matched_set = set(matched_entity_ids)\n                for mem_id, ent_id in all_links:\n                    if ent_id in matched_set:\n                        memory_entity_count[mem_id] = memory_entity_count.get(mem_id, 0) + 1\n                for mem_id in memory_boost_factor:\n                    count = memory_entity_count.get(mem_id, 0)\n                    if count > 1 and memory_boost_factor[mem_id] > 1.0:\n                        extra = min(count - 1, 4) * 0.10\n                        memory_boost_factor[mem_id] = min(\n                            memory_boost_factor[mem_id] * (1.0 + extra),\n                            RECALL_BOOST_CAP,\n                        )\n\n            boosted_memory_ids = set(memory_boost_factor.keys())\n    except (SQLAlchemyError, ValueError):\n        logger.exception(\"Entity/graph boost lookup failed (falling back to pure vector search)\")\n\n    return boosted_memory_ids, memory_boost_factor\n\n\ndef _extract_temporal_hint(query: str) -> timedelta | None:\n    \"\"\"Extract a temporal scope from query for freshness boosting.\"\"\"\n    import re\n\n    q = query.lower()\n\n    if re.search(r\"\\b(today|this morning|tonight)\\b\", q):\n        return timedelta(days=1)\n    if re.search(r\"\\b(yesterday)\\b\", q):\n        return timedelta(days=2)\n    if re.search(r\"\\b(last few days)\\b\", q):\n        return timedelta(days=5)\n    if re.search(r\"\\b(this week|past week)\\b\", q):\n        return timedelta(days=7)\n    if re.search(r\"\\b(last week)\\b\", q):\n        return timedelta(days=14)\n    if re.search(r\"\\b(this month|past month)\\b\", q):\n        return timedelta(days=30)\n    if re.search(r\"\\b(last month)\\b\", q):\n        return timedelta(days=60)\n    if re.search(r\"\\b(this quarter)\\b\", q):\n        return timedelta(days=90)\n    if re.search(r\"\\b(this year)\\b\", q):\n        return timedelta(days=365)\n    if re.search(r\"\\b(last year)\\b\", q):\n        return timedelta(days=730)\n\n    m = re.search(r\"\\blast\\s+(\\d+)\\s+(day|week|month)s?\\b\", q)\n    if m:\n        n = int(m.group(1))\n        if n == 0:\n            return None\n        unit = m.group(2)\n        if unit == \"day\":\n            return timedelta(days=min(n, 365))\n        if unit == \"week\":\n            return timedelta(days=min(n * 7, 365))\n        if unit == \"month\":\n            return timedelta(days=min(n * 30, 365))\n\n    return None\n\n\n# ---------------------------------------------------------------------------\n# Hard date-range extraction (pipeline path → WHERE filter)\n# ---------------------------------------------------------------------------\n\n_WORD_TO_NUMBER: dict[str, int] = {\n    \"one\": 1,\n    \"a\": 1,\n    \"an\": 1,\n    \"two\": 2,\n    \"couple\": 2,\n    \"three\": 3,\n    \"few\": 3,\n    \"four\": 4,\n    \"five\": 5,\n    \"six\": 6,\n    \"seven\": 7,\n    \"eight\": 8,\n    \"nine\": 9,\n    \"ten\": 10,\n    \"eleven\": 11,\n    \"twelve\": 12,\n}\n\n_TEMPORAL_DATE_RANGE_PATTERNS: list[tuple[str, bool]] = [","lineStart":2500,"lineEnd":2879,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728407308,"end":1780728407366}},"metadata":{"openai":{"itemId":"fc_03a44880175beecf016a23c2573d9081918834c34ced6ed951"}},"id":"prt_e9baf24f7001J60R7M6bqP2hHD","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baefa9a001pXMNwWs6YKQqh8"}}
{"type":"tool_use","timestamp":1780728407370,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_h9L5ogOdbASMRtISAucJ6Xvu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":2880,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n2880:     # (pattern, is_future)\n2881:     # \"a couple of weeks ago\", \"a few days back\"\n2882:     (\n2883:         r\"a\\s+(?P<word>couple|few)\\s+(?:of\\s+)?(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\",\n2884:         False,\n2885:     ),\n2886:     # \"two months ago\", \"five days back\"\n2887:     (\n2888:         r\"(?P<word>one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve)\\s+(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\",\n2889:         False,\n2890:     ),\n2891:     # \"in two weeks\", \"in three months\"\n2892:     (\n2893:         r\"in\\s+(?P<word>one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|a|an|couple|few)\\s+(?P<unit>days?|weeks?|months?|years?)\",\n2894:         True,\n2895:     ),\n2896:     # \"3 months ago\", \"10 days back\"\n2897:     (r\"(?P<num>\\d+)\\s+(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\", False),\n2898:     # \"last week\", \"last month\", \"last year\"\n2899:     (r\"last\\s+(?P<unit>week|month|year)\\b\", False),\n2900: ]\n2901: \n2902: _UNIT_TO_DAYS = {\"day\": 1, \"week\": 7, \"month\": 30, \"year\": 365}\n2903: \n2904: # Padding scaled to unit granularity: exact-day for \"day\", ±1 for \"week\",\n2905: # ±3 for \"month\", ±14 for \"year\". Tighter ranges shrink the candidate pool\n2906: # so the soft date-range boost in the scorer can push the right memory up.\n2907: _PAD_DAYS = {\"day\": 0, \"week\": 1, \"month\": 3, \"year\": 14}\n2908: \n2909: \n2910: def _extract_temporal_date_range(\n2911:     query: str,\n2912:     reference_datetime: datetime | None = None,\n2913: ) -> dict[str, str] | None:\n2914:     \"\"\"Extract a hard date-range filter from temporal expressions in *query*.\n2915: \n2916:     Returns ``{\"start_date\": \"YYYY-MM-DD\", \"end_date\": \"YYYY-MM-DD\"}`` or\n2917:     ``None`` when no expression is detected.\n2918: \n2919:     Range padding (see ``_PAD_DAYS``): 0 days for day, ±1 day for week,\n2920:     ±3 days for month, ±14 days for year.  Pairs with the soft date-range\n2921:     boost in the storage scorer — tighter window + softer filter keeps\n2922:     out-of-range memories retrievable when semantically strong.\n2923:     \"\"\"\n2924:     import re\n2925:     from datetime import UTC\n2926: \n2927:     q = query.lower()\n2928:     ref = reference_datetime or datetime.now(UTC)\n2929: \n2930:     for pattern, is_future in _TEMPORAL_DATE_RANGE_PATTERNS:\n2931:         m = re.search(pattern, q)\n2932:         if not m:\n2933:             continue\n2934: \n2935:         groups = m.groupdict()\n2936:         unit_raw = groups.get(\"unit\", \"\")\n2937:         unit = unit_raw.rstrip(\"s\") if unit_raw else \"\"\n2938: \n2939:         # Determine numeric value\n2940:         if \"num\" in groups and groups[\"num\"] is not None:\n2941:             n = int(groups[\"num\"])\n2942:         elif \"word\" in groups and groups[\"word\"] is not None:\n2943:             n = _WORD_TO_NUMBER.get(groups[\"word\"], 0)\n2944:         elif \"last\" in pattern:\n2945:             n = 1\n2946:         else:\n2947:             continue\n2948: \n2949:         if n == 0:\n2950:             continue\n2951: \n2952:         days_offset = n * _UNIT_TO_DAYS.get(unit, 1)\n2953:         delta = timedelta(days=days_offset)\n2954:         target = ref + delta if is_future else ref - delta\n2955: \n2956:         pad = timedelta(days=_PAD_DAYS.get(unit, 3))\n2957: \n2958:         start = (target - pad).date()\n2959:         end = (target + pad).date()\n2960:         return {\"start_date\": start.isoformat(), \"end_date\": end.isoformat()}\n2961: \n2962:     return None\n2963: \n2964: \n2965: async def search_memories(\n2966:     db: AsyncSession,\n2967:     tenant_id: str,\n2968:     query: str,\n2969:     fleet_ids: list[str] | None = None,\n2970:     filter_agent_id: str | None = None,\n2971:     caller_agent_id: str | None = None,\n2972:     memory_type_filter: str | None = None,\n2973:     status_filter: str | None = None,\n2974:     valid_at: datetime | None = None,\n2975:     top_k: int = DEFAULT_SEARCH_TOP_K,\n2976:     recall_boost: bool = True,\n2977:     graph_expand: bool = True,\n2978:     tenant_config=None,\n2979:     search_profile: dict | None = None,\n2980:     diagnostic: bool = False,\n2981:     diagnostic_ctx: dict | None = None,\n2982:     readable_tenant_ids: list[str] | None = None,\n2983: ) -> list[MemoryOut]:\n2984:     # Diagnostic mode requires the pipeline path for score introspection\n2985:     if _USE_PIPELINE_SEARCH or diagnostic:\n2986:         return await _search_memories_pipeline(\n2987:             db,\n2988:             tenant_id,\n2989:             query,\n2990:             fleet_ids=fleet_ids,\n2991:             filter_agent_id=filter_agent_id,\n2992:             caller_agent_id=caller_agent_id,\n2993:             memory_type_filter=memory_type_filter,\n2994:             status_filter=status_filter,\n2995:             valid_at=valid_at,\n2996:             top_k=top_k,\n2997:             recall_boost=recall_boost,\n2998:             graph_expand=graph_expand,\n2999:             tenant_config=tenant_config,\n3000:             search_profile=search_profile,\n3001:             diagnostic=diagnostic,\n3002:             diagnostic_ctx=diagnostic_ctx,\n3003:             readable_tenant_ids=readable_tenant_ids,\n3004:         )\n3005:     logger.warning(\"legacy search path invoked; this path is deprecated and scheduled for removal\")\n3006:     return await _search_memories_legacy(\n3007:         db,\n3008:         tenant_id,\n3009:         query,\n3010:         fleet_ids=fleet_ids,\n3011:         filter_agent_id=filter_agent_id,\n3012:         caller_agent_id=caller_agent_id,\n3013:         memory_type_filter=memory_type_filter,\n3014:         status_filter=status_filter,\n3015:         valid_at=valid_at,\n3016:         top_k=top_k,\n3017:         recall_boost=recall_boost,\n3018:         graph_expand=graph_expand,\n3019:         tenant_config=tenant_config,\n3020:         search_profile=search_profile,\n3021:     )\n3022: \n3023: \n3024: async def _search_memories_pipeline(\n3025:     db: AsyncSession,\n3026:     tenant_id: str,\n3027:     query: str,\n3028:     fleet_ids: list[str] | None = None,\n3029:     filter_agent_id: str | None = None,\n3030:     caller_agent_id: str | None = None,\n3031:     memory_type_filter: str | None = None,\n3032:     status_filter: str | None = None,\n3033:     valid_at: datetime | None = None,\n3034:     top_k: int = DEFAULT_SEARCH_TOP_K,\n3035:     recall_boost: bool = True,\n3036:     graph_expand: bool = True,\n3037:     tenant_config=None,\n3038:     search_profile: dict | None = None,\n3039:     diagnostic: bool = False,\n3040:     diagnostic_ctx: dict | None = None,\n3041:     readable_tenant_ids: list[str] | None = None,\n3042: ) -> list[MemoryOut]:\n3043:     \"\"\"Pipeline-based search_memories -- same logic, decomposed into timed steps.\"\"\"\n3044:     from core_api.pipeline.compositions.search import build_search_pipeline\n3045:     from core_api.pipeline.context import PipelineContext\n3046: \n3047:     ctx = PipelineContext(\n3048:         db=db,\n3049:         data={\n3050:             \"query\": query,\n3051:             \"tenant_id\": tenant_id,\n3052:             \"fleet_ids\": fleet_ids,\n3053:             \"filter_agent_id\": filter_agent_id,\n3054:             \"caller_agent_id\": caller_agent_id,\n3055:             \"memory_type_filter\": memory_type_filter,\n3056:             \"status_filter\": status_filter,\n3057:             \"valid_at\": valid_at,\n3058:             \"top_k\": top_k,\n3059:             \"recall_boost_enabled\": recall_boost,\n3060:             \"graph_expand\": graph_expand,\n3061:             \"tenant_config\": tenant_config,\n3062:             \"search_profile\": search_profile,\n3063:             \"diagnostic\": diagnostic,\n3064:             \"readable_tenant_ids\": readable_tenant_ids,\n3065:         },\n3066:         tenant_config=tenant_config,\n3067:     )\n3068: \n3069:     pipeline = build_search_pipeline()\n3070:     result = await pipeline.run(ctx)\n3071: \n3072:     if result.failed:\n3073:         from core_api.pipeline.step import StepOutcome\n3074: \n3075:         failed_steps = [s for s in result.steps if s.outcome == StepOutcome.FAILED]\n3076:         if failed_steps and failed_steps[-1].error:\n3077:             logger.error(\n3078:                 \"Search pipeline step %r failed: %s\",\n3079:                 failed_steps[-1],\n3080:                 failed_steps[-1].error,\n3081:             )\n3082:         raise HTTPException(status_code=500, detail=\"Search pipeline failed unexpectedly\")\n3083: \n3084:     if diagnostic and diagnostic_ctx is not None:\n3085:         diagnostic_ctx[\"all_candidates\"] = ctx.data.get(\"diagnostic_results\", [])\n3086:         diagnostic_ctx[\"search_params\"] = ctx.data.get(\"search_params\", {})\n3087:         diagnostic_ctx[\"retrieval_strategy\"] = (\n3088:             ctx.data[\"retrieval_plan\"].strategy.value if ctx.data.get(\"retrieval_plan\") else None\n3089:         )\n3090:         diagnostic_ctx[\"diagnostic_original_top_k\"] = ctx.data.get(\"diagnostic_original_top_k\")\n3091: \n3092:     return ctx.data[\"results\"]\n3093: \n3094: \n3095: async def _search_memories_legacy(\n3096:     db: AsyncSession,\n3097:     tenant_id: str,\n3098:     query: str,\n3099:     fleet_ids: list[str] | None = None,\n3100:     filter_agent_id: str | None = None,\n3101:     caller_agent_id: str | None = None,\n3102:     memory_type_filter: str | None = None,\n3103:     status_filter: str | None = None,\n3104:     valid_at: datetime | None = None,\n3105:     top_k: int = DEFAULT_SEARCH_TOP_K,\n3106:     recall_boost: bool = True,\n3107:     graph_expand: bool = True,\n3108:     tenant_config=None,\n3109:     search_profile: dict | None = None,\n3110: ) -> list[MemoryOut]:\n3111:     \"\"\"Legacy search -- uses scored_search storage API endpoint.\"\"\"\n3112:     sc = get_storage_client()\n3113: \n3114:     # Resolve per-agent search profile with fallback to constants\n3115:     from core_api.services.organization_settings import validate_search_profile\n3116: \n3117:     sp = validate_search_profile(search_profile) if search_profile else {}\n3118:     _top_k = sp.get(\"top_k\", top_k)\n3119:     _min_similarity = sp.get(\"min_similarity\", MIN_SEARCH_SIMILARITY)\n3120:     _fts_weight = sp[\"fts_weight\"] if \"fts_weight\" in sp else _adaptive_fts_weight(query)\n3121:     _freshness_floor = sp.get(\"freshness_floor\", FRESHNESS_FLOOR)\n3122:     _freshness_decay_days = sp.get(\"freshness_decay_days\", FRESHNESS_DECAY_DAYS)\n3123:     _recall_boost_cap = sp.get(\"recall_boost_cap\", RECALL_BOOST_CAP)\n3124:     _recall_decay_window_days = sp.get(\"recall_decay_window_days\", RECALL_DECAY_WINDOW_DAYS)\n3125:     _graph_max_hops = sp.get(\"graph_max_hops\", GRAPH_MAX_HOPS)\n3126:     _similarity_blend = sp.get(\"similarity_blend\", SIMILARITY_BLEND)\n3127: \n3128:     # Temporal hint\n3129:     temporal_window = _extract_temporal_hint(query)\n3130: \n3131:     # Parallel: embedding + entity pipeline\n3132:     emb_task = asyncio.ensure_future(_get_or_cache_embedding(query, tenant_id, tenant_config))\n3133:     ent_task = asyncio.ensure_future(\n3134:         _entity_boost_pipeline(db, query, tenant_id, fleet_ids, graph_expand, _graph_max_hops)\n3135:     )\n3136:     try:\n3137:         embedding, (boosted_memory_ids, memory_boost_factor) = await asyncio.gather(emb_task, ent_task)\n3138:     except TimeoutError:\n3139:         emb_task.cancel()\n3140:         ent_task.cancel()\n3141:         raise HTTPException(status_code=504, detail=\"Search embedding timed out\")\n3142:     except ValueError as exc:\n3143:         emb_task.cancel()\n3144:         ent_task.cancel()\n3145:         raise HTTPException(status_code=503, detail=str(exc))\n3146:     except Exception:\n3147:         emb_task.cancel()\n3148:         ent_task.cancel()\n3149:         raise\n3150: \n3151:     # Overfetch so post-filter has headroom to drop low-vec_sim rows without\n3152:     # starving the final result set. Mirrors pipeline ExecuteScoredSearch behavior.\n3153:     _overfetch_top_k = _top_k * SEARCH_OVERFETCH_FACTOR\n3154: \n3155:     # Use scored_search storage API endpoint\n3156:     search_data = {\n3157:         \"tenant_id\": tenant_id,\n3158:         \"embedding\": embedding,\n3159:         \"query\": query,\n3160:         \"fleet_ids\": fleet_ids,\n3161:         \"filter_agent_id\": filter_agent_id,\n3162:         \"caller_agent_id\": caller_agent_id,\n3163:         \"memory_type_filter\": memory_type_filter,\n3164:         \"status_filter\": status_filter,\n3165:         \"valid_at\": valid_at.isoformat() if valid_at else None,\n3166:         \"top_k\": _overfetch_top_k,\n3167:         \"min_similarity\": _min_similarity,\n3168:         \"fts_weight\": _fts_weight,\n3169:         \"freshness_floor\": _freshness_floor,\n3170:         \"freshness_decay_days\": _freshness_decay_days,\n3171:         \"recall_boost_enabled\": recall_boost,\n3172:         \"recall_boost_cap\": _recall_boost_cap,\n3173:         \"recall_decay_window_days\": _recall_decay_window_days,\n3174:         \"similarity_blend\": _similarity_blend,\n3175:         \"temporal_window_days\": temporal_window.days if temporal_window else None,\n3176:         \"boosted_memory_ids\": {str(mid): factor for mid, factor in memory_boost_factor.items()}\n3177:         if memory_boost_factor\n3178:         else None,\n3179:     }\n3180: \n3181:     # CAURA-602 follow-up: per-tenant search bulkhead at the storage\n3182:     # roundtrip. The route-entry slot was already held above; this slot\n3183:     # bounds how many of one tenant's searches occupy storage-reader\n3184:     # connections simultaneously, preserving cold-tenant search latency\n3185:     # under a hot-tenant storm.\n3186:     async with per_tenant_storage_slot(\"storage_search\", tenant_id):\n3187:         rows = await sc.scored_search(search_data)\n3188: \n3189:     # Post-filter by min_similarity, then trim to top_k. The `vec_sim is None`\n3190:     # branch is defensive: the scored_search SQL currently enforces\n3191:     # `Memory.embedding IS NOT NULL` and the storage layer coerces None → 0.0,\n3192:     # so this branch is never taken today. Left in place — mirrored in the\n3193:     # pipeline post_filter step — so that FTS-only rows aren't silently gated\n3194:     # out by the cosine threshold if either invariant ever changes.\n3195:     rows = [r for r in rows if r.get(\"vec_sim\") is None or float(r[\"vec_sim\"]) >= _min_similarity]\n3196:     rows = rows[:_top_k]\n3197: \n3198:     # Build results from storage API response\n3199:     memory_ids = [row.get(\"id\") for row in rows if row.get(\"id\")]\n3200: \n3201:     # Fetch entity links for all result memories\n3202:     links_data = (\n3203:         await sc.get_entity_links_for_memories([str(mid) for mid in memory_ids]) if memory_ids else {}\n3204:     )\n3205: \n3206:     results = []\n3207:     for row in rows:\n3208:         mid = row.get(\"id\")\n3209:         mid_str = str(mid)\n3210:         entity_links = [\n3211:             EntityLinkOut(entity_id=el.get(\"entity_id\"), role=el.get(\"role\"))\n3212:             for el in links_data.get(mid_str, [])\n3213:         ]\n3214:         results.append(\n3215:             _dict_to_memory_out(\n3216:                 row,\n3217:                 entity_links=entity_links,\n3218:                 similarity=round(float(row.get(\"score\", 0)), 4) if row.get(\"score\") is not None else None,\n3219:             )\n\n(Showing lines 2880-3219 of 3230. Use offset=3220 to continue.)\n</content>","metadata":{"preview":"    # (pattern, is_future)\n    # \"a couple of weeks ago\", \"a few days back\"\n    (\n        r\"a\\s+(?P<word>couple|few)\\s+(?:of\\s+)?(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\",\n        False,\n    ),\n    # \"two months ago\", \"five days back\"\n    (\n        r\"(?P<word>one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve)\\s+(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\",\n        False,\n    ),\n    # \"in two weeks\", \"in three months\"\n    (\n        r\"in\\s+(?P<word>one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|a|an|couple|few)\\s+(?P<unit>days?|weeks?|months?|years?)\",\n        True,\n    ),\n    # \"3 months ago\", \"10 days back\"\n    (r\"(?P<num>\\d+)\\s+(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\", False),\n    # \"last week\", \"last month\", \"last year\"\n    (r\"last\\s+(?P<unit>week|month|year)\\b\", False),","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"    # (pattern, is_future)\n    # \"a couple of weeks ago\", \"a few days back\"\n    (\n        r\"a\\s+(?P<word>couple|few)\\s+(?:of\\s+)?(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\",\n        False,\n    ),\n    # \"two months ago\", \"five days back\"\n    (\n        r\"(?P<word>one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve)\\s+(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\",\n        False,\n    ),\n    # \"in two weeks\", \"in three months\"\n    (\n        r\"in\\s+(?P<word>one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|a|an|couple|few)\\s+(?P<unit>days?|weeks?|months?|years?)\",\n        True,\n    ),\n    # \"3 months ago\", \"10 days back\"\n    (r\"(?P<num>\\d+)\\s+(?P<unit>days?|weeks?|months?|years?)\\s+(?P<dir>ago|back)\", False),\n    # \"last week\", \"last month\", \"last year\"\n    (r\"last\\s+(?P<unit>week|month|year)\\b\", False),\n]\n\n_UNIT_TO_DAYS = {\"day\": 1, \"week\": 7, \"month\": 30, \"year\": 365}\n\n# Padding scaled to unit granularity: exact-day for \"day\", ±1 for \"week\",\n# ±3 for \"month\", ±14 for \"year\". Tighter ranges shrink the candidate pool\n# so the soft date-range boost in the scorer can push the right memory up.\n_PAD_DAYS = {\"day\": 0, \"week\": 1, \"month\": 3, \"year\": 14}\n\n\ndef _extract_temporal_date_range(\n    query: str,\n    reference_datetime: datetime | None = None,\n) -> dict[str, str] | None:\n    \"\"\"Extract a hard date-range filter from temporal expressions in *query*.\n\n    Returns ``{\"start_date\": \"YYYY-MM-DD\", \"end_date\": \"YYYY-MM-DD\"}`` or\n    ``None`` when no expression is detected.\n\n    Range padding (see ``_PAD_DAYS``): 0 days for day, ±1 day for week,\n    ±3 days for month, ±14 days for year.  Pairs with the soft date-range\n    boost in the storage scorer — tighter window + softer filter keeps\n    out-of-range memories retrievable when semantically strong.\n    \"\"\"\n    import re\n    from datetime import UTC\n\n    q = query.lower()\n    ref = reference_datetime or datetime.now(UTC)\n\n    for pattern, is_future in _TEMPORAL_DATE_RANGE_PATTERNS:\n        m = re.search(pattern, q)\n        if not m:\n            continue\n\n        groups = m.groupdict()\n        unit_raw = groups.get(\"unit\", \"\")\n        unit = unit_raw.rstrip(\"s\") if unit_raw else \"\"\n\n        # Determine numeric value\n        if \"num\" in groups and groups[\"num\"] is not None:\n            n = int(groups[\"num\"])\n        elif \"word\" in groups and groups[\"word\"] is not None:\n            n = _WORD_TO_NUMBER.get(groups[\"word\"], 0)\n        elif \"last\" in pattern:\n            n = 1\n        else:\n            continue\n\n        if n == 0:\n            continue\n\n        days_offset = n * _UNIT_TO_DAYS.get(unit, 1)\n        delta = timedelta(days=days_offset)\n        target = ref + delta if is_future else ref - delta\n\n        pad = timedelta(days=_PAD_DAYS.get(unit, 3))\n\n        start = (target - pad).date()\n        end = (target + pad).date()\n        return {\"start_date\": start.isoformat(), \"end_date\": end.isoformat()}\n\n    return None\n\n\nasync def search_memories(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n    diagnostic: bool = False,\n    diagnostic_ctx: dict | None = None,\n    readable_tenant_ids: list[str] | None = None,\n) -> list[MemoryOut]:\n    # Diagnostic mode requires the pipeline path for score introspection\n    if _USE_PIPELINE_SEARCH or diagnostic:\n        return await _search_memories_pipeline(\n            db,\n            tenant_id,\n            query,\n            fleet_ids=fleet_ids,\n            filter_agent_id=filter_agent_id,\n            caller_agent_id=caller_agent_id,\n            memory_type_filter=memory_type_filter,\n            status_filter=status_filter,\n            valid_at=valid_at,\n            top_k=top_k,\n            recall_boost=recall_boost,\n            graph_expand=graph_expand,\n            tenant_config=tenant_config,\n            search_profile=search_profile,\n            diagnostic=diagnostic,\n            diagnostic_ctx=diagnostic_ctx,\n            readable_tenant_ids=readable_tenant_ids,\n        )\n    logger.warning(\"legacy search path invoked; this path is deprecated and scheduled for removal\")\n    return await _search_memories_legacy(\n        db,\n        tenant_id,\n        query,\n        fleet_ids=fleet_ids,\n        filter_agent_id=filter_agent_id,\n        caller_agent_id=caller_agent_id,\n        memory_type_filter=memory_type_filter,\n        status_filter=status_filter,\n        valid_at=valid_at,\n        top_k=top_k,\n        recall_boost=recall_boost,\n        graph_expand=graph_expand,\n        tenant_config=tenant_config,\n        search_profile=search_profile,\n    )\n\n\nasync def _search_memories_pipeline(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n    diagnostic: bool = False,\n    diagnostic_ctx: dict | None = None,\n    readable_tenant_ids: list[str] | None = None,\n) -> list[MemoryOut]:\n    \"\"\"Pipeline-based search_memories -- same logic, decomposed into timed steps.\"\"\"\n    from core_api.pipeline.compositions.search import build_search_pipeline\n    from core_api.pipeline.context import PipelineContext\n\n    ctx = PipelineContext(\n        db=db,\n        data={\n            \"query\": query,\n            \"tenant_id\": tenant_id,\n            \"fleet_ids\": fleet_ids,\n            \"filter_agent_id\": filter_agent_id,\n            \"caller_agent_id\": caller_agent_id,\n            \"memory_type_filter\": memory_type_filter,\n            \"status_filter\": status_filter,\n            \"valid_at\": valid_at,\n            \"top_k\": top_k,\n            \"recall_boost_enabled\": recall_boost,\n            \"graph_expand\": graph_expand,\n            \"tenant_config\": tenant_config,\n            \"search_profile\": search_profile,\n            \"diagnostic\": diagnostic,\n            \"readable_tenant_ids\": readable_tenant_ids,\n        },\n        tenant_config=tenant_config,\n    )\n\n    pipeline = build_search_pipeline()\n    result = await pipeline.run(ctx)\n\n    if result.failed:\n        from core_api.pipeline.step import StepOutcome\n\n        failed_steps = [s for s in result.steps if s.outcome == StepOutcome.FAILED]\n        if failed_steps and failed_steps[-1].error:\n            logger.error(\n                \"Search pipeline step %r failed: %s\",\n                failed_steps[-1],\n                failed_steps[-1].error,\n            )\n        raise HTTPException(status_code=500, detail=\"Search pipeline failed unexpectedly\")\n\n    if diagnostic and diagnostic_ctx is not None:\n        diagnostic_ctx[\"all_candidates\"] = ctx.data.get(\"diagnostic_results\", [])\n        diagnostic_ctx[\"search_params\"] = ctx.data.get(\"search_params\", {})\n        diagnostic_ctx[\"retrieval_strategy\"] = (\n            ctx.data[\"retrieval_plan\"].strategy.value if ctx.data.get(\"retrieval_plan\") else None\n        )\n        diagnostic_ctx[\"diagnostic_original_top_k\"] = ctx.data.get(\"diagnostic_original_top_k\")\n\n    return ctx.data[\"results\"]\n\n\nasync def _search_memories_legacy(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n) -> list[MemoryOut]:\n    \"\"\"Legacy search -- uses scored_search storage API endpoint.\"\"\"\n    sc = get_storage_client()\n\n    # Resolve per-agent search profile with fallback to constants\n    from core_api.services.organization_settings import validate_search_profile\n\n    sp = validate_search_profile(search_profile) if search_profile else {}\n    _top_k = sp.get(\"top_k\", top_k)\n    _min_similarity = sp.get(\"min_similarity\", MIN_SEARCH_SIMILARITY)\n    _fts_weight = sp[\"fts_weight\"] if \"fts_weight\" in sp else _adaptive_fts_weight(query)\n    _freshness_floor = sp.get(\"freshness_floor\", FRESHNESS_FLOOR)\n    _freshness_decay_days = sp.get(\"freshness_decay_days\", FRESHNESS_DECAY_DAYS)\n    _recall_boost_cap = sp.get(\"recall_boost_cap\", RECALL_BOOST_CAP)\n    _recall_decay_window_days = sp.get(\"recall_decay_window_days\", RECALL_DECAY_WINDOW_DAYS)\n    _graph_max_hops = sp.get(\"graph_max_hops\", GRAPH_MAX_HOPS)\n    _similarity_blend = sp.get(\"similarity_blend\", SIMILARITY_BLEND)\n\n    # Temporal hint\n    temporal_window = _extract_temporal_hint(query)\n\n    # Parallel: embedding + entity pipeline\n    emb_task = asyncio.ensure_future(_get_or_cache_embedding(query, tenant_id, tenant_config))\n    ent_task = asyncio.ensure_future(\n        _entity_boost_pipeline(db, query, tenant_id, fleet_ids, graph_expand, _graph_max_hops)\n    )\n    try:\n        embedding, (boosted_memory_ids, memory_boost_factor) = await asyncio.gather(emb_task, ent_task)\n    except TimeoutError:\n        emb_task.cancel()\n        ent_task.cancel()\n        raise HTTPException(status_code=504, detail=\"Search embedding timed out\")\n    except ValueError as exc:\n        emb_task.cancel()\n        ent_task.cancel()\n        raise HTTPException(status_code=503, detail=str(exc))\n    except Exception:\n        emb_task.cancel()\n        ent_task.cancel()\n        raise\n\n    # Overfetch so post-filter has headroom to drop low-vec_sim rows without\n    # starving the final result set. Mirrors pipeline ExecuteScoredSearch behavior.\n    _overfetch_top_k = _top_k * SEARCH_OVERFETCH_FACTOR\n\n    # Use scored_search storage API endpoint\n    search_data = {\n        \"tenant_id\": tenant_id,\n        \"embedding\": embedding,\n        \"query\": query,\n        \"fleet_ids\": fleet_ids,\n        \"filter_agent_id\": filter_agent_id,\n        \"caller_agent_id\": caller_agent_id,\n        \"memory_type_filter\": memory_type_filter,\n        \"status_filter\": status_filter,\n        \"valid_at\": valid_at.isoformat() if valid_at else None,\n        \"top_k\": _overfetch_top_k,\n        \"min_similarity\": _min_similarity,\n        \"fts_weight\": _fts_weight,\n        \"freshness_floor\": _freshness_floor,\n        \"freshness_decay_days\": _freshness_decay_days,\n        \"recall_boost_enabled\": recall_boost,\n        \"recall_boost_cap\": _recall_boost_cap,\n        \"recall_decay_window_days\": _recall_decay_window_days,\n        \"similarity_blend\": _similarity_blend,\n        \"temporal_window_days\": temporal_window.days if temporal_window else None,\n        \"boosted_memory_ids\": {str(mid): factor for mid, factor in memory_boost_factor.items()}\n        if memory_boost_factor\n        else None,\n    }\n\n    # CAURA-602 follow-up: per-tenant search bulkhead at the storage\n    # roundtrip. The route-entry slot was already held above; this slot\n    # bounds how many of one tenant's searches occupy storage-reader\n    # connections simultaneously, preserving cold-tenant search latency\n    # under a hot-tenant storm.\n    async with per_tenant_storage_slot(\"storage_search\", tenant_id):\n        rows = await sc.scored_search(search_data)\n\n    # Post-filter by min_similarity, then trim to top_k. The `vec_sim is None`\n    # branch is defensive: the scored_search SQL currently enforces\n    # `Memory.embedding IS NOT NULL` and the storage layer coerces None → 0.0,\n    # so this branch is never taken today. Left in place — mirrored in the\n    # pipeline post_filter step — so that FTS-only rows aren't silently gated\n    # out by the cosine threshold if either invariant ever changes.\n    rows = [r for r in rows if r.get(\"vec_sim\") is None or float(r[\"vec_sim\"]) >= _min_similarity]\n    rows = rows[:_top_k]\n\n    # Build results from storage API response\n    memory_ids = [row.get(\"id\") for row in rows if row.get(\"id\")]\n\n    # Fetch entity links for all result memories\n    links_data = (\n        await sc.get_entity_links_for_memories([str(mid) for mid in memory_ids]) if memory_ids else {}\n    )\n\n    results = []\n    for row in rows:\n        mid = row.get(\"id\")\n        mid_str = str(mid)\n        entity_links = [\n            EntityLinkOut(entity_id=el.get(\"entity_id\"), role=el.get(\"role\"))\n            for el in links_data.get(mid_str, [])\n        ]\n        results.append(\n            _dict_to_memory_out(\n                row,\n                entity_links=entity_links,\n                similarity=round(float(row.get(\"score\", 0)), 4) if row.get(\"score\") is not None else None,\n            )","lineStart":2880,"lineEnd":3219,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728407311,"end":1780728407368}},"metadata":{"openai":{"itemId":"fc_03a44880175beecf016a23c2573da481918c9c4818f7d831ce"}},"id":"prt_e9baf250d001AVXaXzFOYWIVs4","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baefa9a001pXMNwWs6YKQqh8"}}
