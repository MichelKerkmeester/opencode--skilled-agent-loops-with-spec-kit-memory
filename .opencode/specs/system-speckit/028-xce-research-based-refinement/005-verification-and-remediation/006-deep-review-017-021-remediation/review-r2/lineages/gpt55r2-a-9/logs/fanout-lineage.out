{"type":"tool_use","timestamp":1781764200893,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_U2quCvZM2VQ7cxVMDG9deKmu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-truncation.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-truncation.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Truncation\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Confidence-based result truncation\n5: import { isConfidenceTruncationEnabled } from './search-flags.js';\n6: \n7: /* --- 1. TYPES & CONSTANTS --- */\n8: \n9: /** Generic scored result for truncation — supports both numeric and string IDs. */\n10: interface ScoredResult {\n11:   id: number | string;\n12:   score: number;\n13:   [key: string]: unknown;\n14: }\n15: \n16: /** Result of a truncation operation with full audit metadata. */\n17: interface TruncationResult {\n18:   results: ScoredResult[];\n19:   truncated: boolean;\n20:   originalCount: number;\n21:   truncatedCount: number;\n22:   /** Inclusive index of the last kept result (0-based). */\n23:   cutoffIndex: number;\n24:   medianGap: number;\n25:   cutoffGap: number;\n26: }\n27: \n28: /** Options for truncation behaviour. */\n29: interface TruncationOptions {\n30:   /** Minimum number of results to always return, regardless of gap. Default: 3. */\n31:   minResults?: number;\n32: }\n33: \n34: /** Default minimum result count. */\n35: const DEFAULT_MIN_RESULTS = 3;\n36: \n37: /** Gap multiplier: gap must exceed this multiple of the median gap to trigger truncation.\n38:  * 2x median is the elbow heuristic — a gap twice the typical spread signals a relevance cliff. */\n39: const GAP_THRESHOLD_MULTIPLIER = 2;\n40: \n41: /* --- 2. GAP ANALYSIS HELPERS --- */\n42: \n43: /**\n44:  * Compute consecutive score gaps for a sorted (descending) score array.\n45:  * gap[i] = scores[i] - scores[i+1]   for i in [0, n-2]\n46:  * NaN and Infinity scores are filtered out before gap computation.\n47:  * Returns empty array when fewer than 2 finite scores.\n48:  *\n49:  * @param scores - Descending-sorted array of raw scores.\n50:  * @returns Array of consecutive score gaps (length = scores.length - 1).\n51:  */\n52: function computeGaps(scores: number[]): number[] {\n53:   // NaN/Infinity from upstream bugs would corrupt gap statistics — filter them first\n54:   const finite = scores.filter(s => Number.isFinite(s));\n55:   if (finite.length < 2) return [];\n56:   const gaps: number[] = [];\n57:   for (let i = 0; i < finite.length - 1; i++) {\n58:     gaps.push(finite[i] - finite[i + 1]);\n59:   }\n60:   return gaps;\n61: }\n62: \n63: /**\n64:  * Compute the median of an array of numbers.\n65:  * Returns 0 for an empty array.\n66:  *\n67:  * @param values - Array of numeric values.\n68:  * @returns Median value, or 0 for empty input.\n69:  */\n70: function computeMedian(values: number[]): number {\n71:   if (values.length === 0) return 0;\n72:   const sorted = [...values].sort((a, b) => a - b);\n73:   const mid = Math.floor(sorted.length / 2);\n74:   if (sorted.length % 2 === 1) {\n75:     return sorted[mid];\n76:   }\n77:   return (sorted[mid - 1] + sorted[mid]) / 2;\n78: }\n79: \n80: /* --- 3. CORE TRUNCATION LOGIC --- */\n81: \n82: /**\n83:  * Truncate results based on confidence gap analysis.\n84:  *\n85:  * Algorithm:\n86:  * 1. If fewer than minResults results, return unchanged.\n87:  * 2. Compute consecutive score gaps.\n88:  * 3. Compute median gap.\n89:  * 4. Find first index >= (minResults - 1) where gap > 2 * medianGap.\n90:  * 5. Truncate at that index + 1 (keep results 0..cutoffIndex inclusive).\n91:  * 6. If no threshold-exceeding gap found, return all results unchanged.\n92:  *\n93:  * When SPECKIT_CONFIDENCE_TRUNCATION is disabled, passes results through unchanged.\n94:  *\n95:  * Results are expected to be pre-sorted by score descending. This function\n96:  * does NOT sort; it operates on the input order.\n97:  *\n98:  * @param results - Array of scored results (expected descending by score).\n99:  * @param options - Optional truncation options (minResults).\n100:  * @returns TruncationResult with the (possibly shortened) result array and audit metadata.\n101:  */\n102: function truncateByConfidence(\n103:   results: ScoredResult[],\n104:   options?: TruncationOptions,\n105: ): TruncationResult {\n106:   const minResults = options?.minResults ?? DEFAULT_MIN_RESULTS;\n107: \n108:   // Defensive: filter out results with NaN/Infinity scores\n109:   const validResults = results.filter(r => Number.isFinite(r.score));\n110: \n111:   // Defensive: sort descending by score. Callers should pre-sort for efficiency.\n112:   validResults.sort((a, b) => b.score - a.score);\n113: \n114:   const originalCount = validResults.length;\n115: \n116:   // Feature flag gate: pass through when disabled\n117:   if (!isConfidenceTruncationEnabled()) {\n118:     return {\n119:       results: [...validResults],\n120:       truncated: false,\n121:       originalCount,\n122:       truncatedCount: originalCount,\n123:       cutoffIndex: originalCount - 1,\n124:       medianGap: 0,\n125:       cutoffGap: 0,\n126:     };\n127:   }\n128: \n129:   // Not enough results to truncate\n130:   if (validResults.length <= minResults) {\n131:     return {\n132:       results: [...validResults],\n133:       truncated: false,\n134:       originalCount,\n135:       truncatedCount: originalCount,\n136:       cutoffIndex: originalCount - 1,\n137:       medianGap: 0,\n138:       cutoffGap: 0,\n139:     };\n140:   }\n141: \n142:   const scores = validResults.map(r => r.score);\n143:   const gaps = computeGaps(scores);\n144:   const medianGap = computeMedian(gaps);\n145:   const threshold = GAP_THRESHOLD_MULTIPLIER * medianGap;\n146: \n147:   // When medianGap is 0 (all same scores), no meaningful gap exists — return all\n148:   if (medianGap === 0) {\n149:     return {\n150:       results: [...validResults],\n151:       truncated: false,\n152:       originalCount,\n153:       truncatedCount: originalCount,\n154:       cutoffIndex: originalCount - 1,\n155:       medianGap: 0,\n156:       cutoffGap: 0,\n157:     };\n158:   }\n159: \n160:   // Search for the first gap that exceeds the threshold, starting from minResults - 1.\n161:   // Gap[i] is the gap between result i and result i+1.\n162:   // If gap[i] > threshold, we keep results 0..i (cutoffIndex = i).\n163:   let cutoffIndex = -1;\n164:   let cutoffGap = 0;\n165: \n166:   for (let i = minResults - 1; i < gaps.length; i++) {\n167:     if (gaps[i] > threshold) {\n168:       cutoffIndex = i;\n169:       cutoffGap = gaps[i];\n170:       break;\n171:     }\n172:   }\n173: \n174:   // No significant gap found — return all results\n175:   if (cutoffIndex === -1) {\n176:     return {\n177:       results: [...validResults],\n178:       truncated: false,\n179:       originalCount,\n180:       truncatedCount: originalCount,\n181:       cutoffIndex: originalCount - 1,\n182:       medianGap,\n183:       cutoffGap: 0,\n184:     };\n185:   }\n186: \n187:   // Truncate: keep validResults[0..cutoffIndex] inclusive\n188:   const truncatedResults = validResults.slice(0, cutoffIndex + 1);\n189: \n190:   return {\n191:     results: truncatedResults,\n192:     truncated: true,\n193:     originalCount,\n194:     truncatedCount: truncatedResults.length,\n195:     cutoffIndex,\n196:     medianGap,\n197:     cutoffGap,\n198:   };\n199: }\n200: \n201: /* --- 5. EXPORTS --- */\n202: \n203: export {\n204:   // Types\n205:   type ScoredResult,\n206:   type TruncationResult,\n207:   type TruncationOptions,\n208: \n209:   // Constants\n210:   DEFAULT_MIN_RESULTS,\n211:   GAP_THRESHOLD_MULTIPLIER,\n212: \n213:   // Functions\n214:   truncateByConfidence,\n215:   isConfidenceTruncationEnabled,\n216: \n217:   // Internal helpers (exported for testing)\n218:   computeGaps,\n219:   computeMedian,\n220: };\n\n(End of file - total 220 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Truncation\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Confidence-based result truncation\nimport { isConfidenceTruncationEnabled } from './search-flags.js';\n\n/* --- 1. TYPES & CONSTANTS --- */\n\n/** Generic scored result for truncation — supports both numeric and string IDs. */\ninterface ScoredResult {\n  id: number | string;\n  score: number;\n  [key: string]: unknown;\n}\n\n/** Result of a truncation operation with full audit metadata. */\ninterface TruncationResult {\n  results: ScoredResult[];\n  truncated: boolean;\n  originalCount: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-truncation.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Truncation\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Confidence-based result truncation\nimport { isConfidenceTruncationEnabled } from './search-flags.js';\n\n/* --- 1. TYPES & CONSTANTS --- */\n\n/** Generic scored result for truncation — supports both numeric and string IDs. */\ninterface ScoredResult {\n  id: number | string;\n  score: number;\n  [key: string]: unknown;\n}\n\n/** Result of a truncation operation with full audit metadata. */\ninterface TruncationResult {\n  results: ScoredResult[];\n  truncated: boolean;\n  originalCount: number;\n  truncatedCount: number;\n  /** Inclusive index of the last kept result (0-based). */\n  cutoffIndex: number;\n  medianGap: number;\n  cutoffGap: number;\n}\n\n/** Options for truncation behaviour. */\ninterface TruncationOptions {\n  /** Minimum number of results to always return, regardless of gap. Default: 3. */\n  minResults?: number;\n}\n\n/** Default minimum result count. */\nconst DEFAULT_MIN_RESULTS = 3;\n\n/** Gap multiplier: gap must exceed this multiple of the median gap to trigger truncation.\n * 2x median is the elbow heuristic — a gap twice the typical spread signals a relevance cliff. */\nconst GAP_THRESHOLD_MULTIPLIER = 2;\n\n/* --- 2. GAP ANALYSIS HELPERS --- */\n\n/**\n * Compute consecutive score gaps for a sorted (descending) score array.\n * gap[i] = scores[i] - scores[i+1]   for i in [0, n-2]\n * NaN and Infinity scores are filtered out before gap computation.\n * Returns empty array when fewer than 2 finite scores.\n *\n * @param scores - Descending-sorted array of raw scores.\n * @returns Array of consecutive score gaps (length = scores.length - 1).\n */\nfunction computeGaps(scores: number[]): number[] {\n  // NaN/Infinity from upstream bugs would corrupt gap statistics — filter them first\n  const finite = scores.filter(s => Number.isFinite(s));\n  if (finite.length < 2) return [];\n  const gaps: number[] = [];\n  for (let i = 0; i < finite.length - 1; i++) {\n    gaps.push(finite[i] - finite[i + 1]);\n  }\n  return gaps;\n}\n\n/**\n * Compute the median of an array of numbers.\n * Returns 0 for an empty array.\n *\n * @param values - Array of numeric values.\n * @returns Median value, or 0 for empty input.\n */\nfunction computeMedian(values: number[]): number {\n  if (values.length === 0) return 0;\n  const sorted = [...values].sort((a, b) => a - b);\n  const mid = Math.floor(sorted.length / 2);\n  if (sorted.length % 2 === 1) {\n    return sorted[mid];\n  }\n  return (sorted[mid - 1] + sorted[mid]) / 2;\n}\n\n/* --- 3. CORE TRUNCATION LOGIC --- */\n\n/**\n * Truncate results based on confidence gap analysis.\n *\n * Algorithm:\n * 1. If fewer than minResults results, return unchanged.\n * 2. Compute consecutive score gaps.\n * 3. Compute median gap.\n * 4. Find first index >= (minResults - 1) where gap > 2 * medianGap.\n * 5. Truncate at that index + 1 (keep results 0..cutoffIndex inclusive).\n * 6. If no threshold-exceeding gap found, return all results unchanged.\n *\n * When SPECKIT_CONFIDENCE_TRUNCATION is disabled, passes results through unchanged.\n *\n * Results are expected to be pre-sorted by score descending. This function\n * does NOT sort; it operates on the input order.\n *\n * @param results - Array of scored results (expected descending by score).\n * @param options - Optional truncation options (minResults).\n * @returns TruncationResult with the (possibly shortened) result array and audit metadata.\n */\nfunction truncateByConfidence(\n  results: ScoredResult[],\n  options?: TruncationOptions,\n): TruncationResult {\n  const minResults = options?.minResults ?? DEFAULT_MIN_RESULTS;\n\n  // Defensive: filter out results with NaN/Infinity scores\n  const validResults = results.filter(r => Number.isFinite(r.score));\n\n  // Defensive: sort descending by score. Callers should pre-sort for efficiency.\n  validResults.sort((a, b) => b.score - a.score);\n\n  const originalCount = validResults.length;\n\n  // Feature flag gate: pass through when disabled\n  if (!isConfidenceTruncationEnabled()) {\n    return {\n      results: [...validResults],\n      truncated: false,\n      originalCount,\n      truncatedCount: originalCount,\n      cutoffIndex: originalCount - 1,\n      medianGap: 0,\n      cutoffGap: 0,\n    };\n  }\n\n  // Not enough results to truncate\n  if (validResults.length <= minResults) {\n    return {\n      results: [...validResults],\n      truncated: false,\n      originalCount,\n      truncatedCount: originalCount,\n      cutoffIndex: originalCount - 1,\n      medianGap: 0,\n      cutoffGap: 0,\n    };\n  }\n\n  const scores = validResults.map(r => r.score);\n  const gaps = computeGaps(scores);\n  const medianGap = computeMedian(gaps);\n  const threshold = GAP_THRESHOLD_MULTIPLIER * medianGap;\n\n  // When medianGap is 0 (all same scores), no meaningful gap exists — return all\n  if (medianGap === 0) {\n    return {\n      results: [...validResults],\n      truncated: false,\n      originalCount,\n      truncatedCount: originalCount,\n      cutoffIndex: originalCount - 1,\n      medianGap: 0,\n      cutoffGap: 0,\n    };\n  }\n\n  // Search for the first gap that exceeds the threshold, starting from minResults - 1.\n  // Gap[i] is the gap between result i and result i+1.\n  // If gap[i] > threshold, we keep results 0..i (cutoffIndex = i).\n  let cutoffIndex = -1;\n  let cutoffGap = 0;\n\n  for (let i = minResults - 1; i < gaps.length; i++) {\n    if (gaps[i] > threshold) {\n      cutoffIndex = i;\n      cutoffGap = gaps[i];\n      break;\n    }\n  }\n\n  // No significant gap found — return all results\n  if (cutoffIndex === -1) {\n    return {\n      results: [...validResults],\n      truncated: false,\n      originalCount,\n      truncatedCount: originalCount,\n      cutoffIndex: originalCount - 1,\n      medianGap,\n      cutoffGap: 0,\n    };\n  }\n\n  // Truncate: keep validResults[0..cutoffIndex] inclusive\n  const truncatedResults = validResults.slice(0, cutoffIndex + 1);\n\n  return {\n    results: truncatedResults,\n    truncated: true,\n    originalCount,\n    truncatedCount: truncatedResults.length,\n    cutoffIndex,\n    medianGap,\n    cutoffGap,\n  };\n}\n\n/* --- 5. EXPORTS --- */\n\nexport {\n  // Types\n  type ScoredResult,\n  type TruncationResult,\n  type TruncationOptions,\n\n  // Constants\n  DEFAULT_MIN_RESULTS,\n  GAP_THRESHOLD_MULTIPLIER,\n\n  // Functions\n  truncateByConfidence,\n  isConfidenceTruncationEnabled,\n\n  // Internal helpers (exported for testing)\n  computeGaps,\n  computeMedian,\n};","lineStart":1,"lineEnd":220,"totalLines":220,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-truncation.ts","time":{"start":1781764200887,"end":1781764200892}},"metadata":{"openai":{"itemId":"fc_0fbe2d6ffa9859b5016a339068c17c8191802240a12173f224"}},"id":"prt_ed96c19b6001ZZhsK26fZYUegM","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96bef4d001hK6GvmLmXQgcOA"}}
