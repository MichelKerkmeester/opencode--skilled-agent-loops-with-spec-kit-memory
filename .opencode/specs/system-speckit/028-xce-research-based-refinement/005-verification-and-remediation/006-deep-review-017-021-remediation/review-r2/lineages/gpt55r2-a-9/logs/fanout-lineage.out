. memoryState priority filter — rows below minState are removed\n\n  Line 129:  * Remove rows whose `memoryState` falls below `minState` priority and,\n\n  Line 137:  * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n\n  Line 143:   minState: string,\n\n  Line 146:   const normalizedMinState = normalizeStateValue(minState);\n\n  Line 219:    5. MAIN: executeStage4\n\n  Line 242: export async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n\n  Line 257:     config.minState,\n\n  Line 293:     minState: config.minState,\n\n  Line 334:         minState: config.minState,\n","metadata":{"matches":70,"truncated":false},"title":"executePipeline|executeStage1|executeStage2|executeStage3|executeStage4|includeArchived|minState|rerank","time":{"start":1781764169622,"end":1781764169631}},"metadata":{"openai":{"itemId":"fc_0f97a65d44e552c3016a3390497c588191b569068d0e866ff2"}},"id":"prt_ed96b9f78001NtBPpf1DCiXMsS","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b7720001P36CsFJ248isTS"}}
