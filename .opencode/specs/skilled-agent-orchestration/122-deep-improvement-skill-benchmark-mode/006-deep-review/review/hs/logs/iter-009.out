{"type":"tool_use","timestamp":1780205227874,"sessionID":"ses_1838070fafferbmuIbMyAqlS9c","part":{"type":"tool","tool":"read","callID":"call_function_u40ylkyeatzy_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/shared/loop-host.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/shared/loop-host.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * scripts/loop-host.cjs\n6:  *\n7:  * Mode-switching entry point for deep-improvement. Routes between the\n8:  * existing `agent-improvement` scoring path and the new `model-benchmark`\n9:  * pipeline. This is the seam host that was previously missing\n10:  * (deep-improvement has no loop.cjs — orchestration is journal-based).\n11:  *\n12:  * Backward-compat contract: with `--mode=agent-improvement` OR no\n13:  * `--mode` flag, behavior is identical — both route to score-candidate.cjs with\n14:  * the same arguments, so the produced score/state output is byte-identical.\n15:  *\n16:  * Usage:\n17:  *   agent-improvement (default):\n18:  *     node loop-host.cjs [--mode=agent-improvement] --candidate=<path> [--baseline=<path>] [--output=<path>]\n19:  *   model-benchmark:\n20:  *     node loop-host.cjs --mode=model-benchmark --profile=<path-or-id> --outputs-dir=<path> \\\n21:  *        [--output=<path>] [--state-log=<path>] [--label=<string>] [--profiles-dir=<path>] \\\n22:  *        [--scorer=<pattern|5dim>] [--grader=<noop|mock|llm>]\n23:  *\n24:  * Unknown --mode values warn to stderr and fall back to agent-improvement.\n25:  */\n26: \n27: const path = require('path');\n28: const { spawnSync } = require('child_process');\n29: \n30: const SCRIPTS_ROOT = __dirname;\n31: const VALID_MODES = new Set(['agent-improvement', 'model-benchmark', 'skill-benchmark']);\n32: \n33: // Lane separation: planInvocation() returns BARE script names (e.g.\n34: // 'score-candidate.cjs') to keep the backward-compat identity plan\n35: // byte-identical. The real on-disk lane lives in sibling lane dirs relative to\n36: // this file (now scripts/shared/). resolveScriptPath maps a bare name to its\n37: // lane path at SPAWN time so the plan output never carries lane segments.\n38: const LANE_A = new Set([\n39:   'score-candidate.cjs',\n40:   'generate-profile.cjs',\n41:   'rollback-candidate.cjs',\n42:   'candidate-lineage.cjs',\n43:   'scan-integration.cjs',\n44:   'check-mirror-drift.cjs',\n45:   'trade-off-detector.cjs',\n46:   'benchmark-stability.cjs',\n47: ]);\n48: const LANE_MODEL_BENCHMARK = new Set([\n49:   'run-benchmark.cjs',\n50:   'dispatch-model.cjs',\n51: ]);\n52: // Lane C (skill-benchmark): the orchestrator the run resolves to. Sub-scripts\n53: // (router-replay, contamination-lint, d5-connectivity, parse-resource-loads,\n54: // score-skill-benchmark, build-report) are required internally by the\n55: // orchestrator, so only the entry script needs lane-path resolution here.\n56: const LANE_SKILL_BENCHMARK = new Set([\n57:   'run-skill-benchmark.cjs',\n58: ]);\n59: \n60: // Optional flags loop-host forwards to run-skill-benchmark.cjs, in forwarding\n61: // order. --skill and --outputs-dir are required and handled separately. Keep\n62: // aligned with run-skill-benchmark.cjs's accepted options.\n63: const SKILL_BENCHMARK_RUN_OPTIONS = [\n64:   'profile',\n65:   'fixtures-dir',\n66:   'output',\n67:   'state-log',\n68:   'label',\n69:   'trace-mode',\n70:   'grader',\n71:   'advisor-mode',\n72:   'k-runs',\n73: ];\n74: \n75: // Single source of truth for the optional model-benchmark flags loop-host\n76: // forwards to run-benchmark.cjs (one shared benchmark option schema). Order is\n77: // the forwarding order. --profile and --outputs-dir are required and handled\n78: // separately. Keep this aligned with run-benchmark.cjs's accepted options.\n79: const BENCHMARK_RUN_OPTIONS = [\n80:   'output',\n81:   'state-log',\n82:   'label',\n83:   'profiles-dir',\n84:   'integration-report',\n85:   'scorer',\n86:   'grader',\n87: ];\n88: \n89: // The fixture materializer also needs --profiles-dir so a profile passed by ID\n90: // (not a path) resolves identically in BOTH steps. --profile and\n91: // --outputs-dir are forwarded explicitly; this lists the remaining\n92: // materialize-relevant pass-through flags.\n93: const BENCHMARK_MATERIALIZE_OPTIONS = [\n94:   'profiles-dir',\n95: ];\n96: \n97: function resolveScriptPath(scriptName) {\n98:   if (LANE_A.has(scriptName)) {\n99:     return path.join(SCRIPTS_ROOT, '..', 'agent-improvement', scriptName);\n100:   }\n101:   if (LANE_MODEL_BENCHMARK.has(scriptName)) {\n102:     return path.join(SCRIPTS_ROOT, '..', 'model-benchmark', scriptName);\n103:   }\n104:   if (LANE_SKILL_BENCHMARK.has(scriptName)) {\n105:     return path.join(SCRIPTS_ROOT, '..', 'skill-benchmark', scriptName);\n106:   }\n107:   // Other shared scripts (materialize-benchmark-fixtures, promote-candidate,\n108:   // reduce-state, improvement-journal, mutation-coverage) live alongside this file.\n109:   return path.join(SCRIPTS_ROOT, scriptName);\n110: }\n111: \n112: function parseArgs(argv) {\n113:   const args = {};\n114:   for (let index = 0; index < argv.length; index += 1) {\n115:     const entry = argv[index];\n116:     const match = /^--([a-z][a-z0-9-]*)(?:=(.*))?$/.exec(entry);\n117:     if (!match) continue;\n118:     const key = match[1];\n119:     if (match[2] !== undefined) {\n120:       // =-form: byte-identical to the original behavior (identity contract).\n121:       args[key] = match[2];\n122:       continue;\n123:     }\n124:     // Bare --key: if the next token is a value (does not start with '--'),\n125:     // consume it as the space-form value; otherwise it stays a boolean flag.\n126:     // The Lane B command surface invokes loop-host with space-form\n127:     // (--profile {p} --scorer 5dim --grader noop), so these must bind to the\n128:     // following token rather than parse as booleans.\n129:     const next = argv[index + 1];\n130:     if (next !== undefined && !next.startsWith('--')) {\n131:       args[key] = next;\n132:       index += 1;\n133:     } else {\n134:       args[key] = true;\n135:     }\n136:   }\n137:   return args;\n138: }\n139: \n140: function resolveMode(rawMode) {\n141:   if (rawMode === undefined) return 'agent-improvement';\n142:   if (VALID_MODES.has(rawMode)) return rawMode;\n143:   process.stderr.write(`loop-host: unknown mode '${rawMode}', defaulting to 'agent-improvement'\\n`);\n144:   return 'agent-improvement';\n145: }\n146: \n147: /**\n148:  * Pure planner: map (mode, args) -> the ordered script invocations to run.\n149:  * Planning is separated from execution so the backward-compat identity gate\n150:  * the identity gate can assert byte-identical plans for the default and explicit\n151:  * agent-improvement routes without spawning anything.\n152:  *\n153:  * @returns {{ ok: true, steps: Array<{script: string, args: string[]}> } | { ok: false, error: string }}\n154:  */\n155: function planInvocation(mode, args) {\n156:   if (mode === 'model-benchmark') {\n157:     if (!args.profile || !args['outputs-dir']) {\n158:       return { ok: false, error: 'model-benchmark: missing required --profile=<path-or-id> and --outputs-dir=<path>' };\n159:     }\n160:     // materialize MUST run (and succeed) before run-benchmark, else scoring\n161:     // silently produces all-zero \"missing-output\" results. These scripts use\n162:     // space-separated args.\n163:     //\n164:     // Both steps share one option schema (BENCHMARK_* lists) so forwarding stays\n165:     // in sync with run-benchmark.cjs and the materializer, instead of a hand-rolled\n166:     // per-flag chain that silently drifts.\n167:     // run-benchmark.cjs forwards scorer/grader/integration-report so the journal\n168:     // and report.json agree on the requested method; the materializer forwards\n169:     // --profiles-dir so a profile-by-ID resolves identically in both steps.\n170:     const materializeArgs = ['--profile', args.profile, '--outputs-dir', args['outputs-dir']];\n171:     for (const opt of BENCHMARK_MATERIALIZE_OPTIONS) {\n172:       if (args[opt] !== undefined) materializeArgs.push(`--${opt}`, String(args[opt]));\n173:     }\n174:     const benchArgs = ['--profile', args.profile, '--outputs-dir', args['outputs-dir']];\n175:     for (const opt of BENCHMARK_RUN_OPTIONS) {\n176:       if (args[opt] !== undefined) benchArgs.push(`--${opt}`, String(args[opt]));\n177:     }\n178:     return {\n179:       ok: true,\n180:       steps: [\n181:         { script: 'materialize-benchmark-fixtures.cjs', args: materializeArgs },\n182:         { script: 'run-benchmark.cjs', args: benchArgs },\n183:       ],\n184:     };\n185:   }\n186:   if (mode === 'skill-benchmark') {\n187:     if (!args.skill || !args['outputs-dir']) {\n188:       return { ok: false, error: 'skill-benchmark: missing required --skill=<skill-root-or-id> and --outputs-dir=<path>' };\n189:     }\n190:     // Single orchestrator step: run-skill-benchmark.cjs internally sequences\n191:     // D5-gate -> router-replay -> (optional live) -> trace-parse -> score ->\n192:     // report, so the plan stays one step (unlike Lane B's materialize+run pair).\n193:     // Lane C scripts use space-separated args.\n194:     const skillArgs = ['--skill', args.skill, '--outputs-dir', args['outputs-dir']];\n195:     for (const opt of SKILL_BENCHMARK_RUN_OPTIONS) {\n196:       if (args[opt] !== undefined) skillArgs.push(`--${opt}`, String(args[opt]));\n197:     }\n198:     return { ok: true, steps: [{ script: 'run-skill-benchmark.cjs', args: skillArgs }] };\n199:   }\n200:   // agent-improvement (default). score-candidate.cjs uses key=value args.\n201:   if (!args.candidate) {\n202:     return { ok: false, error: 'agent-improvement: missing required --candidate=<path>' };\n203:   }\n204:   const scoreArgs = [`--candidate=${args.candidate}`];\n205:   if (args.baseline) scoreArgs.push(`--baseline=${args.baseline}`);\n206:   if (args.output) scoreArgs.push(`--output=${args.output}`);\n207:   return { ok: true, steps: [{ script: 'score-candidate.cjs', args: scoreArgs }] };\n208: }\n209: \n210: function runNode(scriptName, scriptArgs) {\n211:   const scriptPath = resolveScriptPath(scriptName);\n212:   const res = spawnSync('node', [scriptPath, ...scriptArgs], {\n213:     stdio: 'inherit',\n214:     encoding: 'utf8',\n215:   });\n216:   return res.status == null ? 1 : res.status;\n217: }\n218: \n219: function runPlan(plan) {\n220:   if (!plan.ok) {\n221:     process.stderr.write(`loop-host: ${plan.error}\\n`);\n222:     return 2;\n223:   }\n224:   for (const step of plan.steps) {\n225:     const exit = runNode(step.script, step.args);\n226:     if (exit !== 0) {\n227:       process.stderr.write(`loop-host: ${step.script} failed (exit ${exit}); aborting remaining steps\\n`);\n228:       return exit;\n229:     }\n230:   }\n231:   return 0;\n232: }\n233: \n234: function main() {\n235:   const args = parseArgs(process.argv.slice(2));\n236:   const mode = resolveMode(args.mode);\n237:   process.exit(runPlan(planInvocation(mode, args)));\n238: }\n239: \n240: if (require.main === module) main();\n241: \n242: module.exports = { parseArgs, resolveMode, planInvocation, resolveScriptPath, VALID_MODES, LANE_SKILL_BENCHMARK };\n\n(End of file - total 242 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * scripts/loop-host.cjs\n *\n * Mode-switching entry point for deep-improvement. Routes between the\n * existing `agent-improvement` scoring path and the new `model-benchmark`\n * pipeline. This is the seam host that was previously missing\n * (deep-improvement has no loop.cjs — orchestration is journal-based).\n *\n * Backward-compat contract: with `--mode=agent-improvement` OR no\n * `--mode` flag, behavior is identical — both route to score-candidate.cjs with\n * the same arguments, so the produced score/state output is byte-identical.\n *\n * Usage:\n *   agent-improvement (default):\n *     node loop-host.cjs [--mode=agent-improvement] --candidate=<path> [--baseline=<path>] [--output=<path>]\n *   model-benchmark:\n *     node loop-host.cjs --mode=model-benchmark --profile=<path-or-id> --outputs-dir=<path> \\","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/shared/loop-host.cjs","time":{"start":1780205227866,"end":1780205227873}},"id":"prt_e7c800d5b001UIsweq3eIzRLfq","sessionID":"ses_1838070fafferbmuIbMyAqlS9c","messageID":"msg_e7c7fce03001bKjZX4n1w9Tw3T"}}
