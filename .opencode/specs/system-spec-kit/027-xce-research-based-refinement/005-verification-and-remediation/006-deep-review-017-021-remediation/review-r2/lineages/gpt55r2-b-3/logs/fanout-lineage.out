{"type":"tool_use","timestamp":1781762031557,"sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","part":{"type":"tool","tool":"read","callID":"call_nPeTVpruwzfjzoVjitZFULHx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2368,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2368:             title: routedParsed.title ?? '',\n2369:             qualityScore: routedParsed.qualityScore,\n2370:             qualityFlags: routedParsed.qualityFlags,\n2371:             rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2372:             message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2373:             qualityGate: {\n2374:               pass: false,\n2375:               reasons: qualityGateResult.reasons,\n2376:               layers: qualityGateResult.layers,\n2377:             },\n2378:           };\n2379:         }\n2380: \n2381:         if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n2382:           console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2383:         }\n2384: \n2385:         if (qualityGateResult.wouldReject) {\n2386:           console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2387:         }\n2388:       } catch (qgErr: unknown) {\n2389:         const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n2390:         console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n2391:         // Quality gate errors must not block saves\n2392:       }\n2393:     }\n2394: \n2395:     const duplicatePrecheck = checkContentHashDedup(\n2396:       database,\n2397:       routedParsed,\n2398:       force,\n2399:       validation.warnings,\n2400:       samePathDedupExclusion,\n2401:       scope,\n2402:     );\n2403:     if (duplicatePrecheck) {\n2404:       await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n2405:       return duplicatePrecheck;\n2406:     }\n2407: \n2408:     persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n2409: \n2410:     // PE GATING\n2411:     const peResult = evaluateAndApplyPeDecision(\n2412:       database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope, writeProvenance,\n2413:     );\n2414:     if (peResult.earlyReturn) return peResult.earlyReturn;\n2415: \n2416:     let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n2417:       earlyReturn: null,\n2418:       warnings: [],\n2419:       saveTimeReconsolidation: {\n2420:         status: 'skipped',\n2421:         persistedState: { kind: 'create' },\n2422:       },\n2423:     };\n2424: \n2425:     // Complete async reconsolidation planning before chunking or\n2426:     // taking the SQLite writer lock, so chunked saves do not bypass the gate\n2427:     // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n2428:     reconResult = await runReconsolidationIfEnabled(\n2429:       database,\n2430:       routedParsed,\n2431:       routedFilePath,\n2432:       force,\n2433:       embedding,\n2434:       scope,\n2435:       { plannerMode, provenance: writeProvenance },\n2436:     );\n2437:     if (reconResult.earlyReturn) return reconResult.earlyReturn;\n2438:     if (reconResult.saveTimeReconsolidation.status === 'failed') {\n2439:       return buildSaveTimeReconsolidationFailureResult({\n2440:         parsed: routedParsed,\n2441:         validation,\n2442:         reconWarnings: reconResult.warnings,\n2443:         failure: {\n2444:           status: 'failed',\n2445:           reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n2446:           ...(reconResult.saveTimeReconsolidation.warnings\n2447:             ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n2448:             : {}),\n2449:           ...(reconResult.saveTimeReconsolidation.persistedState\n2450:             ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n2451:             : {}),\n2452:         },\n2453:       });\n2454:     }\n2455: \n2456:     if (shouldChunkContent) {\n2457:       console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n2458:       const chunkedInsertTracker = createChunkedInsertTracker();\n2459:       const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n2460:         force,\n2461:         scope,\n2462:         provenance: writeProvenance,\n2463:         applyPostInsertMetadata: (db, memoryId, fields) => {\n2464:           applyPostInsertMetadata(db, memoryId, fields);\n2465:           trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n2466:         },\n2467:       });\n2468: \n2469:       if (\n2470:         peResult.supersededId != null\n2471:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2472:       ) {\n2473:         try {\n2474:           const finalizeChunkedPeTx = database.transaction(() => {\n2475:             if (chunkedResult.id > 0) {\n2476:               recordCrossPathPeSupersedes(\n2477:                 database,\n2478:                 chunkedResult.id,\n2479:                 peResult.supersededId,\n2480:                 samePathExisting?.id ?? null,\n2481:                 peResult.decision.reason,\n2482:               );\n2483:             }\n2484:             if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n2485:               throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2486:             }\n2487:           });\n2488:           finalizeChunkedPeTx.immediate();\n2489:         } catch (supersedeErr: unknown) {\n2490:           const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n2491:           const cleanupSuffix = cleanup.cleaned\n2492:             ? ' Rolled back the newly created chunk tree.'\n2493:             : cleanup.attempted && cleanup.error\n2494:               ? ` Cleanup failed: ${cleanup.error}`\n2495:               : '';\n2496:           return {\n2497:             ...chunkedResult,\n2498:             status: 'error',\n2499:             error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n2500:             message: `Chunked indexing succeeded, but predecessor ${peResult.supersededId} could not be superseded.${cleanupSuffix}`,\n2501:           };\n2502:         }\n2503:       }\n2504: \n2505:       if (\n2506:         shouldPersistFinalizedFile\n2507:         && finalizedFileContent\n2508:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2509:       ) {\n2510:         try {\n2511:           await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n2512:         } catch (finalizeErr: unknown) {\n2513:           finalizeWarning = `Quality-loop file persistence failed after chunked indexing: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}`;\n2514:           console.warn(`[memory-save] ${finalizeWarning}`);\n2515:         }\n2516:       }\n2517: \n2518:       if (peResult.decision.action !== 'CREATE') {\n2519:         chunkedResult.pe_action = peResult.decision.action;\n2520:         chunkedResult.pe_reason = peResult.decision.reason;\n2521:       }\n2522:       if (peResult.supersededId != null) {\n2523:         chunkedResult.superseded_id = peResult.supersededId;\n2524:       }\n2525:       if (Array.isArray(reconResult.warnings) && reconResult.warnings.length > 0) {\n2526:         const existingWarnings = Array.isArray(chunkedResult.warnings)\n2527:           ? [...(chunkedResult.warnings as string[])]\n2528:           : [];\n2529:         chunkedResult.warnings = [...existingWarnings, ...reconResult.warnings];\n2530:       }\n2531:       if (reconResult.assistiveRecommendation) {\n2532:         reconResult.assistiveRecommendation.advisory_stale = true;\n2533:         chunkedResult.assistiveRecommendation = reconResult.assistiveRecommendation;\n2534:       }\n2535:       chunkedResult.saveTimeReconsolidation = reconResult.saveTimeReconsolidation;\n2536: \n2537:       return appendResultWarning(chunkedResult, finalizeWarning);\n2538:     }\n2539: \n2540:     // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n2541:     // atomicity. Uses database.transaction() so inner transaction() calls in\n2542:     // createMemoryRecord / index_memory correctly nest via SAVEPOINTs instead\n2543:     // of failing with \"cannot start a transaction within a transaction\".\n2544:     // withSpecFolderLock handles in-process serialization; this transaction\n2545:     // provides defense-in-depth against multi-process races.\n2546:     let existing: { id: number; content_hash: string } | undefined;\n2547: \n2548:     // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n2549:     // safe outside the transaction and this avoids an early-return inside the\n2550:     // transaction callback (which would COMMIT an empty tx unnecessarily).\n2551:     const dupResult = checkContentHashDedup(\n2552:       database,\n2553:       routedParsed,\n2554:       force,\n2555:       validation.warnings,\n2556:       samePathDedupExclusion,\n2557:       scope,\n2558:     );\n2559:     if (dupResult) {\n2560:       await repairReplayEnrichmentIfNeeded(database, dupResult.id, routedParsed);\n2561:       return dupResult;\n2562:     }\n2563: \n2564:     const requestedScope = getRequestedScope(scope);\n2565:     const writeTransaction = database.transaction((): number => {\n2566:       if (indexingOrigin !== 'scan' && embedding) {\n2567:         const complementRecheck = findScopeFilteredCandidates({\n2568:           database,\n2569:           embedding,\n2570:           parsed: routedParsed,\n2571:           requestedScope,\n2572:           limit: 1,\n2573:           minSimilarity: 50,\n2574:           overfetchMultiplier: 3,\n2575:         });\n2576:         const topCandidate = complementRecheck.candidates[0];\n2577:         if (topCandidate) {\n2578:           const transactionalAction = determineAction(topCandidate.similarity);\n2579:           if (transactionalAction !== 'complement') {\n2580:             throw new SaveTimeReconsolidationAbort({\n2581:               status: 'failed',\n2582:               reason: 'candidate_changed',\n2583:               warnings: [\n2584:                 `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n2585:               ],\n2586:               persistedState: {\n2587:                 kind: transactionalAction,\n2588:                 candidateMemoryIds: [topCandidate.id],\n2589:               },\n2590:             });\n2591:           }\n2592:         }\n2593:       }\n2594: \n2595:       // CREATE NEW MEMORY\n2596:       existing = findSamePathExistingMemory(\n2597:         database,\n2598:         routedParsed.specFolder,\n2599:         canonicalFilePath,\n2600:         routedFilePath,\n2601:         scope,\n2602:         recordIdentity,\n2603:       ) as { id: number; content_hash: string } | undefined;\n2604: \n2605:       // A same-path re-index whose file content changed appends a new version\n2606:       // row; the prior row for this logical key is retired below so re-indexing\n2607:       // replaces in place rather than leaving a deprecated duplicate. Scoped to\n2608:       // this branch only — PE-gate / reconsolidation lineage (createMemoryRecord)\n2609:       // is intentionally preserved.\n2610:       const samePathSupersededPredecessorId =\n2611:         existing && existing.content_hash !== routedParsed.contentHash ? existing.id : null;\n2612: \n2613:       // Retire the same-path predecessor before inserting the new version so the\n2614:       // active-row uniqueness guard holds at insert time. Deprecating (not deleting)\n2615:       // keeps the predecessor row, its lineage chain, and its history intact while\n2616:       // removing it from the active-row guard; the new version supersedes it in place.\n2617:       const reindexTierCarry = samePathSupersededPredecessorId != null\n2618:         ? retirePredecessorForActiveReindex(database, samePathSupersededPredecessorId)\n2619:         : null;\n2620: \n2621:       const memoryId = samePathSupersededPredecessorId != null\n2622:         ? createAppendOnlyMemoryRecord({\n2623:             database,\n2624:             parsed: routedParsed,\n2625:             filePath: routedFilePath,\n2626:             embedding,\n2627:             embeddingFailureReason,\n2628:             predecessorMemoryId: samePathSupersededPredecessorId,\n2629:             anchorId: recordIdentity.targetAnchorId,\n2630:             tenantId: scope.tenantId,\n2631:             userId: scope.userId,\n2632:             agentId: scope.agentId,\n2633:             sessionId: scope.sessionId,\n2634:             actor: 'mcp:memory_save',\n2635:           })\n2636:         : createMemoryRecord(\n2637:             database,\n2638:             routedParsed,\n2639:             routedFilePath,\n2640:             embedding,\n2641:             embeddingFailureReason,\n2642:             peResult.decision,\n2643:             scope,\n2644:             recordIdentity,\n2645:             writeProvenance,\n2646:           );\n2647: \n2648:       if (samePathSupersededPredecessorId != null) {\n2649:         applyWriteProvenance(database, memoryId, writeProvenance);\n2650:       }\n2651: \n2652:       // A human's tier decision on the retired predecessor carries forward to the\n2653:       // reindexed successor. Re-stamp after provenance so the manual tier and its\n2654:       // human source-kind survive the reindex instead of resetting to the default.\n2655:       if (reindexTierCarry != null) {\n2656:         database\n2657:           .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n2658:           .run(reindexTierCarry.importanceTier, memoryId);\n2659:         persistSourceKind(database, memoryId, reindexTierCarry.sourceKind as SourceKind);\n2660:       }\n2661: \n2662:       // F1.01 fix: Mark superseded memory AFTER new record creation, inside\n2663:       // the same transaction, so a creation failure rolls back both operations.\n2664:       if (peResult.supersededId != null) {\n2665:         const supersededOk = markMemorySuperseded(peResult.supersededId);\n2666:         // C5-3: Supersede failure should abort the transaction\n2667:         if (!supersededOk) {\n2668:           throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2669:         }\n2670:       }\n2671: \n2672:       recordLineageVersion(database, {\n2673:         memoryId,\n2674:         predecessorMemoryId: samePathSupersededPredecessorId,\n2675:         actor: 'mcp:memory_save',\n2676:         transitionEvent: samePathSupersededPredecessorId != null ? 'SUPERSEDE' : 'CREATE',\n2677:       });\n2678:       markEnrichmentPending(database, memoryId, POST_INSERT_ENRICHMENT_VERSION);\n2679: \n2680:       return memoryId;\n2681:     });\n2682: \n2683:     let id: number;\n2684:     try {\n2685:       id = writeTransaction.immediate();\n2686:     } catch (error: unknown) {\n2687:       if (error instanceof SaveTimeReconsolidationAbort) {\n2688:         return buildSaveTimeReconsolidationFailureResult({\n2689:           parsed: routedParsed,\n2690:           validation,\n2691:           reconWarnings: reconResult.warnings,\n2692:           failure: error.result,\n2693:           message: `Save aborted before commit: ${error.result.reason}`,\n2694:         });\n2695:       }\n2696:       throw error;\n2697:     }\n2698: \n2699:     if (shouldPersistFinalizedFile && finalizedFileContent) {\n2700:       try {\n2701:         await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n2702:       } catch (finalizeErr: unknown) {\n2703:         finalizeWarning = `[file-persistence-failed] Quality-loop file persistence failed after DB commit: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}. DB row committed — manual file recovery may be needed.`;\n2704:         console.warn(`[memory-save] ${finalizeWarning}`);\n2705:       }\n2706:     }\n2707: \n2708:     // Data integrity: clean stale auto-entities before re-extraction on update\n2709:     // When a memory is superseded or replaced in-place, purge the predecessor's\n2710:     // auto-entity rows so the entity catalog reflects only active content.\n2711:     if (existing && existing.id !== id) {\n2712:       try {\n2713:         refreshAutoEntitiesForMemory(database, existing.id, []);\n2714:         console.error(`[memory-save] Cleaned stale auto-entities for superseded memory #${existing.id}`);\n2715:       } catch (entityCleanupErr: unknown) {\n2716:         // Entity cleanup failure must not block save — log and continue\n2717:         console.warn(`[memory-save] Auto-entity cleanup for #${existing.id} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n2718:       }\n2719:     }\n2720:     if (peResult.supersededId != null && peResult.supersededId !== existing?.id) {\n2721:       try {\n2722:         refreshAutoEntitiesForMemory(database, peResult.supersededId, []);\n2723:         console.error(`[memory-save] Cleaned stale auto-entities for PE-superseded memory #${peResult.supersededId}`);\n2724:       } catch (entityCleanupErr: unknown) {\n2725:         console.warn(`[memory-save] Auto-entity cleanup for PE #${peResult.supersededId} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n2726:       }\n2727:     }\n2728: \n2729:     if (embedding) {\n2730:       try {\n2731:         recordNearDuplicateCheck({\n2732:           database,\n2733:           memoryId: id,\n2734:           specFolder: routedParsed.specFolder,\n2735:           contentHash: routedParsed.contentHash,\n2736:           embedding,\n2737:           scope,\n2738:         });\n2739:       } catch (error: unknown) {\n2740:         const message = error instanceof Error ? error.message : String(error);\n2741:         console.warn(`[memory-save] Near-duplicate advisory skipped: ${message}`);\n2742:       }\n2743:     }\n2744: \n2745:     // POST-INSERT ENRICHMENT: causal links, entities, summaries, entity linking.\n2746:     // When enrichment is enabled and async (default), run the bundle in the background so the\n2747:     // save returns immediately. The row was marked enrichment-pending inside the commit\n2748:     // transaction (markEnrichmentPending), so a crash before the background run completes is\n2749:     // recovered by the pending-marker replay/backfill path. SPECKIT_POST_INSERT_ENRICHMENT_SYNC\n2750:     // forces synchronous execution when a caller needs the graph fresh in the same response.\n2751:     let postInsertEnrichmentResult: PostInsertEnrichmentResult;\n2752:     if (shouldRunPostInsertEnrichment(plannerMode) && isPostInsertEnrichmentAsync()) {\n2753:       scheduleBackgroundEnrichment(id, routedParsed);\n2754:       postInsertEnrichmentResult = buildDeferredEnrichmentResult('async-background');\n2755:     } else {\n2756:       postInsertEnrichmentResult = await runPostInsertEnrichmentIfEnabled(\n2757:         database,\n2758:         id,\n2759:         routedParsed,\n2760:         { plannerMode },\n2761:       );\n2762:       recordEnrichmentResult(database, id, postInsertEnrichmentResult);\n2763:       emitPostInsertEnrichmentSubscribers(id, 'post-insert-enrichment');\n2764:     }\n2765:     const { causalLinksResult, enrichmentStatus, executionStatus } = postInsertEnrichmentResult;\n2766: \n2767:     if (reconResult.assistiveRecommendation) {\n2768:       reconResult.assistiveRecommendation.advisory_stale = true;\n2769:       if (reconResult.saveTimeReconsolidation.persistedState) {\n2770:         reconResult.saveTimeReconsolidation.persistedState.advisory_stale = true;\n2771:       }\n2772:     }\n2773: \n2774:     // BUILD RESULT\n2775:     return appendResultWarning(buildIndexResult({\n2776:       database,\n2777:       existing,\n2778:       embeddingStatus,\n2779:       id,\n2780:       parsed: routedParsed,\n2781:       validation,\n2782:       reconWarnings: reconResult.warnings,\n2783:       peDecision: peResult.decision,\n2784:       embeddingFailureReason,\n2785:       asyncEmbedding,\n2786:       causalLinksResult,\n2787:       enrichmentStatus,\n\n(Showing lines 2368-2787 of 4082. Use offset=2788 to continue.)\n</content>","metadata":{"preview":"            title: routedParsed.title ?? '',\n            qualityScore: routedParsed.qualityScore,\n            qualityFlags: routedParsed.qualityFlags,\n            rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            qualityGate: {\n              pass: false,\n              reasons: qualityGateResult.reasons,\n              layers: qualityGateResult.layers,\n            },\n          };\n        }\n\n        if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n          console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n\n        if (qualityGateResult.wouldReject) {\n          console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"            title: routedParsed.title ?? '',\n            qualityScore: routedParsed.qualityScore,\n            qualityFlags: routedParsed.qualityFlags,\n            rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            qualityGate: {\n              pass: false,\n              reasons: qualityGateResult.reasons,\n              layers: qualityGateResult.layers,\n            },\n          };\n        }\n\n        if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n          console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n\n        if (qualityGateResult.wouldReject) {\n          console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n      } catch (qgErr: unknown) {\n        const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n        console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n        // Quality gate errors must not block saves\n      }\n    }\n\n    const duplicatePrecheck = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (duplicatePrecheck) {\n      await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n      return duplicatePrecheck;\n    }\n\n    persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n\n    // PE GATING\n    const peResult = evaluateAndApplyPeDecision(\n      database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope, writeProvenance,\n    );\n    if (peResult.earlyReturn) return peResult.earlyReturn;\n\n    let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n      earlyReturn: null,\n      warnings: [],\n      saveTimeReconsolidation: {\n        status: 'skipped',\n        persistedState: { kind: 'create' },\n      },\n    };\n\n    // Complete async reconsolidation planning before chunking or\n    // taking the SQLite writer lock, so chunked saves do not bypass the gate\n    // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n    reconResult = await runReconsolidationIfEnabled(\n      database,\n      routedParsed,\n      routedFilePath,\n      force,\n      embedding,\n      scope,\n      { plannerMode, provenance: writeProvenance },\n    );\n    if (reconResult.earlyReturn) return reconResult.earlyReturn;\n    if (reconResult.saveTimeReconsolidation.status === 'failed') {\n      return buildSaveTimeReconsolidationFailureResult({\n        parsed: routedParsed,\n        validation,\n        reconWarnings: reconResult.warnings,\n        failure: {\n          status: 'failed',\n          reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n          ...(reconResult.saveTimeReconsolidation.warnings\n            ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n            : {}),\n          ...(reconResult.saveTimeReconsolidation.persistedState\n            ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n            : {}),\n        },\n      });\n    }\n\n    if (shouldChunkContent) {\n      console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n      const chunkedInsertTracker = createChunkedInsertTracker();\n      const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n        force,\n        scope,\n        provenance: writeProvenance,\n        applyPostInsertMetadata: (db, memoryId, fields) => {\n          applyPostInsertMetadata(db, memoryId, fields);\n          trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n        },\n      });\n\n      if (\n        peResult.supersededId != null\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          const finalizeChunkedPeTx = database.transaction(() => {\n            if (chunkedResult.id > 0) {\n              recordCrossPathPeSupersedes(\n                database,\n                chunkedResult.id,\n                peResult.supersededId,\n                samePathExisting?.id ?? null,\n                peResult.decision.reason,\n              );\n            }\n            if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n              throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n            }\n          });\n          finalizeChunkedPeTx.immediate();\n        } catch (supersedeErr: unknown) {\n          const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n          const cleanupSuffix = cleanup.cleaned\n            ? ' Rolled back the newly created chunk tree.'\n            : cleanup.attempted && cleanup.error\n              ? ` Cleanup failed: ${cleanup.error}`\n              : '';\n          return {\n            ...chunkedResult,\n            status: 'error',\n            error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n            message: `Chunked indexing succeeded, but predecessor ${peResult.supersededId} could not be superseded.${cleanupSuffix}`,\n          };\n        }\n      }\n\n      if (\n        shouldPersistFinalizedFile\n        && finalizedFileContent\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n        } catch (finalizeErr: unknown) {\n          finalizeWarning = `Quality-loop file persistence failed after chunked indexing: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}`;\n          console.warn(`[memory-save] ${finalizeWarning}`);\n        }\n      }\n\n      if (peResult.decision.action !== 'CREATE') {\n        chunkedResult.pe_action = peResult.decision.action;\n        chunkedResult.pe_reason = peResult.decision.reason;\n      }\n      if (peResult.supersededId != null) {\n        chunkedResult.superseded_id = peResult.supersededId;\n      }\n      if (Array.isArray(reconResult.warnings) && reconResult.warnings.length > 0) {\n        const existingWarnings = Array.isArray(chunkedResult.warnings)\n          ? [...(chunkedResult.warnings as string[])]\n          : [];\n        chunkedResult.warnings = [...existingWarnings, ...reconResult.warnings];\n      }\n      if (reconResult.assistiveRecommendation) {\n        reconResult.assistiveRecommendation.advisory_stale = true;\n        chunkedResult.assistiveRecommendation = reconResult.assistiveRecommendation;\n      }\n      chunkedResult.saveTimeReconsolidation = reconResult.saveTimeReconsolidation;\n\n      return appendResultWarning(chunkedResult, finalizeWarning);\n    }\n\n    // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n    // atomicity. Uses database.transaction() so inner transaction() calls in\n    // createMemoryRecord / index_memory correctly nest via SAVEPOINTs instead\n    // of failing with \"cannot start a transaction within a transaction\".\n    // withSpecFolderLock handles in-process serialization; this transaction\n    // provides defense-in-depth against multi-process races.\n    let existing: { id: number; content_hash: string } | undefined;\n\n    // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n    // safe outside the transaction and this avoids an early-return inside the\n    // transaction callback (which would COMMIT an empty tx unnecessarily).\n    const dupResult = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (dupResult) {\n      await repairReplayEnrichmentIfNeeded(database, dupResult.id, routedParsed);\n      return dupResult;\n    }\n\n    const requestedScope = getRequestedScope(scope);\n    const writeTransaction = database.transaction((): number => {\n      if (indexingOrigin !== 'scan' && embedding) {\n        const complementRecheck = findScopeFilteredCandidates({\n          database,\n          embedding,\n          parsed: routedParsed,\n          requestedScope,\n          limit: 1,\n          minSimilarity: 50,\n          overfetchMultiplier: 3,\n        });\n        const topCandidate = complementRecheck.candidates[0];\n        if (topCandidate) {\n          const transactionalAction = determineAction(topCandidate.similarity);\n          if (transactionalAction !== 'complement') {\n            throw new SaveTimeReconsolidationAbort({\n              status: 'failed',\n              reason: 'candidate_changed',\n              warnings: [\n                `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n              ],\n              persistedState: {\n                kind: transactionalAction,\n                candidateMemoryIds: [topCandidate.id],\n              },\n            });\n          }\n        }\n      }\n\n      // CREATE NEW MEMORY\n      existing = findSamePathExistingMemory(\n        database,\n        routedParsed.specFolder,\n        canonicalFilePath,\n        routedFilePath,\n        scope,\n        recordIdentity,\n      ) as { id: number; content_hash: string } | undefined;\n\n      // A same-path re-index whose file content changed appends a new version\n      // row; the prior row for this logical key is retired below so re-indexing\n      // replaces in place rather than leaving a deprecated duplicate. Scoped to\n      // this branch only — PE-gate / reconsolidation lineage (createMemoryRecord)\n      // is intentionally preserved.\n      const samePathSupersededPredecessorId =\n        existing && existing.content_hash !== routedParsed.contentHash ? existing.id : null;\n\n      // Retire the same-path predecessor before inserting the new version so the\n      // active-row uniqueness guard holds at insert time. Deprecating (not deleting)\n      // keeps the predecessor row, its lineage chain, and its history intact while\n      // removing it from the active-row guard; the new version supersedes it in place.\n      const reindexTierCarry = samePathSupersededPredecessorId != null\n        ? retirePredecessorForActiveReindex(database, samePathSupersededPredecessorId)\n        : null;\n\n      const memoryId = samePathSupersededPredecessorId != null\n        ? createAppendOnlyMemoryRecord({\n            database,\n            parsed: routedParsed,\n            filePath: routedFilePath,\n            embedding,\n            embeddingFailureReason,\n            predecessorMemoryId: samePathSupersededPredecessorId,\n            anchorId: recordIdentity.targetAnchorId,\n            tenantId: scope.tenantId,\n            userId: scope.userId,\n            agentId: scope.agentId,\n            sessionId: scope.sessionId,\n            actor: 'mcp:memory_save',\n          })\n        : createMemoryRecord(\n            database,\n            routedParsed,\n            routedFilePath,\n            embedding,\n            embeddingFailureReason,\n            peResult.decision,\n            scope,\n            recordIdentity,\n            writeProvenance,\n          );\n\n      if (samePathSupersededPredecessorId != null) {\n        applyWriteProvenance(database, memoryId, writeProvenance);\n      }\n\n      // A human's tier decision on the retired predecessor carries forward to the\n      // reindexed successor. Re-stamp after provenance so the manual tier and its\n      // human source-kind survive the reindex instead of resetting to the default.\n      if (reindexTierCarry != null) {\n        database\n          .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n          .run(reindexTierCarry.importanceTier, memoryId);\n        persistSourceKind(database, memoryId, reindexTierCarry.sourceKind as SourceKind);\n      }\n\n      // F1.01 fix: Mark superseded memory AFTER new record creation, inside\n      // the same transaction, so a creation failure rolls back both operations.\n      if (peResult.supersededId != null) {\n        const supersededOk = markMemorySuperseded(peResult.supersededId);\n        // C5-3: Supersede failure should abort the transaction\n        if (!supersededOk) {\n          throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n        }\n      }\n\n      recordLineageVersion(database, {\n        memoryId,\n        predecessorMemoryId: samePathSupersededPredecessorId,\n        actor: 'mcp:memory_save',\n        transitionEvent: samePathSupersededPredecessorId != null ? 'SUPERSEDE' : 'CREATE',\n      });\n      markEnrichmentPending(database, memoryId, POST_INSERT_ENRICHMENT_VERSION);\n\n      return memoryId;\n    });\n\n    let id: number;\n    try {\n      id = writeTransaction.immediate();\n    } catch (error: unknown) {\n      if (error instanceof SaveTimeReconsolidationAbort) {\n        return buildSaveTimeReconsolidationFailureResult({\n          parsed: routedParsed,\n          validation,\n          reconWarnings: reconResult.warnings,\n          failure: error.result,\n          message: `Save aborted before commit: ${error.result.reason}`,\n        });\n      }\n      throw error;\n    }\n\n    if (shouldPersistFinalizedFile && finalizedFileContent) {\n      try {\n        await finalizeMemoryFileContent(routedFilePath, finalizedFileContent);\n      } catch (finalizeErr: unknown) {\n        finalizeWarning = `[file-persistence-failed] Quality-loop file persistence failed after DB commit: ${finalizeErr instanceof Error ? finalizeErr.message : String(finalizeErr)}. DB row committed — manual file recovery may be needed.`;\n        console.warn(`[memory-save] ${finalizeWarning}`);\n      }\n    }\n\n    // Data integrity: clean stale auto-entities before re-extraction on update\n    // When a memory is superseded or replaced in-place, purge the predecessor's\n    // auto-entity rows so the entity catalog reflects only active content.\n    if (existing && existing.id !== id) {\n      try {\n        refreshAutoEntitiesForMemory(database, existing.id, []);\n        console.error(`[memory-save] Cleaned stale auto-entities for superseded memory #${existing.id}`);\n      } catch (entityCleanupErr: unknown) {\n        // Entity cleanup failure must not block save — log and continue\n        console.warn(`[memory-save] Auto-entity cleanup for #${existing.id} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n      }\n    }\n    if (peResult.supersededId != null && peResult.supersededId !== existing?.id) {\n      try {\n        refreshAutoEntitiesForMemory(database, peResult.supersededId, []);\n        console.error(`[memory-save] Cleaned stale auto-entities for PE-superseded memory #${peResult.supersededId}`);\n      } catch (entityCleanupErr: unknown) {\n        console.warn(`[memory-save] Auto-entity cleanup for PE #${peResult.supersededId} failed:`, entityCleanupErr instanceof Error ? entityCleanupErr.message : String(entityCleanupErr));\n      }\n    }\n\n    if (embedding) {\n      try {\n        recordNearDuplicateCheck({\n          database,\n          memoryId: id,\n          specFolder: routedParsed.specFolder,\n          contentHash: routedParsed.contentHash,\n          embedding,\n          scope,\n        });\n      } catch (error: unknown) {\n        const message = error instanceof Error ? error.message : String(error);\n        console.warn(`[memory-save] Near-duplicate advisory skipped: ${message}`);\n      }\n    }\n\n    // POST-INSERT ENRICHMENT: causal links, entities, summaries, entity linking.\n    // When enrichment is enabled and async (default), run the bundle in the background so the\n    // save returns immediately. The row was marked enrichment-pending inside the commit\n    // transaction (markEnrichmentPending), so a crash before the background run completes is\n    // recovered by the pending-marker replay/backfill path. SPECKIT_POST_INSERT_ENRICHMENT_SYNC\n    // forces synchronous execution when a caller needs the graph fresh in the same response.\n    let postInsertEnrichmentResult: PostInsertEnrichmentResult;\n    if (shouldRunPostInsertEnrichment(plannerMode) && isPostInsertEnrichmentAsync()) {\n      scheduleBackgroundEnrichment(id, routedParsed);\n      postInsertEnrichmentResult = buildDeferredEnrichmentResult('async-background');\n    } else {\n      postInsertEnrichmentResult = await runPostInsertEnrichmentIfEnabled(\n        database,\n        id,\n        routedParsed,\n        { plannerMode },\n      );\n      recordEnrichmentResult(database, id, postInsertEnrichmentResult);\n      emitPostInsertEnrichmentSubscribers(id, 'post-insert-enrichment');\n    }\n    const { causalLinksResult, enrichmentStatus, executionStatus } = postInsertEnrichmentResult;\n\n    if (reconResult.assistiveRecommendation) {\n      reconResult.assistiveRecommendation.advisory_stale = true;\n      if (reconResult.saveTimeReconsolidation.persistedState) {\n        reconResult.saveTimeReconsolidation.persistedState.advisory_stale = true;\n      }\n    }\n\n    // BUILD RESULT\n    return appendResultWarning(buildIndexResult({\n      database,\n      existing,\n      embeddingStatus,\n      id,\n      parsed: routedParsed,\n      validation,\n      reconWarnings: reconResult.warnings,\n      peDecision: peResult.decision,\n      embeddingFailureReason,\n      asyncEmbedding,\n      causalLinksResult,\n      enrichmentStatus,","lineStart":2368,"lineEnd":2787,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781762031525,"end":1781762031554}},"metadata":{"openai":{"itemId":"fc_09a20610ed3631ee016a3387ee31b88191a83c57acf1c7f4f7"}},"id":"prt_ed94afa87001ryxsdHvUCK5wEg","sessionID":"ses_126b933ddffe3XZ7heot3Sz6EF","messageID":"msg_ed94aea0f0013eYGWH5IEsmYqD"}}
