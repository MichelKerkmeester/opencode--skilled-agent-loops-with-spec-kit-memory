.opencode/specs/system-spec-kit/026-graph-and-context-optimization/007-code-graph/010-fix-iteration-quality-meta-research/review_archive/round-1-20260502T193723Z/deltas/iter-001.jsonl:2:{"type":"finding","iteration":1,"id":"P1-002","severity":"P1","dimension":"correctness","class":"cross-consumer","title":"Deep-review iteration/state contract does not collect report-required fix-completeness fields","sources":[".opencode/commands/spec_kit/assets/spec_kit_deep-review_auto.yaml:1052-1055",".opencode/agents/deep-review.md:146-179",".opencode/agents/deep-review.md:204-224",".opencode/skills/sk-deep-review/references/state_format.md:190-204"],"summary":"The final report must emit findingClass, scopeProofNeeded, and affectedSurfaceHints, but iteration artifacts and JSONL state do not require or preserve them."}
.opencode/specs/system-spec-kit/026-graph-and-context-optimization/007-code-graph/010-fix-iteration-quality-meta-research/review_archive/round-1-20260502T193723Z/deltas/iter-003.jsonl:1:{"type":"finding","iteration":3,"id":"P1-005","severity":"P1","dimension":"maintainability","class":"cross-consumer","title":"Fix-completeness proof field names drift between scopeProof and scopeProofNeeded","sources":[".opencode/skills/sk-code-review/SKILL.md:319-320",".opencode/skills/sk-code-review/references/review_core.md:86-87",".opencode/commands/spec_kit/assets/spec_kit_deep-review_auto.yaml:1050-1054",".opencode/commands/spec_kit/assets/spec_kit_deep-review_confirm.yaml:1072-1076",".opencode/agents/deep-review.md:146-179",".opencode/skills/sk-deep-review/references/state_format.md:176-204",".opencode/commands/spec_kit/assets/spec_kit_plan_auto.yaml:554-560",".opencode/commands/spec_kit/assets/spec_kit_plan_confirm.yaml:603-609"],"evidenceCommands":["rg -n 'scopeProof|scopeProofNeeded|affectedSurfaceHints|findingClass|findingClasses|requiredFixCompletenessGate|fixCompletenessRequired|fixCompletenessReplay|fix_completeness_replay_gate_pass' .opencode/skills/sk-code-review .opencode/skills/sk-deep-review .opencode/commands/spec_kit .opencode/agent"],"summary":"sk-code-review defines the proof field as scopeProof, while the deep-review Planning Packet requires scopeProofNeeded; state/agent and plan consumers do not preserve or map either field explicitly."}
.opencode/specs/system-spec-kit/026-graph-and-context-optimization/007-code-graph/010-fix-iteration-quality-meta-research/review_archive/round-1-20260502T193723Z/deltas/iter-003.jsonl:2:{"type":"finding","iteration":3,"id":"P2-006","severity":"P2","dimension":"maintainability","class":"cross-consumer","title":"fixCompletenessRequired is not explicitly mapped to convergence gate vocabulary","sources":[".opencode/skills/sk-deep-review/references/convergence.md:43-53",".opencode/skills/sk-deep-review/references/convergence.md:88-104",".opencode/skills/sk-deep-review/references/convergence.md:381-388",".opencode/skills/sk-deep-review/references/convergence.md:417-420",".opencode/commands/spec_kit/assets/spec_kit_deep-review_auto.yaml:480-490",".opencode/commands/spec_kit/assets/spec_kit_deep-review_auto.yaml:500-548",".opencode/commands/spec_kit/assets/spec_kit_deep-review_auto.yaml:1047-1050",".opencode/commands/spec_kit/assets/spec_kit_deep-review_confirm.yaml:508-556",".opencode/commands/spec_kit/assets/spec_kit_deep-review_confirm.yaml:1072-1076"],"evidenceCommands":["rg -n 'scopeProof|scopeProofNeeded|affectedSurfaceHints|findingClass|findingClasses|requiredFixCompletenessGate|fixCompletenessRequired|fixCompletenessReplay|fix_completeness_replay_gate_pass' .opencode/skills/sk-code-review .opencode/skills/sk-deep-review .opencode/commands/spec_kit .opencode/agent"],"summary":"Planning Packet uses fixCompletenessRequired, while convergence uses requiredFixCompletenessGate/fixCompletenessReplayGate and snake_case replay metrics without a documented projection between them."}
.opencode/specs/system-spec-kit/026-graph-and-context-optimization/007-code-graph/010-fix-iteration-quality-meta-research/review_archive/round-1-20260502T193723Z/deltas/iter-004.jsonl:1:{"type":"delta_summary","iteration":4,"mode":"review","dimension":"security","newFindings":[],"findingsSummary":{"P0":0,"P1":0,"P2":0},"evidenceCommands":["rg -n 'Affected Surfaces|affectedSurfacesSeed|findingClasses|fixCompletenessRequired|findingClass|scopeProof|FIX ADDENDUM' .opencode/commands/spec_kit/assets .opencode/skills/sk-code-review .opencode/skills/sk-deep-review .opencode/skills/system-spec-kit/templates/manifest --glob '*.{md,tmpl,yaml,yml}'","rg -n 'Planning Packet|review-report|findings file|findingsFile|Import Risk Matrix|Affected Surfaces table' .opencode/commands/spec_kit/assets"],"summary":"No new security findings; affectedSurfacesSeed is specified by deep-review synthesis but is not consumed by /spec_kit:plan, and the affected-surfaces scaffold does not create an automatic path echo from malicious findings files."}
