+function insertInferredEdges(edges: InferredEdge[]): void {
+  if (edges.length === 0) return;
+  insertEdgesBatch(edges.map((edge) => ({
+    sourceId: edge.sourceId,
+    targetId: edge.targetId,
+    relation: edge.relation,
+    strength: edge.strength,
