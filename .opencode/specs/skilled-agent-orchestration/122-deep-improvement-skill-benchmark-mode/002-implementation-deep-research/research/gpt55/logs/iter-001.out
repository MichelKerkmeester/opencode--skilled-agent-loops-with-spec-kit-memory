     3	/**
     4	 * lib/cache.cjs
     5	 *
     6	 * Atomic, append-only cache layer for the 002-eval-rig pipeline.
     7	 * Two cache kinds live side by side under cache/:
     8	 *   cache/det/      Deterministic check results (regex-checkable; grader-independent).
     9	 *   cache/grader/   Grader-call results (depend on rubric_version + grader_model_build_hash).
    10	 *
    11	 * Storage model:
    12	 *   cache/<kind>/index.jsonl        Append-only index, one JSON row per entry.
    13	 *   cache/<kind>/<key>.out.md       Atomic blob storage (temp+rename), one file per key.
    14	 *
    15	 * Concurrency model:
    16	 *   cache/<kind>/.lock-<key>/       Mkdir-based advisory lock; POSIX atomic mkdir.
    17	 *                                    5-minute TTL stale-lock auto-clear.
    18	 *
    19	 * Cache keys are 32-char SHA-256 hex prefixes derived from canonicalized input bundles.
    20	 *
    21	 * Grader model build hash: hardcoded placeholder "claude-sonnet-4.6@2026-04-01" today.
    22	 * TODO: replace with the real API model-version header captured at dispatch time
    23	 *       (read from response headers when the grader call lands).
    24	 *
    25	 * F017-P2-13a (017 review): the cache root is run-scoped. write_atomic / read /
    26	 * cache_hit / read_index / rebuild_index accept an optional final cacheRoot
    27	 * argument. When omitted they fall back to the legacy in-repo CACHE_ROOT so
    28	 * existing callers keep working, but run-scoped callers (the grader harness)
    29	 * pass a per-run outputs directory instead of writing into a shared in-repo
    30	 * location that is trusted on the cache-hit path. This is the un-applied
    31	 * analogue of the 015 score-candidate cache relocation (F-P1-11).
    32	 */
    33	
    34	const fs = require('fs');
    35	const path = require('path');
    36	const crypto = require('crypto');
    37	
    38	const PACKET_ROOT = path.resolve(__dirname, '..');
    39	const CACHE_ROOT = path.join(PACKET_ROOT, 'cache');
    40	const VALID_KINDS = new Set(['det', 'grader']);
    41	const LOCK_TTL_MS = 5 * 60 * 1000;
    42	const LOCK_RETRY_INTERVAL_MS = 50;
    43	const LOCK_WAIT_MAX_MS = 5 * 60 * 1000;
    44	const GRADER_MODEL_BUILD_HASH_PLACEHOLDER = 'claude-sonnet-4.6@2026-04-01';
    45	
    46	function sha256Hex(input) {
    47	  return crypto.createHash('sha256').update(input, 'utf8').digest('hex');
    48	}
    49	
    50	function canonicalConcat(parts) {
    51	  // Pipe-delimited canonical concatenation; pipes inside parts are escaped.
    52	  return parts
    53	    .map((p) => String(p === undefined || p === null ? '' : p).replace(/\|/g, '\\|'))
    54	    .join('|');
    55	}
    56	
    57	function deriveDetKey({ variant_hash, fixture_id, check_name, check_version }) {
    58	  if (!variant_hash || !fixture_id || !check_name) {
    59	    throw new Error('derive_det_key requires variant_hash, fixture_id, check_name');
    60	  }
    61	  const concat = canonicalConcat([
    62	    'det:v1',
    63	    variant_hash,
    64	    fixture_id,
    65	    check_name,
    66	    check_version || '1.0.0',
    67	  ]);
    68	  return sha256Hex(concat).slice(0, 32);
    69	}
    70	
    71	function deriveGraderKey({
    72	  variant_hash,
    73	  fixture_id,
    74	  rubric_version,
    75	  grader_model_build_hash,
    76	  dim_id,
    77	  swe16_output_hash,
    78	}) {
    79	  if (
    80	    !variant_hash ||
    81	    !fixture_id ||
    82	    !rubric_version ||
    83	    !dim_id ||
    84	    !swe16_output_hash
    85	  ) {
    86	    throw new Error(
    87	      'derive_grader_key requires variant_hash, fixture_id, rubric_version, dim_id, swe16_output_hash'
    88	    );
    89	  }
    90	  const buildHash = grader_model_build_hash || GRADER_MODEL_BUILD_HASH_PLACEHOLDER;
    91	  const concat = canonicalConcat([
    92	    'grader:v1',
    93	    rubric_version,
    94	    variant_hash,
    95	    fixture_id,
    96	    dim_id,
    97	    swe16_output_hash,
    98	    buildHash,
    99	  ]);
   100	  return sha256Hex(concat).slice(0, 32);
   101	}
   102	
   103	// F017-P2-13a: resolve the active cache root. Callers may pass a run-scoped dir;
   104	// undefined falls back to the legacy in-repo CACHE_ROOT for backward compatibility.
   105	function resolveCacheRoot(cacheRoot) {
   106	  return cacheRoot ? path.resolve(cacheRoot) : CACHE_ROOT;
   107	}
   108	
   109	function ensureKindDir(kind, cacheRoot) {
   110	  if (!VALID_KINDS.has(kind)) {
   111	    throw new Error(`unknown cache kind: ${kind}`);
   112	  }
   113	  const dir = path.join(resolveCacheRoot(cacheRoot), kind);
   114	  fs.mkdirSync(dir, { recursive: true });
   115	  const indexFile = path.join(dir, 'index.jsonl');
   116	  if (!fs.existsSync(indexFile)) {
   117	    fs.writeFileSync(indexFile, '', { flag: 'wx' });
   118	  }
   119	  return dir;
   120	}
   121	
   122	function lockDir(kind, key, cacheRoot) {
   123	  return path.join(resolveCacheRoot(cacheRoot), kind, `.lock-${key}`);
   124	}
   125	
   126	function blobPath(kind, key, cacheRoot) {
   127	  return path.join(resolveCacheRoot(cacheRoot), kind, `${key}.out.md`);
   128	}
   129	
   130	function indexPath(kind, cacheRoot) {
   131	  return path.join(resolveCacheRoot(cacheRoot), kind, 'index.jsonl');
   132	}
   133	
   134	function acquireLock(kind, key, cacheRoot) {
   135	  ensureKindDir(kind, cacheRoot);
   136	  const lockPath = lockDir(kind, key, cacheRoot);
   137	  const start = Date.now();
   138	  while (Date.now() - start < LOCK_WAIT_MAX_MS) {
   139	    try {
   140	      fs.mkdirSync(lockPath, { recursive: false });
   141	      return lockPath;
   142	    } catch (err) {
   143	      if (err.code !== 'EEXIST') {
   144	        throw err;
   145	      }
   146	      // Stale-lock check.
   147	      try {
   148	        const st = fs.statSync(lockPath);
   149	        if (Date.now() - st.mtimeMs > LOCK_TTL_MS) {
   150	          // Force-clear stale lock and retry.
   151	          fs.rmSync(lockPath, { recursive: true, force: true });
   152	          continue;
   153	        }
   154	      } catch (_) {
   155	        // Lock disappeared between EEXIST and stat; retry immediately.
   156	        continue;
   157	      }
   158	      // Active lock; sleep and retry.
   159	      const sleepEnd = Date.now() + LOCK_RETRY_INTERVAL_MS;
   160	      while (Date.now() < sleepEnd) {
   161	        // Busy-wait short interval to keep this dependency-free.
   162	      }
   163	    }
   164	  }
   165	  throw new Error(`acquireLock timeout for ${kind}:${key}`);
   166	}
   167	
   168	function releaseLock(lockPath) {
   169	  try {
   170	    fs.rmSync(lockPath, { recursive: true, force: true });
   171	  } catch (_) {
   172	    // best-effort
   173	  }
   174	}
   175	
   176	function writeAtomic(kind, key, outputText, metadata, cacheRoot) {
   177	  if (!VALID_KINDS.has(kind)) {
   178	    throw new Error(`unknown cache kind: ${kind}`);
   179	  }
   180	  if (typeof key !== 'string' || key.length === 0) {
   181	    throw new Error('key required');
   182	  }
   183	  if (typeof outputText !== 'string') {
   184	    throw new Error('outputText must be a string');
   185	  }
   186	  const meta = metadata || {};
   187	  const lockPath = acquireLock(kind, key, cacheRoot);
   188	  try {
   189	    const target = blobPath(kind, key, cacheRoot);
   190	    // Compose a JSON-comment header so the blob is self-describing.
   191	    const header = '<!-- cache-meta ' + JSON.stringify({
   192	      kind,
   193	      key,
   194	      created_at: new Date().toISOString(),
   195	      ...meta,
   196	    }) + ' -->\n';
   197	    const payload = header + outputText;
   198	    const tmp = `${target}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;
   199	    fs.writeFileSync(tmp, payload, 'utf8');
   200	    fs.renameSync(tmp, target);
   201	
   202	    // Append index row atomically (append is POSIX-atomic for small writes).
   203	    const row = JSON.stringify({
   204	      key,
   205	      created_at: new Date().toISOString(),
   206	      ...meta,
   207	    }) + '\n';
   208	    fs.appendFileSync(indexPath(kind, cacheRoot), row, 'utf8');
   209	    return { key, target, kind };
   210	  } finally {
   211	    releaseLock(lockPath);
   212	  }
   213	}
   214	
   215	function read(kind, key, cacheRoot) {
   216	  if (!VALID_KINDS.has(kind)) {
   217	    throw new Error(`unknown cache kind: ${kind}`);
   218	  }
   219	  const target = blobPath(kind, key, cacheRoot);
   220	  if (!fs.existsSync(target)) {
     1	---
     2	title: "scorer: 5-dimension model-variant scorer"
     3	description: "Decoupled 5-dimension scorer that combines deterministic checks and a pluggable grader into a single weighted score."
     4	trigger_phrases:
     5	  - "5-dimension scorer"
     6	  - "score-model-variant"
     7	  - "5dim scoring"
     8	---
     9	
    10	# scorer: 5-dimension model-variant scorer
    11	
    12	---
    13	
    14	## 1. OVERVIEW
    15	
    16	`scorer/` owns the 5-dimension scoring engine for Lane B. `score-model-variant.cjs` takes primitive criteria plus an absolute `cwd`, runs the deterministic check subprocesses and the grader, and returns a weighted score with the per-dimension breakdown.
    17	
    18	Current state:
    19	
    20	- The public `score()` API takes criteria and an absolute `cwd`, never a fixture file path. The caller passes the criteria as data.
    21	- It synthesizes an in-memory virtual fixture, writes it to a temp JSON, and runs the deterministic check scripts plus the grader against it, then removes the temp dir.
    22	- Dimensions: D1 acceptance, D2 bundle gate (hard gate), D3 cwd/path, D4 grader, D5 pre-planning. Weights live in `DEFAULT_RUBRIC`.
    23	- D2 is the hard gate: when it fails, D1 is capped to 0 and `hard_gate_failed` is set.
    24	
    25	---
    26	
    27	## 2. ARCHITECTURE
    28	
    29	```text
    30	╭──────────────────────────────────────────────────────────────────╮
    31	│                             scorer/                               │
    32	╰──────────────────────────────────────────────────────────────────╯
    33	
    34	┌──────────────────────┐
    35	│ score-model-variant  │  builds virtual fixture (absolute cwd)
    36	│ orchestrating scorer │
    37	└──────────┬───────────┘
    38	           │
    39	   ┌───────┴───────────────────────────────┐
    40	   ▼                                        ▼
    41	┌──────────────────────┐          ┌──────────────────────┐
    42	│ deterministic/       │          │ grader/              │
    43	│ bundle-gate (D2)     │          │ harness gradeD4 (D4) │
    44	│ cwd-check    (D3)    │          │ dispute (escalation) │
    45	│ preplanning  (D5)    │          │ prompts/             │
    46	│ hallucination-flag   │          └──────────┬───────────┘
    47	└──────────┬───────────┘                     │
    48	           │                                  ▼
    49	           │                          ┌──────────────────────┐
    50	           │                          │ lib/cache.cjs        │
    51	           │                          │ grader result cache  │
    52	           │                          └──────────────────────┘
    53	           │
    54	           ▼
    55	┌──────────────────────────────────────────────────────┐
    56	│ apply hard gate -> weighted score over D1..D5         │
    57	└──────────────────────────────────────────────────────┘
    58	
    59	Dependency direction:
    60	score-model-variant ───▶ deterministic/ (spawned subprocess)
    61	score-model-variant ───▶ grader/harness ───▶ lib/cache
    62	grader/ ───▶ prompts/ (system prompts)
    63	deterministic/ and lib/ do not import score-model-variant
    64	```
    65	
    66	---
    67	
    68	## 3. DIRECTORY TREE
    69	
    70	```text
    71	scorer/
    72	+-- score-model-variant.cjs   # Orchestrating scorer with the public score() API
    73	+-- deterministic/            # D1-style + D2/D3/D5 deterministic check scripts
    74	+-- grader/                   # D4 LLM grader harness, dispute, system prompts
    75	`-- lib/                      # Scorer-internal cache (runtime cache/ git-ignored)
    76	```
    77	
    78	---
    79	
    80	## 4. KEY FILES
    81	
    82	| File | Responsibility |
    83	|---|---|
    84	| `score-model-variant.cjs` | Public `score()` orchestration. Synthesizes the virtual fixture, runs each deterministic check via `runDetCheck`, builds the grader via `buildGraderFn`, applies the hard gate, and computes the weighted score. |
    85	| `deterministic/` | Standalone check scripts spawned per dimension: bundle gate, cwd check, pre-planning, hallucination flag. |
    86	| `grader/` | The D4 grader. `harness.cjs` builds the prompt, dispatches, parses, and caches. `dispute.cjs` adds adversarial escalation. |
    87	| `lib/` | Scorer-internal cache module backing the grader. |
    88	
    89	---
    90	
    91	## 5. BOUNDARIES AND FLOW
    92	
    93	| Boundary | Rule |
    94	|---|---|
    95	| Imports | `score-model-variant.cjs` requires `grader/harness.cjs` and spawns the `deterministic/*.cjs` scripts as subprocesses. `grader/harness.cjs` requires `lib/cache.cjs`. |
    96	| Exports | `score-model-variant.cjs` exports `score`, `buildGraderFn`, `scoreAcceptanceDeterministic`, and `DEFAULT_RUBRIC`. |
    97	| Ownership | This subtree owns the 5-dimension scoring contract. `cwd` passed into `score()` must be absolute. |
    98	| Grader default | `graderKind` defaults to `mock`. `noop` makes D4 a constant 1.0 and `llm` runs the real grader. The benchmark adapter defaults to `noop` for hermetic runs. |
    99	
   100	---
   101	
   102	## 6. ENTRYPOINTS
   103	
   104	| Entrypoint | Type | Purpose |
   105	|---|---|---|
   106	| `score({ candidateId, outputText, criteria, cwd, graderKind })` | Function | Returns `{ fixtureId, weightedScore, dimensions, hard_gate_failed, deterministic, grader, interaction_terms }`. |
   107	| `node score-model-variant.cjs <output.md> <absolute-cwd> [--grader=mock\|llm\|noop]` | CLI | Smoke-runs the scorer against a single output file. |
   108	
   109	---
   110	
   111	## 7. VALIDATION
   112	
   113	Run from the repository root.
   114	
   115	```bash
   116	npx vitest run .opencode/skills/deep-agent-improvement/scripts/tests/scorer.vitest.ts
   117	```
   118	
   119	Expected result: the scorer suite passes.
   120	
   121	---
   122	
   123	## 8. RELATED
   124	
   125	- [`model-benchmark README`](../README.md)
   126	- [`deterministic README`](./deterministic/README.md)
   127	- [`grader README`](./grader/README.md)
   128	- [`lib README`](./lib/README.md)

