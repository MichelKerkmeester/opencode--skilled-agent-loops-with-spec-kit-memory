sample(s)`);\n1418:   }\n1419:   if (results.divergenceReconcile.escalated > 0) {\n1420:     hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n1421:   }\n1422:   if (results.divergenceReconcile.errors.length > 0) {\n1423:     hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n1424:   }\n1425:   if (results.checkpointRepair.cleared) {\n1426:     hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n1427:   }\n1428:   if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n1429:     hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n1430:   }\n1431:   if (results.checkpointRepair.error) {\n1432:     hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n1433:   }\n1434:   if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n1435:     hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n1436:   }\n1437:   if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n1438:     hints.push('All files already up-to-date. Use force: true to re-index');\n1439:   }\n1440: \n1441:   await releaseScanLease();\n1442: \n1443:   recordMaintenanceRun('memory_index_scan', {\n1444:     status: 'success',\n1445:     counts: {\n1446:       scanned: results.scanned,\n1447:       indexed: results.indexed,\n1448:       updated: results.updated,\n1449:       unchanged: results.unchanged,\n1450:       failed: results.failed,\n1451:       staleDeleted: results.staleDeleted,\n1452:       staleDeleteFailed: results.staleDeleteFailed,\n1453:       orphanSwept: results.orphanSwept,\n1454:     },\n1455:     staleCandidates: filesToDelete.length,\n1456:   });\n1457: \n1458:   return createMCPSuccessResponse({\n1459:     tool: 'memory_index_scan',\n1460:     summary,\n1461:     data: {\n1462:       status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n1463:       ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n1464:       scanKey,\n1465:       batchSize: scanBatchSize,\n1466:       ...results,\n1467:       ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n1468:         ? {\n1469:             _debug_fileCounts: {\n1470:               constitutionalFiles: constitutionalFiles.length,\n1471:               specDocFiles: specDocFiles.length,\n1472:               totalFiles: files.length,\n1473:               mergedFiles: mergedFiles.length,\n1474:               dedupSkipped: dedupDuplicatesSkipped,\n1475:               includeSpecDocs: include_spec_docs,\n1476:               workspacePath,\n1477:             },\n1478:           }\n1479:         : {})\n1480:     },\n1481:     hints\n1482:   });\n1483:   } finally {\n1484:     if (leaseHeartbeat) {\n1485:       clearInterval(leaseHeartbeat);\n1486:       leaseHeartbeat = null;\n1487:     }\n1488:     if (loopLagTimer) {\n1489:       clearInterval(loopLagTimer);\n1490:       loopLagTimer = null;\n1491:       console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n1492:     }\n1493:     await releaseScanLease();\n1494:   }\n1495: }\n1496: \n1497: /** Handle memory_index_scan tool вҖ” dispatches to a synchronous run or a background job.\n1498:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1499: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1500:   if (!args.background) {\n1501:     return runIndexScan(args, {});\n1502:   }\n1503: \n1504:   const jobId = createJobId();\n1505:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1506: \n1507:   setImmediate(() => {\n1508:     void (async () => {\n1509:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1510:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1511:       // background-embedding queue draining this scan's deferred embeddings can\n1512:       // keep it held past the scan itself.\n1513:       const maintenance = beginMaintenance('index_scan');\n1514:       try {\n1515:         await setJobState(jobId, 'running');\n1516:         const response = await runIndexScan(args, {\n1517:           isCancelled: () => isCancelRequestedFast(jobId),\n1518:           onPhase: (phase) => {\n1519:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1520:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1521:             maintenance.refresh();\n1522:             void setJobPhase(jobId, phase).catch(() => {});\n1523:           },\n1524:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1525:         });\n1526:         const scanData = extractEnvelopeData(response);\n1527:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1528:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1529:         if (wasCancelled) {\n1530:           // The run itself short-circuited on cancellation. A cancel that arrives\n1531:           // after the scan already finished does not retroactively cancel it.\n1532:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1533:         } else if (response.isError === true) {\n1534:           // An error envelope (not a thrown error) still means the scan failed.\n1535:           await appendJobError(jobId, '__scan__', scanData);\n1536:           await setJobState(jobId, 'failed');\n1537:         } else {\n1538:           await completeJob(jobId, { state: 'complete', result: scanData });\n1539:         }\n1540:       } catch (error: unknown) {\n1541:         try {\n1542:           await appendJobError(jobId, '__job__', error);\n1543:           await setJobState(jobId, 'failed');\n1544:         } catch (_secondaryError: unknown) {\n1545:           // Best-effort failure record; never surface a background unhandled rejection.\n1546:         }\n1547:       } finally {\n1548:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1549:         // Release this scan's hold; the marker stays present only while the\n1550:         // background-embedding queue still holds it.\n1551:         maintenance.end();\n1552:       }\n1553:     })();\n1554:   });\n1555: \n1556:   return createMCPSuccessResponse({\n1557:     tool: 'memory_index_scan',\n1558:     summary: `Queued background index scan ${jobId}`,\n1559:     data: { jobId, state: 'queued', background: true },\n1560:     hints: [\n1561:       'Use memory_index_scan_status with jobId to poll progress',\n1562:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1563:     ],\n1564:   });\n1565: }\n1566: \n1567: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1568:    9. EXPORTS\n1569: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n1570: \n1571: export {\n1572:   handleMemoryIndexScan,\n1573:   indexSingleFile,\n1574:   findConstitutionalFiles,\n1575:   findSpecDocuments,\n1576:   detectSpecLevel,\n1577:   summarizeAliasConflicts,\n1578:   runDivergenceReconcileHooks,\n1579: };\n1580: \n1581: // Backward-compatible aliases (snake_case)\n1582: const handle_memory_index_scan = handleMemoryIndexScan;\n1583: const index_single_file = indexSingleFile;\n1584: const find_constitutional_files = findConstitutionalFiles;\n1585: const find_spec_documents = findSpecDocuments;\n1586: const detect_spec_level = detectSpecLevel;\n1587: const summarize_alias_conflicts = summarizeAliasConflicts;\n1588: const run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n1589: \n1590: export {\n1591:   handle_memory_index_scan,\n1592:   index_single_file,\n1593:   find_constitutional_files,\n1594:   find_spec_documents,\n1595:   detect_spec_level,\n1596:   summarize_alias_conflicts,\n1597:   run_divergence_reconcile_hooks,\n1598: };\n\n(End of file - total 1598 lines)\n</content>","metadata":{"preview":"          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }\n\n  if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    runScanInvalidationHooks({\n      indexed: results.indexed,\n      updated: results.updated,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n        ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n        : {}),\n      ...(results.postInsertEnrichmentRepaired > 0\n        ? { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired }\n        : {}),\n      ...(results.orphanSwept > 0 || results.orphanSweepFailed > 0\n        ? {\n            orphanSwept: results.orphanSwept,\n            orphanSweepFailed: results.orphanSweepFailed,\n          }\n        : {}),\n    }, scanAppliedActions);\n  }\n\n  runScanHygieneSubscribers(scanAppliedActions);\n\n  const summary = `Scan complete: ${results.indexed} indexed, ${results.updated} updated, ${results.unchanged} unchanged, ${results.staleDeleted} deleted, ${results.orphanSwept} orphan swept, ${results.failed} failed`;\n\n  const hints: string[] = [];\n  if (results.failed > 0) {\n    hints.push(`${results.failed} files failed to index - check file format`);\n  }\n  if (filesToDelete.length > 0 && results.failed > 0 && results.staleDeleted === 0 && results.staleDeleteFailed === 0) {\n    hints.push('Deferred stale index cleanup because one or more replacement files failed to index');\n  }\n  if (results.staleDeleted > 0) {\n    hints.push(`Removed ${results.staleDeleted} stale index record(s) for deleted files`);\n  }\n  if (results.staleDeleteFailed > 0) {\n    hints.push(`${results.staleDeleteFailed} stale index record(s) could not be removed`);\n  }\n  if (results.orphanSwept > 0) {\n    hints.push(`Swept ${results.orphanSwept} orphan index record(s)`);\n  }\n  if (results.postInsertEnrichmentRepaired > 0) {\n    hints.push(`Repaired ${results.postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`);\n  }\n  if (results.nearDuplicateRepaired > 0) {\n    hints.push(`Repaired ${results.nearDuplicateRepaired} near-duplicate marker(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.readyRows) {\n    hints.push(`Backfilled ${results.triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`);\n  }\n  if (results.triggerEmbeddingBackfill?.failedRows) {\n    hints.push(`${results.triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`);\n  }\n  if (results.orphanSweepFailed > 0) {\n    hints.push(`${results.orphanSweepFailed} orphan index record(s) could not be removed`);\n  }\n  if (results.dedup.duplicatesSkipped > 0) {\n    hints.push(`Canonical dedup skipped ${results.dedup.duplicatesSkipped} alias path(s)`);\n  }\n  if (results.aliasConflicts.groups > 0) {\n    hints.push(`Detected ${results.aliasConflicts.groups} specs/.opencode alias group(s); no automatic mutation performed`);\n  }\n  if (results.aliasConflicts.divergentHashGroups > 0) {\n    hints.push(`${results.aliasConflicts.divergentHashGroups} alias group(s) have divergent content hashes`);\n  }\n  if (results.divergenceReconcile.retriesScheduled > 0) {\n    hints.push(`Auto-reconcile scheduled for ${results.divergenceReconcile.retriesScheduled} divergent alias sample(s)`);\n  }\n  if (results.divergenceReconcile.escalated > 0) {\n    hints.push(`Auto-reconcile exhausted for ${results.divergenceReconcile.escalated} sample(s); manual triage required`);\n  }\n  if (results.divergenceReconcile.errors.length > 0) {\n    hints.push(`Auto-reconcile hook encountered ${results.divergenceReconcile.errors.length} error(s)`);\n  }\n  if (results.checkpointRepair.cleared) {\n    hints.push(`Cleared checkpoint derived rebuild sentinel after repairing ${results.checkpointRepair.completed} step(s)`);\n  }\n  if (results.checkpointRepair.attempted && !results.checkpointRepair.cleared) {\n    hints.push('Checkpoint derived rebuild repair did not complete; sentinel retained');\n  }\n  if (results.checkpointRepair.error) {\n    hints.push(`Checkpoint derived rebuild repair error: ${results.checkpointRepair.error}`);\n  }\n  if (results.incremental.enabled && results.incremental.fast_path_skips > 0) {\n    hints.push(`Incremental mode saved time: ${results.incremental.fast_path_skips} files skipped via mtime check`);\n  }\n  if (results.indexed + results.updated === 0 && results.unchanged > 0) {\n    hints.push('All files already up-to-date. Use force: true to re-index');\n  }\n\n  await releaseScanLease();\n\n  recordMaintenanceRun('memory_index_scan', {\n    status: 'success',\n    counts: {\n      scanned: results.scanned,\n      indexed: results.indexed,\n      updated: results.updated,\n      unchanged: results.unchanged,\n      failed: results.failed,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      orphanSwept: results.orphanSwept,\n    },\n    staleCandidates: filesToDelete.length,\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary,\n    data: {\n      status: results.deferred > 0 ? 'complete_with_pending_vectors' : 'complete',\n      ...(results.deferred > 0 ? { pendingVectors: results.deferred } : {}),\n      scanKey,\n      batchSize: scanBatchSize,\n      ...results,\n      ...(process.env.SPECKIT_DEBUG_INDEX_SCAN === 'true'\n        ? {\n            _debug_fileCounts: {\n              constitutionalFiles: constitutionalFiles.length,\n              specDocFiles: specDocFiles.length,\n              totalFiles: files.length,\n              mergedFiles: mergedFiles.length,\n              dedupSkipped: dedupDuplicatesSkipped,\n              includeSpecDocs: include_spec_docs,\n              workspacePath,\n            },\n          }\n        : {})\n    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool вҖ” dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   9. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_memory_index_scan = handleMemoryIndexScan;\nconst index_single_file = indexSingleFile;\nconst find_constitutional_files = findConstitutionalFiles;\nconst find_spec_documents = findSpecDocuments;\nconst detect_spec_level = detectSpecLevel;\nconst summarize_alias_conflicts = summarizeAliasConflicts;\nconst run_divergence_reconcile_hooks = runDivergenceReconcileHooks;\n\nexport {\n  handle_memory_index_scan,\n  index_single_file,\n  find_constitutional_files,\n  find_spec_documents,\n  detect_spec_level,\n  summarize_alias_conflicts,\n  run_divergence_reconcile_hooks,\n};","lineStart":1316,"lineEnd":1598,"totalLines":1598,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781762877354,"end":1781762877360}},"metadata":{"openai":{"itemId":"fc_00bb168e403b2046016a338b3d3dd08191ade8c4a8a3534c4e"}},"id":"prt_ed957e77a001NmwjPJ62Zedhhq","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957bb72001yEPgUg0JVqBslj"}}
{"type":"tool_use","timestamp":1781762877400,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"type":"tool","tool":"read","callID":"call_YtCLsLlkMsM7lwbQwELhxRHb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Retention Sweep\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see вҖ” aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n341: \n342: function appendRetentionLedger(\n343:   database: Database.Database,\n344:   deletedIds: number[],\n345:   candidates: RetentionExpiredRow[],\n346: ): boolean {\n347:   try {\n348:     mutationLedger.initLedger(database);\n349:     mutationLedger.appendEntry(database, {\n350:       mutation_type: 'delete',\n351:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n352:       prior_hash: null,\n353:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n354:       linked_memory_ids: deletedIds.slice(0, 50),\n355:       decision_meta: {\n356:         tool: 'memory_retention_sweep',\n357:         reason: 'retention_expired',\n358:         totalDeleted: deletedIds.length,\n359:         originalDeleteAfter: candidates\n360:           .filter((candidate) => deletedIds.includes(candidate.id))\n361:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n362:       },\n363:       actor: 'mcp:memory_retention_sweep',\n364:     });\n365:     return true;\n366:   } catch (error: unknown) {\n367:     const message = error instanceof Error ? error.message : String(error);\n368:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n369:     return false;\n370:   }\n371: }\n372: \n373: function runPostDeleteMaintenance(database: Database.Database): void {\n374:   try {\n375:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n376:   } catch (error: unknown) {\n377:     const message = error instanceof Error ? error.message : String(error);\n378:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n379:   }\n380: \n381:   const maintenance = new BetterSqliteMaintenance(database, {\n382:     onMaintenanceError: reportRetentionMaintenanceError,\n383:   });\n384:   maintenance.vacuum();\n385:   maintenance.checkpoint({ mode: 'truncate' });\n386: }\n387: \n388: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n389:   const message = error instanceof Error ? error.message : String(error);\n390:   if (operation === 'auto_vacuum') {\n391:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n392:   } else if (operation === 'incremental_vacuum') {\n393:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n394:   } else if (operation === 'wal_checkpoint') {\n395:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n396:   }\n397: }\n398: \n399: /**\n400:  * Sweep expired governed memory rows.\n401:  *\n402:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n403:  * to enforce the ISO timestamps persisted by governed ingest.\n404:  */\n405: export function runMemoryRetentionSweep(\n406:   database: Database.Database,\n407:   args: MemoryRetentionSweepArgs = {},\n408: ): MemoryRetentionSweepResult {\n409:   const startTime = Date.now();\n410:   const dryRun = args.dryRun === true;\n411:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n412: \n413:   if (!hasTable(database, 'memory_index')) {\n414:     return {\n415:       swept: 0,\n416:       retained: 0,\n417:       protectedCount: 0,\n418:       dryRun,\n419:       durationMs: Date.now() - startTime,\n420:       candidates: [],\n421:       deletedIds: [],\n422:       protectedIds: [],\n423:       ledgerRecorded: null,\n424:       tombstoneState: {\n425:         usesPurgeablePartition: false,\n426:         usingPurgeableIndex: false,\n427:         candidateCount: 0,\n428:         deletedCount: 0,\n429:       },\n430:       edgeState: {\n431:         causalEdgesTablePresent: false,\n432:         candidateEdgeCount: 0,\n433:       },\n434:     };\n435:   }\n436: \n437:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n438:   const initialEdgeState = buildEdgeState(database, candidates);\n439:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n440:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n441:     : null;\n442: \n443:   if (dryRun || candidates.length === 0) {\n444:     const totalRows = countRows(database);\n445:     const dryRunProtectedIds = candidates\n446:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n447:       .map((candidate) => candidate.id);\n448:     return {\n449:       swept: 0,\n450:       retained: totalRows,\n451:       protectedCount: dryRunProtectedIds.length,\n452:       dryRun,\n453:       durationMs: Date.now() - startTime,\n454:       candidates,\n455:       deletedIds: [],\n456:       protectedIds: dryRunProtectedIds,\n457:       ledgerRecorded: null,\n458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n459:       edgeState: initialEdgeState,\n460:       ...(feedbackRetention ? { feedbackRetention } : {}),\n461:     };\n462:   }\n463: \n464:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n465:     const auditTx = database.transaction(() => {\n466:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n467:         database,\n468:         candidates,\n469:         feedbackRetention,\n470:         false,\n471:       );\n472:     });\n473:     auditTx();\n474: \n475:     return {\n476:       swept: 0,\n477:       retained: countRows(database),\n478:       protectedCount: feedbackRetention.protectedIds.length,\n479:       dryRun,\n480:       durationMs: Date.now() - startTime,\n481:       candidates,\n482:       deletedIds: [],\n483:       protectedIds: feedbackRetention.protectedIds,\n484:       extendedIds: [],\n485:       ledgerRecorded: null,\n486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n487:       edgeState: initialEdgeState,\n488:       feedbackRetention,\n489:     };\n490:   }\n491: \n492:   initHistory(database);\n493: \n494:   const deletedIds: number[] = [];\n495:   const protectedIds: number[] = [];\n496:   const extendedIds: number[] = [];\n497:   let ledgerRecorded: boolean | null = null;\n498: \n499:   const sweepTx = database.transaction(() => {\n500:     for (const candidate of candidates) {\n501:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n502:       const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n503:       if (!currentCandidate) {\n504:         continue;\n505:       }\n506:       let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n507:       if (feedbackRetention) {\n508:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n509:         if (!decision) {\n510:           continue;\n511:         }\n512: \n513:         if (decision.decision === 'protect') {\n514:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n515:           protectedIds.push(candidate.id);\n516:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n517:             mode: feedbackRetention.mode,\n518:             applied: true,\n519:             activeGatePassed: feedbackRetention.activeGatePassed,\n520:           });\n521:           feedbackRetention.auditCount += 1;\n522:           continue;\n523:         }\n524: \n525:         if (decision.decision === 'extend') {\n526:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n527:             decision.nextDeleteAfter,\n528:             candidate.id,\n529:           );\n530:           extendedIds.push(candidate.id);\n531:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n532:             mode: feedbackRetention.mode,\n533:             applied: true,\n534:             activeGatePassed: feedbackRetention.activeGatePassed,\n535:           });\n536:           feedbackRetention.auditCount += 1;\n537:           continue;\n538:         }\n539:         feedbackDeleteDecision = decision;\n540:       }\n541:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n542:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n543:       if (isProtectedFromRetentionDelete(currentCandidate)) {\n544:         if (feedbackRetention && feedbackDeleteDecision) {\n545:           recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n546:             mode: feedbackRetention.mode,\n547:             applied: false,\n548:             activeGatePassed: feedbackRetention.activeGatePassed,\n549:           });\n550:           feedbackRetention.auditCount += 1;\n551:         }\n552:         protectedIds.push(currentCandidate.id);\n553:         recordGovernanceAudit(database, {\n554:           action: 'retention_sweep',\n555:           decision: 'deny',\n556:           memoryId: currentCandidate.id,\n557:           logicalKey: currentCandidate.filePath,\n558:           tenantId: currentCandidate.tenantId ?? undefined,\n559:           userId: currentCandidate.userId ?? undefined,\n560:           agentId: currentCandidate.agentId ?? undefined,\n561:           sessionId: currentCandidate.sessionId ?? undefined,\n562:           reason: 'retention_tier_protected',\n563:           metadata: {\n564:             originalDeleteAfter: currentCandidate.deleteAfter,\n565:             importanceTier: currentCandidate.importanceTier,\n566:             isPinned: currentCandidate.isPinned,\n567:             specFolder: currentCandidate.specFolder,\n568:             filePath: currentCandidate.filePath,\n569:           },\n570:         });\n571:         continue;\n572:       }\n573:       if (feedbackRetention && feedbackDeleteDecision) {\n574:         recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n575:           mode: feedbackRetention.mode,\n576:           applied: true,\n577:           activeGatePassed: feedbackRetention.activeGatePassed,\n578:         });\n579:         feedbackRetention.auditCount += 1;\n580:       }\n581:       const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n582:       if (!deleted) {\n583:         continue;\n584:       }\n585: \n586:       deletedIds.push(currentCandidate.id);\n587: \n588:       recordHistory(\n589:         currentCandidate.id,\n590:         'DELETE',\n591:         {\n592:           reason: 'retention_expired',\n593:           deleteAfter: currentCandidate.deleteAfter,\n594:           filePath: currentCandidate.filePath,\n595:         },\n596:         null,\n597:         'mcp:memory_retention_sweep',\n598:         currentCandidate.specFolder,\n599:       );\n600: \n601:       recordGovernanceAudit(database, {\n602:         action: 'retention_sweep',\n603:         decision: 'delete',\n604:         memoryId: currentCandidate.id,\n605:         logicalKey: currentCandidate.filePath,\n606:         tenantId: currentCandidate.tenantId ?? undefined,\n607:         userId: currentCandidate.userId ?? undefined,\n608:         agentId: currentCandidate.agentId ?? undefined,\n609:         sessionId: currentCandidate.sessionId ?? undefined,\n610:         reason: 'retention_expired',\n611:         metadata: {\n612:           originalDeleteAfter: currentCandidate.deleteAfter,\n613:           delete_after: currentCandidate.deleteAfter,\n614:           specFolder: currentCandidate.specFolder,\n615:           filePath: currentCandidate.filePath,\n616:         },\n617:       });\n618:     }\n619: \n620:     if (deletedIds.length > 0) {\n621:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n622:     }\n623:   });\n624: \n625:   sweepTx();\n626:   if (deletedIds.length > 0) {\n627:     runPostDeleteMaintenance(database);\n628:   }\n629:   if (feedbackRetention) {\n630:     feedbackRetention.extendedIds = extendedIds;\n631:     feedbackRetention.protectedIds = protectedIds;\n632:     feedbackRetention.deletedIds = deletedIds;\n633:   }\n634: \n635:   return {\n636:     swept: deletedIds.length,\n637:     retained: countRows(database),\n638:     protectedCount: protectedIds.length,\n639:     dryRun,\n640:     durationMs: Date.now() - startTime,\n641:     candidates,\n642:     deletedIds,\n643:     protectedIds,\n644:     ledgerRecorded,\n645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n646:     edgeState: initialEdgeState,\n647:     ...(feedbackRetention ? { extendedIds } : {}),\n648:     ...(feedbackRetention ? { feedbackRetention } : {}),\n649:   };\n650: }\n\n(End of file - total 650 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Retention Sweep\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Retention Sweep\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see вҖ” aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n      if (!currentCandidate) {\n        continue;\n      }\n      let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n        feedbackDeleteDecision = decision;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(currentCandidate)) {\n        if (feedbackRetention && feedbackDeleteDecision) {\n          recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n            mode: feedbackRetention.mode,\n            applied: false,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n        }\n        protectedIds.push(currentCandidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: currentCandidate.id,\n          logicalKey: currentCandidate.filePath,\n          tenantId: currentCandidate.tenantId ?? undefined,\n          userId: currentCandidate.userId ?? undefined,\n          agentId: currentCandidate.agentId ?? undefined,\n          sessionId: currentCandidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: currentCandidate.deleteAfter,\n            importanceTier: currentCandidate.importanceTier,\n            isPinned: currentCandidate.isPinned,\n            specFolder: currentCandidate.specFolder,\n            filePath: currentCandidate.filePath,\n          },\n        });\n        continue;\n      }\n      if (feedbackRetention && feedbackDeleteDecision) {\n        recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(currentCandidate.id);\n\n      recordHistory(\n        currentCandidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: currentCandidate.deleteAfter,\n          filePath: currentCandidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        currentCandidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: currentCandidate.id,\n        logicalKey: currentCandidate.filePath,\n        tenantId: currentCandidate.tenantId ?? undefined,\n        userId: currentCandidate.userId ?? undefined,\n        agentId: currentCandidate.agentId ?? undefined,\n        sessionId: currentCandidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: currentCandidate.deleteAfter,\n          delete_after: currentCandidate.deleteAfter,\n          specFolder: currentCandidate.specFolder,\n          filePath: currentCandidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),\n    ...(feedbackRetention ? { feedbackRetention } : {}),\n  };\n}","lineStart":1,"lineEnd":650,"totalLines":650,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781762877384,"end":1781762877397}},"metadata":{"openai":{"itemId":"fc_00bb168e403b2046016a338b3d3df88191a3d6d7d8cdddab05"}},"id":"prt_ed957e7c7001VhF6m7g8u151eI","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957bb72001yEPgUg0JVqBslj"}}
{"type":"tool_use","timestamp":1781762877400,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"type":"tool","tool":"read","callID":"call_SXihvlfqbygFBIXBaSgx0vf8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Idempotency Receipts\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: import { createHash } from 'node:crypto';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import type { MCPResponse } from '../../handlers/types.js';\n8: \n9: export type IdempotencyOperation = 'memory_save' | 'memory_update';\n10: \n11: export interface IdempotencyReceiptInput {\n12:   operation: IdempotencyOperation;\n13:   contentHash: string | null;\n14:   requestFingerprint: Record<string, unknown>;\n15:   payload: Record<string, unknown>;\n16: }\n17: \n18: export interface IdempotencyReceiptKey {\n19:   operation: IdempotencyOperation;\n20:   receiptKey: string;\n21:   contentHash: string | null;\n22:   requestFingerprintHash: string;\n23:   payloadHash: string;\n24: }\n25: \n26: export type IdempotencyLookupResult =\n27:   | { status: 'miss'; key: IdempotencyReceiptKey }\n28:   | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n29:   | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n30: \n31: interface ReceiptRow {\n32:   payload_hash: string;\n33:   response_payload: string;\n34: }\n35: \n36: interface MemorySaveReceiptCandidate {\n37:   id?: unknown;\n38:   status?: unknown;\n39: }\n40: \n41: const RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n42: \n43: const CLIENT_TOKEN_KEYS = new Set([\n44:   'idempotencykey',\n45:   'idempotency_key',\n46:   'idempotencytoken',\n47:   'idempotency_token',\n48:   'clientidempotencykey',\n49:   'client_idempotency_key',\n50:   'clientidempotencytoken',\n51:   'client_idempotency_token',\n52: ]);\n53: \n54: export function isMemoryIdempotencyEnabled(): boolean {\n55:   const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n56:   return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n57: }\n58: \n59: function normalizeForHash(value: unknown): unknown {\n60:   if (Array.isArray(value)) {\n61:     return value.map(normalizeForHash);\n62:   }\n63:   if (!value || typeof value !== 'object') {\n64:     return value;\n65:   }\n66: \n67:   const record = value as Record<string, unknown>;\n68:   const normalized: Record<string, unknown> = {};\n69:   for (const key of Object.keys(record).sort()) {\n70:     if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n71:       continue;\n72:     }\n73:     const normalizedValue = normalizeForHash(record[key]);\n74:     if (normalizedValue !== undefined) {\n75:       normalized[key] = normalizedValue;\n76:     }\n77:   }\n78:   return normalized;\n79: }\n80: \n81: function hashJson(value: unknown): string {\n82:   return createHash('sha256')\n83:     .update(JSON.stringify(normalizeForHash(value)))\n84:     .digest('hex');\n85: }\n86: \n87: export function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n88:   const requestFingerprintHash = hashJson(input.requestFingerprint);\n89:   const payloadHash = hashJson(input.payload);\n90:   const material = {\n91:     operation: input.operation,\n92:     contentHash: input.contentHash ?? null,\n93:     requestFingerprintHash,\n94:   };\n95:   return {\n96:     operation: input.operation,\n97:     receiptKey: hashJson(material),\n98:     contentHash: input.contentHash ?? null,\n99:     requestFingerprintHash,\n100:     payloadHash,\n101:   };\n102: }\n103: \n104: export function shouldStoreMemorySaveReceipt(\n105:   result: MemorySaveReceiptCandidate,\n106:   response: MCPResponse,\n107: ): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n108:   return response.isError !== true\n109:     && typeof result.id === 'number'\n110:     && Number.isInteger(result.id)\n111:     && result.id > 0\n112:     && typeof result.status === 'string'\n113:     && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n114: }\n115: \n116: export function lookupIdempotencyReceipt(\n117:   database: BetterSqlite3.Database,\n118:   input: IdempotencyReceiptInput,\n119: ): IdempotencyLookupResult {\n120:   return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n121: }\n122: \n123: export function lookupIdempotencyReceiptByKey(\n124:   database: BetterSqlite3.Database,\n125:   key: IdempotencyReceiptKey,\n126: ): IdempotencyLookupResult {\n127:   const row = database.prepare(`\n128:     SELECT payload_hash, response_payload\n129:     FROM memory_idempotency_receipts\n130:     WHERE receipt_key = ?\n131:   `).get(key.receiptKey) as ReceiptRow | undefined;\n132: \n133:   if (!row) {\n134:     return { status: 'miss', key };\n135:   }\n136:   if (row.payload_hash !== key.payloadHash) {\n137:     return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n138:   }\n139:   return {\n140:     status: 'replay',\n141:     key,\n142:     response: JSON.parse(row.response_payload) as MCPResponse,\n143:   };\n144: }\n145: \n146: /**\n147:  * Drops the receipt for a key so a follow-up store writes fresh.\n148:  *\n149:  * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n150:  * not a durable record. When a replay is rejected because the live index no\n151:  * longer matches the receipt's content_hash (the logical path moved on and\n152:  * came back, so the cached response now carries a superseded memory id), the\n153:  * cache entry is stale: leaving it lets the post-write store lose the\n154:  * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n155:  * it first lets the re-indexed write store its current response and keeps the\n156:  * cache consistent with the active row. Best-effort: a delete failure must\n157:  * never block serving the live write.\n158:  */\n159: export function deleteIdempotencyReceiptByKey(\n160:   database: BetterSqlite3.Database,\n161:   key: IdempotencyReceiptKey,\n162: ): void {\n163:   try {\n164:     database.prepare(`\n165:       DELETE FROM memory_idempotency_receipts\n166:       WHERE receipt_key = ?\n167:     `).run(key.receiptKey);\n168:   } catch {\n169:     // Best-effort cache eviction; serving the live write takes priority.\n170:   }\n171: }\n172: \n173: export function storeIdempotencyReceipt(\n174:   database: BetterSqlite3.Database,\n175:   key: IdempotencyReceiptKey,\n176:   response: MCPResponse,\n177:   memoryId?: number | null,\n178: ): boolean {\n179:   const info = database.prepare(`\n180:     INSERT INTO memory_idempotency_receipts (\n181:       receipt_key,\n182:       operation,\n183:       content_hash,\n184:       request_fingerprint,\n185:       payload_hash,\n186:       response_payload,\n187:       memory_id,\n188:       updated_at\n189:     ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n190:     ON CONFLICT(receipt_key) DO NOTHING\n191:   `).run(\n192:     key.receiptKey,\n193:     key.operation,\n194:     key.contentHash,\n195:     key.requestFingerprintHash,\n196:     key.payloadHash,\n197:     JSON.stringify(response),\n198:     memoryId ?? null,\n199:   );\n200:   // changes === 0 means a concurrent caller already stored the canonical receipt\n201:   // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n202:   return info.changes > 0;\n203: }\n204: \n205: /**\n206:  * Marks a mutated loser's response with an explicit store-race conflict.\n207:  *\n208:  * When a writer loses the first-store race to a concurrent SAME-KEY,\n209:  * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n210:  * already landed (so an error response would lie), and the winner's stored\n211:  * response answers a different payload (so replaying it would lie too).\n212:  * Rolling the landed mutation back from this late window is the dangerous\n213:  * non-option. What remains is the loser's own response carrying a visible\n214:  * conflict block, so callers know the canonical receipt for this key\n215:  * belongs to a different concurrent request and a later retry may replay\n216:  * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n217:  * original response is returned unmodified.\n218:  */\n219: export function markResponseWithReceiptStoreConflict(\n220:   response: MCPResponse,\n221:   key: IdempotencyReceiptKey,\n222:   storedPayloadHash: string | undefined,\n223: ): MCPResponse {\n224:   const first = response.content?.[0];\n225:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n226:     return response;\n227:   }\n228:   try {\n229:     const envelope = JSON.parse(first.text) as Record<string, unknown>;\n230:     const data = (envelope.data && typeof envelope.data === 'object')\n231:       ? envelope.data as Record<string, unknown>\n232:       : {};\n233:     data.idempotencyStoreConflict = {\n234:       receiptKey: key.receiptKey,\n235:       payloadHash: key.payloadHash,\n236:       storedPayloadHash: storedPayloadHash ?? null,\n237:     };\n238:     envelope.data = data;\n239:     const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n240:     hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n241:     envelope.hints = hints;\n242:     return {\n243:       ...response,\n244:       content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n245:     };\n246:   } catch {\n247:     return response;\n248:   }\n249: }\n250: \n251: /**\n252:  * Deletes receipts older than the retention window. Receipts are replay\n253:  * caches, not durable records: unbounded growth plus indefinite stale\n254:  * replays (including against deleted memories) is the failure mode this\n255:  * sweep bounds. Best-effort by contract вҖ” callers must never let a sweep\n256:  * failure block serving.\n257:  */\n258: export function pruneExpiredIdempotencyReceipts(\n259:   database: BetterSqlite3.Database,\n260:   ttlDays?: number,\n261: ): number {\n262:   const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n263:   const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n264:   try {\n265:     // Prune on created_at: it is indexed and, since receipts are insert-only\n266:     // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at вҖ”\n267:     // so this is behaviorally identical but avoids a full table scan.\n268:     const info = database.prepare(`\n269:       DELETE FROM memory_idempotency_receipts\n270:       WHERE created_at < datetime('now', ?)\n271:     `).run(`-${days} days`);\n272:     return info.changes;\n273:   } catch {\n274:     return 0;\n275:   }\n276: }\n277: \n278: export function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n279:   const first = response.content?.[0];\n280:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n281:     return null;\n282:   }\n283:   try {\n284:     const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n285:     const id = envelope.data?.id ?? envelope.data?.updated;\n286:     return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n287:   } catch {\n288:     return null;\n289:   }\n290: }\n\n(End of file - total 290 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Idempotency Receipts\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Idempotency Receipts\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;\n  contentHash: string | null;\n  requestFingerprintHash: string;\n  payloadHash: string;\n}\n\nexport type IdempotencyLookupResult =\n  | { status: 'miss'; key: IdempotencyReceiptKey }\n  | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n  | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n\ninterface ReceiptRow {\n  payload_hash: string;\n  response_payload: string;\n}\n\ninterface MemorySaveReceiptCandidate {\n  id?: unknown;\n  status?: unknown;\n}\n\nconst RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n\nconst CLIENT_TOKEN_KEYS = new Set([\n  'idempotencykey',\n  'idempotency_key',\n  'idempotencytoken',\n  'idempotency_token',\n  'clientidempotencykey',\n  'client_idempotency_key',\n  'clientidempotencytoken',\n  'client_idempotency_token',\n]);\n\nexport function isMemoryIdempotencyEnabled(): boolean {\n  const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n  return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n}\n\nfunction normalizeForHash(value: unknown): unknown {\n  if (Array.isArray(value)) {\n    return value.map(normalizeForHash);\n  }\n  if (!value || typeof value !== 'object') {\n    return value;\n  }\n\n  const record = value as Record<string, unknown>;\n  const normalized: Record<string, unknown> = {};\n  for (const key of Object.keys(record).sort()) {\n    if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n      continue;\n    }\n    const normalizedValue = normalizeForHash(record[key]);\n    if (normalizedValue !== undefined) {\n      normalized[key] = normalizedValue;\n    }\n  }\n  return normalized;\n}\n\nfunction hashJson(value: unknown): string {\n  return createHash('sha256')\n    .update(JSON.stringify(normalizeForHash(value)))\n    .digest('hex');\n}\n\nexport function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n  const requestFingerprintHash = hashJson(input.requestFingerprint);\n  const payloadHash = hashJson(input.payload);\n  const material = {\n    operation: input.operation,\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n  };\n  return {\n    operation: input.operation,\n    receiptKey: hashJson(material),\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n    payloadHash,\n  };\n}\n\nexport function shouldStoreMemorySaveReceipt(\n  result: MemorySaveReceiptCandidate,\n  response: MCPResponse,\n): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n  return response.isError !== true\n    && typeof result.id === 'number'\n    && Number.isInteger(result.id)\n    && result.id > 0\n    && typeof result.status === 'string'\n    && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n}\n\nexport function lookupIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  input: IdempotencyReceiptInput,\n): IdempotencyLookupResult {\n  return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n}\n\nexport function lookupIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): IdempotencyLookupResult {\n  const row = database.prepare(`\n    SELECT payload_hash, response_payload\n    FROM memory_idempotency_receipts\n    WHERE receipt_key = ?\n  `).get(key.receiptKey) as ReceiptRow | undefined;\n\n  if (!row) {\n    return { status: 'miss', key };\n  }\n  if (row.payload_hash !== key.payloadHash) {\n    return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n  }\n  return {\n    status: 'replay',\n    key,\n    response: JSON.parse(row.response_payload) as MCPResponse,\n  };\n}\n\n/**\n * Drops the receipt for a key so a follow-up store writes fresh.\n *\n * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n * not a durable record. When a replay is rejected because the live index no\n * longer matches the receipt's content_hash (the logical path moved on and\n * came back, so the cached response now carries a superseded memory id), the\n * cache entry is stale: leaving it lets the post-write store lose the\n * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n * it first lets the re-indexed write store its current response and keeps the\n * cache consistent with the active row. Best-effort: a delete failure must\n * never block serving the live write.\n */\nexport function deleteIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): void {\n  try {\n    database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE receipt_key = ?\n    `).run(key.receiptKey);\n  } catch {\n    // Best-effort cache eviction; serving the live write takes priority.\n  }\n}\n\nexport function storeIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n  response: MCPResponse,\n  memoryId?: number | null,\n): boolean {\n  const info = database.prepare(`\n    INSERT INTO memory_idempotency_receipts (\n      receipt_key,\n      operation,\n      content_hash,\n      request_fingerprint,\n      payload_hash,\n      response_payload,\n      memory_id,\n      updated_at\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n    ON CONFLICT(receipt_key) DO NOTHING\n  `).run(\n    key.receiptKey,\n    key.operation,\n    key.contentHash,\n    key.requestFingerprintHash,\n    key.payloadHash,\n    JSON.stringify(response),\n    memoryId ?? null,\n  );\n  // changes === 0 means a concurrent caller already stored the canonical receipt\n  // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n  return info.changes > 0;\n}\n\n/**\n * Marks a mutated loser's response with an explicit store-race conflict.\n *\n * When a writer loses the first-store race to a concurrent SAME-KEY,\n * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n * already landed (so an error response would lie), and the winner's stored\n * response answers a different payload (so replaying it would lie too).\n * Rolling the landed mutation back from this late window is the dangerous\n * non-option. What remains is the loser's own response carrying a visible\n * conflict block, so callers know the canonical receipt for this key\n * belongs to a different concurrent request and a later retry may replay\n * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n * original response is returned unmodified.\n */\nexport function markResponseWithReceiptStoreConflict(\n  response: MCPResponse,\n  key: IdempotencyReceiptKey,\n  storedPayloadHash: string | undefined,\n): MCPResponse {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return response;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as Record<string, unknown>;\n    const data = (envelope.data && typeof envelope.data === 'object')\n      ? envelope.data as Record<string, unknown>\n      : {};\n    data.idempotencyStoreConflict = {\n      receiptKey: key.receiptKey,\n      payloadHash: key.payloadHash,\n      storedPayloadHash: storedPayloadHash ?? null,\n    };\n    envelope.data = data;\n    const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n    hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n    envelope.hints = hints;\n    return {\n      ...response,\n      content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n    };\n  } catch {\n    return response;\n  }\n}\n\n/**\n * Deletes receipts older than the retention window. Receipts are replay\n * caches, not durable records: unbounded growth plus indefinite stale\n * replays (including against deleted memories) is the failure mode this\n * sweep bounds. Best-effort by contract вҖ” callers must never let a sweep\n * failure block serving.\n */\nexport function pruneExpiredIdempotencyReceipts(\n  database: BetterSqlite3.Database,\n  ttlDays?: number,\n): number {\n  const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n  const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n  try {\n    // Prune on created_at: it is indexed and, since receipts are insert-only\n    // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at вҖ”\n    // so this is behaviorally identical but avoids a full table scan.\n    const info = database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE created_at < datetime('now', ?)\n    `).run(`-${days} days`);\n    return info.changes;\n  } catch {\n    return 0;\n  }\n}\n\nexport function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return null;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n    const id = envelope.data?.id ?? envelope.data?.updated;\n    return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n  } catch {\n    return null;\n  }\n}","lineStart":1,"lineEnd":290,"totalLines":290,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","time":{"start":1781762877386,"end":1781762877399}},"metadata":{"openai":{"itemId":"fc_00bb168e403b2046016a338b3d3e00819181c4813a200ca963"}},"id":"prt_ed957e7c9001XExWO9IqmMOPIp","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957bb72001yEPgUg0JVqBslj"}}
{"type":"tool_use","timestamp":1781762877402,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"type":"tool","tool":"read","callID":"call_7hVC9GKcpG0kzaHzo5MvbdRx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Job Queue\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // True sequential worker, meaningful state transitions,\n5: // Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n6: // Crash recovery with re-enqueue, and original-path progress tracking.\n7: \n8: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n9:    1. IMPORTS\n10: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n11: \n12: import path from 'node:path';\n13: import { requireDb, toErrorMessage } from '../../utils/index.js';\n14: import type { GovernanceDecision } from '../governance/scope-governance.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: // Feature catalog: Async ingestion job lifecycle\n18: \n19: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n20:    2. TYPES\n21: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n22: \n23: /**\n24:  * Defines the IngestJobState type.\n25:  */\n26: export type IngestJobState =\n27:   | 'queued'\n28:   | 'parsing'\n29:   | 'embedding'\n30:   | 'indexing'\n31:   | 'complete'\n32:   | 'failed'\n33:   | 'cancelled';\n34: \n35: /**\n36:  * Describes the IngestJobError shape.\n37:  */\n38: export interface IngestJobError {\n39:   filePath: string;\n40:   message: string;\n41:   timestamp: string;\n42: }\n43: \n44: /**\n45:  * Describes the IngestJob shape.\n46:  */\n47: export interface IngestJob {\n48:   id: string;\n49:   state: IngestJobState;\n50:   specFolder: string | null;\n51:   paths: string[];\n52:   filesTotal: number;\n53:   filesProcessed: number;\n54:   errors: IngestJobError[];\n55:   createdAt: string;\n56:   updatedAt: string;\n57:   // Validated governance decision captured at enqueue time so the worker\n58:   // re-indexes each path under the same provenance/retention/scope the\n59:   // synchronous save path applies. Null for ungoverned jobs (the default).\n60:   governance: GovernanceDecision | null;\n61: }\n62: \n63: export interface IngestJobForecast {\n64:   etaSeconds: number | null;\n65:   etaConfidence: number | null;\n66:   failureRisk: number | null;\n67:   riskSignals: string[];\n68:   caveat: string | null;\n69: }\n70: \n71: interface IngestJobRow {\n72:   id: string;\n73:   state: IngestJobState;\n74:   spec_folder: string | null;\n75:   paths_json: string;\n76:   files_total: number;\n77:   files_processed: number;\n78:   errors_json: string;\n79:   created_at: string;\n80:   updated_at: string;\n81:   governance_json?: string | null;\n82: }\n83: \n84: interface JobQueueConfig {\n85:   processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n86: }\n87: \n88: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n89:    3. CONSTANTS\n90: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n91: \n92: const ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\n93: const TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n94: \n95: const ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n96:   queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n97:   parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n98:   embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n99:   indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n100:   complete: new Set<IngestJobState>([]),\n101:   failed: new Set<IngestJobState>([]),\n102:   cancelled: new Set<IngestJobState>([]),\n103: };\n104: \n105: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n106:    5. STATE MANAGEMENT\n107: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n108: \n109: // True sequential queue вҖ” only one job processes at a time.\n110: const pendingQueue: string[] = [];\n111: let workerActive = false;\n112: // Drain fence. Once set, the worker stops draining and refuses to touch the\n113: // database. This prevents the worker from reopening a connection that shutdown\n114: // has already checkpointed and closed, which would otherwise re-dirty the WAL\n115: // and the unclean-shutdown marker at rest.\n116: let shuttingDown = false;\n117: let processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\n118: const MAX_STORED_ERRORS = 50;\n119: const MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n120: \n121: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n122:    4. HELPERS\n123: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n124: \n125: function toPublicPathLabel(filePath: string): string {\n126:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n127: }\n128: \n129: function sleep(ms: number): Promise<void> {\n130:   return new Promise((resolve) => setTimeout(resolve, ms));\n131: }\n132: \n133: function parsePositiveIntEnv(name: string, fallback: number): number {\n134:   const raw = process.env[name];\n135:   if (!raw) return fallback;\n136: \n137:   const parsed = Number.parseInt(raw, 10);\n138:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n139: }\n140: \n141: function parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n142:   if (!value) return fallback;\n143:   try {\n144:     const parsed = JSON.parse(value) as unknown;\n145:     return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n146:   } catch (_error: unknown) {\n147:     return fallback;\n148:   }\n149: }\n150: \n151: function parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n152:   if (!value) return null;\n153:   try {\n154:     const parsed = JSON.parse(value) as unknown;\n155:     if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n156:       return parsed as GovernanceDecision;\n157:     }\n158:     return null;\n159:   } catch (_error: unknown) {\n160:     return null;\n161:   }\n162: }\n163: \n164: function mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n165:   if (!row) return null;\n166:   return {\n167:     id: row.id,\n168:     state: row.state,\n169:     specFolder: row.spec_folder,\n170:     paths: parseJsonArray<string>(row.paths_json, []),\n171:     filesTotal: row.files_total,\n172:     filesProcessed: row.files_processed,\n173:     errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n174:     createdAt: row.created_at,\n175:     updatedAt: row.updated_at,\n176:     governance: parseGovernanceJson(row.governance_json),\n177:   };\n178: }\n179: \n180: function nowIso(): string {\n181:   return new Date().toISOString();\n182: }\n183: \n184: function isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n185:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n186: }\n187: \n188: // DB accessor for the worker path. While shutting down it refuses to acquire a\n189: // connection so the worker can never travel the requireDb -> getDb -> reopen\n190: // path after shutdown has closed the database. The throw is caught by the\n191: // worker's surrounding error handling and the drain unwinds cleanly.\n192: function acquireWorkerDb(): ReturnType<typeof requireDb> {\n193:   if (shuttingDown) {\n194:     throw new Error('Ingest worker is shutting down; database access refused');\n195:   }\n196:   return requireDb();\n197: }\n198: \n199: function ensureIngestJobsTable(): void {\n200:   const db = requireDb();\n201:   db.exec(`\n202:     CREATE TABLE IF NOT EXISTS ingest_jobs (\n203:       id TEXT PRIMARY KEY,\n204:       state TEXT,\n205:       spec_folder TEXT,\n206:       paths_json TEXT,\n207:       files_total INTEGER,\n208:       files_processed INTEGER,\n209:       errors_json TEXT,\n210:       created_at TEXT,\n211:       updated_at TEXT,\n212:       governance_json TEXT\n213:     )\n214:   `);\n215:   // Backward-compatible migration: add the nullable governance column to tables\n216:   // created before governed ingest existed. In-flight jobs simply carry a null\n217:   // governance and remain ungoverned, exactly as before.\n218:   const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n219:   if (!columns.some((column) => column.name === 'governance_json')) {\n220:     db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n221:   }\n222: }\n223: \n224: // Restart interrupted jobs from the beginning on process startup.\n225: // Indexing is idempotent, and replaying the original path list avoids\n226: // Mismatches when path accessibility changes between runs.\n227: function resetIncompleteJobsToQueued(): string[] {\n228:   const db = requireDb();\n229:   // Collect IDs of jobs that will be reset so we can re-enqueue them.\n230:   const rows = db.prepare(`\n231:     SELECT id FROM ingest_jobs\n232:     WHERE state NOT IN ('complete', 'failed', 'cancelled')\n233:   `).all() as Array<{ id: string }>;\n234: \n235:   if (rows.length === 0) return [];\n236: \n237:   withBusyRetrySync(() =>\n238:     db.prepare(`\n239:       UPDATE ingest_jobs\n240:       SET\n241:         state = 'queued',\n242:         files_processed = 0,\n243:         errors_json = '[]',\n244:         updated_at = ?\n245:       WHERE state NOT IN ('complete', 'failed', 'cancelled')\n246:     `).run(nowIso())\n247:   );\n248: \n249:   return rows.map((r) => r.id);\n250: }\n251: \n252: async function createIngestJob(args: {\n253:   id: string;\n254:   paths: string[];\n255:   specFolder?: string;\n256:   governance?: GovernanceDecision | null;\n257: }): Promise<IngestJob> {\n258:   const db = requireDb();\n259:   const timestamp = nowIso();\n260:   const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n261: \n262:   if (normalizedPaths.length === 0) {\n263:     throw new Error('paths must include at least one file path');\n264:   }\n265: \n266:   const governance = args.governance ?? null;\n267:   const governanceJson = governance ? JSON.stringify(governance) : null;\n268: \n269:   await withBusyRetry(() =>\n270:     db.prepare(`\n271:       INSERT INTO ingest_jobs (\n272:         id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n273:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n274:     `).run(\n275:       args.id,\n276:       'queued',\n277:       args.specFolder ?? null,\n278:       JSON.stringify(normalizedPaths),\n279:       normalizedPaths.length,\n280:       0,\n281:       JSON.stringify([]),\n282:       timestamp,\n283:       timestamp,\n284:       governanceJson,\n285:     )\n286:   );\n287: \n288:   return {\n289:     id: args.id,\n290:     state: 'queued',\n291:     specFolder: args.specFolder ?? null,\n292:     paths: normalizedPaths,\n293:     filesTotal: normalizedPaths.length,\n294:     filesProcessed: 0,\n295:     errors: [],\n296:     createdAt: timestamp,\n297:     updatedAt: timestamp,\n298:     governance,\n299:   };\n300: }\n301: \n302: function getIngestJob(jobId: string): IngestJob | null {\n303:   const db = acquireWorkerDb();\n304:   const row = db.prepare(`\n305:     SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n306:     FROM ingest_jobs\n307:     WHERE id = ?\n308:   `).get(jobId) as IngestJobRow | undefined;\n309:   return mapRowToJob(row);\n310: }\n311: \n312: async function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n313:   const db = acquireWorkerDb();\n314:   const current = getIngestJob(jobId);\n315:   if (!current) {\n316:     throw new Error(`Ingest job not found: ${jobId}`);\n317:   }\n318: \n319:   if (current.state === nextState) {\n320:     return current;\n321:   }\n322: \n323:   if (!isTransitionAllowed(current.state, nextState)) {\n324:     throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n325:   }\n326: \n327:   const updatedAt = nowIso();\n328:   const result = await withBusyRetry(() =>\n329:     db.prepare(`\n330:       UPDATE ingest_jobs\n331:       SET state = ?, updated_at = ?\n332:       WHERE id = ? AND state = ?\n333:     `).run(nextState, updatedAt, jobId, current.state)\n334:   );\n335: \n336:   if ((result as { changes: number }).changes === 0) {\n337:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n338:   }\n339: \n340:   return {\n341:     ...current,\n342:     state: nextState,\n343:     updatedAt,\n344:   };\n345: }\n346: \n347: async function incrementProcessed(jobId: string): Promise<IngestJob> {\n348:   const db = acquireWorkerDb();\n349:   const updatedAt = nowIso();\n350:   await withBusyRetry(() =>\n351:     db.prepare(`\n352:       UPDATE ingest_jobs\n353:       SET files_processed = files_processed + 1, updated_at = ?\n354:       WHERE id = ?\n355:     `).run(updatedAt, jobId)\n356:   );\n357: \n358:   const updated = getIngestJob(jobId);\n359:   if (!updated) {\n360:     throw new Error(`Ingest job not found after progress update: ${jobId}`);\n361:   }\n362:   return updated;\n363: }\n364: \n365: async function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n366:   const db = acquireWorkerDb();\n367:   const current = getIngestJob(jobId);\n368:   if (!current) {\n369:     throw new Error(`Ingest job not found: ${jobId}`);\n370:   }\n371: \n372:   let errors = [\n373:     ...current.errors,\n374:     {\n375:       filePath: toPublicPathLabel(filePath),\n376:       message: toErrorMessage(error),\n377:       timestamp: nowIso(),\n378:     },\n379:   ];\n380: \n381:   if (errors.length > MAX_STORED_ERRORS) {\n382:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n383:     const trimmedCount = errors.length - tailLength;\n384:     const truncationNotice: IngestJobError = {\n385:       filePath: '__job__',\n386:       message: `error log truncated (${trimmedCount} older entries removed)`,\n387:       timestamp: nowIso(),\n388:     };\n389:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n390:     errors = [truncationNotice, ...truncatedTail];\n391:   }\n392: \n393:   const updatedAt = nowIso();\n394:   await withBusyRetry(() =>\n395:     db.prepare(`\n396:       UPDATE ingest_jobs\n397:       SET errors_json = ?, updated_at = ?\n398:       WHERE id = ?\n399:     `).run(JSON.stringify(errors), updatedAt, jobId)\n400:   );\n401: \n402:   return {\n403:     ...current,\n404:     errors,\n405:     updatedAt,\n406:   };\n407: }\n408: \n409: async function cancelIngestJob(jobId: string): Promise<IngestJob> {\n410:   const MAX_CANCEL_RETRIES = 3;\n411: \n412:   for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n413:     const current = getIngestJob(jobId);\n414:     if (!current) {\n415:       throw new Error(`Ingest job not found: ${jobId}`);\n416:     }\n417:     if (TERMINAL_STATES.has(current.state)) {\n418:       return current;\n419:     }\n420: \n421:     try {\n422:       return await setIngestJobState(jobId, 'cancelled');\n423:     } catch (error: unknown) {\n424:       const message = toErrorMessage(error);\n425:       if (message.startsWith('State transition conflict:')) {\n426:         continue;\n427:       }\n428: \n429:       if (message.startsWith('Invalid ingest job state transition:')) {\n430:         const latest = getIngestJob(jobId);\n431:         if (latest && TERMINAL_STATES.has(latest.state)) {\n432:           return latest;\n433:         }\n434:         continue;\n435:       }\n436: \n437:       throw error;\n438:     }\n439:   }\n440: \n441:   const latest = getIngestJob(jobId);\n442:   if (!latest) {\n443:     throw new Error(`Ingest job not found: ${jobId}`);\n444:   }\n445:   if (TERMINAL_STATES.has(latest.state)) {\n446:     return latest;\n447:   }\n448: \n449:   return setIngestJobState(jobId, 'cancelled');\n450: }\n451: \n452: /**\n453:  * Provides the getIngestProgressPercent helper.\n454:  */\n455: export function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n456:   if (job.filesTotal <= 0) return 0;\n457:   const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n458:   return Math.max(0, Math.min(100, raw));\n459: }\n460: \n461: function parseIsoTimestamp(timestamp: string): number | null {\n462:   if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n463:     return null;\n464:   }\n465: \n466:   const parsed = Date.parse(timestamp);\n467:   return Number.isFinite(parsed) ? parsed : null;\n468: }\n469: \n470: function clampUnitInterval(value: number): number {\n471:   if (!Number.isFinite(value)) return 0;\n472:   return Math.max(0, Math.min(1, value));\n473: }\n474: \n475: export function getIngestForecast(\n476:   job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n477: ): IngestJobForecast {\n478:   const filesTotal = Math.max(0, job.filesTotal || 0);\n479:   const filesProcessed = Math.max(0, job.filesProcessed || 0);\n480:   const remaining = Math.max(0, filesTotal - filesProcessed);\n481:   const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n482:   const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n483:   const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n484:   const riskSignals: string[] = [];\n485: \n486:   if (job.state === 'failed') {\n487:     return {\n488:       etaSeconds: 0,\n489:       etaConfidence: 1,\n490:       failureRisk: 1,\n491:       riskSignals: ['terminal_failed'],\n492:       caveat: null,\n493:     };\n494:   }\n495: \n496:   if (job.state === 'complete') {\n497:     return {\n498:       etaSeconds: 0,\n499:       etaConfidence: 1,\n500:       failureRisk: clampUnitInterval(errorRatio * 0.5),\n501:       riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n502:       caveat: null,\n503:     };\n504:   }\n505: \n506:   if (job.state === 'cancelled') {\n507:     return {\n508:       etaSeconds: 0,\n509:       etaConfidence: 1,\n510:       failureRisk: 0,\n511:       riskSignals: ['terminal_cancelled'],\n512:       caveat: 'Forecast is advisory only because the job is no longer progressing.',\n513:     };\n514:   }\n515: \n516:   if (filesTotal <= 0) {\n517:     return {\n518:       etaSeconds: null,\n519:       etaConfidence: null,\n520:       failureRisk: null,\n521:       riskSignals,\n522:       caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n523:     };\n524:   }\n525: \n526:   if (errorCount > 0) {\n527:     riskSignals.push('file_errors_seen');\n528:   }\n529:   if (job.state === 'queued') {\n530:     riskSignals.push('queued_not_started');\n531:   }\n532: \n533:   const createdAtMs = parseIsoTimestamp(job.createdAt);\n534:   const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n535:   const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n536:     ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n537:     : 0;\n538: \n539:   let etaSeconds: number | null = null;\n540:   let etaConfidence: number | null = null;\n541:   let caveat: string | null = null;\n542: \n543:   if (filesProcessed <= 0 || elapsedSeconds < 1) {\n544:     caveat = 'Forecast is low-confidence until at least one file has been processed.';\n545:   } else {\n546:     const throughput = filesProcessed / elapsedSeconds;\n547:     if (throughput > 0) {\n548:       etaSeconds = Math.max(0, Math.round(remaining / throughput));\n549:       etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n550:       if (etaConfidence < 0.4) {\n551:         caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n552:       }\n553:     } else {\n554:       caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n555:     }\n556:   }\n557: \n558:   if (progressRatio <= 0 && job.state !== 'queued') {\n559:     riskSignals.push('active_without_progress');\n560:   }\n561:   if (errorRatio >= 0.5 && errorCount > 0) {\n562:     riskSignals.push('high_error_ratio');\n563:   }\n564: \n565:   const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n566:   const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n567: \n568:   return {\n569:     etaSeconds,\n570:     etaConfidence,\n571:     failureRisk,\n572:     riskSignals,\n573:     caveat,\n574:   };\n575: }\n576: \n577: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n578:    6. WORKER\n579: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n580: \n581: // Real state machine вҖ” states now correspond to actual work phases.\n582: // Progress is tracked against the original submitted path list so terminal\n583: // Accounting stays stable even when some files are inaccessible.\n584: async function processQueuedJob(jobId: string): Promise<void> {\n585:   if (!processFileFn) {\n586:     throw new Error('Ingest queue not initialized: processFile handler is missing');\n587:   }\n588: \n589:   let job = getIngestJob(jobId);\n590:   if (!job || TERMINAL_STATES.has(job.state)) {\n591:     return;\n592:   }\n593: \n594:   // Step 1: Parsing вҖ” validate all paths exist and are readable.\n595:   job = await setIngestJobState(jobId, 'parsing');\n596:   if (TERMINAL_STATES.has(job.state)) return;\n597: \n598:   const { access } = await import('fs/promises');\n599: \n600:   // Step 2: Embedding вҖ” placeholder for batch embedding pre-processing.\n601:   // Transition is meaningful: it signals readiness for indexing after validation.\n602:   const latest1 = getIngestJob(jobId);\n603:   if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n604:   job = await setIngestJobState(jobId, 'embedding');\n605:   if (TERMINAL_STATES.has(job.state)) return;\n606: \n607:   // Step 3: Indexing вҖ” process only validated paths (not original paths).\n608:   const latest2 = getIngestJob(jobId);\n609:   if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n610:   job = await setIngestJobState(jobId, 'indexing');\n611: \n612:   // Resume from filesProcessed against the original submitted path order.\n613:   let currentIndex = job.filesProcessed;\n614:   // Track actual failure count independently of the truncated errors array.\n615:   // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n616:   // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n617:   let failCount = 0;\n618: \n619:   while (currentIndex < job.paths.length) {\n620:     // Stop touching the DB the moment shutdown begins. The job stays in an\n621:     // active state and boot crash-recovery re-enqueues it on the next start.\n622:     if (shuttingDown) return;\n623:     const current = getIngestJob(jobId);\n624:     if (!current) return;\n625:     if (current.state === 'cancelled') return;\n626: \n627:     const nextPath = current.paths[currentIndex];\n628:     if (!nextPath) {\n629:       break;\n630:     }\n631: \n632:     // Continue on file error instead of aborting the entire job.\n633:     try {\n634:       await access(nextPath);\n635:       await processFileFn(nextPath, current.governance);\n636:     } catch (error: unknown) {\n637:       const normalizedError = error instanceof Error\n638:         && 'code' in error\n639:         && typeof error.code === 'string'\n640:         && error.code === 'ENOENT'\n641:         ? new Error('File not accessible')\n642:         : error;\n643:       await appendIngestError(jobId, nextPath, normalizedError);\n644:       failCount += 1;\n645:       console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} вҖ” ${toErrorMessage(normalizedError)}`);\n646:     }\n647: \n648:     job = await incrementProcessed(jobId);\n649:     currentIndex = job.filesProcessed;\n650:   }\n651: \n652:   // Determine terminal state: complete if no errors, failed if all files errored.\n653:   const done = getIngestJob(jobId);\n654:   if (!done) return;\n655:   if (done.state === 'cancelled') return;\n656: \n657:   if (failCount > 0 && failCount >= done.filesTotal) {\n658:     // All files failed вҖ” mark as failed.\n659:     await setIngestJobState(jobId, 'failed');\n660:   } else {\n661:     // Partial or full success вҖ” mark as complete (errors are preserved in record).\n662:     await setIngestJobState(jobId, 'complete');\n663:   }\n664: }\n665: \n666: // True sequential worker вҖ” processes one job at a time.\n667: // Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\n668: async function drainQueue(): Promise<void> {\n669:   if (workerActive) return;\n670:   workerActive = true;\n671: \n672:   try {\n673:     while (pendingQueue.length > 0) {\n674:       // Halt draining once shutdown begins so no new job opens the DB.\n675:       if (shuttingDown) break;\n676:       // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n677:       const jobId = pendingQueue.shift()!;\n678:       try {\n679:         await processQueuedJob(jobId);\n680:       } catch (error: unknown) {\n681:         try {\n682:           await appendIngestError(jobId, '__job__', error);\n683:           const current = getIngestJob(jobId);\n684:           if (current && ACTIVE_STATES.has(current.state)) {\n685:             await setIngestJobState(jobId, 'failed');\n686:           }\n687:         } catch (_error: unknown) {\n688:           // Non-fatal: queue guard to avoid unhandled rejection loops.\n689:         }\n690:       }\n691: \n692:       // Brief yield between jobs to avoid starving the event loop.\n693:       await sleep(10);\n694:     }\n695:   } finally {\n696:     workerActive = false;\n697:   }\n698: }\n699: \n700: function enqueueIngestJob(jobId: string): void {\n701:   // Never admit work or respawn the worker once shutdown has begun.\n702:   if (shuttingDown) {\n703:     return;\n704:   }\n705:   // Prevent duplicate enqueue of the same job.\n706:   if (pendingQueue.includes(jobId)) {\n707:     return;\n708:   }\n709: \n710:   pendingQueue.push(jobId);\n711:   while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n712:     const evictedJobId = pendingQueue.shift();\n713:     if (!evictedJobId) break;\n714:     void appendIngestError(\n715:       evictedJobId,\n716:       '__job__',\n717:       new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n718:     )\n719:       .then(() => cancelIngestJob(evictedJobId))\n720:       .catch((error: unknown) => {\n721:         console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n722:       });\n723:   }\n724: \n725:   // Start worker if not already running (fire-and-forget).\n726:   if (!workerActive) {\n727:     setImmediate(() => {\n728:       void drainQueue().catch((error: unknown) => {\n729:         console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n730:       });\n731:     });\n732:   }\n733: }\n734: \n735: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n736:    7. INITIALIZATION\n737: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n738: \n739: function initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n740:   processFileFn = config.processFile;\n741:   ensureIngestJobsTable();\n742: \n743:   // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n744:   // So they actually get processed by the worker.\n745:   const resetJobIds = resetIncompleteJobsToQueued();\n746:   for (const jobId of resetJobIds) {\n747:     enqueueIngestJob(jobId);\n748:   }\n749: \n750:   return { resetCount: resetJobIds.length };\n751: }\n752: \n753: // Default ceiling for how long stopWorker waits for the active drain to settle.\n754: // The worker yields between files and between jobs, so it observes the fence\n755: // quickly; the bound only guards against a wedged in-flight processFile call.\n756: const STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n757: \n758: // Fence the ingest worker for shutdown: refuse new work, drop the pending\n759: // queue, and wait (bounded) for any in-flight drain to unwind before the\n760: // database is closed. Must run before closeDb() so the worker cannot reopen a\n761: // closed connection. Idempotent and safe to call when the worker is idle.\n762: async function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n763:   shuttingDown = true;\n764:   pendingQueue.length = 0;\n765: \n766:   if (!workerActive) return;\n767: \n768:   const deadline = Date.now()\n769:     + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n770:       ? (options.drainDeadlineMs as number)\n771:       : STOP_WORKER_DRAIN_DEADLINE_MS);\n772: \n773:   while (workerActive && Date.now() < deadline) {\n774:     await sleep(10);\n775:   }\n776: }\n777: \n778: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n779:    8. EXPORTS\n780: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n781: \n782: export {\n783:   initIngestJobQueue,\n784:   stopWorker,\n785:   createIngestJob,\n786:   getIngestJob,\n787:   cancelIngestJob,\n788:   enqueueIngestJob,\n789:   resetIncompleteJobsToQueued,\n790:   MAX_PENDING_INGEST_JOBS,\n791: };\n\n(End of file - total 791 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Job Queue\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Job Queue\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n/**\n * Defines the IngestJobState type.\n */\nexport type IngestJobState =\n  | 'queued'\n  | 'parsing'\n  | 'embedding'\n  | 'indexing'\n  | 'complete'\n  | 'failed'\n  | 'cancelled';\n\n/**\n * Describes the IngestJobError shape.\n */\nexport interface IngestJobError {\n  filePath: string;\n  message: string;\n  timestamp: string;\n}\n\n/**\n * Describes the IngestJob shape.\n */\nexport interface IngestJob {\n  id: string;\n  state: IngestJobState;\n  specFolder: string | null;\n  paths: string[];\n  filesTotal: number;\n  filesProcessed: number;\n  errors: IngestJobError[];\n  createdAt: string;\n  updatedAt: string;\n  // Validated governance decision captured at enqueue time so the worker\n  // re-indexes each path under the same provenance/retention/scope the\n  // synchronous save path applies. Null for ungoverned jobs (the default).\n  governance: GovernanceDecision | null;\n}\n\nexport interface IngestJobForecast {\n  etaSeconds: number | null;\n  etaConfidence: number | null;\n  failureRisk: number | null;\n  riskSignals: string[];\n  caveat: string | null;\n}\n\ninterface IngestJobRow {\n  id: string;\n  state: IngestJobState;\n  spec_folder: string | null;\n  paths_json: string;\n  files_total: number;\n  files_processed: number;\n  errors_json: string;\n  created_at: string;\n  updated_at: string;\n  governance_json?: string | null;\n}\n\ninterface JobQueueConfig {\n  processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. CONSTANTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nconst ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\nconst TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n\nconst ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n  queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n  parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n  embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n  indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. STATE MANAGEMENT\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// True sequential queue вҖ” only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;\nlet processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\nconst MAX_STORED_ERRORS = 50;\nconst MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. HELPERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n  if (!value) return fallback;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n  if (!value) return null;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n      return parsed as GovernanceDecision;\n    }\n    return null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    state: row.state,\n    specFolder: row.spec_folder,\n    paths: parseJsonArray<string>(row.paths_json, []),\n    filesTotal: row.files_total,\n    filesProcessed: row.files_processed,\n    errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    governance: parseGovernanceJson(row.governance_json),\n  };\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\n// DB accessor for the worker path. While shutting down it refuses to acquire a\n// connection so the worker can never travel the requireDb -> getDb -> reopen\n// path after shutdown has closed the database. The throw is caught by the\n// worker's surrounding error handling and the drain unwinds cleanly.\nfunction acquireWorkerDb(): ReturnType<typeof requireDb> {\n  if (shuttingDown) {\n    throw new Error('Ingest worker is shutting down; database access refused');\n  }\n  return requireDb();\n}\n\nfunction ensureIngestJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS ingest_jobs (\n      id TEXT PRIMARY KEY,\n      state TEXT,\n      spec_folder TEXT,\n      paths_json TEXT,\n      files_total INTEGER,\n      files_processed INTEGER,\n      errors_json TEXT,\n      created_at TEXT,\n      updated_at TEXT,\n      governance_json TEXT\n    )\n  `);\n  // Backward-compatible migration: add the nullable governance column to tables\n  // created before governed ingest existed. In-flight jobs simply carry a null\n  // governance and remain ungoverned, exactly as before.\n  const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'governance_json')) {\n    db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n  }\n}\n\n// Restart interrupted jobs from the beginning on process startup.\n// Indexing is idempotent, and replaying the original path list avoids\n// Mismatches when path accessibility changes between runs.\nfunction resetIncompleteJobsToQueued(): string[] {\n  const db = requireDb();\n  // Collect IDs of jobs that will be reset so we can re-enqueue them.\n  const rows = db.prepare(`\n    SELECT id FROM ingest_jobs\n    WHERE state NOT IN ('complete', 'failed', 'cancelled')\n  `).all() as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET\n        state = 'queued',\n        files_processed = 0,\n        errors_json = '[]',\n        updated_at = ?\n      WHERE state NOT IN ('complete', 'failed', 'cancelled')\n    `).run(nowIso())\n  );\n\n  return rows.map((r) => r.id);\n}\n\nasync function createIngestJob(args: {\n  id: string;\n  paths: string[];\n  specFolder?: string;\n  governance?: GovernanceDecision | null;\n}): Promise<IngestJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n\n  if (normalizedPaths.length === 0) {\n    throw new Error('paths must include at least one file path');\n  }\n\n  const governance = args.governance ?? null;\n  const governanceJson = governance ? JSON.stringify(governance) : null;\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO ingest_jobs (\n        id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      'queued',\n      args.specFolder ?? null,\n      JSON.stringify(normalizedPaths),\n      normalizedPaths.length,\n      0,\n      JSON.stringify([]),\n      timestamp,\n      timestamp,\n      governanceJson,\n    )\n  );\n\n  return {\n    id: args.id,\n    state: 'queued',\n    specFolder: args.specFolder ?? null,\n    paths: normalizedPaths,\n    filesTotal: normalizedPaths.length,\n    filesProcessed: 0,\n    errors: [],\n    createdAt: timestamp,\n    updatedAt: timestamp,\n    governance,\n  };\n}\n\nfunction getIngestJob(jobId: string): IngestJob | null {\n  const db = acquireWorkerDb();\n  const row = db.prepare(`\n    SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n    FROM ingest_jobs\n    WHERE id = ?\n  `).get(jobId) as IngestJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nasync function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  return {\n    ...current,\n    state: nextState,\n    updatedAt,\n  };\n}\n\nasync function incrementProcessed(jobId: string): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET files_processed = files_processed + 1, updated_at = ?\n      WHERE id = ?\n    `).run(updatedAt, jobId)\n  );\n\n  const updated = getIngestJob(jobId);\n  if (!updated) {\n    throw new Error(`Ingest job not found after progress update: ${jobId}`);\n  }\n  return updated;\n}\n\nasync function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  let errors = [\n    ...current.errors,\n    {\n      filePath: toPublicPathLabel(filePath),\n      message: toErrorMessage(error),\n      timestamp: nowIso(),\n    },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: IngestJobError = {\n      filePath: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET errors_json = ?, updated_at = ?\n      WHERE id = ?\n    `).run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return {\n    ...current,\n    errors,\n    updatedAt,\n  };\n}\n\nasync function cancelIngestJob(jobId: string): Promise<IngestJob> {\n  const MAX_CANCEL_RETRIES = 3;\n\n  for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n    const current = getIngestJob(jobId);\n    if (!current) {\n      throw new Error(`Ingest job not found: ${jobId}`);\n    }\n    if (TERMINAL_STATES.has(current.state)) {\n      return current;\n    }\n\n    try {\n      return await setIngestJobState(jobId, 'cancelled');\n    } catch (error: unknown) {\n      const message = toErrorMessage(error);\n      if (message.startsWith('State transition conflict:')) {\n        continue;\n      }\n\n      if (message.startsWith('Invalid ingest job state transition:')) {\n        const latest = getIngestJob(jobId);\n        if (latest && TERMINAL_STATES.has(latest.state)) {\n          return latest;\n        }\n        continue;\n      }\n\n      throw error;\n    }\n  }\n\n  const latest = getIngestJob(jobId);\n  if (!latest) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n  if (TERMINAL_STATES.has(latest.state)) {\n    return latest;\n  }\n\n  return setIngestJobState(jobId, 'cancelled');\n}\n\n/**\n * Provides the getIngestProgressPercent helper.\n */\nexport function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n  if (job.filesTotal <= 0) return 0;\n  const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction parseIsoTimestamp(timestamp: string): number | null {\n  if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n    return null;\n  }\n\n  const parsed = Date.parse(timestamp);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction clampUnitInterval(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  return Math.max(0, Math.min(1, value));\n}\n\nexport function getIngestForecast(\n  job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n): IngestJobForecast {\n  const filesTotal = Math.max(0, job.filesTotal || 0);\n  const filesProcessed = Math.max(0, job.filesProcessed || 0);\n  const remaining = Math.max(0, filesTotal - filesProcessed);\n  const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n  const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n  const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n  const riskSignals: string[] = [];\n\n  if (job.state === 'failed') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 1,\n      riskSignals: ['terminal_failed'],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'complete') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: clampUnitInterval(errorRatio * 0.5),\n      riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'cancelled') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 0,\n      riskSignals: ['terminal_cancelled'],\n      caveat: 'Forecast is advisory only because the job is no longer progressing.',\n    };\n  }\n\n  if (filesTotal <= 0) {\n    return {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals,\n      caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n    };\n  }\n\n  if (errorCount > 0) {\n    riskSignals.push('file_errors_seen');\n  }\n  if (job.state === 'queued') {\n    riskSignals.push('queued_not_started');\n  }\n\n  const createdAtMs = parseIsoTimestamp(job.createdAt);\n  const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n  const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n    ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n    : 0;\n\n  let etaSeconds: number | null = null;\n  let etaConfidence: number | null = null;\n  let caveat: string | null = null;\n\n  if (filesProcessed <= 0 || elapsedSeconds < 1) {\n    caveat = 'Forecast is low-confidence until at least one file has been processed.';\n  } else {\n    const throughput = filesProcessed / elapsedSeconds;\n    if (throughput > 0) {\n      etaSeconds = Math.max(0, Math.round(remaining / throughput));\n      etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n      if (etaConfidence < 0.4) {\n        caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n      }\n    } else {\n      caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n    }\n  }\n\n  if (progressRatio <= 0 && job.state !== 'queued') {\n    riskSignals.push('active_without_progress');\n  }\n  if (errorRatio >= 0.5 && errorCount > 0) {\n    riskSignals.push('high_error_ratio');\n  }\n\n  const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n  const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n\n  return {\n    etaSeconds,\n    etaConfidence,\n    failureRisk,\n    riskSignals,\n    caveat,\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. WORKER\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// Real state machine вҖ” states now correspond to actual work phases.\n// Progress is tracked against the original submitted path list so terminal\n// Accounting stays stable even when some files are inaccessible.\nasync function processQueuedJob(jobId: string): Promise<void> {\n  if (!processFileFn) {\n    throw new Error('Ingest queue not initialized: processFile handler is missing');\n  }\n\n  let job = getIngestJob(jobId);\n  if (!job || TERMINAL_STATES.has(job.state)) {\n    return;\n  }\n\n  // Step 1: Parsing вҖ” validate all paths exist and are readable.\n  job = await setIngestJobState(jobId, 'parsing');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  const { access } = await import('fs/promises');\n\n  // Step 2: Embedding вҖ” placeholder for batch embedding pre-processing.\n  // Transition is meaningful: it signals readiness for indexing after validation.\n  const latest1 = getIngestJob(jobId);\n  if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n  job = await setIngestJobState(jobId, 'embedding');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  // Step 3: Indexing вҖ” process only validated paths (not original paths).\n  const latest2 = getIngestJob(jobId);\n  if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n  job = await setIngestJobState(jobId, 'indexing');\n\n  // Resume from filesProcessed against the original submitted path order.\n  let currentIndex = job.filesProcessed;\n  // Track actual failure count independently of the truncated errors array.\n  // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n  // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n  let failCount = 0;\n\n  while (currentIndex < job.paths.length) {\n    // Stop touching the DB the moment shutdown begins. The job stays in an\n    // active state and boot crash-recovery re-enqueues it on the next start.\n    if (shuttingDown) return;\n    const current = getIngestJob(jobId);\n    if (!current) return;\n    if (current.state === 'cancelled') return;\n\n    const nextPath = current.paths[currentIndex];\n    if (!nextPath) {\n      break;\n    }\n\n    // Continue on file error instead of aborting the entire job.\n    try {\n      await access(nextPath);\n      await processFileFn(nextPath, current.governance);\n    } catch (error: unknown) {\n      const normalizedError = error instanceof Error\n        && 'code' in error\n        && typeof error.code === 'string'\n        && error.code === 'ENOENT'\n        ? new Error('File not accessible')\n        : error;\n      await appendIngestError(jobId, nextPath, normalizedError);\n      failCount += 1;\n      console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} вҖ” ${toErrorMessage(normalizedError)}`);\n    }\n\n    job = await incrementProcessed(jobId);\n    currentIndex = job.filesProcessed;\n  }\n\n  // Determine terminal state: complete if no errors, failed if all files errored.\n  const done = getIngestJob(jobId);\n  if (!done) return;\n  if (done.state === 'cancelled') return;\n\n  if (failCount > 0 && failCount >= done.filesTotal) {\n    // All files failed вҖ” mark as failed.\n    await setIngestJobState(jobId, 'failed');\n  } else {\n    // Partial or full success вҖ” mark as complete (errors are preserved in record).\n    await setIngestJobState(jobId, 'complete');\n  }\n}\n\n// True sequential worker вҖ” processes one job at a time.\n// Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\nasync function drainQueue(): Promise<void> {\n  if (workerActive) return;\n  workerActive = true;\n\n  try {\n    while (pendingQueue.length > 0) {\n      // Halt draining once shutdown begins so no new job opens the DB.\n      if (shuttingDown) break;\n      // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n      const jobId = pendingQueue.shift()!;\n      try {\n        await processQueuedJob(jobId);\n      } catch (error: unknown) {\n        try {\n          await appendIngestError(jobId, '__job__', error);\n          const current = getIngestJob(jobId);\n          if (current && ACTIVE_STATES.has(current.state)) {\n            await setIngestJobState(jobId, 'failed');\n          }\n        } catch (_error: unknown) {\n          // Non-fatal: queue guard to avoid unhandled rejection loops.\n        }\n      }\n\n      // Brief yield between jobs to avoid starving the event loop.\n      await sleep(10);\n    }\n  } finally {\n    workerActive = false;\n  }\n}\n\nfunction enqueueIngestJob(jobId: string): void {\n  // Never admit work or respawn the worker once shutdown has begun.\n  if (shuttingDown) {\n    return;\n  }\n  // Prevent duplicate enqueue of the same job.\n  if (pendingQueue.includes(jobId)) {\n    return;\n  }\n\n  pendingQueue.push(jobId);\n  while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n    const evictedJobId = pendingQueue.shift();\n    if (!evictedJobId) break;\n    void appendIngestError(\n      evictedJobId,\n      '__job__',\n      new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n    )\n      .then(() => cancelIngestJob(evictedJobId))\n      .catch((error: unknown) => {\n        console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n      });\n  }\n\n  // Start worker if not already running (fire-and-forget).\n  if (!workerActive) {\n    setImmediate(() => {\n      void drainQueue().catch((error: unknown) => {\n        console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n      });\n    });\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   7. INITIALIZATION\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n  processFileFn = config.processFile;\n  ensureIngestJobsTable();\n\n  // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n  // So they actually get processed by the worker.\n  const resetJobIds = resetIncompleteJobsToQueued();\n  for (const jobId of resetJobIds) {\n    enqueueIngestJob(jobId);\n  }\n\n  return { resetCount: resetJobIds.length };\n}\n\n// Default ceiling for how long stopWorker waits for the active drain to settle.\n// The worker yields between files and between jobs, so it observes the fence\n// quickly; the bound only guards against a wedged in-flight processFile call.\nconst STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n\n// Fence the ingest worker for shutdown: refuse new work, drop the pending\n// queue, and wait (bounded) for any in-flight drain to unwind before the\n// database is closed. Must run before closeDb() so the worker cannot reopen a\n// closed connection. Idempotent and safe to call when the worker is idle.\nasync function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n  shuttingDown = true;\n  pendingQueue.length = 0;\n\n  if (!workerActive) return;\n\n  const deadline = Date.now()\n    + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n      ? (options.drainDeadlineMs as number)\n      : STOP_WORKER_DRAIN_DEADLINE_MS);\n\n  while (workerActive && Date.now() < deadline) {\n    await sleep(10);\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   8. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport {\n  initIngestJobQueue,\n  stopWorker,\n  createIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  enqueueIngestJob,\n  resetIncompleteJobsToQueued,\n  MAX_PENDING_INGEST_JOBS,\n};","lineStart":1,"lineEnd":791,"totalLines":791,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","time":{"start":1781762877382,"end":1781762877401}},"metadata":{"openai":{"itemId":"fc_00bb168e403b2046016a338b3d3df0819183a9048866acebd4"}},"id":"prt_ed957e7c1001Ru0t43N9L4CIOv","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957bb72001yEPgUg0JVqBslj"}}
{"type":"tool_use","timestamp":1781762877418,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"type":"tool","tool":"read","callID":"call_nb9GLMSTbJxUCkpgThrtx574","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Transaction Manager\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Atomic file + index operations with pending file recovery\n6: import type Database from 'better-sqlite3';\n7: import * as fs from 'fs';\n8: import * as path from 'path';\n9: import { resolveDatabasePaths } from '../../core/config.js';\n10: \n11: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n12:    1. CONSTANTS\n13: ----------------------------------------------------------------*/\n14: \n15: const PENDING_SUFFIX = '_pending';\n16: const TEMP_SUFFIX = '.tmp';\n17: const PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n18: \n19: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n20:    2. INTERFACES\n21: ----------------------------------------------------------------*/\n22: \n23: interface TransactionMetrics {\n24:   totalAtomicWrites: number;\n25:   totalDeletes: number;\n26:   totalRecoveries: number;\n27:   totalErrors: number;\n28:   lastOperationTime: string | null;\n29:   [key: string]: unknown;\n30: }\n31: \n32: interface AtomicSaveResult {\n33:   success: boolean;\n34:   filePath: string;\n35:   error?: string;\n36:   /** Set when DB committed but rename failed, indicating partial state */\n37:   dbCommitted?: boolean;\n38: }\n39: \n40: interface RecoveryResult {\n41:   path: string;\n42:   recovered: boolean;\n43:   error?: string;\n44: }\n45: \n46: /**\n47:  * Optional database probe used during pending-file recovery.\n48:  * Return `true` when the original path already has a committed `memory_index` row.\n49:  * Return `false` to leave the `_pending` file in place for manual review.\n50:  * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n51:  */\n52: type IsCommittedCheck = (originalPath: string) => boolean;\n53: \n54: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n55:    3. MODULE STATE\n56: ----------------------------------------------------------------*/\n57: \n58: const metrics: TransactionMetrics = {\n59:   totalAtomicWrites: 0,\n60:   totalDeletes: 0,\n61:   totalRecoveries: 0,\n62:   totalErrors: 0,\n63:   lastOperationTime: null,\n64: };\n65: \n66: const activeTransactions = new WeakMap<object, number>();\n67: \n68: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n69:    4. METRICS\n70: ----------------------------------------------------------------*/\n71: \n72: function getMetrics(): TransactionMetrics {\n73:   return { ...metrics };\n74: }\n75: \n76: function resetMetrics(): void {\n77:   metrics.totalAtomicWrites = 0;\n78:   metrics.totalDeletes = 0;\n79:   metrics.totalRecoveries = 0;\n80:   metrics.totalErrors = 0;\n81:   metrics.lastOperationTime = null;\n82: }\n83: \n84: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n85:    5. PATH HELPERS\n86: ----------------------------------------------------------------*/\n87: \n88: function getPendingPath(filePath: string): string {\n89:   const dir = path.dirname(filePath);\n90:   const ext = path.extname(filePath);\n91:   const base = path.basename(filePath, ext);\n92:   return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n93: }\n94: \n95: interface PendingPathInfo {\n96:   originalPath: string;\n97:   basePendingPath: string;\n98:   uniqueSuffix: string | null;\n99: }\n100: \n101: function parsePendingPath(filePath: string): PendingPathInfo | null {\n102:   const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n103:     const dir = path.dirname(candidatePath);\n104:     const ext = path.extname(candidatePath);\n105:     const base = path.basename(candidatePath, ext);\n106:     if (!base.endsWith(PENDING_SUFFIX)) {\n107:       return null;\n108:     }\n109: \n110:     const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n111:     return {\n112:       originalPath: path.join(dir, `${originalBase}${ext}`),\n113:       basePendingPath: candidatePath,\n114:       uniqueSuffix: null,\n115:     };\n116:   };\n117: \n118:   const suffixExt = path.extname(filePath);\n119:   if (suffixExt) {\n120:     const uniqueSuffix = suffixExt.slice(1);\n121:     const basePendingPath = filePath.slice(0, -suffixExt.length);\n122:     const suffixedMatch = parseBasePendingPath(basePendingPath);\n123:     if (\n124:       suffixedMatch &&\n125:       path.extname(suffixedMatch.basePendingPath) &&\n126:       PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n127:     ) {\n128:       return {\n129:         ...suffixedMatch,\n130:         uniqueSuffix,\n131:       };\n132:     }\n133:   }\n134: \n135:   return parseBasePendingPath(filePath);\n136: }\n137: \n138: function isPendingFile(filePath: string): boolean {\n139:   return parsePendingPath(filePath) !== null;\n140: }\n141: \n142: function getOriginalPath(pendingPath: string): string {\n143:   return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n144: }\n145: \n146: function runInTransaction<T>(database: Database.Database, callback: () => T): T {\n147:   const runCallback = (): T => {\n148:     const depth = activeTransactions.get(database) ?? 0;\n149:     activeTransactions.set(database, depth + 1);\n150:     try {\n151:       return callback();\n152:     } finally {\n153:       const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n154:       if (nextDepth > 0) {\n155:         activeTransactions.set(database, nextDepth);\n156:       } else {\n157:         activeTransactions.delete(database);\n158:       }\n159:     }\n160:   };\n161: \n162:   if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n163:     return runCallback();\n164:   }\n165: \n166:   return database.transaction(() => runCallback())();\n167: }\n168: \n169: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n170:    6. ATOMIC FILE OPERATIONS\n171: ----------------------------------------------------------------*/\n172: \n173: /**\n174:  * Write a file atomically using write-to-temp-then-rename pattern.\n175:  * This prevents partial writes if the process crashes mid-write.\n176:  */\n177: function atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n178:   const tempPath = filePath + TEMP_SUFFIX;\n179: \n180:   try {\n181:     // Ensure directory exists\n182:     const dir = path.dirname(filePath);\n183:     if (!fs.existsSync(dir)) {\n184:       fs.mkdirSync(dir, { recursive: true });\n185:     }\n186: \n187:     // Write to temp file\n188:     fs.writeFileSync(tempPath, content, encoding);\n189: \n190:     // Atomic rename\n191:     fs.renameSync(tempPath, filePath);\n192: \n193:     metrics.totalAtomicWrites++;\n194:     metrics.lastOperationTime = new Date().toISOString();\n195:     return true;\n196:   } catch (error: unknown) {\n197:     const msg = error instanceof Error ? error.message : String(error);\n198:     console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n199:     metrics.totalErrors++;\n200: \n201:     // Clean up temp file\n202:     try {\n203:       if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n204:     } catch { /* ignore cleanup errors */ }\n205: \n206:     return false;\n207:   }\n208: }\n209: \n210: /**\n211:  * Delete a file if it exists.\n212:  */\n213: function deleteFileIfExists(filePath: string): boolean {\n214:   try {\n215:     if (fs.existsSync(filePath)) {\n216:       fs.unlinkSync(filePath);\n217:       metrics.totalDeletes++;\n218:       metrics.lastOperationTime = new Date().toISOString();\n219:       return true;\n220:     }\n221:     return false;\n222:   } catch (error: unknown) {\n223:     const msg = error instanceof Error ? error.message : String(error);\n224:     console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n225:     metrics.totalErrors++;\n226:     return false;\n227:   }\n228: }\n229: \n230: /**\n231:  * Execute an atomic save with pending file pattern.\n232:  * 1. Write to pending path\n233:  * 2. Execute database operations\n234:  * 3. Rename pending to final\n235:  *\n236:  * This function provides file-system-level atomicity (write-to-pending + rename),\n237:  * NOT database transaction isolation. Callers needing transactional guarantees for\n238:  * dbOperation() must wrap it in their own db.transaction() call. The rename step\n239:  * ensures the file is either fully written or not present, but the DB operation\n240:  * is not rolled back if the rename fails (extremely rare on local filesystems).\n241:  */\n242: function executeAtomicSave(\n243:   filePath: string,\n244:   content: string,\n245:   dbOperation: () => void\n246: ): AtomicSaveResult {\n247:   const pendingPath = getPendingPath(filePath);\n248: \n249:   try {\n250:     // Step 1: Write to pending path\n251:     const dir = path.dirname(pendingPath);\n252:     if (!fs.existsSync(dir)) {\n253:       fs.mkdirSync(dir, { recursive: true });\n254:     }\n255:     fs.writeFileSync(pendingPath, content, 'utf-8');\n256: \n257:     // Flag-based rollback coordination.\n258:     // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n259:     // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n260:     // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n261:     // Can report which step failed. No SAVEPOINT is used вҖ” better-sqlite3 transactions\n262:     // Are all-or-nothing within the dbOperation() callback itself.\n263:     let dbCommitted = false;\n264: \n265:     // Step 2: Execute database operation\n266:     try {\n267:       dbOperation();\n268:       dbCommitted = true;\n269:     } catch (dbError: unknown) {\n270:       // Database failed - clean up pending file\n271:       try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n272:       const msg = dbError instanceof Error ? dbError.message : String(dbError);\n273:       metrics.totalErrors++;\n274:       return { success: false, filePath, error: `DB operation failed: ${msg}` };\n275:     }\n276: \n277:     // Step 3: Rename pending to final (atomic)\n278:     // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n279:     // The DB contains the new state but the file is not at its final path. This is\n280:     // A window of vulnerability that cannot be eliminated without two-phase commit.\n281:     // The `dbCommitted` flag on the returned error result enables callers to detect\n282:     // This state and trigger recovery (e.g., re-index from DB or replay the write).\n283:     // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n284:     // Orphaned pending files and rename them to their final paths.\n285:     try {\n286:       fs.renameSync(pendingPath, filePath);\n287:     } catch (renameError: unknown) {\n288:       // Rename failed after DB committed вҖ” DB has new state but file wasn't renamed.\n289:       // Leave pending file for startup recovery and report failure with dbCommitted flag.\n290:       const msg = renameError instanceof Error ? renameError.message : String(renameError);\n291:       console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n292:       metrics.totalErrors++;\n293:       return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n294:     }\n295: \n296:     metrics.totalAtomicWrites++;\n297:     metrics.lastOperationTime = new Date().toISOString();\n298:     return { success: true, filePath };\n299:   } catch (error: unknown) {\n300:     const msg = error instanceof Error ? error.message : String(error);\n301:     metrics.totalErrors++;\n302: \n303:     // Clean up pending file\n304:     try {\n305:       if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n306:     } catch { /* ignore */ }\n307: \n308:     return { success: false, filePath, error: msg };\n309:   }\n310: }\n311: \n312: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n313:    7. RECOVERY\n314: ----------------------------------------------------------------*/\n315: \n316: /**\n317:  * Find pending files in a directory (crash recovery).\n318:  */\n319: function listFilesRecursive(dirPath: string): string[] {\n320:   const files: string[] = [];\n321:   const stack: string[] = [dirPath];\n322: \n323:   while (stack.length > 0) {\n324:     const current = stack.pop();\n325:     if (!current) continue;\n326: \n327:     const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n328:     for (const entry of entries) {\n329:       const fullPath = path.join(current, entry.name);\n330:       if (entry.isDirectory()) {\n331:         stack.push(fullPath);\n332:       } else if (entry.isFile()) {\n333:         files.push(fullPath);\n334:       }\n335:     }\n336:   }\n337: \n338:   return files;\n339: }\n340: \n341: function findPendingFiles(dirPath: string): string[] {\n342:   try {\n343:     if (!fs.existsSync(dirPath)) return [];\n344: \n345:     let files: string[];\n346:     try {\n347:       files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n348:     } catch {\n349:       // Node 18 compatibility fallback when recursive readdir is unavailable.\n350:       files = listFilesRecursive(dirPath);\n351:     }\n352: \n353:     return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n354:   } catch (error: unknown) {\n355:     const msg = error instanceof Error ? error.message : String(error);\n356:     console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n357:     return [];\n358:   }\n359: }\n360: \n361: /**\n362:  * Recover a single pending file by renaming to its original path.\n363:  */\n364: function recoverPendingFile(\n365:   pendingPath: string,\n366:   isCommittedInDb?: IsCommittedCheck,\n367:   databasePathOverride?: string\n368: ): RecoveryResult {\n369:   try {\n370:     // Guard: verify pending file still exists before attempting recovery\n371:     if (!fs.existsSync(pendingPath)) {\n372:       return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n373:     }\n374:     const pendingInfo = parsePendingPath(pendingPath);\n375:     if (!pendingInfo) {\n376:       return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n377:     }\n378: \n379:     const originalPath = pendingInfo.originalPath;\n380:     const originalExists = fs.existsSync(originalPath);\n381:     let committedInDb: boolean | null = null;\n382:     if (isCommittedInDb) {\n383:       const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n384:       if (!fs.existsSync(databasePath)) {\n385:         console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n386:         return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n387:       }\n388:       committedInDb = isCommittedInDb(originalPath);\n389:     }\n390: \n391:     // If original exists and is newer, delete pending\n392:     if (originalExists) {\n393:       const pendingStats = fs.statSync(pendingPath);\n394:       const originalStats = fs.statSync(originalPath);\n395:       if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n396:         fs.unlinkSync(pendingPath);\n397:         return { path: pendingPath, recovered: false, error: 'Original is newer' };\n398:       }\n399:     }\n400: \n401:     // Stale detection: if DB check is provided and row was never committed,\n402:     // Log and leave for manual review instead of renaming.\n403:     if (committedInDb === false) {\n404:       console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n405:       return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n406:     }\n407: \n408:     // Rename pending to original\n409:     fs.renameSync(pendingPath, originalPath);\n410:     metrics.totalRecoveries++;\n411:     metrics.lastOperationTime = new Date().toISOString();\n412: \n413:     return { path: pendingPath, recovered: true };\n414:   } catch (error: unknown) {\n415:     const msg = error instanceof Error ? error.message : String(error);\n416:     metrics.totalErrors++;\n417:     return { path: pendingPath, recovered: false, error: msg };\n418:   }\n419: }\n420: \n421: /**\n422:  * Recover all pending files in a directory.\n423:  */\n424: function recoverAllPendingFiles(\n425:   dirPath: string,\n426:   isCommittedInDb?: IsCommittedCheck,\n427:   databasePathOverride?: string\n428: ): RecoveryResult[] {\n429:   const pendingFiles = findPendingFiles(dirPath);\n430:   return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n431: }\n432: \n433: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n434:    8. EXPORTS\n435: ----------------------------------------------------------------*/\n436: \n437: export {\n438:   PENDING_SUFFIX,\n439:   TEMP_SUFFIX,\n440: \n441:   // Metrics\n442:   getMetrics,\n443:   resetMetrics,\n444: \n445:   // Path helpers\n446:   getPendingPath,\n447:   isPendingFile,\n448:   getOriginalPath,\n449:   runInTransaction,\n450: \n451:   // Atomic operations\n452:   atomicWriteFile,\n453:   deleteFileIfExists,\n454:   executeAtomicSave,\n455: \n456:   // Recovery\n457:   findPendingFiles,\n458:   recoverPendingFile,\n459:   recoverAllPendingFiles,\n460: };\n461: \n462: /**\n463:  * Re-exports related public types.\n464:  */\n465: export type {\n466:   TransactionMetrics,\n467:   AtomicSaveResult,\n468:   RecoveryResult,\n469:   IsCommittedCheck,\n470: };\n\n(End of file - total 470 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Transaction Manager\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. INTERFACES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Transaction Manager\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface TransactionMetrics {\n  totalAtomicWrites: number;\n  totalDeletes: number;\n  totalRecoveries: number;\n  totalErrors: number;\n  lastOperationTime: string | null;\n  [key: string]: unknown;\n}\n\ninterface AtomicSaveResult {\n  success: boolean;\n  filePath: string;\n  error?: string;\n  /** Set when DB committed but rename failed, indicating partial state */\n  dbCommitted?: boolean;\n}\n\ninterface RecoveryResult {\n  path: string;\n  recovered: boolean;\n  error?: string;\n}\n\n/**\n * Optional database probe used during pending-file recovery.\n * Return `true` when the original path already has a committed `memory_index` row.\n * Return `false` to leave the `_pending` file in place for manual review.\n * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n */\ntype IsCommittedCheck = (originalPath: string) => boolean;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nconst metrics: TransactionMetrics = {\n  totalAtomicWrites: 0,\n  totalDeletes: 0,\n  totalRecoveries: 0,\n  totalErrors: 0,\n  lastOperationTime: null,\n};\n\nconst activeTransactions = new WeakMap<object, number>();\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. METRICS\n----------------------------------------------------------------*/\n\nfunction getMetrics(): TransactionMetrics {\n  return { ...metrics };\n}\n\nfunction resetMetrics(): void {\n  metrics.totalAtomicWrites = 0;\n  metrics.totalDeletes = 0;\n  metrics.totalRecoveries = 0;\n  metrics.totalErrors = 0;\n  metrics.lastOperationTime = null;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. PATH HELPERS\n----------------------------------------------------------------*/\n\nfunction getPendingPath(filePath: string): string {\n  const dir = path.dirname(filePath);\n  const ext = path.extname(filePath);\n  const base = path.basename(filePath, ext);\n  return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n}\n\ninterface PendingPathInfo {\n  originalPath: string;\n  basePendingPath: string;\n  uniqueSuffix: string | null;\n}\n\nfunction parsePendingPath(filePath: string): PendingPathInfo | null {\n  const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n    const dir = path.dirname(candidatePath);\n    const ext = path.extname(candidatePath);\n    const base = path.basename(candidatePath, ext);\n    if (!base.endsWith(PENDING_SUFFIX)) {\n      return null;\n    }\n\n    const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n    return {\n      originalPath: path.join(dir, `${originalBase}${ext}`),\n      basePendingPath: candidatePath,\n      uniqueSuffix: null,\n    };\n  };\n\n  const suffixExt = path.extname(filePath);\n  if (suffixExt) {\n    const uniqueSuffix = suffixExt.slice(1);\n    const basePendingPath = filePath.slice(0, -suffixExt.length);\n    const suffixedMatch = parseBasePendingPath(basePendingPath);\n    if (\n      suffixedMatch &&\n      path.extname(suffixedMatch.basePendingPath) &&\n      PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n    ) {\n      return {\n        ...suffixedMatch,\n        uniqueSuffix,\n      };\n    }\n  }\n\n  return parseBasePendingPath(filePath);\n}\n\nfunction isPendingFile(filePath: string): boolean {\n  return parsePendingPath(filePath) !== null;\n}\n\nfunction getOriginalPath(pendingPath: string): string {\n  return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n}\n\nfunction runInTransaction<T>(database: Database.Database, callback: () => T): T {\n  const runCallback = (): T => {\n    const depth = activeTransactions.get(database) ?? 0;\n    activeTransactions.set(database, depth + 1);\n    try {\n      return callback();\n    } finally {\n      const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n      if (nextDepth > 0) {\n        activeTransactions.set(database, nextDepth);\n      } else {\n        activeTransactions.delete(database);\n      }\n    }\n  };\n\n  if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n    return runCallback();\n  }\n\n  return database.transaction(() => runCallback())();\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. ATOMIC FILE OPERATIONS\n----------------------------------------------------------------*/\n\n/**\n * Write a file atomically using write-to-temp-then-rename pattern.\n * This prevents partial writes if the process crashes mid-write.\n */\nfunction atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n  const tempPath = filePath + TEMP_SUFFIX;\n\n  try {\n    // Ensure directory exists\n    const dir = path.dirname(filePath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n\n    // Write to temp file\n    fs.writeFileSync(tempPath, content, encoding);\n\n    // Atomic rename\n    fs.renameSync(tempPath, filePath);\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n    metrics.totalErrors++;\n\n    // Clean up temp file\n    try {\n      if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n    } catch { /* ignore cleanup errors */ }\n\n    return false;\n  }\n}\n\n/**\n * Delete a file if it exists.\n */\nfunction deleteFileIfExists(filePath: string): boolean {\n  try {\n    if (fs.existsSync(filePath)) {\n      fs.unlinkSync(filePath);\n      metrics.totalDeletes++;\n      metrics.lastOperationTime = new Date().toISOString();\n      return true;\n    }\n    return false;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n    metrics.totalErrors++;\n    return false;\n  }\n}\n\n/**\n * Execute an atomic save with pending file pattern.\n * 1. Write to pending path\n * 2. Execute database operations\n * 3. Rename pending to final\n *\n * This function provides file-system-level atomicity (write-to-pending + rename),\n * NOT database transaction isolation. Callers needing transactional guarantees for\n * dbOperation() must wrap it in their own db.transaction() call. The rename step\n * ensures the file is either fully written or not present, but the DB operation\n * is not rolled back if the rename fails (extremely rare on local filesystems).\n */\nfunction executeAtomicSave(\n  filePath: string,\n  content: string,\n  dbOperation: () => void\n): AtomicSaveResult {\n  const pendingPath = getPendingPath(filePath);\n\n  try {\n    // Step 1: Write to pending path\n    const dir = path.dirname(pendingPath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n    fs.writeFileSync(pendingPath, content, 'utf-8');\n\n    // Flag-based rollback coordination.\n    // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n    // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n    // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n    // Can report which step failed. No SAVEPOINT is used вҖ” better-sqlite3 transactions\n    // Are all-or-nothing within the dbOperation() callback itself.\n    let dbCommitted = false;\n\n    // Step 2: Execute database operation\n    try {\n      dbOperation();\n      dbCommitted = true;\n    } catch (dbError: unknown) {\n      // Database failed - clean up pending file\n      try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n      const msg = dbError instanceof Error ? dbError.message : String(dbError);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `DB operation failed: ${msg}` };\n    }\n\n    // Step 3: Rename pending to final (atomic)\n    // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n    // The DB contains the new state but the file is not at its final path. This is\n    // A window of vulnerability that cannot be eliminated without two-phase commit.\n    // The `dbCommitted` flag on the returned error result enables callers to detect\n    // This state and trigger recovery (e.g., re-index from DB or replay the write).\n    // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n    // Orphaned pending files and rename them to their final paths.\n    try {\n      fs.renameSync(pendingPath, filePath);\n    } catch (renameError: unknown) {\n      // Rename failed after DB committed вҖ” DB has new state but file wasn't renamed.\n      // Leave pending file for startup recovery and report failure with dbCommitted flag.\n      const msg = renameError instanceof Error ? renameError.message : String(renameError);\n      console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n    }\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return { success: true, filePath };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n\n    // Clean up pending file\n    try {\n      if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n    } catch { /* ignore */ }\n\n    return { success: false, filePath, error: msg };\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   7. RECOVERY\n----------------------------------------------------------------*/\n\n/**\n * Find pending files in a directory (crash recovery).\n */\nfunction listFilesRecursive(dirPath: string): string[] {\n  const files: string[] = [];\n  const stack: string[] = [dirPath];\n\n  while (stack.length > 0) {\n    const current = stack.pop();\n    if (!current) continue;\n\n    const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n    for (const entry of entries) {\n      const fullPath = path.join(current, entry.name);\n      if (entry.isDirectory()) {\n        stack.push(fullPath);\n      } else if (entry.isFile()) {\n        files.push(fullPath);\n      }\n    }\n  }\n\n  return files;\n}\n\nfunction findPendingFiles(dirPath: string): string[] {\n  try {\n    if (!fs.existsSync(dirPath)) return [];\n\n    let files: string[];\n    try {\n      files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n    } catch {\n      // Node 18 compatibility fallback when recursive readdir is unavailable.\n      files = listFilesRecursive(dirPath);\n    }\n\n    return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Recover a single pending file by renaming to its original path.\n */\nfunction recoverPendingFile(\n  pendingPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult {\n  try {\n    // Guard: verify pending file still exists before attempting recovery\n    if (!fs.existsSync(pendingPath)) {\n      return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n    }\n    const pendingInfo = parsePendingPath(pendingPath);\n    if (!pendingInfo) {\n      return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n    }\n\n    const originalPath = pendingInfo.originalPath;\n    const originalExists = fs.existsSync(originalPath);\n    let committedInDb: boolean | null = null;\n    if (isCommittedInDb) {\n      const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n      if (!fs.existsSync(databasePath)) {\n        console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n        return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n      }\n      committedInDb = isCommittedInDb(originalPath);\n    }\n\n    // If original exists and is newer, delete pending\n    if (originalExists) {\n      const pendingStats = fs.statSync(pendingPath);\n      const originalStats = fs.statSync(originalPath);\n      if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n        fs.unlinkSync(pendingPath);\n        return { path: pendingPath, recovered: false, error: 'Original is newer' };\n      }\n    }\n\n    // Stale detection: if DB check is provided and row was never committed,\n    // Log and leave for manual review instead of renaming.\n    if (committedInDb === false) {\n      console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n      return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n    }\n\n    // Rename pending to original\n    fs.renameSync(pendingPath, originalPath);\n    metrics.totalRecoveries++;\n    metrics.lastOperationTime = new Date().toISOString();\n\n    return { path: pendingPath, recovered: true };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n    return { path: pendingPath, recovered: false, error: msg };\n  }\n}\n\n/**\n * Recover all pending files in a directory.\n */\nfunction recoverAllPendingFiles(\n  dirPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult[] {\n  const pendingFiles = findPendingFiles(dirPath);\n  return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  PENDING_SUFFIX,\n  TEMP_SUFFIX,\n\n  // Metrics\n  getMetrics,\n  resetMetrics,\n\n  // Path helpers\n  getPendingPath,\n  isPendingFile,\n  getOriginalPath,\n  runInTransaction,\n\n  // Atomic operations\n  atomicWriteFile,\n  deleteFileIfExists,\n  executeAtomicSave,\n\n  // Recovery\n  findPendingFiles,\n  recoverPendingFile,\n  recoverAllPendingFiles,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  TransactionMetrics,\n  AtomicSaveResult,\n  RecoveryResult,\n  IsCommittedCheck,\n};","lineStart":1,"lineEnd":470,"totalLines":470,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781762877407,"end":1781762877416}},"metadata":{"openai":{"itemId":"fc_00bb168e403b2046016a338b3d3e048191b188676a8b3033c0"}},"id":"prt_ed957e7cb001t4hYXKMjq6a37a","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957bb72001yEPgUg0JVqBslj"}}
{"type":"tool_use","timestamp":1781762877424,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"type":"tool","tool":"read","callID":"call_BAPMpw6GHZu5RfAwqz5ajaaQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Create Record\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: import path from 'path';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import * as vectorIndex from '../../lib/search/vector-index.js';\n8: import * as bm25Index from '../../lib/search/bm25-index.js';\n9: import * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\n10: import * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\n11: import * as incrementalIndex from '../../lib/storage/incremental-index.js';\n12: import * as causalEdges from '../../lib/storage/causal-edges.js';\n13: import type * as memoryParser from '../../lib/parsing/memory-parser.js';\n14: import { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\n15: import { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\n16: import { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\n17: import { toErrorMessage } from '../../utils/index.js';\n18: \n19: import { recordHistory } from '../../lib/storage/history.js';\n20: import { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';\n21: import { detectSpecLevelFromParsed } from '../handler-utils.js';\n22: import { classifyEncodingIntent } from '../../lib/search/encoding-intent.js';\n23: import { isEncodingIntentEnabled } from '../../lib/search/search-flags.js';\n24: import { applyPostInsertMetadata } from './db-helpers.js';\n25: import { inferDocumentTypeFromPath } from '../../lib/config/memory-types.js';\n26: import {\n27:   applyWriteProvenance,\n28:   deriveSourceKindFromContext,\n29:   normalizeSourceKind,\n30:   persistSourceKind,\n31:   type SourceKind,\n32:   type WriteProvenanceContext,\n33: } from '../../lib/storage/write-provenance.js';\n34: \n35: // Feature catalog: Memory indexing (memory_save)\n36: // Feature catalog: Per-memory history log\n37: // Feature catalog: Prediction-error save arbitration\n38: \n39: \n40: import type { PeDecision, MemoryScopeMatch } from './types.js';\n41: import { normalizeScopeMatchValue } from './types.js';\n42: export type { MemoryScopeMatch };\n43: \n44: export const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n45: \n46: export interface CreateRecordIdentityHints {\n47:   targetDocPath?: string | null;\n48:   canonicalFilePath?: string | null;\n49:   targetAnchorId?: string | null;\n50:   routeAs?: string | null;\n51:   continuitySourceKey?: string | null;\n52: }\n53: \n54: export interface ResolvedCreateRecordIdentity {\n55:   targetDocPath: string;\n56:   canonicalFilePath: string;\n57:   targetAnchorId: string | null;\n58:   routeAs: string | null;\n59:   continuitySourceKey: string | null;\n60: }\n61: \n62: interface LineageRoutingDecision {\n63:   predecessorMemoryId: number | null;\n64:   transitionEvent: 'CREATE' | 'UPDATE' | 'SUPERSEDE';\n65:   causalSupersedesMemoryId: number | null;\n66: }\n67: \n68: type ScopePostInsertMetadata = Partial<{\n69:   tenant_id: string;\n70:   user_id: string;\n71:   agent_id: string;\n72:   session_id: string;\n73: }>;\n74: \n75: export {\n76:   deriveSourceKindFromContext,\n77:   normalizeSourceKind,\n78:   type SourceKind,\n79: };\n80: \n81: function normalizeOptionalString(value: unknown): string | null {\n82:   if (typeof value !== 'string') {\n83:     return null;\n84:   }\n85:   const normalized = value.trim();\n86:   return normalized.length > 0 ? normalized : null;\n87: }\n88: \n89: function pickFirstString(...values: unknown[]): string | null {\n90:   for (const value of values) {\n91:     const normalized = normalizeOptionalString(value);\n92:     if (normalized) {\n93:       return normalized;\n94:     }\n95:   }\n96:   return null;\n97: }\n98: \n99: function getParsedIdentityValue(parsed: ReturnType<typeof memoryParser.parseMemoryFile>, ...keys: string[]): string | null {\n100:   const parsedRecord = parsed as unknown as Record<string, unknown>;\n101:   for (const key of keys) {\n102:     const normalized = normalizeOptionalString(parsedRecord[key]);\n103:     if (normalized) {\n104:       return normalized;\n105:     }\n106:   }\n107:   return null;\n108: }\n109: \n110: export function resolveCreateRecordIdentity(\n111:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n112:   filePath: string,\n113:   hints: CreateRecordIdentityHints = {},\n114: ): ResolvedCreateRecordIdentity {\n115:   const targetDocPath = pickFirstString(\n116:     hints.targetDocPath,\n117:     getParsedIdentityValue(parsed, 'targetDocPath', 'target_doc_path', 'targetFilePath', 'target_file_path', 'routedDocPath', 'routed_doc_path'),\n118:     filePath,\n119:   ) ?? filePath;\n120: \n121:   const routeAs = pickFirstString(\n122:     hints.routeAs,\n123:     getParsedIdentityValue(parsed, 'routeAs', 'route_as'),\n124:   );\n125:   const continuitySourceKey = pickFirstString(\n126:     hints.continuitySourceKey,\n127:     getParsedIdentityValue(parsed, 'continuitySourceKey', 'continuity_source_key', 'sourceKey', 'source_key'),\n128:   );\n129:   const targetAnchorId = pickFirstString(\n130:     hints.targetAnchorId,\n131:     getParsedIdentityValue(parsed, 'targetAnchorId', 'target_anchor_id', 'anchorId', 'anchor_id'),\n132:   ) ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? CONTINUITY_ANCHOR_ID : null);\n133: \n134:   return {\n135:     targetDocPath,\n136:     canonicalFilePath: pickFirstString(hints.canonicalFilePath, getCanonicalPathKey(targetDocPath)) ?? getCanonicalPathKey(targetDocPath),\n137:     targetAnchorId,\n138:     routeAs,\n139:     continuitySourceKey,\n140:   };\n141: }\n142: \n143: export function resolveCreateRecordLineage(\n144:   peDecision: PeDecision,\n145:   samePathExistingId: number | null,\n146: ): LineageRoutingDecision {\n147:   if (peDecision.action === predictionErrorGate.ACTION.SUPERSEDE && peDecision.existingMemoryId != null) {\n148:     return {\n149:       predecessorMemoryId: samePathExistingId,\n150:       transitionEvent: samePathExistingId != null ? 'SUPERSEDE' : 'CREATE',\n151:       causalSupersedesMemoryId: samePathExistingId === peDecision.existingMemoryId\n152:         ? null\n153:         : peDecision.existingMemoryId,\n154:     };\n155:   }\n156: \n157:   if (samePathExistingId != null) {\n158:     return {\n159:       predecessorMemoryId: samePathExistingId,\n160:       transitionEvent: 'UPDATE',\n161:       causalSupersedesMemoryId: null,\n162:     };\n163:   }\n164: \n165:   return {\n166:     predecessorMemoryId: null,\n167:     transitionEvent: 'CREATE',\n168:     causalSupersedesMemoryId: null,\n169:   };\n170: }\n171: \n172: export function buildScopePostInsertMetadata(\n173:   scope: MemoryScopeMatch = {},\n174: ): ScopePostInsertMetadata {\n175:   const tenantId = normalizeScopeMatchValue(scope.tenantId);\n176:   const userId = normalizeScopeMatchValue(scope.userId);\n177:   const agentId = normalizeScopeMatchValue(scope.agentId);\n178:   const sessionId = normalizeScopeMatchValue(scope.sessionId);\n179: \n180:   return {\n181:     ...(tenantId ? { tenant_id: tenantId } : {}),\n182:     ...(userId ? { user_id: userId } : {}),\n183:     ...(agentId ? { agent_id: agentId } : {}),\n184:     ...(sessionId ? { session_id: sessionId } : {}),\n185:   };\n186: }\n187: \n188: function recordCrossPathSupersedesEdge(\n189:   database: BetterSqlite3.Database,\n190:   memoryId: number,\n191:   supersededMemoryId: number | null,\n192:   reason: string | null | undefined,\n193: ): void {\n194:   if (supersededMemoryId == null) {\n195:     return;\n196:   }\n197: \n198:   causalEdges.init(database);\n199:   const evidence = reason && reason.trim().length > 0\n200:     ? reason.trim()\n201:     : 'Prediction-error contradiction across different file paths';\n202:   causalEdges.insertEdge(\n203:     String(memoryId),\n204:     String(supersededMemoryId),\n205:     causalEdges.RELATION_TYPES.SUPERSEDES,\n206:     1.0,\n207:     evidence,\n208:     true,\n209:     'auto',\n210:   );\n211: }\n212: \n213: export function findSamePathExistingMemory(\n214:   database: BetterSqlite3.Database,\n215:   specFolder: string,\n216:   canonicalFilePath: string,\n217:   filePath: string,\n218:   scope: MemoryScopeMatch = {},\n219:   identityHints: CreateRecordIdentityHints = {},\n220: ): { id: number; title: string | null; content_hash?: string | null } | undefined {\n221:   const tenantId = normalizeScopeMatchValue(scope.tenantId);\n222:   const userId = normalizeScopeMatchValue(scope.userId);\n223:   const agentId = normalizeScopeMatchValue(scope.agentId);\n224:   const sessionId = normalizeScopeMatchValue(scope.sessionId);\n225:   const resolvedCanonicalFilePath = normalizeOptionalString(identityHints.canonicalFilePath) ?? canonicalFilePath;\n226:   const resolvedFilePath = normalizeOptionalString(identityHints.targetDocPath) ?? filePath;\n227:   const resolvedAnchorId = normalizeOptionalString(identityHints.targetAnchorId);\n228:   const hasIdentityOverride = resolvedCanonicalFilePath !== canonicalFilePath\n229:     || resolvedFilePath !== filePath\n230:     || identityHints.targetAnchorId !== undefined\n231:     || identityHints.canonicalFilePath !== undefined\n232:     || identityHints.targetDocPath !== undefined;\n233: \n234:   const anchorClause = resolvedAnchorId !== null\n235:     ? 'AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))'\n236:     : hasIdentityOverride\n237:       ? 'AND anchor_id IS NULL'\n238:       : '';\n239: \n240:   const params: Array<string | null> = [\n241:     specFolder,\n242:     resolvedCanonicalFilePath,\n243:     resolvedFilePath,\n244:   ];\n245:   if (resolvedAnchorId !== null) {\n246:     params.push(resolvedAnchorId, resolvedAnchorId);\n247:   }\n248:   params.push(\n249:     tenantId,\n250:     tenantId,\n251:     userId,\n252:     userId,\n253:     agentId,\n254:     agentId,\n255:     sessionId,\n256:     sessionId,\n257:   );\n258: \n259:   return database.prepare(`\n260:     SELECT id, title, content_hash\n261:     FROM memory_index\n262:     WHERE spec_folder = ?\n263:       AND parent_id IS NULL\n264:       AND (canonical_file_path = ? OR file_path = ?)\n265:       ${anchorClause}\n266:       AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n267:       AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n268:       AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n269:       AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n270:     ORDER BY id DESC\n271:     LIMIT 1\n272:   `).get(...params) as { id: number; title: string | null; content_hash?: string | null } | undefined;\n273: }\n274: \n275: /**\n276:  * Creates a memory row with metadata, optional BM25 entry, and save history.\n277:  * Returns the persisted memory id for downstream save handlers.\n278:  */\n279: export function createMemoryRecord(\n280:   database: BetterSqlite3.Database,\n281:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n282:   filePath: string,\n283:   embedding: Float32Array | null,\n284:   embeddingFailureReason: string | null,\n285:   peDecision: PeDecision,\n286:   scope: MemoryScopeMatch = {},\n287:   identityHints: CreateRecordIdentityHints = {},\n288:   provenance: WriteProvenanceContext = {},\n289: ): number {\n290:   const recordIdentity = resolveCreateRecordIdentity(parsed, filePath, identityHints);\n291:   const routedDocumentType = inferDocumentTypeFromPath(recordIdentity.targetDocPath);\n292:   const persistedDocumentType = routedDocumentType !== 'memory'\n293:     ? routedDocumentType\n294:     : (parsed.documentType || 'memory');\n295: \n296:   if (!embedding) {\n297:     console.error(`[memory-save] Using deferred indexing for ${path.basename(recordIdentity.targetDocPath)}`);\n298:   }\n299: \n300:   // Detect spec level for spec documents.\n301:   const specLevel = isSpecDocumentType(persistedDocumentType)\n302:     ? detectSpecLevelFromParsed(recordIdentity.targetDocPath)\n303:     : null;\n304:   const encodingIntent = isEncodingIntentEnabled()\n305:     ? classifyEncodingIntent(parsed.content)\n306:     : undefined;\n307:   // Security: raw provider errors sanitized before persistence/response\n308:   const persistedEmbeddingFailureReason = sanitizeEmbeddingFailureMessage(embeddingFailureReason);\n309: \n310:   const indexWithMetadata = database.transaction(() => {\n311:     // Determine importance weight based on document type.\n312:     const importanceWeight = calculateDocumentWeight(recordIdentity.targetDocPath, parsed.documentType);\n313:     const samePathExisting = findSamePathExistingMemory(\n314:       database,\n315:       parsed.specFolder,\n316:       recordIdentity.canonicalFilePath,\n317:       recordIdentity.targetDocPath,\n318:       scope,\n319:       recordIdentity,\n320:     );\n321:     const lineageRouting = resolveCreateRecordLineage(peDecision, samePathExisting?.id ?? null);\n322:     const predecessorMemoryId = lineageRouting.predecessorMemoryId;\n323:     const transitionEvent = lineageRouting.transitionEvent;\n324: \n325:     // Retire the same-key predecessor before inserting the new active version so the\n326:     // active-row uniqueness guard holds at insert time; lineage and history persist.\n327:     // The carry surfaces a human's tier/source-kind to re-stamp on the successor.\n328:     const reindexCarry = predecessorMemoryId != null\n329:       ? retirePredecessorForActiveReindex(database, predecessorMemoryId)\n330:       : null;\n331: \n332:     const memory_id: number = embedding\n333:       ? vectorIndex.indexMemory({\n334:           specFolder: parsed.specFolder,\n335:           filePath: recordIdentity.targetDocPath,\n336:           anchorId: recordIdentity.targetAnchorId,\n337:           title: parsed.title,\n338:           triggerPhrases: parsed.triggerPhrases,\n339:           importanceWeight,\n340:           embedding,\n341:           encodingIntent,\n342:           documentType: persistedDocumentType,\n343:           specLevel,\n344:           contentText: parsed.content,\n345:           qualityScore: parsed.qualityScore,\n346:           qualityFlags: parsed.qualityFlags,\n347:           appendOnly: predecessorMemoryId != null,\n348:           scope,\n349:         })\n350:       : vectorIndex.indexMemoryDeferred({\n351:           specFolder: parsed.specFolder,\n352:           filePath: recordIdentity.targetDocPath,\n353:           anchorId: recordIdentity.targetAnchorId,\n354:           title: parsed.title,\n355:           triggerPhrases: parsed.triggerPhrases,\n356:           importanceWeight,\n357:           failureReason: persistedEmbeddingFailureReason,\n358:           encodingIntent,\n359:           documentType: persistedDocumentType,\n360:           specLevel,\n361:           contentText: parsed.content,\n362:           qualityScore: parsed.qualityScore,\n363:           qualityFlags: parsed.qualityFlags,\n364:           appendOnly: predecessorMemoryId != null,\n365:           scope,\n366:         });\n367: \n368:     const fileMetadata = incrementalIndex.getFileMetadata(recordIdentity.targetDocPath);\n369:     const fileMtimeMs = fileMetadata ? fileMetadata.mtime : null;\n370:     applyWriteProvenance(database, memory_id, {\n371:       tool: 'memory_save',\n372:       filePath: recordIdentity.targetDocPath,\n373:       scope,\n374:       ...provenance,\n375:     });\n376: \n377:     applyPostInsertMetadata(database, memory_id, {\n378:       content_hash: parsed.contentHash,\n379:       context_type: parsed.contextType,\n380:       importance_tier: parsed.importanceTier,\n381:       memory_type: parsed.memoryType,\n382:       type_inference_source: parsed.memoryTypeSource,\n383:       stability: fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n384:       difficulty: fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n385:       file_mtime_ms: fileMtimeMs,\n386:       encoding_intent: encodingIntent,\n387:       document_type: persistedDocumentType,\n388:       spec_level: specLevel,\n389:       quality_score: parsed.qualityScore ?? 0,\n390:       quality_flags: JSON.stringify(parsed.qualityFlags ?? []),\n391:       ...buildScopePostInsertMetadata(scope),\n392:     });\n393: \n394:     // Re-stamp after the metadata write so a manual predecessor's tier and human\n395:     // source-kind carry to the successor instead of being reset to the incoming\n396:     // default вҖ” keeping the automated-writers-never-overwrite-manual guarantee.\n397:     if (reindexCarry != null) {\n398:       database\n399:         .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n400:         .run(reindexCarry.importanceTier, memory_id);\n401:       persistSourceKind(database, memory_id, reindexCarry.sourceKind as SourceKind);\n402:     }\n403: \n404:     if (embedding && peDecision.action === predictionErrorGate.ACTION.CREATE_LINKED && peDecision.existingMemoryId != null) {\n405:       try {\n406:         database.prepare(`\n407:           UPDATE memory_index\n408:           SET related_memories = ?\n409:           WHERE id = ?\n410:         `).run(JSON.stringify([peDecision.existingMemoryId]), memory_id);\n411:       } catch (err: unknown) {\n412:         const message = toErrorMessage(err);\n413:         console.error('[PE-Gate] Could not store related memories:', message);\n414:       }\n415:     }\n416: \n417:     recordLineageTransition(database, memory_id, {\n418:       actor: 'mcp:memory_save',\n419:       predecessorMemoryId,\n420:       transitionEvent,\n421:     });\n422:     recordCrossPathSupersedesEdge(\n423:       database,\n424:       memory_id,\n425:       lineageRouting.causalSupersedesMemoryId,\n426:       peDecision.reason,\n427:     );\n428: \n429:     if (bm25Index.isBm25Enabled()) {\n430:       try {\n431:         const bm25 = bm25Index.getIndex();\n432:         bm25.addDocument(String(memory_id), bm25Index.buildBm25DocumentText({\n433:           title: parsed.title,\n434:           content_text: parsed.content,\n435:           trigger_phrases: parsed.triggerPhrases,\n436:           file_path: filePath,\n437:         }));\n438:       } catch (bm25_err: unknown) {\n439:         const message = toErrorMessage(bm25_err);\n440:         console.warn(embedding\n441:           ? `[memory-save] BM25 indexing failed: ${message}`\n442:           : `[memory-save] BM25 indexing failed (deferred path): ${message}`);\n443:       }\n444:     }\n445: \n446:     // Append-first writes add a new row for every new current version.\n447:     try {\n448:       recordHistory(memory_id, 'ADD', null, parsed.title ?? filePath, 'mcp:memory_save');\n449:       if (predecessorMemoryId != null) {\n450:         recordHistory(\n451:           predecessorMemoryId,\n452:           'UPDATE',\n453:           samePathExisting?.title ?? null,\n454:           parsed.title ?? recordIdentity.targetDocPath,\n455:           'mcp:memory_save',\n456:         );\n457:       }\n458:     } catch (_histErr: unknown) {\n459:       // History recording is best-effort during save\n460:     }\n461: \n462:     return memory_id;\n463:   });\n464: \n465:   return indexWithMetadata();\n466: }\n\n(End of file - total 466 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Create Record\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport path from 'path';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport * as vectorIndex from '../../lib/search/vector-index.js';\nimport * as bm25Index from '../../lib/search/bm25-index.js';\nimport * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\nimport * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\nimport * as incrementalIndex from '../../lib/storage/incremental-index.js';\nimport * as causalEdges from '../../lib/storage/causal-edges.js';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\nimport { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\nimport { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\nimport { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\nimport { recordHistory } from '../../lib/storage/history.js';\nimport { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Create Record\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport path from 'path';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport * as vectorIndex from '../../lib/search/vector-index.js';\nimport * as bm25Index from '../../lib/search/bm25-index.js';\nimport * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\nimport * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\nimport * as incrementalIndex from '../../lib/storage/incremental-index.js';\nimport * as causalEdges from '../../lib/storage/causal-edges.js';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\nimport { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\nimport { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\nimport { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\nimport { recordHistory } from '../../lib/storage/history.js';\nimport { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';\nimport { detectSpecLevelFromParsed } from '../handler-utils.js';\nimport { classifyEncodingIntent } from '../../lib/search/encoding-intent.js';\nimport { isEncodingIntentEnabled } from '../../lib/search/search-flags.js';\nimport { applyPostInsertMetadata } from './db-helpers.js';\nimport { inferDocumentTypeFromPath } from '../../lib/config/memory-types.js';\nimport {\n  applyWriteProvenance,\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  persistSourceKind,\n  type SourceKind,\n  type WriteProvenanceContext,\n} from '../../lib/storage/write-provenance.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Per-memory history log\n// Feature catalog: Prediction-error save arbitration\n\n\nimport type { PeDecision, MemoryScopeMatch } from './types.js';\nimport { normalizeScopeMatchValue } from './types.js';\nexport type { MemoryScopeMatch };\n\nexport const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n\nexport interface CreateRecordIdentityHints {\n  targetDocPath?: string | null;\n  canonicalFilePath?: string | null;\n  targetAnchorId?: string | null;\n  routeAs?: string | null;\n  continuitySourceKey?: string | null;\n}\n\nexport interface ResolvedCreateRecordIdentity {\n  targetDocPath: string;\n  canonicalFilePath: string;\n  targetAnchorId: string | null;\n  routeAs: string | null;\n  continuitySourceKey: string | null;\n}\n\ninterface LineageRoutingDecision {\n  predecessorMemoryId: number | null;\n  transitionEvent: 'CREATE' | 'UPDATE' | 'SUPERSEDE';\n  causalSupersedesMemoryId: number | null;\n}\n\ntype ScopePostInsertMetadata = Partial<{\n  tenant_id: string;\n  user_id: string;\n  agent_id: string;\n  session_id: string;\n}>;\n\nexport {\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  type SourceKind,\n};\n\nfunction normalizeOptionalString(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction pickFirstString(...values: unknown[]): string | null {\n  for (const value of values) {\n    const normalized = normalizeOptionalString(value);\n    if (normalized) {\n      return normalized;\n    }\n  }\n  return null;\n}\n\nfunction getParsedIdentityValue(parsed: ReturnType<typeof memoryParser.parseMemoryFile>, ...keys: string[]): string | null {\n  const parsedRecord = parsed as unknown as Record<string, unknown>;\n  for (const key of keys) {\n    const normalized = normalizeOptionalString(parsedRecord[key]);\n    if (normalized) {\n      return normalized;\n    }\n  }\n  return null;\n}\n\nexport function resolveCreateRecordIdentity(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  filePath: string,\n  hints: CreateRecordIdentityHints = {},\n): ResolvedCreateRecordIdentity {\n  const targetDocPath = pickFirstString(\n    hints.targetDocPath,\n    getParsedIdentityValue(parsed, 'targetDocPath', 'target_doc_path', 'targetFilePath', 'target_file_path', 'routedDocPath', 'routed_doc_path'),\n    filePath,\n  ) ?? filePath;\n\n  const routeAs = pickFirstString(\n    hints.routeAs,\n    getParsedIdentityValue(parsed, 'routeAs', 'route_as'),\n  );\n  const continuitySourceKey = pickFirstString(\n    hints.continuitySourceKey,\n    getParsedIdentityValue(parsed, 'continuitySourceKey', 'continuity_source_key', 'sourceKey', 'source_key'),\n  );\n  const targetAnchorId = pickFirstString(\n    hints.targetAnchorId,\n    getParsedIdentityValue(parsed, 'targetAnchorId', 'target_anchor_id', 'anchorId', 'anchor_id'),\n  ) ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? CONTINUITY_ANCHOR_ID : null);\n\n  return {\n    targetDocPath,\n    canonicalFilePath: pickFirstString(hints.canonicalFilePath, getCanonicalPathKey(targetDocPath)) ?? getCanonicalPathKey(targetDocPath),\n    targetAnchorId,\n    routeAs,\n    continuitySourceKey,\n  };\n}\n\nexport function resolveCreateRecordLineage(\n  peDecision: PeDecision,\n  samePathExistingId: number | null,\n): LineageRoutingDecision {\n  if (peDecision.action === predictionErrorGate.ACTION.SUPERSEDE && peDecision.existingMemoryId != null) {\n    return {\n      predecessorMemoryId: samePathExistingId,\n      transitionEvent: samePathExistingId != null ? 'SUPERSEDE' : 'CREATE',\n      causalSupersedesMemoryId: samePathExistingId === peDecision.existingMemoryId\n        ? null\n        : peDecision.existingMemoryId,\n    };\n  }\n\n  if (samePathExistingId != null) {\n    return {\n      predecessorMemoryId: samePathExistingId,\n      transitionEvent: 'UPDATE',\n      causalSupersedesMemoryId: null,\n    };\n  }\n\n  return {\n    predecessorMemoryId: null,\n    transitionEvent: 'CREATE',\n    causalSupersedesMemoryId: null,\n  };\n}\n\nexport function buildScopePostInsertMetadata(\n  scope: MemoryScopeMatch = {},\n): ScopePostInsertMetadata {\n  const tenantId = normalizeScopeMatchValue(scope.tenantId);\n  const userId = normalizeScopeMatchValue(scope.userId);\n  const agentId = normalizeScopeMatchValue(scope.agentId);\n  const sessionId = normalizeScopeMatchValue(scope.sessionId);\n\n  return {\n    ...(tenantId ? { tenant_id: tenantId } : {}),\n    ...(userId ? { user_id: userId } : {}),\n    ...(agentId ? { agent_id: agentId } : {}),\n    ...(sessionId ? { session_id: sessionId } : {}),\n  };\n}\n\nfunction recordCrossPathSupersedesEdge(\n  database: BetterSqlite3.Database,\n  memoryId: number,\n  supersededMemoryId: number | null,\n  reason: string | null | undefined,\n): void {\n  if (supersededMemoryId == null) {\n    return;\n  }\n\n  causalEdges.init(database);\n  const evidence = reason && reason.trim().length > 0\n    ? reason.trim()\n    : 'Prediction-error contradiction across different file paths';\n  causalEdges.insertEdge(\n    String(memoryId),\n    String(supersededMemoryId),\n    causalEdges.RELATION_TYPES.SUPERSEDES,\n    1.0,\n    evidence,\n    true,\n    'auto',\n  );\n}\n\nexport function findSamePathExistingMemory(\n  database: BetterSqlite3.Database,\n  specFolder: string,\n  canonicalFilePath: string,\n  filePath: string,\n  scope: MemoryScopeMatch = {},\n  identityHints: CreateRecordIdentityHints = {},\n): { id: number; title: string | null; content_hash?: string | null } | undefined {\n  const tenantId = normalizeScopeMatchValue(scope.tenantId);\n  const userId = normalizeScopeMatchValue(scope.userId);\n  const agentId = normalizeScopeMatchValue(scope.agentId);\n  const sessionId = normalizeScopeMatchValue(scope.sessionId);\n  const resolvedCanonicalFilePath = normalizeOptionalString(identityHints.canonicalFilePath) ?? canonicalFilePath;\n  const resolvedFilePath = normalizeOptionalString(identityHints.targetDocPath) ?? filePath;\n  const resolvedAnchorId = normalizeOptionalString(identityHints.targetAnchorId);\n  const hasIdentityOverride = resolvedCanonicalFilePath !== canonicalFilePath\n    || resolvedFilePath !== filePath\n    || identityHints.targetAnchorId !== undefined\n    || identityHints.canonicalFilePath !== undefined\n    || identityHints.targetDocPath !== undefined;\n\n  const anchorClause = resolvedAnchorId !== null\n    ? 'AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))'\n    : hasIdentityOverride\n      ? 'AND anchor_id IS NULL'\n      : '';\n\n  const params: Array<string | null> = [\n    specFolder,\n    resolvedCanonicalFilePath,\n    resolvedFilePath,\n  ];\n  if (resolvedAnchorId !== null) {\n    params.push(resolvedAnchorId, resolvedAnchorId);\n  }\n  params.push(\n    tenantId,\n    tenantId,\n    userId,\n    userId,\n    agentId,\n    agentId,\n    sessionId,\n    sessionId,\n  );\n\n  return database.prepare(`\n    SELECT id, title, content_hash\n    FROM memory_index\n    WHERE spec_folder = ?\n      AND parent_id IS NULL\n      AND (canonical_file_path = ? OR file_path = ?)\n      ${anchorClause}\n      AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n      AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n      AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n      AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n    ORDER BY id DESC\n    LIMIT 1\n  `).get(...params) as { id: number; title: string | null; content_hash?: string | null } | undefined;\n}\n\n/**\n * Creates a memory row with metadata, optional BM25 entry, and save history.\n * Returns the persisted memory id for downstream save handlers.\n */\nexport function createMemoryRecord(\n  database: BetterSqlite3.Database,\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  filePath: string,\n  embedding: Float32Array | null,\n  embeddingFailureReason: string | null,\n  peDecision: PeDecision,\n  scope: MemoryScopeMatch = {},\n  identityHints: CreateRecordIdentityHints = {},\n  provenance: WriteProvenanceContext = {},\n): number {\n  const recordIdentity = resolveCreateRecordIdentity(parsed, filePath, identityHints);\n  const routedDocumentType = inferDocumentTypeFromPath(recordIdentity.targetDocPath);\n  const persistedDocumentType = routedDocumentType !== 'memory'\n    ? routedDocumentType\n    : (parsed.documentType || 'memory');\n\n  if (!embedding) {\n    console.error(`[memory-save] Using deferred indexing for ${path.basename(recordIdentity.targetDocPath)}`);\n  }\n\n  // Detect spec level for spec documents.\n  const specLevel = isSpecDocumentType(persistedDocumentType)\n    ? detectSpecLevelFromParsed(recordIdentity.targetDocPath)\n    : null;\n  const encodingIntent = isEncodingIntentEnabled()\n    ? classifyEncodingIntent(parsed.content)\n    : undefined;\n  // Security: raw provider errors sanitized before persistence/response\n  const persistedEmbeddingFailureReason = sanitizeEmbeddingFailureMessage(embeddingFailureReason);\n\n  const indexWithMetadata = database.transaction(() => {\n    // Determine importance weight based on document type.\n    const importanceWeight = calculateDocumentWeight(recordIdentity.targetDocPath, parsed.documentType);\n    const samePathExisting = findSamePathExistingMemory(\n      database,\n      parsed.specFolder,\n      recordIdentity.canonicalFilePath,\n      recordIdentity.targetDocPath,\n      scope,\n      recordIdentity,\n    );\n    const lineageRouting = resolveCreateRecordLineage(peDecision, samePathExisting?.id ?? null);\n    const predecessorMemoryId = lineageRouting.predecessorMemoryId;\n    const transitionEvent = lineageRouting.transitionEvent;\n\n    // Retire the same-key predecessor before inserting the new active version so the\n    // active-row uniqueness guard holds at insert time; lineage and history persist.\n    // The carry surfaces a human's tier/source-kind to re-stamp on the successor.\n    const reindexCarry = predecessorMemoryId != null\n      ? retirePredecessorForActiveReindex(database, predecessorMemoryId)\n      : null;\n\n    const memory_id: number = embedding\n      ? vectorIndex.indexMemory({\n          specFolder: parsed.specFolder,\n          filePath: recordIdentity.targetDocPath,\n          anchorId: recordIdentity.targetAnchorId,\n          title: parsed.title,\n          triggerPhrases: parsed.triggerPhrases,\n          importanceWeight,\n          embedding,\n          encodingIntent,\n          documentType: persistedDocumentType,\n          specLevel,\n          contentText: parsed.content,\n          qualityScore: parsed.qualityScore,\n          qualityFlags: parsed.qualityFlags,\n          appendOnly: predecessorMemoryId != null,\n          scope,\n        })\n      : vectorIndex.indexMemoryDeferred({\n          specFolder: parsed.specFolder,\n          filePath: recordIdentity.targetDocPath,\n          anchorId: recordIdentity.targetAnchorId,\n          title: parsed.title,\n          triggerPhrases: parsed.triggerPhrases,\n          importanceWeight,\n          failureReason: persistedEmbeddingFailureReason,\n          encodingIntent,\n          documentType: persistedDocumentType,\n          specLevel,\n          contentText: parsed.content,\n          qualityScore: parsed.qualityScore,\n          qualityFlags: parsed.qualityFlags,\n          appendOnly: predecessorMemoryId != null,\n          scope,\n        });\n\n    const fileMetadata = incrementalIndex.getFileMetadata(recordIdentity.targetDocPath);\n    const fileMtimeMs = fileMetadata ? fileMetadata.mtime : null;\n    applyWriteProvenance(database, memory_id, {\n      tool: 'memory_save',\n      filePath: recordIdentity.targetDocPath,\n      scope,\n      ...provenance,\n    });\n\n    applyPostInsertMetadata(database, memory_id, {\n      content_hash: parsed.contentHash,\n      context_type: parsed.contextType,\n      importance_tier: parsed.importanceTier,\n      memory_type: parsed.memoryType,\n      type_inference_source: parsed.memoryTypeSource,\n      stability: fsrsScheduler.DEFAULT_INITIAL_STABILITY,\n      difficulty: fsrsScheduler.DEFAULT_INITIAL_DIFFICULTY,\n      file_mtime_ms: fileMtimeMs,\n      encoding_intent: encodingIntent,\n      document_type: persistedDocumentType,\n      spec_level: specLevel,\n      quality_score: parsed.qualityScore ?? 0,\n      quality_flags: JSON.stringify(parsed.qualityFlags ?? []),\n      ...buildScopePostInsertMetadata(scope),\n    });\n\n    // Re-stamp after the metadata write so a manual predecessor's tier and human\n    // source-kind carry to the successor instead of being reset to the incoming\n    // default вҖ” keeping the automated-writers-never-overwrite-manual guarantee.\n    if (reindexCarry != null) {\n      database\n        .prepare('UPDATE memory_index SET importance_tier = ? WHERE id = ?')\n        .run(reindexCarry.importanceTier, memory_id);\n      persistSourceKind(database, memory_id, reindexCarry.sourceKind as SourceKind);\n    }\n\n    if (embedding && peDecision.action === predictionErrorGate.ACTION.CREATE_LINKED && peDecision.existingMemoryId != null) {\n      try {\n        database.prepare(`\n          UPDATE memory_index\n          SET related_memories = ?\n          WHERE id = ?\n        `).run(JSON.stringify([peDecision.existingMemoryId]), memory_id);\n      } catch (err: unknown) {\n        const message = toErrorMessage(err);\n        console.error('[PE-Gate] Could not store related memories:', message);\n      }\n    }\n\n    recordLineageTransition(database, memory_id, {\n      actor: 'mcp:memory_save',\n      predecessorMemoryId,\n      transitionEvent,\n    });\n    recordCrossPathSupersedesEdge(\n      database,\n      memory_id,\n      lineageRouting.causalSupersedesMemoryId,\n      peDecision.reason,\n    );\n\n    if (bm25Index.isBm25Enabled()) {\n      try {\n        const bm25 = bm25Index.getIndex();\n        bm25.addDocument(String(memory_id), bm25Index.buildBm25DocumentText({\n          title: parsed.title,\n          content_text: parsed.content,\n          trigger_phrases: parsed.triggerPhrases,\n          file_path: filePath,\n        }));\n      } catch (bm25_err: unknown) {\n        const message = toErrorMessage(bm25_err);\n        console.warn(embedding\n          ? `[memory-save] BM25 indexing failed: ${message}`\n          : `[memory-save] BM25 indexing failed (deferred path): ${message}`);\n      }\n    }\n\n    // Append-first writes add a new row for every new current version.\n    try {\n      recordHistory(memory_id, 'ADD', null, parsed.title ?? filePath, 'mcp:memory_save');\n      if (predecessorMemoryId != null) {\n        recordHistory(\n          predecessorMemoryId,\n          'UPDATE',\n          samePathExisting?.title ?? null,\n          parsed.title ?? recordIdentity.targetDocPath,\n          'mcp:memory_save',\n        );\n      }\n    } catch (_histErr: unknown) {\n      // History recording is best-effort during save\n    }\n\n    return memory_id;\n  });\n\n  return indexWithMetadata();\n}","lineStart":1,"lineEnd":466,"totalLines":466,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","time":{"start":1781762877413,"end":1781762877418}},"metadata":{"openai":{"itemId":"fc_00bb168e403b2046016a338b3d3e0c819188b6f44b9ba8a677"}},"id":"prt_ed957e7df001S96wGIdU4rl3Nd","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957bb72001yEPgUg0JVqBslj"}}
