{"type":"tool_use","timestamp":1780906482880,"sessionID":"ses_159b57c7effe9b0auhWP6vzE3c","part":{"type":"tool","tool":"read","callID":"call_4CyasBRwPvIN0zkScfBlBKAi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   releaseRespawnLockFile,\n37:   sampleProcessTreeRssMb,\n38:   shouldAbortRelaunchOnFire,\n39:   shouldSkipLaunch,\n40:   signalProcess,\n41:   superviseChildExit,\n42:   waitForPidExit,\n43: } = mss;\n44: \n45: const root = path.resolve(__dirname, '..', '..');\n46: const opencodeDir = path.join(root, '.opencode');\n47: \n48: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n49: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n50: // Minimal parser — no external dependency.\n51: function loadEnvFile(filePath) {\n52:   if (!fs.existsSync(filePath)) return 0;\n53:   let count = 0;\n54:   const raw = fs.readFileSync(filePath, 'utf8');\n55:   for (const line of raw.split('\\n')) {\n56:     const trimmed = line.trim();\n57:     if (!trimmed || trimmed.startsWith('#')) continue;\n58:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n59:     if (!m) continue;\n60:     const key = m[1];\n61:     let val = m[2];\n62:     // Strip matching outer quotes (single or double)\n63:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n64:       val = val.slice(1, -1);\n65:     }\n66:     if (!(key in process.env)) {\n67:       process.env[key] = val;\n68:       count++;\n69:     }\n70:   }\n71:   return count;\n72: }\n73: \n74: function isStrictModeDisabled(value) {\n75:   if (value === undefined || value === null) return false;\n76:   const v = String(value).trim().toLowerCase();\n77:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n78: }\n79: \n80: let skillsDir = path.join(opencodeDir, 'skills');\n81: let legacySkillDir = path.join(opencodeDir, 'skill');\n82: let kitDir = path.join(skillsDir, 'system-spec-kit');\n83: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n84: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n85: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n86: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n87: let stateFile = path.join(dbDir, PID_FILE_NAME);\n88: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n89: \n90: const rel = (p) => path.relative(root, p) || '.';\n91: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n92: const now = () => new Date().toISOString();\n93: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n94: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n95: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n96: let childProcess = null;\n97: let ownerLeasePid = null;\n98: let leaseStartedAt = null;\n99: let launcherShutdownInProgress = false;\n100: let rssBreachSelfExitInProgress = false;\n101: let rssWatchdogTimer = null;\n102: let crashLoopGuard = null;\n103: let supervisorRelaunchTimer = null;\n104: // The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n105: // launcher's parent. When the host disposes its session the launcher is orphaned and its\n106: // ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n107: // path can tell \"owning runtime went away\" apart from a genuine daemon crash.\n108: const LAUNCHER_INITIAL_PPID = process.ppid;\n109: let ownerLeaseHeartbeatTimer = null;\n110: let ownerLeaseRequired = true;\n111: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n112: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n113: // orphaned sidecar after the child has already exited.\n114: let lastKnownDescendantPids = [];\n115: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n116: const durableWriteWarnings = new Set();\n117: \n118: function log(message) {\n119:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n120:   persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n121: }\n122: \n123: function isDurableWriteUnavailable(error) {\n124:   const code = error && typeof error === 'object' ? error.code : undefined;\n125:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n126: }\n127: \n128: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n129:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n130:   const key = `${operation}:${targetPath}:${code}`;\n131:   if (durableWriteWarnings.has(key)) return;\n132:   durableWriteWarnings.add(key);\n133:   const detail = error instanceof Error ? error.message : String(error ?? code);\n134:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n135: }\n136: \n137: // Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n138: // ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n139: // durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n140: // launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n141: // grow without bound.\n142: function launcherLogIsEnabled(env = process.env) {\n143:   return env.SPECKIT_LAUNCHER_LOG !== '0';\n144: }\n145: function launcherLogMaxBytes(env = process.env) {\n146:   return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n147: }\n148: function resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n149:   const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n150:   return typeof override === 'string' && override.trim()\n151:     ? override.trim()\n152:     : path.join(baseDir, '.mk-spec-memory-launcher.log');\n153: }\n154: function shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n155:   return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n156: }\n157: function persistLauncherLogLine(line) {\n158:   if (!launcherLogIsEnabled()) return;\n159:   let target;\n160:   try {\n161:     target = resolveLauncherLogPath();\n162:     try {\n163:       const { size } = fs.statSync(target);\n164:       if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n165:         try {\n166:           // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n167:           // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n168:           // suffix still rotates instead of renaming the file onto itself and growing without bound.\n169:           const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n170:           fs.renameSync(target, rotated);\n171:         } catch {\n172:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n173:         }\n174:       }\n175:     } catch (statErr) {\n176:       if (statErr.code !== 'ENOENT') throw statErr;\n177:     }\n178:     fs.appendFileSync(target, line, { mode: 0o600 });\n179:   } catch (error) {\n180:     if (target && isDurableWriteUnavailable(error)) {\n181:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n182:       return;\n183:     }\n184:     // Logging must never break the launcher.\n185:   }\n186: }\n187: \n188: // Daemon re-election (default-on via the committed runtime configs; the code default below stays off\n189: // so the configs are the single on-switch). When enabled the owner spawns the daemon detached and, on\n190: // its own shutdown, RELEASES the daemon (leaves it running for a live secondary to bridge to) instead\n191: // of killing it, so a session ending does not tear the shared backend out from under other sessions.\n192: // A fresh session that finds the released daemon under a stale lease reaps it before respawn, so the\n193: // database keeps a single writer. Flag off collapses every path below to the prior behavior (daemon\n194: // tied to the owner, killed on shutdown). A released daemon reparents to pid 1, bounded by its idle\n195: // self-exit, so the orphan sweeper bounds any leak.\n196: function daemonReelectionEnabled(env = process.env) {\n197:   return env.SPECKIT_DAEMON_REELECTION === '1' || env.SPECKIT_DAEMON_REELECTION === 'on';\n198: }\n199: function contextServerSpawnIo(reelectionEnabled) {\n200:   return reelectionEnabled\n201:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n202:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n203: }\n204: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n205:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n206: }\n207: \n208: function cleanupTmpFile(tmpPath) {\n209:   try {\n210:     fs.unlinkSync(tmpPath);\n211:   } catch (error) {\n212:     if (error.code !== 'ENOENT') {\n213:       // Best-effort cleanup only; the original durable-write failure is more useful.\n214:     }\n215:   }\n216: }\n217: \n218: function writeAtomicJsonFile(targetPath, payload, operation) {\n219:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n220:   const tmp = `${currentPath}.tmp.${process.pid}`;\n221:   try {\n222:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n223:     fs.renameSync(tmp, currentPath);\n224:     return true;\n225:   } catch (error) {\n226:     cleanupTmpFile(tmp);\n227:     if (isDurableWriteUnavailable(error)) {\n228:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n229:       return false;\n230:     }\n231:     throw error;\n232:   }\n233: }\n234: \n235: function loadProjectEnvFiles() {\n236:   for (const fname of ['.env.local', '.env']) {\n237:     const p = path.join(root, fname);\n238:     if (fs.existsSync(p)) {\n239:       const n = loadEnvFile(p);\n240:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n241:     }\n242:   }\n243: }\n244: \n245: function parsePositiveInteger(value, fallback) {\n246:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n247:   const parsed = Number.parseInt(String(value).trim(), 10);\n248:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n249: }\n250: \n251: function loadBridgeModule() {\n252:   try {\n253:     return require('./lib/launcher-ipc-bridge.cjs');\n254:   } catch (error) {\n255:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n256:     return {\n257:       async maybeBridgeLeaseHolder({ leaseResult }) {\n258:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n259:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n260:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n\n(Showing lines 1-260 of 1612. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;\nlet crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\n// The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n// launcher's parent. When the host disposes its session the launcher is orphaned and its\n// ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n// path can tell \"owning runtime went away\" apart from a genuine daemon crash.\nconst LAUNCHER_INITIAL_PPID = process.ppid;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n  persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\n// Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n// ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n// durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n// launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n// grow without bound.\nfunction launcherLogIsEnabled(env = process.env) {\n  return env.SPECKIT_LAUNCHER_LOG !== '0';\n}\nfunction launcherLogMaxBytes(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n}\nfunction resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n  const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n  return typeof override === 'string' && override.trim()\n    ? override.trim()\n    : path.join(baseDir, '.mk-spec-memory-launcher.log');\n}\nfunction shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n  return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n}\nfunction persistLauncherLogLine(line) {\n  if (!launcherLogIsEnabled()) return;\n  let target;\n  try {\n    target = resolveLauncherLogPath();\n    try {\n      const { size } = fs.statSync(target);\n      if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n        try {\n          // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n          // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n          // suffix still rotates instead of renaming the file onto itself and growing without bound.\n          const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (default-on via the committed runtime configs; the code default below stays off\n// so the configs are the single on-switch). When enabled the owner spawns the daemon detached and, on\n// its own shutdown, RELEASES the daemon (leaves it running for a live secondary to bridge to) instead\n// of killing it, so a session ending does not tear the shared backend out from under other sessions.\n// A fresh session that finds the released daemon under a stale lease reaps it before respawn, so the\n// database keeps a single writer. Flag off collapses every path below to the prior behavior (daemon\n// tied to the owner, killed on shutdown). A released daemon reparents to pid 1, bounded by its idle\n// self-exit, so the orphan sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION === '1' || env.SPECKIT_DAEMON_REELECTION === 'on';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';","lineStart":1,"lineEnd":260,"totalLines":1612,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780906482854,"end":1780906482874}},"metadata":{"openai":{"itemId":"fc_0af27da313d0a0d9016a2679f279688191a749d4ada9a7f88e"}},"id":"prt_ea64c5be8001iYwLa2EnCSDLmG","sessionID":"ses_159b57c7effe9b0auhWP6vzE3c","messageID":"msg_ea64c0c4a0019whB5591O99g29"}}
