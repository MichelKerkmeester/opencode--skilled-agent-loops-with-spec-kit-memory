{"type":"text","timestamp":1781144241979,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"id":"prt_eb4783433001c20iCThrjHpgY7","messageID":"msg_eb477fee8001w4gZqiXMJ1Rd3D","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","type":"text","text":"The main routed paths preserve the intended retry and maintenance constants. I’m checking traversal semantics and vector-store contract parity next, because those are the highest-risk adapter seams.","time":{"start":1781144237108,"end":1781144241974},"metadata":{"openai":{"itemId":"msg_0c16151930509033016a2a1aad197881918b4d2e31598811e8","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781144242057,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"grep","callID":"call_3wE1XTMwnlcgh6RPVw4fHlue","state":{"status":"completed","input":{"pattern":"function index_memory|export function index_memory|async function index_memory","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","include":"*.ts"},"output":"Found 2 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts:\n  Line 228: export function index_memory(\n\n  Line 349: export function index_memory_deferred(\n","metadata":{"matches":2,"truncated":false},"title":"function index_memory|export function index_memory|async function index_memory","time":{"start":1781144242047,"end":1781144242057}},"metadata":{"openai":{"itemId":"fc_0c16151930509033016a2a1ab1f38c8191825516f3d38d8546"}},"id":"prt_eb478477d001lsW0G2XrlqQr8G","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477fee8001w4gZqiXMJ1Rd3D"}}
{"type":"tool_use","timestamp":1781144242059,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_hIqKBJOdEh9khxq1bea6A9O5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: BFS Traversal\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type Database from 'better-sqlite3';\n6: \n7: type TraversalNode = number | string;\n8: \n9: const SQLITE_BINDING_CHUNK_SIZE = 900;\n10: \n11: /** Edge returned by a weighted graph reader. */\n12: export interface WeightedTraversalEdge<TNode extends TraversalNode> {\n13:   readonly from: TNode;\n14:   readonly to: TNode;\n15:   readonly weight: number;\n16:   readonly strength?: number;\n17: }\n18: \n19: /** Aggregated weighted walk output for one reached node. */\n20: export interface WeightedWalkResult<TNode extends TraversalNode> {\n21:   readonly nodeId: TNode;\n22:   readonly minHop: number;\n23:   readonly maxWalkScore: number;\n24: }\n25: \n26: /** Options for hop-capped weighted graph traversal. */\n27: export interface WeightedWalkOptions<TNode extends TraversalNode> {\n28:   readonly seeds: readonly TNode[];\n29:   readonly maxHops: number;\n30:   readonly readEdges: (nodeIds: readonly TNode[]) => readonly WeightedTraversalEdge<TNode>[];\n31: }\n32: \n33: /** Edge returned by a directed graph reader. */\n34: export interface DirectedTraversalEdge<TNode extends TraversalNode> {\n35:   readonly from: TNode;\n36:   readonly to: TNode;\n37: }\n38: \n39: /** Options for directed reachability traversal. */\n40: export interface DirectedReachabilityOptions<TNode extends TraversalNode> {\n41:   readonly roots: readonly TNode[];\n42:   readonly readEdges: (nodeIds: readonly TNode[]) => readonly DirectedTraversalEdge<TNode>[];\n43: }\n44: \n45: interface WeightedWalkState<TNode extends TraversalNode> {\n46:   readonly origin: TNode;\n47:   readonly nodeId: TNode;\n48:   readonly hop: number;\n49:   readonly walkScore: number;\n50: }\n51: \n52: interface CausalEdgeRow {\n53:   readonly source_id: string;\n54:   readonly target_id: string;\n55:   readonly relation: string;\n56:   readonly strength: number | null;\n57: }\n58: \n59: interface DependencyEdgeRow {\n60:   readonly parent_path: string;\n61:   readonly child_path: string;\n62: }\n63: \n64: function uniqueNodes<TNode extends TraversalNode>(nodeIds: readonly TNode[]): TNode[] {\n65:   return Array.from(new Set(nodeIds));\n66: }\n67: \n68: function sameNode<TNode extends TraversalNode>(left: TNode, right: TNode): boolean {\n69:   return left === right;\n70: }\n71: \n72: function stateKey<TNode extends TraversalNode>(state: WeightedWalkState<TNode>): string {\n73:   return `${String(state.origin)}\\u0000${String(state.nodeId)}\\u0000${state.hop}\\u0000${state.walkScore}`;\n74: }\n75: \n76: function groupWeightedEdges<TNode extends TraversalNode>(\n77:   edges: readonly WeightedTraversalEdge<TNode>[],\n78: ): Map<TNode, WeightedTraversalEdge<TNode>[]> {\n79:   const grouped = new Map<TNode, WeightedTraversalEdge<TNode>[]>();\n80:   for (const edge of edges) {\n81:     const group = grouped.get(edge.from) ?? [];\n82:     group.push(edge);\n83:     grouped.set(edge.from, group);\n84:   }\n85:   return grouped;\n86: }\n87: \n88: function placeholders(count: number): string {\n89:   return Array.from({ length: count }, () => '?').join(', ');\n90: }\n91: \n92: function chunks<T>(items: readonly T[], size: number): T[][] {\n93:   const result: T[][] = [];\n94:   for (let index = 0; index < items.length; index += size) {\n95:     result.push(items.slice(index, index + size));\n96:   }\n97:   return result;\n98: }\n99: \n100: function relationWeight(relation: string, relationWeights: Readonly<Record<string, number>>): number {\n101:   const multiplier = relationWeights[relation] ?? 1.0;\n102:   return Number.isFinite(multiplier) ? multiplier : 1.0;\n103: }\n104: \n105: function edgeStrength(value: number | null): number {\n106:   return typeof value === 'number' && Number.isFinite(value) ? value : 1.0;\n107: }\n108: \n109: function nextWalkScore<TNode extends TraversalNode>(\n110:   state: WeightedWalkState<TNode>,\n111:   edge: WeightedTraversalEdge<TNode>,\n112: ): number {\n113:   const weighted = state.walkScore * edge.weight;\n114:   return edge.strength === undefined ? weighted : weighted * edge.strength;\n115: }\n116: \n117: /**\n118:  * Run a hop-capped weighted walk and aggregate by reached node.\n119:  * The aggregation intentionally keeps min hop and max score independent.\n120:  */\n121: export function collectWeightedWalk<TNode extends TraversalNode>(\n122:   options: WeightedWalkOptions<TNode>,\n123: ): Map<TNode, WeightedWalkResult<TNode>> {\n124:   const maxHops = Math.max(0, Math.trunc(options.maxHops));\n125:   const seeds = uniqueNodes(options.seeds);\n126:   const seedSet = new Set(seeds);\n127:   const results = new Map<TNode, WeightedWalkResult<TNode>>();\n128:   if (seeds.length === 0 || maxHops === 0) {\n129:     return results;\n130:   }\n131: \n132:   let frontier: WeightedWalkState<TNode>[] = seeds.map((seed) => ({\n133:     origin: seed,\n134:     nodeId: seed,\n135:     hop: 0,\n136:     walkScore: 1.0,\n137:   }));\n138:   const seenStates = new Set<string>();\n139: \n140:   while (frontier.length > 0) {\n141:     const expandable = frontier.filter((state) => state.hop < maxHops);\n142:     if (expandable.length === 0) break;\n143: \n144:     const nodeIds = uniqueNodes(expandable.map((state) => state.nodeId));\n145:     const edgesByFrom = groupWeightedEdges(options.readEdges(nodeIds));\n146:     const nextFrontier: WeightedWalkState<TNode>[] = [];\n147: \n148:     for (const state of expandable) {\n149:       const edges = edgesByFrom.get(state.nodeId) ?? [];\n150:       for (const edge of edges) {\n151:         if (state.hop > 0 && sameNode(edge.to, state.origin)) {\n152:           continue;\n153:         }\n154: \n155:         const nextState: WeightedWalkState<TNode> = {\n156:           origin: state.origin,\n157:           nodeId: edge.to,\n158:           hop: state.hop + 1,\n159:           walkScore: nextWalkScore(state, edge),\n160:         };\n161:         const key = stateKey(nextState);\n162:         if (seenStates.has(key)) {\n163:           continue;\n164:         }\n165:         seenStates.add(key);\n166:         nextFrontier.push(nextState);\n167: \n168:         if (seedSet.has(nextState.nodeId)) {\n169:           continue;\n170:         }\n171: \n172:         const current = results.get(nextState.nodeId);\n173:         if (!current) {\n174:           results.set(nextState.nodeId, {\n175:             nodeId: nextState.nodeId,\n176:             minHop: nextState.hop,\n177:             maxWalkScore: nextState.walkScore,\n178:           });\n179:         } else {\n180:           results.set(nextState.nodeId, {\n181:             nodeId: nextState.nodeId,\n182:             minHop: Math.min(current.minHop, nextState.hop),\n183:             maxWalkScore: Math.max(current.maxWalkScore, nextState.walkScore),\n184:           });\n185:         }\n186:       }\n187:     }\n188: \n189:     frontier = nextFrontier;\n190:   }\n191: \n192:   return results;\n193: }\n194: \n195: /** Collect all nodes reachable from the given roots through directed edges. */\n196: export function collectDirectedReachability<TNode extends TraversalNode>(\n197:   options: DirectedReachabilityOptions<TNode>,\n198: ): TNode[] {\n199:   const roots = uniqueNodes(options.roots);\n200:   if (roots.length === 0) {\n201:     return [];\n202:   }\n203: \n204:   const rootSet = new Set(roots);\n205:   const visited = new Set<TNode>();\n206:   const reached: TNode[] = [];\n207:   let frontier = roots;\n208: \n209:   while (frontier.length > 0) {\n210:     const nextFrontier: TNode[] = [];\n211:     const edges = options.readEdges(frontier);\n212: \n213:     for (const edge of edges) {\n214:       if (visited.has(edge.to)) {\n215:         continue;\n216:       }\n217:       visited.add(edge.to);\n218:       if (!rootSet.has(edge.to)) {\n219:         reached.push(edge.to);\n220:       }\n221:       nextFrontier.push(edge.to);\n222:     }\n223: \n224:     frontier = uniqueNodes(nextFrontier);\n225:   }\n226: \n227:   return reached;\n228: }\n229: \n230: /** Read causal edges as an undirected, weighted adjacency view without OR joins. */\n231: export function readCausalNeighborEdges(\n232:   database: Database.Database,\n233:   nodeIds: readonly number[],\n234:   relationWeights: Readonly<Record<string, number>>,\n235: ): WeightedTraversalEdge<number>[] {\n236:   const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n237:   const edges: WeightedTraversalEdge<number>[] = [];\n238:   if (nodes.length === 0) {\n239:     return edges;\n240:   }\n241: \n242:   for (const nodeChunk of chunks(nodes.map((nodeId) => String(nodeId)), SQLITE_BINDING_CHUNK_SIZE)) {\n243:     const chunkPlaceholders = placeholders(nodeChunk.length);\n244:     const outgoingRows = database.prepare(`\n245:       SELECT source_id, target_id, relation, strength\n246:       FROM causal_edges\n247:       WHERE source_id IN (${chunkPlaceholders})\n248:     `).all(...nodeChunk) as CausalEdgeRow[];\n249:     const incomingRows = database.prepare(`\n250:       SELECT source_id, target_id, relation, strength\n251:       FROM causal_edges\n252:       WHERE target_id IN (${chunkPlaceholders})\n253:     `).all(...nodeChunk) as CausalEdgeRow[];\n254: \n255:     for (const row of outgoingRows) {\n256:       const from = Number.parseInt(row.source_id, 10);\n257:       const to = Number.parseInt(row.target_id, 10);\n258:       if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n259:       edges.push({\n260:         from,\n261:         to,\n262:         weight: relationWeight(row.relation, relationWeights),\n263:         strength: edgeStrength(row.strength),\n264:       });\n265:     }\n266:     for (const row of incomingRows) {\n267:       const from = Number.parseInt(row.target_id, 10);\n268:       const to = Number.parseInt(row.source_id, 10);\n269:       if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n270:       edges.push({\n271:         from,\n272:         to,\n273:         weight: relationWeight(row.relation, relationWeights),\n274:         strength: edgeStrength(row.strength),\n275:       });\n276:     }\n277:   }\n278: \n279:   return edges;\n280: }\n281: \n282: /** Traverse causal edges with the production weighted-walk reader. */\n283: export function collectCausalWeightedNeighbors(\n284:   database: Database.Database,\n285:   seeds: readonly number[],\n286:   maxHops: number,\n287:   relationWeights: Readonly<Record<string, number>>,\n288: ): Map<number, WeightedWalkResult<number>> {\n289:   return collectWeightedWalk({\n290:     seeds,\n291:     maxHops,\n292:     readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n293:   });\n294: }\n295: \n296: /** Read memo dependency edges in parent-to-child direction. */\n297: export function readDependencyChildren(\n298:   database: Database.Database,\n299:   parentPaths: readonly string[],\n300: ): DirectedTraversalEdge<string>[] {\n301:   const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n302:   const edges: DirectedTraversalEdge<string>[] = [];\n303:   if (parents.length === 0) {\n304:     return edges;\n305:   }\n306: \n307:   for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n308:     const chunkPlaceholders = placeholders(parentChunk.length);\n309:     const rows = database.prepare(`\n310:       SELECT parent_path, child_path\n311:       FROM dependency_edges\n312:       WHERE parent_path IN (${chunkPlaceholders})\n313:     `).all(...parentChunk) as DependencyEdgeRow[];\n314: \n315:     for (const row of rows) {\n316:       edges.push({ from: row.parent_path, to: row.child_path });\n317:     }\n318:   }\n319: \n320:   return edges;\n321: }\n322: \n323: /** Traverse memo dependency edges from parent paths to all transitive children. */\n324: export function collectDependencyReachability(\n325:   database: Database.Database,\n326:   roots: readonly string[],\n327: ): string[] {\n328:   return collectDirectedReachability({\n329:     roots,\n330:     readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n331:   });\n332: }\n\n(End of file - total 332 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: BFS Traversal\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype TraversalNode = number | string;\n\nconst SQLITE_BINDING_CHUNK_SIZE = 900;\n\n/** Edge returned by a weighted graph reader. */\nexport interface WeightedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n  readonly weight: number;\n  readonly strength?: number;\n}\n\n/** Aggregated weighted walk output for one reached node. */\nexport interface WeightedWalkResult<TNode extends TraversalNode> {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: BFS Traversal\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype TraversalNode = number | string;\n\nconst SQLITE_BINDING_CHUNK_SIZE = 900;\n\n/** Edge returned by a weighted graph reader. */\nexport interface WeightedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n  readonly weight: number;\n  readonly strength?: number;\n}\n\n/** Aggregated weighted walk output for one reached node. */\nexport interface WeightedWalkResult<TNode extends TraversalNode> {\n  readonly nodeId: TNode;\n  readonly minHop: number;\n  readonly maxWalkScore: number;\n}\n\n/** Options for hop-capped weighted graph traversal. */\nexport interface WeightedWalkOptions<TNode extends TraversalNode> {\n  readonly seeds: readonly TNode[];\n  readonly maxHops: number;\n  readonly readEdges: (nodeIds: readonly TNode[]) => readonly WeightedTraversalEdge<TNode>[];\n}\n\n/** Edge returned by a directed graph reader. */\nexport interface DirectedTraversalEdge<TNode extends TraversalNode> {\n  readonly from: TNode;\n  readonly to: TNode;\n}\n\n/** Options for directed reachability traversal. */\nexport interface DirectedReachabilityOptions<TNode extends TraversalNode> {\n  readonly roots: readonly TNode[];\n  readonly readEdges: (nodeIds: readonly TNode[]) => readonly DirectedTraversalEdge<TNode>[];\n}\n\ninterface WeightedWalkState<TNode extends TraversalNode> {\n  readonly origin: TNode;\n  readonly nodeId: TNode;\n  readonly hop: number;\n  readonly walkScore: number;\n}\n\ninterface CausalEdgeRow {\n  readonly source_id: string;\n  readonly target_id: string;\n  readonly relation: string;\n  readonly strength: number | null;\n}\n\ninterface DependencyEdgeRow {\n  readonly parent_path: string;\n  readonly child_path: string;\n}\n\nfunction uniqueNodes<TNode extends TraversalNode>(nodeIds: readonly TNode[]): TNode[] {\n  return Array.from(new Set(nodeIds));\n}\n\nfunction sameNode<TNode extends TraversalNode>(left: TNode, right: TNode): boolean {\n  return left === right;\n}\n\nfunction stateKey<TNode extends TraversalNode>(state: WeightedWalkState<TNode>): string {\n  return `${String(state.origin)}\\u0000${String(state.nodeId)}\\u0000${state.hop}\\u0000${state.walkScore}`;\n}\n\nfunction groupWeightedEdges<TNode extends TraversalNode>(\n  edges: readonly WeightedTraversalEdge<TNode>[],\n): Map<TNode, WeightedTraversalEdge<TNode>[]> {\n  const grouped = new Map<TNode, WeightedTraversalEdge<TNode>[]>();\n  for (const edge of edges) {\n    const group = grouped.get(edge.from) ?? [];\n    group.push(edge);\n    grouped.set(edge.from, group);\n  }\n  return grouped;\n}\n\nfunction placeholders(count: number): string {\n  return Array.from({ length: count }, () => '?').join(', ');\n}\n\nfunction chunks<T>(items: readonly T[], size: number): T[][] {\n  const result: T[][] = [];\n  for (let index = 0; index < items.length; index += size) {\n    result.push(items.slice(index, index + size));\n  }\n  return result;\n}\n\nfunction relationWeight(relation: string, relationWeights: Readonly<Record<string, number>>): number {\n  const multiplier = relationWeights[relation] ?? 1.0;\n  return Number.isFinite(multiplier) ? multiplier : 1.0;\n}\n\nfunction edgeStrength(value: number | null): number {\n  return typeof value === 'number' && Number.isFinite(value) ? value : 1.0;\n}\n\nfunction nextWalkScore<TNode extends TraversalNode>(\n  state: WeightedWalkState<TNode>,\n  edge: WeightedTraversalEdge<TNode>,\n): number {\n  const weighted = state.walkScore * edge.weight;\n  return edge.strength === undefined ? weighted : weighted * edge.strength;\n}\n\n/**\n * Run a hop-capped weighted walk and aggregate by reached node.\n * The aggregation intentionally keeps min hop and max score independent.\n */\nexport function collectWeightedWalk<TNode extends TraversalNode>(\n  options: WeightedWalkOptions<TNode>,\n): Map<TNode, WeightedWalkResult<TNode>> {\n  const maxHops = Math.max(0, Math.trunc(options.maxHops));\n  const seeds = uniqueNodes(options.seeds);\n  const seedSet = new Set(seeds);\n  const results = new Map<TNode, WeightedWalkResult<TNode>>();\n  if (seeds.length === 0 || maxHops === 0) {\n    return results;\n  }\n\n  let frontier: WeightedWalkState<TNode>[] = seeds.map((seed) => ({\n    origin: seed,\n    nodeId: seed,\n    hop: 0,\n    walkScore: 1.0,\n  }));\n  const seenStates = new Set<string>();\n\n  while (frontier.length > 0) {\n    const expandable = frontier.filter((state) => state.hop < maxHops);\n    if (expandable.length === 0) break;\n\n    const nodeIds = uniqueNodes(expandable.map((state) => state.nodeId));\n    const edgesByFrom = groupWeightedEdges(options.readEdges(nodeIds));\n    const nextFrontier: WeightedWalkState<TNode>[] = [];\n\n    for (const state of expandable) {\n      const edges = edgesByFrom.get(state.nodeId) ?? [];\n      for (const edge of edges) {\n        if (state.hop > 0 && sameNode(edge.to, state.origin)) {\n          continue;\n        }\n\n        const nextState: WeightedWalkState<TNode> = {\n          origin: state.origin,\n          nodeId: edge.to,\n          hop: state.hop + 1,\n          walkScore: nextWalkScore(state, edge),\n        };\n        const key = stateKey(nextState);\n        if (seenStates.has(key)) {\n          continue;\n        }\n        seenStates.add(key);\n        nextFrontier.push(nextState);\n\n        if (seedSet.has(nextState.nodeId)) {\n          continue;\n        }\n\n        const current = results.get(nextState.nodeId);\n        if (!current) {\n          results.set(nextState.nodeId, {\n            nodeId: nextState.nodeId,\n            minHop: nextState.hop,\n            maxWalkScore: nextState.walkScore,\n          });\n        } else {\n          results.set(nextState.nodeId, {\n            nodeId: nextState.nodeId,\n            minHop: Math.min(current.minHop, nextState.hop),\n            maxWalkScore: Math.max(current.maxWalkScore, nextState.walkScore),\n          });\n        }\n      }\n    }\n\n    frontier = nextFrontier;\n  }\n\n  return results;\n}\n\n/** Collect all nodes reachable from the given roots through directed edges. */\nexport function collectDirectedReachability<TNode extends TraversalNode>(\n  options: DirectedReachabilityOptions<TNode>,\n): TNode[] {\n  const roots = uniqueNodes(options.roots);\n  if (roots.length === 0) {\n    return [];\n  }\n\n  const rootSet = new Set(roots);\n  const visited = new Set<TNode>();\n  const reached: TNode[] = [];\n  let frontier = roots;\n\n  while (frontier.length > 0) {\n    const nextFrontier: TNode[] = [];\n    const edges = options.readEdges(frontier);\n\n    for (const edge of edges) {\n      if (visited.has(edge.to)) {\n        continue;\n      }\n      visited.add(edge.to);\n      if (!rootSet.has(edge.to)) {\n        reached.push(edge.to);\n      }\n      nextFrontier.push(edge.to);\n    }\n\n    frontier = uniqueNodes(nextFrontier);\n  }\n\n  return reached;\n}\n\n/** Read causal edges as an undirected, weighted adjacency view without OR joins. */\nexport function readCausalNeighborEdges(\n  database: Database.Database,\n  nodeIds: readonly number[],\n  relationWeights: Readonly<Record<string, number>>,\n): WeightedTraversalEdge<number>[] {\n  const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n  const edges: WeightedTraversalEdge<number>[] = [];\n  if (nodes.length === 0) {\n    return edges;\n  }\n\n  for (const nodeChunk of chunks(nodes.map((nodeId) => String(nodeId)), SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(nodeChunk.length);\n    const outgoingRows = database.prepare(`\n      SELECT source_id, target_id, relation, strength\n      FROM causal_edges\n      WHERE source_id IN (${chunkPlaceholders})\n    `).all(...nodeChunk) as CausalEdgeRow[];\n    const incomingRows = database.prepare(`\n      SELECT source_id, target_id, relation, strength\n      FROM causal_edges\n      WHERE target_id IN (${chunkPlaceholders})\n    `).all(...nodeChunk) as CausalEdgeRow[];\n\n    for (const row of outgoingRows) {\n      const from = Number.parseInt(row.source_id, 10);\n      const to = Number.parseInt(row.target_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n    for (const row of incomingRows) {\n      const from = Number.parseInt(row.target_id, 10);\n      const to = Number.parseInt(row.source_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse causal edges with the production weighted-walk reader. */\nexport function collectCausalWeightedNeighbors(\n  database: Database.Database,\n  seeds: readonly number[],\n  maxHops: number,\n  relationWeights: Readonly<Record<string, number>>,\n): Map<number, WeightedWalkResult<number>> {\n  return collectWeightedWalk({\n    seeds,\n    maxHops,\n    readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n  });\n}\n\n/** Read memo dependency edges in parent-to-child direction. */\nexport function readDependencyChildren(\n  database: Database.Database,\n  parentPaths: readonly string[],\n): DirectedTraversalEdge<string>[] {\n  const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n  const edges: DirectedTraversalEdge<string>[] = [];\n  if (parents.length === 0) {\n    return edges;\n  }\n\n  for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(parentChunk.length);\n    const rows = database.prepare(`\n      SELECT parent_path, child_path\n      FROM dependency_edges\n      WHERE parent_path IN (${chunkPlaceholders})\n    `).all(...parentChunk) as DependencyEdgeRow[];\n\n    for (const row of rows) {\n      edges.push({ from: row.parent_path, to: row.child_path });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse memo dependency edges from parent paths to all transitive children. */\nexport function collectDependencyReachability(\n  database: Database.Database,\n  roots: readonly string[],\n): string[] {\n  return collectDirectedReachability({\n    roots,\n    readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n  });\n}","lineStart":1,"lineEnd":332,"totalLines":332,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","time":{"start":1781144242043,"end":1781144242059}},"metadata":{"openai":{"itemId":"fc_0c16151930509033016a2a1ab1f37c81918463c4b4cd9ea609"}},"id":"prt_eb47847390016mc3mZNGHlGfzM","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477fee8001w4gZqiXMJ1Rd3D"}}
{"type":"tool_use","timestamp":1781144242060,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_g69HdUsdn7wt84cVgVc055Is","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Mutations\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL mutation functions:\n6: // Index, update, delete, and status/confidence updates.\n7: \n8: import * as embeddingsProvider from '../providers/embeddings.js';\n9: import {\n10:   buildGovernanceLogicalKey,\n11:   normalizeScopeValue,\n12:   recordTierDowngradeAudit,\n13: } from '../governance/scope-governance.js';\n14: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n15: import { recordHistory } from '../storage/history.js';\n16: import { buildMemoryLogicalKey } from '../storage/lineage-state.js';\n17: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n18: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n19: import { createLogger } from '../utils/logger.js';\n20: import { deleteByContentHash } from '../cache/embedding-cache.js';\n21: import { clearDegreeCacheForDb } from './graph-search-fn.js';\n22: import { sweepCausalEdges } from '../causal/sweep.js';\n23: import * as bm25Index from './bm25-index.js';\n24: import {\n25:   clear_search_cache,\n26: } from './vector-index-aliases.js';\n27: import { invalidateEntityDensityCache } from './entity-density.js';\n28: import {\n29:   get_error_message,\n30:   to_embedding_buffer,\n31:   VectorIndexError,\n32:   VectorIndexErrorCode,\n33: } from './vector-index-types.js';\n34: import {\n35:   clear_constitutional_cache,\n36:   get_embedding_dim,\n37:   initialize_db,\n38:   init_prepared_statements,\n39:   refresh_interference_scores_for_folder,\n40:   sqlite_vec_available as get_sqlite_vec_available,\n41:   activeVectorSource,\n42: } from './vector-index-store.js';\n43: import type {\n44:   IndexMemoryParams as SharedIndexMemoryParams,\n45:   MemoryScopeParams,\n46:   UpdateMemoryParams as SharedUpdateMemoryParams,\n47: } from './vector-index-types.js';\n48: import type Database from 'better-sqlite3';\n49: \n50: const logger = createLogger('VectorIndex');\n51: \n52: function isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n53:   const message = get_error_message(error).toLowerCase();\n54:   return message.includes('no such table') && message.includes('vec_memories');\n55: }\n56: \n57: function invalidateGraphCaches(database: Database.Database): void {\n58:   try {\n59:     clearDegreeCacheForDb(database);\n60:   } catch (_error: unknown) {\n61:     // Degree cache invalidation is best-effort for legacy mutation paths.\n62:   }\n63: \n64:   try {\n65:     clearGraphSignalsCache();\n66:   } catch (_error: unknown) {\n67:     // Graph signal cache invalidation is best-effort for legacy mutation paths.\n68:   }\n69: }\n70: \n71: function tryRecordTierDowngradeAudit(\n72:   database: Database.Database,\n73:   params: {\n74:     memoryId: number;\n75:     specFolder: string | null | undefined;\n76:     anchorId: string | null | undefined;\n77:     filePath: string | null | undefined;\n78:     canonicalFilePath: string | null | undefined;\n79:     requestedTier?: string | null | undefined;\n80:     previousTier?: string | null | undefined;\n81:     nextTier: string;\n82:     source: string;\n83:   },\n84: ): void {\n85:   try {\n86:     recordTierDowngradeAudit(database, {\n87:       memoryId: params.memoryId,\n88:       logicalKey: buildGovernanceLogicalKey(\n89:         params.specFolder,\n90:         params.canonicalFilePath || params.filePath,\n91:         params.anchorId,\n92:       ),\n93:       requestedTier: params.requestedTier ?? undefined,\n94:       previousTier: params.previousTier ?? undefined,\n95:       nextTier: params.nextTier,\n96:       source: params.source,\n97:       filePath: params.filePath ?? null,\n98:       canonicalFilePath: params.canonicalFilePath ?? null,\n99:     });\n100:   } catch (error: unknown) {\n101:     logger.warn('Failed to record governance audit for tier downgrade', {\n102:       memoryId: params.memoryId,\n103:       source: params.source,\n104:       message: get_error_message(error),\n105:     });\n106:   }\n107: }\n108: \n109: function deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n110:   const ancillaryTables = [\n111:     'DELETE FROM degree_snapshots WHERE memory_id = ?',\n112:     'DELETE FROM community_assignments WHERE memory_id = ?',\n113:     'DELETE FROM memory_summaries WHERE memory_id = ?',\n114:     'DELETE FROM memory_entities WHERE memory_id = ?',\n115:     'DELETE FROM memory_lineage WHERE memory_id = ?',\n116:   ];\n117: \n118:   for (const sql of ancillaryTables) {\n119:     try {\n120:       const paramCount = (sql.match(/\\?/g) || []).length;\n121:       if (paramCount === 2) {\n122:         database.prepare(sql).run(id, id);\n123:       } else {\n124:         database.prepare(sql).run(id);\n125:       }\n126:     } catch (_error: unknown) {\n127:       // Best-effort for legacy databases that may not have these tables yet.\n128:     }\n129:   }\n130: \n131:   // B10: Clean active_memory_projection rows referencing this memory.\n132:   try {\n133:     database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n134:   } catch (_error: unknown) {\n135:     // Best-effort for legacy databases that may not have projection tables yet.\n136:   }\n137: \n138:   try {\n139:     const result = sweepCausalEdges(database, {\n140:       memoryIds: [id, String(id)],\n141:       reason: 'memory row mutation cleanup',\n142:       command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n143:       restoreContext: { memoryId: id },\n144:       invalidateCaches: false,\n145:     });\n146:     if (result.deleted > 0) {\n147:       invalidateGraphCaches(database);\n148:     }\n149:   } catch (_error: unknown) {\n150:     // Best-effort for legacy databases that may not have causal edges yet.\n151:   }\n152: }\n153: \n154: function upsert_active_projection(\n155:   database: ReturnType<typeof initialize_db>,\n156:   specFolder: string,\n157:   canonicalFilePath: string,\n158:   anchorId: string | null,\n159:   memoryId: number,\n160:   updatedAt: string,\n161:   scope: NormalizedMemoryScope,\n162: ): void {\n163:   const logicalKey = buildMemoryLogicalKey({\n164:     specFolder,\n165:     filePath: canonicalFilePath,\n166:     canonicalFilePath,\n167:     anchorId,\n168:     ...scope,\n169:   });\n170:   // Evict any stale projection row that maps a *different* logical_key to the\n171:   // same active_memory_id — prevents UNIQUE constraint violation on re-index\n172:   // when the logical_key changes (e.g. anchor or path normalization drift).\n173:   database.prepare(\n174:     'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n175:   ).run(memoryId, logicalKey);\n176:   database.prepare(`\n177:     INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n178:     VALUES (?, ?, ?, ?)\n179:     ON CONFLICT(logical_key) DO UPDATE SET\n180:       root_memory_id = excluded.root_memory_id,\n181:       active_memory_id = excluded.active_memory_id,\n182:       updated_at = excluded.updated_at\n183:   `).run(logicalKey, memoryId, memoryId, updatedAt);\n184: }\n185: \n186: // These mutation-local extensions are intentional until the shared query/store\n187: // contract adopts appendOnly and canonicalFilePath semantics.\n188: type IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n189:   readonly appendOnly?: boolean;\n190: };\n191: type IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n192:   readonly failureReason?: string | null;\n193: };\n194: type UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n195:   readonly canonicalFilePath?: string;\n196: };\n197: \n198: type NormalizedMemoryScope = {\n199:   tenant_id: string | null;\n200:   user_id: string | null;\n201:   agent_id: string | null;\n202:   session_id: string | null;\n203: };\n204: \n205: function normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n206:   return {\n207:     tenant_id: normalizeScopeValue(scope?.tenantId),\n208:     user_id: normalizeScopeValue(scope?.userId),\n209:     agent_id: normalizeScopeValue(scope?.agentId),\n210:     session_id: normalizeScopeValue(scope?.sessionId),\n211:   };\n212: }\n213: \n214: /**\n215:  * Indexes a memory with an embedding payload.\n216:  * @param params - The memory values to index.\n217:  * @returns The indexed memory identifier.\n218:  * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n219:  * @example\n220:  * ```ts\n221:  * const id = index_memory({\n222:  *   specFolder: 'specs/001-demo',\n223:  *   filePath: 'spec.md',\n224:  *   embedding,\n225:  * });\n226:  * ```\n227:  */\n228: export function index_memory(\n229:   params: IndexMemoryParams,\n230:   database: Database.Database = initialize_db(),\n231: ): number {\n232:   const {\n233:     specFolder,\n234:     filePath,\n235:     parentId = null,\n236:     anchorId = null,\n237:     title = null,\n238:     triggerPhrases = [],\n239:     importanceWeight = 0.5,\n240:     embedding,\n241:     encodingIntent,\n242:     documentType = 'memory',\n243:     specLevel = null,\n244:     contentText = null,\n245:     qualityScore = 0,\n246:     qualityFlags = [],\n247:     appendOnly = false,\n248:   } = params;\n249:   const scope = normalizeMemoryScope(params.scope);\n250: \n251:   if (!embedding) {\n252:     throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n253:   }\n254: \n255:   const expected_dim = get_embedding_dim();\n256:   if (embedding.length !== expected_dim) {\n257:     console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n258:     throw new VectorIndexError(\n259:       `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n260:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n261:     );\n262:   }\n263: \n264:   const now = new Date().toISOString();\n265:   const triggers_json = JSON.stringify(triggerPhrases);\n266:   const embedding_buffer = to_embedding_buffer(embedding);\n267:   const canonicalFilePath = getCanonicalPathKey(filePath);\n268: \n269:   const stmts = init_prepared_statements(database);\n270:   const existing = appendOnly\n271:     ? null\n272:     : stmts.get_by_folder_and_path.get(\n273:         specFolder,\n274:         canonicalFilePath,\n275:         filePath,\n276:         anchorId,\n277:         scope.tenant_id,\n278:         scope.user_id,\n279:         scope.agent_id,\n280:         scope.session_id,\n281:       );\n282: \n283:   if (existing && !appendOnly) {\n284:     return update_memory({\n285:       id: existing.id,\n286:       title: title ?? undefined,\n287:       triggerPhrases,\n288:       importanceWeight,\n289:       embedding,\n290:       encodingIntent,\n291:       documentType,\n292:       specLevel,\n293:       contentText,\n294:       qualityScore,\n295:       qualityFlags,\n296:       canonicalFilePath,\n297:     }, database);\n298:   }\n299: \n300:   const sqlite_vec = get_sqlite_vec_available();\n\n(Showing lines 1-300 of 957. Use offset=301 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Mutations\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Mutations\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';\nimport { clearDegreeCacheForDb } from './graph-search-fn.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport * as bm25Index from './bm25-index.js';\nimport {\n  clear_search_cache,\n} from './vector-index-aliases.js';\nimport { invalidateEntityDensityCache } from './entity-density.js';\nimport {\n  get_error_message,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  clear_constitutional_cache,\n  get_embedding_dim,\n  initialize_db,\n  init_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource,\n} from './vector-index-store.js';\nimport type {\n  IndexMemoryParams as SharedIndexMemoryParams,\n  MemoryScopeParams,\n  UpdateMemoryParams as SharedUpdateMemoryParams,\n} from './vector-index-types.js';\nimport type Database from 'better-sqlite3';\n\nconst logger = createLogger('VectorIndex');\n\nfunction isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n  const message = get_error_message(error).toLowerCase();\n  return message.includes('no such table') && message.includes('vec_memories');\n}\n\nfunction invalidateGraphCaches(database: Database.Database): void {\n  try {\n    clearDegreeCacheForDb(database);\n  } catch (_error: unknown) {\n    // Degree cache invalidation is best-effort for legacy mutation paths.\n  }\n\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signal cache invalidation is best-effort for legacy mutation paths.\n  }\n}\n\nfunction tryRecordTierDowngradeAudit(\n  database: Database.Database,\n  params: {\n    memoryId: number;\n    specFolder: string | null | undefined;\n    anchorId: string | null | undefined;\n    filePath: string | null | undefined;\n    canonicalFilePath: string | null | undefined;\n    requestedTier?: string | null | undefined;\n    previousTier?: string | null | undefined;\n    nextTier: string;\n    source: string;\n  },\n): void {\n  try {\n    recordTierDowngradeAudit(database, {\n      memoryId: params.memoryId,\n      logicalKey: buildGovernanceLogicalKey(\n        params.specFolder,\n        params.canonicalFilePath || params.filePath,\n        params.anchorId,\n      ),\n      requestedTier: params.requestedTier ?? undefined,\n      previousTier: params.previousTier ?? undefined,\n      nextTier: params.nextTier,\n      source: params.source,\n      filePath: params.filePath ?? null,\n      canonicalFilePath: params.canonicalFilePath ?? null,\n    });\n  } catch (error: unknown) {\n    logger.warn('Failed to record governance audit for tier downgrade', {\n      memoryId: params.memoryId,\n      source: params.source,\n      message: get_error_message(error),\n    });\n  }\n}\n\nfunction deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n  const ancillaryTables = [\n    'DELETE FROM degree_snapshots WHERE memory_id = ?',\n    'DELETE FROM community_assignments WHERE memory_id = ?',\n    'DELETE FROM memory_summaries WHERE memory_id = ?',\n    'DELETE FROM memory_entities WHERE memory_id = ?',\n    'DELETE FROM memory_lineage WHERE memory_id = ?',\n  ];\n\n  for (const sql of ancillaryTables) {\n    try {\n      const paramCount = (sql.match(/\\?/g) || []).length;\n      if (paramCount === 2) {\n        database.prepare(sql).run(id, id);\n      } else {\n        database.prepare(sql).run(id);\n      }\n    } catch (_error: unknown) {\n      // Best-effort for legacy databases that may not have these tables yet.\n    }\n  }\n\n  // B10: Clean active_memory_projection rows referencing this memory.\n  try {\n    database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n  } catch (_error: unknown) {\n    // Best-effort for legacy databases that may not have projection tables yet.\n  }\n\n  try {\n    const result = sweepCausalEdges(database, {\n      memoryIds: [id, String(id)],\n      reason: 'memory row mutation cleanup',\n      command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n      restoreContext: { memoryId: id },\n      invalidateCaches: false,\n    });\n    if (result.deleted > 0) {\n      invalidateGraphCaches(database);\n    }\n  } catch (_error: unknown) {\n    // Best-effort for legacy databases that may not have causal edges yet.\n  }\n}\n\nfunction upsert_active_projection(\n  database: ReturnType<typeof initialize_db>,\n  specFolder: string,\n  canonicalFilePath: string,\n  anchorId: string | null,\n  memoryId: number,\n  updatedAt: string,\n  scope: NormalizedMemoryScope,\n): void {\n  const logicalKey = buildMemoryLogicalKey({\n    specFolder,\n    filePath: canonicalFilePath,\n    canonicalFilePath,\n    anchorId,\n    ...scope,\n  });\n  // Evict any stale projection row that maps a *different* logical_key to the\n  // same active_memory_id — prevents UNIQUE constraint violation on re-index\n  // when the logical_key changes (e.g. anchor or path normalization drift).\n  database.prepare(\n    'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n  ).run(memoryId, logicalKey);\n  database.prepare(`\n    INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n    VALUES (?, ?, ?, ?)\n    ON CONFLICT(logical_key) DO UPDATE SET\n      root_memory_id = excluded.root_memory_id,\n      active_memory_id = excluded.active_memory_id,\n      updated_at = excluded.updated_at\n  `).run(logicalKey, memoryId, memoryId, updatedAt);\n}\n\n// These mutation-local extensions are intentional until the shared query/store\n// contract adopts appendOnly and canonicalFilePath semantics.\ntype IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n  readonly appendOnly?: boolean;\n};\ntype IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n  readonly failureReason?: string | null;\n};\ntype UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n  readonly canonicalFilePath?: string;\n};\n\ntype NormalizedMemoryScope = {\n  tenant_id: string | null;\n  user_id: string | null;\n  agent_id: string | null;\n  session_id: string | null;\n};\n\nfunction normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n  return {\n    tenant_id: normalizeScopeValue(scope?.tenantId),\n    user_id: normalizeScopeValue(scope?.userId),\n    agent_id: normalizeScopeValue(scope?.agentId),\n    session_id: normalizeScopeValue(scope?.sessionId),\n  };\n}\n\n/**\n * Indexes a memory with an embedding payload.\n * @param params - The memory values to index.\n * @returns The indexed memory identifier.\n * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n * @example\n * ```ts\n * const id = index_memory({\n *   specFolder: 'specs/001-demo',\n *   filePath: 'spec.md',\n *   embedding,\n * });\n * ```\n */\nexport function index_memory(\n  params: IndexMemoryParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    specFolder,\n    filePath,\n    parentId = null,\n    anchorId = null,\n    title = null,\n    triggerPhrases = [],\n    importanceWeight = 0.5,\n    embedding,\n    encodingIntent,\n    documentType = 'memory',\n    specLevel = null,\n    contentText = null,\n    qualityScore = 0,\n    qualityFlags = [],\n    appendOnly = false,\n  } = params;\n  const scope = normalizeMemoryScope(params.scope);\n\n  if (!embedding) {\n    throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n  }\n\n  const expected_dim = get_embedding_dim();\n  if (embedding.length !== expected_dim) {\n    console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n    throw new VectorIndexError(\n      `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const now = new Date().toISOString();\n  const triggers_json = JSON.stringify(triggerPhrases);\n  const embedding_buffer = to_embedding_buffer(embedding);\n  const canonicalFilePath = getCanonicalPathKey(filePath);\n\n  const stmts = init_prepared_statements(database);\n  const existing = appendOnly\n    ? null\n    : stmts.get_by_folder_and_path.get(\n        specFolder,\n        canonicalFilePath,\n        filePath,\n        anchorId,\n        scope.tenant_id,\n        scope.user_id,\n        scope.agent_id,\n        scope.session_id,\n      );\n\n  if (existing && !appendOnly) {\n    return update_memory({\n      id: existing.id,\n      title: title ?? undefined,\n      triggerPhrases,\n      importanceWeight,\n      embedding,\n      encodingIntent,\n      documentType,\n      specLevel,\n      contentText,\n      qualityScore,\n      qualityFlags,\n      canonicalFilePath,\n    }, database);\n  }\n\n  const sqlite_vec = get_sqlite_vec_available();","lineStart":1,"lineEnd":300,"totalLines":957,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","time":{"start":1781144242051,"end":1781144242060}},"metadata":{"openai":{"itemId":"fc_0c16151930509033016a2a1ab1f3948191b05f5c8b8afc1e26"}},"id":"prt_eb4784781001opxX9ZfkuFsaw0","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477fee8001w4gZqiXMJ1Rd3D"}}
{"type":"tool_use","timestamp":1781144242146,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_prfIaKicpU6tZixl6m0sMOOU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Queries\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL query/search functions,\n6: // Content extraction, ranking, stats, cleanup, and integrity checks.\n7: \n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: import type Database from 'better-sqlite3';\n11: import { formatAgeString as format_age_string } from '../utils/format-helpers.js';\n12: import { createLogger } from '../utils/logger.js';\n13: import { recordHistory } from '../storage/history.js';\n14: import * as embeddingsProvider from '../providers/embeddings.js';\n15: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\n16: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n17: import { getEmbedderAdapter } from '../embedders/execution-router.js';\n18: import { getManifest } from '../embedders/registry.js';\n19: import {\n20:   computeContentHash,\n21:   getActiveEmbeddingProfileKey,\n22:   lookupEmbedding,\n23:   storeEmbedding,\n24: } from '../cache/embedding-cache.js';\n25: import {\n26:   get_error_message,\n27:   parse_trigger_phrases,\n28:   to_embedding_buffer,\n29:   VectorIndexError,\n30:   VectorIndexErrorCode,\n31: } from './vector-index-types.js';\n32: import {\n33:   initialize_db,\n34:   get_embedding_dim,\n35:   get_constitutional_memories,\n36:   init_prepared_statements,\n37:   validate_file_path_local,\n38:   safe_read_file_async,\n39:   safe_parse_json,\n40:   search_weights,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource as activeVectorSchema,\n43: } from './vector-index-store.js';\n44: import { delete_memory_from_database } from './vector-index-mutations.js';\n45: import type {\n46:   EmbeddingInput,\n47:   EnrichedSearchResult,\n48:   MemoryRow,\n49:   VectorSearchOptions,\n50: } from './vector-index-types.js';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: type RelatedMemoryLink = { id: number; similarity: number };\n55: type UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\n56: type CleanupOptions = {\n57:   maxAgeDays?: number;\n58:   maxAccessCount?: number;\n59:   maxConfidence?: number;\n60:   limit?: number;\n61: };\n62: type VectorSource = {\n63:   dim: number;\n64:   tableName: string;\n65:   idColumn: string;\n66:   embeddingColumn: string;\n67: };\n68: \n69: export interface KnnQueryShapeBenchmarkResult {\n70:   readonly corpusSize: number;\n71:   readonly iterations: number;\n72:   readonly scalarJoinAverageMs: number;\n73:   readonly matchAverageMs: number | null;\n74:   readonly matchSupported: boolean;\n75:   readonly matchImprovementPct: number | null;\n76:   readonly decision: 'adopt_match' | 'keep_scalar_join';\n77:   readonly reason: string;\n78: }\n79: \n80: const KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n81: \n82: function appendSpecFolderScope(\n83:   clauses: string[],\n84:   params: unknown[],\n85:   specFolder: string | null | undefined,\n86:   column = 'm.spec_folder',\n87: ): void {\n88:   if (!specFolder) return;\n89:   clauses.push(`(${column} = ? OR ${column} LIKE ?)`);\n90:   params.push(specFolder, `${specFolder}/%`);\n91: }\n92: \n93: function tableExists(database: Database.Database, tableName: string): boolean {\n94:   const row = database.prepare(`\n95:     SELECT 1 AS found\n96:     FROM active_vec.sqlite_master\n97:     WHERE type = 'table' AND name = ?\n98:     LIMIT 1\n99:   `).get(tableName) as { found?: number } | undefined;\n100:   return row?.found === 1;\n101: }\n102: \n103: function getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n104:   const active = getActiveEmbedder(database);\n105:   const dimTableName = `vec_${active.dim}`;\n106:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n107:     return {\n108:       dim: active.dim,\n109:       tableName: activeVectorSchema(dimTableName),\n110:       idColumn: 'id',\n111:       embeddingColumn: 'vec',\n112:     };\n113:   }\n114: \n115:   return {\n116:     dim: get_embedding_dim(),\n117:     tableName: activeVectorSchema('vec_memories'),\n118:     idColumn: 'rowid',\n119:     embeddingColumn: 'embedding',\n120:   };\n121: }\n122: \n123: function elapsedMs(start: bigint): number {\n124:   return Number(process.hrtime.bigint() - start) / 1_000_000;\n125: }\n126: \n127: function average(values: number[]): number {\n128:   if (values.length === 0) return 0;\n129:   return values.reduce((sum, value) => sum + value, 0) / values.length;\n130: }\n131: \n132: export function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n133:   return result.matchSupported === true\n134:     && typeof result.matchImprovementPct === 'number'\n135:     && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n136: }\n137: \n138: export function benchmarkKnnQueryShapes(\n139:   query_embedding: EmbeddingInput,\n140:   options: { iterations?: number; limit?: number } = {},\n141:   database: Database.Database = initialize_db(),\n142: ): KnnQueryShapeBenchmarkResult {\n143:   const vectorSource = getActiveVectorSourceForQuery(database);\n144:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n145:     throw new VectorIndexError(\n146:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n147:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n148:     );\n149:   }\n150: \n151:   const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n152:   const limit = Math.max(1, Math.floor(options.limit ?? 20));\n153:   const queryBuffer = to_embedding_buffer(query_embedding);\n154:   const corpusSize = (database.prepare(`\n155:     SELECT COUNT(*) AS count\n156:     FROM memory_index m\n157:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n158:     WHERE m.embedding_status = 'success'\n159:   `).get() as { count: number }).count;\n160: \n161:   const scalarSql = `\n162:     SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n163:     FROM memory_index m\n164:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n165:     JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n166:     WHERE m.embedding_status = 'success'\n167:     ORDER BY distance ASC\n168:     LIMIT ?\n169:   `;\n170:   const scalarStmt = database.prepare(scalarSql);\n171:   scalarStmt.all(queryBuffer, limit);\n172:   const scalarRuns: number[] = [];\n173:   for (let i = 0; i < iterations; i += 1) {\n174:     const start = process.hrtime.bigint();\n175:     scalarStmt.all(queryBuffer, limit);\n176:     scalarRuns.push(elapsedMs(start));\n177:   }\n178: \n179:   const matchTable = activeVectorSchema('vec_memories');\n180:   const matchAvailable = tableExists(database, 'vec_memories');\n181:   let matchAverageMs: number | null = null;\n182:   let matchError: string | null = null;\n183: \n184:   if (matchAvailable) {\n185:     try {\n186:       const matchSql = `\n187:         WITH knn AS (\n188:           SELECT rowid, distance\n189:           FROM ${matchTable}\n190:           WHERE embedding MATCH ? AND k = ?\n191:         )\n192:         SELECT m.id, knn.distance\n193:         FROM knn\n194:         JOIN memory_index m ON m.id = knn.rowid\n195:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n196:         WHERE m.embedding_status = 'success'\n197:         ORDER BY knn.distance ASC\n198:         LIMIT ?\n199:       `;\n200:       const matchStmt = database.prepare(matchSql);\n201:       matchStmt.all(queryBuffer, limit, limit);\n202:       const matchRuns: number[] = [];\n203:       for (let i = 0; i < iterations; i += 1) {\n204:         const start = process.hrtime.bigint();\n205:         matchStmt.all(queryBuffer, limit, limit);\n206:         matchRuns.push(elapsedMs(start));\n207:       }\n208:       matchAverageMs = average(matchRuns);\n209:     } catch (error: unknown) {\n210:       matchError = get_error_message(error);\n211:     }\n212:   }\n213: \n214:   const scalarJoinAverageMs = average(scalarRuns);\n215:   const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n216:     ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n217:     : null;\n218:   const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n219:     matchSupported: matchAverageMs !== null,\n220:     matchImprovementPct,\n221:   };\n222:   const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n223: \n224:   return {\n225:     corpusSize,\n226:     iterations,\n227:     scalarJoinAverageMs,\n228:     matchAverageMs,\n229:     matchSupported: matchAverageMs !== null,\n230:     matchImprovementPct,\n231:     decision,\n232:     reason: decision === 'adopt_match'\n233:       ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n234:       : matchError\n235:         ? `MATCH unavailable: ${matchError}`\n236:         : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n237:   };\n238: }\n239: \n240: /* ───────────────────────────────────────────────────────────────\n241:    SIMPLE QUERIES\n242: ----------------------------------------------------------------*/\n243: \n244: /**\n245:  * Gets one indexed memory by identifier.\n246:  * @param id - The memory identifier.\n247:  * @returns The matching memory row, if found.\n248:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n249:  * @example\n250:  * ```ts\n251:  * const memory = get_memory(42);\n252:  * ```\n253:  */\n254: export function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n255:   const stmts = init_prepared_statements(database);\n256:   const row = stmts.get_by_id.get(id);\n257: \n258:   if (row) {\n259:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n260:     row.isConstitutional = row.importance_tier === 'constitutional';\n261:   }\n262: \n263:   return row || null;\n264: }\n265: \n266: /**\n267:  * Gets indexed memories for a spec folder.\n268:  * @param spec_folder - The spec folder to query.\n269:  * @returns The memory rows for the folder.\n270:  */\n271: export function get_memories_by_folder(\n272:   spec_folder: string,\n273:   database: Database.Database = initialize_db(),\n274: ): MemoryRow[] {\n275:   const rows = database.prepare(`\n276:     SELECT m.*\n277:     FROM memory_index m\n278:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n279:     WHERE (m.spec_folder = ? OR m.spec_folder LIKE ?)\n280:     ORDER BY m.created_at DESC\n281:   `).all(spec_folder, `${spec_folder}/%`) as MemoryRow[];\n282: \n283:   return rows.map((row: MemoryRow) => {\n284:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n285:     row.isConstitutional = row.importance_tier === 'constitutional';\n286:     return row;\n287:   });\n288: }\n289: \n290: /**\n291:  * Gets the total number of indexed memories.\n292:  * @returns The total memory count.\n293:  */\n294: export function get_memory_count(database: Database.Database = initialize_db()): number {\n295:   const stmts = init_prepared_statements(database);\n296:   const result = stmts.count_all.get();\n297:   return result?.count ?? 0;\n298: }\n299: \n300: /**\n301:  * Gets memory counts grouped by embedding status.\n302:  * @returns The counts for each embedding status.\n303:  */\n304: export function get_status_counts(\n305:   database: Database.Database = initialize_db(),\n306: ): { pending: number; success: number; failed: number; retry: number; partial: number } {\n307:   const rows = database.prepare(`\n308:     SELECT m.embedding_status, COUNT(*) as count\n309:     FROM memory_index m\n310:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n311:     GROUP BY m.embedding_status\n312:   `).all();\n313: \n314:   // Include 'partial' status in counts.\n315:   const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n316:   for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n317:     if (row.embedding_status in counts) {\n318:       counts[row.embedding_status] = row.count;\n319:     }\n320:   }\n321: \n322:   return counts;\n323: }\n324: \n325: /**\n326:  * Gets summary counts for indexed memories.\n327:  * @returns The aggregate memory statistics.\n328:  */\n329: export function get_stats(\n330:   database: Database.Database = initialize_db(),\n331: ): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n332:   const counts = get_status_counts(database);\n333:   const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n334: \n335:   return {\n336:     total,\n337:     ...counts\n338:   };\n339: }\n340: \n341: /* ───────────────────────────────────────────────────────────────\n342:    VECTOR SEARCH\n343: ----------------------------------------------------------------*/\n344: \n345: /**\n346:  * Searches indexed memories by vector similarity.\n347:  * @param query_embedding - The query embedding to search with.\n348:  * @param options - Search options.\n349:  * @returns The matching memory rows.\n350:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n351:  * @example\n352:  * ```ts\n353:  * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n354:  * ```\n355:  */\n356: export function vector_search(\n357:   query_embedding: EmbeddingInput,\n358:   options: VectorSearchOptions = {},\n359:   database: Database.Database = initialize_db(),\n360: ): MemoryRow[] {\n\n(Showing lines 1-360 of 1706. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport {\n  get_error_message,\n  parse_trigger_phrases,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  initialize_db,\n  get_embedding_dim,\n  get_constitutional_memories,\n  init_prepared_statements,\n  validate_file_path_local,\n  safe_read_file_async,\n  safe_parse_json,\n  search_weights,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource as activeVectorSchema,\n} from './vector-index-store.js';\nimport { delete_memory_from_database } from './vector-index-mutations.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\nconst logger = createLogger('VectorIndex');\n\ntype RelatedMemoryLink = { id: number; similarity: number };\ntype UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\ntype CleanupOptions = {\n  maxAgeDays?: number;\n  maxAccessCount?: number;\n  maxConfidence?: number;\n  limit?: number;\n};\ntype VectorSource = {\n  dim: number;\n  tableName: string;\n  idColumn: string;\n  embeddingColumn: string;\n};\n\nexport interface KnnQueryShapeBenchmarkResult {\n  readonly corpusSize: number;\n  readonly iterations: number;\n  readonly scalarJoinAverageMs: number;\n  readonly matchAverageMs: number | null;\n  readonly matchSupported: boolean;\n  readonly matchImprovementPct: number | null;\n  readonly decision: 'adopt_match' | 'keep_scalar_join';\n  readonly reason: string;\n}\n\nconst KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n\nfunction appendSpecFolderScope(\n  clauses: string[],\n  params: unknown[],\n  specFolder: string | null | undefined,\n  column = 'm.spec_folder',\n): void {\n  if (!specFolder) return;\n  clauses.push(`(${column} = ? OR ${column} LIKE ?)`);\n  params.push(specFolder, `${specFolder}/%`);\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM active_vec.sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\nfunction getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n  const active = getActiveEmbedder(database);\n  const dimTableName = `vec_${active.dim}`;\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n    return {\n      dim: active.dim,\n      tableName: activeVectorSchema(dimTableName),\n      idColumn: 'id',\n      embeddingColumn: 'vec',\n    };\n  }\n\n  return {\n    dim: get_embedding_dim(),\n    tableName: activeVectorSchema('vec_memories'),\n    idColumn: 'rowid',\n    embeddingColumn: 'embedding',\n  };\n}\n\nfunction elapsedMs(start: bigint): number {\n  return Number(process.hrtime.bigint() - start) / 1_000_000;\n}\n\nfunction average(values: number[]): number {\n  if (values.length === 0) return 0;\n  return values.reduce((sum, value) => sum + value, 0) / values.length;\n}\n\nexport function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n  return result.matchSupported === true\n    && typeof result.matchImprovementPct === 'number'\n    && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n}\n\nexport function benchmarkKnnQueryShapes(\n  query_embedding: EmbeddingInput,\n  options: { iterations?: number; limit?: number } = {},\n  database: Database.Database = initialize_db(),\n): KnnQueryShapeBenchmarkResult {\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n  const limit = Math.max(1, Math.floor(options.limit ?? 20));\n  const queryBuffer = to_embedding_buffer(query_embedding);\n  const corpusSize = (database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE m.embedding_status = 'success'\n  `).get() as { count: number }).count;\n\n  const scalarSql = `\n    SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n    WHERE m.embedding_status = 'success'\n    ORDER BY distance ASC\n    LIMIT ?\n  `;\n  const scalarStmt = database.prepare(scalarSql);\n  scalarStmt.all(queryBuffer, limit);\n  const scalarRuns: number[] = [];\n  for (let i = 0; i < iterations; i += 1) {\n    const start = process.hrtime.bigint();\n    scalarStmt.all(queryBuffer, limit);\n    scalarRuns.push(elapsedMs(start));\n  }\n\n  const matchTable = activeVectorSchema('vec_memories');\n  const matchAvailable = tableExists(database, 'vec_memories');\n  let matchAverageMs: number | null = null;\n  let matchError: string | null = null;\n\n  if (matchAvailable) {\n    try {\n      const matchSql = `\n        WITH knn AS (\n          SELECT rowid, distance\n          FROM ${matchTable}\n          WHERE embedding MATCH ? AND k = ?\n        )\n        SELECT m.id, knn.distance\n        FROM knn\n        JOIN memory_index m ON m.id = knn.rowid\n        JOIN active_memory_projection p ON p.active_memory_id = m.id\n        WHERE m.embedding_status = 'success'\n        ORDER BY knn.distance ASC\n        LIMIT ?\n      `;\n      const matchStmt = database.prepare(matchSql);\n      matchStmt.all(queryBuffer, limit, limit);\n      const matchRuns: number[] = [];\n      for (let i = 0; i < iterations; i += 1) {\n        const start = process.hrtime.bigint();\n        matchStmt.all(queryBuffer, limit, limit);\n        matchRuns.push(elapsedMs(start));\n      }\n      matchAverageMs = average(matchRuns);\n    } catch (error: unknown) {\n      matchError = get_error_message(error);\n    }\n  }\n\n  const scalarJoinAverageMs = average(scalarRuns);\n  const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n    ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n    : null;\n  const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n  };\n  const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n\n  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n\n/**\n * Gets one indexed memory by identifier.\n * @param id - The memory identifier.\n * @returns The matching memory row, if found.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const memory = get_memory(42);\n * ```\n */\nexport function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n  const stmts = init_prepared_statements(database);\n  const row = stmts.get_by_id.get(id);\n\n  if (row) {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n  }\n\n  return row || null;\n}\n\n/**\n * Gets indexed memories for a spec folder.\n * @param spec_folder - The spec folder to query.\n * @returns The memory rows for the folder.\n */\nexport function get_memories_by_folder(\n  spec_folder: string,\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const rows = database.prepare(`\n    SELECT m.*\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE (m.spec_folder = ? OR m.spec_folder LIKE ?)\n    ORDER BY m.created_at DESC\n  `).all(spec_folder, `${spec_folder}/%`) as MemoryRow[];\n\n  return rows.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/**\n * Gets the total number of indexed memories.\n * @returns The total memory count.\n */\nexport function get_memory_count(database: Database.Database = initialize_db()): number {\n  const stmts = init_prepared_statements(database);\n  const result = stmts.count_all.get();\n  return result?.count ?? 0;\n}\n\n/**\n * Gets memory counts grouped by embedding status.\n * @returns The counts for each embedding status.\n */\nexport function get_status_counts(\n  database: Database.Database = initialize_db(),\n): { pending: number; success: number; failed: number; retry: number; partial: number } {\n  const rows = database.prepare(`\n    SELECT m.embedding_status, COUNT(*) as count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    GROUP BY m.embedding_status\n  `).all();\n\n  // Include 'partial' status in counts.\n  const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n  for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n    if (row.embedding_status in counts) {\n      counts[row.embedding_status] = row.count;\n    }\n  }\n\n  return counts;\n}\n\n/**\n * Gets summary counts for indexed memories.\n * @returns The aggregate memory statistics.\n */\nexport function get_stats(\n  database: Database.Database = initialize_db(),\n): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n  const counts = get_status_counts(database);\n  const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n\n  return {\n    total,\n    ...counts\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories by vector similarity.\n * @param query_embedding - The query embedding to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {","lineStart":1,"lineEnd":360,"totalLines":1706,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781144242137,"end":1781144242145}},"metadata":{"openai":{"itemId":"fc_0c16151930509033016a2a1ab1f39c8191b223be90964f162c"}},"id":"prt_eb478478e001NbJ9ezdIrn1vRT","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477fee8001w4gZqiXMJ1Rd3D"}}
{"type":"tool_use","timestamp":1781144242152,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"grep","callID":"call_njiQXhAHbTdjOcLVgSbvw8d1","state":{"status":"completed","input":{"pattern":"function vector_search|export function vector_search|function get_memory|export function get_memory|delete_memory","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search","include":"*.ts"},"output":"Found 23 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts:\n  Line 639:  * const deleted = delete_memory(42);\n\n  Line 642: export function delete_memory(id: number, database: Database.Database = initialize_db()): boolean {\n\n  Line 643:   return delete_memory_from_database(database, id);\n\n  Line 654:  * const deleted = delete_memory_from_database(database, 42);\n\n  Line 657: export function delete_memory_from_database(database: Database.Database, id: number): boolean {\n\n  Line 660:   const delete_memory_tx = database.transaction(() => {\n\n  Line 701:   const deleted = delete_memory_tx();\n\n  Line 732:  * const deleted = delete_memory_by_path('specs/001-demo', 'spec.md');\n\n  Line 735: export function delete_memory_by_path(\n\n  Line 753:     const deleted = delete_memory_from_database(database, row.id);\n\n  Line 953: export { delete_memory as deleteMemory };\n\n  Line 954: export { delete_memory_by_path as deleteMemoryByPath };\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts:\n  Line 48:   delete_memory,\n\n  Line 49:   delete_memory_by_path,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts:\n  Line 44: import { delete_memory_from_database } from './vector-index-mutations.js';\