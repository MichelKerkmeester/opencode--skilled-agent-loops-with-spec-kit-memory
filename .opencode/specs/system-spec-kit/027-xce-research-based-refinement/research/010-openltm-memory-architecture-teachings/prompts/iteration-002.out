56:           }\n457:         } catch (err) {\n458:           process.stderr.write(`[recall] Semantic fallback failed: ${err}\\n`);\n459:         }\n460:       }\n461:     }\n462:   }\n463: \n464:   if (input.tags && input.tags.length > 0) {\n465:     const tagIds = input.tags.map(t => {\n466:       const row = db.query<{ id: number }, [string]>(`SELECT id FROM tags WHERE name=?`).get(t.toLowerCase());\n467:       return row?.id;\n468:     }).filter((id): id is number => id !== undefined);\n469: \n470:     if (tagIds.length > 0) {\n471:       const placeholders = tagIds.map(() => \"?\").join(\",\");\n472:       const tagMemIds = db.query<{ memory_id: number }, number[]>(\n473:         `SELECT DISTINCT memory_id FROM memory_tags WHERE tag_id IN (${placeholders})`\n474:       ).all(...tagIds).map(r => r.memory_id);\n475: \n476:       const tagSet = new Set(tagMemIds);\n477:       ids = ids ? new Set([...ids].filter(id => tagSet.has(id))) : tagSet;\n478:     }\n479:   }\n480: \n481:   const conditions: string[] = [];\n482:   const params: (string | number | null)[] = [];\n483: \n484:   if (ids !== null) {\n485:     if (ids.size === 0) return [];\n486:     const placeholders = [...ids].map(() => \"?\").join(\",\");\n487:     conditions.push(`id IN (${placeholders})`);\n488:     params.push(...ids);\n489:   }\n490: \n491:   if (input.category) {\n492:     conditions.push(\"category=?\");\n493:     params.push(input.category);\n494:   }\n495: \n496:   if (input.project) {\n497:     conditions.push(\"(project_scope IS NULL OR project_scope=?)\");\n498:     params.push(input.project);\n499:   }\n500: \n501:   if (input.workspace_id) {\n502:     conditions.push(\"(workspace_id IS NULL OR workspace_id=?)\");\n503:     params.push(input.workspace_id);\n504:   }\n505:   if (input.agent_id) {\n506:     conditions.push(\"(agent_id IS NULL OR agent_id=?)\");\n507:     params.push(input.agent_id);\n508:   }\n509: \n510:   conditions.push(\"status = 'active'\");\n511: \n512:   if (input.since) {\n513:     conditions.push(\"(created_at > ? OR last_recalled_at > ?)\");\n514:     params.push(input.since, input.since);\n515:   }\n516:   if (input.until) {\n517:     conditions.push(\"(created_at < ? OR last_recalled_at < ?)\");\n518:     params.push(input.until, input.until);\n519:   }\n520: \n521:   const where = `WHERE ${conditions.join(\" AND \")}`;\n522:   // Explicit columns — excludes embedding blob (~260 KB/row) from hot recall path.\n523:   // Use getById(id, { withEmbedding: true }) when the blob is needed.\n524:   // default sort (no query): ORDER BY decay_score DESC pushed to SQL → O(log N)\n525:   const defaultSqlSort = (!input.sort_by || input.sort_by === \"relevance\") && ids === null;\n526:   const orderBy = defaultSqlSort ? \"ORDER BY decay_score DESC\" : \"\";\n527:   const rows = db.query<Memory, typeof params>(\n528:     `SELECT id, content, category, importance, confidence, source, project_scope, dedup_key,\n529:             created_at, last_confirmed_at, last_used_at, confirm_count, status,\n530:             first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n531:             workspace_id, agent_id, decay_score\n532:      FROM memories ${where} ${orderBy} LIMIT ${limit}`\n533:   ).all(...params);\n534: \n535:   let sorted: typeof rows;\n536:   if (defaultSqlSort) {\n537:     sorted = rows; // already ordered by decay_score DESC in SQL\n538:   } else if (input.sort_by === \"created\") {\n539:     sorted = rows.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());\n\n(Showing lines 430-539 of 780. Use offset=540 to continue.)\n</content>","metadata":{"preview":"      .filter(Boolean)\n      .map(t => `\"${t.replace(/\"/g, '\"\"')}\"`)\n      .join(\" OR \");\n    const ftsResults = db.query<{ rowid: number; rank: number }, [string]>(\n      `SELECT rowid, rank FROM memories_fts WHERE memories_fts MATCH ? ORDER BY rank LIMIT 50`\n    ).all(ftsQuery);\n    ids = new Set<number>();\n    for (const r of ftsResults) {\n      ids.add(r.rowid);\n      // FTS5 BM25 rank is a negative number (closer to 0 = better).\n      // Math.exp maps it to (0, 1] where 1 is a perfect match.\n      ftsRanks.set(r.rowid, Math.exp(r.rank));\n    }\n\n    // Semantic fallback: if FTS5 returned fewer results than requested, augment with vector search\n    if (ids.size < limit) {\n      const { readConfigSync } = await import(\"./config.js\");\n      const cfg = readConfigSync();\n      const semanticEnabled = cfg.ltm?.semanticFallback !== false; // default true\n      if (semanticEnabled) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","text":"      .filter(Boolean)\n      .map(t => `\"${t.replace(/\"/g, '\"\"')}\"`)\n      .join(\" OR \");\n    const ftsResults = db.query<{ rowid: number; rank: number }, [string]>(\n      `SELECT rowid, rank FROM memories_fts WHERE memories_fts MATCH ? ORDER BY rank LIMIT 50`\n    ).all(ftsQuery);\n    ids = new Set<number>();\n    for (const r of ftsResults) {\n      ids.add(r.rowid);\n      // FTS5 BM25 rank is a negative number (closer to 0 = better).\n      // Math.exp maps it to (0, 1] where 1 is a perfect match.\n      ftsRanks.set(r.rowid, Math.exp(r.rank));\n    }\n\n    // Semantic fallback: if FTS5 returned fewer results than requested, augment with vector search\n    if (ids.size < limit) {\n      const { readConfigSync } = await import(\"./config.js\");\n      const cfg = readConfigSync();\n      const semanticEnabled = cfg.ltm?.semanticFallback !== false; // default true\n      if (semanticEnabled) {\n        try {\n          const { getSimilarMemories } = await import(\"./embeddings.js\");\n          const semantic = await getSimilarMemories(input.query, limit * 2, 0.5);\n          for (const m of semantic) {\n            ids.add(m.id);\n            semanticScores.set(m.id, m.similarity);\n          }\n        } catch (err) {\n          process.stderr.write(`[recall] Semantic fallback failed: ${err}\\n`);\n        }\n      }\n    }\n  }\n\n  if (input.tags && input.tags.length > 0) {\n    const tagIds = input.tags.map(t => {\n      const row = db.query<{ id: number }, [string]>(`SELECT id FROM tags WHERE name=?`).get(t.toLowerCase());\n      return row?.id;\n    }).filter((id): id is number => id !== undefined);\n\n    if (tagIds.length > 0) {\n      const placeholders = tagIds.map(() => \"?\").join(\",\");\n      const tagMemIds = db.query<{ memory_id: number }, number[]>(\n        `SELECT DISTINCT memory_id FROM memory_tags WHERE tag_id IN (${placeholders})`\n      ).all(...tagIds).map(r => r.memory_id);\n\n      const tagSet = new Set(tagMemIds);\n      ids = ids ? new Set([...ids].filter(id => tagSet.has(id))) : tagSet;\n    }\n  }\n\n  const conditions: string[] = [];\n  const params: (string | number | null)[] = [];\n\n  if (ids !== null) {\n    if (ids.size === 0) return [];\n    const placeholders = [...ids].map(() => \"?\").join(\",\");\n    conditions.push(`id IN (${placeholders})`);\n    params.push(...ids);\n  }\n\n  if (input.category) {\n    conditions.push(\"category=?\");\n    params.push(input.category);\n  }\n\n  if (input.project) {\n    conditions.push(\"(project_scope IS NULL OR project_scope=?)\");\n    params.push(input.project);\n  }\n\n  if (input.workspace_id) {\n    conditions.push(\"(workspace_id IS NULL OR workspace_id=?)\");\n    params.push(input.workspace_id);\n  }\n  if (input.agent_id) {\n    conditions.push(\"(agent_id IS NULL OR agent_id=?)\");\n    params.push(input.agent_id);\n  }\n\n  conditions.push(\"status = 'active'\");\n\n  if (input.since) {\n    conditions.push(\"(created_at > ? OR last_recalled_at > ?)\");\n    params.push(input.since, input.since);\n  }\n  if (input.until) {\n    conditions.push(\"(created_at < ? OR last_recalled_at < ?)\");\n    params.push(input.until, input.until);\n  }\n\n  const where = `WHERE ${conditions.join(\" AND \")}`;\n  // Explicit columns — excludes embedding blob (~260 KB/row) from hot recall path.\n  // Use getById(id, { withEmbedding: true }) when the blob is needed.\n  // default sort (no query): ORDER BY decay_score DESC pushed to SQL → O(log N)\n  const defaultSqlSort = (!input.sort_by || input.sort_by === \"relevance\") && ids === null;\n  const orderBy = defaultSqlSort ? \"ORDER BY decay_score DESC\" : \"\";\n  const rows = db.query<Memory, typeof params>(\n    `SELECT id, content, category, importance, confidence, source, project_scope, dedup_key,\n            created_at, last_confirmed_at, last_used_at, confirm_count, status,\n            first_recalled_at, last_recalled_at, recall_count, superseded_by, superseded_at,\n            workspace_id, agent_id, decay_score\n     FROM memories ${where} ${orderBy} LIMIT ${limit}`\n  ).all(...params);\n\n  let sorted: typeof rows;\n  if (defaultSqlSort) {\n    sorted = rows; // already ordered by decay_score DESC in SQL\n  } else if (input.sort_by === \"created\") {\n    sorted = rows.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());","lineStart":430,"lineEnd":539,"totalLines":780,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/db.ts","time":{"start":1780925367244,"end":1780925367252}},"metadata":{"openai":{"itemId":"fc_0da42d7f858b0596016a26c3b6103c8191810b118a7e14c735"}},"id":"prt_ea76c7f41001TED7wU8MVk0GHE","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76c5d3c0016LnhwEOW29E3iQ"}}
