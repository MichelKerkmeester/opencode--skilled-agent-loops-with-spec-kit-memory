{"type":"tool_use","timestamp":1781763080633,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_xfktXdiaqT0AfoXo5qPVCuua","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // --------------------------------------------------------------------------\n3: // COMPONENT: Spec Memory CLI Shim\n4: // PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n5: // --------------------------------------------------------------------------\n6: 'use strict';\n7: \n8: const fs = require('fs');\n9: const path = require('path');\n10: const crypto = require('crypto');\n11: const { spawnSync } = require('child_process');\n12: \n13: const opencodeDir = path.resolve(__dirname, '..');\n14: const mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\n15: const cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\n16: const sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\n17: const defaultSocketDir = '/tmp/mk-spec-memory';\n18: const socketFileName = 'daemon-ipc.sock';\n19: const allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n20: \n21: function fail(message) {\n22:   process.stderr.write(`${message}\\n`);\n23:   process.exit(69);\n24: }\n25: \n26: // Recursively collects the CLI's compiled-source surface (entry, local schema\n27: // imports, tsconfig) so new files under candidate directories are watched\n28: // without editing this list. Must stay in lock-step with\n29: // scripts/finalize-dist.mjs, which writes the matching hash at build time.\n30: function sourceCandidates() {\n31:   const candidates = [\n32:     path.join(mcpServerDir, 'spec-memory-cli.ts'),\n33:     path.join(mcpServerDir, 'tool-schemas.ts'),\n34:     path.join(mcpServerDir, 'tsconfig.json'),\n35:     path.join(mcpServerDir, 'schemas'),\n36:   ];\n37:   const files = [];\n38: \n39:   const visit = (candidate) => {\n40:     if (!fs.existsSync(candidate)) return;\n41:     const stat = fs.statSync(candidate);\n42:     if (stat.isDirectory()) {\n43:       for (const entry of fs.readdirSync(candidate)) {\n44:         visit(path.join(candidate, entry));\n45:       }\n46:       return;\n47:     }\n48:     if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n49:       files.push(candidate);\n50:     }\n51:   };\n52: \n53:   for (const candidate of candidates) visit(candidate);\n54:   return files;\n55: }\n56: \n57: function hashSourceFiles(existingSources) {\n58:   const hash = crypto.createHash('sha256');\n59:   for (const filePath of [...existingSources].sort()) {\n60:     hash.update(path.relative(mcpServerDir, filePath));\n61:     hash.update('\\0');\n62:     hash.update(fs.readFileSync(filePath));\n63:     hash.update('\\0');\n64:   }\n65:   return hash.digest('hex');\n66: }\n67: \n68: function readStoredSourceHash() {\n69:   try {\n70:     const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n71:     return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n72:   } catch {\n73:     return null;\n74:   }\n75: }\n76: \n77: function writeStoredSourceHash(sourceHash) {\n78:   try {\n79:     fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n80:     fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n81:   } catch {\n82:     // Freshness metadata is an optimization; stale detection remains conservative.\n83:   }\n84: }\n85: \n86: function ensureFreshDist() {\n87:   if (!fs.existsSync(cliDist)) {\n88:     fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n89:   }\n90:   if (allowStale) return;\n91:   const existingSources = sourceCandidates();\n92:   if (existingSources.length === 0) return;\n93:   const currentSourceHash = hashSourceFiles(existingSources);\n94:   if (readStoredSourceHash() === currentSourceHash) return;\n95:   const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n96:   const distMtime = fs.statSync(cliDist).mtimeMs;\n97:   if (newestSourceMtime > distMtime) {\n98:     fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n99:   }\n100:   writeStoredSourceHash(currentSourceHash);\n101: }\n102: \n103: function ensureSocketDir() {\n104:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n105:     process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n106:   }\n107:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n108:   if (socketDir.startsWith('tcp://')) return;\n109:   fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n110:   const socketPath = path.join(path.resolve(socketDir), socketFileName);\n111:   if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n112:     fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n113:   }\n114: }\n115: \n116: ensureSocketDir();\n117: ensureFreshDist();\n118: \n119: const result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n120:   cwd: path.dirname(opencodeDir),\n121:   env: process.env,\n122:   stdio: 'inherit',\n123: });\n124: \n125: if (result.error) {\n126:   process.stderr.write(`${result.error.message}\\n`);\n127:   process.exit(75);\n128: }\n129: \n130: process.exit(result.status ?? 1);\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/spec-memory.cjs","text":"#!/usr/bin/env node\n// --------------------------------------------------------------------------\n// COMPONENT: Spec Memory CLI Shim\n// PURPOSE: Runs the built daemon-backed mk-spec-memory CLI.\n// --------------------------------------------------------------------------\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\nconst opencodeDir = path.resolve(__dirname, '..');\nconst mcpServerDir = path.join(opencodeDir, 'skills', 'system-spec-kit', 'mcp_server');\nconst cliDist = path.join(mcpServerDir, 'dist', 'spec-memory-cli.js');\nconst sourceHashState = path.join(path.dirname(cliDist), '.spec-memory-cli-source-hash.json');\nconst defaultSocketDir = '/tmp/mk-spec-memory';\nconst socketFileName = 'daemon-ipc.sock';\nconst allowStale = process.env.SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE === '1';\n\nfunction fail(message) {\n  process.stderr.write(`${message}\\n`);\n  process.exit(69);\n}\n\n// Recursively collects the CLI's compiled-source surface (entry, local schema\n// imports, tsconfig) so new files under candidate directories are watched\n// without editing this list. Must stay in lock-step with\n// scripts/finalize-dist.mjs, which writes the matching hash at build time.\nfunction sourceCandidates() {\n  const candidates = [\n    path.join(mcpServerDir, 'spec-memory-cli.ts'),\n    path.join(mcpServerDir, 'tool-schemas.ts'),\n    path.join(mcpServerDir, 'tsconfig.json'),\n    path.join(mcpServerDir, 'schemas'),\n  ];\n  const files = [];\n\n  const visit = (candidate) => {\n    if (!fs.existsSync(candidate)) return;\n    const stat = fs.statSync(candidate);\n    if (stat.isDirectory()) {\n      for (const entry of fs.readdirSync(candidate)) {\n        visit(path.join(candidate, entry));\n      }\n      return;\n    }\n    if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {\n      files.push(candidate);\n    }\n  };\n\n  for (const candidate of candidates) visit(candidate);\n  return files;\n}\n\nfunction hashSourceFiles(existingSources) {\n  const hash = crypto.createHash('sha256');\n  for (const filePath of [...existingSources].sort()) {\n    hash.update(path.relative(mcpServerDir, filePath));\n    hash.update('\\0');\n    hash.update(fs.readFileSync(filePath));\n    hash.update('\\0');\n  }\n  return hash.digest('hex');\n}\n\nfunction readStoredSourceHash() {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(sourceHashState, 'utf8'));\n    return typeof parsed?.sourceHash === 'string' ? parsed.sourceHash : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction writeStoredSourceHash(sourceHash) {\n  try {\n    fs.mkdirSync(path.dirname(sourceHashState), { recursive: true });\n    fs.writeFileSync(sourceHashState, `${JSON.stringify({ version: 1, sourceHash })}\\n`);\n  } catch {\n    // Freshness metadata is an optimization; stale detection remains conservative.\n  }\n}\n\nfunction ensureFreshDist() {\n  if (!fs.existsSync(cliDist)) {\n    fail(`spec-memory dist entrypoint is missing: ${cliDist}. Run npm run build --workspace=@spec-kit/mcp-server.`);\n  }\n  if (allowStale) return;\n  const existingSources = sourceCandidates();\n  if (existingSources.length === 0) return;\n  const currentSourceHash = hashSourceFiles(existingSources);\n  if (readStoredSourceHash() === currentSourceHash) return;\n  const newestSourceMtime = Math.max(...existingSources.map((filePath) => fs.statSync(filePath).mtimeMs));\n  const distMtime = fs.statSync(cliDist).mtimeMs;\n  if (newestSourceMtime > distMtime) {\n    fail('spec-memory dist entrypoint is stale. Run npm run build --workspace=@spec-kit/mcp-server.');\n  }\n  writeStoredSourceHash(currentSourceHash);\n}\n\nfunction ensureSocketDir() {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = defaultSocketDir;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (socketDir.startsWith('tcp://')) return;\n  fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  const socketPath = path.join(path.resolve(socketDir), socketFileName);\n  if (process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103) {\n    fail(`spec-memory socket path exceeds the Darwin sun_path limit: ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory or a tcp:// endpoint.`);\n  }\n}\n\nensureSocketDir();\nensureFreshDist();\n\nconst result = spawnSync(process.execPath, [cliDist, ...process.argv.slice(2)], {\n  cwd: path.dirname(opencodeDir),\n  env: process.env,\n  stdio: 'inherit',\n});\n\nif (result.error) {\n  process.stderr.write(`${result.error.message}\\n`);\n  process.exit(75);\n}\n\nprocess.exit(result.status ?? 1);","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/bin/spec-memory.cjs","time":{"start":1781763080623,"end":1781763080631}},"metadata":{"openai":{"itemId":"fc_0772a166e6b2003e016a338c06e8488191b939b74d0f4feaac"}},"id":"prt_ed95b01a0001kR7rC9y7PhhHas","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95ac290001Wbuv974LwSxSrP"}}
{"type":"tool_use","timestamp":1781763080639,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_i01oU0QVqf8hKAseKWGLI4QJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","offset":1,"limit":2600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Embeddings\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // PROVIDERS: EMBEDDINGS\n6: // Re-export from shared/ (canonical source)\n7: // Includes multi-provider support, task-specific functions, dynamic dimensions\n8: // MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n9: // Explicit named exports required for auditability.\n10: export {\n11:   generateEmbedding,\n12:   generateEmbeddingWithTimeout,\n13:   generateBatchEmbeddings,\n14:   generateDocumentEmbedding,\n15:   generateQueryEmbedding,\n16:   generateClusteringEmbedding,\n17:   buildWeightedDocumentText,\n18:   semanticChunk,\n19:   getEmbeddingDimension,\n20:   getModelName,\n21:   isModelLoaded,\n22:   getModelLoadTime,\n23:   getCurrentDevice,\n24:   getOptimalDevice,\n25:   getTaskPrefix,\n26:   preWarmModel,\n27:   getEmbeddingProfile,\n28:   getEmbeddingProfileAsync,\n29:   getProviderMetadata,\n30:   clearEmbeddingCache,\n31:   getEmbeddingCacheStats,\n32:   isProviderInitialized,\n33:   invalidateProviderSingleton,\n34:   shouldEagerWarmup,\n35:   getLazyLoadingStats,\n36:   validateApiKey,\n37:   VALIDATION_TIMEOUT_MS,\n38:   EMBEDDING_DIM,\n39:   EMBEDDING_TIMEOUT,\n40:   MAX_TEXT_LENGTH,\n41:   MODEL_NAME,\n42:   DEFAULT_MODEL_NAME,\n43:   TASK_PREFIX,\n44:   BATCH_DELAY_MS,\n45:   BATCH_RATE_LIMIT_DELAY,\n46:   RESERVED_OVERVIEW,\n47:   RESERVED_OUTCOME,\n48:   MIN_SECTION_LENGTH,\n49:   __embeddingCircuitTestables,\n50: } from '@spec-kit/shared/embeddings';\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embeddings\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// PROVIDERS: EMBEDDINGS\n// Re-export from shared/ (canonical source)\n// Includes multi-provider support, task-specific functions, dynamic dimensions\n// MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n// Explicit named exports required for auditability.\nexport {\n  generateEmbedding,\n  generateEmbeddingWithTimeout,\n  generateBatchEmbeddings,\n  generateDocumentEmbedding,\n  generateQueryEmbedding,\n  generateClusteringEmbedding,\n  buildWeightedDocumentText,\n  semanticChunk,\n  getEmbeddingDimension,\n  getModelName,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embeddings\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// PROVIDERS: EMBEDDINGS\n// Re-export from shared/ (canonical source)\n// Includes multi-provider support, task-specific functions, dynamic dimensions\n// MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n// Explicit named exports required for auditability.\nexport {\n  generateEmbedding,\n  generateEmbeddingWithTimeout,\n  generateBatchEmbeddings,\n  generateDocumentEmbedding,\n  generateQueryEmbedding,\n  generateClusteringEmbedding,\n  buildWeightedDocumentText,\n  semanticChunk,\n  getEmbeddingDimension,\n  getModelName,\n  isModelLoaded,\n  getModelLoadTime,\n  getCurrentDevice,\n  getOptimalDevice,\n  getTaskPrefix,\n  preWarmModel,\n  getEmbeddingProfile,\n  getEmbeddingProfileAsync,\n  getProviderMetadata,\n  clearEmbeddingCache,\n  getEmbeddingCacheStats,\n  isProviderInitialized,\n  invalidateProviderSingleton,\n  shouldEagerWarmup,\n  getLazyLoadingStats,\n  validateApiKey,\n  VALIDATION_TIMEOUT_MS,\n  EMBEDDING_DIM,\n  EMBEDDING_TIMEOUT,\n  MAX_TEXT_LENGTH,\n  MODEL_NAME,\n  DEFAULT_MODEL_NAME,\n  TASK_PREFIX,\n  BATCH_DELAY_MS,\n  BATCH_RATE_LIMIT_DELAY,\n  RESERVED_OVERVIEW,\n  RESERVED_OUTCOME,\n  MIN_SECTION_LENGTH,\n  __embeddingCircuitTestables,\n} from '@spec-kit/shared/embeddings';","lineStart":1,"lineEnd":50,"totalLines":50,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","time":{"start":1781763080626,"end":1781763080638}},"metadata":{"openai":{"itemId":"fc_0772a166e6b2003e016a338c06e84c8191b1b2721b8b5322c6"}},"id":"prt_ed95b01b1001X2ZkzRKjs8pSN7","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95ac290001Wbuv974LwSxSrP"}}
{"type":"tool_use","timestamp":1781763080641,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_1aUTBUOnhfcpuqtEzmmfIXwM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retry Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Embedding retry orchestrator\n5: // Node stdlib\n6: import * as fsPromises from 'fs/promises';\n7: \n8: // Internal modules\n9: import * as vectorIndex from '../search/vector-index.js';\n10: import { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\n11: import { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\n12: import { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\n13: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n14: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n15: import { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n16: \n17: // Type imports\n18: import type { MemoryDbRow } from '@spec-kit/shared/types';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. TYPES\n22: ──────────────────────────────────────────────────────────────── */\n23: \n24: interface BackgroundJobConfig {\n25:   intervalMs: number;\n26:   batchSize: number;\n27:   enabled: boolean;\n28: }\n29: \n30: interface RetryStats {\n31:   pending: number;\n32:   retry: number;\n33:   failed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health — no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n221: \n222: function sanitizeEmbeddingFailure(\n223:   raw: unknown,\n224:   options: SanitizeEmbeddingFailureOptions = {},\n225: ): SanitizedEmbeddingFailure {\n226:   const publicMessage = raw instanceof Error\n227:     ? raw.message.trim()\n228:     : String(raw ?? '').trim();\n229: \n230:   if (publicMessage.length === 0) {\n231:     return {\n232:       code: null,\n233:       provider: null,\n234:       errorType: null,\n235:       publicMessage,\n236:       sanitized: false,\n237:     };\n238:   }\n239: \n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n241:     return {\n242:       code: null,\n243:       provider: null,\n244:       errorType: null,\n245:       publicMessage,\n246:       sanitized: false,\n247:     };\n248:   }\n249: \n250:   const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n251:   const { code, errorType } = inferEmbeddingFailure(publicMessage);\n252: \n253:   return {\n254:     code,\n255:     provider,\n256:     errorType,\n257:     publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n258:     sanitized: true,\n259:   };\n260: }\n261: \n262: export function sanitizeEmbeddingFailureMessage(\n263:   raw: unknown,\n264:   options: SanitizeEmbeddingFailureOptions = {},\n265: ): string | null {\n266:   const failure = sanitizeEmbeddingFailure(raw, options);\n267:   return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n268: }\n269: \n270: export function sanitizeAndLogEmbeddingFailure(\n271:   context: string,\n272:   raw: unknown,\n273:   options: SanitizeEmbeddingFailureOptions = {},\n274: ): string | null {\n275:   const failure = sanitizeEmbeddingFailure(raw, options);\n276:   if (failure.publicMessage.length === 0) {\n277:     return null;\n278:   }\n279: \n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n301:   const now = new Date().toISOString();\n302:   const retryCount = getRetryCountValue(memory);\n303:   const lastRetryAt = getLastRetryAtValue(memory);\n304:   // Concurrency: atomic claim prevents double-processing of retry jobs\n305:   const result = previousStatus === 'pending'\n306:     ? db.prepare(`\n307:         UPDATE memory_index\n308:         SET embedding_status = 'retry',\n309:             last_retry_at = ?,\n310:             updated_at = ?\n311:         WHERE id = ?\n312:           AND embedding_status = 'pending'\n313:           AND retry_count = ?\n314:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n315:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n316:     : db.prepare(`\n317:         UPDATE memory_index\n318:         SET last_retry_at = ?,\n319:             updated_at = ?\n320:         WHERE id = ?\n321:           AND embedding_status = 'retry'\n322:           AND retry_count = ?\n323:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n324:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n325: \n326:   return {\n327:     claimed: result.changes > 0,\n328:     previousStatus,\n329:   };\n330: }\n331: \n332: /* ───────────────────────────────────────────────────────────────\n333:    2. CONFIGURATION\n334: ──────────────────────────────────────────────────────────────── */\n335: \n336: // Backoff delays in milliseconds (1min, 5min, 15min)\n337: const BACKOFF_DELAYS: number[] = [\n338:   60 * 1000,\n339:   5 * 60 * 1000,\n340:   15 * 60 * 1000,\n341: ];\n342: \n343: const MAX_RETRIES = 3;\n344: const MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n345: const MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n346: \n347: // 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n348: // applies to a long-lived daemon without depending on the exact restart sequence. The\n349: // module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\n350: function getMaxRetryQueuePending(): number {\n351:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n352: }\n353: \n354: function getMaxRetryQueueAgeMs(): number {\n355:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n356: }\n357: \n358: // Background retry job configuration\n359: // Env-overrideable\n360: //   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n361: //   SPECKIT_RETRY_BATCH_SIZE  — items processed per batch (default 5)\n362: //   SPECKIT_RETRY_ENABLED     — set to \"false\" to disable the background loop entirely (default enabled)\n363: const BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n364:   intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n365:   batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n366:   enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n367: };\n368: \n369: // Background job state\n370: let backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\n371: let backgroundJobRunning = false;\n372: let shutdownRequested = false;\n373: let retryAbortController: AbortController | null = null;\n374: \n375: // In-memory retry telemetry (never persisted to DB — read by getEmbeddingRetryStats)\n376: let lastBackgroundRunAt: string | null = null;\n377: let totalRetryAttempts = 0;\n378: const retryHealthSnapshot: EmbeddingRetryStats = {\n379:   pending: 0,\n380:   failed: 0,\n381:   retryAttempts: 0,\n382:   circuitBreakerOpen: false,\n383:   lastRun: null,\n384:   queueDepth: 0,\n385: };\n386: \n387: // circuit breaker — prevents the background retry job from\n388: // Hammering the embedding API when the provider is entirely down. After\n389: // PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n390: // Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n391: // The API call and return a transient error instead.\n392: const PROVIDER_FAILURE_THRESHOLD = 5;\n393: const PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\n394: const CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\n395: const FLAPPING_THRESHOLD = 2;\n396: const circuitTransitions: number[] = [];\n397: \n398: let providerFailures = 0;\n399: let providerCircuitOpenedAt: number | null = null;\n400: \n401: function parsePositiveIntEnv(name: string, fallback: number): number {\n402:   const raw = process.env[name];\n403:   if (!raw) return fallback;\n404: \n405:   const parsed = Number.parseInt(raw, 10);\n406:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n407: }\n408: \n409: function recordCircuitTransition(): void {\n410:   const now = Date.now();\n411:   circuitTransitions.push(now);\n412:   while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n413:     circuitTransitions.shift();\n414:   }\n415: }\n416: \n417: function getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n418:   const now = Date.now();\n419:   const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n420:   return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n421: }\n422: \n423: function isProviderCircuitOpen(): boolean {\n424:   if (providerCircuitOpenedAt === null) return false;\n425:   if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n426:     providerCircuitOpenedAt = null;\n427:     providerFailures = 0;\n428:     recordCircuitTransition();\n429:     return false;\n430:   }\n431:   return true;\n432: }\n433: \n434: function recordProviderSuccess(): void {\n435:   providerFailures = 0;\n436:   providerCircuitOpenedAt = null;\n437:   retryHealthSnapshot.circuitBreakerOpen = false;\n438: }\n439: \n440: function recordProviderFailure(): void {\n441:   providerFailures++;\n442:   if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n443:     providerCircuitOpenedAt = Date.now();\n444:     recordCircuitTransition();\n445:     console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n446:   }\n447:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n448: }\n449: \n450: function applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n451:   if (previousStatus === 'pending') {\n452:     retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n453:   }\n454: \n455:   if (previousStatus === 'pending' || previousStatus === 'retry') {\n456:     retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n457:   }\n458: \n459:   if (nextStatus === 'pending') {\n460:     retryHealthSnapshot.pending++;\n461:     retryHealthSnapshot.queueDepth++;\n462:   }\n463: \n464:   if (nextStatus === 'retry') {\n465:     retryHealthSnapshot.queueDepth++;\n466:   }\n467: \n468:   if (previousStatus === 'failed') {\n469:     retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n470:   }\n471: \n472:   if (nextStatus === 'failed') {\n473:     retryHealthSnapshot.failed++;\n474:   }\n475: }\n476: \n477: function refreshRetryHealthSnapshot(stats: RetryStats): void {\n478:   retryHealthSnapshot.pending = stats.pending;\n479:   retryHealthSnapshot.failed = stats.failed;\n480:   retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n481:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n482:   retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n483:   retryHealthSnapshot.queueDepth = stats.queue_size;\n484: }\n485: \n486: function enforceRetryRetentionLimits(\n487:   maxPending = getMaxRetryQueuePending(),\n488:   maxAgeMs = getMaxRetryQueueAgeMs(),\n489:   now: Date = new Date(),\n490: ): { expired: number; overflow: number } {\n491:   const db = vectorIndex.getDb();\n492:   if (!db) return { expired: 0, overflow: 0 };\n493: \n494:   const nowIso = now.toISOString();\n495:   const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n496:   // Retention is non-destructive for never-attempted clean `pending` rows.\n497:   // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n498:   // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n499:   // embedded instead of being parked as `failed` before the drain can claim it.\n500:   const expired = db.prepare(`\n501:     UPDATE memory_index\n502:     SET embedding_status = 'failed',\n503:         failure_reason = 'Retry retention max age exceeded',\n504:         updated_at = ?\n505:     WHERE embedding_status IN ('pending', 'retry')\n506:       AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n507:       AND COALESCE(last_retry_at, created_at, updated_at) < ?\n508:   `).run(nowIso, oldestAllowedIso).changes;\n509: \n510:   const rows = db.prepare(`\n511:     SELECT id FROM memory_index\n512:     WHERE embedding_status IN ('pending', 'retry')\n513:       AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n514:     ORDER BY COALESCE(last_retry_at, created_at, updated_at) ASC, id ASC\n515:     LIMIT -1 OFFSET ?\n516:   `).all(maxPending) as Array<{ id: number }>;\n517: \n518:   let overflow = 0;\n519:   if (rows.length > 0) {\n520:     const updateOverflow = db.prepare(`\n521:       UPDATE memory_index\n522:       SET embedding_status = 'failed',\n523:           failure_reason = 'Retry retention pending cap exceeded',\n524:           updated_at = ?\n525:       WHERE id = ?\n526:         AND embedding_status IN ('pending', 'retry')\n527:         AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n528:     `);\n529:     const txn = db.transaction((ids: number[]) => {\n530:       for (const id of ids) {\n531:         overflow += updateOverflow.run(nowIso, id).changes;\n532:       }\n533:     });\n534:     txn(rows.map((row) => row.id));\n535:   }\n536: \n537:   if (expired > 0 || overflow > 0) {\n538:     console.warn(`[retry-manager] Retention pruned expired=${expired}, overflow=${overflow}`);\n539:   }\n540: \n541:   return { expired, overflow };\n542: }\n543: \n544: /* ───────────────────────────────────────────────────────────────\n545:    3. RETRY QUEUE\n546: ──────────────────────────────────────────────────────────────── */\n547: \n548: function getRetryQueue(limit = 10): RetryMemoryRow[] {\n549:   vectorIndex.initializeDb();\n550:   const db = vectorIndex.getDb();\n551:   if (!db) {\n552:     console.warn('[retry-manager] Database not initialized. Server may still be starting up.');\n553:     return [];\n554:   }\n555:   enforceRetryRetentionLimits();\n556:   const now = Date.now();\n557: \n558:   const rows = db.prepare(`\n559:     SELECT * FROM memory_index\n560:     WHERE embedding_status IN ('pending', 'retry')\n561:       AND retry_count < ?\n562:     ORDER BY\n563:       CASE WHEN embedding_status = 'pending' THEN 0 ELSE 1 END,\n564:       retry_count ASC,\n565:       created_at ASC\n566:     LIMIT ?\n567:   `).all(MAX_RETRIES, limit * 2) as RetryMemoryRow[];\n568: \n569:   const eligible: RetryMemoryRow[] = [];\n570:   for (const row of rows) {\n571:     if (isEligibleForRetry(row, now)) {\n572:       eligible.push(parseRow(row));\n573:       if (eligible.length >= limit) break;\n574:     }\n575:   }\n576: \n577:   return eligible;\n578: }\n579: \n580: function isEligibleForRetry(row: RetryMemoryRow, now: number): boolean {\n581:   // Note: better-sqlite3 returns snake_case column names from SELECT *\n582:   if (row.embedding_status === 'pending') return true;\n583: \n584:   if (row.embedding_status === 'retry' && row.last_retry_at) {\n585:     const lastRetry = new Date(row.last_retry_at).getTime();\n586:     const retryCount = (row.retry_count as number) ?? (row.retryCount as number) ?? 0;\n587:     // Off-by-one fix: retryCount is already incremented after the failure that triggered\n588:     // The retry status, so use (retryCount - 1) for the backoff index. First retry (retryCount=1)\n589:     // Should use BACKOFF_DELAYS[0] (1 minute), not BACKOFF_DELAYS[1] (5 minutes).\n590:     const backoffIndex = Math.max(0, retryCount - 1);\n591:     const requiredDelay = BACKOFF_DELAYS[Math.min(backoffIndex, BACKOFF_DELAYS.length - 1)];\n592:     return (now - lastRetry) >= requiredDelay;\n593:   }\n594: \n595:   return row.embedding_status === 'retry';\n596: }\n597: \n598: function getFailedEmbeddings(): RetryMemoryRow[] {\n599:   const db = vectorIndex.getDb();\n600:   if (!db) {\n601:     console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning empty array.');\n602:     return [];\n603:   }\n604: \n605:   const rows = db.prepare(`\n606:     SELECT * FROM memory_index\n607:     WHERE embedding_status = 'failed'\n608:     ORDER BY updated_at DESC\n609:   `).all() as RetryMemoryRow[];\n610: \n611:   return rows.map(parseRow);\n612: }\n613: \n614: function getRetryStats(): RetryStats {\n615:   const db = vectorIndex.getDb();\n616:   if (!db) {\n617:     console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning default stats.');\n618:     return { pending: 0, retry: 0, failed: 0, success: 0, total: 0, queue_size: 0 };\n619:   }\n620: \n621:   const stats = db.prepare(`\n622:     SELECT\n623:       SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n624:       SUM(CASE WHEN embedding_status = 'retry' THEN 1 ELSE 0 END) as retry,\n625:       SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed,\n626:       SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as success,\n627:       COUNT(*) as total\n628:     FROM memory_index\n629:   `).get() as Record<string, number>;\n630: \n631:   const result = {\n632:     pending: stats.pending || 0,\n633:     retry: stats.retry || 0,\n634:     failed: stats.failed || 0,\n635:     success: stats.success || 0,\n636:     total: stats.total || 0,\n637:     queue_size: (stats.pending || 0) + (stats.retry || 0),\n638:   };\n639: \n640:   refreshRetryHealthSnapshot(result);\n641:   return result;\n642: }\n643: \n644: /**\n645:  * Return a lightweight in-memory snapshot of embedding retry health.\n646:  * PULL accessor — synchronous, zero DB access, always safe to call.\n647:  * Returns zero-state when the retry manager has not yet been initialized.\n648:  */\n649: function getEmbeddingRetryStats(): EmbeddingRetryStats {\n650:   return {\n651:     pending: retryHealthSnapshot.pending,\n652:     failed: retryHealthSnapshot.failed,\n653:     retryAttempts: totalRetryAttempts,\n654:     circuitBreakerOpen: isProviderCircuitOpen(),\n655:     lastRun: lastBackgroundRunAt,\n656:     queueDepth: retryHealthSnapshot.queueDepth,\n657:   };\n658: }\n659: \n660: /* ───────────────────────────────────────────────────────────────\n661:    4. RETRY OPERATIONS\n662: ──────────────────────────────────────────────────────────────── */\n663: \n664: async function retryEmbedding(\n665:   id: number,\n666:   content: string,\n667:   claimedPreviousStatus: RetryQueueStatus | null = null,\n668: ): Promise<RetryResult> {\n669:   const db = vectorIndex.getDb();\n670:   if (!db) return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n671: \n672:   const now = new Date().toISOString();\n673: \n674:   try {\n675:     const memory = vectorIndex.getMemory(id);\n676:     if (!memory) return { success: false, error: 'Memory not found' };\n677:     const previousStatus = claimedPreviousStatus ?? (\n678:       typeof memory.embedding_status === 'string'\n679:         ? memory.embedding_status\n680:         : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n681:           ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n682:           : null\n683:     );\n684: \n685:     if ((memory.retry_count as number) >= MAX_RETRIES) {\n686:       markAsFailed(id, 'Maximum retry attempts exceeded');\n687:       return { success: false, error: 'Maximum retries exceeded', permanent: true };\n688:     }\n689: \n690:     // Normalize content before embedding to match sync save path (memory-save.ts:1119).\n691:     // Without this, async-saved memories get embeddings from raw markdown (YAML frontmatter, HTML\n692:     // Comments, code fences) while sync-saved memories get clean normalized embeddings.\n693:     const normalizedContent = normalizeContentForEmbedding(content);\n694:     const modelId = getModelName();\n695:     const embeddingDim = getEmbeddingDimension();\n696:     const contentHash = computeContentHash(normalizedContent);\n697:     const cachedEmbedding = lookupEmbedding(db, contentHash, modelId, embeddingDim);\n698: \n699:     let embedding: Float32Array | null = null;\n700: \n701:     if (cachedEmbedding) {\n702:       embedding = new Float32Array(\n703:         cachedEmbedding.buffer,\n704:         cachedEmbedding.byteOffset,\n705:         Math.floor(cachedEmbedding.byteLength / Float32Array.BYTES_PER_ELEMENT),\n706:       );\n707:     } else {\n708:       // Skip API call if provider circuit breaker is open\n709:       if (isProviderCircuitOpen()) {\n710:         return { success: false, error: 'Embedding provider circuit breaker open — skipping API call' };\n711:       }\n712: \n713:       try {\n714:         embedding = await generateDocumentEmbedding(normalizedContent);\n715:       } catch (providerError: unknown) {\n716:         const sanitizedError = sanitizeAndLogEmbeddingFailure(\n717:           `[retry-manager] Embedding retry failed for #${id}`,\n718:           providerError,\n719:           { provider: modelId, force: true },\n720:         ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n721:         recordProviderFailure();\n722:         // Security: raw provider errors sanitized before persistence/response\n723:         incrementRetryCount(id, sanitizedError);\n724:         return { success: false, error: sanitizedError };\n725:       }\n726: \n727:       if (embedding) {\n728:         recordProviderSuccess();\n729:         storeEmbedding(\n730:           db,\n731:           contentHash,\n732:           modelId,\n733:           Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n734:           embedding.length,\n735:         );\n736:       } else {\n737:         recordProviderFailure();\n738:       }\n739:     }\n740: \n741:     if (!embedding) {\n742:       incrementRetryCount(id, 'Embedding generation returned null');\n743:       return { success: false, error: 'Embedding returned null' };\n744:     }\n745: \n746:     const updateTx = db.transaction(() => {\n747:       db.prepare(`\n748:         UPDATE memory_index\n749:         SET embedding_status = 'success',\n750:             embedding_generated_at = ?,\n751:             updated_at = ?,\n752:             failure_reason = NULL\n753:         WHERE id = ?\n754:       `).run(now, now, id);\n755: \n756:       try {\n757:         db.prepare('DELETE FROM vec_memories WHERE rowid = ?').run(BigInt(id));\n758:       } catch (_error: unknown) {\n759:         // Ignore if doesn't exist\n760:       }\n761: \n762:       const embeddingBuffer = Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength);\n763:       db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)').run(BigInt(id), embeddingBuffer);\n764:     });\n765: \n766:     try {\n767:       updateTx();\n768:       applyRetryHealthTransition(previousStatus, 'success');\n769:       return { success: true, id, dimensions: embedding.length };\n770:     } catch (tx_error: unknown) {\n771:       // Security: raw provider errors sanitized before persistence/response\n772:       console.error(`[retry-manager] Transaction error for #${id}:`, tx_error instanceof Error ? tx_error.message : String(tx_error));\n773:       incrementRetryCount(id, 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)');\n774:       return { success: false, error: 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)' };\n775:     }\n776:   } catch (error: unknown) {\n777:     recordProviderFailure();\n778:     // Security: raw provider errors sanitized before persistence/response\n779:     const sanitizedMessage = sanitizeAndLogEmbeddingFailure(\n780:       `[retry-manager] Unexpected retry error for #${id}`,\n781:       error,\n782:       { provider: null, force: true },\n783:     ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n784:     incrementRetryCount(id, sanitizedMessage);\n785:     return { success: false, error: sanitizedMessage };\n786:   }\n787: }\n788: \n789: function incrementRetryCount(id: number, reason: string): void {\n790:   totalRetryAttempts++;\n791:   const db = vectorIndex.getDb();\n792:   if (!db) return;\n793: \n794:   const now = new Date().toISOString();\n795:   const memory = vectorIndex.getMemory(id);\n796:   if (!memory) {\n797:     console.warn(`[retry-manager] Memory ${id} not found during retry count increment`);\n798:     return;\n799:   }\n800: \n801:   const newRetryCount = (Number(memory.retry_count) || 0) + 1;\n802:   // Security: raw provider errors sanitized before persistence/response\n803:   const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n804:   const previousStatus = typeof memory.embedding_status === 'string'\n805:     ? memory.embedding_status\n806:     : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n807:       ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n808:       : null;\n809: \n810:   if (newRetryCount >= MAX_RETRIES) {\n811:     markAsFailed(id, reason);\n812:   } else {\n813:     db.prepare(`\n814:       UPDATE memory_index\n815:       SET embedding_status = 'retry',\n816:           retry_count = ?,\n817:           last_retry_at = ?,\n818:           failure_reason = ?,\n819:           updated_at = ?\n820:       WHERE id = ?\n821:     `).run(newRetryCount, now, persistedReason, now, id);\n822:     applyRetryHealthTransition(previousStatus, 'retry');\n823:   }\n824: }\n825: \n826: function markAsFailed(id: number, reason: string): void {\n827:   const db = vectorIndex.getDb();\n828:   if (!db) {\n829:     console.warn('[retry-manager] Database not initialized. Server may still be starting up. Cannot mark as failed.');\n830:     return;\n831:   }\n832:   const now = new Date().toISOString();\n833:   const memory = vectorIndex.getMemory(id);\n834:   // Security: raw provider errors sanitized before persistence/response\n835:   const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n836:   const previousStatus = memory && typeof memory.embedding_status === 'string'\n837:     ? memory.embedding_status\n838:     : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n839:       ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n840:       : null;\n841: \n842:   db.prepare(`\n843:     UPDATE memory_index\n844:     SET embedding_status = 'failed',\n845:         failure_reason = ?,\n846:         updated_at = ?\n847:     WHERE id = ?\n848:   `).run(persistedReason, now, id);\n849:   applyRetryHealthTransition(previousStatus, 'failed');\n850: }\n851: \n852: function resetForRetry(id: number): boolean {\n853:   const db = vectorIndex.getDb();\n854:   if (!db) return false;\n855:   const now = new Date().toISOString();\n856:   const memory = vectorIndex.getMemory(id);\n857:   const previousStatus = memory && typeof memory.embedding_status === 'string'\n858:     ? memory.embedding_status\n859:     : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n860:       ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n861:       : null;\n862: \n863:   const result = db.prepare(`\n864:     UPDATE memory_index\n865:     SET embedding_status = 'retry',\n866:         retry_count = 0,\n867:         last_retry_at = NULL,\n868:         failure_reason = NULL,\n869:         updated_at = ?\n870:     WHERE id = ? AND embedding_status = 'failed'\n871:   `).run(now, id);\n872: \n873:   if (result.changes > 0) {\n874:     applyRetryHealthTransition(previousStatus, 'retry');\n875:   }\n876: \n877:   return result.changes > 0;\n878: }\n879: \n880: /* ───────────────────────────────────────────────────────────────\n881:    5. BATCH PROCESSING\n882: ──────────────────────────────────────────────────────────────── */\n883: \n884: async function processRetryQueue(limit = 3, contentLoader: ContentLoader | null = null): Promise<BatchResult> {\n885:   if (shutdownRequested || retryAbortController?.signal.aborted) {\n886:     return { processed: 0, succeeded: 0, failed: 0, details: [] };\n887:   }\n888: \n889:   const queue = getRetryQueue(limit);\n890: \n891:   if (queue.length === 0) {\n892:     return { processed: 0, succeeded: 0, failed: 0 };\n893:   }\n894: \n895:   const results: BatchResult = {\n896:     processed: 0,\n897:     succeeded: 0,\n898:     failed: 0,\n899:     details: [],\n900:   };\n901:   const details = results.details ?? (results.details = []);\n902: \n903:   for (const memory of queue) {\n904:     if (shutdownRequested || retryAbortController?.signal.aborted) {\n905:       break;\n906:     }\n907: \n908:     // For items that have never been attempted (pending), check provider state first.\n909:     // Claiming a pending item promotes it to retry, which is subject to retention pruning.\n910:     // During an outage, leave pending rows as-is so they are not pruned before the drain can embed them.\n911:     if (memory.embedding_status === 'pending' && isProviderCircuitOpen()) {\n912:       continue;\n913:     }\n914: \n915:     const claim = claimRetryCandidate(memory);\n916:     if (!claim.claimed) {\n917:       continue;\n918:     }\n919: \n920:     let content: string | null = null;\n921: \n922:     if (contentLoader) {\n923:       content = await contentLoader(memory);\n924:     } else if (typeof memory.content_text === 'string' && memory.content_text.length > 0) {\n925:       // Use stored content_text — critical for chunks which share file_path with parent\n926:       content = memory.content_text;\n927:     } else {\n928:       content = await loadContentFromFile(memory.file_path);\n929:     }\n930: \n931:     if (shutdownRequested || retryAbortController?.signal.aborted) {\n932:       break;\n933:     }\n934: \n935:     if (!content) {\n936:       // Count content load failure as a retry attempt to prevent infinite retry loops\n937:       incrementRetryCount(memory.id, 'Content load failed: file unreadable or missing');\n938:       details.push({ id: memory.id, success: false, error: 'Could not load content (counted as retry)' });\n939:       results.failed++;\n940:       results.processed++;\n941:       continue;\n942:     }\n943: \n944:     const result = await retryEmbedding(memory.id, content, claim.previousStatus);\n945:     results.processed++;\n946: \n947:     if (result.success) {\n948:       results.succeeded++;\n949:     } else {\n950:       results.failed++;\n951:     }\n952: \n953:     details.push({ id: memory.id, ...result } as RetryDetailEntry);\n954:   }\n955: \n956:   return results;\n957: }\n958: \n959: /* ───────────────────────────────────────────────────────────────\n960:    6. BACKGROUND RETRY JOB\n961: ──────────────────────────────────────────────────────────────── */\n962: \n963: function startBackgroundJob(options: Partial<BackgroundJobConfig> = {}): boolean {\n964:   if (backgroundJobInterval) {\n965:     console.error('[retry-manager] Background job already running');\n966:     return false;\n967:   }\n968: \n969:   const config = { ...BACKGROUND_JOB_CONFIG, ...options };\n970:   shutdownRequested = false;\n971:   retryAbortController = new AbortController();\n972: \n973:   if (!config.enabled) {\n974:     console.error('[retry-manager] Background job is disabled');\n975:     return false;\n976:   }\n977: \n978:   console.error(`[retry-manager] Starting background retry job (interval: ${config.intervalMs}ms, batch: ${config.batchSize})`);\n979: \n980:   runBackgroundJob(config.batchSize).catch((err: unknown) => {\n981:     const message = err instanceof Error ? err.message : String(err);\n982:     console.error('[retry-manager] Initial background job failed:', message);\n983:   });\n984: \n985:   backgroundJobInterval = registerInterval(() => {\n986:     runBackgroundJob(config.batchSize).catch((err: unknown) => {\n987:       const message = err instanceof Error ? err.message : String(err);\n988:       console.error('[retry-manager] Background job iteration failed:', message);\n989:     });\n990:   }, config.intervalMs, { unref: true });\n991: \n992:   return true;\n993: }\n994: \n995: function stopBackgroundJob(): boolean {\n996:   shutdownRequested = true;\n997:   retryAbortController?.abort();\n998:   retryAbortController = null;\n999:   if (!backgroundJobInterval) return false;\n1000: \n1001:   clearRegisteredTimer(backgroundJobInterval);\n1002:   backgroundJobInterval = null;\n1003:   backgroundJobRunning = false;\n1004:   console.error('[retry-manager] Background retry job stopped');\n1005:   return true;\n1006: }\n1007: \n1008: function isBackgroundJobRunning(): boolean {\n1009:   return backgroundJobInterval !== null;\n1010: }\n1011: \n1012: async function runBackgroundJob(batchSize: number = BACKGROUND_JOB_CONFIG.batchSize): Promise<BackgroundJobResult> {\n1013:   if (backgroundJobRunning) {\n1014:     return { skipped: true, reason: 'Previous run still in progress' };\n1015:   }\n1016: \n1017:   backgroundJobRunning = true;\n1018:   if (!retryAbortController || retryAbortController.signal.aborted) {\n1019:     retryAbortController = new AbortController();\n1020:   }\n1021: \n1022:   // Held only while a tick has real work; the empty-queue path below never creates\n1023:   // a handle, so an idle tick leaves the daemon reapable.\n1024:   let maintenanceHandle: MaintenanceMarkerHandle | null = null;\n1025:   try {\n1026:     enforceRetryRetentionLimits();\n1027:     if (shutdownRequested || retryAbortController.signal.aborted) {\n1028:       return { skipped: true, reason: 'Shutdown requested' };\n1029:     }\n1030:     const stats = getRetryStats();\n1031: \n1032:     if (stats.queue_size === 0) {\n1033:       return { processed: 0, queue_empty: true };\n1034:     }\n1035: \n1036:     // The deferred-embedding burst keeps the daemon busy; mark it busy-by-design so\n1037:     // a competing launcher adopts it rather than reaping it mid-drain.\n1038:     maintenanceHandle = beginMaintenance('embedding-queue');\n1039:     console.error(`[retry-manager] Background job: Processing up to ${batchSize} of ${stats.queue_size} pending embeddings`);\n1040: \n1041:     const result = await processRetryQueue(batchSize);\n1042: \n1043:     if (result.processed > 0) {\n1044:       console.error(`[retry-manager] Background job complete: ${result.succeeded}/${result.processed} succeeded`);\n1045:     }\n1046: \n1047:     return result;\n1048:   } catch (error: unknown) {\n1049:     const message = error instanceof Error ? error.message : String(error);\n1050:     console.error('[retry-manager] Background job error:', message);\n1051:     return { error: message };\n1052:   } finally {\n1053:     // Release the busy mark on every exit (success, error). The empty-queue path\n1054:     // never set it, so this is a safe no-op there; end() is idempotent regardless.\n1055:     maintenanceHandle?.end();\n1056:     lastBackgroundRunAt = new Date().toISOString();\n1057:     retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n1058:     retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n1059:     retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n1060:     backgroundJobRunning = false;\n1061:   }\n1062: }\n1063: \n1064: registerShutdownHook(() => {\n1065:   stopBackgroundJob();\n1066: }, { timeoutMs: 250 });\n1067: \n1068: /* ───────────────────────────────────────────────────────────────\n1069:    7. UTILITIES\n1070: ──────────────────────────────────────────────────────────────── */\n1071: \n1072: function parseRow(row: RetryMemoryRow): RetryMemoryRow {\n1073:   if (row.triggerPhrases && typeof row.triggerPhrases === 'string') {\n1074:     try {\n1075:       return { ...row, triggerPhrases: JSON.parse(row.triggerPhrases) };\n1076:     } catch (_error: unknown) {\n1077:       return { ...row, triggerPhrases: [] };\n1078:     }\n1079:   }\n1080:   return { ...row };\n1081: }\n1082: \n1083: async function loadContentFromFile(filePath: string): Promise<string | null> {\n1084:   try {\n1085:     return await fsPromises.readFile(filePath, 'utf-8');\n1086:   } catch (_error: unknown) {\n1087:     return null;\n1088:   }\n1089: }\n1090: \n1091: async function claimAndRetryEmbedding(\n1092:   id: number,\n1093:   content: string,\n1094:   expectedStatus: RetryQueueStatus = 'pending',\n1095: ): Promise<RetryResult | null> {\n1096:   const memory = vectorIndex.getMemory(id) as RetryMemoryRow | undefined;\n1097:   if (!memory) {\n1098:     return { success: false, error: 'Memory not found' };\n1099:   }\n1100: \n1101:   const parsedMemory = parseRow(memory);\n1102:   if (getRetryStatus(parsedMemory) !== expectedStatus) {\n1103:     return null;\n1104:   }\n1105: \n1106:   const claim = claimRetryCandidate(parsedMemory);\n1107:   if (!claim.claimed) {\n1108:     return null;\n1109:   }\n1110: \n1111:   return retryEmbedding(id, content, claim.previousStatus);\n1112: }\n1113: \n1114: /* ───────────────────────────────────────────────────────────────\n1115:    8. EXPORTS\n1116: ──────────────────────────────────────────────────────────────── */\n1117: \n1118: export {\n1119:   getRetryQueue,\n1120:   getFailedEmbeddings,\n1121:   getRetryStats,\n1122:   getEmbeddingRetryStats,\n1123:   getCircuitFlapState,\n1124:   retryEmbedding,\n1125:   claimAndRetryEmbedding,\n1126:   markAsFailed,\n1127:   resetForRetry,\n1128:   processRetryQueue,\n1129:   startBackgroundJob,\n1130:   stopBackgroundJob,\n1131:   isBackgroundJobRunning,\n1132:   runBackgroundJob,\n1133:   enforceRetryRetentionLimits,\n1134:   BACKGROUND_JOB_CONFIG,\n1135:   BACKOFF_DELAYS,\n1136:   MAX_RETRIES,\n1137:   MAX_RETRY_QUEUE_PENDING,\n1138:   MAX_RETRY_QUEUE_AGE_MS,\n1139:   getMaxRetryQueuePending,\n1140:   getMaxRetryQueueAgeMs,\n1141: };\n\n(End of file - total 1141 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health — no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}\n\nfunction sanitizeEmbeddingFailure(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): SanitizedEmbeddingFailure {\n  const publicMessage = raw instanceof Error\n    ? raw.message.trim()\n    : String(raw ?? '').trim();\n\n  if (publicMessage.length === 0) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };\n}\n\nexport function sanitizeEmbeddingFailureMessage(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n}\n\nexport function sanitizeAndLogEmbeddingFailure(\n  context: string,\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  if (failure.publicMessage.length === 0) {\n    return null;\n  }\n\n  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n\n  const now = new Date().toISOString();\n  const retryCount = getRetryCountValue(memory);\n  const lastRetryAt = getLastRetryAtValue(memory);\n  // Concurrency: atomic claim prevents double-processing of retry jobs\n  const result = previousStatus === 'pending'\n    ? db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'pending'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n    : db.prepare(`\n        UPDATE memory_index\n        SET last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'retry'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n\n  return {\n    claimed: result.changes > 0,\n    previousStatus,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Backoff delays in milliseconds (1min, 5min, 15min)\nconst BACKOFF_DELAYS: number[] = [\n  60 * 1000,\n  5 * 60 * 1000,\n  15 * 60 * 1000,\n];\n\nconst MAX_RETRIES = 3;\nconst MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\nconst MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n\n// 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n// applies to a long-lived daemon without depending on the exact restart sequence. The\n// module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\nfunction getMaxRetryQueuePending(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n}\n\nfunction getMaxRetryQueueAgeMs(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n}\n\n// Background retry job configuration\n// Env-overrideable\n//   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n//   SPECKIT_RETRY_BATCH_SIZE  — items processed per batch (default 5)\n//   SPECKIT_RETRY_ENABLED     — set to \"false\" to disable the background loop entirely (default enabled)\nconst BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n  intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n  batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n  enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n};\n\n// Background job state\nlet backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\nlet backgroundJobRunning = false;\nlet shutdownRequested = false;\nlet retryAbortController: AbortController | null = null;\n\n// In-memory retry telemetry (never persisted to DB — read by getEmbeddingRetryStats)\nlet lastBackgroundRunAt: string | null = null;\nlet totalRetryAttempts = 0;\nconst retryHealthSnapshot: EmbeddingRetryStats = {\n  pending: 0,\n  failed: 0,\n  retryAttempts: 0,\n  circuitBreakerOpen: false,\n  lastRun: null,\n  queueDepth: 0,\n};\n\n// circuit breaker — prevents the background retry job from\n// Hammering the embedding API when the provider is entirely down. After\n// PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n// Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n// The API call and return a transient error instead.\nconst PROVIDER_FAILURE_THRESHOLD = 5;\nconst PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\nconst CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\nconst FLAPPING_THRESHOLD = 2;\nconst circuitTransitions: number[] = [];\n\nlet providerFailures = 0;\nlet providerCircuitOpenedAt: number | null = null;\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction recordCircuitTransition(): void {\n  const now = Date.now();\n  circuitTransitions.push(now);\n  while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n    circuitTransitions.shift();\n  }\n}\n\nfunction getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n  const now = Date.now();\n  const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n  return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n}\n\nfunction isProviderCircuitOpen(): boolean {\n  if (providerCircuitOpenedAt === null) return false;\n  if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n    providerCircuitOpenedAt = null;\n    providerFailures = 0;\n    recordCircuitTransition();\n    return false;\n  }\n  return true;\n}\n\nfunction recordProviderSuccess(): void {\n  providerFailures = 0;\n  providerCircuitOpenedAt = null;\n  retryHealthSnapshot.circuitBreakerOpen = false;\n}\n\nfunction recordProviderFailure(): void {\n  providerFailures++;\n  if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n    providerCircuitOpenedAt = Date.now();\n    recordCircuitTransition();\n    console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n  }\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n}\n\nfunction applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n  if (previousStatus === 'pending') {\n    retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n  }\n\n  if (previousStatus === 'pending' || previousStatus === 'retry') {\n    retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n  }\n\n  if (nextStatus === 'pending') {\n    retryHealthSnapshot.pending++;\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (nextStatus === 'retry') {\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (previousStatus === 'failed') {\n    retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n  }\n\n  if (nextStatus === 'failed') {\n    retryHealthSnapshot.failed++;\n  }\n}\n\nfunction refreshRetryHealthSnapshot(stats: RetryStats): void {\n  retryHealthSnapshot.pending = stats.pending;\n  retryHealthSnapshot.failed = stats.failed;\n  retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n  retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n  retryHealthSnapshot.queueDepth = stats.queue_size;\n}\n\nfunction enforceRetryRetentionLimits(\n  maxPending = getMaxRetryQueuePending(),\n  maxAgeMs = getMaxRetryQueueAgeMs(),\n  now: Date = new Date(),\n): { expired: number; overflow: number } {\n  const db = vectorIndex.getDb();\n  if (!db) return { expired: 0, overflow: 0 };\n\n  const nowIso = now.toISOString();\n  const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n  // Retention is non-destructive for never-attempted clean `pending` rows.\n  // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n  // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n  // embedded instead of being parked as `failed` before the drain can claim it.\n  const expired = db.prepare(`\n    UPDATE memory_index\n    SET embedding_status = 'failed',\n        failure_reason = 'Retry retention max age exceeded',\n        updated_at = ?\n    WHERE embedding_status IN ('pending', 'retry')\n      AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n      AND COALESCE(last_retry_at, created_at, updated_at) < ?\n  `).run(nowIso, oldestAllowedIso).changes;\n\n  const rows = db.prepare(`\n    SELECT id FROM memory_index\n    WHERE embedding_status IN ('pending', 'retry')\n      AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n    ORDER BY COALESCE(last_retry_at, created_at, updated_at) ASC, id ASC\n    LIMIT -1 OFFSET ?\n  `).all(maxPending) as Array<{ id: number }>;\n\n  let overflow = 0;\n  if (rows.length > 0) {\n    const updateOverflow = db.prepare(`\n      UPDATE memory_index\n      SET embedding_status = 'failed',\n          failure_reason = 'Retry retention pending cap exceeded',\n          updated_at = ?\n      WHERE id = ?\n        AND embedding_status IN ('pending', 'retry')\n        AND (embedding_status = 'retry' OR COALESCE(retry_count, 0) > 0)\n    `);\n    const txn = db.transaction((ids: number[]) => {\n      for (const id of ids) {\n        overflow += updateOverflow.run(nowIso, id).changes;\n      }\n    });\n    txn(rows.map((row) => row.id));\n  }\n\n  if (expired > 0 || overflow > 0) {\n    console.warn(`[retry-manager] Retention pruned expired=${expired}, overflow=${overflow}`);\n  }\n\n  return { expired, overflow };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. RETRY QUEUE\n──────────────────────────────────────────────────────────────── */\n\nfunction getRetryQueue(limit = 10): RetryMemoryRow[] {\n  vectorIndex.initializeDb();\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up.');\n    return [];\n  }\n  enforceRetryRetentionLimits();\n  const now = Date.now();\n\n  const rows = db.prepare(`\n    SELECT * FROM memory_index\n    WHERE embedding_status IN ('pending', 'retry')\n      AND retry_count < ?\n    ORDER BY\n      CASE WHEN embedding_status = 'pending' THEN 0 ELSE 1 END,\n      retry_count ASC,\n      created_at ASC\n    LIMIT ?\n  `).all(MAX_RETRIES, limit * 2) as RetryMemoryRow[];\n\n  const eligible: RetryMemoryRow[] = [];\n  for (const row of rows) {\n    if (isEligibleForRetry(row, now)) {\n      eligible.push(parseRow(row));\n      if (eligible.length >= limit) break;\n    }\n  }\n\n  return eligible;\n}\n\nfunction isEligibleForRetry(row: RetryMemoryRow, now: number): boolean {\n  // Note: better-sqlite3 returns snake_case column names from SELECT *\n  if (row.embedding_status === 'pending') return true;\n\n  if (row.embedding_status === 'retry' && row.last_retry_at) {\n    const lastRetry = new Date(row.last_retry_at).getTime();\n    const retryCount = (row.retry_count as number) ?? (row.retryCount as number) ?? 0;\n    // Off-by-one fix: retryCount is already incremented after the failure that triggered\n    // The retry status, so use (retryCount - 1) for the backoff index. First retry (retryCount=1)\n    // Should use BACKOFF_DELAYS[0] (1 minute), not BACKOFF_DELAYS[1] (5 minutes).\n    const backoffIndex = Math.max(0, retryCount - 1);\n    const requiredDelay = BACKOFF_DELAYS[Math.min(backoffIndex, BACKOFF_DELAYS.length - 1)];\n    return (now - lastRetry) >= requiredDelay;\n  }\n\n  return row.embedding_status === 'retry';\n}\n\nfunction getFailedEmbeddings(): RetryMemoryRow[] {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning empty array.');\n    return [];\n  }\n\n  const rows = db.prepare(`\n    SELECT * FROM memory_index\n    WHERE embedding_status = 'failed'\n    ORDER BY updated_at DESC\n  `).all() as RetryMemoryRow[];\n\n  return rows.map(parseRow);\n}\n\nfunction getRetryStats(): RetryStats {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning default stats.');\n    return { pending: 0, retry: 0, failed: 0, success: 0, total: 0, queue_size: 0 };\n  }\n\n  const stats = db.prepare(`\n    SELECT\n      SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n      SUM(CASE WHEN embedding_status = 'retry' THEN 1 ELSE 0 END) as retry,\n      SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed,\n      SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as success,\n      COUNT(*) as total\n    FROM memory_index\n  `).get() as Record<string, number>;\n\n  const result = {\n    pending: stats.pending || 0,\n    retry: stats.retry || 0,\n    failed: stats.failed || 0,\n    success: stats.success || 0,\n    total: stats.total || 0,\n    queue_size: (stats.pending || 0) + (stats.retry || 0),\n  };\n\n  refreshRetryHealthSnapshot(result);\n  return result;\n}\n\n/**\n * Return a lightweight in-memory snapshot of embedding retry health.\n * PULL accessor — synchronous, zero DB access, always safe to call.\n * Returns zero-state when the retry manager has not yet been initialized.\n */\nfunction getEmbeddingRetryStats(): EmbeddingRetryStats {\n  return {\n    pending: retryHealthSnapshot.pending,\n    failed: retryHealthSnapshot.failed,\n    retryAttempts: totalRetryAttempts,\n    circuitBreakerOpen: isProviderCircuitOpen(),\n    lastRun: lastBackgroundRunAt,\n    queueDepth: retryHealthSnapshot.queueDepth,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. RETRY OPERATIONS\n──────────────────────────────────────────────────────────────── */\n\nasync function retryEmbedding(\n  id: number,\n  content: string,\n  claimedPreviousStatus: RetryQueueStatus | null = null,\n): Promise<RetryResult> {\n  const db = vectorIndex.getDb();\n  if (!db) return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n\n  const now = new Date().toISOString();\n\n  try {\n    const memory = vectorIndex.getMemory(id);\n    if (!memory) return { success: false, error: 'Memory not found' };\n    const previousStatus = claimedPreviousStatus ?? (\n      typeof memory.embedding_status === 'string'\n        ? memory.embedding_status\n        : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n          ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n          : null\n    );\n\n    if ((memory.retry_count as number) >= MAX_RETRIES) {\n      markAsFailed(id, 'Maximum retry attempts exceeded');\n      return { success: false, error: 'Maximum retries exceeded', permanent: true };\n    }\n\n    // Normalize content before embedding to match sync save path (memory-save.ts:1119).\n    // Without this, async-saved memories get embeddings from raw markdown (YAML frontmatter, HTML\n    // Comments, code fences) while sync-saved memories get clean normalized embeddings.\n    const normalizedContent = normalizeContentForEmbedding(content);\n    const modelId = getModelName();\n    const embeddingDim = getEmbeddingDimension();\n    const contentHash = computeContentHash(normalizedContent);\n    const cachedEmbedding = lookupEmbedding(db, contentHash, modelId, embeddingDim);\n\n    let embedding: Float32Array | null = null;\n\n    if (cachedEmbedding) {\n      embedding = new Float32Array(\n        cachedEmbedding.buffer,\n        cachedEmbedding.byteOffset,\n        Math.floor(cachedEmbedding.byteLength / Float32Array.BYTES_PER_ELEMENT),\n      );\n    } else {\n      // Skip API call if provider circuit breaker is open\n      if (isProviderCircuitOpen()) {\n        return { success: false, error: 'Embedding provider circuit breaker open — skipping API call' };\n      }\n\n      try {\n        embedding = await generateDocumentEmbedding(normalizedContent);\n      } catch (providerError: unknown) {\n        const sanitizedError = sanitizeAndLogEmbeddingFailure(\n          `[retry-manager] Embedding retry failed for #${id}`,\n          providerError,\n          { provider: modelId, force: true },\n        ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n        recordProviderFailure();\n        // Security: raw provider errors sanitized before persistence/response\n        incrementRetryCount(id, sanitizedError);\n        return { success: false, error: sanitizedError };\n      }\n\n      if (embedding) {\n        recordProviderSuccess();\n        storeEmbedding(\n          db,\n          contentHash,\n          modelId,\n          Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n          embedding.length,\n        );\n      } else {\n        recordProviderFailure();\n      }\n    }\n\n    if (!embedding) {\n      incrementRetryCount(id, 'Embedding generation returned null');\n      return { success: false, error: 'Embedding returned null' };\n    }\n\n    const updateTx = db.transaction(() => {\n      db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'success',\n            embedding_generated_at = ?,\n            updated_at = ?,\n            failure_reason = NULL\n        WHERE id = ?\n      `).run(now, now, id);\n\n      try {\n        db.prepare('DELETE FROM vec_memories WHERE rowid = ?').run(BigInt(id));\n      } catch (_error: unknown) {\n        // Ignore if doesn't exist\n      }\n\n      const embeddingBuffer = Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength);\n      db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)').run(BigInt(id), embeddingBuffer);\n    });\n\n    try {\n      updateTx();\n      applyRetryHealthTransition(previousStatus, 'success');\n      return { success: true, id, dimensions: embedding.length };\n    } catch (tx_error: unknown) {\n      // Security: raw provider errors sanitized before persistence/response\n      console.error(`[retry-manager] Transaction error for #${id}:`, tx_error instanceof Error ? tx_error.message : String(tx_error));\n      incrementRetryCount(id, 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)');\n      return { success: false, error: 'EMBEDDING_PROVIDER_ERROR (provider=system, type=transaction_failed)' };\n    }\n  } catch (error: unknown) {\n    recordProviderFailure();\n    // Security: raw provider errors sanitized before persistence/response\n    const sanitizedMessage = sanitizeAndLogEmbeddingFailure(\n      `[retry-manager] Unexpected retry error for #${id}`,\n      error,\n      { provider: null, force: true },\n    ) ?? 'EMBEDDING_PROVIDER_ERROR (provider=unknown, type=provider_error)';\n    incrementRetryCount(id, sanitizedMessage);\n    return { success: false, error: sanitizedMessage };\n  }\n}\n\nfunction incrementRetryCount(id: number, reason: string): void {\n  totalRetryAttempts++;\n  const db = vectorIndex.getDb();\n  if (!db) return;\n\n  const now = new Date().toISOString();\n  const memory = vectorIndex.getMemory(id);\n  if (!memory) {\n    console.warn(`[retry-manager] Memory ${id} not found during retry count increment`);\n    return;\n  }\n\n  const newRetryCount = (Number(memory.retry_count) || 0) + 1;\n  // Security: raw provider errors sanitized before persistence/response\n  const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n  const previousStatus = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n      ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n      : null;\n\n  if (newRetryCount >= MAX_RETRIES) {\n    markAsFailed(id, reason);\n  } else {\n    db.prepare(`\n      UPDATE memory_index\n      SET embedding_status = 'retry',\n          retry_count = ?,\n          last_retry_at = ?,\n          failure_reason = ?,\n          updated_at = ?\n      WHERE id = ?\n    `).run(newRetryCount, now, persistedReason, now, id);\n    applyRetryHealthTransition(previousStatus, 'retry');\n  }\n}\n\nfunction markAsFailed(id: number, reason: string): void {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Cannot mark as failed.');\n    return;\n  }\n  const now = new Date().toISOString();\n  const memory = vectorIndex.getMemory(id);\n  // Security: raw provider errors sanitized before persistence/response\n  const persistedReason = sanitizeEmbeddingFailureMessage(reason) ?? reason;\n  const previousStatus = memory && typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n      ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n      : null;\n\n  db.prepare(`\n    UPDATE memory_index\n    SET embedding_status = 'failed',\n        failure_reason = ?,\n        updated_at = ?\n    WHERE id = ?\n  `).run(persistedReason, now, id);\n  applyRetryHealthTransition(previousStatus, 'failed');\n}\n\nfunction resetForRetry(id: number): boolean {\n  const db = vectorIndex.getDb();\n  if (!db) return false;\n  const now = new Date().toISOString();\n  const memory = vectorIndex.getMemory(id);\n  const previousStatus = memory && typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : memory && typeof (memory as { embeddingStatus?: unknown }).embeddingStatus === 'string'\n      ? (memory as { embeddingStatus?: string }).embeddingStatus ?? null\n      : null;\n\n  const result = db.prepare(`\n    UPDATE memory_index\n    SET embedding_status = 'retry',\n        retry_count = 0,\n        last_retry_at = NULL,\n        failure_reason = NULL,\n        updated_at = ?\n    WHERE id = ? AND embedding_status = 'failed'\n  `).run(now, id);\n\n  if (result.changes > 0) {\n    applyRetryHealthTransition(previousStatus, 'retry');\n  }\n\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. BATCH PROCESSING\n──────────────────────────────────────────────────────────────── */\n\nasync function processRetryQueue(limit = 3, contentLoader: ContentLoader | null = null): Promise<BatchResult> {\n  if (shutdownRequested || retryAbortController?.signal.aborted) {\n    return { processed: 0, succeeded: 0, failed: 0, details: [] };\n  }\n\n  const queue = getRetryQueue(limit);\n\n  if (queue.length === 0) {\n    return { processed: 0, succeeded: 0, failed: 0 };\n  }\n\n  const results: BatchResult = {\n    processed: 0,\n    succeeded: 0,\n    failed: 0,\n    details: [],\n  };\n  const details = results.details ?? (results.details = []);\n\n  for (const memory of queue) {\n    if (shutdownRequested || retryAbortController?.signal.aborted) {\n      break;\n    }\n\n    // For items that have never been attempted (pending), check provider state first.\n    // Claiming a pending item promotes it to retry, which is subject to retention pruning.\n    // During an outage, leave pending rows as-is so they are not pruned before the drain can embed them.\n    if (memory.embedding_status === 'pending' && isProviderCircuitOpen()) {\n      continue;\n    }\n\n    const claim = claimRetryCandidate(memory);\n    if (!claim.claimed) {\n      continue;\n    }\n\n    let content: string | null = null;\n\n    if (contentLoader) {\n      content = await contentLoader(memory);\n    } else if (typeof memory.content_text === 'string' && memory.content_text.length > 0) {\n      // Use stored content_text — critical for chunks which share file_path with parent\n      content = memory.content_text;\n    } else {\n      content = await loadContentFromFile(memory.file_path);\n    }\n\n    if (shutdownRequested || retryAbortController?.signal.aborted) {\n      break;\n    }\n\n    if (!content) {\n      // Count content load failure as a retry attempt to prevent infinite retry loops\n      incrementRetryCount(memory.id, 'Content load failed: file unreadable or missing');\n      details.push({ id: memory.id, success: false, error: 'Could not load content (counted as retry)' });\n      results.failed++;\n      results.processed++;\n      continue;\n    }\n\n    const result = await retryEmbedding(memory.id, content, claim.previousStatus);\n    results.processed++;\n\n    if (result.success) {\n      results.succeeded++;\n    } else {\n      results.failed++;\n    }\n\n    details.push({ id: memory.id, ...result } as RetryDetailEntry);\n  }\n\n  return results;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. BACKGROUND RETRY JOB\n──────────────────────────────────────────────────────────────── */\n\nfunction startBackgroundJob(options: Partial<BackgroundJobConfig> = {}): boolean {\n  if (backgroundJobInterval) {\n    console.error('[retry-manager] Background job already running');\n    return false;\n  }\n\n  const config = { ...BACKGROUND_JOB_CONFIG, ...options };\n  shutdownRequested = false;\n  retryAbortController = new AbortController();\n\n  if (!config.enabled) {\n    console.error('[retry-manager] Background job is disabled');\n    return false;\n  }\n\n  console.error(`[retry-manager] Starting background retry job (interval: ${config.intervalMs}ms, batch: ${config.batchSize})`);\n\n  runBackgroundJob(config.batchSize).catch((err: unknown) => {\n    const message = err instanceof Error ? err.message : String(err);\n    console.error('[retry-manager] Initial background job failed:', message);\n  });\n\n  backgroundJobInterval = registerInterval(() => {\n    runBackgroundJob(config.batchSize).catch((err: unknown) => {\n      const message = err instanceof Error ? err.message : String(err);\n      console.error('[retry-manager] Background job iteration failed:', message);\n    });\n  }, config.intervalMs, { unref: true });\n\n  return true;\n}\n\nfunction stopBackgroundJob(): boolean {\n  shutdownRequested = true;\n  retryAbortController?.abort();\n  retryAbortController = null;\n  if (!backgroundJobInterval) return false;\n\n  clearRegisteredTimer(backgroundJobInterval);\n  backgroundJobInterval = null;\n  backgroundJobRunning = false;\n  console.error('[retry-manager] Background retry job stopped');\n  return true;\n}\n\nfunction isBackgroundJobRunning(): boolean {\n  return backgroundJobInterval !== null;\n}\n\nasync function runBackgroundJob(batchSize: number = BACKGROUND_JOB_CONFIG.batchSize): Promise<BackgroundJobResult> {\n  if (backgroundJobRunning) {\n    return { skipped: true, reason: 'Previous run still in progress' };\n  }\n\n  backgroundJobRunning = true;\n  if (!retryAbortController || retryAbortController.signal.aborted) {\n    retryAbortController = new AbortController();\n  }\n\n  // Held only while a tick has real work; the empty-queue path below never creates\n  // a handle, so an idle tick leaves the daemon reapable.\n  let maintenanceHandle: MaintenanceMarkerHandle | null = null;\n  try {\n    enforceRetryRetentionLimits();\n    if (shutdownRequested || retryAbortController.signal.aborted) {\n      return { skipped: true, reason: 'Shutdown requested' };\n    }\n    const stats = getRetryStats();\n\n    if (stats.queue_size === 0) {\n      return { processed: 0, queue_empty: true };\n    }\n\n    // The deferred-embedding burst keeps the daemon busy; mark it busy-by-design so\n    // a competing launcher adopts it rather than reaping it mid-drain.\n    maintenanceHandle = beginMaintenance('embedding-queue');\n    console.error(`[retry-manager] Background job: Processing up to ${batchSize} of ${stats.queue_size} pending embeddings`);\n\n    const result = await processRetryQueue(batchSize);\n\n    if (result.processed > 0) {\n      console.error(`[retry-manager] Background job complete: ${result.succeeded}/${result.processed} succeeded`);\n    }\n\n    return result;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error('[retry-manager] Background job error:', message);\n    return { error: message };\n  } finally {\n    // Release the busy mark on every exit (success, error). The empty-queue path\n    // never set it, so this is a safe no-op there; end() is idempotent regardless.\n    maintenanceHandle?.end();\n    lastBackgroundRunAt = new Date().toISOString();\n    retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n    retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n    retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n    backgroundJobRunning = false;\n  }\n}\n\nregisterShutdownHook(() => {\n  stopBackgroundJob();\n}, { timeoutMs: 250 });\n\n/* ───────────────────────────────────────────────────────────────\n   7. UTILITIES\n──────────────────────────────────────────────────────────────── */\n\nfunction parseRow(row: RetryMemoryRow): RetryMemoryRow {\n  if (row.triggerPhrases && typeof row.triggerPhrases === 'string') {\n    try {\n      return { ...row, triggerPhrases: JSON.parse(row.triggerPhrases) };\n    } catch (_error: unknown) {\n      return { ...row, triggerPhrases: [] };\n    }\n  }\n  return { ...row };\n}\n\nasync function loadContentFromFile(filePath: string): Promise<string | null> {\n  try {\n    return await fsPromises.readFile(filePath, 'utf-8');\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nasync function claimAndRetryEmbedding(\n  id: number,\n  content: string,\n  expectedStatus: RetryQueueStatus = 'pending',\n): Promise<RetryResult | null> {\n  const memory = vectorIndex.getMemory(id) as RetryMemoryRow | undefined;\n  if (!memory) {\n    return { success: false, error: 'Memory not found' };\n  }\n\n  const parsedMemory = parseRow(memory);\n  if (getRetryStatus(parsedMemory) !== expectedStatus) {\n    return null;\n  }\n\n  const claim = claimRetryCandidate(parsedMemory);\n  if (!claim.claimed) {\n    return null;\n  }\n\n  return retryEmbedding(id, content, claim.previousStatus);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  getRetryQueue,\n  getFailedEmbeddings,\n  getRetryStats,\n  getEmbeddingRetryStats,\n  getCircuitFlapState,\n  retryEmbedding,\n  claimAndRetryEmbedding,\n  markAsFailed,\n  resetForRetry,\n  processRetryQueue,\n  startBackgroundJob,\n  stopBackgroundJob,\n  isBackgroundJobRunning,\n  runBackgroundJob,\n  enforceRetryRetentionLimits,\n  BACKGROUND_JOB_CONFIG,\n  BACKOFF_DELAYS,\n  MAX_RETRIES,\n  MAX_RETRY_QUEUE_PENDING,\n  MAX_RETRY_QUEUE_AGE_MS,\n  getMaxRetryQueuePending,\n  getMaxRetryQueueAgeMs,\n};","lineStart":1,"lineEnd":1141,"totalLines":1141,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781763080628,"end":1781763080640}},"metadata":{"openai":{"itemId":"fc_0772a166e6b2003e016a338c06e8548191bd58141ecd6470ab"}},"id":"prt_ed95b01b3001V8nFsIDXRBARv3","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95ac290001Wbuv974LwSxSrP"}}
