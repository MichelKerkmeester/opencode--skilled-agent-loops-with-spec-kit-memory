{
  "profileId": "kimi-k2.7-frameworks",
  "id": "kimi-k2.7-frameworks",
  "version": "1.0",
  "family": "deep-improvement",
  "mode": "framework-bakeoff",
  "fixtureDir": ".opencode/skills/deep-loop-workflows/deep-improvement/assets/model_benchmark/benchmark-fixtures",
  "fixtures": ["t3-lower-bound", "t3-compare-versions"],
  "fixtureSelection": {
    "include": ["t3-lower-bound", "t3-compare-versions"],
    "filters": { "tier": ["T3"] }
  },
  "frameworks": ["rcaf", "race", "cidi", "tidd-ec", "costar"],
  "models": [
    { "executor": "cli-opencode", "provider": "kimi-for-coding", "model_slug": "k2p7", "variant": "default" }
  ],
  "scoring": {
    "scorer": "5dim",
    "correctnessGate": { "threshold": 1.0 },
    "dimensions": [
      { "id": "D1", "weight": 0.25 },
      { "id": "D2", "weight": 0.3 },
      { "id": "D3", "weight": 0.2 },
      { "id": "D4", "weight": 0.15 },
      { "id": "D5", "weight": 0.1 }
    ]
  },
  "sampling": { "samplesPerCell": 3, "seed": 1729 },
  "reporting": { "groupBy": "framework", "leaderboard": true, "history": true },
  "outputsDir": "{spec_folder}/improvement/benchmark-outputs",
  "metrics": ["score", "delta", "pass_rate"],
  "thresholdDelta": 0.05,
  "benchmark": {
    "requiredAggregateScore": 80,
    "minimumFixtureScore": 70,
    "repeatabilityTolerance": 0
  }
}
