_K|MAX_SEARCH_TOP_K|SEARCH_OVERFETCH_FACTOR|SIMILARITY_BLEND|FTS_WEIGHT|FTS_WEIGHT_BOOSTED|MIN_SEARCH_SIMILARITY|GRAPH_MAX_HOPS|GRAPH_MAX_BOOSTED_MEMORIES|RECALL_BOOST_CAP|FRESHNESS","time":{"start":1780727811462,"end":1780727811467}},"metadata":{"openai":{"itemId":"fc_0713ba13c97d71a1016a23c0036b888191a71413f25e545442"}},"id":"prt_e9ba60d810014d7aRy617NU4HG","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba5e510001QqqXjbYHdeASii"}}
{"type":"tool_use","timestamp":1780727811525,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"grep","callID":"call_Nf4n1lMWYjpzXUAAcs8shheW","state":{"status":"completed","input":{"pattern":"DEFAULT_SEARCH_TOP_K|MAX_SEARCH_TOP_K|SEARCH_OVERFETCH_FACTOR|SIMILARITY_BLEND|FTS_WEIGHT|FTS_WEIGHT_BOOSTED|MIN_SEARCH_SIMILARITY|GRAPH_MAX_HOPS|GRAPH_MAX_BOOSTED_MEMORIES|RECALL_BOOST_CAP|FRESHNESS","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/constants.py","include":"*.py"},"output":"Found 1 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/constants.py:\n  Line 62: GRAPH_MAX_HOPS = 2  # max relation hops to expand during search\n","metadata":{"matches":1,"truncated":false},"title":"DEFAULT_SEARCH_TOP_K|MAX_SEARCH_TOP_K|SEARCH_OVERFETCH_FACTOR|SIMILARITY_BLEND|FTS_WEIGHT|FTS_WEIGHT_BOOSTED|MIN_SEARCH_SIMILARITY|GRAPH_MAX_HOPS|GRAPH_MAX_BOOSTED_MEMORIES|RECALL_BOOST_CAP|FRESHNESS","time":{"start":1780727811503,"end":1780727811523}},"metadata":{"openai":{"itemId":"fc_0713ba13c97d71a1016a23c0036b988191b8c4b8f3eab7f2dc"}},"id":"prt_e9ba60d89001RwofTc51Xt4Yb3","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba5e510001QqqXjbYHdeASii"}}
{"type":"tool_use","timestamp":1780727811609,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_1WqxYtpRROglviH3JsGRoRbl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/constants.py","offset":1,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/constants.py</path>\n<type>file</type>\n<content>\n1: \"\"\"DB-query constants shared between core-api and core-storage-api.\"\"\"\n2: \n3: # ── Embeddings ──\n4: # Native dim of the default embedder (BAAI/bge-m3, see local-embedder docs).\n5: # Schema upgrade lives in alembic migration 012_vector_dim_1024.py — keep\n6: # this constant in lock-step with that migration.\n7: VECTOR_DIM = 1024\n8: \n9: # ── Write-time semantic dedup ──\n10: SEMANTIC_DEDUP_THRESHOLD = 0.95  # cosine similarity above this -> near-duplicate\n11: SEMANTIC_DEDUP_CANDIDATE_LIMIT = 1  # only need to know if any match exists\n12: \n13: # Two-tier dedup constants (A1 #15). The dispatch that consumes them\n14: # lives in A1 #16. Today's single-tier code keeps using\n15: # ``SEMANTIC_DEDUP_THRESHOLD`` above — this PR adds the band cutoffs\n16: # without changing any call site.\n17: #\n18: # Decision band (cosine similarity to nearest existing memory):\n19: #   ≥ AUTO          → auto-reject (clear duplicate; no LLM)\n20: #   JUDGE ≤ s < AUTO → LLM judge decides (A1 #16; A4 #12 verdict+confidence)\n21: #   < JUDGE         → accept (not a dup)\n22: SEMANTIC_DEDUP_AUTO_THRESHOLD = 0.97  # auto-reject band — tighter than the\n23: # legacy 0.95 so refinements (same first sentence + extra detail) drop into\n24: # the judge band rather than getting silently rejected.\n25: SEMANTIC_DEDUP_JUDGE_THRESHOLD = 0.85  # broad enough to catch refinements,\n26: # tight enough that the LLM judge isn't swamped with unrelated memories that\n27: # happen to share vocabulary.\n28: \n29: # ── Contradiction detection ──\n30: CONTRADICTION_SIMILARITY_THRESHOLD = (\n31:     0.70  # cosine similarity above this triggers LLM check\n32: )\n33: CONTRADICTION_CANDIDATE_MAX = (\n34:     8  # max similar memories to check (LLM is the quality gate)\n35: )\n36: \n37: # ── Recall boost ──\n38: RECALL_BOOST_SCALE = 10  # recalls needed to reach half of max boost\n39: \n40: # ── Per-type decay windows ──\n41: TYPE_DECAY_DAYS: dict[str, int] = {\n42:     \"preference\": 365,\n43:     \"decision\": 180,\n44:     \"fact\": 120,\n45:     \"semantic\": 120,\n46:     \"commitment\": 120,\n47:     \"outcome\": 90,\n48:     \"plan\": 60,\n49:     \"intention\": 60,\n50:     \"episode\": 45,\n51:     \"task\": 30,\n52:     \"action\": 30,\n53:     \"cancellation\": 14,\n54:     \"rule\": 365,\n55:     \"insight\": 90,\n56: }\n57: \n58: # ── Entity resolution (embedding-based) ──\n59: ENTITY_RESOLUTION_CANDIDATE_LIMIT = 3  # max candidates to evaluate\n60: \n61: # ── Knowledge graph ──\n62: GRAPH_MAX_HOPS = 2  # max relation hops to expand during search\n63: GRAPH_MAX_EXPANDED_ENTITIES = (\n64:     200  # cap on entity IDs in the IN clause after graph expansion\n65: )\n66: \n67: # Relation-type weights: strong semantic relations boost more than structural ones.\n68: RELATION_TYPE_WEIGHTS: dict[str, float] = {\n69:     # Strong -- direct actionable connections\n70:     \"manages\": 1.0,\n71:     \"works_on\": 1.0,\n72:     \"created_by\": 1.0,\n73:     \"authored_by\": 1.0,\n74:     \"owns\": 1.0,\n75:     \"leads\": 1.0,\n76:     \"reports_to\": 1.0,\n77:     # Medium -- useful but weaker signal\n78:     \"uses\": 0.7,\n79:     \"depends_on\": 0.7,\n80:     \"belongs_to\": 0.7,\n81:     \"part_of\": 0.7,\n82:     \"related_to\": 0.5,\n83:     \"mentions\": 0.5,\n84:     # Weak -- structural/geographic, rarely query-relevant\n85:     \"located_in\": 0.3,\n86:     \"contains\": 0.3,\n87:     \"instance_of\": 0.3,\n88: }\n89: DEFAULT_RELATION_TYPE_WEIGHT = 0.5  # unknown relation types get neutral weight\n90: \n91: # Predicates where only one value can be true at a time for a given subject.\n92: SINGLE_VALUE_PREDICATES: frozenset[str] = frozenset(\n93:     {\n94:         # -- Identity & status --\n95:         \"named\",\n96:         \"name\",\n97:         \"renamed_to\",\n98:         \"status\",\n99:         \"has_status\",\n100:         \"current_status\",\n101:         \"phase\",\n102:         \"current_phase\",\n103:         \"state\",\n104:         \"current_state\",\n105:         \"role\",\n106:         \"has_role\",\n107:         \"current_role\",\n108:         \"title\",\n109:         \"has_title\",\n110:         \"job_title\",\n111:         \"type\",\n112:         \"has_type\",\n113:         \"category\",\n114:         \"classified_as\",\n115:         \"identified_as\",\n116:         \"labeled_as\",\n117:         # -- Location & position --\n118:         \"lives_in\",\n119:         \"located_in\",\n120:         \"is_located_in\",\n121:         \"location\",\n122:         \"current_location\",\n123:         \"headquartered_in\",\n124:         \"hq_in\",\n125:         \"based_in\",\n126:         \"is_based_in\",\n127:         \"resides_in\",\n128:         \"resides_at\",\n129:         \"stationed_at\",\n130:         \"hosted_on\",\n131:         \"hosted_at\",\n132:         \"is_hosted_on\",\n133:         \"deployed_to\",\n134:         \"deployed_at\",\n135:         \"deployed_on\",\n136:         \"is_deployed_to\",\n137:         \"runs_on\",\n138:         \"running_on\",\n139:         \"stored_in\",\n140:         \"stored_at\",\n141:         \"registered_in\",\n142:         \"registered_at\",\n143:         \"country\",\n144:         \"city\",\n145:         \"region\",\n146:         \"address\",\n147:         # -- Hierarchy & singular roles --\n148:         \"reports_to\",\n149:         \"reporting_to\",\n150:         \"led_by\",\n151:         \"owned_by\",\n152:         \"managed_by\",\n153:         \"manager\",\n154:         \"manager_of\",\n155:         \"headed_by\",\n156:         \"head_of\",\n157:         \"ceo_of\",\n158:         \"ceo\",\n159:         \"cto_of\",\n160:         \"cto\",\n161:         \"cfo_of\",\n162:         \"cfo\",\n163:         \"assigned_to\",\n164:         \"assignee\",\n165:         \"is_assigned_to\",\n166:         \"maintained_by\",\n167:         \"maintainer\",\n168:         \"maintainer_of\",\n169:         \"supervised_by\",\n170:         \"supervisor\",\n\n(Showing lines 1-170 of 388. Use offset=171 to continue.)\n</content>","metadata":{"preview":"\"\"\"DB-query constants shared between core-api and core-storage-api.\"\"\"\n\n# ── Embeddings ──\n# Native dim of the default embedder (BAAI/bge-m3, see local-embedder docs).\n# Schema upgrade lives in alembic migration 012_vector_dim_1024.py — keep\n# this constant in lock-step with that migration.\nVECTOR_DIM = 1024\n\n# ── Write-time semantic dedup ──\nSEMANTIC_DEDUP_THRESHOLD = 0.95  # cosine similarity above this -> near-duplicate\nSEMANTIC_DEDUP_CANDIDATE_LIMIT = 1  # only need to know if any match exists\n\n# Two-tier dedup constants (A1 #15). The dispatch that consumes them\n# lives in A1 #16. Today's single-tier code keeps using\n# ``SEMANTIC_DEDUP_THRESHOLD`` above — this PR adds the band cutoffs\n# without changing any call site.\n#\n# Decision band (cosine similarity to nearest existing memory):\n#   ≥ AUTO          → auto-reject (clear duplicate; no LLM)\n#   JUDGE ≤ s < AUTO → LLM judge decides (A1 #16; A4 #12 verdict+confidence)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/constants.py","text":"\"\"\"DB-query constants shared between core-api and core-storage-api.\"\"\"\n\n# ── Embeddings ──\n# Native dim of the default embedder (BAAI/bge-m3, see local-embedder docs).\n# Schema upgrade lives in alembic migration 012_vector_dim_1024.py — keep\n# this constant in lock-step with that migration.\nVECTOR_DIM = 1024\n\n# ── Write-time semantic dedup ──\nSEMANTIC_DEDUP_THRESHOLD = 0.95  # cosine similarity above this -> near-duplicate\nSEMANTIC_DEDUP_CANDIDATE_LIMIT = 1  # only need to know if any match exists\n\n# Two-tier dedup constants (A1 #15). The dispatch that consumes them\n# lives in A1 #16. Today's single-tier code keeps using\n# ``SEMANTIC_DEDUP_THRESHOLD`` above — this PR adds the band cutoffs\n# without changing any call site.\n#\n# Decision band (cosine similarity to nearest existing memory):\n#   ≥ AUTO          → auto-reject (clear duplicate; no LLM)\n#   JUDGE ≤ s < AUTO → LLM judge decides (A1 #16; A4 #12 verdict+confidence)\n#   < JUDGE         → accept (not a dup)\nSEMANTIC_DEDUP_AUTO_THRESHOLD = 0.97  # auto-reject band — tighter than the\n# legacy 0.95 so refinements (same first sentence + extra detail) drop into\n# the judge band rather than getting silently rejected.\nSEMANTIC_DEDUP_JUDGE_THRESHOLD = 0.85  # broad enough to catch refinements,\n# tight enough that the LLM judge isn't swamped with unrelated memories that\n# happen to share vocabulary.\n\n# ── Contradiction detection ──\nCONTRADICTION_SIMILARITY_THRESHOLD = (\n    0.70  # cosine similarity above this triggers LLM check\n)\nCONTRADICTION_CANDIDATE_MAX = (\n    8  # max similar memories to check (LLM is the quality gate)\n)\n\n# ── Recall boost ──\nRECALL_BOOST_SCALE = 10  # recalls needed to reach half of max boost\n\n# ── Per-type decay windows ──\nTYPE_DECAY_DAYS: dict[str, int] = {\n    \"preference\": 365,\n    \"decision\": 180,\n    \"fact\": 120,\n    \"semantic\": 120,\n    \"commitment\": 120,\n    \"outcome\": 90,\n    \"plan\": 60,\n    \"intention\": 60,\n    \"episode\": 45,\n    \"task\": 30,\n    \"action\": 30,\n    \"cancellation\": 14,\n    \"rule\": 365,\n    \"insight\": 90,\n}\n\n# ── Entity resolution (embedding-based) ──\nENTITY_RESOLUTION_CANDIDATE_LIMIT = 3  # max candidates to evaluate\n\n# ── Knowledge graph ──\nGRAPH_MAX_HOPS = 2  # max relation hops to expand during search\nGRAPH_MAX_EXPANDED_ENTITIES = (\n    200  # cap on entity IDs in the IN clause after graph expansion\n)\n\n# Relation-type weights: strong semantic relations boost more than structural ones.\nRELATION_TYPE_WEIGHTS: dict[str, float] = {\n    # Strong -- direct actionable connections\n    \"manages\": 1.0,\n    \"works_on\": 1.0,\n    \"created_by\": 1.0,\n    \"authored_by\": 1.0,\n    \"owns\": 1.0,\n    \"leads\": 1.0,\n    \"reports_to\": 1.0,\n    # Medium -- useful but weaker signal\n    \"uses\": 0.7,\n    \"depends_on\": 0.7,\n    \"belongs_to\": 0.7,\n    \"part_of\": 0.7,\n    \"related_to\": 0.5,\n    \"mentions\": 0.5,\n    # Weak -- structural/geographic, rarely query-relevant\n    \"located_in\": 0.3,\n    \"contains\": 0.3,\n    \"instance_of\": 0.3,\n}\nDEFAULT_RELATION_TYPE_WEIGHT = 0.5  # unknown relation types get neutral weight\n\n# Predicates where only one value can be true at a time for a given subject.\nSINGLE_VALUE_PREDICATES: frozenset[str] = frozenset(\n    {\n        # -- Identity & status --\n        \"named\",\n        \"name\",\n        \"renamed_to\",\n        \"status\",\n        \"has_status\",\n        \"current_status\",\n        \"phase\",\n        \"current_phase\",\n        \"state\",\n        \"current_state\",\n        \"role\",\n        \"has_role\",\n        \"current_role\",\n        \"title\",\n        \"has_title\",\n        \"job_title\",\n        \"type\",\n        \"has_type\",\n        \"category\",\n        \"classified_as\",\n        \"identified_as\",\n        \"labeled_as\",\n        # -- Location & position --\n        \"lives_in\",\n        \"located_in\",\n        \"is_located_in\",\n        \"location\",\n        \"current_location\",\n        \"headquartered_in\",\n        \"hq_in\",\n        \"based_in\",\n        \"is_based_in\",\n        \"resides_in\",\n        \"resides_at\",\n        \"stationed_at\",\n        \"hosted_on\",\n        \"hosted_at\",\n        \"is_hosted_on\",\n        \"deployed_to\",\n        \"deployed_at\",\n        \"deployed_on\",\n        \"is_deployed_to\",\n        \"runs_on\",\n        \"running_on\",\n        \"stored_in\",\n        \"stored_at\",\n        \"registered_in\",\n        \"registered_at\",\n        \"country\",\n        \"city\",\n        \"region\",\n        \"address\",\n        # -- Hierarchy & singular roles --\n        \"reports_to\",\n        \"reporting_to\",\n        \"led_by\",\n        \"owned_by\",\n        \"managed_by\",\n        \"manager\",\n        \"manager_of\",\n        \"headed_by\",\n        \"head_of\",\n        \"ceo_of\",\n        \"ceo\",\n        \"cto_of\",\n        \"cto\",\n        \"cfo_of\",\n        \"cfo\",\n        \"assigned_to\",\n        \"assignee\",\n        \"is_assigned_to\",\n        \"maintained_by\",\n        \"maintainer\",\n        \"maintainer_of\",\n        \"supervised_by\",\n        \"supervisor\",","lineStart":1,"lineEnd":170,"totalLines":388,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/constants.py","time":{"start":1780727811602,"end":1780727811608}},"metadata":{"openai":{"itemId":"fc_0713ba13c97d71a1016a23c0036ba4819192b24df38136341c"}},"id":"prt_e9ba60e10001E8DzAZez3Rradb","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba5e510001QqqXjbYHdeASii"}}
{"type":"tool_use","timestamp":1780727811613,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_SCNabYXFpVlA0NnitDJfEXkL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Centralised constants for the MemClaw API.\"\"\"\n2: \n3: import importlib.metadata\n4: import os\n5: \n6: # Re-export DB-query constants from common (shared with core-storage-api).\n7: from common.constants import (  # noqa: F401\n8:     CONTRADICTION_CANDIDATE_MAX,\n9:     CONTRADICTION_SIMILARITY_THRESHOLD,\n10:     DEFAULT_RELATION_TYPE_WEIGHT,\n11:     ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n12:     GRAPH_MAX_EXPANDED_ENTITIES,\n13:     GRAPH_MAX_HOPS,\n14:     LIFECYCLE_STALE_ARCHIVE_WEIGHT,\n15:     RECALL_BOOST_SCALE,\n16:     RELATION_TYPE_WEIGHTS,\n17:     SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n18:     SEMANTIC_DEDUP_THRESHOLD,\n19:     SINGLE_VALUE_PREDICATES,\n20:     TYPE_DECAY_DAYS,\n21:     VECTOR_DIM,\n22: )\n23: \n24: # Re-export memory-vocabulary constants from common.enrichment (CAURA-595).\n25: # common is the source of truth so core-api and core-worker stay in sync.\n26: from common.enrichment.constants import (  # noqa: F401\n27:     DEFAULT_MEMORY_TYPE,\n28:     DEFAULT_MEMORY_WEIGHT,\n29:     MEMORY_STATUSES,\n30:     MEMORY_TYPE_DESCRIPTIONS,\n31:     MEMORY_TYPES,\n32:     MemoryType,\n33: )\n34: \n35: # Re-export LLM provider constants from common.llm (CAURA-595).\n36: from common.llm.constants import (  # noqa: F401\n37:     ANTHROPIC_CHAT_BASE_URL,\n38:     ANTHROPIC_DEFAULT_MODEL,\n39:     GEMINI_DEFAULT_MODEL,\n40:     LLM_FALLBACK_MODEL_OPENAI,\n41:     LLM_RETRY_ATTEMPTS,\n42:     LLM_RETRY_DELAY_S,\n43:     OPENAI_CHAT_BASE_URL,\n44:     OPENAI_REQUEST_TIMEOUT_SECONDS,\n45:     OPENROUTER_CHAT_BASE_URL,\n46:     OPENROUTER_DEFAULT_MODEL,\n47:     VERTEX_LLM_DEFAULT_MODEL,\n48: )\n49: \n50: \n51: def is_mcp_path(path: str) -> bool:\n52:     \"\"\"True for requests routed to the MCP mount (/mcp, /mcp/*).\n53: \n54:     Middlewares that need to opt out of MCP's long-lived streaming\n55:     semantics (security headers, request-wide timeouts) gate on this.\n56:     \"\"\"\n57:     return path == \"/mcp\" or path.startswith(\"/mcp/\")\n58: \n59: \n60: # ── Version ──\n61: # Source-only dev (PYTHONPATH set but no `pip install -e`) has no\n62: # package metadata; fall back to \"dev\" rather than crashing import.\n63: try:\n64:     VERSION = importlib.metadata.version(\"core-api\")\n65: except importlib.metadata.PackageNotFoundError:\n66:     VERSION = \"dev\"\n67: OPENAI_EMBEDDING_MODEL = os.environ.get(\"OPENAI_EMBEDDING_MODEL\", \"text-embedding-3-small\")\n68: EMBEDDING_RETRY_ATTEMPTS = 2\n69: EMBEDDING_RETRY_DELAY_S = 1.0\n70: EMBEDDING_REEMBED_DELAY_S = 30.0\n71: EMBEDDING_REEMBED_BATCH_SIZE = 50\n72: EMBEDDING_CACHE_TTL = 259200  # 3 days — embeddings are deterministic per model+query\n73: \n74: # ── Memory ──\n75: # Derived from MEMORY_TYPES (the SoT) so adding a new type in\n76: # common/enrichment/constants.py propagates here without hand-editing.\n77: MEMORY_TYPES_PATTERN = \"^(\" + \"|\".join(MEMORY_TYPES) + \")$\"\n78: MEMORY_TYPES_DESCRIPTION = (\n79:     \"Memory type. Auto-classified by LLM if omitted. Valid values: \" + \", \".join(MEMORY_TYPES) + \".\"\n80: )\n81: \n82: # ── Memory status lifecycle ──\n83: MEMORY_STATUSES_PATTERN = (\n84:     r\"^(active|pending|confirmed|cancelled\"\n85:     r\"|outdated|conflicted|archived|deleted)$\"\n86: )\n87: \n88: # ── Health / status probe timeouts ──\n89: # Upper bound on a single dependency probe (storage / redis / event_bus).\n90: # Cloud Run typically gives health checks 10-30s before marking a revision\n91: # unhealthy; we want to fail-fast well before that so a stalled backend\n92: # can't hang the whole probe. Shared between ``/health`` (binary 503 deploy\n93: # gate) and ``/stats`` / ``/status`` (public endpoints with the same posture\n94: # — return ``0`` / \"unreachable\" rather than block landing-page hits).\n95: PROBE_TIMEOUT_SECONDS = 5.0\n96: \n97: # ── Memory visibility levels ──\n98: # Named constants are the SoT — ``MEMORY_VISIBILITIES`` and the regex below\n99: # derive from them so a rename here propagates to membership checks and\n100: # the Pydantic pattern automatically. SQL filters and any other call\n101: # site should import the named constant rather than the bare string so\n102: # a typo turns into a NameError at import time, not a silent miss.\n103: MEMORY_VISIBILITY_SCOPE_AGENT = \"scope_agent\"\n104: MEMORY_VISIBILITY_SCOPE_TEAM = \"scope_team\"\n105: MEMORY_VISIBILITY_SCOPE_ORG = \"scope_org\"\n106: MEMORY_VISIBILITIES = (\n107:     MEMORY_VISIBILITY_SCOPE_AGENT,\n108:     MEMORY_VISIBILITY_SCOPE_TEAM,\n109:     MEMORY_VISIBILITY_SCOPE_ORG,\n110: )\n111: MEMORY_VISIBILITIES_PATTERN = (\n112:     f\"^({MEMORY_VISIBILITY_SCOPE_AGENT}|{MEMORY_VISIBILITY_SCOPE_TEAM}|{MEMORY_VISIBILITY_SCOPE_ORG})$\"\n113: )\n114: \n115: MAX_CONTENT_LENGTH = 10000\n116: CHUNKING_THRESHOLD_CHARS = 2000  # content above this triggers auto-chunking\n117: MAX_QUERY_LENGTH = 5000\n118: \n119: # ── Tool surface bookkeeping ──\n120: # Tool descriptions live inline in `core_api/tools/memclaw_*.py` spec\n121: # modules (the SoT). Nothing else should hold a copy.\n122: # STM tools were dropped in 6fea229; STM_ONLY_TOOLS constant removed.\n123: \n124: # ── Search / ranking ──\n125: DEFAULT_SEARCH_TOP_K = 5\n126: MAX_SEARCH_TOP_K = 20\n127: MIN_SEARCH_SIMILARITY = 0.3\n128: FRESHNESS_DECAY_DAYS = 90\n129: FRESHNESS_FLOOR = 0.7\n130: ENTITY_BOOST_FACTOR = 1.3\n131: ENTITY_TOKEN_MIN_LENGTH = 2  # A7: was 3; lowered to retain 2-char acronym\n132: # entities (``AI`` / ``ML`` / ``PR`` / ``UI`` / ``QA`` / ``HR`` /\n133: # ``UK`` / ``US``…). 2-char English fillers (``in`` / ``on`` / ``to``\n134: # / ``be`` / ``is``…) are already in ENTITY_STOPWORDS so the noise\n135: # floor is unchanged; single-letter tokens still drop via the >=2\n136: # check.\n137: ENTITY_STOPWORDS: frozenset[str] = frozenset(\n138:     {\n139:         # ── Determiners / articles ──\n140:         \"the\",\n141:         \"a\",\n142:         \"an\",\n143:         \"this\",\n144:         \"that\",\n145:         \"these\",\n146:         \"those\",\n147:         \"my\",\n148:         \"your\",\n149:         \"his\",\n150:         \"her\",\n151:         \"its\",\n152:         \"our\",\n153:         \"their\",\n154:         \"some\",\n155:         \"any\",\n156:         \"each\",\n157:         \"every\",\n158:         \"all\",\n159:         \"both\",\n160:         # ── Pronouns ──\n\n(Showing lines 1-160 of 638. Use offset=161 to continue.)\n</content>","metadata":{"preview":"\"\"\"Centralised constants for the MemClaw API.\"\"\"\n\nimport importlib.metadata\nimport os\n\n# Re-export DB-query constants from common (shared with core-storage-api).\nfrom common.constants import (  # noqa: F401\n    CONTRADICTION_CANDIDATE_MAX,\n    CONTRADICTION_SIMILARITY_THRESHOLD,\n    DEFAULT_RELATION_TYPE_WEIGHT,\n    ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n    GRAPH_MAX_EXPANDED_ENTITIES,\n    GRAPH_MAX_HOPS,\n    LIFECYCLE_STALE_ARCHIVE_WEIGHT,\n    RECALL_BOOST_SCALE,\n    RELATION_TYPE_WEIGHTS,\n    SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n    SEMANTIC_DEDUP_THRESHOLD,\n    SINGLE_VALUE_PREDICATES,\n    TYPE_DECAY_DAYS,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","text":"\"\"\"Centralised constants for the MemClaw API.\"\"\"\n\nimport importlib.metadata\nimport os\n\n# Re-export DB-query constants from common (shared with core-storage-api).\nfrom common.constants import (  # noqa: F401\n    CONTRADICTION_CANDIDATE_MAX,\n    CONTRADICTION_SIMILARITY_THRESHOLD,\n    DEFAULT_RELATION_TYPE_WEIGHT,\n    ENTITY_RESOLUTION_CANDIDATE_LIMIT,\n    GRAPH_MAX_EXPANDED_ENTITIES,\n    GRAPH_MAX_HOPS,\n    LIFECYCLE_STALE_ARCHIVE_WEIGHT,\n    RECALL_BOOST_SCALE,\n    RELATION_TYPE_WEIGHTS,\n    SEMANTIC_DEDUP_CANDIDATE_LIMIT,\n    SEMANTIC_DEDUP_THRESHOLD,\n    SINGLE_VALUE_PREDICATES,\n    TYPE_DECAY_DAYS,\n    VECTOR_DIM,\n)\n\n# Re-export memory-vocabulary constants from common.enrichment (CAURA-595).\n# common is the source of truth so core-api and core-worker stay in sync.\nfrom common.enrichment.constants import (  # noqa: F401\n    DEFAULT_MEMORY_TYPE,\n    DEFAULT_MEMORY_WEIGHT,\n    MEMORY_STATUSES,\n    MEMORY_TYPE_DESCRIPTIONS,\n    MEMORY_TYPES,\n    MemoryType,\n)\n\n# Re-export LLM provider constants from common.llm (CAURA-595).\nfrom common.llm.constants import (  # noqa: F401\n    ANTHROPIC_CHAT_BASE_URL,\n    ANTHROPIC_DEFAULT_MODEL,\n    GEMINI_DEFAULT_MODEL,\n    LLM_FALLBACK_MODEL_OPENAI,\n    LLM_RETRY_ATTEMPTS,\n    LLM_RETRY_DELAY_S,\n    OPENAI_CHAT_BASE_URL,\n    OPENAI_REQUEST_TIMEOUT_SECONDS,\n    OPENROUTER_CHAT_BASE_URL,\n    OPENROUTER_DEFAULT_MODEL,\n    VERTEX_LLM_DEFAULT_MODEL,\n)\n\n\ndef is_mcp_path(path: str) -> bool:\n    \"\"\"True for requests routed to the MCP mount (/mcp, /mcp/*).\n\n    Middlewares that need to opt out of MCP's long-lived streaming\n    semantics (security headers, request-wide timeouts) gate on this.\n    \"\"\"\n    return path == \"/mcp\" or path.startswith(\"/mcp/\")\n\n\n# ── Version ──\n# Source-only dev (PYTHONPATH set but no `pip install -e`) has no\n# package metadata; fall back to \"dev\" rather than crashing import.\ntry:\n    VERSION = importlib.metadata.version(\"core-api\")\nexcept importlib.metadata.PackageNotFoundError:\n    VERSION = \"dev\"\nOPENAI_EMBEDDING_MODEL = os.environ.get(\"OPENAI_EMBEDDING_MODEL\", \"text-embedding-3-small\")\nEMBEDDING_RETRY_ATTEMPTS = 2\nEMBEDDING_RETRY_DELAY_S = 1.0\nEMBEDDING_REEMBED_DELAY_S = 30.0\nEMBEDDING_REEMBED_BATCH_SIZE = 50\nEMBEDDING_CACHE_TTL = 259200  # 3 days — embeddings are deterministic per model+query\n\n# ── Memory ──\n# Derived from MEMORY_TYPES (the SoT) so adding a new type in\n# common/enrichment/constants.py propagates here without hand-editing.\nMEMORY_TYPES_PATTERN = \"^(\" + \"|\".join(MEMORY_TYPES) + \")$\"\nMEMORY_TYPES_DESCRIPTION = (\n    \"Memory type. Auto-classified by LLM if omitted. Valid values: \" + \", \".join(MEMORY_TYPES) + \".\"\n)\n\n# ── Memory status lifecycle ──\nMEMORY_STATUSES_PATTERN = (\n    r\"^(active|pending|confirmed|cancelled\"\n    r\"|outdated|conflicted|archived|deleted)$\"\n)\n\n# ── Health / status probe timeouts ──\n# Upper bound on a single dependency probe (storage / redis / event_bus).\n# Cloud Run typically gives health checks 10-30s before marking a revision\n# unhealthy; we want to fail-fast well before that so a stalled backend\n# can't hang the whole probe. Shared between ``/health`` (binary 503 deploy\n# gate) and ``/stats`` / ``/status`` (public endpoints with the same posture\n# — return ``0`` / \"unreachable\" rather than block landing-page hits).\nPROBE_TIMEOUT_SECONDS = 5.0\n\n# ── Memory visibility levels ──\n# Named constants are the SoT — ``MEMORY_VISIBILITIES`` and the regex below\n# derive from them so a rename here propagates to membership checks and\n# the Pydantic pattern automatically. SQL filters and any other call\n# site should import the named constant rather than the bare string so\n# a typo turns into a NameError at import time, not a silent miss.\nMEMORY_VISIBILITY_SCOPE_AGENT = \"scope_agent\"\nMEMORY_VISIBILITY_SCOPE_TEAM = \"scope_team\"\nMEMORY_VISIBILITY_SCOPE_ORG = \"scope_org\"\nMEMORY_VISIBILITIES = (\n    MEMORY_VISIBILITY_SCOPE_AGENT,\n    MEMORY_VISIBILITY_SCOPE_TEAM,\n    MEMORY_VISIBILITY_SCOPE_ORG,\n)\nMEMORY_VISIBILITIES_PATTERN = (\n    f\"^({MEMORY_VISIBILITY_SCOPE_AGENT}|{MEMORY_VISIBILITY_SCOPE_TEAM}|{MEMORY_VISIBILITY_SCOPE_ORG})$\"\n)\n\nMAX_CONTENT_LENGTH = 10000\nCHUNKING_THRESHOLD_CHARS = 2000  # content above this triggers auto-chunking\nMAX_QUERY_LENGTH = 5000\n\n# ── Tool surface bookkeeping ──\n# Tool descriptions live inline in `core_api/tools/memclaw_*.py` spec\n# modules (the SoT). Nothing else should hold a copy.\n# STM tools were dropped in 6fea229; STM_ONLY_TOOLS constant removed.\n\n# ── Search / ranking ──\nDEFAULT_SEARCH_TOP_K = 5\nMAX_SEARCH_TOP_K = 20\nMIN_SEARCH_SIMILARITY = 0.3\nFRESHNESS_DECAY_DAYS = 90\nFRESHNESS_FLOOR = 0.7\nENTITY_BOOST_FACTOR = 1.3\nENTITY_TOKEN_MIN_LENGTH = 2  # A7: was 3; lowered to retain 2-char acronym\n# entities (``AI`` / ``ML`` / ``PR`` / ``UI`` / ``QA`` / ``HR`` /\n# ``UK`` / ``US``…). 2-char English fillers (``in`` / ``on`` / ``to``\n# / ``be`` / ``is``…) are already in ENTITY_STOPWORDS so the noise\n# floor is unchanged; single-letter tokens still drop via the >=2\n# check.\nENTITY_STOPWORDS: frozenset[str] = frozenset(\n    {\n        # ── Determiners / articles ──\n        \"the\",\n        \"a\",\n        \"an\",\n        \"this\",\n        \"that\",\n        \"these\",\n        \"those\",\n        \"my\",\n        \"your\",\n        \"his\",\n        \"her\",\n        \"its\",\n        \"our\",\n        \"their\",\n        \"some\",\n        \"any\",\n        \"each\",\n        \"every\",\n        \"all\",\n        \"both\",\n        # ── Pronouns ──","lineStart":1,"lineEnd":160,"totalLines":638,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","time":{"start":1780727811596,"end":1780727811612}},"metadata":{"openai":{"itemId":"fc_0713ba13c97d71a1016a23c0036ba08191a7c83d532c610304"}},"id":"prt_e9ba60dd40013FOYd4e7ftW7j4","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba5e510001QqqXjbYHdeASii"}}
{"type":"step_finish","timestamp":1780727811966,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba60f7c001IzkwkH0rCcjjqo","reason":"tool-calls","snapshot":"4433d1b6f76c0d41259b05cb28b52e5c2741cb12","messageID":"msg_e9ba5e510001QqqXjbYHdeASii","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","type":"step-finish","tokens":{"total":143447,"input":2723,"output":424,"reasoning":12,"cache":{"write":0,"read":140288}},"cost":0}}
{"type":"step_start","timestamp":1780727813907,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"id":"prt_e9ba61711001pNtRFL2UGHFlzL","messageID":"msg_e9ba61096001A5orMuz1k5TaT6","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","snapshot":"2ccc487436e9c4f130f43ef2875b8546cb8ef572","type":"step-start"}}
{"type":"tool_use","timestamp":1780727816312,"sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","part":{"type":"tool","tool":"read","callID":"call_75420bhDmzKtc0LtbFz5ik5V","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","offset":440,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py</path>\n<type>file</type>\n<content>\n440:         \"new\",\n441:         \"old\",\n442:     }\n443: )\n444: GRAPH_HOP_BOOST = {\n445:     0: 1.3,\n446:     1: 1.2,\n447:     2: 1.1,\n448: }  # boost factor per hop distance (0 = direct match)\n449: GRAPH_MAX_BOOSTED_MEMORIES = 50  # cap on memories receiving graph boost (prevents popular-entity fan-out)\n450: # CAURA-698: cap on entity FTS matches that triggers the ENTITY_LOOKUP\n451: # short-circuit. Above this, the query almost certainly did not name a\n452: # specific entity (it matched broadly against a dense entity index); the\n453: # precision argument for entity_lookup breaks down at high match counts,\n454: # so fall through to keyword/semantic search instead.\n455: #\n456: # Calibrated against etoro prod data (2026-06-02, 6h, 98 user_or_assistant\n457: # queries). The distribution is bimodal with a wide empty gap between\n458: # ~75 and ~500 matches, so any threshold in that range is equivalent on\n459: # this dataset. Sampling the actual queries in each band revealed they\n460: # are all multi-keyword topical searches (e.g., \"DeFi web3 smart contract\",\n461: # \"docker caddy dns\", \"marketing campaign email creative\") — none name a\n462: # specific entity. T=20 lands the entity_lookup rate in the 20-30% target\n463: # band on user traffic while still allowing low-count cases that might\n464: # represent legitimate \"name a thing\" queries on other tenants' data.\n465: # Tune via prod measurement, not bench alone.\n466: ENTITY_LOOKUP_MAX_MATCHES = 20\n467: \n468: FTS_WEIGHT = 0.3  # blend: (1 - FTS_WEIGHT) * vector + FTS_WEIGHT * keyword\n469: FTS_WEIGHT_BOOSTED = 0.6  # for short specific queries (1-3 proper nouns / identifiers)\n470: FTS_BOOST_MAX_TOKENS = 3  # queries with more meaningful tokens than this stay at FTS_WEIGHT\n471: FTS_BOOST_SPECIFICITY_RATIO = 0.4  # strict >; at N=2 this means >=1 specific token triggers boost\n472: SIMILARITY_BLEND = 0.85  # base_score = SIMILARITY_BLEND * similarity + (1 - SIMILARITY_BLEND) * weight (raised from 0.75 — LoCoMo sweep showed +13pp recall)\n473: SEARCH_OVERFETCH_FACTOR = 2  # fetch top_k * N candidates from storage, trim to top_k after min_similarity filter — gives post-filter headroom\n474: RECALL_BOOST_CAP = 1.5  # max multiplier from frequent recall\n475: RECALL_DECAY_WINDOW_DAYS = 90  # only recalls within this window contribute to boost\n476: \n477: # ── Recall summary ──\n478: MEMORY_RECALL_SUMMARY_TEMPERATURE = 0.3\n479: MEMORY_RECALL_SUMMARY_MAX_TOKENS = 1000\n480: \n481: # ── Insights ──\n482: INSIGHTS_MAX_MEMORIES = 50  # max memories per analysis pass (token budget ~10k)\n483: INSIGHTS_TEMPERATURE = 0.3  # analytical, not creative\n484: INSIGHTS_DISCOVER_SAMPLE_SIZE = 200  # memories to sample for vector clustering\n485: INSIGHTS_DISCOVER_CLUSTERS = 6  # k-means cluster count for discover mode\n486: INSIGHTS_FOCUS_MODES = (\"contradictions\", \"failures\", \"stale\", \"divergence\", \"patterns\", \"discover\")\n487: \n488: # Shared scope enum used by memclaw_list, memclaw_insights, memclaw_evolve and\n489: # their REST counterparts. Trust-level gating per scope lives in the individual\n490: # handlers (trust_service.require_trust); this tuple is the single source of\n491: # truth for \"what values are accepted\".\n492: VALID_SCOPES = (\"agent\", \"fleet\", \"all\")\n493: \n494: # ── Evolve (Karpathy Loop) ──\n495: EVOLVE_SUCCESS_DELTA = 0.1  # weight increase on success\n496: EVOLVE_FAILURE_DELTA = -0.15  # weight decrease on failure (asymmetric — failures propagate faster)\n497: EVOLVE_PARTIAL_DELTA = 0.03  # slight nudge for partial outcomes\n498: EVOLVE_WEIGHT_FLOOR = 0.05  # never reduce weight below this (archival value)\n499: EVOLVE_WEIGHT_CAP = 1.0  # never increase weight above this\n500: EVOLVE_RULE_CONFIDENCE_THRESHOLD = 0.5  # min LLM confidence to persist a generated rule\n501: EVOLVE_RULE_TEMPERATURE = 0.3  # analytical rule generation\n502: EVOLVE_OUTCOME_TYPES = (\"success\", \"failure\", \"partial\")\n503: EVOLVE_MAX_RELATED_IDS = 50  # cap on memories touched per evolve call\n504: \n505: MEMORY_RECALL_SUMMARY_NUM_SENTENCES = 10\n506: \n507: # ── Pagination ──\n508: DEFAULT_LIST_LIMIT = 50\n509: MAX_LIST_LIMIT = 500\n510: DEFAULT_AUDIT_LIMIT = 50\n511: MAX_AUDIT_LIMIT = 200\n512: DEFAULT_ENTITY_LIMIT = 100\n513: \n514: # ── Tier limits ──\n515: TIER_LIMITS = {\n516:     \"free\": {\n517:         \"max_memories\": 10_000,\n518:         \"writes_per_month\": 5_000,\n519:         \"searches_per_month\": 5_000,\n520:     },\n521:     \"pro\": {\n522:         \"max_memories\": 250_000,\n523:         \"writes_per_month\": 25_000,\n524:         \"searches_per_month\": 50_000,\n525:     },\n526:     \"business\": {\n527:         \"max_memories\": 1_000_000,\n528:         \"writes_per_month\": 100_000,\n529:         \"searches_per_month\": 500_000,\n\n(Showing lines 440-529 of 638. Use offset=530 to continue.)\n</content>","metadata":{"preview":"        \"new\",\n        \"old\",\n    }\n)\nGRAPH_HOP_BOOST = {\n    0: 1.3,\n    1: 1.2,\n    2: 1.1,\n}  # boost factor per hop distance (0 = direct match)\nGRAPH_MAX_BOOSTED_MEMORIES = 50  # cap on memories receiving graph boost (prevents popular-entity fan-out)\n# CAURA-698: cap on entity FTS matches that triggers the ENTITY_LOOKUP\n# short-circuit. Above this, the query almost certainly did not name a\n# specific entity (it matched broadly against a dense entity index); the\n# precision argument for entity_lookup breaks down at high match counts,\n# so fall through to keyword/semantic search instead.\n#\n# Calibrated against etoro prod data (2026-06-02, 6h, 98 user_or_assistant\n# queries). The distribution is bimodal with a wide empty gap between\n# ~75 and ~500 matches, so any threshold in that range is equivalent on\n# this dataset. Sampling the actual queries in each band revealed they","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","text":"        \"new\",\n        \"old\",\n    }\n)\nGRAPH_HOP_BOOST = {\n    0: 1.3,\n    1: 1.2,\n    2: 1.1,\n}  # boost factor per hop distance (0 = direct match)\nGRAPH_MAX_BOOSTED_MEMORIES = 50  # cap on memories receiving graph boost (prevents popular-entity fan-out)\n# CAURA-698: cap on entity FTS matches that triggers the ENTITY_LOOKUP\n# short-circuit. Above this, the query almost certainly did not name a\n# specific entity (it matched broadly against a dense entity index); the\n# precision argument for entity_lookup breaks down at high match counts,\n# so fall through to keyword/semantic search instead.\n#\n# Calibrated against etoro prod data (2026-06-02, 6h, 98 user_or_assistant\n# queries). The distribution is bimodal with a wide empty gap between\n# ~75 and ~500 matches, so any threshold in that range is equivalent on\n# this dataset. Sampling the actual queries in each band revealed they\n# are all multi-keyword topical searches (e.g., \"DeFi web3 smart contract\",\n# \"docker caddy dns\", \"marketing campaign email creative\") — none name a\n# specific entity. T=20 lands the entity_lookup rate in the 20-30% target\n# band on user traffic while still allowing low-count cases that might\n# represent legitimate \"name a thing\" queries on other tenants' data.\n# Tune via prod measurement, not bench alone.\nENTITY_LOOKUP_MAX_MATCHES = 20\n\nFTS_WEIGHT = 0.3  # blend: (1 - FTS_WEIGHT) * vector + FTS_WEIGHT * keyword\nFTS_WEIGHT_BOOSTED = 0.6  # for short specific queries (1-3 proper nouns / identifiers)\nFTS_BOOST_MAX_TOKENS = 3  # queries with more meaningful tokens than this stay at FTS_WEIGHT\nFTS_BOOST_SPECIFICITY_RATIO = 0.4  # strict >; at N=2 this means >=1 specific token triggers boost\nSIMILARITY_BLEND = 0.85  # base_score = SIMILARITY_BLEND * similarity + (1 - SIMILARITY_BLEND) * weight (raised from 0.75 — LoCoMo sweep showed +13pp recall)\nSEARCH_OVERFETCH_FACTOR = 2  # fetch top_k * N candidates from storage, trim to top_k after min_similarity filter — gives post-filter headroom\nRECALL_BOOST_CAP = 1.5  # max multiplier from frequent recall\nRECALL_DECAY_WINDOW_DAYS = 90  # only recalls within this window contribute to boost\n\n# ── Recall summary ──\nMEMORY_RECALL_SUMMARY_TEMPERATURE = 0.3\nMEMORY_RECALL_SUMMARY_MAX_TOKENS = 1000\n\n# ── Insights ──\nINSIGHTS_MAX_MEMORIES = 50  # max memories per analysis pass (token budget ~10k)\nINSIGHTS_TEMPERATURE = 0.3  # analytical, not creative\nINSIGHTS_DISCOVER_SAMPLE_SIZE = 200  # memories to sample for vector clustering\nINSIGHTS_DISCOVER_CLUSTERS = 6  # k-means cluster count for discover mode\nINSIGHTS_FOCUS_MODES = (\"contradictions\", \"failures\", \"stale\", \"divergence\", \"patterns\", \"discover\")\n\n# Shared scope enum used by memclaw_list, memclaw_insights, memclaw_evolve and\n# their REST counterparts. Trust-level gating per scope lives in the individual\n# handlers (trust_service.require_trust); this tuple is the single source of\n# truth for \"what values are accepted\".\nVALID_SCOPES = (\"agent\", \"fleet\", \"all\")\n\n# ── Evolve (Karpathy Loop) ──\nEVOLVE_SUCCESS_DELTA = 0.1  # weight increase on success\nEVOLVE_FAILURE_DELTA = -0.15  # weight decrease on failure (asymmetric — failures propagate faster)\nEVOLVE_PARTIAL_DELTA = 0.03  # slight nudge for partial outcomes\nEVOLVE_WEIGHT_FLOOR = 0.05  # never reduce weight below this (archival value)\nEVOLVE_WEIGHT_CAP = 1.0  # never increase weight above this\nEVOLVE_RULE_CONFIDENCE_THRESHOLD = 0.5  # min LLM confidence to persist a generated rule\nEVOLVE_RULE_TEMPERATURE = 0.3  # analytical rule generation\nEVOLVE_OUTCOME_TYPES = (\"success\", \"failure\", \"partial\")\nEVOLVE_MAX_RELATED_IDS = 50  # cap on memories touched per evolve call\n\nMEMORY_RECALL_SUMMARY_NUM_SENTENCES = 10\n\n# ── Pagination ──\nDEFAULT_LIST_LIMIT = 50\nMAX_LIST_LIMIT = 500\nDEFAULT_AUDIT_LIMIT = 50\nMAX_AUDIT_LIMIT = 200\nDEFAULT_ENTITY_LIMIT = 100\n\n# ── Tier limits ──\nTIER_LIMITS = {\n    \"free\": {\n        \"max_memories\": 10_000,\n        \"writes_per_month\": 5_000,\n        \"searches_per_month\": 5_000,\n    },\n    \"pro\": {\n        \"max_memories\": 250_000,\n        \"writes_per_month\": 25_000,\n        \"searches_per_month\": 50_000,\n    },\n    \"business\": {\n        \"max_memories\": 1_000_000,\n        \"writes_per_month\": 100_000,\n        \"searches_per_month\": 500_000,","lineStart":440,"lineEnd":529,"totalLines":638,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","time":{"start":1780727816303,"end":1780727816310}},"metadata":{"openai":{"itemId":"fc_06c1e67bb0a19f75016a23c00702a88191a382a50945e632ce"}},"id":"prt_e9ba61b83001A9rJx77sDBrrb1","sessionID":"ses_1645cad37ffeA4S42Sj1D0XYfI","messageID":"msg_e9ba61096001A5orMuz1k5TaT6"}}
