s\": 27,\n    \"references\": 136\n  },\n  \"totalDefects\": 9,\n  \"defectCounts\": {\n    \"hyphen\": 0,\n    \"frontmatter\": 0,\n    \"version\": 0,\n    \"h1\": 0,\n    \"intro\": 1,\n    \"overview\": 0,\n    \"modeSection\": 2,\n    \"numbering\": 5,\n    \"relatedLast\": 0,\n    \"introPurposeDuplicate\": 1,\n    \"validator\": 0\n  },\n  \"samples\": {\n    \"intro\": [\n      \".opencode/skills/sk-code/code-opencode/references/rust/style_guide/interop_errors_and_parity.md\"\n    ],\n    \"modeSection\": [\n      \".opencode/skills/sk-code/code-webflow/references/css/patterns/tokens_state_machine_and_triggers.md\",\n      \".opencode/skills/sk-code/code-webflow/references/implementation/observer_patterns/mutation_and_intersection.md\"\n    ],\n    \"numbering\": [\n      \".opencode/skills/sk-code/code-webflow/references/css/quality_standards/focus_has_print_and_quick_reference.md\",\n      \".opencode/skills/sk-code/code-webflow/references/css/quick_reference.md\",\n      \".opencode/skills/sk-code/code-webflow/references/css/style_guide.md\",\n      \".opencode/skills/sk-code/code-webflow/references/html/quality_standards.md\",\n      \".opencode/skills/sk-code/code-webflow/references/html/style_guide.md\"\n    ],\n    \"introPurposeDuplicate\": [\n      \".opencode/skills/sk-code/code-webflow/references/implementation/third_party_integrations/overview_hls_and_lenis.md\"\n    ]\n  }\n}\n","exit":0,"truncated":false},"title":"node \".opencode/specs/sk-code/019-split-doc-template-alignment/review/xhigh-verify/lineages/xhigh-b/logs/corpus-audit.cjs\"","time":{"start":1783915949622,"end":1783915949625}},"metadata":{"openai":{"itemId":"fc_03f62c80601aa219016a5465a5c6588191be4af8e23ccbfaf1"}},"id":"prt_f59ad0f860014YxYzH8LrDyOPh","sessionID":"ses_0a65ac472ffeDn3G1fX5LbU2k8","messageID":"msg_f59ad04d1001MogRnIFTEOMfHJ"}}
