   223	
   224	      step_classify_session:
   225	        action: "Classify the session before writing files"
   226	        inspect:
   227	          - "{state_paths.config}"
   228	          - "{state_paths.state_log}"
   229	          - "{state_paths.findings_registry}"
   230	          - "{state_paths.strategy}"
   231	        classify:
   232	          fresh: "None of the three state artifacts exist"
   233	          resume: "Config, JSONL, and strategy all exist and config.mode == 'review' and agree on target/spec folder"
   234	          completed-session: "Resume artifacts exist and config.status == 'complete'"
   235	          invalid-state: "Any partial, missing, or contradictory combination"
   236	        outputs:
   237	          - session_state: "fresh | resume | completed-session | invalid-state"
   238	        on_resume:
   239	          show_dashboard: "{state_paths.dashboard}"
   240	          ask: "Existing review session is consistent. Resume where it left off, or restart (archive the current review packet under the root-level review_archive/ tree and start a fresh session)?"
