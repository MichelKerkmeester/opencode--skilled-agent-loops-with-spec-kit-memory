     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * validate-playbook-topology.cjs — pre-dispatch gate over a hub's manual
     9	 * testing playbook. Every scenario carries typed gold in its frontmatter:
    10	 * `expected_workflow_mode` plus an `expected_leaf_resources` list of
    11	 * `{ workflow_mode, leaf_resource_id }` pairs. This gate runs three checks,
    12	 * in order, before any scenario is allowed to dispatch:
    13	 *
    14	 *   (a) schema     - the frontmatter carries well-formed typed gold
    15	 *   (b) manifest   - every typed pair resolves against the hub's committed
    16	 *                    leaf-manifest.json (the single source of truth)
    17	 *   (c) selected-map join - every pair's workflowMode belongs to the
    18	 *                    scenario's own declared `expected_workflow_mode` set,
    19	 *                    and a non-full-inventory scenario stays within the
    20	 *                    selected-map union cap (maxWorkflowModes: 2)
    21	 *
    22	 * A scenario that fails any stage is an invalid oracle: it is blocked from
    23	 * dispatch and reported as excluded, never silently scored as zero recall.
    24	 * That is a stale-fixture or missing-alias signal, not a routing failure,
    25	 * so it must never be folded into a routing-accuracy denominator.
    26	 *
    27	 * This module owns pre-dispatch classification only. It does not touch the
    28	 * manifest, the alias table, or any emitter; it reads them read-only.
    29	 */
    30	
    31	// ─────────────────────────────────────────────────────────────────────────────
    32	// 1. IMPORTS
    33	// ─────────────────────────────────────────────────────────────────────────────
    34	
    35	const fs = require('fs');
    36	const path = require('path');
    37	const contract = require('./lib/leaf-resource-contract.cjs');
    38	
    39	// ─────────────────────────────────────────────────────────────────────────────
    40	// 2. CONSTANTS
    41	// ─────────────────────────────────────────────────────────────────────────────
    42	
    43	// A scenario may span at most this many simultaneous workflow modes unless
    44	// it opts into `full_inventory_intent: true` (an explicit, named bypass, not
    45	// an inferred condition).
    46	const MAX_SIMULTANEOUS_WORKFLOW_MODES = 2;
    47	
    48	// A scenario with zero positive resource gold (e.g. an UNKNOWN-fallback
    49	// fixture) never needs a manifest-registered workflowMode; this is the one
    50	// declared exception to "every workflowMode must be a real hub mode".
    51	const EMPTY_GOLD_WORKFLOW_MODE = 'UNKNOWN';
    52	
    53	const CLASS_SCHEMA = 'fixture_schema_error';
    54	const CLASS_TOPOLOGY = 'fixture_topology_error';
    55	const CLASS_SELECTION = 'fixture_selection_error';
    56	
    57	// ─────────────────────────────────────────────────────────────────────────────
    58	// 3. FRONTMATTER PARSING (typed gold only; legacy fields are read elsewhere)
    59	// ─────────────────────────────────────────────────────────────────────────────
    60	
    61	function readFileSafe(filePath) {
    62	  try { return fs.readFileSync(filePath, 'utf8'); } catch { return null; }
    63	}
    64	
    65	function extractFrontmatter(text) {
    66	  const m = /^---\n([\s\S]*?)\n---/.exec(text || '');
    67	  return m ? m[1] : null;
    68	}
    69	
    70	// Splits a scenario's declared route on its two legal separators:
    71	// "+" for a simultaneous multi-mode bundle, "→" for a sequential multi-turn
    72	// scenario (each turn is an independent dispatch, so the union cap does not
    73	// apply the same way). A single mode or the literal UNKNOWN sentinel yields
    74	// one entry.
    75	function splitDeclaredModes(expectedWorkflowMode) {
    76	  if (!expectedWorkflowMode) return { modes: [], sequential: false };
    77	  if (expectedWorkflowMode.includes('→')) {
    78	    return { modes: expectedWorkflowMode.split('→').map((s) => s.trim()).filter(Boolean), sequential: true };
    79	  }
    80	  return { modes: expectedWorkflowMode.split('+').map((s) => s.trim()).filter(Boolean), sequential: false };
    81	}
    82	
    83	// Parses the fixed two-line-per-entry shape this migration writes:
    84	//   expected_leaf_resources:
    85	//     - workflow_mode: <mode>
    86	//       leaf_resource_id: <id>
    87	// or the empty-list shape `expected_leaf_resources: []`.
    88	function parseExpectedLeafResources(block) {
    89	  if (/(?:^|\n)[ \t]*expected_leaf_resources:[ \t]*\[\][ \t]*(?:\n|$)/.test(block)) {
    90	    return { ok: true, pairs: [] };
    91	  }
    92	  const m = /(?:^|\n)[ \t]*expected_leaf_resources:[ \t]*\n((?:[ \t]*-[ \t]*workflow_mode:.*\n[ \t]*leaf_resource_id:.*\n?)+)/.exec(block);
    93	  if (!m) return { ok: false, pairs: null };
    94	  const pairs = [];
    95	  const entryRe = /-[ \t]*workflow_mode:[ \t]*(\S+)[ \t]*\n[ \t]*leaf_resource_id:[ \t]*(\S+)/g;
    96	  let entry;
    97	  while ((entry = entryRe.exec(m[1])) !== null) {
    98	    pairs.push({ workflowMode: entry[1].trim(), leafResourceId: entry[2].trim() });
    99	  }
   100	  return { ok: true, pairs };
   101	}
   102	
   103	function parseFixture(absPath, playbookDir) {
   104	  const text = readFileSafe(absPath);
   105	  if (!text) return { ok: false, path: absPath, error: 'UNREADABLE_FILE' };
   106	  const block = extractFrontmatter(text);
   107	  if (!block) return { ok: false, path: absPath, error: 'NO_FRONTMATTER' };
   108	
   109	  const idM = /(?:^|\n)[ \t]*id:[ \t]*["']?([A-Za-z0-9-]+)/.exec(block);
   110	  const modeM = /(?:^|\n)[ \t]*expected_workflow_mode:[ \t]*(.+)/.exec(block);
   111	  const fullInventoryM = /(?:^|\n)[ \t]*full_inventory_intent:[ \t]*(true|false)/.exec(block);
   112	  const leafResult = parseExpectedLeafResources(block);
   113	
   114	  return {
   115	    ok: true,
   116	    id: idM ? idM[1].trim() : null,
   117	    relPath: path.relative(playbookDir, absPath),
   118	    expectedWorkflowMode: modeM ? modeM[1].trim() : null,
   119	    fullInventoryIntent: fullInventoryM ? fullInventoryM[1] === 'true' : false,
   120	    leafResourcesParsed: leafResult.ok,
   121	    pairs: leafResult.pairs || [],
   122	  };
   123	}
   124	
   125	function walkFixtureFiles(playbookDir) {
   126	  const out = [];
   127	  const stack = [playbookDir];
   128	  while (stack.length) {
   129	    const cur = stack.pop();
   130	    let entries;
   131	    try { entries = fs.readdirSync(cur, { withFileTypes: true }); } catch { continue; }
   132	    for (const entry of entries) {
   133	      const full = path.join(cur, entry.name);
   134	      if (entry.isDirectory()) { stack.push(full); continue; }
   135	      if (!entry.isFile() || !entry.name.endsWith('.md')) continue;
   136	      if (entry.name === 'manual-testing-playbook.md' || entry.name === 'feature-catalog.md') continue;
   137	      out.push(full);
   138	    }
   139	  }
   140	  return out.sort();
   141	}
   142	
   143	function assertPlaybookBoundary(playbookDir) {
   144	  const basename = path.basename(playbookDir);
   145	  const normalized = basename.toLowerCase().replace(/-/g, '_');
   146	  if (normalized.startsWith('manual_testing_playbook')
   147	      && contract.canonicalPackageRoot(basename) !== 'manual-testing-playbook') {
   148	    throw new contract.ContractError('UNSUPPORTED_PLAYBOOK_ROOT', `unsupported playbook root: ${playbookDir}`);
   149	  }
   150	}
   151	
   152	function resolvePlaybookBoundary(skillDir, explicitDir) {
   153	  if (explicitDir) {
   154	    const resolved = path.resolve(explicitDir);
   155	    assertPlaybookBoundary(resolved);
   156	    return resolved;
   157	  }
   158	  // Fail closed: a legacy underscore playbook dir must be migrated, never silently ignored in
   159	  // favor of a canonical sibling. Mirrors assertPlaybookBoundary's near-match detection.
   160	  const unsupported = fs.existsSync(skillDir)
   161	    ? fs.readdirSync(skillDir, { withFileTypes: true }).find((entry) => entry.isDirectory()
   162	        && entry.name.toLowerCase().replace(/-/g, '_').startsWith('manual_testing_playbook')
   163	        && contract.canonicalPackageRoot(entry.name) !== 'manual-testing-playbook')
   164	    : null;
   165	  if (unsupported) {
   166	    throw new contract.ContractError('UNSUPPORTED_PLAYBOOK_ROOT', `unsupported playbook root: ${path.join(skillDir, unsupported.name)}`);
   167	  }
   168	  const roots = ['manual-testing-playbook']
   169	    .map((name) => path.join(skillDir, name))
   170	    .filter((candidate) => fs.existsSync(candidate));
   171	  if (roots.length === 1) return roots[0];
   172	  throw new contract.ContractError('MISSING_PLAYBOOK_ROOT', `no supported playbook root under ${skillDir}`);
   173	}
   174	
   175	// ─────────────────────────────────────────────────────────────────────────────
   176	// 4. MANIFEST + ALIAS LOADING (read-only)
   177	// ─────────────────────────────────────────────────────────────────────────────
   178	
   179	function readJson(filePath) {
   180	  return JSON.parse(fs.readFileSync(filePath, 'utf8'));
   181	}
   182	
   183	function loadManifestLeaves(skillDir) {
   184	  const manifestPath = path.join(skillDir, 'leaf-manifest.json');
   185	  if (!fs.existsSync(manifestPath)) {
   186	    throw new contract.ContractError('MISSING_MANIFEST', `leaf-manifest.json not found under ${skillDir}`);
   187	  }
   188	  const manifest = readJson(manifestPath);
   189	  const leavesByMode = new Map();
   190	  for (const mode of manifest.modes || []) {
   191	    leavesByMode.set(mode.workflowMode, new Set(mode.leaves || []));
   192	  }
   193	  return leavesByMode;
   194	}
   195	
   196	// ─────────────────────────────────────────────────────────────────────────────
   197	// 5. THREE-STAGE VALIDATION (schema -> manifest -> selected-map join)
   198	// ─────────────────────────────────────────────────────────────────────────────
   199	
   200	function validateSchema(fixture) {
   201	  const problems = [];
   202	  if (!fixture.id) problems.push('missing id');
   203	  if (!fixture.expectedWorkflowMode) problems.push('missing expected_workflow_mode');
   204	  if (!fixture.leafResourcesParsed) problems.push('missing or malformed expected_leaf_resources');
   205	  for (const pair of fixture.pairs) {
   206	    if (!pair.workflowMode) problems.push(`typed pair missing workflow_mode (leaf_resource_id=${pair.leafResourceId || '?'})`);
   207	    if (!pair.leafResourceId) problems.push(`typed pair missing leaf_resource_id (workflow_mode=${pair.workflowMode || '?'})`);
   208	    if (pair.leafResourceId) {
   209	      try {
   210	        contract.assertContainment(pair.leafResourceId);
   211	      } catch (err) {
   212	        problems.push(`leaf_resource_id fails containment: ${pair.leafResourceId} (${err.code})`);
   213	      }
   214	    }
   215	  }
   216	  return problems;
   217	}
   218	
   219	function validateManifestResolution(fixture, leavesByMode) {
   220	  const problems = [];
   221	  for (const pair of fixture.pairs) {
   222	    if (pair.workflowMode === EMPTY_GOLD_WORKFLOW_MODE) continue;
   223	    const leaves = leavesByMode.get(pair.workflowMode);
   224	    if (!leaves) {
   225	      problems.push(`unregistered workflowMode: ${pair.workflowMode}`);
   226	      continue;
   227	    }
   228	    if (!leaves.has(pair.leafResourceId)) {
   229	      problems.push(`no manifest leaf for (${pair.workflowMode}, ${pair.leafResourceId}) - missing alias/target`);
   230	    }
   231	  }
   232	  return problems;
   233	}
   234	
   235	function validateSelectedMapJoin(fixture) {
   236	  const problems = [];
   237	  const { modes: declaredModes, sequential } = splitDeclaredModes(fixture.expectedWorkflowMode);
   238	  const declaredSet = new Set(declaredModes);
   239	
   240	  for (const pair of fixture.pairs) {
   241	    if (!declaredSet.has(pair.workflowMode)) {
   242	      problems.push(`typed pair workflowMode "${pair.workflowMode}" is not part of declared expected_workflow_mode "${fixture.expectedWorkflowMode}"`);
   243	    }
   244	  }
   245	
   246	  if (!sequential && !fixture.fullInventoryIntent && declaredModes.length > MAX_SIMULTANEOUS_WORKFLOW_MODES) {
   247	    problems.push(
   248	      `declares ${declaredModes.length} simultaneous workflow modes, exceeding the selected-map union cap `
   249	      + `(${MAX_SIMULTANEOUS_WORKFLOW_MODES}) without full_inventory_intent: true`,
   250	    );
   251	  }
   252	
   253	  return problems;
   254	}
   255	
   256	function classifyFixture(fixture, leavesByMode) {
   257	  const schemaProblems = validateSchema(fixture);
   258	  if (schemaProblems.length) {
   259	    return { status: 'blocked', errorClass: CLASS_SCHEMA, problems: schemaProblems };
   260	  }
   261	
   262	  const manifestProblems = validateManifestResolution(fixture, leavesByMode);
   263	  const selectionProblems = validateSelectedMapJoin(fixture);
   264	
   265	  if (manifestProblems.length) {
   266	    return { status: 'blocked', errorClass: CLASS_TOPOLOGY, problems: manifestProblems.concat(selectionProblems) };
   267	  }
   268	  if (selectionProblems.length) {
   269	    return { status: 'blocked', errorClass: CLASS_SELECTION, problems: selectionProblems };
   270	  }
   271	  return { status: 'valid', errorClass: null, problems: [] };
   272	}
   273	
   274	// ─────────────────────────────────────────────────────────────────────────────
   275	// 6. CORE LOGIC
   276	// ─────────────────────────────────────────────────────────────────────────────
   277	
   278	/**
   279	 * Run the pre-dispatch topology gate over every scenario file under a
   280	 * playbook directory. Read-only: never mutates the manifest, aliases, or
   281	 * fixture files.
   282	 *
   283	 * @param {Object} args - Run inputs.
   284	 * @param {string} args.playbookDir - Directory holding scenario `.md` files.
   285	 * @param {string} args.skillDir - Hub root holding `leaf-manifest.json`.
   286	 * @returns {{results: Array, validCount: number, blockedCount: number}} Report.
   287	 */
   288	function runValidation({ playbookDir, skillDir }) {
   289	  assertPlaybookBoundary(playbookDir);
   290	  const leavesByMode = loadManifestLeaves(skillDir);
   291	  const files = walkFixtureFiles(playbookDir);
   292	  const results = [];
   293	
   294	  for (const absPath of files) {
   295	    const fixture = parseFixture(absPath, playbookDir);
   296	    if (!fixture.ok) {
   297	      results.push({
   298	        id: null,
   299	        relPath: path.relative(playbookDir, absPath),
   300	        status: 'blocked',
   301	        errorClass: CLASS_SCHEMA,
   302	        problems: [fixture.error],
   303	      });
   304	      continue;
   305	    }
   306	    const verdict = classifyFixture(fixture, leavesByMode);
   307	    results.push({
   308	      id: fixture.id,
   309	      relPath: fixture.relPath,
   310	      expectedWorkflowMode: fixture.expectedWorkflowMode,
   311	      pairCount: fixture.pairs.length,
   312	      status: verdict.status,
   313	      errorClass: verdict.errorClass,
   314	      problems: verdict.problems,
   315	    });
   316	  }
   317	
   318	  const validCount = results.filter((r) => r.status === 'valid').length;
   319	  const blockedCount = results.length - validCount;
   320	  return { results, validCount, blockedCount };
   321	}
   322	
   323	function formatReport(report) {
   324	  const lines = [];
   325	  for (const r of report.results) {
   326	    const label = r.id || '(unknown id)';
   327	    if (r.status === 'valid') {
   328	      lines.push(`PASS  ${label}  ${r.relPath}  pairs=${r.pairCount}  mode=${r.expectedWorkflowMode}`);
   329	    } else {
   330	      lines.push(`BLOCK ${label}  ${r.relPath}  class=${r.errorClass}  excluded_from_denominators=true`);
   331	      for (const p of r.problems) lines.push(`        - ${p}`);
   332	    }
   333	  }
   334	  lines.push('');
   335	  lines.push(`valid=${report.validCount} blocked=${report.blockedCount} total=${report.results.length}`);
   336	  return lines.join('\n');
   337	}
   338	
   339	// ─────────────────────────────────────────────────────────────────────────────
   340	// 7. CLI
   341	// ─────────────────────────────────────────────────────────────────────────────
   342	
   343	function parseArgs(argv) {
   344	  const args = { dir: null, skillDir: null, strict: false, format: 'text' };
   345	  for (let i = 0; i < argv.length; i += 1) {
   346	    const a = argv[i];
   347	    if (a === '--dir') { args.dir = argv[i + 1]; i += 1; }
   348	    else if (a === '--skill-dir') { args.skillDir = argv[i + 1]; i += 1; }
   349	    else if (a === '--strict') { args.strict = true; }
   350	    else if (a === '--format') { args.format = argv[i + 1]; i += 1; }
   351	  }
   352	  return args;
   353	}
   354	
   355	// ─────────────────────────────────────────────────────────────────────────────
   356	// 8. EXPORTS
   357	// ─────────────────────────────────────────────────────────────────────────────
   358	
   359	module.exports = {
   360	  MAX_SIMULTANEOUS_WORKFLOW_MODES,
   361	  EMPTY_GOLD_WORKFLOW_MODE,
   362	  CLASS_SCHEMA,
   363	  CLASS_TOPOLOGY,
   364	  CLASS_SELECTION,
   365	  parseFixture,
   366	  walkFixtureFiles,
   367	  loadManifestLeaves,
   368	  assertPlaybookBoundary,
   369	  resolvePlaybookBoundary,
   370	  classifyFixture,
   371	  runValidation,
   372	  formatReport,
   373	};
   374	
   375	if (require.main === module) {
   376	  const args = parseArgs(process.argv.slice(2));
   377	  const skillDir = path.resolve(args.skillDir || path.resolve(__dirname, '..', '..'));
   378	
   379	  try {
   380	    const playbookDir = resolvePlaybookBoundary(skillDir, args.dir);
   381	    const report = runValidation({ playbookDir, skillDir });
   382	    if (args.format === 'json') {
   383	      process.stdout.write(`${JSON.stringify(report, null, 2)}\n`);
   384	    } else {
   385	      process.stdout.write(`${formatReport(report)}\n`);
   386	    }
   387	    if (args.strict && report.blockedCount > 0) {
   388	      process.exit(1);
   389	    }
   390	    process.exit(0);
   391	  } catch (err) {
   392	    process.stderr.write(`validate-playbook-topology: ${err.message}\n`);
   393	    process.exit(2);
   394	  }
   395	}
     1	---
     2	title: Manual Testing Playbook Creation - Templates and Standards
     3	description: Templates for creating feature-catalog-style manual testing playbooks with an integrated root playbook, root-level per-feature files, current frontmatter conventions, and orchestration guidance.
     4	trigger_phrases:
     5	  - "manual testing playbook template"
     6	  - "testing playbook scaffold"
     7	  - "deterministic scenario matrix"
     8	  - "playbook root structure"
     9	importance_tier: normal
    10	contextType: general
    11	version: 1.8.0.16
    12	---
    13	
    14	# Manual Testing Playbook Creation - Templates and Standards
    15	
    16	Templates for creating manual testing playbooks with deterministic scenarios, structured evidence collection, integrated root-level review/orchestration guidance, root-level per-feature files, and current frontmatter conventions.
    17	
    18	---
    19	
    20	## 1. OVERVIEW
    21	
    22	**Purpose**: Manual testing playbooks provide operator-facing validation matrices for skills. They define deterministic scenarios with realistic user requests, orchestrator execution guidance, exact prompts, command sequences, expected signals, and pass/fail criteria so any operator can execute and grade tests consistently.
    23	
    24	**Key Characteristics**:
    25	- **Deterministic**: Every scenario has an exact prompt and exact command sequence.
    26	- **9-column contract**: Standardized table covering Feature ID through Failure Triage.
    27	- **Feature-catalog rooted**: The root playbook acts as the directory, review surface, and cross-reference index.
    28	- **Per-feature files**: Each scenario gets its own file in a category folder at the playbook root.
    29	- **Orchestrator-led**: Scenarios should mimic real user testing, including coordinator prompts, delegation decisions, and user-visible outcomes.
    30	- **Integrated root guidance**: Review protocol and orchestration rules live inside the root playbook, not in separate canonical sidecar docs.
    31	- **Feature-catalog shaped files**: Per-feature playbook files should mirror feature-catalog snippet structure by leading with prose, then current reality, then structured source references.
    32	- **Evidence-driven**: Every scenario requires captured evidence with explicit verdicts.
    33	- **Validator-limited**: The current validator checks the root playbook for markdown structure, but it does not recurse into category folders or verify cross-file references yet.
    34	- **Evergreen**: Playbooks validate current behavior. Scenario IDs are allowed; spec or phase packet-history references are not.
    35	
    36	**Location Convention**: `{SKILL_PATH}/manual-testing-playbook/`
    37	
    38	Canonical layout:
    39	
    40	```text
    41	manual-testing-playbook/
    42	├── manual-testing-playbook.md          # Root directory page, review rules, and orchestration guidance
    43	├── category-name/                      # Required per-feature files for category 1
    44	│   ├── feature-name.md
    45	│   └── another-feature-name.md
    46	└── another-category/                   # Required per-feature files for category 2
    47	    └── feature-name.md
    48	```
    49	
    50	Category folders and per-feature files use descriptive kebab-case names; the root `manual-testing-playbook.md` index owns display order, not the folder name.
    51	
    52	**Existing Examples**:
    53	- `.opencode/skills/system-spec-kit/manual-testing-playbook/` (integrated root playbook + 195 per-feature files)
    54	- `.opencode/skills/system-code-graph/manual-testing-playbook/` (older package shape; migrate toward integrated root guidance)
    55	
    56	These existing examples keep their legacy underscore roots until the repository content migration. New packages emit only the canonical hyphenated layout above.
    57	
    58	---
    59	
    60	## 2. WHEN TO CREATE PLAYBOOKS
    61	
    62	**Create a playbook when**:
    63	- A skill has 5+ distinct features that need manual validation.
    64	- Automated tests do not cover integration-level or end-to-end behavior.
    65	- Multiple operators (human or AI) will execute the same test suite.
    66	- Release readiness requires structured evidence collection.
    67	- Realistic orchestration behavior matters, including sub-agent or alternate-CLI usage.
    68	
    69	**Keep simple when**:
    70	- Skill has fewer than 5 features.
    71	- All behavior is covered by automated tests.
    72	- A single operator will run tests once.
    73	
    74	Decision tree:
    75	
    76	```text
    77	Skill has 5+ manually testable features?
    78	  YES -> Does it need structured evidence for release?
    79	    YES -> Create root playbook + root-level per-feature files
    80	    NO  -> Create lightweight checklist in spec folder
    81	  NO -> Document test steps inline in spec folder tasks.md
    82	```
    83	
    84	---
    85	
    86	## 3. CATEGORY AND ID DESIGN
    87	
    88	Each category groups related features under a short prefix.
    89	
    90	| Category Purpose | Example Prefix | Example IDs |
    91	|---|---|---|
    92	| Existing features | `EX` | EX-001, EX-002 |
    93	| New features | `NEW` | NEW-001, NEW-002 |
    94	| Phase features | `PHASE` | PHASE-001, PHASE-002 |
    95	| Memory/spec-kit workflows | `M` | M-001, M-002 |
    96	
    97	ID format:
    98	
    99	```text
   100	{PREFIX}-{NNN}
   101	```
   102	
   103	- `PREFIX`: 1-5 uppercase letters identifying the category.
   104	- `NNN`: zero-padded 3-digit sequence number starting at 001.
   105	- IDs are unique across the entire playbook.
   106	- Gaps are allowed; do not renumber published IDs.
   107	- IDs should identify current validation scenarios, not the packet that created them. Replace packet-history notes with source anchors or feature references.
   108	
   109	Per-feature file path:
   110	
   111	```text
   112	manual-testing-playbook/{CATEGORY_DIR}/{FEATURE_SLUG}.md
   113	```
   114	
   115	Per-feature file shape:
   116	1. `## 1. OVERVIEW`
   117	2. `## 2. SCENARIO CONTRACT`
   118	3. `## 3. TEST EXECUTION`
   119	4. `## 4. SOURCE FILES`
   120	5. `## 5. SOURCE METADATA`
   121	
   122	---
   123	
   124	## 4. THE 9-COLUMN SCENARIO CONTRACT
   125	
   126	Every scenario row uses exactly 9 columns:
   127	
   128	| # | Column | Content |
   129	|---|---|---|
   130	| 1 | Feature ID | `PREFIX-NNN` |
   131	| 2 | Feature Name | Short human-readable name |
   132	| 3 | Scenario Name / Objective | What the scenario proves |
   133	| 4 | Exact Prompt | Copy-paste-ready natural-language prompt |
   134	| 5 | Exact Command Sequence | Deterministic steps with `->` separators |
   135	| 6 | Expected Signals | Observable outputs per step |
   136	| 7 | Evidence | What to capture as proof |
   137	| 8 | Pass/Fail Criteria | Binary grading rule |
   138	| 9 | Failure Triage | Ordered debugging checks |
   139	
   140	Copy-paste header:
   141	
   142	```markdown
   143	| Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |
   144	|---|---|---|---|---|---|---|---|---|
   145	```
   146	
   147	---
   148	
   149	## 5. ROOT PLAYBOOK SCAFFOLD
   150	
   151	Copy this scaffold to create `{SKILL_PATH}/manual-testing-playbook/manual-testing-playbook.md`:
   152	
   153	```markdown
   154	---
   155	title: "{SKILL_NAME}: Manual Testing Playbook"
   156	description: "Operator-facing reference combining the manual testing directory, integrated review/orchestration guidance, execution expectations, and per-feature validation files for the {SKILL_NAME} skill."
   157	version: 1.0.0.0
   158	---
   159	
   160	# {SKILL_NAME}: Manual Testing Playbook
   161	
   162	This document combines the full manual-validation contract for the `{SKILL_SLUG}` skill into a single reference. The root playbook acts as the operator directory, review protocol, and orchestration guide: it explains how realistic user-driven tests should be run, how evidence should be captured, how results should be graded, and where each per-feature validation file lives. The per-feature files provide the deeper execution contract for each scenario, including the user request, orchestrator prompt, execution process, source anchors, and validation criteria.
   163	
   164	---
   165	
   166	This playbook package adopts the Feature Catalog split-document pattern for the `{SKILL_SLUG}` skill. The root document acts as the directory, review surface, and orchestration guide, while per-feature execution detail lives in the category folders at the playbook root.
   167	
   168	Canonical package artifacts:
   169	- `manual-testing-playbook.md`
   170	- `{CAT1_DIR}/`
   171	- `{CAT2_DIR}/`
   172	
   173	---
   174	
   175	## 1. OVERVIEW
   176	
   177	This playbook provides {SCENARIO_COUNT} deterministic scenarios across {CATEGORY_COUNT} categories validating the `{SKILL_SLUG}` skill surface. Each feature keeps its original ID and links to a dedicated feature file with the full execution contract.
   178	
   179	Coverage note ({PLAYBOOK_DATE}): {COVERAGE_NOTE}.
   180	
   181	### Realistic Test Model
   182	
   183	1. A realistic user request is given to an orchestrator.
   184	2. The orchestrator decides whether to work locally, delegate to sub-agents, or invoke another CLI/runtime.
   185	3. The operator captures both the execution process and the user-visible outcome.
   186	4. The scenario passes only when the workflow is sound and the returned result would satisfy a real user.
   187	
   188	### What Each Feature File Should Explain
   189	
   190	- The realistic user request that should trigger the behavior
   191	- The orchestrator brief or agent-facing prompt that should drive the test
   192	- The expected execution process, including delegation or external CLI use when relevant
   193	- The desired user-visible outcome
   194	- The implementation or regression-test anchors that justify the scenario
   195	
   196	---
   197	
   198	## 2. GLOBAL PRECONDITIONS
   199	1. Working directory is project root.
   200	2. {PRECONDITION_2}
   201	3. {PRECONDITION_3}
   202	4. {PRECONDITION_4}
   203	5. Destructive scenario {DESTRUCTIVE_IDS} MUST verify recovery is possible.
   204	
   205	---
   206	
   207	## 3. GLOBAL EVIDENCE REQUIREMENTS
   208	- Command transcript
   209	- User request used
   210	- Orchestrator or agent-facing prompt used
   211	- Delegation or runtime-routing notes when applicable
   212	- Output snippets
   213	- Final user-facing response or outcome summary
   214	- Artifact path or output reference
   215	- Scenario verdict with rationale
   216	
   217	---
   218	
   219	## 4. DETERMINISTIC COMMAND NOTATION
   220	- CLI commands shown as `{CLI_TOOL} <subcommand> [args]`.
   221	- MCP tool calls shown as `{MCP_TOOL_PREFIX}({ key: value })`.
   222	- Bash commands shown as `bash: <command>`.
   223	- Agent prompts shown as `agent: <instruction>`.
   224	- `->` separates sequential steps.
   225	
   226	---
   227	
   228	## 5. REVIEW PROTOCOL AND RELEASE READINESS
   229	
   230	### Inputs Required
   231	
   232	1. `manual-testing-playbook.md`
   233	2. Referenced per-feature files under `manual-testing-playbook/<category>/`
   234	3. Scenario execution evidence
   235	4. Feature-to-scenario coverage map
   236	5. Triage notes for all non-pass outcomes
   237	
   238	### Scenario Acceptance Rules
   239	
   240	For each executed scenario, check:
   241	
   242	1. Preconditions were satisfied.
   243	2. Prompt and command sequence were executed as written.
   244	3. Expected signals are present.
   245	4. Evidence is complete and readable.
   246	5. Outcome rationale is explicit.
   247	
   248	Scenario verdict:
   249	- `PASS`: all acceptance checks true
   250	- `PARTIAL`: core behavior works but non-critical evidence or metadata is incomplete
   251	- `FAIL`: expected behavior missing, contradictory output, or critical check failed
   252	
   253	### Feature Verdict Rules
   254	
   255	- `PASS`: all mapped scenarios for feature are `PASS`
   256	- `PARTIAL`: at least one mapped scenario is `PARTIAL`, none are `FAIL`
   257	- `FAIL`: any mapped scenario is `FAIL`
   258	
   259	Hard rule:
   260	- Any critical-path scenario `FAIL` forces feature verdict to `FAIL`.
   261	
   262	### Release Readiness Rule
   263	
   264	Release is `READY` only when:
   265	
   266	1. No feature verdict is `FAIL`.
   267	2. All critical scenarios are `PASS`.
   268	3. Coverage is 100% of playbook scenarios defined by the root index and backed by per-feature files (`COVERED_FEATURES == TOTAL_FEATURES`).
   269	4. No unresolved blocking triage item remains.
   270	
   271	### Root-vs-Feature Rule
   272	
   273	Keep global verdict logic in the root playbook. Put feature-specific acceptance caveats in the matching per-feature files.
   274	
   275	---
   276	
   277	## 6. SUB-AGENT ORCHESTRATION AND WAVE PLANNING
   278	
   279	### Purpose
   280	
   281	This section records wave planning and capacity guidance for the manual testing package. It is not a runtime support matrix by itself.
   282	
   283	### Operational Rules
   284	
   285	1. Probe runtime capacity at start.
   286	2. Reserve one coordinator.
   287	3. Saturate remaining worker slots.
   288	4. Pre-assign explicit scenario IDs and matching per-feature files to each wave before execution.
   289	5. Run destructive scenarios in a dedicated sandbox-only wave.
   290	6. After each wave, save context and evidence, then begin the next wave.
   291	7. Record utilization table, per-feature file references, and evidence paths in the final report.
   292	
   293	### What Belongs In Per-Feature Files
   294	
   295	- Real user request
   296	- Prompt field following the Role -> Context -> Action -> Format contract
   297	- Expected delegation or alternate-CLI routing
   298	- Desired user-visible outcome
   299	- Feature-specific acceptance caveats or isolation constraints
   300	
   301	---
   302	
   303	## 7. {CAT1_HEADING} (`{CAT1}-001..{CAT1}-NNN`)
   304	
   305	### {CAT1}-001 | {FEATURE_NAME}
   306	
   307	#### Description
   308	Verify {OBJECTIVE}.
   309	
   310	#### Scenario Contract
   311	Prompt: `{PROMPT — natural-human by default; use RCAF "As a {ROLE}, ..." only when actor is an AI orchestrator. See references/prompt-voice.md.}`
   312	
   313	{SCENARIO_CONTRACT_SUMMARY}
   314	
   315	Desired user-visible outcome: {DESIRED_USER_OUTCOME}
   316	
   317	#### Test Execution
   318	> **Feature File:** [{CAT1}-001]({CAT1_DIR}/{FEATURE_SLUG}.md)
   319	> **Catalog:** [{CATALOG_PATH_1}](../feature-catalog/{CATALOG_PATH_1})
   320	
   321	---
   322	
   323	## 8. {CAT2_HEADING} (`{CAT2}-001..{CAT2}-NNN`)
   324	
   325	### {CAT2}-001 | {FEATURE_NAME_2}
   326	
   327	#### Description
   328	Verify {OBJECTIVE_2}.
   329	
   330	#### Scenario Contract
   331	Prompt: `{PROMPT_2 — natural-human by default; use RCAF only for orchestrator-as-actor scenarios per references/prompt-voice.md}`
   332	
   333	{SCENARIO_CONTRACT_SUMMARY_2}
   334	
   335	Desired user-visible outcome: {DESIRED_USER_OUTCOME_2}
   336	
   337	#### Test Execution
   338	> **Feature File:** [{CAT2}-001]({CAT2_DIR}/{FEATURE_SLUG_2}.md)
   339	> **Catalog:** [{CATALOG_PATH_2}](../feature-catalog/{CATALOG_PATH_2})
   340	
     1	---
     2	title: Manual Testing Playbook Snippet Template
     3	description: Template for per-feature scenario files stored directly under manual-testing-playbook category directories.
     4	trigger_phrases:
     5	  - "playbook snippet template"
     6	  - "per feature scenario file"
     7	  - "nine column test row"
     8	  - "scenario execution detail"
     9	importance_tier: normal
    10	contextType: general
    11	version: 1.8.0.11
    12	---
    13	
    14	# Manual Testing Playbook Snippet Template
    15	
    16	Per-feature scenario files for split manual testing playbooks. Use this template for the one-file-per-feature contract described in the main playbook template.
    17	
    18	> **EXECUTION POLICY**: Every scenario MUST be executed for real — not mocked, not stubbed, not classified as "unautomatable". AI agents executing these scenarios must run the actual commands, inspect real files, call real handlers, and verify real outputs. The only acceptable classifications are PASS, FAIL, or SKIP (with a specific sandbox blocker documented). "UNAUTOMATABLE" is not a valid status.
    19	
    20	---
    21	
    22	## 1. OVERVIEW
    23	
    24	Each feature file is the canonical home for full scenario execution detail. The root `manual-testing-playbook.md` stays readable by summarizing the feature and linking here, while the feature file carries the realistic user-testing context, orchestration process, 9-column test row, structured source references, and concise metadata. The file shape should intentionally mirror the Feature Catalog snippet pattern so operators can move between the catalog and the playbook without relearning the document structure.
    25	
    26	**Required uses**:
    27	- One file per feature ID
    28	- One primary 9-column scenario row per file
    29	- Frontmatter that mirrors the larger root docs (`title` + `description`)
    30	- Root playbook summary plus per-feature file cross-link
    31	- Realistic user request and orchestrator prompt
    32	- Desired user-visible outcome and execution process notes
    33	
    34	**Do not use this template for**:
    35	- General reusable prose fragments
    36	- Replacing root-level review/release-readiness or orchestration guidance
    37	- Spreading one feature across multiple primary files without a clear reason
    38	
    39	**Validator note**: The current validator checks markdown structure on the root playbook and does not recurse into category folders, so per-feature file structure needs manual review. Cross-file markdown links are verified separately by the `check-markdown-links.cjs` CI guard (fails the PR on any broken markdown link).
    40	
    41	---
    42	
    43	## 2. TEMPLATE SCAFFOLD
    44	
    45	Copy this into `manual-testing-playbook/{CATEGORY_DIR}/{FEATURE_SLUG}.md`. Both placeholder values must be kebab-case:
    46	
    47	```markdown
    48	---
    49	title: "{FEATURE_ID} -- {FEATURE_NAME}"
    50	description: "This scenario validates {FEATURE_NAME} for `{FEATURE_ID}`. It focuses on {OBJECTIVE}."
    51	stage: routing   # routing | holdout | negative — benchmark-tier grouping; carries what a numbered filename prefix used to encode
    52	# Lane C skill-benchmark fields — REQUIRED when this playbook also serves as a hub's
    53	# skill-benchmark corpus. The scenario loader SKIPS any feature file whose frontmatter
    54	# carries none of id / expected_intent / expected_resources, so a routing scenario
    55	# without them is silently absent from the D1 benchmark. Omit them for a pure
    56	# manual-testing playbook that is never scored.
    57	id: "{FEATURE_ID}"                       # stable scenario id; falls back to the filename if omitted
    58	expected_intent: "{EXPECTED_INTENT}"     # routing intent/mode the skill should select for this prompt
    59	expected_resources:                      # resource paths the correct route must load (one per line)
    60	  - "{EXPECTED_RESOURCE_PATH}"
    61	version: 1.0.0.0
    62	---
    63	
    64	# {FEATURE_ID} -- {FEATURE_NAME}
    65	
    66	This document captures the realistic user-testing contract, current behavior, execution flow, source anchors, and metadata for `{FEATURE_ID}`.
    67	
    68	---
    69	
    70	## 1. OVERVIEW
    71	
    72	This scenario validates {FEATURE_NAME} for `{FEATURE_ID}`. It focuses on {OBJECTIVE}.
    73	
    74	### Why This Matters
    75	
    76	{WHY_THIS_MATTERS}
    77	
    78	---
    79	
    80	## 2. SCENARIO CONTRACT
    81	
    82	Operators run the exact prompt and command sequence for `{FEATURE_ID}` and confirm the expected signals without contradictory evidence.
    83	
    84	- Objective: {OBJECTIVE}
    85	- Real user request: `{REAL_USER_REQUEST}`
    86	- Prompt: `{PROMPT — natural-human voice by default (e.g., "Review this auth diff for security issues"); use RCAF "As a {ROLE}, {ACTION} against {TARGET}. Verify {EXPECTED_OUTCOME}. Return {OUTPUT_FORMAT}." only when actor is an AI orchestrator. See references/prompt-voice.md.}`
    87	- Expected execution process: {EXPECTED_PROCESS}
    88	- Expected signals: {EXPECTED_SIGNALS}
    89	- Desired user-visible outcome: {DESIRED_USER_OUTCOME}
    90	- Pass/fail: PASS if {PASS_CONDITION}; FAIL if {FAIL_CONDITION}
    91	
    92	---
    93	
    94	## 3. TEST EXECUTION
    95	
    96	### Prompt
    97	
    98	- Prompt: `{PROMPT — natural-human voice by default (e.g., "Review this auth diff for security issues"); use RCAF "As a {ROLE}, {ACTION} against {TARGET}. Verify {EXPECTED_OUTCOME}. Return {OUTPUT_FORMAT}." only when actor is an AI orchestrator. See references/prompt-voice.md.}`
    99	
   100	### Commands
   101	
   102	1. `{COMMAND_1}`
   103	2. `{COMMAND_2}`
   104	
   105	### Expected
   106	
   107	{EXPECTED_SIGNALS}
   108	
   109	### Evidence
   110	
   111	{EVIDENCE_DESCRIPTION}
   112	
   113	### Pass / Fail
   114	
   115	- **Pass**: {PASS_CONDITION}
   116	- **Fail**: {FAIL_CONDITION}
   117	
   118	### Failure Triage
   119	
   120	{TRIAGE_STEPS}
   121	
   122	### Optional Supplemental Checks
   123	
   124	Use this subsection only when the feature needs a tightly scoped follow-up variant, compatibility check, or artifact note.
   125	
   126	---
   127	
   128	## 4. SOURCE FILES
   129	
   130	### Playbook Sources
   131	
   132	| File | Role |
   133	|---|---|
   134	| `manual-testing-playbook.md` | Root directory page and scenario summary |
   135	| `../../feature-catalog/{CATALOG_PATH}` | Feature-catalog source describing the implementation contract |
   136	
   137	### Implementation And Test Anchors
   138	
   139	| File | Role |
   140	|---|---|
   141	| `{IMPLEMENTATION_FILE}` | Primary implementation anchor |
   142	| `{TEST_FILE}` | Regression or validation anchor |
   143	
   144	---
   145	
   146	## 5. SOURCE METADATA
   147	
   148	- Group: {CATEGORY_NAME}
   149	- Playbook ID: {FEATURE_ID}
   150	- Canonical root source: `manual-testing-playbook.md`
   151	- Feature file path: `{CATEGORY_DIR}/{FEATURE_SLUG}.md`
   152	```
   153	
   154	### Authoring Notes
   155	
   156	- Keep the feature file aligned with the matching root summary block and feature-catalog entry.
   157	- Preserve stable feature IDs and file paths once published.
   158	- The per-feature filename is a descriptive kebab-case slug with no numeric prefix (e.g. `full-runtime-dispatch.md`, not `001-full-runtime-dispatch.md`). Ordering and benchmark tier are owned by the root index and the `stage:` frontmatter field, not the filename — the scenario loader discovers files by their frontmatter, so a numbered filename buys nothing and forces a renumber-on-insert cascade.
   159	- Set `stage:` to mark the scenario's benchmark tier: `routing` (default — a positive in-domain recall scenario), `holdout` (a generalization scenario held out of the primary set), or `negative` (an out-of-domain scenario the skill must NOT route to). This is what a numbered/holdout/negative filename token used to signal implicitly. The skill-benchmark loader treats `stage: negative` as a suppression test (negative activation), not a positive routing hit.
   160	- For a scenario that also feeds the Lane C skill-benchmark, fill `id`, `expected_intent`, and `expected_resources` in the frontmatter, and keep the exact executor prompt in the `### Prompt` block — the loader parses the prompt from that block and records a `missing-exact-prompt` warning when it is absent. `expected_resources` is the list of resource paths the correct route should load; the D1 score is measured against it.
   161	- When a feature needs extra checks, add them beneath the main row instead of creating a second primary scenario row by default.
   162	- Put feature-specific review caveats, routing notes, and isolation constraints here instead of inventing separate sidecar docs.

