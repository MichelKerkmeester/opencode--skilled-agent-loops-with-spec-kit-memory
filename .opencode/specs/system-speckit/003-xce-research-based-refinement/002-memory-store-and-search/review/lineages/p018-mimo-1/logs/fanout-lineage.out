{"type":"tool_use","timestamp":1781718259570,"sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","part":{"type":"tool","tool":"read","callID":"call_d821f67b8dea410e88035760","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Index\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import { createHash } from 'node:crypto';\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. CORE AND UTILS IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\n13: import { beginMaintenance } from '../lib/storage/maintenance-marker.js';\n14: import { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\n15: import { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\n16: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* ───────────────────────────────────────────────────────────────\n24:    2. LIB MODULE IMPORTS\n25: ──────────────────────────────────────────────────────────────── */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* ───────────────────────────────────────────────────────────────\n82:    4. TYPES\n83: ──────────────────────────────────────────────────────────────── */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   orphanSwept: number;\n161:   orphanSweepFailed: number;\n162:   orphanSweepScanned: number;\n163:   orphanSweepNextCursor: number | null;\n164:   moveReconciled?: number;\n165:   files: ScanFileEntry[];\n166:   constitutional: {\n167:     found: number;\n168:     indexed: number;\n169:     alreadyIndexed: number;\n170:   };\n171:   incremental: {\n172:     enabled: boolean;\n173:     fast_path_skips: number;\n174:     mtime_changed: number;\n175:     metadataPromoter: {\n176:       processed: number;\n177:       resolved: number;\n178:       inserted: number;\n179:       skippedManual: number;\n180:       staleTombstoned: number;\n181:       staleDeleted: number;\n182:       warnings: number;\n183:     };\n184:   };\n185:   dedup: {\n186:     inputTotal: number;\n187:     uniqueTotal: number;\n188:     duplicatesSkipped: number;\n189:   };\n190:   aliasConflicts: AliasConflictSummary;\n191:   divergenceReconcile: DivergenceReconcileSummary;\n192:   checkpointRepair: CheckpointRepairReport;\n193:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n194:   warnings: string[];\n195:   capExceeded: DiscoveryCapExceeded;\n196: }\n197: \n198: interface CategorizedFiles {\n199:   toIndex: string[];\n200:   toUpdate: string[];\n201:   toSkip: string[];\n202:   toDelete: string[];\n203: }\n204: \n205: interface ScanKeyOptions {\n206:   spec_folder: string | null;\n207:   force: boolean;\n208:   incremental: boolean;\n209:   include_constitutional: boolean;\n210:   include_spec_docs: boolean;\n211: }\n212: \n213: interface RecordDeleteResult {\n214:   deleted: number;\n215:   failed: number;\n216:   actions: StatediffAction[];\n217: }\n218: \n219: interface OrphanSweepDeleteResult {\n220:   swept: number;\n221:   failed: number;\n222:   scannedRows: number;\n223:   nextCursor: number | null;\n224:   actions: StatediffAction[];\n225: }\n226: \n227: interface OrphanSweepCandidates {\n228:   swept: number;\n229:   nextCursor: number | null;\n230:   scannedRows: number;\n231:   orphanRecordIds?: number[];\n232: }\n233: \n234: const ORPHAN_SWEEP_LIMIT = 200;\n235: \n236: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n237: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n238: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n239: // event-loop block from a phase that is merely slow but yields — the two need\n240: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n241: const LOOP_LAG_SAMPLE_MS = 250;\n242: const LOOP_LAG_WARN_MS = 1000;\n243: \n244: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n245:   return {\n246:     sentinelPresent: false,\n247:     attempted: false,\n248:     completed: 0,\n249:     failed: 0,\n250:     skipped: 0,\n251:     cleared: false,\n252:     error: null,\n253:   };\n254: }\n255: \n256: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n257:   try {\n258:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n259:       source: 'memory_index_scan',\n260:       actor: 'mcp:memory_index_scan',\n261:     });\n262:     return {\n263:       sentinelPresent: repair.sentinelPresent,\n264:       attempted: repair.attempted,\n265:       completed: repair.summary?.completed.length ?? 0,\n266:       failed: repair.summary?.failed.length ?? 0,\n267:       skipped: repair.summary?.skipped.length ?? 0,\n268:       cleared: repair.cleared,\n269:       error: repair.error,\n270:     };\n271:   } catch (error: unknown) {\n272:     return {\n273:       ...emptyCheckpointRepairReport(),\n274:       sentinelPresent: true,\n275:       attempted: true,\n276:       error: toErrorMessage(error),\n277:     };\n278:   }\n279: }\n280: \n281: function createScanKey(options: ScanKeyOptions): string {\n282:   const normalized = {\n283:     spec_folder: options.spec_folder ?? null,\n284:     force: !!options.force,\n285:     incremental: !!options.incremental,\n286:     include_constitutional: !!options.include_constitutional,\n287:     include_spec_docs: !!options.include_spec_docs,\n288:   };\n289: \n290:   return createHash('sha256')\n291:     .update(JSON.stringify(normalized))\n292:     .digest('hex')\n293:     .slice(0, 16);\n294: }\n295: \n296: interface ScanArgs {\n297:   specFolder?: string | null;\n298:   force?: boolean;\n299:   includeConstitutional?: boolean;\n300:   includeSpecDocs?: boolean;\n301:   incremental?: boolean;\n302:   // Opt-in: run the scan as a background job and return a jobId immediately.\n303:   background?: boolean;\n304:   tenantId?: string;\n305:   userId?: string;\n306:   agentId?: string;\n307:   sessionId?: string;\n308:   provenanceSource?: string;\n309:   provenanceActor?: string;\n310:   governedAt?: string;\n311:   retentionPolicy?: 'keep' | 'ephemeral';\n312:   deleteAfter?: string;\n313: }\n314: \n315: /* ───────────────────────────────────────────────────────────────\n316:    5. SHARED INDEXING LOGIC\n317: ──────────────────────────────────────────────────────────────── */\n318: \n319: import { indexMemoryFile } from './memory-save.js';\n320: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n321: import type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n322: \n323: /** Index a single memory file, delegating to the shared indexMemoryFile logic */\n324: async function indexSingleFile(\n325:   filePath: string,\n326:   force: boolean = false,\n327:   options?: {\n328:     qualityGateMode?: 'enforce' | 'warn-only';\n329:     fromScan?: boolean;\n330:     asyncEmbedding?: boolean;\n331:     governance?: GovernanceDecision;\n332:     provenance?: WriteProvenanceContext;\n333:   },\n334: ): Promise<IndexResult> {\n335:   return indexMemoryFile(filePath, {\n336:     force,\n337:     qualityGateMode: options?.qualityGateMode,\n338:     fromScan: options?.fromScan,\n339:     asyncEmbedding: options?.asyncEmbedding,\n340:     governance: options?.governance,\n341:     provenance: options?.provenance,\n342:   });\n343: }\n344: \n345: /* ───────────────────────────────────────────────────────────────\n346:    6. MEMORY INDEX SCAN HANDLER\n347: ──────────────────────────────────────────────────────────────── */\n348: \n349: // Hooks let a background runner observe cancellation and report phase/progress.\n350: // On the synchronous path every hook is undefined, so behavior is identical.\n351: interface ScanRunContext {\n352:   isCancelled?: () => boolean;\n353:   onPhase?: (phase: string) => void;\n354:   onProgress?: (progress: { processed: number; total: number }) => void;\n355: }\n356: \n357: // Pull the envelope.data field back out of an MCP response so status can echo it.\n358: function extractEnvelopeData(response: MCPResponse): unknown {\n359:   try {\n360:     const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n361:     if (typeof text !== 'string') return null;\n362:     const parsed = JSON.parse(text) as { data?: unknown };\n363:     return parsed?.data ?? null;\n364:   } catch (_error: unknown) {\n365:     return null;\n366:   }\n367: }\n368: \n369: // Persisted payload for debugging: scan shape only, no governance identifiers.\n370: function redactScanArgs(args: ScanArgs): Record<string, unknown> {\n371:   return {\n372:     specFolder: args.specFolder ?? null,\n373:     force: !!args.force,\n374:     includeConstitutional: args.includeConstitutional !== false,\n375:     includeSpecDocs: args.includeSpecDocs !== false,\n376:     incremental: args.incremental !== false,\n377:     background: true,\n378:   };\n379: }\n380: \n381: function cancelledScanEnvelope(scanKey: string): MCPResponse {\n382:   return createMCPSuccessResponse({\n383:     tool: 'memory_index_scan',\n384:     summary: 'Index scan cancelled before completion',\n385:     data: { status: 'cancelled', cancelled: true, scanKey },\n386:     hints: ['The scan was cancelled via memory_index_scan_cancel'],\n387:   });\n388: }\n389: \n390: /** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\n391: async function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n392:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n393:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n394:   if (restoreBarrier) {\n395:     recordMaintenanceRun('memory_index_scan', { status: 'error' });\n396:     return createMCPErrorResponse({\n397:       tool: 'memory_index_scan',\n398:       error: restoreBarrier.message,\n399:       code: restoreBarrier.code,\n400:       recovery: {\n401:         hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n402:         actions: ['Wait for the restore to finish', 'Retry the index scan'],\n403:         severity: 'warning',\n404:       },\n405:     });\n406:   }\n407: \n408:   const {\n409:     specFolder: spec_folder = null,\n410:     force = false,\n411:     includeConstitutional: include_constitutional = true,\n412:     includeSpecDocs: include_spec_docs = true,\n413:     incremental = true\n414:   } = args;\n415:   const scanKey = createScanKey({\n416:     spec_folder,\n417:     force,\n418:     incremental,\n419:     include_constitutional,\n420:     include_spec_docs,\n421:   });\n422:   const governedIngest = requiresGovernedIngest(args);\n423:   const governanceDecision = validateGovernedIngest(args);\n424:   if (!governanceDecision.allowed) {\n425:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n426:   }\n427: \n428:   // Pre-flight dimension check\n429:   try {\n430:     const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n431:     if (profile) {\n432:       console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n433:     }\n434:   } catch (dimCheckError: unknown) {\n435:     const message = toErrorMessage(dimCheckError);\n436:     console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n437:   }\n438: \n439:   await checkDatabaseUpdated();\n440: \n441:   // Atomic scan lease check.\n442:   // Reserve scan_started_at up front to avoid check-then-set race windows.\n443:   const now = Date.now();\n444:   const lease = await acquireIndexScanLease({\n445:     now,\n446:     cooldownMs: INDEX_SCAN_COOLDOWN,\n447:   });\n448:   if (!lease.acquired) {\n449:     let message: string;\n450:     if (lease.reason === 'lease_active') {\n451:       message = 'A scan is already in progress; this call coalesced onto it.';\n452:     } else if (lease.reason === 'contention') {\n453:       message = 'The index DB is briefly locked by another writer; retry shortly.';\n454:     } else {\n455:       message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n456:     }\n457:     recordMaintenanceRun('memory_index_scan', {\n458:       status: 'coalesced',\n459:       counts: { waitSeconds: lease.waitSeconds },\n460:       staleCandidates: 0,\n461:     });\n462:     return createMCPSuccessResponse({\n463:       tool: 'memory_index_scan',\n464:       summary: message,\n465:       data: {\n466:         success: true,\n467:         coalesced: true,\n468:         status: 'coalesced',\n469:         reason: lease.reason,\n470:         scanKey,\n471:         waitSeconds: lease.waitSeconds,\n472:         nextPollAfterMs: lease.waitSeconds * 1000,\n473:         message,\n474:       },\n475:       hints: [message],\n476:     });\n477:   }\n478: \n479:   let scanLeaseReleased = false;\n480:   const releaseScanLease = async (): Promise<void> => {\n481:     if (scanLeaseReleased) return;\n482:     scanLeaseReleased = true;\n483:     await completeIndexScanLease(Date.now());\n484:   };\n485: \n486:   const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n487: \n488:   // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n489:   // processBatches() runs all batches sequentially and may exceed the lease expiry\n490:   // window (each batch waits on embedding/API latency). Without a periodic refresh\n491:   // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n492:   // launch a second parallel scan. Refresh well inside the expiry window (a third of\n493:   // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n494:   // from holding the event loop open at shutdown; finally clears it before release.\n495:   const leaseExpiryMs = lease.leaseExpiryMs;\n496:   const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n497:   let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n498: \n499:   // Background scans pass an onPhase hook; the synchronous foreground path does not.\n500:   // Gate diagnostics on it so the synchronous path's behavior stays identical.\n501:   const instrument = typeof ctx.onPhase === 'function';\n502:   let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n503:   let maxLoopLagMs = 0;\n504: \n505:   try {\n506:   leaseHeartbeat = setInterval(() => {\n507:     refreshScanLease();\n508:   }, leaseHeartbeatMs);\n509:   leaseHeartbeat.unref?.();\n510: \n511:   if (instrument) {\n512:     let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n513:     loopLagTimer = setInterval(() => {\n514:       const sampledAt = Date.now();\n515:       const lag = sampledAt - loopLagExpectedAt;\n516:       loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n517:       if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n518:       if (lag > LOOP_LAG_WARN_MS) {\n519:         // A late sample means the loop was blocked since the prior tick; logged\n520:         // adjacent to the phase=... line of whatever phase just ran, so the daemon\n521:         // log timeline fingers the blocking phase.\n522:         console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n523:       }\n524:     }, LOOP_LAG_SAMPLE_MS);\n525:     loopLagTimer.unref?.();\n526:   }\n527: \n528:   if (ctx.isCancelled?.()) {\n529:     await releaseScanLease();\n530:     return cancelledScanEnvelope(scanKey);\n531:   }\n532:   ctx.onPhase?.('discovering');\n533: \n534:   const workspacePath: string = DEFAULT_BASE_PATH;\n535: \n536:   const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n537:   const specDocFiles = include_spec_docs\n538:     ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n539:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n540:   const graphMetadataFiles = include_spec_docs\n541:     ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n542:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n543:   const walkerWarnings = [\n544:     ...discoveryWarnings(specDocFiles),\n545:     ...discoveryWarnings(graphMetadataFiles),\n546:   ];\n547:   const walkerCapExceeded = mergeDiscoveryCapExceeded(\n548:     discoveryCaps(specDocFiles),\n549:     discoveryCaps(graphMetadataFiles),\n550:   );\n551: \n552:   const canonicalKeyCache = new Map<string, string>();\n553:   const getCachedKey = (filePath: string): string => {\n554:     const cached = canonicalKeyCache.get(filePath);\n555:     if (cached) {\n556:       return cached;\n557:     }\n558: \n559:     const canonicalKey = getCanonicalPathKey(filePath);\n560:     canonicalKeyCache.set(filePath, canonicalKey);\n561:     return canonicalKey;\n562:   };\n563: \n564:   const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n565:   const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n566:   const seenCanonicalFiles = new Set<string>();\n567:   const files: string[] = [];\n568: \n569:   for (const filePath of mergedFiles) {\n570:     const canonicalKey = getCachedKey(filePath);\n571:     if (seenCanonicalFiles.has(canonicalKey)) {\n572:       continue;\n573:     }\n574:     seenCanonicalFiles.add(canonicalKey);\n575:     files.push(filePath);\n576:   }\n577: \n578:   const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n579:   if (dedupDuplicatesSkipped > 0) {\n580:     console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n581:   }\n582: \n583:   const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n584:     if (recordIds.length === 0) {\n585:       return { deleted: 0, failed: 0, actions: [] };\n586:     }\n587: \n588:     let deleted = 0;\n589:     let failed = 0;\n590:     const actions: StatediffAction[] = [];\n591: \n592:     for (const staleRecordId of recordIds) {\n593:       try {\n594:         const database = vectorIndex.getDb();\n595:         const staleSnapshot = database?.prepare(\n596:           'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n597:         ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n598: \n599:         if (database) {\n600:           causalEdges.init(database);\n601:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n602:             reason: 'memory_index stale record cleanup',\n603:             command: 'memory-index.deleteIndexedRecordIds',\n604:             restoreContext: {\n605:               memoryId: staleRecordId,\n606:               specFolder: staleSnapshot?.spec_folder ?? null,\n607:               filePath: staleSnapshot?.file_path ?? null,\n608:             },\n609:           });\n610:         }\n611: \n612:         if (vectorIndex.deleteMemory(staleRecordId)) {\n613:           deleted++;\n614:           actions.push(createStatediffAction('delete', {\n615:             target: 'memory_index',\n616:             key: String(staleRecordId),\n617:             sourceOperation: 'scan',\n618:             oldStateHash: null,\n619:             newStateHash: null,\n620:             metadata: {\n621:               filePath: staleSnapshot?.file_path ?? null,\n622:               specFolder: staleSnapshot?.spec_folder ?? null,\n623:             },\n624:           }));\n625:           // Record DELETE history only after confirmed deletion.\n626:           try {\n627:             recordHistory(\n628:               staleRecordId,\n629:               'DELETE',\n630:               staleSnapshot?.file_path ?? null,\n631:               null,\n632:               'mcp:memory_index_scan',\n633:               staleSnapshot?.spec_folder ?? null,\n634:             );\n635:           } catch (_histErr: unknown) {\n636:             // History recording is best-effort\n637:           }\n638:         } else {\n639:           failed++;\n640:         }\n641:       } catch (_error: unknown) {\n642:         failed++;\n643:       }\n644:     }\n645: \n646:     return { deleted, failed, actions };\n647:   };\n648: \n649:   const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n650:     if (paths.length === 0) {\n651:       return { deleted: 0, failed: 0, actions: [] };\n652:     }\n653: \n654:     return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n655:   };\n656: \n657:   const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n658:     if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n659:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n660:     }\n661: \n662:     const sweepOrphanIndexRows = (incrementalIndex as {\n663:       sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n664:     }).sweepOrphanIndexRows;\n665: \n666:     if (typeof sweepOrphanIndexRows !== 'function') {\n667:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n668:     }\n669: \n670:     const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n671:     const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n672:     return {\n673:       swept: deleteResult.deleted,\n674:       failed: deleteResult.failed,\n675:       scannedRows: sweep.scannedRows,\n676:       nextCursor: sweep.nextCursor,\n677:       actions: deleteResult.actions,\n678:     };\n679:   };\n680: \n681:   const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n682:     try {\n683:       runPostMutationHooks('scan', { ...context, statediffActions: actions });\n684:     } catch (error: unknown) {\n685:       console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n686:     }\n687:   };\n688: \n689:   const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n690:     result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n691:   );\n692: \n693:   const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n694:     target: 'memory_index',\n695:     key: 'trigger-embedding-backfill',\n696:     sourceOperation: 'scan',\n697:     metadata: {\n698:       readyRows: result.readyRows,\n699:       failedRows: result.failedRows,\n700:       pendingRows: result.pendingRows,\n701:     },\n702:   });\n703: \n704:   const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n705:     if (actions.length === 0) {\n706:       return;\n707:     }\n708:     results.aliasConflicts = detectAliasConflictsFromIndex();\n709:     results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n710:   };\n711: \n712:   const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n713:     try {\n714:       const repairResult = await repairIncompleteMarkers(\n715:         { database: requireDb(), plannerMode: 'full-auto' },\n716:         { limit: BATCH_SIZE },\n717:       );\n718:       if (repairResult.failed > 0) {\n719:         console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n720:       }\n721:       return repairResult.repaired;\n722:     } catch (error: unknown) {\n723:       console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n724:       return 0;\n725:     }\n726:   };\n727: \n728:   const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n729:     if (!isMemoryIdempotencyEnabled()) {\n730:       return 0;\n731:     }\n732:     try {\n733:       const database = requireDb();\n734:       const rows = database.prepare(`\n735:         SELECT id, spec_folder, title, content_text, content_hash,\n736:                tenant_id, user_id, agent_id, session_id\n737:         FROM memory_index\n738:         WHERE parent_id IS NULL\n739:           AND embedding_status = 'success'\n740:           AND content_text IS NOT NULL\n741:           AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n742:         ORDER BY id ASC\n743:         LIMIT ?\n744:       `).all(BATCH_SIZE) as Array<{\n745:         id: number;\n746:         spec_folder: string;\n747:         title: string | null;\n748:         content_text: string;\n749:         content_hash: string | null;\n750:         tenant_id: string | null;\n751:         user_id: string | null;\n752:         agent_id: string | null;\n753:         session_id: string | null;\n754:       }>;\n755:       let repaired = 0;\n756:       for (const row of rows) {\n757:         try {\n758:           const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n759:           const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n760:           recordNearDuplicateCheck({\n761:             database,\n762:             memoryId: row.id,\n763:             specFolder: row.spec_folder,\n764:             contentHash: row.content_hash,\n765:             embedding,\n766:             scope: {\n767:               tenantId: row.tenant_id,\n768:               userId: row.user_id,\n769:               agentId: row.agent_id,\n770:               sessionId: row.session_id,\n771:             },\n772:           });\n773:           repaired++;\n774:         } catch (error: unknown) {\n775:           console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n776:         }\n777:       }\n778:       return repaired;\n779:     } catch (error: unknown) {\n780:       console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n781:       return 0;\n782:     }\n783:   };\n784: \n785:   if (files.length === 0) {\n786:     let staleDeleted = 0;\n787:     let staleDeleteFailed = 0;\n788:     const orphanSweepResult = runGlobalOrphanSweep();\n789:     const postInsertEnrichmentRepaired = await runPostInsertEnrichmentRepairBackfill();\n790:     await runNearDuplicateRepairBackfill();\n791: \n792:     if (incremental && !force) {\n793:       const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n794:       const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n795:       staleDeleted = staleDeleteResult.deleted;\n796:       staleDeleteFailed = staleDeleteResult.failed;\n797:       if (staleDeleted > 0) {\n798:         runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n799:       }\n800:     }\n801: \n802:     const triggerEmbeddingBackfill = await runTriggerEmbeddingBackfill(requireDb(), {\n803:       isCancelled: () => ctx.isCancelled?.() ?? false,\n804:     });\n805: \n806:     if (orphanSweepResult.swept > 0) {\n807:       runScanInvalidationHooks({\n808:         orphanSwept: orphanSweepResult.swept,\n809:         orphanSweepFailed: orphanSweepResult.failed,\n810:         operation: 'orphan-sweep',\n811:       }, orphanSweepResult.actions);\n812:     }\n813:     if (postInsertEnrichmentRepaired > 0) {\n814:       runScanInvalidationHooks({\n815:         postInsertEnrichmentRepaired,\n816:         operation: 'post-insert-enrichment-repair',\n817:       }, [createStatediffAction('upsert', {\n818:         target: 'graph_edge',\n819:         key: 'post-insert-enrichment-repair',\n820:         sourceOperation: 'scan',\n821:         metadata: { postInsertEnrichmentRepaired },\n822:       })]);\n823:     }\n824:     if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n825:       runScanInvalidationHooks({\n826:         triggerEmbeddingBackfill,\n827:         operation: 'trigger-embedding-backfill',\n828:       }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n829:     }\n830: \n831:     recordMaintenanceRun('memory_index_scan', {\n832:       status: 'success',\n833:       counts: {\n834:         scanned: 0,\n835:         indexed: 0,\n836:         updated: 0,\n837:         unchanged: 0,\n838:         failed: 0,\n839:         staleDeleted,\n840:         staleDeleteFailed,\n841:         orphanSwept: orphanSweepResult.swept,\n842:       },\n843:       staleCandidates: staleDeleted + staleDeleteFailed,\n844:     });\n845:     await releaseScanLease();\n846:     return createMCPSuccessResponse({\n847:       tool: 'memory_index_scan',\n848:       summary: 'No memory files found',\n849:       data: {\n850:         status: 'complete',\n851:         scanKey,\n852:         scanned: 0,\n853:         indexed: 0,\n854:         updated: 0,\n855:         unchanged: 0,\n856:         failed: 0,\n857:         staleDeleted,\n858:         staleDeleteFailed,\n859:         postInsertEnrichmentRepaired,\n860:         triggerEmbeddingBackfill,\n861:         orphanSwept: orphanSweepResult.swept,\n862:         orphanSweepFailed: orphanSweepResult.failed,\n863:         orphanSweepScanned: orphanSweepResult.scannedRows,\n864:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n865:         checkpointRepair,\n866:         warnings: walkerWarnings,\n867:         capExceeded: walkerCapExceeded,\n868:       },\n869:       hints: [\n870:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n871:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n872:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n873:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n874:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n875:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n876:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n877:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n878:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n879:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n880:         'Constitutional files go in .opencode/skills/*/constitutional/'\n881:       ]\n882:     });\n883:   }\n884: \n885:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n886: \n887:   const results: ScanResults = {\n888:     scanned: files.length,\n889:     indexed: 0,\n890:     updated: 0,\n891:     unchanged: 0,\n892:     failed: 0,\n893:     deferred: 0,\n894:     skipped_mtime: 0,\n895:     mtimeUpdates: 0,\n896:     staleDeleted: 0,\n897:     staleDeleteFailed: 0,\n898:     postInsertEnrichmentRepaired: 0,\n899:     orphanSwept: 0,\n900:     orphanSweepFailed: 0,\n901:     orphanSweepScanned: 0,\n902:     orphanSweepNextCursor: null,\n903:     files: [],\n904:     constitutional: {\n905:       found: constitutionalFiles.length,\n906:       indexed: 0,\n907:       alreadyIndexed: 0\n908:     },\n909:     incremental: {\n910:       enabled: incremental && !force,\n911:       fast_path_skips: 0,\n912:       mtime_changed: 0,\n913:       metadataPromoter: {\n914:         processed: 0,\n915:         resolved: 0,\n916:         inserted: 0,\n917:         skippedManual: 0,\n918:         staleTombstoned: 0,\n919:         staleDeleted: 0,\n920:         warnings: 0,\n921:       }\n922:     },\n923:     dedup: {\n924:       inputTotal: mergedFiles.length,\n925:       uniqueTotal: files.length,\n926:       duplicatesSkipped: dedupDuplicatesSkipped,\n927:     },\n928:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n929:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n930:     checkpointRepair,\n931:     warnings: walkerWarnings,\n932:     capExceeded: walkerCapExceeded,\n933:   };\n934:   const scanAppliedActions: StatediffAction[] = [];\n935: \n936:   let filesToIndex: string[] = files;\n937:   let filesToDelete: string[] = [];\n938: \n939:   if (incremental && !force) {\n940:     const startCategorize = Date.now();\n941:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n942: \n943:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n944:     filesToDelete = categorized.toDelete;\n945: \n946:     results.unchanged = categorized.toSkip.length;\n947:     results.skipped_mtime = categorized.toSkip.length;\n948:     results.incremental.fast_path_skips = categorized.toSkip.length;\n949:     results.incremental.mtime_changed = categorized.toUpdate.length;\n950: \n951:     for (const unchangedPath of categorized.toSkip) {\n952:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n953:         results.constitutional.alreadyIndexed++;\n954:       }\n955:     }\n956: \n957:     const categorizeTime = Date.now() - startCategorize;\n958:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n959:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n960:   }\n961: \n962:   // Attempt move reconciliation before full delete+reindex cycle.\n963:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n964:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n965:   // stored-document_type cross-checks; the matched row is updated in place.\n966:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n967:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n968:     if (moveResult.reconciled.length > 0) {\n969:       results.moveReconciled = moveResult.reconciled.length;\n970:       filesToDelete = moveResult.filteredToDelete;\n971:       filesToIndex = moveResult.filteredToIndex;\n972:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n973:     }\n974:   }\n975: \n976:   const plannedScanActions = [\n977:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n978:       target: 'memory_index',\n979:       key: getCachedKey(filePath),\n980:       sourceOperation: 'scan',\n981:       metadata: { filePath },\n982:     })),\n983:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n984:       target: 'memory_index',\n985:       key: getCachedKey(filePath),\n986:       sourceOperation: 'scan',\n987:       metadata: { filePath },\n988:     })),\n989:   ];\n990:   if (plannedScanActions.length > 0) {\n991:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n992:   }\n993: \n994:   // Track successfully indexed files for post-indexing mtime update.\n995:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n996:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n997:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n998:   // Before indexing would cause silent data loss — a failed file would be\n999:   // Marked \"already indexed\" and permanently skipped.\n1000:   const successfullyIndexedFiles: string[] = [];\n1001:   const scanBatchSize = BATCH_SIZE;\n1002: \n1003:   ctx.onPhase?.('indexing');\n1004:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1005: \n1006:   if (filesToIndex.length > 0) {\n1007:     let processedInScan = 0;\n1008:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1009:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1010:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1011:       if (ctx.isCancelled?.()) {\n1012:         return { status: 'cancelled' } as IndexResult;\n1013:       }\n1014:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1015:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1016:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1017:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1018:       // spec docs and pass them through warn-only mode so they index against the same\n1019:       // pipeline without the document-evidence requirements.\n1020:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1021:       // During force reindex, use warn-only for all files — the goal is to index\n1022:       // everything that has valid frontmatter, not to enforce template contracts on\n1023:       // older files created before current templates were established.\n1024:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1025:       const indexResult = await indexSingleFile(filePath, force, {\n1026:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1027:         fromScan: true,\n1028:         asyncEmbedding: true,\n1029:         governance: governedIngest ? governanceDecision : undefined,\n1030:       });\n1031:       processedInScan += 1;\n1032:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1033:       return indexResult;\n1034:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1035: \n1036:     for (let i = 0; i < batchResults.length; i++) {\n1037:       const result = batchResults[i];\n1038:       const filePath = filesToIndex[i];\n1039:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1040: \n1041:       if (result.error) {\n1042:         results.failed++;\n1043:         results.files.push({\n1044:           file: path.basename(filePath),\n1045:           filePath,\n1046:           status: 'failed',\n1047:           error: result.error,\n1048:           errorDetail: result.errorDetail\n1049:         });\n1050:       } else if (isIndexResult(result)) {\n1051:         const isSuccessfulStatus =\n1052:           result.status === 'success' ||\n1053:           result.status === 'indexed' ||\n1054:           result.status === 'updated' ||\n1055:           result.status === 'unchanged' ||\n1056:           result.status === 'reinforced' ||\n1057:           result.status === 'duplicate' ||\n1058:           result.status === 'deferred';\n1059:         if (!isSuccessfulStatus) {\n1060:           results.failed++;\n1061:         }\n1062: \n1063:         if (result.status === 'indexed') {\n1064:           results.indexed++;\n1065:           successfullyIndexedFiles.push(filePath);\n1066:           scanAppliedActions.push(createStatediffAction('insert', {\n1067:             target: 'memory_index',\n1068:             key: String(result.id ?? getCachedKey(filePath)),\n1069:             sourceOperation: 'scan',\n1070:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1071:           }));\n1072:         } else if (result.status === 'updated') {\n1073:           results.updated++;\n1074:           successfullyIndexedFiles.push(filePath);\n1075:           scanAppliedActions.push(createStatediffAction('upsert', {\n1076:             target: 'memory_index',\n1077:             key: String(result.id ?? getCachedKey(filePath)),\n1078:             sourceOperation: 'scan',\n1079:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1080:           }));\n1081:         } else if (result.status === 'unchanged') {\n1082:           results.unchanged++;\n1083:           successfullyIndexedFiles.push(filePath);\n1084:         } else if (result.status === 'reinforced') {\n1085:           results.updated++;\n1086:           successfullyIndexedFiles.push(filePath);\n1087:           scanAppliedActions.push(createStatediffAction('upsert', {\n1088:             target: 'memory_index',\n1089:             key: String(result.id ?? getCachedKey(filePath)),\n1090:             sourceOperation: 'scan',\n1091:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1092:           }));\n1093:         } else if (result.status === 'duplicate') {\n1094:           results.unchanged++;\n1095:           successfullyIndexedFiles.push(filePath);\n1096:         } else if (result.status === 'deferred') {\n1097:           results.indexed++;\n1098:           results.deferred++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('insert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         }\n1107: \n1108:         if (isConstitutional) {\n1109:           if (result.status === 'indexed') {\n1110:             results.constitutional.indexed++;\n1111:           } else if (result.status === 'unchanged') {\n1112:             results.constitutional.alreadyIndexed++;\n1113:           }\n1114:         }\n1115: \n1116:         if (result.status !== 'unchanged') {\n1117:           const rejectionDetail = !isSuccessfulStatus\n1118:             ? {\n1119:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1120:                   ? { rejectionCode: result.rejectionCode }\n1121:                   : {}),\n1122:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1123:                   ? { rejectionReason: result.rejectionReason }\n1124:                   : (typeof result.message === 'string' && result.message.length > 0\n1125:                     ? { rejectionReason: result.message }\n1126:                     : {})),\n1127:                 ...(typeof result.error === 'string' && result.error.length > 0\n1128:                   ? { error: result.error }\n1129:                   : {}),\n1130:               }\n1131:             : {};\n1132: \n1133:           results.files.push({\n1134:             file: path.basename(filePath),\n1135:             filePath,\n1136:             specFolder: result.specFolder,\n1137:             status: result.status,\n1138:             id: result.id,\n1139:             isConstitutional,\n1140:             ...rejectionDetail,\n1141:           });\n1142:         }\n1143:       } else {\n1144:         results.failed++;\n1145:         results.files.push({\n1146:           file: path.basename(filePath),\n1147:           filePath,\n1148:           status: 'failed',\n1149:           error: 'Unexpected batch result shape',\n1150:           errorDetail: JSON.stringify(result),\n1151:         });\n1152:       }\n1153:     }\n1154:   }\n1155: \n1156:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1157:   // Failed files keep their old mtime so they are retried on next scan.\n1158:   // This is the ONLY place where scan-triggered mtime updates occur.\n1159:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1160:   // Which rolls back atomically on failure — a complementary safety mechanism.\n1161:   if (successfullyIndexedFiles.length > 0) {\n1162:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1163:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1164:   }\n1165: \n1166:   if (include_spec_docs) {\n1167:     const database = requireDb();\n1168:     let promoterYieldCount = 0;\n1169:     for (const fileResult of results.files) {\n1170:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1171:       // that is the whole corpus, so without a periodic macrotask yield the event\n1172:       // loop is starved for the duration and no IPC (status, cancel, health,\n1173:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1174:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1175:       // inside one, so atomicity on the shared connection is preserved.\n1176:       if (++promoterYieldCount % 200 === 0) {\n1177:         if (ctx.isCancelled?.()) {\n1178:           return cancelledScanEnvelope(scanKey);\n1179:         }\n1180:         await new Promise<void>((resolve) => setImmediate(resolve));\n1181:       }\n1182:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1183:         continue;\n1184:       }\n1185:       try {\n1186:         const promotion = promoteMetadataEdges(database, {\n1187:           memoryId: fileResult.id,\n1188:           filePath: fileResult.filePath,\n1189:         });\n1190:         results.incremental.metadataPromoter.processed += promotion.processed;\n1191:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1192:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1193:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1194:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1195:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1196:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1197:         for (const warning of promotion.warnings) {\n1198:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1199:         }\n1200:       } catch (error: unknown) {\n1201:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1202:       }\n1203:     }\n1204:   }\n1205: \n1206:   if (ctx.isCancelled?.()) {\n1207:     return cancelledScanEnvelope(scanKey);\n1208:   }\n1209:   ctx.onPhase?.('post-processing');\n1210: \n1211:   if (filesToDelete.length > 0) {\n1212:     if (results.failed === 0) {\n1213:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1214:       results.staleDeleted = staleDeleteResult.deleted;\n1215:       results.staleDeleteFailed = staleDeleteResult.failed;\n1216:       scanAppliedActions.push(...staleDeleteResult.actions);\n1217:     } else {\n1218:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1219:     }\n1220:   }\n1221: \n1222:   // Time each un-yielded tail phase: because these phases do not yield, their\n1223:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n1224:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n1225:   // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n1226:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n1227:     ctx.onPhase?.(phase);\n1228:     if (!instrument) {\n1229:       return await fn();\n1230:     }\n1231:     const startedAt = Date.now();\n1232:     try {\n1233:       return await fn();\n1234:     } finally {\n1235:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n1236:     }\n1237:   };\n1238: \n1239:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1240:   results.orphanSwept = orphanSweepResult.swept;\n1241:   results.orphanSweepFailed = orphanSweepResult.failed;\n1242:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1243:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1244:   scanAppliedActions.push(...orphanSweepResult.actions);\n1245: \n1246:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1247:   if (results.postInsertEnrichmentRepaired > 0) {\n1248:     scanAppliedActions.push(createStatediffAction('upsert', {\n1249:       target: 'graph_edge',\n1250:       key: 'post-insert-enrichment-repair',\n1251:       sourceOperation: 'scan',\n1252:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1253:     }));\n1254:   }\n1255: \n1256:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1257:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1258:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1259:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1260:   }\n1261:   await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1262: \n1263:   // Create causal chains between spec folder documents.\n1264:   // Includes deferred indexing outcomes and incremental single-file updates.\n1265:   if (include_spec_docs) {\n1266:     try {\n1267:       // Determine which spec folders had spec document changes in this scan.\n1268:       // We use parsed document type (not basename) to avoid false positives\n1269:       // From memory/plan.md or similar filenames.\n1270:       const affectedSpecFolders = new Set<string>();\n1271:       for (const fileResult of results.files) {\n1272:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1273:           continue;\n1274:         }\n1275: \n1276:         if (!fileResult.filePath) {\n1277:           continue;\n1278:         }\n1279: \n1280:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1281:         if (\n1282:           docType !== 'memory' &&\n1283:           docType !== 'constitutional'\n1284:         ) {\n1285:           affectedSpecFolders.add(fileResult.specFolder);\n1286:         }\n1287:       }\n1288: \n1289:       if (affectedSpecFolders.size > 0) {\n1290:         const database = requireDb();\n1291:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1292:         initCausalEdges(database);\n1293: \n1294:         // Build full per-folder document map from DB (not just this scan's files).\n1295:         const selectDocIds = database.prepare(`\n1296:           SELECT document_type, MAX(id) AS id\n1297:           FROM memory_index\n1298:           WHERE spec_folder = ?\n1299:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1300:           GROUP BY document_type\n1301:         `);\n1302: \n1303:         let chainsCreated = 0;\n1304:         let foldersProcessed = 0;\n1305:         let chainYieldCount = 0;\n1306: \n1307:         for (const folder of affectedSpecFolders) {\n1308:           // Per-folder synchronous DB work; yield + cancel-check between folders so a\n1309:           // large affected set cannot block the event loop (same rationale as the\n1310:           // metadata-edge sweep above).\n1311:           if (++chainYieldCount % 50 === 0) {\n1312:             if (ctx.isCancelled?.()) {\n1313:               return cancelledScanEnvelope(scanKey);\n1314:             }\n1315:             await new Promise<void>((resolve) => setImmediate(resolve));\n1316:           }\n1317:           const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n1318:           const docIds: Record<string, number> = {};\n1319: \n1320:           for (const row of rows) {\n1321:             if (row.document_type && typeof row.id === 'number') {\n\n(Output capped at 50 KB. Showing lines 1-1321. Use offset=1322 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* ───────────────────────────────────────────────────────────────\n   4. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields — the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. SHARED INDEXING LOGIC\n──────────────────────────────────────────────────────────────── */\n\nimport { indexMemoryFile } from './memory-save.js';\nimport type { GovernanceDecision } from '../lib/governance/scope-governance.js';\nimport type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n\n/** Index a single memory file, delegating to the shared indexMemoryFile logic */\nasync function indexSingleFile(\n  filePath: string,\n  force: boolean = false,\n  options?: {\n    qualityGateMode?: 'enforce' | 'warn-only';\n    fromScan?: boolean;\n    asyncEmbedding?: boolean;\n    governance?: GovernanceDecision;\n    provenance?: WriteProvenanceContext;\n  },\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    force,\n    qualityGateMode: options?.qualityGateMode,\n    fromScan: options?.fromScan,\n    asyncEmbedding: options?.asyncEmbedding,\n    governance: options?.governance,\n    provenance: options?.provenance,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MEMORY INDEX SCAN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n// Hooks let a background runner observe cancellation and report phase/progress.\n// On the synchronous path every hook is undefined, so behavior is identical.\ninterface ScanRunContext {\n  isCancelled?: () => boolean;\n  onPhase?: (phase: string) => void;\n  onProgress?: (progress: { processed: number; total: number }) => void;\n}\n\n// Pull the envelope.data field back out of an MCP response so status can echo it.\nfunction extractEnvelopeData(response: MCPResponse): unknown {\n  try {\n    const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n    if (typeof text !== 'string') return null;\n    const parsed = JSON.parse(text) as { data?: unknown };\n    return parsed?.data ?? null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\n// Persisted payload for debugging: scan shape only, no governance identifiers.\nfunction redactScanArgs(args: ScanArgs): Record<string, unknown> {\n  return {\n    specFolder: args.specFolder ?? null,\n    force: !!args.force,\n    includeConstitutional: args.includeConstitutional !== false,\n    includeSpecDocs: args.includeSpecDocs !== false,\n    incremental: args.incremental !== false,\n    background: true,\n  };\n}\n\nfunction cancelledScanEnvelope(scanKey: string): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: 'Index scan cancelled before completion',\n    data: { status: 'cancelled', cancelled: true, scanKey },\n    hints: ['The scan was cancelled via memory_index_scan_cancel'],\n  });\n}\n\n/** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\nasync function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    recordMaintenanceRun('memory_index_scan', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      recovery: {\n        hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the index scan'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    specFolder: spec_folder = null,\n    force = false,\n    includeConstitutional: include_constitutional = true,\n    includeSpecDocs: include_spec_docs = true,\n    incremental = true\n  } = args;\n  const scanKey = createScanKey({\n    spec_folder,\n    force,\n    incremental,\n    include_constitutional,\n    include_spec_docs,\n  });\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  // Pre-flight dimension check\n  try {\n    const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n    if (profile) {\n      console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n    }\n  } catch (dimCheckError: unknown) {\n    const message = toErrorMessage(dimCheckError);\n    console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n  }\n\n  await checkDatabaseUpdated();\n\n  // Atomic scan lease check.\n  // Reserve scan_started_at up front to avoid check-then-set race windows.\n  const now = Date.now();\n  const lease = await acquireIndexScanLease({\n    now,\n    cooldownMs: INDEX_SCAN_COOLDOWN,\n  });\n  if (!lease.acquired) {\n    let message: string;\n    if (lease.reason === 'lease_active') {\n      message = 'A scan is already in progress; this call coalesced onto it.';\n    } else if (lease.reason === 'contention') {\n      message = 'The index DB is briefly locked by another writer; retry shortly.';\n    } else {\n      message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n    }\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'coalesced',\n      counts: { waitSeconds: lease.waitSeconds },\n      staleCandidates: 0,\n    });\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: message,\n      data: {\n        success: true,\n        coalesced: true,\n        status: 'coalesced',\n        reason: lease.reason,\n        scanKey,\n        waitSeconds: lease.waitSeconds,\n        nextPollAfterMs: lease.waitSeconds * 1000,\n        message,\n      },\n      hints: [message],\n    });\n  }\n\n  let scanLeaseReleased = false;\n  const releaseScanLease = async (): Promise<void> => {\n    if (scanLeaseReleased) return;\n    scanLeaseReleased = true;\n    await completeIndexScanLease(Date.now());\n  };\n\n  const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n\n  // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n  // processBatches() runs all batches sequentially and may exceed the lease expiry\n  // window (each batch waits on embedding/API latency). Without a periodic refresh\n  // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n  // launch a second parallel scan. Refresh well inside the expiry window (a third of\n  // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n  // from holding the event loop open at shutdown; finally clears it before release.\n  const leaseExpiryMs = lease.leaseExpiryMs;\n  const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n  let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n\n  // Background scans pass an onPhase hook; the synchronous foreground path does not.\n  // Gate diagnostics on it so the synchronous path's behavior stays identical.\n  const instrument = typeof ctx.onPhase === 'function';\n  let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n  let maxLoopLagMs = 0;\n\n  try {\n  leaseHeartbeat = setInterval(() => {\n    refreshScanLease();\n  }, leaseHeartbeatMs);\n  leaseHeartbeat.unref?.();\n\n  if (instrument) {\n    let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n    loopLagTimer = setInterval(() => {\n      const sampledAt = Date.now();\n      const lag = sampledAt - loopLagExpectedAt;\n      loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n      if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n      if (lag > LOOP_LAG_WARN_MS) {\n        // A late sample means the loop was blocked since the prior tick; logged\n        // adjacent to the phase=... line of whatever phase just ran, so the daemon\n        // log timeline fingers the blocking phase.\n        console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n      }\n    }, LOOP_LAG_SAMPLE_MS);\n    loopLagTimer.unref?.();\n  }\n\n  if (ctx.isCancelled?.()) {\n    await releaseScanLease();\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('discovering');\n\n  const workspacePath: string = DEFAULT_BASE_PATH;\n\n  const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n  const specDocFiles = include_spec_docs\n    ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const graphMetadataFiles = include_spec_docs\n    ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const walkerWarnings = [\n    ...discoveryWarnings(specDocFiles),\n    ...discoveryWarnings(graphMetadataFiles),\n  ];\n  const walkerCapExceeded = mergeDiscoveryCapExceeded(\n    discoveryCaps(specDocFiles),\n    discoveryCaps(graphMetadataFiles),\n  );\n\n  const canonicalKeyCache = new Map<string, string>();\n  const getCachedKey = (filePath: string): string => {\n    const cached = canonicalKeyCache.get(filePath);\n    if (cached) {\n      return cached;\n    }\n\n    const canonicalKey = getCanonicalPathKey(filePath);\n    canonicalKeyCache.set(filePath, canonicalKey);\n    return canonicalKey;\n  };\n\n  const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n  const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n  const seenCanonicalFiles = new Set<string>();\n  const files: string[] = [];\n\n  for (const filePath of mergedFiles) {\n    const canonicalKey = getCachedKey(filePath);\n    if (seenCanonicalFiles.has(canonicalKey)) {\n      continue;\n    }\n    seenCanonicalFiles.add(canonicalKey);\n    files.push(filePath);\n  }\n\n  const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n  if (dedupDuplicatesSkipped > 0) {\n    console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n  }\n\n  const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n    if (recordIds.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    let deleted = 0;\n    let failed = 0;\n    const actions: StatediffAction[] = [];\n\n    for (const staleRecordId of recordIds) {\n      try {\n        const database = vectorIndex.getDb();\n        const staleSnapshot = database?.prepare(\n          'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n        ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n\n        if (database) {\n          causalEdges.init(database);\n          causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n            reason: 'memory_index stale record cleanup',\n            command: 'memory-index.deleteIndexedRecordIds',\n            restoreContext: {\n              memoryId: staleRecordId,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n              filePath: staleSnapshot?.file_path ?? null,\n            },\n          });\n        }\n\n        if (vectorIndex.deleteMemory(staleRecordId)) {\n          deleted++;\n          actions.push(createStatediffAction('delete', {\n            target: 'memory_index',\n            key: String(staleRecordId),\n            sourceOperation: 'scan',\n            oldStateHash: null,\n            newStateHash: null,\n            metadata: {\n              filePath: staleSnapshot?.file_path ?? null,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n            },\n          }));\n          // Record DELETE history only after confirmed deletion.\n          try {\n            recordHistory(\n              staleRecordId,\n              'DELETE',\n              staleSnapshot?.file_path ?? null,\n              null,\n              'mcp:memory_index_scan',\n              staleSnapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort\n          }\n        } else {\n          failed++;\n        }\n      } catch (_error: unknown) {\n        failed++;\n      }\n    }\n\n    return { deleted, failed, actions };\n  };\n\n  const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n    if (paths.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n  };\n\n  const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n    if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweepOrphanIndexRows = (incrementalIndex as {\n      sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n    }).sweepOrphanIndexRows;\n\n    if (typeof sweepOrphanIndexRows !== 'function') {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n    const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n    return {\n      swept: deleteResult.deleted,\n      failed: deleteResult.failed,\n      scannedRows: sweep.scannedRows,\n      nextCursor: sweep.nextCursor,\n      actions: deleteResult.actions,\n    };\n  };\n\n  const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n    try {\n      runPostMutationHooks('scan', { ...context, statediffActions: actions });\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n    }\n  };\n\n  const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n    result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n  );\n\n  const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n    target: 'memory_index',\n    key: 'trigger-embedding-backfill',\n    sourceOperation: 'scan',\n    metadata: {\n      readyRows: result.readyRows,\n      failedRows: result.failedRows,\n      pendingRows: result.pendingRows,\n    },\n  });\n\n  const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n    if (actions.length === 0) {\n      return;\n    }\n    results.aliasConflicts = detectAliasConflictsFromIndex();\n    results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n  };\n\n  const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n    try {\n      const repairResult = await repairIncompleteMarkers(\n        { database: requireDb(), plannerMode: 'full-auto' },\n        { limit: BATCH_SIZE },\n      );\n      if (repairResult.failed > 0) {\n        console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n      }\n      return repairResult.repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n    if (!isMemoryIdempotencyEnabled()) {\n      return 0;\n    }\n    try {\n      const database = requireDb();\n      const rows = database.prepare(`\n        SELECT id, spec_folder, title, content_text, content_hash,\n               tenant_id, user_id, agent_id, session_id\n        FROM memory_index\n        WHERE parent_id IS NULL\n          AND embedding_status = 'success'\n          AND content_text IS NOT NULL\n          AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n        ORDER BY id ASC\n        LIMIT ?\n      `).all(BATCH_SIZE) as Array<{\n        id: number;\n        spec_folder: string;\n        title: string | null;\n        content_text: string;\n        content_hash: string | null;\n        tenant_id: string | null;\n        user_id: string | null;\n        agent_id: string | null;\n        session_id: string | null;\n      }>;\n      let repaired = 0;\n      for (const row of rows) {\n        try {\n          const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n          const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n          recordNearDuplicateCheck({\n            database,\n            memoryId: row.id,\n            specFolder: row.spec_folder,\n            contentHash: row.content_hash,\n            embedding,\n            scope: {\n              tenantId: row.tenant_id,\n              userId: row.user_id,\n              agentId: row.agent_id,\n              sessionId: row.session_id,\n            },\n          });\n          repaired++;\n        } catch (error: unknown) {\n          console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n        }\n      }\n      return repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  if (files.length === 0) {\n    let staleDeleted = 0;\n    let staleDeleteFailed = 0;\n    const orphanSweepResult = runGlobalOrphanSweep();\n    const postInsertEnrichmentRepaired = await runPostInsertEnrichmentRepairBackfill();\n    await runNearDuplicateRepairBackfill();\n\n    if (incremental && !force) {\n      const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n      const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n      staleDeleted = staleDeleteResult.deleted;\n      staleDeleteFailed = staleDeleteResult.failed;\n      if (staleDeleted > 0) {\n        runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n      }\n    }\n\n    const triggerEmbeddingBackfill = await runTriggerEmbeddingBackfill(requireDb(), {\n      isCancelled: () => ctx.isCancelled?.() ?? false,\n    });\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files — the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        if (!isSuccessfulStatus) {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure — a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {\n          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {","lineStart":1,"lineEnd":1321,"totalLines":1322,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781718259563,"end":1781718259567}},"id":"prt_ed6af1769001qdY1QDQrijc9l3","sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","messageID":"msg_ed6af053c001z8osPcUJsg0aHp"}}
{"type":"tool_use","timestamp":1781718260103,"sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","part":{"type":"tool","tool":"read","callID":"call_dfaf894bec8c42f0aaeb8c4f","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Batch Processor\n3: // ───────────────────────────────────────────────────────────────\n4: import { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n5: \n6: // ───────────────────────────────────────────────────────────────\n7: // 1. TYPES\n8: \n9: // ───────────────────────────────────────────────────────────────\n10: /** Retry options for batch processing */\n11: export interface RetryOptions {\n12:   maxRetries?: number;\n13:   retryDelay?: number;\n14:   // Early-abort hook. When it returns true the batch loop stops immediately,\n15:   // skipping every remaining batch AND its inter-batch pacing delay. Without\n16:   // this a cancelled long run still drains thousands of no-op batches (and their\n17:   // delays) before the caller's post-loop cancel check is reached.\n18:   shouldAbort?: () => boolean;\n19: }\n20: \n21: /** Default retry configuration */\n22: export interface RetryDefaults {\n23:   maxRetries: number;\n24:   retryDelay: number;\n25: }\n26: \n27: /** Error result from a failed retry operation */\n28: export interface RetryErrorResult {\n29:   error: string;\n30:   errorDetail?: string;\n31:   item: unknown;\n32:   retries_failed: boolean;\n33: }\n34: \n35: /** Processor function type */\n36: export type ItemProcessor<T, R> = (item: T) => Promise<R>;\n37: \n38: // ───────────────────────────────────────────────────────────────\n39: // 2. CONFIGURATION CONSTANTS\n40: \n41: // ───────────────────────────────────────────────────────────────\n42: // Single source of truth for batch config — imported from core/config.ts\n43: import { BATCH_SIZE, BATCH_DELAY_MS } from '../core/config.js';\n44: export { BATCH_SIZE, BATCH_DELAY_MS };\n45: export const MAX_BATCH_SIZE = 100;\n46: const COOPERATIVE_YIELD_EVERY = 50;\n47: \n48: /** Default retry configuration */\n49: export const DEFAULT_RETRY_OPTIONS: Readonly<RetryDefaults> = {\n50:   maxRetries: 2,\n51:   retryDelay: 1000\n52: } as const;\n53: \n54: function normalizeRetryValue(value: number | undefined, fallback: number): number {\n55:   if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {\n56:     return fallback;\n57:   }\n58:   return Math.floor(value);\n59: }\n60: \n61: function cooperativeYield(): Promise<void> {\n62:   return new Promise<void>(resolve => setImmediate(resolve));\n63: }\n64: \n65: // ───────────────────────────────────────────────────────────────\n66: // 3. RETRY LOGIC\n67: \n68: // ───────────────────────────────────────────────────────────────\n69: /**\n70:  * Process a single item with retry logic for transient failures.\n71:  * Uses exponential backoff strategy for retries.\n72:  */\n73: export async function processWithRetry<T, R>(\n74:   item: T,\n75:   processor: ItemProcessor<T, R>,\n76:   options: RetryOptions = {}\n77: ): Promise<R | RetryErrorResult> {\n78:   const maxRetries = normalizeRetryValue(options.maxRetries, DEFAULT_RETRY_OPTIONS.maxRetries);\n79:   const retryDelay = normalizeRetryValue(options.retryDelay, DEFAULT_RETRY_OPTIONS.retryDelay);\n80:   let last_error: Error | undefined;\n81: \n82:   for (let attempt = 0; attempt <= maxRetries; attempt++) {\n83:     try {\n84:       return await processor(item);\n85:     } catch (err: unknown) {\n86:       last_error = err instanceof Error ? err : new Error(String(err));\n87:       // Only retry transient errors\n88:       if (attempt < maxRetries && isTransientError(last_error)) {\n89:         const delay = retryDelay * (attempt + 1); // Exponential backoff\n90:         console.error(`[batch-retry] Attempt ${attempt + 1}/${maxRetries + 1} failed, retrying in ${delay}ms: ${last_error.message}`);\n91:         await new Promise<void>(r => setTimeout(r, delay));\n92:       } else if (attempt < maxRetries) {\n93:         // Non-transient error, don't retry\n94:         break;\n95:       }\n96:     }\n97:   }\n98:   if (!last_error) {\n99:     last_error = new Error('Retry loop exited without processor result');\n100:   }\n101: \n102:   return {\n103:     error: userFriendlyError(last_error),\n104:     errorDetail: last_error.message,\n105:     item,\n106:     retries_failed: true,\n107:   };\n108: }\n109: \n110: // ───────────────────────────────────────────────────────────────\n111: // 4. BATCH PROCESSING\n112: \n113: // ───────────────────────────────────────────────────────────────\n114: /**\n115:  * Process items in batches with concurrency control and retry logic.\n116:  * Provides controlled execution to prevent resource exhaustion.\n117:  *\n118:  * @throws {Error} If batchSize is not a positive finite integer.\n119:  * Validates batchSize BEFORE any processing to prevent\n120:  *   infinite loops (batchSize=0) or nonsensical iteration (NaN, negative,\n121:  *   Infinity, fractional values).\n122:  */\n123: export async function processBatches<T, R>(\n124:   items: T[],\n125:   processor: ItemProcessor<T, R>,\n126:   batchSize: number = BATCH_SIZE,\n127:   delayMs: number = BATCH_DELAY_MS,\n128:   retryOptions: RetryOptions = {}\n129: ): Promise<Array<R | RetryErrorResult>> {\n130:   // Validate batchSize before any processing.\n131:   // NaN <= 0 is false, so the original <= 0 check alone would miss NaN.\n132:   // Also reject Infinity and non-integer values for safety.\n133:   if (typeof batchSize !== 'number' || !Number.isFinite(batchSize) || batchSize <= 0 || batchSize !== Math.floor(batchSize)) {\n134:     throw new Error(`batchSize must be a positive integer, got: ${batchSize}`);\n135:   }\n136: \n137:   const effectiveBatchSize = Math.min(batchSize, MAX_BATCH_SIZE);\n138:   if (effectiveBatchSize !== batchSize) {\n139:     console.warn(\n140:       `[batch-processor] Clamped batch size ${batchSize} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n141:     );\n142:   }\n143: \n144:   const results: Array<R | RetryErrorResult> = [];\n145:   const totalBatches = Math.ceil(items.length / effectiveBatchSize);\n146:   let currentBatch = 0;\n147:   let processedSinceYield = 0;\n148: \n149:   for (let i = 0; i < items.length; i += effectiveBatchSize) {\n150:     if (retryOptions.shouldAbort?.()) break;\n151:     currentBatch++;\n152:     console.error(`[batch-processor] Processing batch ${currentBatch}/${totalBatches}`);\n153: \n154:     const batch = items.slice(i, i + effectiveBatchSize);\n155:     const batchResults = await Promise.all(\n156:       batch.map(async (item, index) => {\n157:         if (index > 0 && index % COOPERATIVE_YIELD_EVERY === 0) {\n158:           await cooperativeYield();\n159:         }\n160:         return processWithRetry(item, processor, retryOptions);\n161:       })\n162:     );\n163:     results.push(...batchResults);\n164:     processedSinceYield += batchResults.length;\n165: \n166:     if (processedSinceYield >= COOPERATIVE_YIELD_EVERY) {\n167:       await cooperativeYield();\n168:       processedSinceYield %= COOPERATIVE_YIELD_EVERY;\n169:     }\n170: \n171:     // Small delay between batches to prevent resource exhaustion\n172:     if (i + effectiveBatchSize < items.length && delayMs > 0) {\n173:       await new Promise<void>(resolve => setTimeout(resolve, delayMs));\n174:     }\n175:   }\n176: \n177:   return results;\n178: }\n179: \n180: /**\n181:  * Process items sequentially (one at a time) with retry logic.\n182:  * Use when order matters or for resource-constrained operations.\n183:  */\n184: export async function processSequentially<T, R>(\n185:   items: T[],\n186:   processor: ItemProcessor<T, R>,\n187:   retryOptions: RetryOptions = {}\n188: ): Promise<Array<R | RetryErrorResult>> {\n189:   const results: Array<R | RetryErrorResult> = [];\n190: \n191:   for (let i = 0; i < items.length; i++) {\n192:     console.error(`[batch-processor] Processing item ${i + 1}/${items.length}`);\n193:     const result = await processWithRetry(items[i], processor, retryOptions);\n194:     results.push(result);\n195:   }\n196: \n197:   return results;\n198: }\n199: \n200: /* ───────────────────────────────────────────────────────────────\n201:    5. (ESM exports above — no CommonJS module.exports needed)\n202:    ──────────────────────────────────────────────────────────────── */\n\n(End of file - total 202 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Batch Processor\n// ───────────────────────────────────────────────────────────────\nimport { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Retry options for batch processing */\nexport interface RetryOptions {\n  maxRetries?: number;\n  retryDelay?: number;\n  // Early-abort hook. When it returns true the batch loop stops immediately,\n  // skipping every remaining batch AND its inter-batch pacing delay. Without\n  // this a cancelled long run still drains thousands of no-op batches (and their\n  // delays) before the caller's post-loop cancel check is reached.\n  shouldAbort?: () => boolean;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Batch Processor\n// ───────────────────────────────────────────────────────────────\nimport { isTransientError, userFriendlyError } from '../lib/errors/core.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Retry options for batch processing */\nexport interface RetryOptions {\n  maxRetries?: number;\n  retryDelay?: number;\n  // Early-abort hook. When it returns true the batch loop stops immediately,\n  // skipping every remaining batch AND its inter-batch pacing delay. Without\n  // this a cancelled long run still drains thousands of no-op batches (and their\n  // delays) before the caller's post-loop cancel check is reached.\n  shouldAbort?: () => boolean;\n}\n\n/** Default retry configuration */\nexport interface RetryDefaults {\n  maxRetries: number;\n  retryDelay: number;\n}\n\n/** Error result from a failed retry operation */\nexport interface RetryErrorResult {\n  error: string;\n  errorDetail?: string;\n  item: unknown;\n  retries_failed: boolean;\n}\n\n/** Processor function type */\nexport type ItemProcessor<T, R> = (item: T) => Promise<R>;\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONFIGURATION CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\n// Single source of truth for batch config — imported from core/config.ts\nimport { BATCH_SIZE, BATCH_DELAY_MS } from '../core/config.js';\nexport { BATCH_SIZE, BATCH_DELAY_MS };\nexport const MAX_BATCH_SIZE = 100;\nconst COOPERATIVE_YIELD_EVERY = 50;\n\n/** Default retry configuration */\nexport const DEFAULT_RETRY_OPTIONS: Readonly<RetryDefaults> = {\n  maxRetries: 2,\n  retryDelay: 1000\n} as const;\n\nfunction normalizeRetryValue(value: number | undefined, fallback: number): number {\n  if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {\n    return fallback;\n  }\n  return Math.floor(value);\n}\n\nfunction cooperativeYield(): Promise<void> {\n  return new Promise<void>(resolve => setImmediate(resolve));\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. RETRY LOGIC\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Process a single item with retry logic for transient failures.\n * Uses exponential backoff strategy for retries.\n */\nexport async function processWithRetry<T, R>(\n  item: T,\n  processor: ItemProcessor<T, R>,\n  options: RetryOptions = {}\n): Promise<R | RetryErrorResult> {\n  const maxRetries = normalizeRetryValue(options.maxRetries, DEFAULT_RETRY_OPTIONS.maxRetries);\n  const retryDelay = normalizeRetryValue(options.retryDelay, DEFAULT_RETRY_OPTIONS.retryDelay);\n  let last_error: Error | undefined;\n\n  for (let attempt = 0; attempt <= maxRetries; attempt++) {\n    try {\n      return await processor(item);\n    } catch (err: unknown) {\n      last_error = err instanceof Error ? err : new Error(String(err));\n      // Only retry transient errors\n      if (attempt < maxRetries && isTransientError(last_error)) {\n        const delay = retryDelay * (attempt + 1); // Exponential backoff\n        console.error(`[batch-retry] Attempt ${attempt + 1}/${maxRetries + 1} failed, retrying in ${delay}ms: ${last_error.message}`);\n        await new Promise<void>(r => setTimeout(r, delay));\n      } else if (attempt < maxRetries) {\n        // Non-transient error, don't retry\n        break;\n      }\n    }\n  }\n  if (!last_error) {\n    last_error = new Error('Retry loop exited without processor result');\n  }\n\n  return {\n    error: userFriendlyError(last_error),\n    errorDetail: last_error.message,\n    item,\n    retries_failed: true,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. BATCH PROCESSING\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Process items in batches with concurrency control and retry logic.\n * Provides controlled execution to prevent resource exhaustion.\n *\n * @throws {Error} If batchSize is not a positive finite integer.\n * Validates batchSize BEFORE any processing to prevent\n *   infinite loops (batchSize=0) or nonsensical iteration (NaN, negative,\n *   Infinity, fractional values).\n */\nexport async function processBatches<T, R>(\n  items: T[],\n  processor: ItemProcessor<T, R>,\n  batchSize: number = BATCH_SIZE,\n  delayMs: number = BATCH_DELAY_MS,\n  retryOptions: RetryOptions = {}\n): Promise<Array<R | RetryErrorResult>> {\n  // Validate batchSize before any processing.\n  // NaN <= 0 is false, so the original <= 0 check alone would miss NaN.\n  // Also reject Infinity and non-integer values for safety.\n  if (typeof batchSize !== 'number' || !Number.isFinite(batchSize) || batchSize <= 0 || batchSize !== Math.floor(batchSize)) {\n    throw new Error(`batchSize must be a positive integer, got: ${batchSize}`);\n  }\n\n  const effectiveBatchSize = Math.min(batchSize, MAX_BATCH_SIZE);\n  if (effectiveBatchSize !== batchSize) {\n    console.warn(\n      `[batch-processor] Clamped batch size ${batchSize} to ${MAX_BATCH_SIZE} to avoid unbounded concurrency`,\n    );\n  }\n\n  const results: Array<R | RetryErrorResult> = [];\n  const totalBatches = Math.ceil(items.length / effectiveBatchSize);\n  let currentBatch = 0;\n  let processedSinceYield = 0;\n\n  for (let i = 0; i < items.length; i += effectiveBatchSize) {\n    if (retryOptions.shouldAbort?.()) break;\n    currentBatch++;\n    console.error(`[batch-processor] Processing batch ${currentBatch}/${totalBatches}`);\n\n    const batch = items.slice(i, i + effectiveBatchSize);\n    const batchResults = await Promise.all(\n      batch.map(async (item, index) => {\n        if (index > 0 && index % COOPERATIVE_YIELD_EVERY === 0) {\n          await cooperativeYield();\n        }\n        return processWithRetry(item, processor, retryOptions);\n      })\n    );\n    results.push(...batchResults);\n    processedSinceYield += batchResults.length;\n\n    if (processedSinceYield >= COOPERATIVE_YIELD_EVERY) {\n      await cooperativeYield();\n      processedSinceYield %= COOPERATIVE_YIELD_EVERY;\n    }\n\n    // Small delay between batches to prevent resource exhaustion\n    if (i + effectiveBatchSize < items.length && delayMs > 0) {\n      await new Promise<void>(resolve => setTimeout(resolve, delayMs));\n    }\n  }\n\n  return results;\n}\n\n/**\n * Process items sequentially (one at a time) with retry logic.\n * Use when order matters or for resource-constrained operations.\n */\nexport async function processSequentially<T, R>(\n  items: T[],\n  processor: ItemProcessor<T, R>,\n  retryOptions: RetryOptions = {}\n): Promise<Array<R | RetryErrorResult>> {\n  const results: Array<R | RetryErrorResult> = [];\n\n  for (let i = 0; i < items.length; i++) {\n    console.error(`[batch-processor] Processing item ${i + 1}/${items.length}`);\n    const result = await processWithRetry(items[i], processor, retryOptions);\n    results.push(result);\n  }\n\n  return results;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. (ESM exports above — no CommonJS module.exports needed)\n   ──────────────────────────────────────────────────────────────── */","lineStart":1,"lineEnd":202,"totalLines":202,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/utils/batch-processor.ts","time":{"start":1781718260099,"end":1781718260102}},"id":"prt_ed6af19810011Plp6xDnT53vYJ","sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","messageID":"msg_ed6af053c001z8osPcUJsg0aHp"}}
{"type":"text","timestamp":1781718260638,"sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","part":{"id":"prt_ed6af1005001GY269Vu6tiSm5G","messageID":"msg_ed6af053c001z8osPcUJsg0aHp","sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","type":"text","text":"Now let me read the implementation files and set up the artifact directory.","time":{"start":1781718257669,"end":1781718260637}}}
{"type":"tool_use","timestamp":1781718260641,"sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","part":{"type":"tool","tool":"read","callID":"call_5c443a52313b4664ba4271fa","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance Job Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Kind-agnostic persisted job lifecycle: jobId, state record, progress\n5: // counters, error capture+truncation, cancel flag, and crash-recovery\n6: // reset. Shared lifecycle/registry across long-running maintenance jobs.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import { randomBytes } from 'node:crypto';\n13: \n14: import { requireDb, toErrorMessage } from '../../utils/index.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: export type MaintenanceJobKind = 'ingest' | 'index_scan';\n22: \n23: export type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n24: \n25: export interface JobError {\n26:   source: string;\n27:   message: string;\n28:   timestamp: string;\n29: }\n30: \n31: export interface MaintenanceJob {\n32:   id: string;\n33:   kind: MaintenanceJobKind;\n34:   state: JobLifecycleState;\n35:   phase: string | null;\n36:   progressTotal: number;\n37:   progressProcessed: number;\n38:   cancelRequested: boolean;\n39:   errors: JobError[];\n40:   result: unknown | null;\n41:   payload: unknown | null;\n42:   createdAt: string;\n43:   updatedAt: string;\n44: }\n45: \n46: interface MaintenanceJobRow {\n47:   id: string;\n48:   kind: string;\n49:   state: string;\n50:   phase: string | null;\n51:   progress_total: number;\n52:   progress_processed: number;\n53:   cancel_requested: number;\n54:   errors_json: string;\n55:   result_json: string | null;\n56:   payload_json: string | null;\n57:   created_at: string;\n58:   updated_at: string;\n59: }\n60: \n61: /* ───────────────────────────────────────────────────────────────\n62:    3. CONSTANTS\n63: ──────────────────────────────────────────────────────────────── */\n64: \n65: export const MAX_STORED_ERRORS = 50;\n66: \n67: const TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n68: \n69: // In-process mirror of cancel_requested. A running job polls this from a hot loop\n70: // to decide whether to stop, avoiding a DB SELECT on the single shared connection\n71: // every check. The cancel request runs in this same process, so the Set is\n72: // authoritative for an in-flight run; the durable column still backs status\n73: // responses and crash recovery. Entries are cleared when a job reaches a terminal\n74: // state so the Set cannot grow without bound across many jobs.\n75: const cancelledJobIds = new Set<string>();\n76: \n77: const ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n78:   queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n79:   running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n80:   complete: new Set<JobLifecycleState>([]),\n81:   failed: new Set<JobLifecycleState>([]),\n82:   cancelled: new Set<JobLifecycleState>([]),\n83: };\n84: \n85: // URL-safe 12-char identifier without a UUID dependency.\n86: const NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    4. HELPERS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: function nowIso(): string {\n93:   return new Date().toISOString();\n94: }\n95: \n96: function isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n97:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n98: }\n99: \n100: function parseJson<T>(value: string | null | undefined, fallback: T): T {\n101:   if (value === null || value === undefined) return fallback;\n102:   try {\n103:     return JSON.parse(value) as T;\n104:   } catch (_error: unknown) {\n105:     return fallback;\n106:   }\n107: }\n108: \n109: function parseJobErrors(value: string | null | undefined): JobError[] {\n110:   const parsed = parseJson<unknown>(value, []);\n111:   return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n112: }\n113: \n114: function mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n115:   if (!row) return null;\n116:   return {\n117:     id: row.id,\n118:     kind: row.kind as MaintenanceJobKind,\n119:     state: row.state as JobLifecycleState,\n120:     phase: row.phase,\n121:     progressTotal: row.progress_total,\n122:     progressProcessed: row.progress_processed,\n123:     cancelRequested: row.cancel_requested === 1,\n124:     errors: parseJobErrors(row.errors_json),\n125:     result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n126:     payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n127:     createdAt: row.created_at,\n128:     updatedAt: row.updated_at,\n129:   };\n130: }\n131: \n132: const SELECT_COLUMNS =\n133:   'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n134: \n135: /* ───────────────────────────────────────────────────────────────\n136:    5. SCHEMA\n137: ──────────────────────────────────────────────────────────────── */\n138: \n139: export function ensureMaintenanceJobsTable(): void {\n140:   const db = requireDb();\n141:   db.exec(`\n142:     CREATE TABLE IF NOT EXISTS maintenance_jobs (\n143:       id TEXT PRIMARY KEY,\n144:       kind TEXT NOT NULL,\n145:       state TEXT NOT NULL,\n146:       phase TEXT,\n147:       progress_total INTEGER NOT NULL DEFAULT 0,\n148:       progress_processed INTEGER NOT NULL DEFAULT 0,\n149:       cancel_requested INTEGER NOT NULL DEFAULT 0,\n150:       errors_json TEXT NOT NULL DEFAULT '[]',\n151:       result_json TEXT,\n152:       payload_json TEXT,\n153:       created_at TEXT NOT NULL,\n154:       updated_at TEXT NOT NULL\n155:     )\n156:   `);\n157:   db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n158: }\n159: \n160: /* ───────────────────────────────────────────────────────────────\n161:    6. IDENTIFIERS\n162: ──────────────────────────────────────────────────────────────── */\n163: \n164: export function createJobId(): string {\n165:   const bytes = randomBytes(12);\n166:   let id = '';\n167:   for (let i = 0; i < 12; i++) {\n168:     id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n169:   }\n170:   return `job_${id}`;\n171: }\n172: \n173: /* ───────────────────────────────────────────────────────────────\n174:    7. LIFECYCLE\n175: ──────────────────────────────────────────────────────────────── */\n176: \n177: export async function createMaintenanceJob(args: {\n178:   id: string;\n179:   kind: MaintenanceJobKind;\n180:   payload?: unknown;\n181: }): Promise<MaintenanceJob> {\n182:   const db = requireDb();\n183:   const timestamp = nowIso();\n184:   const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n185: \n186:   await withBusyRetry(() =>\n187:     db.prepare(`\n188:       INSERT INTO maintenance_jobs (\n189:         id, kind, state, phase, progress_total, progress_processed,\n190:         cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n191:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n192:     `).run(\n193:       args.id,\n194:       args.kind,\n195:       'queued',\n196:       null,\n197:       0,\n198:       0,\n199:       0,\n200:       '[]',\n201:       null,\n202:       payloadJson,\n203:       timestamp,\n204:       timestamp,\n205:     )\n206:   );\n207: \n208:   return {\n209:     id: args.id,\n210:     kind: args.kind,\n211:     state: 'queued',\n212:     phase: null,\n213:     progressTotal: 0,\n214:     progressProcessed: 0,\n215:     cancelRequested: false,\n216:     errors: [],\n217:     result: null,\n218:     payload: args.payload ?? null,\n219:     createdAt: timestamp,\n220:     updatedAt: timestamp,\n221:   };\n222: }\n223: \n224: export function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n225:   const db = requireDb();\n226:   const row = db.prepare(`\n227:     SELECT ${SELECT_COLUMNS}\n228:     FROM maintenance_jobs\n229:     WHERE id = ?\n230:   `).get(jobId) as MaintenanceJobRow | undefined;\n231:   return mapRowToJob(row);\n232: }\n233: \n234: export async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n235:   const db = requireDb();\n236:   const current = getMaintenanceJob(jobId);\n237:   if (!current) {\n238:     throw new Error(`Maintenance job not found: ${jobId}`);\n239:   }\n240: \n241:   if (current.state === nextState) {\n242:     return current;\n243:   }\n244: \n245:   if (!isTransitionAllowed(current.state, nextState)) {\n246:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n247:   }\n248: \n249:   const updatedAt = nowIso();\n250:   const result = await withBusyRetry(() =>\n251:     db.prepare(`\n252:       UPDATE maintenance_jobs\n253:       SET state = ?, updated_at = ?\n254:       WHERE id = ? AND state = ?\n255:     `).run(nextState, updatedAt, jobId, current.state)\n256:   );\n257: \n258:   if ((result as { changes: number }).changes === 0) {\n259:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n260:   }\n261: \n262:   return { ...current, state: nextState, updatedAt };\n263: }\n264: \n265: export async function setJobPhase(jobId: string, phase: string): Promise<void> {\n266:   const db = requireDb();\n267:   await withBusyRetry(() =>\n268:     db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n269:       .run(phase, nowIso(), jobId)\n270:   );\n271: }\n272: \n273: export async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n274:   const db = requireDb();\n275:   const processed = Math.max(0, Math.trunc(progress.processed));\n276:   const total = Math.max(0, Math.trunc(progress.total));\n277:   await withBusyRetry(() =>\n278:     db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n279:       .run(processed, total, nowIso(), jobId)\n280:   );\n281: }\n282: \n283: export async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n284:   const db = requireDb();\n285:   const current = getMaintenanceJob(jobId);\n286:   if (!current) {\n287:     throw new Error(`Maintenance job not found: ${jobId}`);\n288:   }\n289: \n290:   let errors: JobError[] = [\n291:     ...current.errors,\n292:     { source, message: toErrorMessage(error), timestamp: nowIso() },\n293:   ];\n294: \n295:   if (errors.length > MAX_STORED_ERRORS) {\n296:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n297:     const trimmedCount = errors.length - tailLength;\n298:     const truncationNotice: JobError = {\n299:       source: '__job__',\n300:       message: `error log truncated (${trimmedCount} older entries removed)`,\n301:       timestamp: nowIso(),\n302:     };\n303:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n304:     errors = [truncationNotice, ...truncatedTail];\n305:   }\n306: \n307:   const updatedAt = nowIso();\n308:   await withBusyRetry(() =>\n309:     db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n310:       .run(JSON.stringify(errors), updatedAt, jobId)\n311:   );\n312: \n313:   return { ...current, errors, updatedAt };\n314: }\n315: \n316: export async function requestCancel(jobId: string): Promise<void> {\n317:   // Set the in-process flag first so a running loop observes the cancel even if the\n318:   // durable write contends on the shared connection.\n319:   cancelledJobIds.add(jobId);\n320:   const db = requireDb();\n321:   await withBusyRetry(() =>\n322:     db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n323:       .run(nowIso(), jobId)\n324:   );\n325: }\n326: \n327: // Synchronous so the runner can poll it inline at batch/phase boundaries.\n328: export function isCancelRequested(jobId: string): boolean {\n329:   const db = requireDb();\n330:   const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n331:     .get(jobId) as { cancel_requested?: number } | undefined;\n332:   return !!row && row.cancel_requested === 1;\n333: }\n334: \n335: // Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n336: // mirror, so it is safe to call thousands of times during a scan without touching\n337: // the shared SQLite connection. Use isCancelRequested when durability across the\n338: // in-memory boundary matters (status responses, post-restart).\n339: export function isCancelRequestedFast(jobId: string): boolean {\n340:   return cancelledJobIds.has(jobId);\n341: }\n342: \n343: export async function completeJob(\n344:   jobId: string,\n345:   options: { state: JobLifecycleState; result?: unknown },\n346: ): Promise<MaintenanceJob> {\n347:   const db = requireDb();\n348:   const current = getMaintenanceJob(jobId);\n349:   if (!current) {\n350:     throw new Error(`Maintenance job not found: ${jobId}`);\n351:   }\n352: \n353:   if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n354:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n355:   }\n356: \n357:   const updatedAt = nowIso();\n358:   const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n359:   const completion = await withBusyRetry(() =>\n360:     db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n361:       .run(options.state, resultJson, updatedAt, jobId, current.state)\n362:   );\n363:   if (completion.changes === 0) {\n364:     // The row moved out from under the read-then-check; refuse to clobber a state\n365:     // another writer set rather than overwriting it from a stale read.\n366:     throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n367:   }\n368: \n369:   cancelledJobIds.delete(jobId);\n370:   return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n371: }\n372: \n373: // Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n374: // re-run fresh, so they are reset to 'failed' rather than re-enqueued.\n375: export function resetRunningJobsForKind(\n376:   kind: MaintenanceJobKind,\n377:   // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n378:   // target keeps a caller from persisting an illegal transition past the guard.\n379:   options: { to: 'failed' | 'cancelled' },\n380: ): string[] {\n381:   const db = requireDb();\n382:   const rows = db.prepare(`\n383:     SELECT id FROM maintenance_jobs\n384:     WHERE kind = ? AND state IN ('queued', 'running')\n385:   `).all(kind) as Array<{ id: string }>;\n386: \n387:   if (rows.length === 0) return [];\n388: \n389:   withBusyRetrySync(() =>\n390:     db.prepare(`\n391:       UPDATE maintenance_jobs\n392:       SET state = ?, updated_at = ?\n393:       WHERE kind = ? AND state IN ('queued', 'running')\n394:     `).run(options.to, nowIso(), kind)\n395:   );\n396: \n397:   for (const row of rows) {\n398:     cancelledJobIds.delete(row.id);\n399:   }\n400:   return rows.map((r) => r.id);\n401: }\n402: \n403: export function isTerminalJobState(state: JobLifecycleState): boolean {\n404:   return TERMINAL_STATES.has(state);\n405: }\n\n(End of file - total 405 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\nexport type MaintenanceJobKind = 'ingest' | 'index_scan';\n\nexport type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n\nexport interface JobError {\n  source: string;\n  message: string;\n  timestamp: string;\n}\n\nexport interface MaintenanceJob {\n  id: string;\n  kind: MaintenanceJobKind;\n  state: JobLifecycleState;\n  phase: string | null;\n  progressTotal: number;\n  progressProcessed: number;\n  cancelRequested: boolean;\n  errors: JobError[];\n  result: unknown | null;\n  payload: unknown | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\ninterface MaintenanceJobRow {\n  id: string;\n  kind: string;\n  state: string;\n  phase: string | null;\n  progress_total: number;\n  progress_processed: number;\n  cancel_requested: number;\n  errors_json: string;\n  result_json: string | null;\n  payload_json: string | null;\n  created_at: string;\n  updated_at: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nexport const MAX_STORED_ERRORS = 50;\n\nconst TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n\n// In-process mirror of cancel_requested. A running job polls this from a hot loop\n// to decide whether to stop, avoiding a DB SELECT on the single shared connection\n// every check. The cancel request runs in this same process, so the Set is\n// authoritative for an in-flight run; the durable column still backs status\n// responses and crash recovery. Entries are cleared when a job reaches a terminal\n// state so the Set cannot grow without bound across many jobs.\nconst cancelledJobIds = new Set<string>();\n\nconst ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n  queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n  running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n  complete: new Set<JobLifecycleState>([]),\n  failed: new Set<JobLifecycleState>([]),\n  cancelled: new Set<JobLifecycleState>([]),\n};\n\n// URL-safe 12-char identifier without a UUID dependency.\nconst NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\nfunction parseJson<T>(value: string | null | undefined, fallback: T): T {\n  if (value === null || value === undefined) return fallback;\n  try {\n    return JSON.parse(value) as T;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseJobErrors(value: string | null | undefined): JobError[] {\n  const parsed = parseJson<unknown>(value, []);\n  return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n}\n\nfunction mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    kind: row.kind as MaintenanceJobKind,\n    state: row.state as JobLifecycleState,\n    phase: row.phase,\n    progressTotal: row.progress_total,\n    progressProcessed: row.progress_processed,\n    cancelRequested: row.cancel_requested === 1,\n    errors: parseJobErrors(row.errors_json),\n    result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n    payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nconst SELECT_COLUMNS =\n  'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n\n/* ───────────────────────────────────────────────────────────────\n   5. SCHEMA\n──────────────────────────────────────────────────────────────── */\n\nexport function ensureMaintenanceJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS maintenance_jobs (\n      id TEXT PRIMARY KEY,\n      kind TEXT NOT NULL,\n      state TEXT NOT NULL,\n      phase TEXT,\n      progress_total INTEGER NOT NULL DEFAULT 0,\n      progress_processed INTEGER NOT NULL DEFAULT 0,\n      cancel_requested INTEGER NOT NULL DEFAULT 0,\n      errors_json TEXT NOT NULL DEFAULT '[]',\n      result_json TEXT,\n      payload_json TEXT,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL\n    )\n  `);\n  db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. IDENTIFIERS\n──────────────────────────────────────────────────────────────── */\n\nexport function createJobId(): string {\n  const bytes = randomBytes(12);\n  let id = '';\n  for (let i = 0; i < 12; i++) {\n    id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n  }\n  return `job_${id}`;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LIFECYCLE\n──────────────────────────────────────────────────────────────── */\n\nexport async function createMaintenanceJob(args: {\n  id: string;\n  kind: MaintenanceJobKind;\n  payload?: unknown;\n}): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO maintenance_jobs (\n        id, kind, state, phase, progress_total, progress_processed,\n        cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      args.kind,\n      'queued',\n      null,\n      0,\n      0,\n      0,\n      '[]',\n      null,\n      payloadJson,\n      timestamp,\n      timestamp,\n    )\n  );\n\n  return {\n    id: args.id,\n    kind: args.kind,\n    state: 'queued',\n    phase: null,\n    progressTotal: 0,\n    progressProcessed: 0,\n    cancelRequested: false,\n    errors: [],\n    result: null,\n    payload: args.payload ?? null,\n    createdAt: timestamp,\n    updatedAt: timestamp,\n  };\n}\n\nexport function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n  const db = requireDb();\n  const row = db.prepare(`\n    SELECT ${SELECT_COLUMNS}\n    FROM maintenance_jobs\n    WHERE id = ?\n  `).get(jobId) as MaintenanceJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nexport async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  return { ...current, state: nextState, updatedAt };\n}\n\nexport async function setJobPhase(jobId: string, phase: string): Promise<void> {\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n      .run(phase, nowIso(), jobId)\n  );\n}\n\nexport async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n  const db = requireDb();\n  const processed = Math.max(0, Math.trunc(progress.processed));\n  const total = Math.max(0, Math.trunc(progress.total));\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n      .run(processed, total, nowIso(), jobId)\n  );\n}\n\nexport async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  let errors: JobError[] = [\n    ...current.errors,\n    { source, message: toErrorMessage(error), timestamp: nowIso() },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: JobError = {\n      source: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n      .run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return { ...current, errors, updatedAt };\n}\n\nexport async function requestCancel(jobId: string): Promise<void> {\n  // Set the in-process flag first so a running loop observes the cancel even if the\n  // durable write contends on the shared connection.\n  cancelledJobIds.add(jobId);\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n      .run(nowIso(), jobId)\n  );\n}\n\n// Synchronous so the runner can poll it inline at batch/phase boundaries.\nexport function isCancelRequested(jobId: string): boolean {\n  const db = requireDb();\n  const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n    .get(jobId) as { cancel_requested?: number } | undefined;\n  return !!row && row.cancel_requested === 1;\n}\n\n// Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n// mirror, so it is safe to call thousands of times during a scan without touching\n// the shared SQLite connection. Use isCancelRequested when durability across the\n// in-memory boundary matters (status responses, post-restart).\nexport function isCancelRequestedFast(jobId: string): boolean {\n  return cancelledJobIds.has(jobId);\n}\n\nexport async function completeJob(\n  jobId: string,\n  options: { state: JobLifecycleState; result?: unknown },\n): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n  }\n\n  const updatedAt = nowIso();\n  const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n  const completion = await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n      .run(options.state, resultJson, updatedAt, jobId, current.state)\n  );\n  if (completion.changes === 0) {\n    // The row moved out from under the read-then-check; refuse to clobber a state\n    // another writer set rather than overwriting it from a stale read.\n    throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n  }\n\n  cancelledJobIds.delete(jobId);\n  return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n}\n\n// Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n// re-run fresh, so they are reset to 'failed' rather than re-enqueued.\nexport function resetRunningJobsForKind(\n  kind: MaintenanceJobKind,\n  // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n  // target keeps a caller from persisting an illegal transition past the guard.\n  options: { to: 'failed' | 'cancelled' },\n): string[] {\n  const db = requireDb();\n  const rows = db.prepare(`\n    SELECT id FROM maintenance_jobs\n    WHERE kind = ? AND state IN ('queued', 'running')\n  `).all(kind) as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE kind = ? AND state IN ('queued', 'running')\n    `).run(options.to, nowIso(), kind)\n  );\n\n  for (const row of rows) {\n    cancelledJobIds.delete(row.id);\n  }\n  return rows.map((r) => r.id);\n}\n\nexport function isTerminalJobState(state: JobLifecycleState): boolean {\n  return TERMINAL_STATES.has(state);\n}","lineStart":1,"lineEnd":405,"totalLines":405,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","time":{"start":1781718260632,"end":1781718260640}},"id":"prt_ed6af1b960018BDPSJUpAD02qq","sessionID":"ses_1295140cdffeXNidg4HPeWTJzE","messageID":"msg_ed6af053c001z8osPcUJsg0aHp"}}
