:                   ...(targetAnchorId ? { targetAnchorId } : {}),\n3509:                 },\n3510:               }),\n3511:             ],\n3512:           },\n3513:         });\n3514:       }\n3515: \n3516:       const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n3517:         typeof e === 'string' ? e : e.message\n3518:       ).join('; ');\n3519: \n3520:       // Use the actual error code from the\n3521:       // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n3522:       const firstError = preflightResult.errors[0];\n3523:       const errorCode = (typeof firstError === 'object' && firstError?.code)\n3524:         ? firstError.code\n3525:         : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n3526:       throw new preflight.PreflightError(\n3527:         errorCode,\n3528:         `Pre-flight validation failed: ${errorMessages}`,\n3529:         {\n3530:           errors: preflightResult.errors,\n3531:           warnings: preflightResult.warnings,\n3532:           recoverable: true,\n3533:           suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n3534:         }\n3535:       );\n3536:     }\n3537: \n3538:     if (preflightResult.warnings.length > 0) {\n3539:       console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n3540:       preflightResult.warnings.forEach((w: string | { message: string }) => {\n3541:         const msg = typeof w === 'string' ? w : w.message;\n3542:         console.warn(`[preflight]   - ${msg}`);\n3543:       });\n3544:     }\n3545:   }\n3546: \n3547:   if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n3548:     try {\n3549:       const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n3550:       // The compared payload IS the fingerprint object: both lookup inputs\n3551:       // below point at this same idempotencySemantics value, so payloadHash\n3552:       // always equals requestFingerprintHash and the receiptKey is derived from\n3553:       // it. Consequence: distinct logical requests always produce distinct\n3554:       // keys, so the same-key/different-payload 'conflict' status can never fire\n3555:       // from this caller (a force-flip yields a key MISS, not a conflict). The\n3556:       // conflict branch below is fail-safe defense-in-depth, not active\n3557:       // protection. To make conflicts detectable, the payload would have to\n3558:       // carry MORE than the key material (e.g. execution-mode flags); it\n3559:       // deliberately does not, so a benign flag flip cannot become a false\n3560:       // hard conflict.\n3561:       const idempotencySemantics = {\n3562:         filePath: canonicalValidatedPath,\n3563:         contentHash: parsedForIdempotency.contentHash,\n3564:         routeAs: routeAs ?? null,\n3565:         mergeModeHint: mergeModeHint ?? null,\n3566:         targetAnchorId: targetAnchorId ?? null,\n3567:         scope: saveScope,\n3568:         // A force-flipped retry is a DIFFERENT logical request: keeping force in\n3569:         // the key material makes it a distinct key (a clean MISS that re-runs),\n3570:         // never a collision with the non-forced receipt.\n3571:         force: force === true,\n3572:       };\n3573:       const lookup = lookupIdempotencyReceipt(database, {\n3574:         operation: 'memory_save',\n3575:         contentHash: parsedForIdempotency.contentHash,\n3576:         requestFingerprint: idempotencySemantics,\n3577:         payload: idempotencySemantics,\n3578:       });\n3579:       idempotencyKey = lookup.key;\n3580:       if (lookup.status === 'replay') {\n3581:         // A receipt is a replay cache, not proof the cached response still\n3582:         // describes the live state. After an A->B->A revert the receipt for A\n3583:         // is intact but the active row now holds B (or, after deletion, a\n3584:         // superseded