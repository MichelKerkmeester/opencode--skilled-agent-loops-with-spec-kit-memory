{"type":"tool_use","timestamp":1784525276368,"sessionID":"ses_08202bafbffe7aMYl1BZMs5SAo","part":{"type":"tool","tool":"read","callID":"call_EUZVKfCZ5yczeHWz1XePUOdp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep Research State Reducer                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: const crypto = require('node:crypto');\n14: const { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\n15: const { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\n16: const {\n17:   buildCarriedForwardOpenQuestions,\n18:   deriveNextFocusFromContinuity,\n19:   formatCarriedForwardOpenQuestions,\n20: } = require('../../runtime/lib/deep-loop/continuity-thread.cjs');\n21: const { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n22: \n23: // ─────────────────────────────────────────────────────────────────────────────\n24: // 2. HELPERS\n25: // ─────────────────────────────────────────────────────────────────────────────\n26: \n27: const DEFAULT_SPARKLINE_WIDTH = 20;\n28: const DEFAULT_TREND_FLATLINE_WINDOW = 3;\n29: const DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\n30: const DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\n31: const DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\n32: const MIN_IDEA_OBSERVATIONS = 1;\n33: const MAX_IDEA_OBSERVATIONS = 10;\n34: const INBOX_FILE_NAME = 'inbox.jsonl';\n35: const DEFAULT_INBOX_SOURCE = 'research-inbox';\n36: const LEGACY_IMPORT_ORIGIN = 'legacy-import';\n37: const LEGACY_IMPORT_SOURCE = 'key-questions';\n38: const QUESTION_CONFLICT_EVENT = 'question_conflict';\n39: const DEFAULT_QUESTION_DECISION = 'needs_decision';\n40: const MAX_REJECTED_PATTERNS = 100;\n41: const REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\n42: const REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\n43: const IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\n44: const IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\n45: const IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\n46: const IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\n47: const IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\n48: const IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\n49: const VALID_QUESTION_ORIGINS = new Set([\n50:   'angle-bank',\n51:   'analyst-strategy',\n52:   'operator',\n53:   LEGACY_IMPORT_ORIGIN,\n54: ]);\n55: const VALID_QUESTION_DECISIONS = new Set([\n56:   'accepted',\n57:   'rejected',\n58:   'superseded',\n59:   DEFAULT_QUESTION_DECISION,\n60: ]);\n61: const SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n62: \n63: function readUtf8(filePath) {\n64:   return fs.readFileSync(filePath, 'utf8');\n65: }\n66: \n67: function writeUtf8(filePath, content) {\n68:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n69:   fs.writeFileSync(filePath, content, 'utf8');\n70: }\n71: \n72: function readJson(filePath) {\n73:   return JSON.parse(readUtf8(filePath));\n74: }\n75: \n76: function getResourceMapEmitSetting(config) {\n77:   const nested = config && typeof config === 'object'\n78:     ? (config.resource_map || config.resourceMap || null)\n79:     : null;\n80:   if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n81:     return nested.emit;\n82:   }\n83:   return true;\n84: }\n85: \n86: function slugify(value) {\n87:   return value\n88:     .toLowerCase()\n89:     .replace(/[^a-z0-9]+/g, '-')\n90:     .replace(/^-+|-+$/g, '')\n91:     .slice(0, 80) || 'entry';\n92: }\n93: \n94: function normalizeText(value) {\n95:   return value.replace(/\\s+/g, ' ').trim();\n96: }\n97: \n98: function normalizeOptionalText(value) {\n99:   return typeof value === 'string' ? normalizeText(value) : '';\n100: }\n101: \n102: function normalizeQuestionOrigin(value) {\n103:   const origin = normalizeOptionalText(value).toLowerCase();\n104:   return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n105: }\n106: \n107: function normalizeQuestionSource(value, fallback) {\n108:   return normalizeOptionalText(value) || fallback;\n109: }\n110: \n111: function normalizeQuestionIteration(value) {\n112:   return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n113: }\n114: \n115: function normalizeQuestionId(value) {\n116:   const normalized = normalizeOptionalText(value);\n117:   return normalized || null;\n118: }\n119: \n120: function normalizeQuestionDecision(value) {\n121:   const decision = normalizeOptionalText(value).toLowerCase();\n122:   return VALID_QUESTION_DECISIONS.has(decision) ? decision : null;\n123: }\n124: \n125: function contentHash(value) {\n126:   return crypto\n127:     .createHash('sha256')\n128:     .update(normalizeText(String(value)).toLowerCase())\n129:     .digest('hex')\n130:     .slice(0, 12);\n131: }\n132: \n133: function normalizeRejectedPatternKey(value) {\n134:   return normalizeText(String(value ?? ''))\n135:     .toLowerCase()\n136:     .replace(/[^a-z0-9]+/g, ' ')\n137:     .trim();\n138: }\n139: \n140: function normalizeRejectedPatternCategory(value) {\n141:   const normalized = normalizeOptionalText(value).toLowerCase();\n142:   return normalized || DEFAULT_REJECTED_PATTERN_CATEGORY;\n143: }\n144: \n145: function normalizeRejectedPatternId(value) {\n146:   const normalized = normalizeOptionalText(value);\n147:   return normalized || null;\n148: }\n149: \n150: function isNamedEvent(record, eventNames) {\n151:   return record\n152:     && record.type === 'event'\n153:     && typeof record.event === 'string'\n154:     && eventNames.has(record.event);\n155: }\n156: \n157: function readFirstTextField(record, fields) {\n158:   if (!record || typeof record !== 'object' || Array.isArray(record)) {\n159:     return '';\n160:   }\n161: \n162:   for (const field of fields) {\n163:     const value = normalizeOptionalText(record[field]);\n164:     if (value) {\n165:       return value;\n166:     }\n167:   }\n168:   return '';\n169: }\n170: \n171: function readRejectedPatternText(record) {\n172:   return readFirstTextField(record, REJECTED_PATTERN_EVENT_FIELDS);\n173: }\n174: \n175: function readCandidateText(candidate) {\n176:   if (typeof candidate === 'string') {\n177:     return normalizeOptionalText(candidate);\n178:   }\n179:   return readFirstTextField(candidate, REJECTED_PATTERN_CANDIDATE_FIELDS);\n180: }\n181: \n182: function readCandidateCategory(candidate, fallbackCategory) {\n183:   if (candidate && typeof candidate === 'object' && !Array.isArray(candidate)) {\n184:     return normalizeRejectedPatternCategory(candidate.category ?? fallbackCategory);\n185:   }\n186:   return normalizeRejectedPatternCategory(fallbackCategory);\n187: }\n188: \n189: function isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory) {\n190:   const rejected = normalizeRejectedPatternCategory(rejectedCategory);\n191:   const candidate = normalizeRejectedPatternCategory(candidateCategory);\n192:   return rejected === candidate\n193:     || rejected === DEFAULT_REJECTED_PATTERN_CATEGORY\n194:     || candidate === DEFAULT_REJECTED_PATTERN_CATEGORY;\n195: }\n196: \n197: function resolveRejectedPatternFuzzyThreshold(config) {\n198:   const rawThreshold =\n199:     config?.rejectedPatternFuzzyThreshold\n200:     ?? config?.rejectedPatterns?.fuzzyThreshold\n201:     ?? DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n202:   return typeof rawThreshold === 'number' && Number.isFinite(rawThreshold) && rawThreshold >= 0 && rawThreshold <= 1\n203:     ? rawThreshold\n204:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n205: }\n206: \n207: function normalizeRejectedPatternEvent(record) {\n208:   const pattern = readRejectedPatternText(record);\n209:   const normalizedPattern = normalizeRejectedPatternKey(pattern);\n210:   if (!normalizedPattern) {\n211:     return null;\n212:   }\n213: \n214:   const category = normalizeRejectedPatternCategory(record.category);\n215:   return {\n216:     id: normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id)\n217:       || `rejected-${category}-${contentHash(normalizedPattern)}`,\n218:     ideaId: normalizeRejectedPatternId(record.ideaId),\n219:     pattern,\n220:     normalizedPattern,\n\n(Showing lines 1-220 of 2941. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Research State Reducer                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst crypto = require('node:crypto');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\nconst {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n} = require('../../runtime/lib/deep-loop/continuity-thread.cjs');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Research State Reducer                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst crypto = require('node:crypto');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\nconst {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n} = require('../../runtime/lib/deep-loop/continuity-thread.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst DEFAULT_SPARKLINE_WIDTH = 20;\nconst DEFAULT_TREND_FLATLINE_WINDOW = 3;\nconst DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\nconst DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\nconst DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\nconst MIN_IDEA_OBSERVATIONS = 1;\nconst MAX_IDEA_OBSERVATIONS = 10;\nconst INBOX_FILE_NAME = 'inbox.jsonl';\nconst DEFAULT_INBOX_SOURCE = 'research-inbox';\nconst LEGACY_IMPORT_ORIGIN = 'legacy-import';\nconst LEGACY_IMPORT_SOURCE = 'key-questions';\nconst QUESTION_CONFLICT_EVENT = 'question_conflict';\nconst DEFAULT_QUESTION_DECISION = 'needs_decision';\nconst MAX_REJECTED_PATTERNS = 100;\nconst REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\nconst REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\nconst IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\nconst IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\nconst IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\nconst IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\nconst IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\nconst IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\nconst VALID_QUESTION_ORIGINS = new Set([\n  'angle-bank',\n  'analyst-strategy',\n  'operator',\n  LEGACY_IMPORT_ORIGIN,\n]);\nconst VALID_QUESTION_DECISIONS = new Set([\n  'accepted',\n  'rejected',\n  'superseded',\n  DEFAULT_QUESTION_DECISION,\n]);\nconst SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n\nfunction readUtf8(filePath) {\n  return fs.readFileSync(filePath, 'utf8');\n}\n\nfunction writeUtf8(filePath, content) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.writeFileSync(filePath, content, 'utf8');\n}\n\nfunction readJson(filePath) {\n  return JSON.parse(readUtf8(filePath));\n}\n\nfunction getResourceMapEmitSetting(config) {\n  const nested = config && typeof config === 'object'\n    ? (config.resource_map || config.resourceMap || null)\n    : null;\n  if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n    return nested.emit;\n  }\n  return true;\n}\n\nfunction slugify(value) {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 80) || 'entry';\n}\n\nfunction normalizeText(value) {\n  return value.replace(/\\s+/g, ' ').trim();\n}\n\nfunction normalizeOptionalText(value) {\n  return typeof value === 'string' ? normalizeText(value) : '';\n}\n\nfunction normalizeQuestionOrigin(value) {\n  const origin = normalizeOptionalText(value).toLowerCase();\n  return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n}\n\nfunction normalizeQuestionSource(value, fallback) {\n  return normalizeOptionalText(value) || fallback;\n}\n\nfunction normalizeQuestionIteration(value) {\n  return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n}\n\nfunction normalizeQuestionId(value) {\n  const normalized = normalizeOptionalText(value);\n  return normalized || null;\n}\n\nfunction normalizeQuestionDecision(value) {\n  const decision = normalizeOptionalText(value).toLowerCase();\n  return VALID_QUESTION_DECISIONS.has(decision) ? decision : null;\n}\n\nfunction contentHash(value) {\n  return crypto\n    .createHash('sha256')\n    .update(normalizeText(String(value)).toLowerCase())\n    .digest('hex')\n    .slice(0, 12);\n}\n\nfunction normalizeRejectedPatternKey(value) {\n  return normalizeText(String(value ?? ''))\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .trim();\n}\n\nfunction normalizeRejectedPatternCategory(value) {\n  const normalized = normalizeOptionalText(value).toLowerCase();\n  return normalized || DEFAULT_REJECTED_PATTERN_CATEGORY;\n}\n\nfunction normalizeRejectedPatternId(value) {\n  const normalized = normalizeOptionalText(value);\n  return normalized || null;\n}\n\nfunction isNamedEvent(record, eventNames) {\n  return record\n    && record.type === 'event'\n    && typeof record.event === 'string'\n    && eventNames.has(record.event);\n}\n\nfunction readFirstTextField(record, fields) {\n  if (!record || typeof record !== 'object' || Array.isArray(record)) {\n    return '';\n  }\n\n  for (const field of fields) {\n    const value = normalizeOptionalText(record[field]);\n    if (value) {\n      return value;\n    }\n  }\n  return '';\n}\n\nfunction readRejectedPatternText(record) {\n  return readFirstTextField(record, REJECTED_PATTERN_EVENT_FIELDS);\n}\n\nfunction readCandidateText(candidate) {\n  if (typeof candidate === 'string') {\n    return normalizeOptionalText(candidate);\n  }\n  return readFirstTextField(candidate, REJECTED_PATTERN_CANDIDATE_FIELDS);\n}\n\nfunction readCandidateCategory(candidate, fallbackCategory) {\n  if (candidate && typeof candidate === 'object' && !Array.isArray(candidate)) {\n    return normalizeRejectedPatternCategory(candidate.category ?? fallbackCategory);\n  }\n  return normalizeRejectedPatternCategory(fallbackCategory);\n}\n\nfunction isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory) {\n  const rejected = normalizeRejectedPatternCategory(rejectedCategory);\n  const candidate = normalizeRejectedPatternCategory(candidateCategory);\n  return rejected === candidate\n    || rejected === DEFAULT_REJECTED_PATTERN_CATEGORY\n    || candidate === DEFAULT_REJECTED_PATTERN_CATEGORY;\n}\n\nfunction resolveRejectedPatternFuzzyThreshold(config) {\n  const rawThreshold =\n    config?.rejectedPatternFuzzyThreshold\n    ?? config?.rejectedPatterns?.fuzzyThreshold\n    ?? DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n  return typeof rawThreshold === 'number' && Number.isFinite(rawThreshold) && rawThreshold >= 0 && rawThreshold <= 1\n    ? rawThreshold\n    : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n}\n\nfunction normalizeRejectedPatternEvent(record) {\n  const pattern = readRejectedPatternText(record);\n  const normalizedPattern = normalizeRejectedPatternKey(pattern);\n  if (!normalizedPattern) {\n    return null;\n  }\n\n  const category = normalizeRejectedPatternCategory(record.category);\n  return {\n    id: normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id)\n      || `rejected-${category}-${contentHash(normalizedPattern)}`,\n    ideaId: normalizeRejectedPatternId(record.ideaId),\n    pattern,\n    normalizedPattern,","lineStart":1,"lineEnd":220,"totalLines":2941,"truncated":true}},"title":".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs","time":{"start":1784525276330,"end":1784525276363}},"metadata":{"openai":{"itemId":"fc_07a1edd92c53aa47016a5db1dc26e08191acc4ca4e2562535a"}},"id":"prt_f7dfec4a3001AplMmUm9nItGa0","sessionID":"ses_08202bafbffe7aMYl1BZMs5SAo","messageID":"msg_f7dfea03d0012v1fctSYqg3mDb"}}
