{
  "color": {
    "aubergine": {
      "$value": "#611f69",
      "$type": "color",
      "$description": "Aubergine — Filled CTA buttons, primary navigation fills, dark hero backgrounds — the brand's signature mid-plum, dense enough to ground without veering black"
    },
    "deep-plum": {
      "$value": "#481a54",
      "$type": "color",
      "$description": "Deep Plum — Largest canvas inversion — full-bleed dark section backgrounds, decorative dark blocks, surface for headline text on white sections"
    },
    "purple-haze": {
      "$value": "#f9f0ff",
      "$type": "color",
      "$description": "Purple Haze — Softest lilac wash for body backgrounds, pill fills, and card surfaces — the quiet brand tint that never competes with text"
    },
    "lavender-mist": {
      "$value": "#eac8fe",
      "$type": "color",
      "$description": "Lavender Mist — Mid-saturation lavender for card borders, decorative outlines, and pill borders — bridges white and purple without harsh contrast"
    },
    "vivid-violet": {
      "$value": "#9602c7",
      "$type": "color",
      "$description": "Vivid Violet — Headline accent text and gradient text fills on dark sections — the bright punch of color that makes key phrases feel switched on; Diagonal black-to-violet gradient for accent text and decorative text fills on dark sections"
    },
    "plum-shadow": {
      "$value": "#3d0157",
      "$type": "color",
      "$description": "Plum Shadow — Darker plum for button text and shadow tones on aubergine surfaces — reads as near-black against purple fills"
    },
    "iris": {
      "$value": "#730394",
      "$type": "color",
      "$description": "Iris — Secondary purple for background fills and link accents — sits between Aubergine and Vivid Violet on the purple ramp"
    },
    "iris-light": {
      "$value": "#d17dfe",
      "$type": "color",
      "$description": "Iris Light — Decorative card text and bright accents inside feature cards — a lighter iris that adds lift without losing brand identity"
    },
    "channel-blue": {
      "$value": "#1264a3",
      "$type": "color",
      "$description": "Channel Blue — Slack's channel-link blue for in-product references, sidebar highlights, and hyperlink color — appears inside product UI screenshots, not marketing chrome"
    },
    "mid-blue": {
      "$value": "#0b4c8c",
      "$type": "color",
      "$description": "Mid Blue — Blue text accent for links, tags, and emphasized short phrases."
    },
    "sky-mist": {
      "$value": "#2f8ab7",
      "$type": "color",
      "$description": "Sky Mist — Decorative illustration backgrounds — soft secondary blue used only inside graphic blocks"
    },
    "carbon": {
      "$value": "#1d1c1d",
      "$type": "color",
      "$description": "Carbon — Primary body and nav text — Slack's near-black that reads warmer than pure #000 at small sizes"
    },
    "charcoal": {
      "$value": "#454245",
      "$type": "color",
      "$description": "Charcoal — Secondary body text, icon fills, muted captions — the middle step between Carbon and Mid Gray"
    },
    "mid-gray": {
      "$value": "#696969",
      "$type": "color",
      "$description": "Mid Gray — Navigation text, subdued labels, disabled-state text — the working neutral for chrome"
    },
    "steel": {
      "$value": "#808080",
      "$type": "color",
      "$description": "Steel — Placeholder card backgrounds and neutral fill swatches"
    },
    "fog": {
      "$value": "#edeaed",
      "$type": "color",
      "$description": "Fog — Hairline borders, divider lines, subtle 1px separators — the structural neutral that holds cards together"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Primary surface — card backgrounds, text on dark, pill fills, button text on purple"
    },
    "soft-white": {
      "$value": "#fefbff",
      "$type": "color",
      "$description": "Soft White — Page canvas — faintly lilac-tinted white that sets the page apart from harsh #fff"
    },
    "ice-blue": {
      "$value": "#e8f5fa",
      "$type": "color",
      "$description": "Ice Blue — Cool-tinted surface wash for secondary panels and nav highlights"
    },
    "black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Black — Headline text on light sections, icon fills, deepest emphasis — used at display sizes where maximum weight is needed"
    }
  },
  "font": {
    "salesforce-avant-garde": {
      "$value": "Salesforce-Avant-Garde",
      "$type": "fontFamily",
      "$description": "Display and heading face — geometric, wide, compressed. Carries every headline from 21px subheads up to 96px hero display. The 400-weight at 76px is anti-convention: Slack trusts its letterforms enough to let headlines whisper rather than shout. Tracking tightens progressively from -0.004em at body sizes to -0.012em at 64px+"
    },
    "salesforce-sans": {
      "$value": "Salesforce-Sans",
      "$type": "fontFamily",
      "$description": "Workhorse body and UI face — handles nav, body copy, buttons, captions, and labels. The 12px/700 with 0.057em tracking (uppercase) is the eyebrow-label pattern used for section tags. Body sits at 16px/1.5 — generous enough for reading, compact enough for dense product cards"
    }
  },
