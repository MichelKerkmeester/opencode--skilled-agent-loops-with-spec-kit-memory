 require('../model-benchmark/scorer/grader/harness.cjs');\n\n  Line 35:  * Grade the on/off output pair into a normalized D4 usefulness score.\n\n  Line 36:  * Deterministic when graderMode is a mock mode. score in [0,1]: 0.5 = no delta,\n\n  Line 39: async function gradeAblation({ scenario, onText, offText, graderMode = 'mock', cacheDir }) {\n\n  Line 41:     variant_hash: 'live', rubric_version: 'v1.0.0', grader_model_build_hash: 'na',\n\n  Line 42:     mode: graderMode,\n\n  Line 43:     mock_mode: graderMode.startsWith('mock-') ? graderMode.slice('mock-'.length) : 'default',\n\n  Line 47:   const onG = await grader.gradeD4({ fixture: { id: `${scenario.scenarioId}#on`, rubric }, swe16_output_text: onText || '', ...base });\n\n  Line 48:   const offG = await grader.gradeD4({ fixture: { id: `${scenario.scenarioId}#off`, rubric }, swe16_output_text: offText || '', ...base });\n\n  Line 52:   return { d4: { score, onScore, offScore, attribution: 'approximate', graderMode }, raw: { onG, offG } };\n\n  Line 56:  * Full live ablation: two real dispatches (on/off) + grade. Spends API.\n\n  Line 58: async function runD4Ablation({ scenario, skillRoot, model, variant, graderMode = 'mock', cacheDir }) {\n\n  Line 65:     return { d4: { score: null, unscored: 'ablation dispatch failed', attribution: 'approximate' } };\n\n  Line 78:     scenario, onText: onParsed.raw.responseText, offText: offParsed.raw.responseText, graderMode, cacheDir,\n\n  Line 83: module.exports = { runD4Ablation, gradeAblation, buildSkillOffPrompt, clamp01 };\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/executor-dispatch.cjs:\n  Line 40:     // Browser scenarios need a real browser (bdg). Run them only in live mode;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/build-report.cjs:\n  Line 52:   lines.push(dimLine('D4 usefulness', d.D4));\n\n 