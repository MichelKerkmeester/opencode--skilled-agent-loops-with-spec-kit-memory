   986	def _apply_family_affinity(
   987	    skill_boosts: Dict[str, float],
   988	    boost_reasons: Dict[str, List[str]],
   989	) -> None:
   990	    """When one family member has a strong signal, lightly boost siblings."""
   991	    graph = _load_skill_graph()
   992	    if not graph:
   993	        return
   994	    families = graph.get("families", {})
   995	
   996	    for family_name, members in families.items():
   997	        boosted = [(m, skill_boosts.get(m, 0)) for m in members if skill_boosts.get(m, 0) > 1.0]
   998	        if not boosted:
   999	            continue
  1000	        max_boost = max(b for _, b in boosted)
  1001	        for member in members:
  1002	            if 0 < skill_boosts.get(member, 0) < 1.0 and max_boost > 1.5:
  1003	                affinity = max_boost * 0.08
  1004	                if affinity >= 0.1:
  1005	                    skill_boosts[member] = skill_boosts.get(member, 0) + affinity
  1006	                    boost_reasons.setdefault(member, []).append(f"!graph:family({family_name})")
