   293	      };
   294	    }
   295	
   296	    try {
   297	      return {
   298	        ok: true,
   299	        recommendations: parseRecommendations(attemptResult.stdout),
   300	        errorCode: null,
   301	        exitCode: attemptResult.exitCode,
   302	        signal: attemptResult.signal,
   303	        stderr: sanitizeStderr(attemptResult.stderr),
   304	        durationMs: performance.now() - startedAt,
   305	        retriesAttempted,
   306	      };
   307	    } catch (error: unknown) {
   308	      return {
   309	        ok: false,
   310	        recommendations: [],
   311	        errorCode: error instanceof SyntaxError ? 'JSON_PARSE_FAILED' : 'INVALID_JSON_SHAPE',
   312	        exitCode: attemptResult.exitCode,
   313	        signal: attemptResult.signal,
   314	        stderr: null,
   315	        durationMs: performance.now() - startedAt,
   316	        retriesAttempted,
   317	      };
   318	    }
   319	  }
   320	
   321	  return {
   322	    ok: false,
   323	    recommendations: [],
   324	    errorCode: 'SQLITE_BUSY_EXHAUSTED',
   325	    exitCode: null,
   326	    signal: null,
   327	    stderr: null,
   328	    durationMs: performance.now() - startedAt,
   329	    retriesAttempted,
