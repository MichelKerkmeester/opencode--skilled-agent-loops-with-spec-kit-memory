new server-generated session and reuse the effectiveSessionId returned by the server.\",\n  \"data\": {\n    \"error\": \"sessionId \\\"fanout-gpt-1-1781144891515-7jxn7r\\\" does not match a server-managed session. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.\",\n    \"code\": \"E_SESSION_SCOPE\",\n    \"details\": {\n      \"requestedSessionId\": \"fanout-gpt-1-1781144891515-7jxn7r\"\n    }\n  },\n  \"hints\": [\n    \"Omit session_id to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.\"\n  ],\n  \"meta\": {\n    \"tool\": \"memory_match_triggers\",\n    \"tokenCount\": 223,\n    \"cacheHit\": false,\n    \"isError\": true,\n    \"severity\": \"error\",\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781144910418,"end":1781144914914}},"metadata":{"openai":{"itemId":"fc_0195aca1edb0e33d016a2a1d4bacc88191a29b2e31ee2f814a"}},"id":"prt_eb4826fa7001zDbBTSKZmAcCs7","sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","messageID":"msg_eb48235d6001h3Sy1r4siWXQVU"}}
