{"type":"tool_use","timestamp":1781151294894,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_jfo1Ph84pVt6wnJgrln392Ei","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","offset":220,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts</path>\n<type>file</type>\n<content>\n220:       ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n221:       LIMIT 1\n222:     `).get() as { key: string; value: string } | undefined;\n223: \n224:     if (stored_row) {\n225:       const stored_dim = parseInt(stored_row.value, 10);\n226:       if (Number.isFinite(stored_dim) && stored_dim > 0) {\n227:         return {\n228:           existing_db: true,\n229:           stored_dim,\n230:           source: stored_row.key === 'active_embedder_dim' ? 'active_embedder_profile' : 'vec_metadata',\n231:         };\n232:       }\n233:     }\n234:   }\n235: \n236:   if (allowProfileFallback) {\n237:     const active = getActiveEmbedder(database);\n238:     if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n239:       return {\n240:         existing_db: true,\n241:         stored_dim: active.dim,\n242:         source: 'active_embedder_profile',\n243:       };\n244:     }\n245: \n246:     const startupProfile = getStartupEmbeddingProfile();\n247:     if (Number.isInteger(startupProfile.dim) && startupProfile.dim > 0) {\n248:       return {\n249:         existing_db: true,\n250:         stored_dim: startupProfile.dim,\n251:         source: 'startup_profile',\n252:       };\n253:     }\n254:   }\n255: \n256:   const vec_table = database.prepare(`\n257:     SELECT sql FROM sqlite_master WHERE name='vec_memories'\n258:   `).get() as { sql: string | null } | undefined;\n259:   const vec_sql = typeof vec_table?.sql === 'string' ? vec_table.sql : null;\n260:   const match = vec_sql?.match(/FLOAT\\[(\\d+)\\]/i);\n261: \n262:   if (match) {\n263:     const stored_dim = parseInt(match[1], 10);\n264:     if (Number.isFinite(stored_dim) && stored_dim > 0) {\n265:       console.warn('[vector-index] Falling back to vec_memories schema text for embedding dimension; configure an active embedder profile to make dimension discovery authoritative.');\n266:       return {\n267:         existing_db: true,\n268:         stored_dim,\n269:         source: 'vec_memories',\n270:       };\n271:     }\n272:   }\n273: \n274:   return {\n275:     existing_db: true,\n276:     stored_dim: null,\n277:     source: null,\n278:     reason: 'No stored vector dimension found for existing schema',\n279:   };\n280: }\n281: \n282: function validate_embedding_dimension_for_connection(\n283:   database: Database.Database | null,\n284:   _sqlite_vec_available: boolean,\n285: ): EmbeddingDimensionValidation {\n286:   if (!database) {\n287:     return { valid: true, stored: null, current: null, reason: 'No database' };\n288:   }\n289: \n290:   try {\n291:     const active = getActiveEmbedder(database);\n292:     const current_dim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0\n293:       ? active.dim\n294:       : get_embedding_dim();\n295:     const existing = get_existing_embedding_dimension(database);\n296: \n297:     if (!existing.existing_db) {\n298:       return { valid: true, stored: null, current: current_dim, reason: existing.reason };\n299:     }\n300: \n301:     if (existing.stored_dim == null) {\n302:       return { valid: true, stored: null, current: current_dim, reason: existing.reason || 'No stored dimension' };\n303:     }\n304: \n305:     if (existing.stored_dim !== current_dim) {\n306:       const source_label = existing.source === 'vec_metadata' ? 'vec_metadata' : 'vec_memories schema';\n307:       const warning = `EMBEDDING DIMENSION MISMATCH: Existing database stores ${existing.stored_dim}-dim vectors (${source_label}), ` +\n308:         `but the active embedding configuration resolves to ${current_dim}. Refusing to bootstrap because vector search would fail. ` +\n309:         `Solutions: 1) Delete database and re-index, 2) Set EMBEDDINGS_PROVIDER to match original, ` +\n310:         `3) Let SPEC_KIT_DB_DIR auto-derive a profile-specific database, or set MEMORY_DB_PATH only for an intentional file override.`;\n311:       console.error(`[vector-index] WARNING: ${warning}`);\n312:       return { valid: false, stored: existing.stored_dim, current: current_dim, warning };\n313:     }\n314: \n315:     return { valid: true, stored: existing.stored_dim, current: current_dim };\n316:   } catch (e: unknown) {\n317:     console.warn('[vector-index] Dimension validation error:', get_error_message(e));\n318:     return { valid: true, stored: null, current: get_embedding_dim(), reason: get_error_message(e) };\n319:   }\n320: }\n321: \n322: /**\n323:  * Validates that stored vector dimensions match the provider.\n324:  * @returns The validation result.\n325:  */\n326: export function validate_embedding_dimension(): { valid: boolean; stored: number | null; current: number | null; reason?: string; warning?: string } {\n327:   return validate_embedding_dimension_for_connection(db, sqlite_vec_available_flag);\n328: }\n329: \n330: /* ───────────────────────────────────────────────────────────────\n331:    2. DATABASE PATH AND SECURITY\n332: ----------------------------------------------------------------*/\n333: \n334: function get_default_db_path(): string {\n335:   return process.env.MEMORY_DB_PATH || resolveDatabasePaths().databasePath;\n336: }\n337: \n338: /** Default path for the vector-index database file. */\n339: export const DEFAULT_DB_PATH = process.env.MEMORY_DB_PATH\n340:   || get_default_db_path();\n341: const DB_PERMISSIONS = 0o600;\n342: \n343: function resolve_database_path() {\n344:   return process.env.MEMORY_DB_PATH || get_default_db_path();\n345: }\n346: \n347: export const ACTIVE_VECTOR_SCHEMA = 'active_vec';\n348: \n349: type ActiveVectorSourceTelemetry = {\n350:   canonical_path: string;\n351:   shard_path: string;\n352:   attached: boolean;\n353:   profile: {\n354:     provider: string;\n355:     model: string;\n356:     dim: number;\n357:     dtype: string | null;\n358:   };\n359: };\n360: \n361: function quote_sql_string(value: string): string {\n362:   return `'${value.replace(/'/g, \"''\")}'`;\n363: }\n364: \n365: function quote_identifier(value: string): string {\n366:   return `\"${value.replace(/\"/g, '\"\"')}\"`;\n367: }\n368: \n369: function get_database_file_path(database: Database.Database): string {\n370:   const row = database.prepare('PRAGMA database_list').all()\n371:     .find((entry: unknown) => (entry as { name?: string }).name === 'main') as { file?: string } | undefined;\n372:   return row?.file && row.file.length > 0 ? row.file : db_path;\n373: }\n374: \n375: function resolve_database_base_dir(database: Database.Database): string {\n376:   const filePath = get_database_file_path(database);\n377:   if (!filePath || filePath === ':memory:') {\n378:     return resolveDatabasePaths().databaseDir;\n379:   }\n380:   return path.dirname(filePath);\n381: }\n382: \n383: function legacy_profile_database_path(profile: EmbeddingProfile, baseDir: string): string {\n384:   return path.join(baseDir, `context-index__${profile.slug}.sqlite`);\n385: }\n386: \n387: function get_vector_shard_path(profile: EmbeddingProfile, baseDir: string): string {\n388:   const vectorDir = path.join(baseDir, 'vectors');\n389:   if (!fs.existsSync(vectorDir)) {\n390:     fs.mkdirSync(vectorDir, { recursive: true, mode: 0o700 });\n391:   }\n392:   return path.join(vectorDir, `context-vectors__${profile.slug}.sqlite`);\n393: }\n394: \n395: function resolve_profile_for_active_embedder(database: Database.Database): EmbeddingProfile {\n396:   const active = getActiveEmbedder(database);\n397:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n398:     const startup = getStartupEmbeddingProfile();\n399:     return new EmbeddingProfile({\n400:       provider: active.provider ?? startup.provider,\n401:       model: active.name,\n402:       dim: active.dim,\n403:       dtype: null,\n404:       baseUrl: startup.baseUrl,\n405:     });\n406:   }\n407:   return getStartupEmbeddingProfile();\n408: }\n409: \n410: function vector_table_name_for_profile(profile: EmbeddingProfile): string {\n411:   return `vec_${profile.dim}`;\n412: }\n413: \n414: function active_schema_table(tableName: string): string {\n415:   return `${ACTIVE_VECTOR_SCHEMA}.${tableName}`;\n416: }\n417: \n418: export function activeVectorSource(tableName?: string): string {\n419:   return tableName ? active_schema_table(tableName) : ACTIVE_VECTOR_SCHEMA;\n420: }\n421: \n422: function get_attached_vector_path(database: Database.Database): string | null {\n423:   const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>;\n424:   const row = attached.find((entry) => entry.name === ACTIVE_VECTOR_SCHEMA);\n425:   return row?.file ? path.resolve(row.file) : null;\n426: }\n427: \n428: function table_exists_in_schema(database: Database.Database, schema: string, tableName: string): boolean {\n429:   const row = database.prepare(`\n430:     SELECT 1 AS found\n431:     FROM ${quote_identifier(schema)}.sqlite_master\n432:     WHERE type IN ('table', 'view') AND name = ?\n433:     LIMIT 1\n434:   `).get(tableName) as { found?: number } | undefined;\n435:   return row?.found === 1;\n436: }\n437: \n438: type VectorShardIntegrityProbeResult =\n439:   | { ok: true }\n440:   | { ok: false; reason: string };\n441: \n442: function quick_check_verdict(database: Database.Database, schema?: string): string {\n443:   const rows = schema\n444:     ? database.pragma(`${schema}.quick_check(1)`) as Array<Record<string, unknown>>\n445:     : database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n446:   const first = rows?.[0] ? Object.values(rows[0])[0] : undefined;\n447:   return typeof first === 'string' ? first : 'quick_check returned no verdict';\n448: }\n449: \n450: function required_vector_shard_tables(profile: EmbeddingProfile, vecAvailable: boolean): string[] {\n451:   return [\n452:     'vec_metadata',\n453:     'embedding_cache',\n454:     vector_table_name_for_profile(profile),\n455:     ...(vecAvailable ? ['vec_memories'] : []),\n456:   ];\n457: }\n458: \n459: function run_attached_vector_shard_integrity_probe(\n460:   database: Database.Database,\n461:   profile: EmbeddingProfile,\n462:   vecAvailable: boolean,\n463: ): VectorShardIntegrityProbeResult {\n464:   try {\n465:     const verdict = quick_check_verdict(database, ACTIVE_VECTOR_SCHEMA);\n466:     if (verdict !== 'ok') {\n467:       return { ok: false, reason: `quick_check failed: ${verdict}` };\n468:     }\n469:     for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n470:       if (!table_exists_in_schema(database, ACTIVE_VECTOR_SCHEMA, tableName)) {\n471:         return { ok: false, reason: `required table missing: ${tableName}` };\n472:       }\n473:     }\n474:     return { ok: true };\n475:   } catch (error: unknown) {\n476:     return { ok: false, reason: get_error_message(error) };\n477:   }\n478: }\n479: \n480: function run_vector_shard_integrity_probe_at_path(\n481:   shardPath: string,\n482:   profile: EmbeddingProfile,\n483:   vecAvailable: boolean,\n484: ): VectorShardIntegrityProbeResult {\n485:   if (!fs.existsSync(shardPath)) {\n486:     return { ok: true };\n487:   }\n488: \n489:   let shard: Database.Database | null = null;\n490:   try {\n491:     shard = new Database(shardPath, { readonly: true, fileMustExist: true });\n492:     if (vecAvailable) {\n493:       sqliteVec.load(shard);\n494:     }\n495:     const verdict = quick_check_verdict(shard);\n496:     if (verdict !== 'ok') {\n497:       return { ok: false, reason: `quick_check failed: ${verdict}` };\n498:     }\n499:     for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n500:       const row = shard.prepare(`\n501:         SELECT 1 AS found\n502:         FROM sqlite_master\n503:         WHERE type IN ('table', 'view') AND name = ?\n504:         LIMIT 1\n505:       `).get(tableName) as { found?: number } | undefined;\n506:       if (row?.found !== 1) {\n507:         return { ok: false, reason: `required table missing: ${tableName}` };\n508:       }\n509:     }\n510:     return { ok: true };\n511:   } catch (error: unknown) {\n512:     return { ok: false, reason: get_error_message(error) };\n513:   } finally {\n514:     if (shard) {\n515:       try { shard.close(); } catch (_error: unknown) { /* best-effort */ }\n516:     }\n517:   }\n518: }\n519: \n520: function quarantine_vector_shard(shardPath: string, reason: string): string {\n521:   const stamp = new Date().toISOString().replace(/[^0-9A-Za-z]/g, '');\n522:   const quarantinePath = `${shardPath}.quarantined-${stamp}-${process.pid}`;\n523:   for (const suffix of ['', '-wal', '-shm']) {\n524:     const source = `${shardPath}${suffix}`;\n525:     if (!fs.existsSync(source)) {\n526:       continue;\n527:     }\n528:     fs.renameSync(source, `${quarantinePath}${suffix}`);\n529:   }\n530:   fsync_file_if_possible(quarantinePath);\n531:   fsync_directory_if_possible(path.dirname(shardPath));\n532:   recordVectorShardQuarantined({ shardPath, quarantinePath, reason });\n533:   return quarantinePath;\n534: }\n535: \n536: function schedule_vector_shard_rebuild(\n537:   database: Database.Database,\n538:   profile: EmbeddingProfile,\n539:   shardPath: string,\n540:   reason: string,\n541: ): void {\n542:   setImmediate(() => {\n543:     void import('../embedders/reindex.js')\n544:       .then(({ startVectorShardRepairReindex }) => {\n545:         startVectorShardRepairReindex(profile, { db: database, reason, shardPath });\n546:       })\n547:       .catch((error: unknown) => {\n548:         recordVectorShardRebuildFailed({\n549:           jobId: 'not-started',\n550:           shardPath,\n551:           reason: get_error_message(error),\n552:         });\n553:       });\n554:   });\n555: }\n556: \n557: function quarantine_and_rebuild_vector_shard(\n558:   database: Database.Database,\n559:   profile: EmbeddingProfile,\n560:   shardPath: string,\n561:   reason: string,\n562: ): void {\n563:   recordVectorShardProbeFailure({ shardPath, reason });\n564:   const quarantinePath = quarantine_vector_shard(shardPath, reason);\n565:   schedule_vector_shard_rebuild(database, profile, shardPath, `${reason}; quarantined as ${path.basename(quarantinePath)}`);\n566: }\n567: \n568: function write_shard_metadata(database: Database.Database, profile: EmbeddingProfile): void {\n569:   database.exec(`\n570:     CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.vec_metadata (\n571:       key TEXT PRIMARY KEY,\n572:       value TEXT NOT NULL,\n573:       created_at TEXT DEFAULT (datetime('now'))\n574:     )\n575:   `);\n576: \n577:   const rows = database.prepare(`\n578:     SELECT key, value\n579:     FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata\n580:     WHERE key IN ('provider', 'model', 'dim', 'embedding_dim')\n581:   `).all() as Array<{ key: string; value: string }>;\n582:   const metadata = new Map(rows.map((row) => [row.key, row.value]));\n583:   const mismatches = [\n584:     ['provider', profile.provider],\n585:     ['model', profile.model],\n586:     ['dim', String(profile.dim)],\n587:     ['embedding_dim', String(profile.dim)],\n588:   ].filter(([key, expected]) => {\n589:     const actual = metadata.get(key);\n590:     return actual != null && actual.length > 0 && actual !== expected;\n591:   });\n592: \n593:   if (mismatches.length > 0) {\n594:     const detail = mismatches.map(([key, expected]) => `${key}: expected ${expected}, got ${metadata.get(key)}`).join('; ');\n595:     throw new VectorIndexError(\n596:       `Attached vector shard metadata mismatch (${detail})`,\n597:       VectorIndexErrorCode.INTEGRITY_ERROR,\n598:     );\n599:   }\n\n(Showing lines 220-599 of 1989. Use offset=600 to continue.)\n</content>","metadata":{"preview":"      ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n      LIMIT 1\n    `).get() as { key: string; value: string } | undefined;\n\n    if (stored_row) {\n      const stored_dim = parseInt(stored_row.value, 10);\n      if (Number.isFinite(stored_dim) && stored_dim > 0) {\n        return {\n          existing_db: true,\n          stored_dim,\n          source: stored_row.key === 'active_embedder_dim' ? 'active_embedder_profile' : 'vec_metadata',\n        };\n      }\n    }\n  }\n\n  if (allowProfileFallback) {\n    const active = getActiveEmbedder(database);\n    if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n      return {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":"      ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n      LIMIT 1\n    `).get() as { key: string; value: string } | undefined;\n\n    if (stored_row) {\n      const stored_dim = parseInt(stored_row.value, 10);\n      if (Number.isFinite(stored_dim) && stored_dim > 0) {\n        return {\n          existing_db: true,\n          stored_dim,\n          source: stored_row.key === 'active_embedder_dim' ? 'active_embedder_profile' : 'vec_metadata',\n        };\n      }\n    }\n  }\n\n  if (allowProfileFallback) {\n    const active = getActiveEmbedder(database);\n    if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n      return {\n        existing_db: true,\n        stored_dim: active.dim,\n        source: 'active_embedder_profile',\n      };\n    }\n\n    const startupProfile = getStartupEmbeddingProfile();\n    if (Number.isInteger(startupProfile.dim) && startupProfile.dim > 0) {\n      return {\n        existing_db: true,\n        stored_dim: startupProfile.dim,\n        source: 'startup_profile',\n      };\n    }\n  }\n\n  const vec_table = database.prepare(`\n    SELECT sql FROM sqlite_master WHERE name='vec_memories'\n  `).get() as { sql: string | null } | undefined;\n  const vec_sql = typeof vec_table?.sql === 'string' ? vec_table.sql : null;\n  const match = vec_sql?.match(/FLOAT\\[(\\d+)\\]/i);\n\n  if (match) {\n    const stored_dim = parseInt(match[1], 10);\n    if (Number.isFinite(stored_dim) && stored_dim > 0) {\n      console.warn('[vector-index] Falling back to vec_memories schema text for embedding dimension; configure an active embedder profile to make dimension discovery authoritative.');\n      return {\n        existing_db: true,\n        stored_dim,\n        source: 'vec_memories',\n      };\n    }\n  }\n\n  return {\n    existing_db: true,\n    stored_dim: null,\n    source: null,\n    reason: 'No stored vector dimension found for existing schema',\n  };\n}\n\nfunction validate_embedding_dimension_for_connection(\n  database: Database.Database | null,\n  _sqlite_vec_available: boolean,\n): EmbeddingDimensionValidation {\n  if (!database) {\n    return { valid: true, stored: null, current: null, reason: 'No database' };\n  }\n\n  try {\n    const active = getActiveEmbedder(database);\n    const current_dim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0\n      ? active.dim\n      : get_embedding_dim();\n    const existing = get_existing_embedding_dimension(database);\n\n    if (!existing.existing_db) {\n      return { valid: true, stored: null, current: current_dim, reason: existing.reason };\n    }\n\n    if (existing.stored_dim == null) {\n      return { valid: true, stored: null, current: current_dim, reason: existing.reason || 'No stored dimension' };\n    }\n\n    if (existing.stored_dim !== current_dim) {\n      const source_label = existing.source === 'vec_metadata' ? 'vec_metadata' : 'vec_memories schema';\n      const warning = `EMBEDDING DIMENSION MISMATCH: Existing database stores ${existing.stored_dim}-dim vectors (${source_label}), ` +\n        `but the active embedding configuration resolves to ${current_dim}. Refusing to bootstrap because vector search would fail. ` +\n        `Solutions: 1) Delete database and re-index, 2) Set EMBEDDINGS_PROVIDER to match original, ` +\n        `3) Let SPEC_KIT_DB_DIR auto-derive a profile-specific database, or set MEMORY_DB_PATH only for an intentional file override.`;\n      console.error(`[vector-index] WARNING: ${warning}`);\n      return { valid: false, stored: existing.stored_dim, current: current_dim, warning };\n    }\n\n    return { valid: true, stored: existing.stored_dim, current: current_dim };\n  } catch (e: unknown) {\n    console.warn('[vector-index] Dimension validation error:', get_error_message(e));\n    return { valid: true, stored: null, current: get_embedding_dim(), reason: get_error_message(e) };\n  }\n}\n\n/**\n * Validates that stored vector dimensions match the provider.\n * @returns The validation result.\n */\nexport function validate_embedding_dimension(): { valid: boolean; stored: number | null; current: number | null; reason?: string; warning?: string } {\n  return validate_embedding_dimension_for_connection(db, sqlite_vec_available_flag);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. DATABASE PATH AND SECURITY\n----------------------------------------------------------------*/\n\nfunction get_default_db_path(): string {\n  return process.env.MEMORY_DB_PATH || resolveDatabasePaths().databasePath;\n}\n\n/** Default path for the vector-index database file. */\nexport const DEFAULT_DB_PATH = process.env.MEMORY_DB_PATH\n  || get_default_db_path();\nconst DB_PERMISSIONS = 0o600;\n\nfunction resolve_database_path() {\n  return process.env.MEMORY_DB_PATH || get_default_db_path();\n}\n\nexport const ACTIVE_VECTOR_SCHEMA = 'active_vec';\n\ntype ActiveVectorSourceTelemetry = {\n  canonical_path: string;\n  shard_path: string;\n  attached: boolean;\n  profile: {\n    provider: string;\n    model: string;\n    dim: number;\n    dtype: string | null;\n  };\n};\n\nfunction quote_sql_string(value: string): string {\n  return `'${value.replace(/'/g, \"''\")}'`;\n}\n\nfunction quote_identifier(value: string): string {\n  return `\"${value.replace(/\"/g, '\"\"')}\"`;\n}\n\nfunction get_database_file_path(database: Database.Database): string {\n  const row = database.prepare('PRAGMA database_list').all()\n    .find((entry: unknown) => (entry as { name?: string }).name === 'main') as { file?: string } | undefined;\n  return row?.file && row.file.length > 0 ? row.file : db_path;\n}\n\nfunction resolve_database_base_dir(database: Database.Database): string {\n  const filePath = get_database_file_path(database);\n  if (!filePath || filePath === ':memory:') {\n    return resolveDatabasePaths().databaseDir;\n  }\n  return path.dirname(filePath);\n}\n\nfunction legacy_profile_database_path(profile: EmbeddingProfile, baseDir: string): string {\n  return path.join(baseDir, `context-index__${profile.slug}.sqlite`);\n}\n\nfunction get_vector_shard_path(profile: EmbeddingProfile, baseDir: string): string {\n  const vectorDir = path.join(baseDir, 'vectors');\n  if (!fs.existsSync(vectorDir)) {\n    fs.mkdirSync(vectorDir, { recursive: true, mode: 0o700 });\n  }\n  return path.join(vectorDir, `context-vectors__${profile.slug}.sqlite`);\n}\n\nfunction resolve_profile_for_active_embedder(database: Database.Database): EmbeddingProfile {\n  const active = getActiveEmbedder(database);\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n    const startup = getStartupEmbeddingProfile();\n    return new EmbeddingProfile({\n      provider: active.provider ?? startup.provider,\n      model: active.name,\n      dim: active.dim,\n      dtype: null,\n      baseUrl: startup.baseUrl,\n    });\n  }\n  return getStartupEmbeddingProfile();\n}\n\nfunction vector_table_name_for_profile(profile: EmbeddingProfile): string {\n  return `vec_${profile.dim}`;\n}\n\nfunction active_schema_table(tableName: string): string {\n  return `${ACTIVE_VECTOR_SCHEMA}.${tableName}`;\n}\n\nexport function activeVectorSource(tableName?: string): string {\n  return tableName ? active_schema_table(tableName) : ACTIVE_VECTOR_SCHEMA;\n}\n\nfunction get_attached_vector_path(database: Database.Database): string | null {\n  const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>;\n  const row = attached.find((entry) => entry.name === ACTIVE_VECTOR_SCHEMA);\n  return row?.file ? path.resolve(row.file) : null;\n}\n\nfunction table_exists_in_schema(database: Database.Database, schema: string, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM ${quote_identifier(schema)}.sqlite_master\n    WHERE type IN ('table', 'view') AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\ntype VectorShardIntegrityProbeResult =\n  | { ok: true }\n  | { ok: false; reason: string };\n\nfunction quick_check_verdict(database: Database.Database, schema?: string): string {\n  const rows = schema\n    ? database.pragma(`${schema}.quick_check(1)`) as Array<Record<string, unknown>>\n    : database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n  const first = rows?.[0] ? Object.values(rows[0])[0] : undefined;\n  return typeof first === 'string' ? first : 'quick_check returned no verdict';\n}\n\nfunction required_vector_shard_tables(profile: EmbeddingProfile, vecAvailable: boolean): string[] {\n  return [\n    'vec_metadata',\n    'embedding_cache',\n    vector_table_name_for_profile(profile),\n    ...(vecAvailable ? ['vec_memories'] : []),\n  ];\n}\n\nfunction run_attached_vector_shard_integrity_probe(\n  database: Database.Database,\n  profile: EmbeddingProfile,\n  vecAvailable: boolean,\n): VectorShardIntegrityProbeResult {\n  try {\n    const verdict = quick_check_verdict(database, ACTIVE_VECTOR_SCHEMA);\n    if (verdict !== 'ok') {\n      return { ok: false, reason: `quick_check failed: ${verdict}` };\n    }\n    for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n      if (!table_exists_in_schema(database, ACTIVE_VECTOR_SCHEMA, tableName)) {\n        return { ok: false, reason: `required table missing: ${tableName}` };\n      }\n    }\n    return { ok: true };\n  } catch (error: unknown) {\n    return { ok: false, reason: get_error_message(error) };\n  }\n}\n\nfunction run_vector_shard_integrity_probe_at_path(\n  shardPath: string,\n  profile: EmbeddingProfile,\n  vecAvailable: boolean,\n): VectorShardIntegrityProbeResult {\n  if (!fs.existsSync(shardPath)) {\n    return { ok: true };\n  }\n\n  let shard: Database.Database | null = null;\n  try {\n    shard = new Database(shardPath, { readonly: true, fileMustExist: true });\n    if (vecAvailable) {\n      sqliteVec.load(shard);\n    }\n    const verdict = quick_check_verdict(shard);\n    if (verdict !== 'ok') {\n      return { ok: false, reason: `quick_check failed: ${verdict}` };\n    }\n    for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n      const row = shard.prepare(`\n        SELECT 1 AS found\n        FROM sqlite_master\n        WHERE type IN ('table', 'view') AND name = ?\n        LIMIT 1\n      `).get(tableName) as { found?: number } | undefined;\n      if (row?.found !== 1) {\n        return { ok: false, reason: `required table missing: ${tableName}` };\n      }\n    }\n    return { ok: true };\n  } catch (error: unknown) {\n    return { ok: false, reason: get_error_message(error) };\n  } finally {\n    if (shard) {\n      try { shard.close(); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction quarantine_vector_shard(shardPath: string, reason: string): string {\n  const stamp = new Date().toISOString().replace(/[^0-9A-Za-z]/g, '');\n  const quarantinePath = `${shardPath}.quarantined-${stamp}-${process.pid}`;\n  for (const suffix of ['', '-wal', '-shm']) {\n    const source = `${shardPath}${suffix}`;\n    if (!fs.existsSync(source)) {\n      continue;\n    }\n    fs.renameSync(source, `${quarantinePath}${suffix}`);\n  }\n  fsync_file_if_possible(quarantinePath);\n  fsync_directory_if_possible(path.dirname(shardPath));\n  recordVectorShardQuarantined({ shardPath, quarantinePath, reason });\n  return quarantinePath;\n}\n\nfunction schedule_vector_shard_rebuild(\n  database: Database.Database,\n  profile: EmbeddingProfile,\n  shardPath: string,\n  reason: string,\n): void {\n  setImmediate(() => {\n    void import('../embedders/reindex.js')\n      .then(({ startVectorShardRepairReindex }) => {\n        startVectorShardRepairReindex(profile, { db: database, reason, shardPath });\n      })\n      .catch((error: unknown) => {\n        recordVectorShardRebuildFailed({\n          jobId: 'not-started',\n          shardPath,\n          reason: get_error_message(error),\n        });\n      });\n  });\n}\n\nfunction quarantine_and_rebuild_vector_shard(\n  database: Database.Database,\n  profile: EmbeddingProfile,\n  shardPath: string,\n  reason: string,\n): void {\n  recordVectorShardProbeFailure({ shardPath, reason });\n  const quarantinePath = quarantine_vector_shard(shardPath, reason);\n  schedule_vector_shard_rebuild(database, profile, shardPath, `${reason}; quarantined as ${path.basename(quarantinePath)}`);\n}\n\nfunction write_shard_metadata(database: Database.Database, profile: EmbeddingProfile): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.vec_metadata (\n      key TEXT PRIMARY KEY,\n      value TEXT NOT NULL,\n      created_at TEXT DEFAULT (datetime('now'))\n    )\n  `);\n\n  const rows = database.prepare(`\n    SELECT key, value\n    FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata\n    WHERE key IN ('provider', 'model', 'dim', 'embedding_dim')\n  `).all() as Array<{ key: string; value: string }>;\n  const metadata = new Map(rows.map((row) => [row.key, row.value]));\n  const mismatches = [\n    ['provider', profile.provider],\n    ['model', profile.model],\n    ['dim', String(profile.dim)],\n    ['embedding_dim', String(profile.dim)],\n  ].filter(([key, expected]) => {\n    const actual = metadata.get(key);\n    return actual != null && actual.length > 0 && actual !== expected;\n  });\n\n  if (mismatches.length > 0) {\n    const detail = mismatches.map(([key, expected]) => `${key}: expected ${expected}, got ${metadata.get(key)}`).join('; ');\n    throw new VectorIndexError(\n      `Attached vector shard metadata mismatch (${detail})`,\n      VectorIndexErrorCode.INTEGRITY_ERROR,\n    );\n  }","lineStart":220,"lineEnd":599,"totalLines":1989,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1781151294888,"end":1781151294893}},"metadata":{"openai":{"itemId":"fc_0a3c79976b7d1942016a2a363ed3b08191b02624972f7287b9"}},"id":"prt_eb4e3e585001qWM1V0TNLf2fCC","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3bebc001TVrc4Vv5DX0iRt"}}
{"type":"tool_use","timestamp":1781151294916,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_dC3sMPoaQGbGM6RPa7nUfSz9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","offset":1200,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts</path>\n<type>file</type>\n<content>\n1200:   canonicalPath: string,\n1201:   profile: EmbeddingProfile,\n1202: ): void {\n1203:   if (canonicalPath === ':memory:') {\n1204:     return;\n1205:   }\n1206: \n1207:   const baseDir = path.dirname(canonicalPath);\n1208:   const shardPath = get_vector_shard_path(profile, baseDir);\n1209:   const legacyPath = legacy_profile_database_path(profile, baseDir);\n1210:   if (path.resolve(legacyPath) === path.resolve(canonicalPath)) {\n1211:     return;\n1212:   }\n1213: \n1214:   migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n1215: }\n1216: \n1217: export function attachActiveVectorShard(database: Database.Database, profile: EmbeddingProfile): void {\n1218:   try {\n1219:     sqliteVec.load(database);\n1220:     sqlite_vec_available_flag = true;\n1221:   } catch (_error: unknown) {\n1222:     sqlite_vec_available_flag = false;\n1223:   }\n1224:   database.pragma('journal_mode = WAL');\n1225:   const canonicalPath = get_database_file_path(database);\n1226:   const baseDir = resolve_database_base_dir(database);\n1227:   const shardPath = get_vector_shard_path(profile, baseDir);\n1228:   const attachedPath = get_attached_vector_path(database);\n1229: \n1230:   if (attachedPath && attachedPath !== path.resolve(shardPath)) {\n1231:     drop_legacy_temp_aliases(database);\n1232:     database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1233:   } else if (attachedPath === path.resolve(shardPath)) {\n1234:     const probe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n1235:     if (!probe.ok) {\n1236:       drop_legacy_temp_aliases(database);\n1237:       database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1238:       quarantine_and_rebuild_vector_shard(database, profile, shardPath, probe.reason);\n1239:       database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1240:       ensure_vector_shard_schema(database, profile);\n1241:       drop_canonical_vector_payload_tables(database);\n1242:       create_legacy_temp_aliases(database, profile);\n1243:       active_vector_source = {\n1244:         canonical_path: canonicalPath,\n1245:         shard_path: shardPath,\n1246:         attached: true,\n1247:         profile: {\n1248:           provider: profile.provider,\n1249:           model: profile.model,\n1250:           dim: profile.dim,\n1251:           dtype: profile.dtype,\n1252:         },\n1253:       };\n1254:       return;\n1255:     }\n1256:     ensure_vector_shard_schema(database, profile);\n1257:     drop_canonical_vector_payload_tables(database);\n1258:     create_legacy_temp_aliases(database, profile);\n1259:     active_vector_source = {\n1260:       canonical_path: canonicalPath,\n1261:       shard_path: shardPath,\n1262:       attached: true,\n1263:       profile: {\n1264:         provider: profile.provider,\n1265:         model: profile.model,\n1266:         dim: profile.dim,\n1267:         dtype: profile.dtype,\n1268:       },\n1269:     };\n1270:     return;\n1271:   }\n1272: \n1273:   const shardExistedBeforeAttach = fs.existsSync(shardPath);\n1274:   const preAttachProbe = run_vector_shard_integrity_probe_at_path(shardPath, profile, sqlite_vec_available_flag);\n1275:   let needsPostAttachProbe = shardExistedBeforeAttach && preAttachProbe.ok;\n1276:   if (!preAttachProbe.ok) {\n1277:     quarantine_and_rebuild_vector_shard(database, profile, shardPath, preAttachProbe.reason);\n1278:     needsPostAttachProbe = false;\n1279:   }\n1280: \n1281:   try {\n1282:     database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1283:   } catch (attachError: unknown) {\n1284:     const reason = get_error_message(attachError);\n1285:     if (!fs.existsSync(shardPath)) {\n1286:       throw attachError;\n1287:     }\n1288:     quarantine_and_rebuild_vector_shard(database, profile, shardPath, reason);\n1289:     needsPostAttachProbe = false;\n1290:     database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1291:   }\n1292: \n1293:   if (needsPostAttachProbe) {\n1294:     const attachedProbe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n1295:     if (!attachedProbe.ok) {\n1296:       drop_legacy_temp_aliases(database);\n1297:       database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1298:       quarantine_and_rebuild_vector_shard(database, profile, shardPath, attachedProbe.reason);\n1299:       database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1300:     }\n1301:   }\n1302:   ensure_vector_shard_schema(database, profile);\n1303:   drop_canonical_vector_payload_tables(database);\n1304:   create_legacy_temp_aliases(database, profile);\n1305:   active_vector_source = {\n1306:     canonical_path: canonicalPath,\n1307:     shard_path: shardPath,\n1308:     attached: true,\n1309:     profile: {\n1310:       provider: profile.provider,\n1311:       model: profile.model,\n1312:       dim: profile.dim,\n1313:       dtype: profile.dtype,\n1314:     },\n1315:   };\n1316: }\n1317: \n1318: export function attachActiveVectorShardForActiveProfile(database: Database.Database): void {\n1319:   attachActiveVectorShard(database, resolve_profile_for_active_embedder(database));\n1320: }\n1321: \n1322: export function detachActiveVectorShard(database: Database.Database): void {\n1323:   drop_legacy_temp_aliases(database);\n1324: \n1325:   if (get_attached_vector_path(database)) {\n1326:     database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1327:   }\n1328: \n1329:   if (active_vector_source) {\n1330:     active_vector_source = { ...active_vector_source, attached: false };\n1331:   }\n1332: }\n1333: \n1334: export function getActiveVectorSource(): ActiveVectorSourceTelemetry {\n1335:   if (db) {\n1336:     const profile = resolve_profile_for_active_embedder(db);\n1337:     const canonicalPath = get_database_file_path(db);\n1338:     const baseDir = resolve_database_base_dir(db);\n1339:     const shardPath = get_vector_shard_path(profile, baseDir);\n\n(Showing lines 1200-1339 of 1989. Use offset=1340 to continue.)\n</content>","metadata":{"preview":"  canonicalPath: string,\n  profile: EmbeddingProfile,\n): void {\n  if (canonicalPath === ':memory:') {\n    return;\n  }\n\n  const baseDir = path.dirname(canonicalPath);\n  const shardPath = get_vector_shard_path(profile, baseDir);\n  const legacyPath = legacy_profile_database_path(profile, baseDir);\n  if (path.resolve(legacyPath) === path.resolve(canonicalPath)) {\n    return;\n  }\n\n  migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n}\n\nexport function attachActiveVectorShard(database: Database.Database, profile: EmbeddingProfile): void {\n  try {\n    sqliteVec.load(database);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":"  canonicalPath: string,\n  profile: EmbeddingProfile,\n): void {\n  if (canonicalPath === ':memory:') {\n    return;\n  }\n\n  const baseDir = path.dirname(canonicalPath);\n  const shardPath = get_vector_shard_path(profile, baseDir);\n  const legacyPath = legacy_profile_database_path(profile, baseDir);\n  if (path.resolve(legacyPath) === path.resolve(canonicalPath)) {\n    return;\n  }\n\n  migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n}\n\nexport function attachActiveVectorShard(database: Database.Database, profile: EmbeddingProfile): void {\n  try {\n    sqliteVec.load(database);\n    sqlite_vec_available_flag = true;\n  } catch (_error: unknown) {\n    sqlite_vec_available_flag = false;\n  }\n  database.pragma('journal_mode = WAL');\n  const canonicalPath = get_database_file_path(database);\n  const baseDir = resolve_database_base_dir(database);\n  const shardPath = get_vector_shard_path(profile, baseDir);\n  const attachedPath = get_attached_vector_path(database);\n\n  if (attachedPath && attachedPath !== path.resolve(shardPath)) {\n    drop_legacy_temp_aliases(database);\n    database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n  } else if (attachedPath === path.resolve(shardPath)) {\n    const probe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n    if (!probe.ok) {\n      drop_legacy_temp_aliases(database);\n      database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n      quarantine_and_rebuild_vector_shard(database, profile, shardPath, probe.reason);\n      database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n      ensure_vector_shard_schema(database, profile);\n      drop_canonical_vector_payload_tables(database);\n      create_legacy_temp_aliases(database, profile);\n      active_vector_source = {\n        canonical_path: canonicalPath,\n        shard_path: shardPath,\n        attached: true,\n        profile: {\n          provider: profile.provider,\n          model: profile.model,\n          dim: profile.dim,\n          dtype: profile.dtype,\n        },\n      };\n      return;\n    }\n    ensure_vector_shard_schema(database, profile);\n    drop_canonical_vector_payload_tables(database);\n    create_legacy_temp_aliases(database, profile);\n    active_vector_source = {\n      canonical_path: canonicalPath,\n      shard_path: shardPath,\n      attached: true,\n      profile: {\n        provider: profile.provider,\n        model: profile.model,\n        dim: profile.dim,\n        dtype: profile.dtype,\n      },\n    };\n    return;\n  }\n\n  const shardExistedBeforeAttach = fs.existsSync(shardPath);\n  const preAttachProbe = run_vector_shard_integrity_probe_at_path(shardPath, profile, sqlite_vec_available_flag);\n  let needsPostAttachProbe = shardExistedBeforeAttach && preAttachProbe.ok;\n  if (!preAttachProbe.ok) {\n    quarantine_and_rebuild_vector_shard(database, profile, shardPath, preAttachProbe.reason);\n    needsPostAttachProbe = false;\n  }\n\n  try {\n    database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n  } catch (attachError: unknown) {\n    const reason = get_error_message(attachError);\n    if (!fs.existsSync(shardPath)) {\n      throw attachError;\n    }\n    quarantine_and_rebuild_vector_shard(database, profile, shardPath, reason);\n    needsPostAttachProbe = false;\n    database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n  }\n\n  if (needsPostAttachProbe) {\n    const attachedProbe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n    if (!attachedProbe.ok) {\n      drop_legacy_temp_aliases(database);\n      database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n      quarantine_and_rebuild_vector_shard(database, profile, shardPath, attachedProbe.reason);\n      database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n    }\n  }\n  ensure_vector_shard_schema(database, profile);\n  drop_canonical_vector_payload_tables(database);\n  create_legacy_temp_aliases(database, profile);\n  active_vector_source = {\n    canonical_path: canonicalPath,\n    shard_path: shardPath,\n    attached: true,\n    profile: {\n      provider: profile.provider,\n      model: profile.model,\n      dim: profile.dim,\n      dtype: profile.dtype,\n    },\n  };\n}\n\nexport function attachActiveVectorShardForActiveProfile(database: Database.Database): void {\n  attachActiveVectorShard(database, resolve_profile_for_active_embedder(database));\n}\n\nexport function detachActiveVectorShard(database: Database.Database): void {\n  drop_legacy_temp_aliases(database);\n\n  if (get_attached_vector_path(database)) {\n    database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n  }\n\n  if (active_vector_source) {\n    active_vector_source = { ...active_vector_source, attached: false };\n  }\n}\n\nexport function getActiveVectorSource(): ActiveVectorSourceTelemetry {\n  if (db) {\n    const profile = resolve_profile_for_active_embedder(db);\n    const canonicalPath = get_database_file_path(db);\n    const baseDir = resolve_database_base_dir(db);\n    const shardPath = get_vector_shard_path(profile, baseDir);","lineStart":1200,"lineEnd":1339,"totalLines":1989,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1781151294911,"end":1781151294915}},"metadata":{"openai":{"itemId":"fc_0a3c79976b7d1942016a2a363ed3c08191a14d118568e2632b"}},"id":"prt_eb4e3e5a9001k2zQMxaSe8snq0","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3bebc001TVrc4Vv5DX0iRt"}}
