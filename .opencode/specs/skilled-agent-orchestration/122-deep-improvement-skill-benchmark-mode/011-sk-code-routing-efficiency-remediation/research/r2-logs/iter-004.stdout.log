{"type":"tool_use","timestamp":1780372681809,"sessionID":"ses_17985835dffe8as3Ygnwtbh8Aj","part":{"type":"tool","tool":"read","callID":"call_Od4jfcS4gc5YlLkcq5TJYr9P","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * score-skill-benchmark.cjs — compute Lane C dimensions for one scenario and\n6:  * aggregate across a scenario set.\n7:  *\n8:  * Mode A (router-replay, deterministic) scores the dimensions that need no live\n9:  * model: D1-intra (in-skill routing), D2 (unprompted discovery proxy), D3\n10:  * (efficiency proxy), D5 (structural connectivity, hard gate). D1-inter (advisor\n11:  * selection) and D4 (usefulness ablation) require live dispatch / the advisor\n12:  * scorer and are reported as unscored in Mode A rather than faked — the\n13:  * aggregate is normalized over the dimensions actually measured so a Mode A\n14:  * score is honest about its coverage.\n15:  *\n16:  * Converged point weights (for reference / live mode): D1=25 (inter12+intra13),\n17:  * D2=20, D3=15, D4=25, D5=15 (gate).\n18:  */\n19: \n20: const { scoreD1Inter } = require('./advisor-probe.cjs');\n21: \n22: const WEIGHTS = { d1inter: 12, d1intra: 13, d2: 20, d3: 15, d4: 25, d5: 15 };\n23: \n24: function setRecall(expected, actual) {\n25:   if (!expected || expected.length === 0) return null; // not applicable\n26:   const have = new Set(actual || []);\n27:   const hit = expected.filter((e) => have.has(e)).length;\n28:   return hit / expected.length;\n29: }\n30: \n31: /**\n32:  * Score a single scenario from its router-replay result joined with private gold.\n33:  * @returns {{ scenarioId, dims, firstFailingStage, modeAScore, applicable }}\n34:  */\n35: function scoreScenario(arg) {\n36:   let { scenarioId, tier, routerResult, expected, advisorResult } = arg;\n37:   // Back-compat adapter. Legacy callers pass {routerResult, expected}; the\n38:   // playbook/live path passes {scenario, observed, traceMode}. Normalize the new\n39:   // shape onto the legacy locals so the scoring body stays shared (and the\n40:   // existing unit tests keep exercising it unchanged).\n41:   let scenario = arg.scenario || null;\n42:   if (scenario && arg.observed) {\n43:     const obs = arg.observed;\n44:     scenarioId = scenario.scenarioId;\n45:     tier = scenario.tier || tier || (obs.mode === 'live' ? 'live' : 'playbook');\n46:     routerResult = {\n47:       parseable: obs.parseable !== false,\n48:       intents: obs.observedIntents || [],\n49:       resources: obs.observedResources || [],\n50:       missingResources: obs.missingResources || [],\n51:     };\n52:     expected = {\n53:       skillId: scenario.expectedSkillId || scenario.skillId || arg.skillId,\n54:       // Playbook gold is SURFACE + RESOURCES. Router intent keys are a different\n55:       // vocabulary, so intent-key recall applies only to intent-gold skills\n56:       // (sk-doc's expectedIntent); surface correctness is scored separately.\n57:       intentKeys: scenario.expectedIntent ? [scenario.expectedIntent] : [],\n58:       resources: scenario.expectedResources || [],\n59:       negativeActivation: scenario.negativeActivation === true,\n60:     };\n61:   }\n62:   // Surface correctness is meaningful only when an executor observed a surface\n63:   // (live mode); router mode leaves observedSurface null. Computed up front so a\n64:   // wrong observed surface can fail routing rather than passing on incidental\n65:   // resource overlap.\n66:   const obs = arg.observed || null;\n67:   const expectedSurface = scenario ? scenario.expectedSurface : undefined;\n68:   const observedSurface = obs ? (obs.observedSurface || null) : undefined;\n69:   const surfaceMatch = (expectedSurface && observedSurface)\n70:     ? (observedSurface === expectedSurface) : null;\n71: \n72:   const dims = {};\n73:   const negative = expected && expected.negativeActivation === true;\n74: \n75:   // D1-intra: did the in-skill router select the expected intents + resources?\n76:   const intentRecall = setRecall(expected && expected.intentKeys, routerResult.intents);\n77:   const resourceRecall = setRecall(expected && expected.resources, routerResult.resources);\n78:   if (negative) {\n79:     // For a should-not-activate scenario, routing nothing relevant is success.\n80:     const leakedExpected = (expected.resources || []).some((r) => routerResult.resources.includes(r));\n81:     dims.d1intra = { score: leakedExpected ? 0 : 1, intentRecall, resourceRecall, negative: true };\n82:   } else {\n83:     const ir = intentRecall == null ? 1 : intentRecall;\n84:     const rr = resourceRecall == null ? 1 : resourceRecall;\n85:     dims.d1intra = { score: 0.4 * ir + 0.6 * rr, intentRecall, resourceRecall, negative: false };\n86:   }\n87:   // Live-only: a wrong observed surface is a routing failure regardless of any\n88:   // incidental resource overlap, so cap D1-intra below the pass line.\n89:   if (surfaceMatch === false && !negative) {\n90:     dims.d1intra.surfaceMismatch = true;\n91:     dims.d1intra.score = Math.min(dims.d1intra.score, 0.25);\n92:   }\n93: \n94:   // D2 proxy (Mode A): recall of expected resources in the routed set. In live\n95:   // mode this is replaced by Hit@k/Recall@k/MRR over the observed load trace.\n96:   dims.d2 = {\n97:     score: negative ? (dims.d1intra.score) : (resourceRecall == null ? 1 : resourceRecall),\n98:     proxy: 'router-replay-recall',\n99:     note: 'Mode A proxy; live-mode replaces with observed-load Hit@k/Recall@k/MRR',\n100:   };\n101: \n102:   // D3 efficiency proxy (Mode A): penalize over-routing — resources routed that\n103:   // are not in the expected set are \"wasted loads\". Live mode uses tool-call /\n104:   // token cost to first expected resource.\n105:   const routed = routerResult.resources.length;\n106:   const wasted = expected && expected.resources\n107:     ? routerResult.resources.filter((r) => !expected.resources.includes(r)).length\n108:     : 0;\n109:   // For a negative scenario the \"expected\" resources are the ones that must NOT\n110:   // be routed, so the over-routing math inverts (routing them reads as zero\n111:   // waste). Couple D3 to the suppression outcome instead, mirroring D2.\n112:   dims.d3 = negative\n113:     ? { score: dims.d1intra.score, routedCount: routed, wastedCount: routed, proxy: 'negative-activation', note: 'negative scenario: D3 tracks the suppression outcome, not over-routing' }\n114:     : {\n115:         score: routed === 0 ? 1 : Math.max(0, 1 - wasted / routed),\n116:         routedCount: routed, wastedCount: wasted,\n117:         proxy: 'router-overload', note: 'Mode A proxy; live-mode replaces with calls/tokens-to-first-expected',\n118:       };\n119: \n120:   // D1-inter: scored deterministically when an advisor probe is supplied (the\n121:   // Python advisor reads the SQLite graph, no LLM), else left unscored.\n122:   if (advisorResult) {\n123:     const inter = scoreD1Inter({ advisorResult, expectedSkillId: expected && expected.skillId, negative });\n124:     dims.d1inter = inter.ok\n125:       ? { score: inter.score, rank: inter.rank, topSkill: inter.topSkill }\n126:       : { score: null, unscored: 'advisor probe failed', error: advisorResult.error };\n127:   } else {\n128:     dims.d1inter = { score: null, unscored: 'no advisor probe (run with --advisor-mode=python)' };\n129:   }\n130:   // D4 usefulness ablation: still needs live skill-on/off dispatch (follow-on).\n131:   dims.d4 = { score: null, unscored: 'requires skill-on/off ablation (live mode)' };\n132: \n133:   // First failing stage (funnel): advisor activate -> router parse -> intra -> discovery.\n134:   let firstFailingStage = null;\n135:   if (dims.d1inter.score !== null && dims.d1inter.score < 0.5) firstFailingStage = 'activated-inter';\n136:   else if (!routerResult.parseable) firstFailingStage = 'router-unparseable';\n137:   else if (surfaceMatch === false) firstFailingStage = 'surface-mismatch';\n138:   else if (dims.d1intra.score < 0.5) firstFailingStage = 'routed-intra';\n139:   else if (dims.d2.score < 0.5) firstFailingStage = 'discovered';\n140: \n141:   // Mode A scenario score: weight the measured dims, normalize over their weights.\n142:   // D1-inter joins the measured set only when an advisor probe produced a score.\n143:   const measured = [\n144:     [dims.d1intra.score, WEIGHTS.d1intra],\n145:     [dims.d2.score, WEIGHTS.d2],\n146:     [dims.d3.score, WEIGHTS.d3],\n147:   ];\n148:   if (dims.d1inter.score !== null) measured.push([dims.d1inter.score, WEIGHTS.d1inter]);\n149:   const wsum = measured.reduce((a, [, w]) => a + w, 0);\n150:   const modeAScore = Math.round((measured.reduce((a, [s, w]) => a + s * w, 0) / wsum) * 100);\n151: \n152:   // Trimmed live evidence so a live report is inspectable (what the model\n153:   // actually did) without bloating the JSON with full transcripts.\n154:   const liveEvidence = (obs && obs.raw) ? {\n155:     eventCount: obs.raw.eventCount,\n156:     activated: obs.activation ? obs.activation.activated : undefined,\n157:     toolCalls: (obs.raw.toolCalls || []).map((t) => t.tool),\n158:     observedReads: obs.raw.observedReads,\n159:     statedRoutingParsed: !!(obs.raw.stated && Object.keys(obs.raw.stated).length),\n160:     responseHead: (obs.raw.responseText || '').slice(0, 300),\n161:   } : undefined;\n162: \n163:   return {\n164:     scenarioId, tier, dims, firstFailingStage, modeAScore, applicable: true,\n165:     classKind: scenario ? scenario.classKind : undefined,\n166:     expectedSurface, observedSurface, surfaceMatch,\n167:     traceMode: arg.traceMode || (obs ? obs.mode : undefined),\n168:     liveEvidence,\n169:   };\n170: }\n171: \n172: /**\n173:  * A↔B divergence: the 122-research finding class — the router can reach a\n174:  * resource but the live model doesn't (the skill doesn't signpost it inline),\n175:  * or vice versa. Compared per scenario from a router observation and a live\n176:  * observation of the SAME scenario.\n177:  * @returns {{ scenarioId, resourceDelta:{onlyRouter:string[],onlyLive:string[]}, surfaceAgree:boolean|null, severity:string }}\n178:  */\n179: function computeDivergence({ scenarioId, routerObserved, liveObserved }) {\n180:   const rRefs = new Set((routerObserved && routerObserved.observedResources) || []);\n\n(Showing lines 1-180 of 280. Use offset=181 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * score-skill-benchmark.cjs — compute Lane C dimensions for one scenario and\n * aggregate across a scenario set.\n *\n * Mode A (router-replay, deterministic) scores the dimensions that need no live\n * model: D1-intra (in-skill routing), D2 (unprompted discovery proxy), D3\n * (efficiency proxy), D5 (structural connectivity, hard gate). D1-inter (advisor\n * selection) and D4 (usefulness ablation) require live dispatch / the advisor\n * scorer and are reported as unscored in Mode A rather than faked — the\n * aggregate is normalized over the dimensions actually measured so a Mode A\n * score is honest about its coverage.\n *\n * Converged point weights (for reference / live mode): D1=25 (inter12+intra13),\n * D2=20, D3=15, D4=25, D5=15 (gate).\n */\n\nconst { scoreD1Inter } = require('./advisor-probe.cjs');","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs","time":{"start":1780372681763,"end":1780372681803}},"metadata":{"openai":{"itemId":"fc_011301244ef57a47016a1e54c9b4688191b27cab48a5cdba05"}},"id":"prt_e867b3401001c2FULnfaSHBHTp","sessionID":"ses_17985835dff