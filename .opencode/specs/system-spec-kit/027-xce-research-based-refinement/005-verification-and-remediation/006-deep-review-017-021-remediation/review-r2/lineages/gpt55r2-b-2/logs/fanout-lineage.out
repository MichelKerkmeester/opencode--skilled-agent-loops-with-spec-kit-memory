troller();\n\n  Line 1027:     if (shutdownRequested || retryAbortController.signal.aborted) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/api-validation.vitest.ts:\n  Line 41:       error.name = 'AbortError';\n\n  Line 52:             error.name = 'AbortError';\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts:\n  Line 253:   shouldAbort?: () => boolean;\n\n  Line 261:   const { shouldAbort, waker } = options;\n\n  Line 265:     shouldAbort,\n\n  Line 359:   // AbortController per file path for cancellation of stale reindex\n\n  Line 360:   const activeAbortControllers = new Map<string, AbortController>();\n\n  Line 428:     // Abort any in-flight reindex for this same file before scheduling new one\n\n  Line 430:       const prev = activeAbortControllers.get(filePath);\n\n  Line 439:       const controller = new AbortController();\n\n  Line 440:       activeAbortControllers.set(filePath, controller);\n\n  Line 455:         activeAbortControllers.set(resolvedPath, controller);\n\n  Line 510:           }, { shouldAbort: () => isClosing, waker: retryWaker });\n\n  Line 522:         if (activeAbortControllers.get(filePath) === controller) {\n\n  Line 523:           activeAbortControllers.delete(filePath);\n\n  Line 526:         if (resolvedPath && activeAbortControllers.get(resolvedPath) === controller) {\n\n  Line 527:           activeAbortControllers.delete(resolvedPath);\n\n  Line 554:       }, { shouldAbort: () => isClosing, waker: retryWaker });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hyde.ts:\n  Line 241:   const controller = new AbortController();\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/llm-reformulation.ts:\n  Line 221:   const controller = new AbortController();\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts:\n  Line 23:   readonly shouldAbort?: () => boolean;\n\n  Line 123:       if (options.shouldAbort?.()) {\n\n  Line 136:         if (options.shouldAbort?.()) {\n\n  Line 151:       if (options.shouldAbort?.()) {\n\n  Line 164:         if (options.shouldAbort?.()) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/reconsolidation.ts:\n  Line 76: export type MergeAbortStatus = 'predecessor_changed' | 'predecessor_gone';\n\n  Line 79: export interface MergeAbortedResult {\n\n  Line 81:   status: MergeAbortStatus;\n\n  Line 98: export type ConflictAbortStatus = 'conflict_stale_predecessor' | 'scope_retagged';\n\n  Line 100: export interface ConflictAbortedResult {\n\n  Line 102:   status: ConflictAbortStatus;\n\n  Line 125:   | MergeAbortedResult\n\n  Line 127:   | ConflictAbortedResult\n\n  Line 234: ): Promise<MergeResult | MergeAbortedResult> {\n\n  Line 245:       return buildMergeAbortResult(existingMemory, newMemory, 'predecessor_gone');\n\n  Line 273:     const txResult = db.transaction((): { status: 'merged' } | { status: MergeAbortStatus } => {\n\n  Line 410:       return buildMergeAbortResult(existingMemory, newMemory, txResult.status);\n\n  Line 501: ): ConflictResult | ConflictAbortedResult {\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"function processBatches|export .*processBatches|shouldAbort|Abort","time":{"start":1781761536917,"end":1781761536934}},"metadata":{"openai":{"itemId":"fc_04ac05a5a1995714016a33860077708191a9e405848046b71b"}},"id":"prt_ed94371d4001vLdfxJUw00hVg8","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed94348e00010WFrl45fnr8zP9"}}
