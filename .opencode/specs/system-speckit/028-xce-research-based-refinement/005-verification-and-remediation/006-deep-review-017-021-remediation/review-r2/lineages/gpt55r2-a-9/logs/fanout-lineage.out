') {\n    const effectiveEmbedding: Float32Array | number[] | null =\n      queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n    if (!effectiveEmbedding) {\n      throw new Error('[stage1-candidate-gen] Failed to generate embedding for vector search query');\n    }\n\n    channelCount = 1;\n    let vectorResults = vectorIndex.vectorSearch(effectiveEmbedding, {\n      limit,\n      specFolder,\n      tier,\n      contextType,\n      includeConstitutional: false, // Constitutional managed separately below\n      includeArchived,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"  }\n\n  // -- Channel: Vector ---------------------------------------------------------\n\n  else if (searchType === 'vector') {\n    const effectiveEmbedding: Float32Array | number[] | null =\n      queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n    if (!effectiveEmbedding) {\n      throw new Error('[stage1-candidate-gen] Failed to generate embedding for vector search query');\n    }\n\n    channelCount = 1;\n    let vectorResults = vectorIndex.vectorSearch(effectiveEmbedding, {\n      limit,\n      specFolder,\n      tier,\n      contextType,\n      includeConstitutional: false, // Constitutional managed separately below\n      includeArchived,\n    }) as PipelineRow[];\n    if (isTemporalContiguityEnabled()) {\n      vectorResults = (\n        vectorSearchWithContiguity(\n          vectorResults as Array<PipelineRow & { similarity: number; created_at: string }>,\n          3600,\n        ) as PipelineRow[] | null\n      ) ?? vectorResults;\n    }\n    candidates = vectorResults;\n  }\n\n  // -- Unknown search type -----------------------------------------------------\n\n  else {\n    throw new Error(\n      `[stage1-candidate-gen] Unknown searchType: \"${searchType}\". Expected 'multi-concept', 'hybrid', or 'vector'.`\n    );\n  }\n\n  // -- Tier and contextType filtering -----------------------------------------\n  //\n  // Applied after candidate collection but before constitutional injection so\n  // Injected constitutional rows are evaluated by the same filters.\n  // Exception: for hybrid search, tier/contextType are applied here because\n  // SearchWithFallback does not accept these parameters directly.\n  // For vector search, tier/contextType were already passed to vectorSearch,\n  // So this is a no-op guard for those fields.\n\n  if (tier) {\n    candidates = candidates.filter((r) => r.importance_tier === tier);\n  }\n\n  if (contextType) {\n    candidates = candidates.filter(\n      (r) => resolveRowContextType(r) === contextType\n    );\n  }\n\n  // P0 fix: sessionId is for dedup/state tracking, NOT a governance boundary.\n  // Including it here caused all candidates to be filtered out when memory_context\n  // passed an ephemeral sessionId, because memories don't have session-scoped access.\n  const hasGovernanceScope = Boolean(\n    tenantId\n    || userId\n    || agentId\n  );\n  const shouldApplyScopeFiltering = hasGovernanceScope;\n  const scopeFilter = {\n    tenantId,\n    userId,\n    agentId,\n  };\n\n  if (shouldApplyScopeFiltering) {\n    try {\n      const db = requireDb();\n      void db;\n      candidates = filterRowsByScope(candidates, scopeFilter);\n    } catch (_error: unknown) {","lineStart":1010,"lineEnd":1089,"totalLines":1510,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781764147795,"end":1781764147801}},"metadata":{"openai":{"itemId":"fc_04eb56e93c5a7710016a339033983c81919df21852b272a938"}},"id":"prt_ed96b4a41001grrzOeAzzaEe3X","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b244f001E8JXdWHzhDYB3d"}}
{"type":"tool_use","timestamp":1781764147840,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_OmCyRG4F5OWzTWLSX3aoOohk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","offset":1300,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts</path>\n<type>file</type>\n<content>\n1300:   // + deduplicate by ID.\n1301:   if (isMemorySummariesEnabled()) {\n1302:     try {\n1303:       const db = requireDb();\n1304:       if (checkScaleGate(db)) {\n1305:         const summaryEmbedding: Float32Array | number[] | null =\n1306:           queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n1307: \n1308:         if (summaryEmbedding) {\n1309:           const summaryResults = querySummaryEmbeddings(db, summaryEmbedding, limit);\n1310:           if (summaryResults.length > 0) {\n1311:             const existingIds = new Set(candidates.map((r) => String(r.id)));\n1312:             const newSummaryHits: PipelineRow[] = [];\n1313: \n1314:             // F02-003: Batch-fetch instead of N+1 per-item queries\n1315:             const newSummaryIds = summaryResults\n1316:               .filter((sr) => !existingIds.has(String(sr.memoryId)))\n1317:               .map((sr) => sr.memoryId);\n1318: \n1319:             if (newSummaryIds.length > 0) {\n1320:               const placeholders = newSummaryIds.map(() => '?').join(', ');\n1321:               const memRows = db.prepare(\n1322:                 `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n1323:               ).all(...newSummaryIds) as PipelineRow[];\n1324: \n1325:               const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n1326:               for (const sr of summaryResults) {\n1327:                 if (!existingIds.has(String(sr.memoryId))) {\n1328:                   const memRow = memRowMap.get(sr.memoryId);\n1329:                   if (memRow) {\n1330:                     newSummaryHits.push({\n1331:                       ...memRow,\n1332:                       similarity: sr.similarity * 100,\n1333:                       score: sr.similarity,\n1334:                     });\n1335:                     existingIds.add(String(sr.memoryId));\n1336:                   }\n1337:                 }\n1338:               }\n1339:             }\n1340: \n1341:             const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n1342:             const folderFilteredSummaryHits = applyFolderFilter(archiveFilteredSummaryHits, specFolder);\n1343:             const tierFilteredSummaryHits = applyTierFilter(folderFilteredSummaryHits, tier);\n1344:             const contextFilteredSummaryHits = contextType\n1345:               ? tierFilteredSummaryHits.filter((r) => resolveRowContextType(r) === contextType)\n1346:               : tierFilteredSummaryHits;\n1347:             const scopeFilteredSummaryHits = shouldApplyScopeFiltering\n1348:               ? filterRowsByScope(contextFilteredSummaryHits, scopeFilter)\n1349:               : contextFilteredSummaryHits;\n1350: \n1351:             // Apply the same quality threshold that other candidates go through\n1352:             const backfilledSummaryHits = backfillMissingQualityScores(scopeFilteredSummaryHits);\n1353:             const filteredSummaryHits = filterByMinQualityScore(backfilledSummaryHits, qualityThreshold);\n1354: \n1355:             if (filteredSummaryHits.length > 0) {\n1356:               candidates = [...candidates, ...filteredSummaryHits];\n1357:               channelCount++;\n1358: \n1359:               if (trace) {\n1360:                 addTraceEntry(trace, 'candidate', 1, filteredSummaryHits.length, 0, {\n1361:                   channel: 'r8-summary-embeddings',\n1362:                   summaryHits: filteredSummaryHits.length,\n1363:                   preFilterCount: newSummaryHits.length,\n1364:                 });\n1365:               }\n1366:             }\n1367:           }\n1368:         }\n1369:       }\n1370:     } catch (r8Err: unknown) {\n1371:       const r8Msg = r8Err instanceof Error ? r8Err.message : String(r8Err);\n1372:       console.warn(`[stage1-candidate-gen] R8 summary channel failed: ${r8Msg}`);\n1373:     }\n1374:   }\n1375: \n1376:   // -- Query Surrogate Matching (SPECKIT_QUERY_SURROGATES) ----\n1377:   //\n1378:   // When SPECKIT_QUERY_SURROGATES is enabled, batch-load stored surrogates for\n1379:   // all candidate IDs and run matchSurrogates() against each. Candidates with\n1380:   // a surrogate match above MIN_MATCH_THRESHOLD receive a score boost (additive,\n1381:   // capped at 0.15) to improve ranking for vocabulary-mismatched queries.\n1382:   //\n1383:   // This is a lightweight post-candidate boost — no new candidates are added,\n1384:   // only existing ones are re-scored. No LLM calls on this path.\n1385:   //\n1386:   // Fail-open: any error leaves candidates unchanged.\n1387: \n1388:   if (isQuerySurrogatesEnabled() && candidates.length > 0) {\n1389:     try {\n\n(Showing lines 1300-1389 of 1510. Use offset=1390 to continue.)\n</content>","metadata":{"preview":"  // + deduplicate by ID.\n  if (isMemorySummariesEnabled()) {\n    try {\n      const db = requireDb();\n      if (checkScaleGate(db)) {\n        const summaryEmbedding: Float32Array | number[] | null =\n          queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n        if (summaryEmbedding) {\n          const summaryResults = querySummaryEmbeddings(db, summaryEmbedding, limit);\n          if (summaryResults.length > 0) {\n            const existingIds = new Set(candidates.map((r) => String(r.id)));\n            const newSummaryHits: PipelineRow[] = [];\n\n            // F02-003: Batch-fetch instead of N+1 per-item queries\n            const newSummaryIds = summaryResults\n              .filter((sr) => !existingIds.has(String(sr.memoryId)))\n              .map((sr) => sr.memoryId);\n\n            if (newSummaryIds.length > 0) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"  // + deduplicate by ID.\n  if (isMemorySummariesEnabled()) {\n    try {\n      const db = requireDb();\n      if (checkScaleGate(db)) {\n        const summaryEmbedding: Float32Array | number[] | null =\n          queryEmbedding ?? (await vectorIndex.generateQueryEmbedding(query));\n\n        if (summaryEmbedding) {\n          const summaryResults = querySummaryEmbeddings(db, summaryEmbedding, limit);\n          if (summaryResults.length > 0) {\n            const existingIds = new Set(candidates.map((r) => String(r.id)));\n            const newSummaryHits: PipelineRow[] = [];\n\n            // F02-003: Batch-fetch instead of N+1 per-item queries\n            const newSummaryIds = summaryResults\n              .filter((sr) => !existingIds.has(String(sr.memoryId)))\n              .map((sr) => sr.memoryId);\n\n            if (newSummaryIds.length > 0) {\n              const placeholders = newSummaryIds.map(() => '?').join(', ');\n              const memRows = db.prepare(\n                `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n              ).all(...newSummaryIds) as PipelineRow[];\n\n              const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n              for (const sr of summaryResults) {\n                if (!existingIds.has(String(sr.memoryId))) {\n                  const memRow = memRowMap.get(sr.memoryId);\n                  if (memRow) {\n                    newSummaryHits.push({\n                      ...memRow,\n                      similarity: sr.similarity * 100,\n                      score: sr.similarity,\n                    });\n                    existingIds.add(String(sr.memoryId));\n                  }\n                }\n              }\n            }\n\n            const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n            const folderFilteredSummaryHits = applyFolderFilter(archiveFilteredSummaryHits, specFolder);\n            const tierFilteredSummaryHits = applyTierFilter(folderFilteredSummaryHits, tier);\n            const contextFilteredSummaryHits = contextType\n              ? tierFilteredSummaryHits.filter((r) => resolveRowContextType(r) === contextType)\n              : tierFilteredSummaryHits;\n            const scopeFilteredSummaryHits = shouldApplyScopeFiltering\n              ? filterRowsByScope(contextFilteredSummaryHits, scopeFilter)\n              : contextFilteredSummaryHits;\n\n            // Apply the same quality threshold that other candidates go through\n            const backfilledSummaryHits = backfillMissingQualityScores(scopeFilteredSummaryHits);\n            const filteredSummaryHits = filterByMinQualityScore(backfilledSummaryHits, qualityThreshold);\n\n            if (filteredSummaryHits.length > 0) {\n              candidates = [...candidates, ...filteredSummaryHits];\n              channelCount++;\n\n              if (trace) {\n                addTraceEntry(trace, 'candidate', 1, filteredSummaryHits.length, 0, {\n                  channel: 'r8-summary-embeddings',\n                  summaryHits: filteredSummaryHits.length,\n                  preFilterCount: newSummaryHits.length,\n                });\n              }\n            }\n          }\n        }\n      }\n    } catch (r8Err: unknown) {\n      const r8Msg = r8Err instanceof Error ? r8Err.message : String(r8Err);\n      console.warn(`[stage1-candidate-gen] R8 summary channel failed: ${r8Msg}`);\n    }\n  }\n\n  // -- Query Surrogate Matching (SPECKIT_QUERY_SURROGATES) ----\n  //\n  // When SPECKIT_QUERY_SURROGATES is enabled, batch-load stored surrogates for\n  // all candidate IDs and run matchSurrogates() against each. Candidates with\n  // a surrogate match above MIN_MATCH_THRESHOLD receive a score boost (additive,\n  // capped at 0.15) to improve ranking for vocabulary-mismatched queries.\n  //\n  // This is a lightweight post-candidate boost — no new candidates are added,\n  // only existing ones are re-scored. No LLM calls on this path.\n  //\n  // Fail-open: any error leaves candidates unchanged.\n\n  if (isQuerySurrogatesEnabled() && candidates.length > 0) {\n    try {","lineStart":1300,"lineEnd":1389,"totalLines":1510,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781764147833,"end":1781764147838}},"metadata":{"openai":{"itemId":"fc_04eb56e93c5a7710016a33903398448191976c95588f15ae38"}},"id":"prt_ed96b4a57001zKGMRDoKVjKmcs","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b244f001E8JXdWHzhDYB3d"}}
{"type":"tool_use","timestamp":1781764147855,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_TloLAOBuT7GteHDtiuF4yuvh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage4 Filter\n3: // ───────────────────────────────────────────────────────────────\n4: // Final stage of the 4-stage retrieval pipeline.\n5: //\n6: // ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n7: // Any ordering change after Stage 3 is a bug. Score fields on\n8: // Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n9: // Via captureScoreSnapshot / verifyScoreInvariant provides a second\n10: // Defence-in-depth layer.\n11: //\n12: // I/O CONTRACT:\n13: // Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n14: // Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n15: // Key invariants:\n16: //     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n17: // AttentionScore, importance_weight) may change between input and output\n18: //     - Ordering from Stage 3 is preserved for all surviving rows\n19: //     - final contains only rows at or above config.minState priority\n20: // Side effects:\n21: //     - None — this stage is read-only with respect to the database\n22: //\n23: // FILTER APPLICATION ORDER (within filterByMemoryState):\n24: // 1. memoryState priority filter — rows below minState are removed\n25: // 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n26: //\n27: // Responsibilities (in execution order):\n28: // 1. Capture score snapshot BEFORE any operations (runtime invariant)\n29: // 2. Apply memory-state filtering (filterByMemoryState)\n30: // 3. Apply evidence gap detection via TRM (Z-score confidence check)\n31: // 4. Add annotation metadata (feature flags, state stats, etc.)\n32: // 5. Verify score invariant AFTER all operations\n33: //\n34: // NOT in Stage 4: session dedup — that happens after cache in the\n35: // Main handler to avoid double-counting and cache pollution.\n36: \n37: import type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\n38: import { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\n39: import { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\n40: import { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\n41: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n42: \n43: // Feature catalog: 4-stage pipeline architecture\n44: // Feature catalog: Confidence-based result truncation\n45: \n46: \n47: // ───────────────────────────────────────────────────────────────\n48: // 2. CONSTANTS\n49: \n50: \n51: // ───────────────────────────────────────────────────────────────\n52: /**\n53:  * Memory state priority map. Higher number = higher priority.\n54:  * Used to compare states numerically so filtering is O(1) per row.\n55:  */\n56: const STATE_PRIORITY: Record<string, number> = {\n57:   HOT: 5,\n58:   WARM: 4,\n59:   COLD: 3,\n60:   DORMANT: 2,\n61:   ARCHIVED: 1,\n62: };\n63: \n64: /**\n65:  * Per-tier hard limits applied when `applyStateLimits` is true.\n66:  * Prevents any single tier from monopolising the result window.\n67:  */\n68: export const STATE_LIMITS: Record<string, number> = {\n69:   HOT: 50,\n70:   WARM: 30,\n71:   COLD: 20,\n72:   DORMANT: 10,\n73:   ARCHIVED: 5,\n74: };\n75: \n76: /** Fallback priority for unknown/missing memoryState values.\n77:  * Set above HOT (5) so UNKNOWN memories always pass state filters.\n78:  * memoryState column doesn't exist yet — all memories are UNKNOWN.\n79:  * Reset to 0 when the TRM state column is implemented. */\n80: const UNKNOWN_STATE_PRIORITY = 6;\n81: \n82: function normalizeStateValue(state: unknown): string | null {\n83:   if (typeof state !== 'string') {\n84:     return null;\n85:   }\n86:   const normalizedState = state.toUpperCase();\n87:   return normalizedState in STATE_PRIORITY ? normalizedState : null;\n88: }\n89: \n90: function resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n91:   const explicitState = normalizeStateValue(row.memoryState);\n92:   if (explicitState) {\n93:     return explicitState;\n94:   }\n95: \n96:   return 'UNKNOWN';\n97: }\n98: \n99: // ───────────────────────────────────────────────────────────────\n100: // 3. TYPES\n101: \n102: \n103: // ───────────────────────────────────────────────────────────────\n104: /**\n105:  * Per-state tally produced by `filterByMemoryState`.\n106:  * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n107:  */\n108: export type StateStats = Record<string, number>;\n109: \n110: /**\n111:  * Return value of the internal `filterByMemoryState` function.\n112:  */\n113: export interface FilterResult {\n114:   /** Rows that survived state filtering, in original order. */\n115:   filtered: Stage4ReadonlyRow[];\n116:   /** Pre-filter per-state counts (includes removed rows). */\n117:   statsBefore: StateStats;\n118:   /** Post-filter per-state counts. */\n119:   statsAfter: StateStats;\n120:   /** Total number of rows removed. */\n121:   removedCount: number;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    3. INTERNAL: filterByMemoryState\n126:    ──────────────────────────────────────────────────────────────── */\n127: \n128: /**\n129:  * Remove rows whose `memoryState` falls below `minState` priority and,\n130:  * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n131:  *\n132:  * IMPORTANT: This function ONLY removes items — it never reorders or\n133:  * modifies score fields. The original ordering from Stage 3 is preserved\n134:  * for all rows that survive.\n135:  *\n136:  * @param results        - Read-only rows from Stage 3 output.\n137:  * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n138:  * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n139:  * @returns FilterResult with the surviving rows and before/after stats.\n140:  */\n141: export function filterByMemoryState(\n142:   results: Stage4ReadonlyRow[],\n143:   minState: string,\n144:   applyStateLimits: boolean,\n145: ): FilterResult {\n146:   const normalizedMinState = normalizeStateValue(minState);\n147:   const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n148: \n149:   // -- 3a. Tally states before filtering --\n150:   const statsBefore: StateStats = {};\n151:   for (const row of results) {\n152:     const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n153:     statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n154:   }\n155: \n156:   // -- 3b. State-priority filter --\n157:   let passing = results.filter(row => {\n158:     const state = resolveStateForFiltering(row);\n159:     const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n160:     return priority >= minPriority;\n161:   });\n162: \n163:   // -- 3c. Per-tier limits (optional) --\n164:   if (applyStateLimits) {\n165:     const tierCounters: Record<string, number> = {};\n166:     const limitPassing: Stage4ReadonlyRow[] = [];\n167: \n168:     for (const row of passing) {\n169:       const state = resolveStateForFiltering(row);\n170:       const limit = STATE_LIMITS[state] ?? Infinity;\n171:       const count = tierCounters[state] ?? 0;\n172: \n173:       if (count < limit) {\n174:         tierCounters[state] = count + 1;\n175:         limitPassing.push(row);\n176:       }\n177:       // Rows exceeding the per-tier limit are silently dropped (no score change).\n178:     }\n179: \n180:     passing = limitPassing;\n181:   }\n182: \n183:   // -- 3d. Tally states after filtering --\n184:   const statsAfter: StateStats = {};\n185:   for (const row of passing) {\n186:     const state = resolveStateForFiltering(row);\n187:     statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n188:   }\n189: \n190:   return {\n191:     filtered: passing,\n192:     statsBefore,\n193:     statsAfter,\n194:     removedCount: results.length - passing.length,\n195:   };\n196: }\n197: \n198: /* ───────────────────────────────────────────────────────────────\n199:    4. INTERNAL: extractScoringValues\n200:    ──────────────────────────────────────────────────────────────── */\n201: \n202: /**\n203:  * Extract the best available numeric score from a row for evidence-gap\n204:  * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n205:  * so scoring, sorting, and filtering all agree on precedence and normalization.\n206:  *\n207:  * A1 FIX: Previously used a different precedence order (rrfScore first) and\n208:  * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n209:  * that only had the similarity field set.\n210:  *\n211:  * @param row - A Stage4ReadonlyRow to inspect.\n212:  * @returns The best available numeric score clamped to [0,1], or 0.\n213:  */\n214: export function extractScoringValue(row: Stage4ReadonlyRow): number {\n215:   return resolveEffectiveScore(row as unknown as PipelineRow);\n216: }\n217: \n218: /* ───────────────────────────────────────────────────────────────\n219:    5. MAIN: executeStage4\n220:    ──────────────────────────────────────────────────────────────── */\n\n(Showing lines 1-220 of 370. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:\n//     - None — this stage is read-only with respect to the database\n//\n// FILTER APPLICATION ORDER (within filterByMemoryState):\n// 1. memoryState priority filter — rows below minState are removed\n// 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n//\n// Responsibilities (in execution order):\n// 1. Capture score snapshot BEFORE any operations (runtime invariant)\n// 2. Apply memory-state filtering (filterByMemoryState)\n// 3. Apply evidence gap detection via TRM (Z-score confidence check)\n// 4. Add annotation metadata (feature flags, state stats, etc.)\n// 5. Verify score invariant AFTER all operations\n//\n// NOT in Stage 4: session dedup — that happens after cache in the\n// Main handler to avoid double-counting and cache pollution.\n\nimport type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\nimport { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\nimport { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\nimport { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Confidence-based result truncation\n\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Memory state priority map. Higher number = higher priority.\n * Used to compare states numerically so filtering is O(1) per row.\n */\nconst STATE_PRIORITY: Record<string, number> = {\n  HOT: 5,\n  WARM: 4,\n  COLD: 3,\n  DORMANT: 2,\n  ARCHIVED: 1,\n};\n\n/**\n * Per-tier hard limits applied when `applyStateLimits` is true.\n * Prevents any single tier from monopolising the result window.\n */\nexport const STATE_LIMITS: Record<string, number> = {\n  HOT: 50,\n  WARM: 30,\n  COLD: 20,\n  DORMANT: 10,\n  ARCHIVED: 5,\n};\n\n/** Fallback priority for unknown/missing memoryState values.\n * Set above HOT (5) so UNKNOWN memories always pass state filters.\n * memoryState column doesn't exist yet — all memories are UNKNOWN.\n * Reset to 0 when the TRM state column is implemented. */\nconst UNKNOWN_STATE_PRIORITY = 6;\n\nfunction normalizeStateValue(state: unknown): string | null {\n  if (typeof state !== 'string') {\n    return null;\n  }\n  const normalizedState = state.toUpperCase();\n  return normalizedState in STATE_PRIORITY ? normalizedState : null;\n}\n\nfunction resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n  const explicitState = normalizeStateValue(row.memoryState);\n  if (explicitState) {\n    return explicitState;\n  }\n\n  return 'UNKNOWN';\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. TYPES\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Per-state tally produced by `filterByMemoryState`.\n * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n */\nexport type StateStats = Record<string, number>;\n\n/**\n * Return value of the internal `filterByMemoryState` function.\n */\nexport interface FilterResult {\n  /** Rows that survived state filtering, in original order. */\n  filtered: Stage4ReadonlyRow[];\n  /** Pre-filter per-state counts (includes removed rows). */\n  statsBefore: StateStats;\n  /** Post-filter per-state counts. */\n  statsAfter: StateStats;\n  /** Total number of rows removed. */\n  removedCount: number;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. INTERNAL: filterByMemoryState\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Remove rows whose `memoryState` falls below `minState` priority and,\n * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n *\n * IMPORTANT: This function ONLY removes items — it never reorders or\n * modifies score fields. The original ordering from Stage 3 is preserved\n * for all rows that survive.\n *\n * @param results        - Read-only rows from Stage 3 output.\n * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n * @returns FilterResult with the surviving rows and before/after stats.\n */\nexport function filterByMemoryState(\n  results: Stage4ReadonlyRow[],\n  minState: string,\n  applyStateLimits: boolean,\n): FilterResult {\n  const normalizedMinState = normalizeStateValue(minState);\n  const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n\n  // -- 3a. Tally states before filtering --\n  const statsBefore: StateStats = {};\n  for (const row of results) {\n    const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n    statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n  }\n\n  // -- 3b. State-priority filter --\n  let passing = results.filter(row => {\n    const state = resolveStateForFiltering(row);\n    const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n    return priority >= minPriority;\n  });\n\n  // -- 3c. Per-tier limits (optional) --\n  if (applyStateLimits) {\n    const tierCounters: Record<string, number> = {};\n    const limitPassing: Stage4ReadonlyRow[] = [];\n\n    for (const row of passing) {\n      const state = resolveStateForFiltering(row);\n      const limit = STATE_LIMITS[state] ?? Infinity;\n      const count = tierCounters[state] ?? 0;\n\n      if (count < limit) {\n        tierCounters[state] = count + 1;\n        limitPassing.push(row);\n      }\n      // Rows exceeding the per-tier limit are silently dropped (no score change).\n    }\n\n    passing = limitPassing;\n  }\n\n  // -- 3d. Tally states after filtering --\n  const statsAfter: StateStats = {};\n  for (const row of passing) {\n    const state = resolveStateForFiltering(row);\n    statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n  }\n\n  return {\n    filtered: passing,\n    statsBefore,\n    statsAfter,\n    removedCount: results.length - passing.length,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INTERNAL: extractScoringValues\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Extract the best available numeric score from a row for evidence-gap\n * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n * so scoring, sorting, and filtering all agree on precedence and normalization.\n *\n * A1 FIX: Previously used a different precedence order (rrfScore first) and\n * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n * that only had the similarity field set.\n *\n * @param row - A Stage4ReadonlyRow to inspect.\n * @returns The best available numeric score clamped to [0,1], or 0.\n */\nexport function extractScoringValue(row: Stage4ReadonlyRow): number {\n  return resolveEffectiveScore(row as unknown as PipelineRow);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. MAIN: executeStage4\n   ──────────────────────────────────────────────────────────────── */","lineStart":1,"lineEnd":220,"totalLines":370,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","time":{"start":1781764147851,"end":1781764147854}},"metadata":{"openai":{"itemId":"fc_04eb56e93c5a7710016a339033984c8191b8e64534671873a6"}},"id":"prt_ed96b4a7f001j6oVSVWnLBN6FJ","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b244f001E8JXdWHzhDYB3d"}}
