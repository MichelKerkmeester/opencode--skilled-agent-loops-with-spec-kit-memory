{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["scripts/**/*", "tests/**/*"],
  "ts-node": {
    "files": true
  },
  "exclude": ["node_modules", "dist", "output"]
}
