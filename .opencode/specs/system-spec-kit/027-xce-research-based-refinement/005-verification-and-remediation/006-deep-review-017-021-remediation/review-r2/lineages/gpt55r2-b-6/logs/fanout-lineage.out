n  Line 193:     vi.mocked(causalEdgesMod.deleteEdgesForMemory).mockImplementation((id: string) => {\n\n  Line 261:     vi.mocked(causalEdgesMod.deleteEdgesForMemory).mockImplementation((id: string) => { calls.causalDeleteEdges.push(id); });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edges-unit.vitest.ts:\n  Line 17: // DeleteEdge, deleteEdgesForMemory, getGraphStats,\n\n  Line 626:      deleteEdgesForMemory\n\n  Line 629:   describe('deleteEdgesForMemory', () => {\n\n  Line 630:     it('DM1: deleteEdgesForMemory removes 3 edges', () => {\n\n  Line 638:       const count = causalEdges.deleteEdgesForMemory('2');\n\n  Line 649:       causalEdges.deleteEdgesForMemory('2');\n\n  Line 657:       const count = causalEdges.deleteEdgesForMemory('999');\n\n  Line 680:     it('DC2: deleteEdgesForMemory invalidates cached degree scores', () => {\n\n  Line 684:       const deleted = causalEdges.deleteEdgesForMemory('1');\n\n  Line 725:     it('R-007-12-G4: deleteEdgesForMemory bumps the generation counter', () => {\n\n  Line 729:       causalEdges.deleteEdgesForMemory('1');\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edges.vitest.ts:\n  Line 545:       const removed = causalEdges.deleteEdgesForMemory('2');\n\n  Line 1032:     it('T010-U3: deleteEdgesForMemory removes all edges for a memory', () => {\n\n  Line 1038:       const removed = causalEdges.deleteEdgesForMemory('5');\n\n  Line 1053:       const removed = causalEdges.deleteEdgesForMemory('5');\n","metadata":{"matches":26,"truncated":false},"title":"deleteEdgesForMemory|deleteEdgesForMemory\\(","time":{"start":1781762982775,"end":1781762982803}},"metadata":{"openai":{"itemId":"fc_0b9204e7477dd1d3016a338ba699748191a5fdf8641d78deac"}},"id":"prt_ed9598374001zvhr6tQ7WDR2SM","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed9591151001lJAi7DeKudRYN