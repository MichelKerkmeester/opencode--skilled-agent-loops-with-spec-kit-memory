rStoreContract('FakeVectorStore contract', () => ({\n425:   port: new FakeVectorStore<VectorFixtureMetadata>(),\n426:   cleanup: () => {},\n427: }));\n428: \n429: runMaintenanceContract('BetterSqliteMaintenance contract', createBetterSqliteMaintenanceSubject);\n430: \n431: runMaintenanceContract('FakeMaintenance contract', () => ({\n432:   port: new FakeMaintenance({ ok: true, message: 'healthy' }),\n433:   cleanup: () => {},\n434: }));\n435: \n436: runContentionPolicyContract('BetterSqliteContentionPolicy contract', createBetterSqliteContentionSubject);\n437: \n438: runContentionPolicyContract('FakeContentionPolicy contract', () => ({\n439:   port: new FakeContentionPolicy(),\n440:   cleanup: () => {},\n441: }));\n442: \n443: describe('BetterSqliteContentionPolicy', () => {\n444:   it('applies better-sqlite busy_timeout pragmas through the port', () => {\n445:     const subject = createBetterSqliteContentionSubject();\n446:     try {\n447:       subject.port.setBusyTimeout(subject.database, 1234);\n448: \n449:       expect(subject.database.pragma('busy_timeout', { simple: true })).toBe(1234);\n450:     } finally {\n451:       subject.cleanup();\n452:     }\n453:   });\n454: });\n455: \n456: describe('storage port fakes', () => {\n457:   it('FakeVectorStore stores vectors and returns cosine-ranked matches', () => {\n458:     const store = new FakeVectorStore<{ readonly type: string }>();\n459:     store.upsert({ id: 'left', embedding: [1, 0], metadata: { type: 'axis' } });\n460:     store.upsert({ id: 'right', embedding: [0, 1], metadata: { type: 'axis' } });\n461: \n462:     const results = store.search([1, 0], { limit: 2, minScore: 0 });\n463: \n464:     expect(results.map((result) => result.id)).toEqual(['left', 'right']);\n465:     expect(store.get('left')?.metadata.type).toBe('axis');\n466:     expect(store.delete('left')).toBe(true);\n467:     expect(store.get('left')).toBeNull();\n468:   });\n469: \n470:   it('FakeMaintenance records calls and returns configured results', () => {\n471:     const maintenance = new FakeMaintenance({ ok: true, message: 'healthy' });\n472: \n473:     expect(maintenance.integrityCheck()).toEqual({ ok: true, message: 'healthy' });\n474:     expect(maintenance.vacuum()).toEqual({ ok: true, message: 'healthy' });\n475:     expect(maintenance.checkpoint({ mode: 'truncate' })).toEqual({ ok: true, message: 'healthy' });\n476:     expect(maintenance.calls).toEqual(['integrityCheck', 'vacuum', 'checkpoint:truncate']);\n477:   });\n478: \n479:   it('FakeContentionPolicy retries transient failures', async () => {\n480:     const policy = new FakeContentionPolicy();\n481:     let attempts = 0;\n482: \n483:     const result = await policy.withRetry(() => {\n484:       attempts += 1;\n485:       if (attempts === 1) {\n486:         const error = new Error('SQLITE_BUSY: database is locked');\n487:         (error as unknown as { code: string }).code = 'SQLITE_BUSY';\n488:         throw error;\n489:       }\n490:       return 'ok';\n491:     }, { attempts: 2 });\n492: \n493:     expect(result).toBe('ok');\n494:     expect(attempts).toBe(2);\n495:     await expect(policy.withWriteLock(() => 'locked')).resolves.toBe('locked');\n496:     const database = new Database(':memory:');\n497:     policy.setBusyTimeout(database, 250);\n498:     database.close();\n499:     expect(policy.busyTimeouts).toEqual([250]);\n\n(Showing lines 380-499 of 501. Use offset=500 to continue.)\n</content>","metadata":{"preview":"        expect(attempts).toBe(2);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('runs exclusive write sections through the port', async () => {\n      const subject = createSubject();\n      try {\n        const result = await subject.port.withWriteLock(() => 'locked', { sync: true });\n\n        expect(result).toBe('locked');\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nrunGraphTraversalContract('BetterSqliteGraphTraversal contract', () => {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","text":"        expect(attempts).toBe(2);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('runs exclusive write sections through the port', async () => {\n      const subject = createSubject();\n      try {\n        const result = await subject.port.withWriteLock(() => 'locked', { sync: true });\n\n        expect(result).toBe('locked');\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nrunGraphTraversalContract('BetterSqliteGraphTraversal contract', () => {\n  const database = createGraphFixtureDb();\n  return {\n    port: new BetterSqliteGraphTraversal(database),\n    cleanup: () => database.close(),\n  };\n});\n\nrunGraphTraversalContract('FakeGraphTraversal contract', () => ({\n  port: createFakeGraphTraversal(),\n  cleanup: () => {},\n}));\n\nrunLexicalSearchContract('PackedBm25LexicalSearch contract', () => ({\n  port: new PackedBm25LexicalSearch(),\n  cleanup: () => {},\n}));\n\nrunLexicalSearchContract('FakeLexicalSearch contract', () => ({\n  port: new FakeLexicalSearch(),\n  cleanup: () => {},\n}));\n\nrunVectorStoreContract('BetterSqliteVectorStore contract', createBetterSqliteVectorSubject);\n\nrunVectorStoreContract('FakeVectorStore contract', () => ({\n  port: new FakeVectorStore<VectorFixtureMetadata>(),\n  cleanup: () => {},\n}));\n\nrunMaintenanceContract('BetterSqliteMaintenance contract', createBetterSqliteMaintenanceSubject);\n\nrunMaintenanceContract('FakeMaintenance contract', () => ({\n  port: new FakeMaintenance({ ok: true, message: 'healthy' }),\n  cleanup: () => {},\n}));\n\nrunContentionPolicyContract('BetterSqliteContentionPolicy contract', createBetterSqliteContentionSubject);\n\nrunContentionPolicyContract('FakeContentionPolicy contract', () => ({\n  port: new FakeContentionPolicy(),\n  cleanup: () => {},\n}));\n\ndescribe('BetterSqliteContentionPolicy', () => {\n  it('applies better-sqlite busy_timeout pragmas through the port', () => {\n    const subject = createBetterSqliteContentionSubject();\n    try {\n      subject.port.setBusyTimeout(subject.database, 1234);\n\n      expect(subject.database.pragma('busy_timeout', { simple: true })).toBe(1234);\n    } finally {\n      subject.cleanup();\n    }\n  });\n});\n\ndescribe('storage port fakes', () => {\n  it('FakeVectorStore stores vectors and returns cosine-ranked matches', () => {\n    const store = new FakeVectorStore<{ readonly type: string }>();\n    store.upsert({ id: 'left', embedding: [1, 0], metadata: { type: 'axis' } });\n    store.upsert({ id: 'right', embedding: [0, 1], metadata: { type: 'axis' } });\n\n    const results = store.search([1, 0], { limit: 2, minScore: 0 });\n\n    expect(results.map((result) => result.id)).toEqual(['left', 'right']);\n    expect(store.get('left')?.metadata.type).toBe('axis');\n    expect(store.delete('left')).toBe(true);\n    expect(store.get('left')).toBeNull();\n  });\n\n  it('FakeMaintenance records calls and returns configured results', () => {\n    const maintenance = new FakeMaintenance({ ok: true, message: 'healthy' });\n\n    expect(maintenance.integrityCheck()).toEqual({ ok: true, message: 'healthy' });\n    expect(maintenance.vacuum()).toEqual({ ok: true, message: 'healthy' });\n    expect(maintenance.checkpoint({ mode: 'truncate' })).toEqual({ ok: true, message: 'healthy' });\n    expect(maintenance.calls).toEqual(['integrityCheck', 'vacuum', 'checkpoint:truncate']);\n  });\n\n  it('FakeContentionPolicy retries transient failures', async () => {\n    const policy = new FakeContentionPolicy();\n    let attempts = 0;\n\n    const result = await policy.withRetry(() => {\n      attempts += 1;\n      if (attempts === 1) {\n        const error = new Error('SQLITE_BUSY: database is locked');\n        (error as unknown as { code: string }).code = 'SQLITE_BUSY';\n        throw error;\n      }\n      return 'ok';\n    }, { attempts: 2 });\n\n    expect(result).toBe('ok');\n    expect(attempts).toBe(2);\n    await expect(policy.withWriteLock(() => 'locked')).resolves.toBe('locked');\n    const database = new Database(':memory:');\n    policy.setBusyTimeout(database, 250);\n    database.close();\n    expect(policy.busyTimeouts).toEqual([250]);","lineStart":380,"lineEnd":499,"totalLines":501,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","time":{"start":1781144227693,"end":1781144227701}},"metadata":{"openai":{"itemId":"fc_022c56d7e4100d5b016a2a1aa3945c8191b81f13974ca4694d"}},"id":"prt_eb4780f6c001nKE6Zou7bZCK17","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477ca4f0011f6vPLD3wWOlxe"}}
{"type":"tool_use","timestamp":1781144227704,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_ZTSD56J2p72wMUGAauIKMocS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":100,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n100:   entries: TierDowngradeAuditParams[],\n101: ): void {\n102:   for (const entry of entries) {\n103:     try {\n104:       recordTierDowngradeAudit(database, entry);\n105:     } catch (error: unknown) {\n106:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n107:     }\n108:   }\n109: }\n110: \n111: /* ───────────────────────────────────────────────────────────────\n112:    1. CONSTANTS\n113: ----------------------------------------------------------------*/\n114: \n115: const MAX_CHECKPOINTS = 10;\n116: const CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\n117: const CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\n118: const CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\n119: const RESTORE_JOURNAL_NAME = '.restore-journal.json';\n120: const NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n121: const checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n122: \n123: const CHECKPOINT_MANIFEST = Object.freeze({\n124:   snapshot: [\n125:     'memory_index',\n126:     'vec_memories',\n127:     'vec_metadata',\n128:     'working_memory',\n129:     'causal_edges',\n130:     'weight_history',\n131:     'memory_history',\n132:     'mutation_ledger',\n133:     'memory_conflicts',\n134:     'memory_corrections',\n135:     'adaptive_signal_events',\n136:     'negative_feedback_events',\n137:     'learned_feedback_audit',\n138:     'session_learning',\n139:     'governance_audit',\n140:     'session_state',\n141:     'session_sent_memories',\n142:     'memory_summaries',\n143:   ],\n144:   rebuild: [\n145:     'memory_lineage',\n146:     'active_memory_projection',\n147:     'memory_entities',\n148:     'entity_catalog',\n149:     'degree_snapshots',\n150:     'community_assignments',\n151:     'graph_communities',\n152:     'community_summaries',\n153:     'memory_fts',\n154:   ],\n155:   skip: [\n156:     'checkpoints',\n157:     'schema_version',\n158:     'embedding_cache',\n159:     'adaptive_shadow_runs',\n160:   ],\n161: });\n162: \n163: const CHECKPOINT_RESTORE_ORDER = [\n164:   'memory_index',\n165:   'vec_memories',\n166:   'vec_metadata',\n167:   'working_memory',\n168:   'causal_edges',\n169:   'weight_history',\n170:   'memory_history',\n171:   'mutation_ledger',\n172:   'memory_conflicts',\n173:   'memory_corrections',\n174:   'adaptive_signal_events',\n175:   'negative_feedback_events',\n176:   'learned_feedback_audit',\n177:   'session_learning',\n178:   'governance_audit',\n179:   'session_state',\n180:   'session_sent_memories',\n181:   'memory_summaries',\n182: ] as const;\n183: \n184: const CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n185: \n186: const MUTATION_LEDGER_TRIGGER_SQL = `\n187:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n188:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n189:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n190:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n191: `;\n192: \n193: /* ───────────────────────────────────────────────────────────────\n194:    2. INTERFACES\n195: ----------------------------------------------------------------*/\n196: \n197: interface CheckpointEntry {\n198:   id: number;\n199:   name: string;\n200:   created_at: string;\n201:   spec_folder: string | null;\n202:   git_branch: string | null;\n203:   memory_snapshot: Buffer | null;\n204:   file_snapshot: Buffer | null;\n205:   snapshot_format?: string | null;\n206:   snapshot_path?: string | null;\n207:   metadata: string | null;\n208: }\n209: \n210: interface CheckpointInfo {\n211:   id: number;\n212:   name: string;\n213:   createdAt: string;\n214:   specFolder: string | null;\n215:   gitBranch: string | null;\n216:   snapshotSize: number;\n217:   metadata: Record<string, unknown>;\n218:   [key: string]: unknown;\n219: }\n220: \n221: interface CreateCheckpointOptions {\n222:   name?: string;\n223:   specFolder?: string | null;\n224:   includeEmbeddings?: boolean;\n225:   metadata?: Record<string, unknown>;\n226:   scope?: ScopeContext;\n227: }\n228: \n229: type CheckpointCreateErrorCode =\n\n(Showing lines 100-229 of 3319. Use offset=230 to continue.)\n</content>","metadata":{"preview":"  entries: TierDowngradeAuditParams[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordTierDowngradeAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MAX_CHECKPOINTS = 10;\nconst CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\nconst CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\nconst CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"  entries: TierDowngradeAuditParams[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordTierDowngradeAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MAX_CHECKPOINTS = 10;\nconst CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\nconst CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\nconst CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';\nconst NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\nconst checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n\nconst CHECKPOINT_MANIFEST = Object.freeze({\n  snapshot: [\n    'memory_index',\n    'vec_memories',\n    'vec_metadata',\n    'working_memory',\n    'causal_edges',\n    'weight_history',\n    'memory_history',\n    'mutation_ledger',\n    'memory_conflicts',\n    'memory_corrections',\n    'adaptive_signal_events',\n    'negative_feedback_events',\n    'learned_feedback_audit',\n    'session_learning',\n    'governance_audit',\n    'session_state',\n    'session_sent_memories',\n    'memory_summaries',\n  ],\n  rebuild: [\n    'memory_lineage',\n    'active_memory_projection',\n    'memory_entities',\n    'entity_catalog',\n    'degree_snapshots',\n    'community_assignments',\n    'graph_communities',\n    'community_summaries',\n    'memory_fts',\n  ],\n  skip: [\n    'checkpoints',\n    'schema_version',\n    'embedding_cache',\n    'adaptive_shadow_runs',\n  ],\n});\n\nconst CHECKPOINT_RESTORE_ORDER = [\n  'memory_index',\n  'vec_memories',\n  'vec_metadata',\n  'working_memory',\n  'causal_edges',\n  'weight_history',\n  'memory_history',\n  'mutation_ledger',\n  'memory_conflicts',\n  'memory_corrections',\n  'adaptive_signal_events',\n  'negative_feedback_events',\n  'learned_feedback_audit',\n  'session_learning',\n  'governance_audit',\n  'session_state',\n  'session_sent_memories',\n  'memory_summaries',\n] as const;\n\nconst CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n\nconst MUTATION_LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CheckpointEntry {\n  id: number;\n  name: string;\n  created_at: string;\n  spec_folder: string | null;\n  git_branch: string | null;\n  memory_snapshot: Buffer | null;\n  file_snapshot: Buffer | null;\n  snapshot_format?: string | null;\n  snapshot_path?: string | null;\n  metadata: string | null;\n}\n\ninterface CheckpointInfo {\n  id: number;\n  name: string;\n  createdAt: string;\n  specFolder: string | null;\n  gitBranch: string | null;\n  snapshotSize: number;\n  metadata: Record<string, unknown>;\n  [key: string]: unknown;\n}\n\ninterface CreateCheckpointOptions {\n  name?: string;\n  specFolder?: string | null;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n  scope?: ScopeContext;\n}\n\ntype CheckpointCreateErrorCode =","lineStart":100,"lineEnd":229,"totalLines":3319,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781144227683,"end":1781144227703}},"metadata":{"openai":{"itemId":"fc_022c56d7e4100d5b016a2a1aa394588191a6e093e6aef82d4a"}},"id":"prt_eb4780f5b0018puAH8k9ngzSJw","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477ca4f0011f6vPLD3wWOlxe"}}
