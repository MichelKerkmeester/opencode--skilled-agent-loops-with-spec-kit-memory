{"type":"text","timestamp":1781762706502,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"id":"prt_ed9553b53001zofuVE5z9YNP9p","messageID":"msg_ed9551e550012uLA5CELRt7vzs","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","type":"text","text":"The query layer has active/purgeable indexes, so I’m checking whether read paths and delete callers actually honor `deleted_at IS NULL`. This decides whether the soft-delete issue is duplicate-audit only or user-visible.","time":{"start":1781762702163,"end":1781762706499},"metadata":{"openai":{"itemId":"msg_09c9ded08b6f7f8c016a338a8e21188191b1fd5b161f585582","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781762706568,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_H7z8DTonzpyhMO39zMjmb4bB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1440,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1440:       confidence: row.confidence || 0.5,\n1441:       ageString: age_string,\n1442:       lastAccessString: last_access_string,\n1443:       reasons\n1444:     };\n1445:   });\n1446: }\n1447: \n1448: /**\n1449:  * Builds a preview payload for a stored memory.\n1450:  * @param memory_id - The memory identifier.\n1451:  * @param max_lines - The maximum number of file lines to include.\n1452:  * @returns The memory preview, if found.\n1453:  */\n1454: export function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n1455:   const database = initialize_db();\n1456: \n1457:   let memory: MemoryRow | undefined;\n1458:   try {\n1459:     memory = database.prepare(`\n1460:       SELECT * FROM memory_index WHERE id = ?\n1461:     `).get(memory_id) as MemoryRow | undefined;\n1462:   } catch (e: unknown) {\n1463:     console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n1464:     return null;\n1465:   }\n1466: \n1467:   if (!memory) return null;\n1468: \n1469:   let content = '';\n1470:   try {\n1471:     // Validate DB-stored file paths before reading\n1472:     if (memory.file_path) {\n1473:       const valid_path = validate_file_path_local(memory.file_path);\n1474:       if (valid_path && fs.existsSync(valid_path)) {\n1475:         const full_content = fs.readFileSync(valid_path, 'utf-8');\n1476:         const lines = full_content.split('\\n');\n1477:         content = lines.slice(0, max_lines).join('\\n');\n1478:         if (lines.length > max_lines) {\n1479:           content += `\\n... (${lines.length - max_lines} more lines)`;\n1480:         }\n1481:       }\n1482:     }\n1483:   } catch (e: unknown) {\n1484:     console.warn('[vector-index] get_memory_preview file read warning', {\n1485:       operation: 'get_memory_preview',\n1486:       memoryId: memory_id,\n1487:       filePath: memory.file_path ?? null,\n1488:       error: get_error_message(e),\n1489:     });\n1490:     content = '(Unable to read file content)';\n1491:   }\n1492: \n1493:   return {\n1494:     id: memory.id,\n1495:     specFolder: memory.spec_folder,\n1496:     filePath: memory.file_path,\n1497:     title: memory.title || 'Untitled',\n1498:     createdAt: memory.created_at,\n1499:     lastAccessedAt: memory.last_accessed,\n1500:     accessCount: memory.access_count || 0,\n1501:     confidence: memory.confidence || 0.5,\n1502:     ageString: format_age_string(memory.created_at ?? null),\n1503:     lastAccessString: format_age_string(\n1504:       typeof memory.last_accessed === 'number' ? new Date(memory.last_accessed).toISOString() : null\n1505:     ),\n1506:     content\n1507:   };\n1508: }\n1509: \n1510: /* ───────────────────────────────────────────────────────────────\n1511:    DATABASE INTEGRITY\n1512: ----------------------------------------------------------------*/\n1513: \n1514: // Added autoClean option for automatic orphan cleanup\n1515: /**\n1516:  * Verifies vector-index consistency and optional cleanup results.\n1517:  * @param options - Integrity verification options.\n1518:  * @returns The integrity summary.\n1519:  */\n1520: export function verify_integrity(\n1521:   options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n1522:   database: Database.Database = initialize_db(),\n1523: ): { totalMemories: number; totalVectors: number; orphanedVectors: number; missingVectors: number; orphanedFiles: Array<{ id: number; file_path: string; reason: string }>; orphanedChunks: number; isConsistent: boolean; vectorSurfaceDivergence?: { activeSurface: string; activeCount: number; vecMemoriesCount: number; divergence: number }; cleaned?: { vectors: number; chunks: number; files: number } } {\n1524:   const { autoClean = false, cleanFiles = false } = options;\n1525:   const sqlite_vec = get_sqlite_vec_available();\n1526: \n1527:   // Measure the surface that live queries actually read. When a non-default\n1528:   // embedder is active, that surface is the dimension-tagged BLOB table, not\n1529:   // vec_memories; checking vec_memories there reports a clean graph while the\n1530:   // active surface silently drops rows. The vec0 virtual table requires\n1531:   // sqlite-vec; a plain dimension-tagged table does not.\n1532:   const source = getActiveVectorSourceForQuery(database);\n1533:   const sourceNeedsSqliteVec = source.tableName === activeVectorSchema('vec_memories');\n1534:   const sourceQueryable = sqlite_vec || !sourceNeedsSqliteVec;\n1535: \n1536:   const find_orphaned_vector_ids = () => {\n1537:     if (!sourceQueryable) {\n1538:       console.warn('[vector-index] find_orphaned_vector_ids: sqlite-vec not available');\n1539:       return [];\n1540:     }\n1541:     try {\n1542:       return (database.prepare(`\n1543: \t        SELECT v.${source.idColumn} AS vid FROM ${source.tableName} v\n1544:         WHERE NOT EXISTS (SELECT 1 FROM memory_index m WHERE m.id = v.${source.idColumn})\n1545:       `).all() as Array<{ vid: number }>).map((r) => r.vid);\n1546:     } catch (e: unknown) {\n1547:       console.warn('[vector-index] Could not query orphaned vectors:', get_error_message(e));\n1548:       return [];\n1549:     }\n1550:   };\n1551: \n1552:   const orphaned_vector_ids = find_orphaned_vector_ids();\n1553:   const orphaned_vectors = orphaned_vector_ids.length;\n1554: \n1555:   let cleaned_vectors = 0;\n1556:   if (autoClean && orphaned_vectors > 0 && sourceQueryable) {\n1557:     logger.info(`Auto-cleaning ${orphaned_vectors} orphaned vectors...`);\n1558:     const delete_stmt = database.prepare(`DELETE FROM ${source.tableName} WHERE ${source.idColumn} = ?`);\n1559:     for (const rowid of orphaned_vector_ids) {\n1560:       try {\n1561:         delete_stmt.run(BigInt(rowid));\n1562:         cleaned_vectors++;\n1563:       } catch (e: unknown) {\n1564:         console.warn(`[vector-index] Failed to clean orphaned vector ${rowid}: ${get_error_message(e)}`);\n1565:       }\n1566:     }\n1567:     logger.info(`Cleaned ${cleaned_vectors} orphaned vectors`);\n1568:   }\n1569: \n1570:   // Guard the active vector surface queries by availability: the vec_memories\n1571:   // vec0 virtual table requires sqlite-vec; a dimension-tagged BLOB table does not.\n1572:   const missing_vectors = sourceQueryable\n1573:     ? (database.prepare(`\n1574:         SELECT COUNT(*) as count FROM memory_index m\n1575:         WHERE m.embedding_status = 'success'\n1576: \t        AND NOT EXISTS (SELECT 1 FROM ${source.tableName} v WHERE v.${source.idColumn} = m.id)\n1577:       `).get() as { count: number }).count\n1578:     : 0;\n1579: \n1580:   const total_memories = (database.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number }).count;\n1581:   const total_vectors = sourceQueryable\n1582:     ? (database.prepare(`SELECT COUNT(*) as count FROM ${source.tableName}`).get() as { count: number }).count\n1583:     : 0;\n1584: \n1585:   // Cross-surface divergence health: when a dimension-tagged table is the active\n1586:   // query surface, vec_memories (the vec0 index) is a parallel surface that\n1587:   // should track it row-for-row. A persistent divergence signals dual-write or\n1588:   // coverage drift between the two surfaces; it is reported for deliberate\n1589:   // operator reconcile rather than auto-resolved here.\n1590:   let vector_surface_divergence: { activeSurface: string; activeCount: number; vecMemoriesCount: number; divergence: number } | undefined;\n1591:   if (sqlite_vec && source.tableName !== activeVectorSchema('vec_memories') && tableExists(database, 'vec_memories')) {\n1592:     try {\n1593:       const vec_memories_count = (database.prepare(`SELECT COUNT(*) as count FROM ${activeVectorSchema('vec_memories')}`).get() as { count: number }).count;\n1594:       vector_surface_divergence = {\n1595:         activeSurface: source.tableName,\n1596:         activeCount: total_vectors,\n1597:         vecMemoriesCount: vec_memories_count,\n1598:         divergence: total_vectors - vec_memories_count,\n1599:       };\n1600:     } catch (e: unknown) {\n1601:       console.warn('[vector-index] Could not compute vector surface divergence:', get_error_message(e));\n1602:     }\n1603:   }\n1604: \n1605:   const check_orphaned_files = () => {\n1606:     const memories = database.prepare('SELECT id, file_path FROM memory_index').all() as Array<{ id: number; file_path?: string | null }>;\n1607:     const orphaned: Array<{ id: number; file_path: string; reason: string }> = [];\n1608: \n1609:     for (const memory of memories) {\n1610:       if (memory.file_path && !fs.existsSync(memory.file_path)) {\n1611:         orphaned.push({\n1612:           id: memory.id,\n1613:           file_path: memory.file_path,\n1614:           reason: 'File no longer exists on filesystem'\n1615:         });\n1616:       }\n1617:     }\n1618: \n1619:     return orphaned;\n1620:   };\n1621: \n1622:   const orphaned_files_pre = check_orphaned_files();\n1623:   let cleaned_files = 0;\n1624:   const cleaned_file_ids = new Set<number>();\n1625: \n1626:   if (autoClean && cleanFiles && orphaned_files_pre.length > 0) {\n1627:     logger.info(`Auto-cleaning ${orphaned_files_pre.length} orphaned file rows...`);\n1628:     for (const orphan of orphaned_files_pre) {\n1629:       try {\n1630:         const spec_folder = (database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?')\n1631:           .get(orphan.id) as { spec_folder: string | null } | undefined)?.spec_folder ?? null;\n1632:         const deleted = delete_memory_from_database(database, orphan.id);\n1633:         if (deleted) {\n1634:           cleaned_files++;\n1635:           cleaned_file_ids.add(orphan.id);\n1636:           try {\n1637:             recordHistory(orphan.id, 'DELETE', null, null, 'mcp:integrity_check_files', spec_folder);\n1638:           } catch (error: unknown) {\n1639:             logger.warn('Failed to record integrity-check-files delete history', {\n1640:               error: error instanceof Error ? error.message : String(error),\n1641:             });\n1642:           }\n1643:         }\n1644:       } catch (e: unknown) {\n1645:         console.warn(`[vector-index] Failed to clean orphaned file row ${orphan.id}: ${get_error_message(e)}`);\n1646:       }\n1647:     }\n1648:     logger.info(`Cleaned ${cleaned_files} orphaned file rows`);\n1649:   }\n1650: \n1651:   const orphaned_files = (autoClean && cleanFiles)\n1652:     ? orphaned_files_pre.filter((o) => !cleaned_file_ids.has(o.id))\n1653:     : orphaned_files_pre;\n1654: \n1655:   const find_orphaned_chunks = () => {\n1656:     try {\n1657:       return database.prepare(`\n1658:         SELECT id, parent_id, chunk_index, chunk_label, spec_folder\n1659:         FROM memory_index\n1660:         WHERE parent_id IS NOT NULL\n1661:           AND NOT EXISTS (\n1662:             SELECT 1 FROM memory_index parent\n1663:             WHERE parent.id = memory_index.parent_id\n1664:               AND parent.parent_id IS NULL\n1665:           )\n1666:       `).all() as Array<{ id: number; parent_id: number; chunk_index: number; chunk_label: string | null; spec_folder: string | null }>;\n1667:     } catch (e: unknown) {\n1668:       console.warn('[vector-index] Could not query orphaned chunks:', get_error_message(e));\n1669:       return [];\n1670:     }\n1671:   };\n1672: \n1673:   const orphaned_chunks = find_orphaned_chunks();\n1674:   let cleaned_chunks = 0;\n1675: \n1676:   if (autoClean && orphaned_chunks.length > 0) {\n1677:     logger.info(`Auto-cleaning ${orphaned_chunks.length} orphaned chunks...`);\n1678:     for (const chunk of orphaned_chunks) {\n1679:       try {\n1680:         // Graph cleanup: Use delete_memory_from_database to clean ancillary rows\n1681:         // (lineage, projections, graph residue) instead of raw DELETE.\n1682:         const deleted = delete_memory_from_database(database, chunk.id);\n1683:         if (deleted) {\n1684:           cleaned_chunks++;\n1685:           try {\n1686:             recordHistory(chunk.id, 'DELETE', null, null, 'mcp:integrity_check', chunk.spec_folder ?? null);\n1687:           } catch (error: unknown) {\n1688:             logger.warn('Failed to record integrity-check delete history', {\n1689:               error: error instanceof Error ? error.message : String(error),\n1690:             });\n1691:           }\n1692:         }\n1693:       } catch (e: unknown) {\n1694:         console.warn(`[vector-index] Failed to clean orphaned chunk ${chunk.id}: ${get_error_message(e)}`);\n1695:       }\n1696:     }\n1697:     logger.info(`Cleaned ${cleaned_chunks} orphaned chunks`);\n1698:   }\n1699: \n1700:   const effective_orphaned_chunks = autoClean ? orphaned_chunks.length - cleaned_chunks : orphaned_chunks.length;\n1701: \n1702:   return {\n1703:     totalMemories: total_memories,\n1704:     totalVectors: total_vectors,\n1705:     orphanedVectors: autoClean ? orphaned_vectors - cleaned_vectors : orphaned_vectors,\n1706:     missingVectors: missing_vectors,\n1707:     orphanedFiles: orphaned_files,\n1708:     orphanedChunks: effective_orphaned_chunks,\n1709:     isConsistent: (orphaned_vectors - cleaned_vectors) === 0 && missing_vectors === 0 && orphaned_files.length === 0 && effective_orphaned_chunks === 0,\n1710:     ...(vector_surface_divergence ? { vectorSurfaceDivergence: vector_surface_divergence } : {}),\n1711:     cleaned: (autoClean && (cleaned_vectors > 0 || cleaned_chunks > 0 || cleaned_files > 0))\n1712:       ? { vectors: cleaned_vectors, chunks: cleaned_chunks, files: cleaned_files }\n1713:       : undefined\n1714:   };\n1715: }\n1716: \n1717: // CamelCase aliases\n1718: export { get_memory as getMemory };\n1719: export { get_memories_by_folder as getMemoriesByFolder };\n1720: export { get_memory_count as getMemoryCount };\n1721: export { get_status_counts as getStatusCounts };\n1722: export { get_stats as getStats };\n1723: export { vector_search as vectorSearch };\n1724: export { get_constitutional_memories_public as getConstitutionalMemories };\n1725: export { multi_concept_search as multiConceptSearch };\n1726: export { extract_title as extractTitle };\n1727: export { extract_snippet as extractSnippet };\n1728: export { extract_tags as extractTags };\n1729: export { extract_date as extractDate };\n1730: export { generate_query_embedding as generateQueryEmbedding };\n1731: export { keyword_search as keywordSearch };\n1732: export { vector_search_enriched as vectorSearchEnriched };\n1733: export { multi_concept_search_enriched as multiConceptSearchEnriched };\n1734: export { multi_concept_keyword_search as multiConceptKeywordSearch };\n1735: export { parse_quoted_terms as parseQuotedTerms };\n1736: export { apply_smart_ranking as applySmartRanking };\n1737: export { apply_diversity as applyDiversity };\n1738: export { get_related_memories as getRelatedMemories };\n1739: export { get_usage_stats as getUsageStats };\n1740: export { find_cleanup_candidates as findCleanupCandidates };\n1741: export { get_memory_preview as getMemoryPreview };\n1742: export { verify_integrity as verifyIntegrity };\n\n(End of file - total 1742 lines)\n</content>","metadata":{"preview":"      confidence: row.confidence || 0.5,\n      ageString: age_string,\n      lastAccessString: last_access_string,\n      reasons\n    };\n  });\n}\n\n/**\n * Builds a preview payload for a stored memory.\n * @param memory_id - The memory identifier.\n * @param max_lines - The maximum number of file lines to include.\n * @returns The memory preview, if found.\n */\nexport function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n  const database = initialize_db();\n\n  let memory: MemoryRow | undefined;\n  try {\n    memory = database.prepare(`","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"      confidence: row.confidence || 0.5,\n      ageString: age_string,\n      lastAccessString: last_access_string,\n      reasons\n    };\n  });\n}\n\n/**\n * Builds a preview payload for a stored memory.\n * @param memory_id - The memory identifier.\n * @param max_lines - The maximum number of file lines to include.\n * @returns The memory preview, if found.\n */\nexport function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n  const database = initialize_db();\n\n  let memory: MemoryRow | undefined;\n  try {\n    memory = database.prepare(`\n      SELECT * FROM memory_index WHERE id = ?\n    `).get(memory_id) as MemoryRow | undefined;\n  } catch (e: unknown) {\n    console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n    return null;\n  }\n\n  if (!memory) return null;\n\n  let content = '';\n  try {\n    // Validate DB-stored file paths before reading\n    if (memory.file_path) {\n      const valid_path = validate_file_path_local(memory.file_path);\n      if (valid_path && fs.existsSync(valid_path)) {\n        const full_content = fs.readFileSync(valid_path, 'utf-8');\n        const lines = full_content.split('\\n');\n        content = lines.slice(0, max_lines).join('\\n');\n        if (lines.length > max_lines) {\n          content += `\\n... (${lines.length - max_lines} more lines)`;\n        }\n      }\n    }\n  } catch (e: unknown) {\n    console.warn('[vector-index] get_memory_preview file read warning', {\n      operation: 'get_memory_preview',\n      memoryId: memory_id,\n      filePath: memory.file_path ?? null,\n      error: get_error_message(e),\n    });\n    content = '(Unable to read file content)';\n  }\n\n  return {\n    id: memory.id,\n    specFolder: memory.spec_folder,\n    filePath: memory.file_path,\n    title: memory.title || 'Untitled',\n    createdAt: memory.created_at,\n    lastAccessedAt: memory.last_accessed,\n    accessCount: memory.access_count || 0,\n    confidence: memory.confidence || 0.5,\n    ageString: format_age_string(memory.created_at ?? null),\n    lastAccessString: format_age_string(\n      typeof memory.last_accessed === 'number' ? new Date(memory.last_accessed).toISOString() : null\n    ),\n    content\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   DATABASE INTEGRITY\n----------------------------------------------------------------*/\n\n// Added autoClean option for automatic orphan cleanup\n/**\n * Verifies vector-index consistency and optional cleanup results.\n * @param options - Integrity verification options.\n * @returns The integrity summary.\n */\nexport function verify_integrity(\n  options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n  database: Database.Database = initialize_db(),\n): { totalMemories: number; totalVectors: number; orphanedVectors: number; missingVectors: number; orphanedFiles: Array<{ id: number; file_path: string; reason: string }>; orphanedChunks: number; isConsistent: boolean; vectorSurfaceDivergence?: { activeSurface: string; activeCount: number; vecMemoriesCount: number; divergence: number }; cleaned?: { vectors: number; chunks: number; files: number } } {\n  const { autoClean = false, cleanFiles = false } = options;\n  const sqlite_vec = get_sqlite_vec_available();\n\n  // Measure the surface that live queries actually read. When a non-default\n  // embedder is active, that surface is the dimension-tagged BLOB table, not\n  // vec_memories; checking vec_memories there reports a clean graph while the\n  // active surface silently drops rows. The vec0 virtual table requires\n  // sqlite-vec; a plain dimension-tagged table does not.\n  const source = getActiveVectorSourceForQuery(database);\n  const sourceNeedsSqliteVec = source.tableName === activeVectorSchema('vec_memories');\n  const sourceQueryable = sqlite_vec || !sourceNeedsSqliteVec;\n\n  const find_orphaned_vector_ids = () => {\n    if (!sourceQueryable) {\n      console.warn('[vector-index] find_orphaned_vector_ids: sqlite-vec not available');\n      return [];\n    }\n    try {\n      return (database.prepare(`\n\t        SELECT v.${source.idColumn} AS vid FROM ${source.tableName} v\n        WHERE NOT EXISTS (SELECT 1 FROM memory_index m WHERE m.id = v.${source.idColumn})\n      `).all() as Array<{ vid: number }>).map((r) => r.vid);\n    } catch (e: unknown) {\n      console.warn('[vector-index] Could not query orphaned vectors:', get_error_message(e));\n      return [];\n    }\n  };\n\n  const orphaned_vector_ids = find_orphaned_vector_ids();\n  const orphaned_vectors = orphaned_vector_ids.length;\n\n  let cleaned_vectors = 0;\n  if (autoClean && orphaned_vectors > 0 && sourceQueryable) {\n    logger.info(`Auto-cleaning ${orphaned_vectors} orphaned vectors...`);\n    const delete_stmt = database.prepare(`DELETE FROM ${source.tableName} WHERE ${source.idColumn} = ?`);\n    for (const rowid of orphaned_vector_ids) {\n      try {\n        delete_stmt.run(BigInt(rowid));\n        cleaned_vectors++;\n      } catch (e: unknown) {\n        console.warn(`[vector-index] Failed to clean orphaned vector ${rowid}: ${get_error_message(e)}`);\n      }\n    }\n    logger.info(`Cleaned ${cleaned_vectors} orphaned vectors`);\n  }\n\n  // Guard the active vector surface queries by availability: the vec_memories\n  // vec0 virtual table requires sqlite-vec; a dimension-tagged BLOB table does not.\n  const missing_vectors = sourceQueryable\n    ? (database.prepare(`\n        SELECT COUNT(*) as count FROM memory_index m\n        WHERE m.embedding_status = 'success'\n\t        AND NOT EXISTS (SELECT 1 FROM ${source.tableName} v WHERE v.${source.idColumn} = m.id)\n      `).get() as { count: number }).count\n    : 0;\n\n  const total_memories = (database.prepare('SELECT COUNT(*) as count FROM memory_index').get() as { count: number }).count;\n  const total_vectors = sourceQueryable\n    ? (database.prepare(`SELECT COUNT(*) as count FROM ${source.tableName}`).get() as { count: number }).count\n    : 0;\n\n  // Cross-surface divergence health: when a dimension-tagged table is the active\n  // query surface, vec_memories (the vec0 index) is a parallel surface that\n  // should track it row-for-row. A persistent divergence signals dual-write or\n  // coverage drift between the two surfaces; it is reported for deliberate\n  // operator reconcile rather than auto-resolved here.\n  let vector_surface_divergence: { activeSurface: string; activeCount: number; vecMemoriesCount: number; divergence: number } | undefined;\n  if (sqlite_vec && source.tableName !== activeVectorSchema('vec_memories') && tableExists(database, 'vec_memories')) {\n    try {\n      const vec_memories_count = (database.prepare(`SELECT COUNT(*) as count FROM ${activeVectorSchema('vec_memories')}`).get() as { count: number }).count;\n      vector_surface_divergence = {\n        activeSurface: source.tableName,\n        activeCount: total_vectors,\n        vecMemoriesCount: vec_memories_count,\n        divergence: total_vectors - vec_memories_count,\n      };\n    } catch (e: unknown) {\n      console.warn('[vector-index] Could not compute vector surface divergence:', get_error_message(e));\n    }\n  }\n\n  const check_orphaned_files = () => {\n    const memories = database.prepare('SELECT id, file_path FROM memory_index').all() as Array<{ id: number; file_path?: string | null }>;\n    const orphaned: Array<{ id: number; file_path: string; reason: string }> = [];\n\n    for (const memory of memories) {\n      if (memory.file_path && !fs.existsSync(memory.file_path)) {\n        orphaned.push({\n          id: memory.id,\n          file_path: memory.file_path,\n          reason: 'File no longer exists on filesystem'\n        });\n      }\n    }\n\n    return orphaned;\n  };\n\n  const orphaned_files_pre = check_orphaned_files();\n  let cleaned_files = 0;\n  const cleaned_file_ids = new Set<number>();\n\n  if (autoClean && cleanFiles && orphaned_files_pre.length > 0) {\n    logger.info(`Auto-cleaning ${orphaned_files_pre.length} orphaned file rows...`);\n    for (const orphan of orphaned_files_pre) {\n      try {\n        const spec_folder = (database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?')\n          .get(orphan.id) as { spec_folder: string | null } | undefined)?.spec_folder ?? null;\n        const deleted = delete_memory_from_database(database, orphan.id);\n        if (deleted) {\n          cleaned_files++;\n          cleaned_file_ids.add(orphan.id);\n          try {\n            recordHistory(orphan.id, 'DELETE', null, null, 'mcp:integrity_check_files', spec_folder);\n          } catch (error: unknown) {\n            logger.warn('Failed to record integrity-check-files delete history', {\n              error: error instanceof Error ? error.message : String(error),\n            });\n          }\n        }\n      } catch (e: unknown) {\n        console.warn(`[vector-index] Failed to clean orphaned file row ${orphan.id}: ${get_error_message(e)}`);\n      }\n    }\n    logger.info(`Cleaned ${cleaned_files} orphaned file rows`);\n  }\n\n  const orphaned_files = (autoClean && cleanFiles)\n    ? orphaned_files_pre.filter((o) => !cleaned_file_ids.has(o.id))\n    : orphaned_files_pre;\n\n  const find_orphaned_chunks = () => {\n    try {\n      return database.prepare(`\n        SELECT id, parent_id, chunk_index, chunk_label, spec_folder\n        FROM memory_index\n        WHERE parent_id IS NOT NULL\n          AND NOT EXISTS (\n            SELECT 1 FROM memory_index parent\n            WHERE parent.id = memory_index.parent_id\n              AND parent.parent_id IS NULL\n          )\n      `).all() as Array<{ id: number; parent_id: number; chunk_index: number; chunk_label: string | null; spec_folder: string | null }>;\n    } catch (e: unknown) {\n      console.warn('[vector-index] Could not query orphaned chunks:', get_error_message(e));\n      return [];\n    }\n  };\n\n  const orphaned_chunks = find_orphaned_chunks();\n  let cleaned_chunks = 0;\n\n  if (autoClean && orphaned_chunks.length > 0) {\n    logger.info(`Auto-cleaning ${orphaned_chunks.length} orphaned chunks...`);\n    for (const chunk of orphaned_chunks) {\n      try {\n        // Graph cleanup: Use delete_memory_from_database to clean ancillary rows\n        // (lineage, projections, graph residue) instead of raw DELETE.\n        const deleted = delete_memory_from_database(database, chunk.id);\n        if (deleted) {\n          cleaned_chunks++;\n          try {\n            recordHistory(chunk.id, 'DELETE', null, null, 'mcp:integrity_check', chunk.spec_folder ?? null);\n          } catch (error: unknown) {\n            logger.warn('Failed to record integrity-check delete history', {\n              error: error instanceof Error ? error.message : String(error),\n            });\n          }\n        }\n      } catch (e: unknown) {\n        console.warn(`[vector-index] Failed to clean orphaned chunk ${chunk.id}: ${get_error_message(e)}`);\n      }\n    }\n    logger.info(`Cleaned ${cleaned_chunks} orphaned chunks`);\n  }\n\n  const effective_orphaned_chunks = autoClean ? orphaned_chunks.length - cleaned_chunks : orphaned_chunks.length;\n\n  return {\n    totalMemories: total_memories,\n    totalVectors: total_vectors,\n    orphanedVectors: autoClean ? orphaned_vectors - cleaned_vectors : orphaned_vectors,\n    missingVectors: missing_vectors,\n    orphanedFiles: orphaned_files,\n    orphanedChunks: effective_orphaned_chunks,\n    isConsistent: (orphaned_vectors - cleaned_vectors) === 0 && missing_vectors === 0 && orphaned_files.length === 0 && effective_orphaned_chunks === 0,\n    ...(vector_surface_divergence ? { vectorSurfaceDivergence: vector_surface_divergence } : {}),\n    cleaned: (autoClean && (cleaned_vectors > 0 || cleaned_chunks > 0 || cleaned_files > 0))\n      ? { vectors: cleaned_vectors, chunks: cleaned_chunks, files: cleaned_files }\n      : undefined\n  };\n}\n\n// CamelCase aliases\nexport { get_memory as getMemory };\nexport { get_memories_by_folder as getMemoriesByFolder };\nexport { get_memory_count as getMemoryCount };\nexport { get_status_counts as getStatusCounts };\nexport { get_stats as getStats };\nexport { vector_search as vectorSearch };\nexport { get_constitutional_memories_public as getConstitutionalMemories };\nexport { multi_concept_search as multiConceptSearch };\nexport { extract_title as extractTitle };\nexport { extract_snippet as extractSnippet };\nexport { extract_tags as extractTags };\nexport { extract_date as extractDate };\nexport { generate_query_embedding as generateQueryEmbedding };\nexport { keyword_search as keywordSearch };\nexport { vector_search_enriched as vectorSearchEnriched };\nexport { multi_concept_search_enriched as multiConceptSearchEnriched };\nexport { multi_concept_keyword_search as multiConceptKeywordSearch };\nexport { parse_quoted_terms as parseQuotedTerms };\nexport { apply_smart_ranking as applySmartRanking };\nexport { apply_diversity as applyDiversity };\nexport { get_related_memories as getRelatedMemories };\nexport { get_usage_stats as getUsageStats };\nexport { find_cleanup_candidates as findCleanupCandidates };\nexport { get_memory_preview as getMemoryPreview };\nexport { verify_integrity as verifyIntegrity };","lineStart":1440,"lineEnd":1742,"totalLines":1742,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781762706559,"end":1781762706566}},"metadata":{"openai":{"itemId":"fc_09c9ded08b6f7f8c016a338a9272c081919b92fbf43e4d28bd"}},"id":"prt_ed9554c45001cWYrYeMqoHUwSI","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9551e550012uLA5CELRt7vzs"}}
{"type":"tool_use","timestamp":1781762706590,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_6y3lRcew2bjqK9K099sLIgcr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edge-tombstones.vitest.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edge-tombstones.vitest.ts</path>\n<type>file</type>\n<content>\n1: import type Database from 'better-sqlite3';\n2: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n3: \n4: import * as core from '../core';\n5: import { handleMemoryCausalUnlink } from '../handlers/causal-graph';\n6: import { handleMemoryDelete } from '../handlers/memory-crud-delete';\n7: import { handleMemoryHealth } from '../handlers/memory-crud-health';\n8: import { handleMemoryBulkDelete } from '../handlers/memory-bulk-delete';\n9: import * as vectorIndex from '../lib/search/vector-index';\n10: import {\n11:   createMemoryDbFixture,\n12:   disposeMemoryDbFixture,\n13:   seedCausalEdge,\n14:   seedMemoryRow,\n15: } from './helpers/memory-db-fixture';\n16: \n17: const SPEC_FOLDER = 'specs/tombstone-fixture';\n18: const SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n19: \n20: function parseResponse(response: { content: Array<{ text: string }> }): Record<string, any> {\n21:   return JSON.parse(response.content[0].text) as Record<string, any>;\n22: }\n23: \n24: function tombstones(db: Database.Database): Array<Record<string, any>> {\n25:   return db.prepare(`\n26:     SELECT * FROM causal_edge_tombstones ORDER BY id ASC\n27:   `).all() as Array<Record<string, any>>;\n28: }\n29: \n30: function activeEdgeCount(db: Database.Database): number {\n31:   return (db.prepare('SELECT COUNT(*) AS count FROM causal_edges').get() as { count: number }).count;\n32: }\n33: \n34: function deletedAt(db: Database.Database, id: number): string | null {\n35:   const row = db.prepare('SELECT deleted_at FROM memory_index WHERE id = ?').get(id) as { deleted_at: string | null };\n36:   return row.deleted_at;\n37: }\n38: \n39: describe('causal edge tombstones', () => {\n40:   let db: Database.Database;\n41:   let originalSoftDeleteFlag: string | undefined;\n42: \n43:   beforeEach(() => {\n44:     vi.restoreAllMocks();\n45:     originalSoftDeleteFlag = process.env[SOFT_DELETE_FLAG];\n46:     delete process.env[SOFT_DELETE_FLAG];\n47:     db = createMemoryDbFixture();\n48:   });\n49: \n50:   afterEach(() => {\n51:     if (originalSoftDeleteFlag === undefined) {\n52:       delete process.env[SOFT_DELETE_FLAG];\n53:     } else {\n54:       process.env[SOFT_DELETE_FLAG] = originalSoftDeleteFlag;\n55:     }\n56:     vi.restoreAllMocks();\n57:     disposeMemoryDbFixture(db);\n58:   });\n59: \n60:   it('hard-deletes memory rows by default while cleaning related edges', async () => {\n61:     seedMemoryRow(db, { id: 401, specFolder: SPEC_FOLDER });\n62:     seedMemoryRow(db, { id: 402, specFolder: SPEC_FOLDER });\n63:     seedCausalEdge(db, { sourceId: '401', targetId: '402', relation: 'supports' });\n64: \n65:     const response = await handleMemoryDelete({ id: 401, confirm: true });\n66:     const envelope = parseResponse(response);\n67: \n68:     expect(envelope.data.deleted).toBe(1);\n69:     expect((db.prepare('SELECT COUNT(*) AS count FROM memory_index WHERE id = 401').get() as { count: number }).count).toBe(0);\n70:     expect(activeEdgeCount(db)).toBe(0);\n71:     expect(tombstones(db)).toHaveLength(1);\n72:   });\n73: \n74:   it('tombstones incoming and outgoing edges before single memory delete', async () => {\n75:     seedMemoryRow(db, { id: 1, specFolder: SPEC_FOLDER });\n76:     seedMemoryRow(db, { id: 2, specFolder: SPEC_FOLDER });\n77:     seedMemoryRow(db, { id: 3, specFolder: SPEC_FOLDER });\n78:     seedCausalEdge(db, {\n79:       sourceId: '1',\n80:       targetId: '2',\n81:       relation: 'supports',\n82:       evidence: 'outgoing edge evidence',\n83:       sourceAnchor: 'source-anchor',\n84:       targetAnchor: 'target-anchor',\n85:       createdBy: 'manual',\n86:     });\n87:     seedCausalEdge(db, {\n88:       sourceId: '3',\n89:       targetId: '1',\n90:       relation: 'caused',\n91:       evidence: 'incoming edge evidence',\n92:       createdBy: 'manual',\n93:     });\n94: \n95:     const response = await handleMemoryDelete({ id: 1, confirm: true });\n96:     const envelope = parseResponse(response);\n97: \n98:     expect(envelope.data.deleted).toBe(1);\n99:     expect(activeEdgeCount(db)).toBe(0);\n100: \n101:     const rows = tombstones(db);\n102:     expect(rows).toHaveLength(2);\n103:     expect(rows.map((row) => row.reason)).toEqual([\n104:       'memory row mutation cleanup',\n105:       'memory row mutation cleanup',\n106:     ]);\n107: \n108:     const metadata = JSON.parse(rows[0].restore_metadata);\n109:     expect(metadata.edge).toMatchObject({\n110:       source_id: '1',\n111:       target_id: '2',\n112:       source_anchor: 'source-anchor',\n113:       target_anchor: 'target-anchor',\n114:       evidence: 'outgoing edge evidence',\n115:       created_by: 'manual',\n116:     });\n117:   });\n118: \n119:   it('tombstones each removed active edge during bulk delete', async () => {\n120:     seedMemoryRow(db, { id: 10, specFolder: SPEC_FOLDER, importanceTier: 'temporary' });\n121:     seedMemoryRow(db, { id: 20, specFolder: SPEC_FOLDER, importanceTier: 'normal' });\n122:     seedMemoryRow(db, { id: 30, specFolder: SPEC_FOLDER, importanceTier: 'normal' });\n123:     seedCausalEdge(db, { sourceId: '10', targetId: '20', relation: 'supports' });\n124:     seedCausalEdge(db, { sourceId: '30', targetId: '10', relation: 'enabled' });\n125: \n126:     const response = await handleMemoryBulkDelete({\n127:       tier: 'temporary',\n128:       specFolder: SPEC_FOLDER,\n129:       confirm: true,\n130:       skipCheckpoint: true,\n131:     });\n132:     const envelope = parseResponse(response);\n133: \n134:     expect(envelope.data.deleted).toBe(1);\n135:     expect(activeEdgeCount(db)).toBe(0);\n136:     expect(tombstones(db)).toHaveLength(2);\n137:   });\n138: \n139:   it('preserves the first tombstone timestamp on repeated single delete', async () => {\n140:     process.env[SOFT_DELETE_FLAG] = 'true';\n141:     seedMemoryRow(db, { id: 40, specFolder: SPEC_FOLDER });\n142: \n143:     vi.useFakeTimers();\n144:     try {\n145:       vi.setSystemTime(new Date('2026-06-10T00:00:00.000Z'));\n146:       expect(parseResponse(await handleMemoryDelete({ id: 40, confirm: true })).data.deleted).toBe(1);\n147:       const firstDeletedAt = deletedAt(db, 40);\n148:       expect(firstDeletedAt).toBe('2026-06-10T00:00:00.000Z');\n149: \n150:       vi.setSystemTime(new Date('2026-06-12T00:00:00.000Z'));\n151:       expect(parseResponse(await handleMemoryDelete({ id: 40, confirm: true })).data.deleted).toBe(1);\n152:       expect(parseResponse(await handleMemoryDelete({ id: 40, confirm: true })).data.deleted).toBe(1);\n153: \n154:       expect(deletedAt(db, 40)).toBe(firstDeletedAt);\n155:       expect((db.prepare('SELECT COUNT(*) AS count FROM memory_index WHERE id = 40').get() as { count: number }).count).toBe(1);\n156:     } finally {\n157:       vi.useRealTimers();\n158:     }\n159:   });\n160: \n161:   it('preserves the first tombstone timestamp on repeated bulk delete', async () => {\n162:     process.env[SOFT_DELETE_FLAG] = 'true';\n163:     seedMemoryRow(db, { id: 50, specFolder: SPEC_FOLDER, importanceTier: 'temporary' });\n164: \n165:     vi.useFakeTimers();\n166:     try {\n167:       vi.setSystemTime(new Date('2026-06-10T01:00:00.000Z'));\n168:       expect(parseResponse(await handleMemoryBulkDelete({\n169:         tier: 'temporary',\n170:         specFolder: SPEC_FOLDER,\n171:         confirm: true,\n172:         skipCheckpoint: true,\n173:       })).data.deleted).toBe(1);\n174:       const firstDeletedAt = deletedAt(db, 50);\n175:       expect(firstDeletedAt).toBe('2026-06-10T01:00:00.000Z');\n176: \n177:       vi.setSystemTime(new Date('2026-06-13T01:00:00.000Z'));\n178:       expect(parseResponse(await handleMemoryBulkDelete({\n179:         tier: 'temporary',\n180:         specFolder: SPEC_FOLDER,\n181:         confirm: true,\n182:         skipCheckpoint: true,\n183:       })).data.deleted).toBe(1);\n184:       expect(parseResponse(await handleMemoryBulkDelete({\n185:         tier: 'temporary',\n186:         specFolder: SPEC_FOLDER,\n187:         confirm: true,\n188:         skipCheckpoint: true,\n189:       })).data.deleted).toBe(1);\n190: \n191:       expect(deletedAt(db, 50)).toBe(firstDeletedAt);\n192:       expect((db.prepare('SELECT COUNT(*) AS count FROM memory_index WHERE id = 50').get() as { count: number }).count).toBe(1);\n193:     } finally {\n194:       vi.useRealTimers();\n195:     }\n196:   });\n197: \n198:   it('manual causal unlink records reason and restore metadata', async () => {\n199:     seedMemoryRow(db, { id: 101, specFolder: SPEC_FOLDER });\n200:     seedMemoryRow(db, { id: 102, specFolder: SPEC_FOLDER });\n201:     const edgeId = seedCausalEdge(db, {\n202:       sourceId: '101',\n203:       targetId: '102',\n204:       relation: 'derived_from',\n205:       evidence: 'manual unlink evidence',\n206:       createdBy: 'manual',\n207:     });\n208:     vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n209:     vi.spyOn(vectorIndex, 'initializeDb').mockImplementation(() => db as ReturnType<typeof vectorIndex.initializeDb>);\n210:     vi.spyOn(vectorIndex, 'getDb').mockReturnValue(db as ReturnType<typeof vectorIndex.getDb>);\n211: \n212:     const response = await handleMemoryCausalUnlink({ edgeId });\n213:     const envelope = parseResponse(response);\n214: \n215:     expect(envelope.data.deleted).toBe(true);\n216:     expect(activeEdgeCount(db)).toBe(0);\n217: \n218:     const [row] = tombstones(db);\n219:     expect(row.reason).toBe('manual causal unlink');\n220:     expect(row.lifecycle_generation).toBe(1);\n221:     const metadata = JSON.parse(row.restore_metadata);\n222:     expect(metadata).toMatchObject({ command: 'memory_causal_unlink' });\n223:     expect(metadata.edge).toMatchObject({\n224:       id: edgeId,\n225:       source_id: '101',\n226:       target_id: '102',\n227:       relation: 'derived_from',\n228:       evidence: 'manual unlink evidence',\n229:     });\n230:   });\n231: \n232:   it('reports orphan edges before confirmed health repair and tombstones on repair', async () => {\n233:     seedMemoryRow(db, { id: 201, specFolder: SPEC_FOLDER });\n234:     seedCausalEdge(db, {\n235:       sourceId: '201',\n236:       targetId: '999',\n237:       relation: 'supports',\n238:       evidence: 'orphan edge evidence',\n239:       createdBy: 'manual',\n240:     });\n241: \n242:     const report = parseResponse(await handleMemoryHealth({ reportMode: 'full' }));\n243:     expect(report.data.causalEdges.orphanedEdges).toBe(1);\n244:     expect(report.data.causalEdges.sample[0]).toMatchObject({\n245:       sourceId: '201',\n246:       targetId: '999',\n247:       sourceExists: true,\n248:       targetExists: false,\n249:     });\n250:     expect(activeEdgeCount(db)).toBe(1);\n251:     expect(tombstones(db)).toHaveLength(0);\n252: \n253:     const repaired = parseResponse(await handleMemoryHealth({\n254:       reportMode: 'full',\n255:       autoRepair: true,\n256:       confirmed: true,\n257:     }));\n258: \n259:     expect(repaired.data.causalEdges.repaired).toBe(1);\n260:     expect(repaired.data.causalEdges.tombstoned).toBe(1);\n261:     expect(activeEdgeCount(db)).toBe(0);\n262:     const [row] = tombstones(db);\n263:     expect(row.reason).toBe('orphan causal edge cleanup');\n264:   });\n265: });\n\n(End of file - total 265 lines)\n</content>","metadata":{"preview":"import type Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nimport * as core from '../core';\nimport { handleMemoryCausalUnlink } from '../handlers/causal-graph';\nimport { handleMemoryDelete } from '../handlers/memory-crud-delete';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health';\nimport { handleMemoryBulkDelete } from '../handlers/memory-bulk-delete';\nimport * as vectorIndex from '../lib/search/vector-index';\nimport {\n  createMemoryDbFixture,\n  disposeMemoryDbFixture,\n  seedCausalEdge,\n  seedMemoryRow,\n} from './helpers/memory-db-fixture';\n\nconst SPEC_FOLDER = 'specs/tombstone-fixture';\nconst SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, any> {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edge-tombstones.vitest.ts","text":"import type Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nimport * as core from '../core';\nimport { handleMemoryCausalUnlink } from '../handlers/causal-graph';\nimport { handleMemoryDelete } from '../handlers/memory-crud-delete';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health';\nimport { handleMemoryBulkDelete } from '../handlers/memory-bulk-delete';\nimport * as vectorIndex from '../lib/search/vector-index';\nimport {\n  createMemoryDbFixture,\n  disposeMemoryDbFixture,\n  seedCausalEdge,\n  seedMemoryRow,\n} from './helpers/memory-db-fixture';\n\nconst SPEC_FOLDER = 'specs/tombstone-fixture';\nconst SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, any> {\n  return JSON.parse(response.content[0].text) as Record<string, any>;\n}\n\nfunction tombstones(db: Database.Database): Array<Record<string, any>> {\n  return db.prepare(`\n    SELECT * FROM causal_edge_tombstones ORDER BY id ASC\n  `).all() as Array<Record<string, any>>;\n}\n\nfunction activeEdgeCount(db: Database.Database): number {\n  return (db.prepare('SELECT COUNT(*) AS count FROM causal_edges').get() as { count: number }).count;\n}\n\nfunction deletedAt(db: Database.Database, id: number): string | null {\n  const row = db.prepare('SELECT deleted_at FROM memory_index WHERE id = ?').get(id) as { deleted_at: string | null };\n  return row.deleted_at;\n}\n\ndescribe('causal edge tombstones', () => {\n  let db: Database.Database;\n  let originalSoftDeleteFlag: string | undefined;\n\n  beforeEach(() => {\n    vi.restoreAllMocks();\n    originalSoftDeleteFlag = process.env[SOFT_DELETE_FLAG];\n    delete process.env[SOFT_DELETE_FLAG];\n    db = createMemoryDbFixture();\n  });\n\n  afterEach(() => {\n    if (originalSoftDeleteFlag === undefined) {\n      delete process.env[SOFT_DELETE_FLAG];\n    } else {\n      process.env[SOFT_DELETE_FLAG] = originalSoftDeleteFlag;\n    }\n    vi.restoreAllMocks();\n    disposeMemoryDbFixture(db);\n  });\n\n  it('hard-deletes memory rows by default while cleaning related edges', async () => {\n    seedMemoryRow(db, { id: 401, specFolder: SPEC_FOLDER });\n    seedMemoryRow(db, { id: 402, specFolder: SPEC_FOLDER });\n    seedCausalEdge(db, { sourceId: '401', targetId: '402', relation: 'supports' });\n\n    const response = await handleMemoryDelete({ id: 401, confirm: true });\n    const envelope = parseResponse(response);\n\n    expect(envelope.data.deleted).toBe(1);\n    expect((db.prepare('SELECT COUNT(*) AS count FROM memory_index WHERE id = 401').get() as { count: number }).count).toBe(0);\n    expect(activeEdgeCount(db)).toBe(0);\n    expect(tombstones(db)).toHaveLength(1);\n  });\n\n  it('tombstones incoming and outgoing edges before single memory delete', async () => {\n    seedMemoryRow(db, { id: 1, specFolder: SPEC_FOLDER });\n    seedMemoryRow(db, { id: 2, specFolder: SPEC_FOLDER });\n    seedMemoryRow(db, { id: 3, specFolder: SPEC_FOLDER });\n    seedCausalEdge(db, {\n      sourceId: '1',\n      targetId: '2',\n      relation: 'supports',\n      evidence: 'outgoing edge evidence',\n      sourceAnchor: 'source-anchor',\n      targetAnchor: 'target-anchor',\n      createdBy: 'manual',\n    });\n    seedCausalEdge(db, {\n      sourceId: '3',\n      targetId: '1',\n      relation: 'caused',\n      evidence: 'incoming edge evidence',\n      createdBy: 'manual',\n    });\n\n    const response = await handleMemoryDelete({ id: 1, confirm: true });\n    const envelope = parseResponse(response);\n\n    expect(envelope.data.deleted).toBe(1);\n    expect(activeEdgeCount(db)).toBe(0);\n\n    const rows = tombstones(db);\n    expect(rows).toHaveLength(2);\n    expect(rows.map((row) => row.reason)).toEqual([\n      'memory row mutation cleanup',\n      'memory row mutation cleanup',\n    ]);\n\n    const metadata = JSON.parse(rows[0].restore_metadata);\n    expect(metadata.edge).toMatchObject({\n      source_id: '1',\n      target_id: '2',\n      source_anchor: 'source-anchor',\n      target_anchor: 'target-anchor',\n      evidence: 'outgoing edge evidence',\n      created_by: 'manual',\n    });\n  });\n\n  it('tombstones each removed active edge during bulk delete', async () => {\n    seedMemoryRow(db, { id: 10, specFolder: SPEC_FOLDER, importanceTier: 'temporary' });\n    seedMemoryRow(db, { id: 20, specFolder: SPEC_FOLDER, importanceTier: 'normal' });\n    seedMemoryRow(db, { id: 30, specFolder: SPEC_FOLDER, importanceTier: 'normal' });\n    seedCausalEdge(db, { sourceId: '10', targetId: '20', relation: 'supports' });\n    seedCausalEdge(db, { sourceId: '30', targetId: '10', relation: 'enabled' });\n\n    const response = await handleMemoryBulkDelete({\n      tier: 'temporary',\n      specFolder: SPEC_FOLDER,\n      confirm: true,\n      skipCheckpoint: true,\n    });\n    const envelope = parseResponse(response);\n\n    expect(envelope.data.deleted).toBe(1);\n    expect(activeEdgeCount(db)).toBe(0);\n    expect(tombstones(db)).toHaveLength(2);\n  });\n\n  it('preserves the first tombstone timestamp on repeated single delete', async () => {\n    process.env[SOFT_DELETE_FLAG] = 'true';\n    seedMemoryRow(db, { id: 40, specFolder: SPEC_FOLDER });\n\n    vi.useFakeTimers();\n    try {\n      vi.setSystemTime(new Date('2026-06-10T00:00:00.000Z'));\n      expect(parseResponse(await handleMemoryDelete({ id: 40, confirm: true })).data.deleted).toBe(1);\n      const firstDeletedAt = deletedAt(db, 40);\n      expect(firstDeletedAt).toBe('2026-06-10T00:00:00.000Z');\n\n      vi.setSystemTime(new Date('2026-06-12T00:00:00.000Z'));\n      expect(parseResponse(await handleMemoryDelete({ id: 40, confirm: true })).data.deleted).toBe(1);\n      expect(parseResponse(await handleMemoryDelete({ id: 40, confirm: true })).data.deleted).toBe(1);\n\n      expect(deletedAt(db, 40)).toBe(firstDeletedAt);\n      expect((db.prepare('SELECT COUNT(*) AS count FROM memory_index WHERE id = 40').get() as { count: number }).count).toBe(1);\n    } finally {\n      vi.useRealTimers();\n    }\n  });\n\n  it('preserves the first tombstone timestamp on repeated bulk delete', async () => {\n    process.env[SOFT_DELETE_FLAG] = 'true';\n    seedMemoryRow(db, { id: 50, specFolder: SPEC_FOLDER, importanceTier: 'temporary' });\n\n    vi.useFakeTimers();\n    try {\n      vi.setSystemTime(new Date('2026-06-10T01:00:00.000Z'));\n      expect(parseResponse(await handleMemoryBulkDelete({\n        tier: 'temporary',\n        specFolder: SPEC_FOLDER,\n        confirm: true,\n        skipCheckpoint: true,\n      })).data.deleted).toBe(1);\n      const firstDeletedAt = deletedAt(db, 50);\n      expect(firstDeletedAt).toBe('2026-06-10T01:00:00.000Z');\n\n      vi.setSystemTime(new Date('2026-06-13T01:00:00.000Z'));\n      expect(parseResponse(await handleMemoryBulkDelete({\n        tier: 'temporary',\n        specFolder: SPEC_FOLDER,\n        confirm: true,\n        skipCheckpoint: true,\n      })).data.deleted).toBe(1);\n      expect(parseResponse(await handleMemoryBulkDelete({\n        tier: 'temporary',\n        specFolder: SPEC_FOLDER,\n        confirm: true,\n        skipCheckpoint: true,\n      })).data.deleted).toBe(1);\n\n      expect(deletedAt(db, 50)).toBe(firstDeletedAt);\n      expect((db.prepare('SELECT COUNT(*) AS count FROM memory_index WHERE id = 50').get() as { count: number }).count).toBe(1);\n    } finally {\n      vi.useRealTimers();\n    }\n  });\n\n  it('manual causal unlink records reason and restore metadata', async () => {\n    seedMemoryRow(db, { id: 101, specFolder: SPEC_FOLDER });\n    seedMemoryRow(db, { id: 102, specFolder: SPEC_FOLDER });\n    const edgeId = seedCausalEdge(db, {\n      sourceId: '101',\n      targetId: '102',\n      relation: 'derived_from',\n      evidence: 'manual unlink evidence',\n      createdBy: 'manual',\n    });\n    vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n    vi.spyOn(vectorIndex, 'initializeDb').mockImplementation(() => db as ReturnType<typeof vectorIndex.initializeDb>);\n    vi.spyOn(vectorIndex, 'getDb').mockReturnValue(db as ReturnType<typeof vectorIndex.getDb>);\n\n    const response = await handleMemoryCausalUnlink({ edgeId });\n    const envelope = parseResponse(response);\n\n    expect(envelope.data.deleted).toBe(true);\n    expect(activeEdgeCount(db)).toBe(0);\n\n    const [row] = tombstones(db);\n    expect(row.reason).toBe('manual causal unlink');\n    expect(row.lifecycle_generation).toBe(1);\n    const metadata = JSON.parse(row.restore_metadata);\n    expect(metadata).toMatchObject({ command: 'memory_causal_unlink' });\n    expect(metadata.edge).toMatchObject({\n      id: edgeId,\n      source_id: '101',\n      target_id: '102',\n      relation: 'derived_from',\n      evidence: 'manual unlink evidence',\n    });\n  });\n\n  it('reports orphan edges before confirmed health repair and tombstones on repair', async () => {\n    seedMemoryRow(db, { id: 201, specFolder: SPEC_FOLDER });\n    seedCausalEdge(db, {\n      sourceId: '201',\n      targetId: '999',\n      relation: 'supports',\n      evidence: 'orphan edge evidence',\n      createdBy: 'manual',\n    });\n\n    const report = parseResponse(await handleMemoryHealth({ reportMode: 'full' }));\n    expect(report.data.causalEdges.orphanedEdges).toBe(1);\n    expect(report.data.causalEdges.sample[0]).toMatchObject({\n      sourceId: '201',\n      targetId: '999',\n      sourceExists: true,\n      targetExists: false,\n    });\n    expect(activeEdgeCount(db)).toBe(1);\n    expect(tombstones(db)).toHaveLength(0);\n\n    const repaired = parseResponse(await handleMemoryHealth({\n      reportMode: 'full',\n      autoRepair: true,\n      confirmed: true,\n    }));\n\n    expect(repaired.data.causalEdges.repaired).toBe(1);\n    expect(repaired.data.causalEdges.tombstoned).toBe(1);\n    expect(activeEdgeCount(db)).toBe(0);\n    const [row] = tombstones(db);\n    expect(row.reason).toBe('orphan causal edge cleanup');\n  });\n});","lineStart":1,"lineEnd":265,"totalLines":265,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/causal-edge-tombstones.vitest.ts","time":{"start":1781762706581,"end":1781762706589}},"metadata":{"openai":{"itemId":"fc_09c9ded08b6f7f8c016a338a9272d081919d5e44ebc55e46ef"}},"id":"prt_ed9554c80001jMh3Pgysai7yds","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9551e550012uLA5CELRt7vzs"}}
{"type":"tool_use","timestamp":1781762706591,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_3T5dua3h9VyugTOxPxnERtt6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-retention-sweep.vitest.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-retention-sweep.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Tests\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: import { describe, expect, it, vi } from 'vitest';\n6: import { mkdtempSync, rmSync } from 'node:fs';\n7: import { join } from 'node:path';\n8: import { tmpdir } from 'node:os';\n9: import Database from 'better-sqlite3';\n10: \n11: import { runMemoryRetentionSweep, __retentionSweepTestables } from '../lib/governance/memory-retention-sweep';\n12: import { createMemoryIndexTestDatabase } from './fixtures/memory-index-db';\n13: \n14: const SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n15: \n16: function withSoftDeleteFlag<T>(value: string | undefined, fn: () => T): T {\n17:   const previous = process.env[SOFT_DELETE_FLAG];\n18:   if (value === undefined) {\n19:     delete process.env[SOFT_DELETE_FLAG];\n20:   } else {\n21:     process.env[SOFT_DELETE_FLAG] = value;\n22:   }\n23: \n24:   try {\n25:     return fn();\n26:   } finally {\n27:     if (previous === undefined) {\n28:       delete process.env[SOFT_DELETE_FLAG];\n29:     } else {\n30:       process.env[SOFT_DELETE_FLAG] = previous;\n31:     }\n32:   }\n33: }\n34: \n35: function isoOffset(ms: number): string {\n36:   return new Date(Date.now() + ms).toISOString();\n37: }\n38: \n39: function installSearchTables(db: ReturnType<typeof createMemoryIndexTestDatabase>): void {\n40:   db.exec(`\n41:     CREATE VIRTUAL TABLE memory_fts USING fts5(\n42:       title, trigger_phrases, file_path, content_text,\n43:       content='memory_index', content_rowid='id'\n44:     );\n45:     CREATE TRIGGER memory_fts_insert AFTER INSERT ON memory_index BEGIN\n46:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n47:       VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n48:     END;\n49:     CREATE TRIGGER memory_fts_delete AFTER DELETE ON memory_index BEGIN\n50:       INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n51:       VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n52:     END;\n53:     CREATE TABLE vec_memories (embedding BLOB);\n54:   `);\n55: }\n56: \n57: function insertMemory(\n58:   db: ReturnType<typeof createMemoryIndexTestDatabase>,\n59:   id: number,\n60:   deleteAfter: string | null,\n61:   title = `memory ${id}`,\n62: ): void {\n63:   db.prepare(`\n64:     INSERT INTO memory_index (\n65:       id, spec_folder, file_path, title, trigger_phrases, content_hash,\n66:       content_text, embedding_status, created_at, updated_at,\n67:       tenant_id, user_id, session_id, delete_after\n68:     ) VALUES (?, ?, ?, ?, ?, ?, ?, 'success', ?, ?, ?, ?, ?, ?)\n69:   `).run(\n70:     id,\n71:     'specs/test-retention',\n72:     `specs/test-retention/${id}.md`,\n73:     title,\n74:     JSON.stringify([title]),\n75:     `hash-${id}`,\n76:     `${title} content`,\n77:     isoOffset(-10_000),\n78:     isoOffset(-10_000),\n79:     'tenant-a',\n80:     'user-a',\n81:     'session-a',\n82:     deleteAfter,\n83:   );\n84: \n85:   try {\n86:     db.prepare('INSERT INTO vec_memories(rowid, embedding) VALUES (?, ?)').run(id, Buffer.from([1, 2, 3]));\n87:   } catch {\n88:     // Individual tests that do not install vec_memories do not need vector rows.\n89:   }\n90: }\n91: \n92: function memoryIds(db: ReturnType<typeof createMemoryIndexTestDatabase>): number[] {\n93:   return (db.prepare('SELECT id FROM memory_index ORDER BY id').all() as Array<{ id: number }>)\n94:     .map((row) => row.id);\n95: }\n96: \n97: describe('memory retention sweep', () => {\n98:   it('deletes expired rows and retains non-expired rows', () => {\n99:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n100:     insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n101:     insertMemory(db, 2, isoOffset(3_600_000), 'future');\n102:     insertMemory(db, 3, null, 'keep');\n103: \n104:     const result = runMemoryRetentionSweep(db);\n105: \n106:     expect(result).toMatchObject({\n107:       swept: 1,\n108:       retained: 2,\n109:       dryRun: false,\n110:       deletedIds: [1],\n111:     });\n112:     expect(memoryIds(db)).toEqual([2, 3]);\n113:   });\n114: \n115:   it('reaps expired active rows by default even when deleted_at is present', () => {\n116:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n117:     db.exec(`\n118:       ALTER TABLE memory_index ADD COLUMN deleted_at TEXT;\n119:       CREATE INDEX idx_memory_purgeable_retention\n120:         ON memory_index(delete_after, deleted_at, id)\n121:         WHERE deleted_at IS NOT NULL;\n122:     `);\n123:     insertMemory(db, 1, isoOffset(-3_600_000), 'active expired');\n124:     insertMemory(db, 2, isoOffset(-3_600_000), 'tombstoned expired');\n125:     insertMemory(db, 3, isoOffset(3_600_000), 'future');\n126:     db.prepare('UPDATE memory_index SET deleted_at = ? WHERE id = 2').run('2026-06-10T00:00:00.000Z');\n127: \n128:     const result = withSoftDeleteFlag(undefined, () => runMemoryRetentionSweep(db));\n129: \n130:     expect(result).toMatchObject({\n131:       swept: 2,\n132:       deletedIds: [1, 2],\n133:       tombstoneState: {\n134:         usesPurgeablePartition: false,\n135:         usingPurgeableIndex: false,\n136:         candidateCount: 2,\n137:         deletedCount: 2,\n138:       },\n139:     });\n140:     expect(memoryIds(db)).toEqual([3]);\n141:   });\n142: \n143:   it('uses the purgeable tombstone partition when the tombstone flag is enabled', () => {\n144:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n145:     db.exec(`\n146:       ALTER TABLE memory_index ADD COLUMN deleted_at TEXT;\n147:       CREATE INDEX idx_memory_purgeable_retention\n148:         ON memory_index(delete_after, deleted_at, id)\n149:         WHERE deleted_at IS NOT NULL;\n150:     `);\n151:     insertMemory(db, 1, isoOffset(-3_600_000), 'tombstoned expired');\n152:     insertMemory(db, 2, isoOffset(-3_600_000), 'active expired');\n153:     insertMemory(db, 3, isoOffset(3_600_000), 'future tombstone');\n154:     db.prepare('UPDATE memory_index SET deleted_at = ? WHERE id IN (1, 3)').run('2026-06-10T00:00:00.000Z');\n155: \n156:     const plan = db.prepare(`\n157:       EXPLAIN QUERY PLAN\n158:       SELECT id FROM memory_index INDEXED BY idx_memory_purgeable_retention\n159:       WHERE delete_after IS NOT NULL\n160:         AND deleted_at IS NOT NULL\n161:         AND datetime(delete_after) < datetime('now')\n162:     `).all() as Array<{ detail: string }>;\n163:     const result = withSoftDeleteFlag('true', () => runMemoryRetentionSweep(db));\n164: \n165:     expect(plan.some((row) => row.detail.includes('idx_memory_purgeable_retention'))).toBe(true);\n166:     expect(result).toMatchObject({\n167:       swept: 1,\n168:       deletedIds: [1],\n169:       tombstoneState: {\n170:         usesPurgeablePartition: true,\n171:         usingPurgeableIndex: true,\n172:         candidateCount: 1,\n173:         deletedCount: 1,\n174:       },\n175:     });\n176:     expect(memoryIds(db)).toEqual([2, 3]);\n177:   });\n178: \n179:   it('isStillExpired re-validates delete_after for the in-transaction TOCTOU guard', () => {\n180:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n181:     insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n182:     insertMemory(db, 2, isoOffset(3_600_000), 'future');\n183:     insertMemory(db, 3, null, 'never');\n184: \n185:     const { isStillExpired } = __retentionSweepTestables;\n186:     expect(isStillExpired(db, 1)).toBe(true); // past delete_after -> still expired\n187:     expect(isStillExpired(db, 2)).toBe(false); // future delete_after -> not expired\n188:     expect(isStillExpired(db, 3)).toBe(false); // null delete_after -> never expires\n189:     expect(isStillExpired(db, 999)).toBe(false); // missing row -> not expired\n190:   });\n191: \n192:   it('getCurrentExpiredRow re-reads protection metadata for the delete transaction', () => {\n193:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true, includeRetentionColumns: true });\n194:     insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n195:     db.prepare(`\n196:       UPDATE memory_index\n197:       SET importance_tier = 'critical', is_pinned = 1\n198:       WHERE id = 1\n199:     `).run();\n200: \n201:     const row = __retentionSweepTestables.getCurrentExpiredRow(db, 1);\n202: \n203:     expect(row).toMatchObject({\n204:       id: 1,\n205:       importanceTier: 'critical',\n206:       isPinned: 1,\n207:     });\n208:   });\n209: \n210:   it('dry-run returns expired candidates without mutating rows or audit tables', () => {\n211:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n212:     insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n213:     insertMemory(db, 2, isoOffset(3_600_000), 'future');\n214: \n215:     const result = runMemoryRetentionSweep(db, { dryRun: true });\n216: \n217:     expect(result.swept).toBe(0);\n218:     expect(result.retained).toBe(2);\n219:     expect(result.candidates.map((row) => row.id)).toEqual([1]);\n220:     expect(memoryIds(db)).toEqual([1, 2]);\n221:     expect(\n222:       (db.prepare('SELECT COUNT(*) AS count FROM governance_audit').get() as { count: number }).count,\n223:     ).toBe(0);\n224:   });\n225: \n226:   it('records audit rows with retention_expired reason and original delete_after', () => {\n227:     const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n228:     const deleteAfter = isoOffset(-3_600_000);\n229:     insertMemory(db, 1, deleteAfter, 'expired');\n230: \n231:     runMemoryRetentionSweep(db);\n232: \n233:     const audit = db.prepare(`\n234:       SELECT action, decision, memory_id, reason, metadata\n235:       FROM governance_audit\n236:       WHERE memory_id = 1\n237:     `).get() as {\n238:       action: string;\n239:       decision: string;\n240:       memory_id: number;\n\n(Showing lines 1-240 of 540. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Tests\n// ───────────────────────────────────────────────────────────────────\n\nimport { describe, expect, it, vi } from 'vitest';\nimport { mkdtempSync, rmSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { tmpdir } from 'node:os';\nimport Database from 'better-sqlite3';\n\nimport { runMemoryRetentionSweep, __retentionSweepTestables } from '../lib/governance/memory-retention-sweep';\nimport { createMemoryIndexTestDatabase } from './fixtures/memory-index-db';\n\nconst SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\nfunction withSoftDeleteFlag<T>(value: string | undefined, fn: () => T): T {\n  const previous = process.env[SOFT_DELETE_FLAG];\n  if (value === undefined) {\n    delete process.env[SOFT_DELETE_FLAG];\n  } else {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-retention-sweep.vitest.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Tests\n// ───────────────────────────────────────────────────────────────────\n\nimport { describe, expect, it, vi } from 'vitest';\nimport { mkdtempSync, rmSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { tmpdir } from 'node:os';\nimport Database from 'better-sqlite3';\n\nimport { runMemoryRetentionSweep, __retentionSweepTestables } from '../lib/governance/memory-retention-sweep';\nimport { createMemoryIndexTestDatabase } from './fixtures/memory-index-db';\n\nconst SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\nfunction withSoftDeleteFlag<T>(value: string | undefined, fn: () => T): T {\n  const previous = process.env[SOFT_DELETE_FLAG];\n  if (value === undefined) {\n    delete process.env[SOFT_DELETE_FLAG];\n  } else {\n    process.env[SOFT_DELETE_FLAG] = value;\n  }\n\n  try {\n    return fn();\n  } finally {\n    if (previous === undefined) {\n      delete process.env[SOFT_DELETE_FLAG];\n    } else {\n      process.env[SOFT_DELETE_FLAG] = previous;\n    }\n  }\n}\n\nfunction isoOffset(ms: number): string {\n  return new Date(Date.now() + ms).toISOString();\n}\n\nfunction installSearchTables(db: ReturnType<typeof createMemoryIndexTestDatabase>): void {\n  db.exec(`\n    CREATE VIRTUAL TABLE memory_fts USING fts5(\n      title, trigger_phrases, file_path, content_text,\n      content='memory_index', content_rowid='id'\n    );\n    CREATE TRIGGER memory_fts_insert AFTER INSERT ON memory_index BEGIN\n      INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n      VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n    END;\n    CREATE TRIGGER memory_fts_delete AFTER DELETE ON memory_index BEGIN\n      INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n      VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n    END;\n    CREATE TABLE vec_memories (embedding BLOB);\n  `);\n}\n\nfunction insertMemory(\n  db: ReturnType<typeof createMemoryIndexTestDatabase>,\n  id: number,\n  deleteAfter: string | null,\n  title = `memory ${id}`,\n): void {\n  db.prepare(`\n    INSERT INTO memory_index (\n      id, spec_folder, file_path, title, trigger_phrases, content_hash,\n      content_text, embedding_status, created_at, updated_at,\n      tenant_id, user_id, session_id, delete_after\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, 'success', ?, ?, ?, ?, ?, ?)\n  `).run(\n    id,\n    'specs/test-retention',\n    `specs/test-retention/${id}.md`,\n    title,\n    JSON.stringify([title]),\n    `hash-${id}`,\n    `${title} content`,\n    isoOffset(-10_000),\n    isoOffset(-10_000),\n    'tenant-a',\n    'user-a',\n    'session-a',\n    deleteAfter,\n  );\n\n  try {\n    db.prepare('INSERT INTO vec_memories(rowid, embedding) VALUES (?, ?)').run(id, Buffer.from([1, 2, 3]));\n  } catch {\n    // Individual tests that do not install vec_memories do not need vector rows.\n  }\n}\n\nfunction memoryIds(db: ReturnType<typeof createMemoryIndexTestDatabase>): number[] {\n  return (db.prepare('SELECT id FROM memory_index ORDER BY id').all() as Array<{ id: number }>)\n    .map((row) => row.id);\n}\n\ndescribe('memory retention sweep', () => {\n  it('deletes expired rows and retains non-expired rows', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n    insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n    insertMemory(db, 2, isoOffset(3_600_000), 'future');\n    insertMemory(db, 3, null, 'keep');\n\n    const result = runMemoryRetentionSweep(db);\n\n    expect(result).toMatchObject({\n      swept: 1,\n      retained: 2,\n      dryRun: false,\n      deletedIds: [1],\n    });\n    expect(memoryIds(db)).toEqual([2, 3]);\n  });\n\n  it('reaps expired active rows by default even when deleted_at is present', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n    db.exec(`\n      ALTER TABLE memory_index ADD COLUMN deleted_at TEXT;\n      CREATE INDEX idx_memory_purgeable_retention\n        ON memory_index(delete_after, deleted_at, id)\n        WHERE deleted_at IS NOT NULL;\n    `);\n    insertMemory(db, 1, isoOffset(-3_600_000), 'active expired');\n    insertMemory(db, 2, isoOffset(-3_600_000), 'tombstoned expired');\n    insertMemory(db, 3, isoOffset(3_600_000), 'future');\n    db.prepare('UPDATE memory_index SET deleted_at = ? WHERE id = 2').run('2026-06-10T00:00:00.000Z');\n\n    const result = withSoftDeleteFlag(undefined, () => runMemoryRetentionSweep(db));\n\n    expect(result).toMatchObject({\n      swept: 2,\n      deletedIds: [1, 2],\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 2,\n        deletedCount: 2,\n      },\n    });\n    expect(memoryIds(db)).toEqual([3]);\n  });\n\n  it('uses the purgeable tombstone partition when the tombstone flag is enabled', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n    db.exec(`\n      ALTER TABLE memory_index ADD COLUMN deleted_at TEXT;\n      CREATE INDEX idx_memory_purgeable_retention\n        ON memory_index(delete_after, deleted_at, id)\n        WHERE deleted_at IS NOT NULL;\n    `);\n    insertMemory(db, 1, isoOffset(-3_600_000), 'tombstoned expired');\n    insertMemory(db, 2, isoOffset(-3_600_000), 'active expired');\n    insertMemory(db, 3, isoOffset(3_600_000), 'future tombstone');\n    db.prepare('UPDATE memory_index SET deleted_at = ? WHERE id IN (1, 3)').run('2026-06-10T00:00:00.000Z');\n\n    const plan = db.prepare(`\n      EXPLAIN QUERY PLAN\n      SELECT id FROM memory_index INDEXED BY idx_memory_purgeable_retention\n      WHERE delete_after IS NOT NULL\n        AND deleted_at IS NOT NULL\n        AND datetime(delete_after) < datetime('now')\n    `).all() as Array<{ detail: string }>;\n    const result = withSoftDeleteFlag('true', () => runMemoryRetentionSweep(db));\n\n    expect(plan.some((row) => row.detail.includes('idx_memory_purgeable_retention'))).toBe(true);\n    expect(result).toMatchObject({\n      swept: 1,\n      deletedIds: [1],\n      tombstoneState: {\n        usesPurgeablePartition: true,\n        usingPurgeableIndex: true,\n        candidateCount: 1,\n        deletedCount: 1,\n      },\n    });\n    expect(memoryIds(db)).toEqual([2, 3]);\n  });\n\n  it('isStillExpired re-validates delete_after for the in-transaction TOCTOU guard', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n    insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n    insertMemory(db, 2, isoOffset(3_600_000), 'future');\n    insertMemory(db, 3, null, 'never');\n\n    const { isStillExpired } = __retentionSweepTestables;\n    expect(isStillExpired(db, 1)).toBe(true); // past delete_after -> still expired\n    expect(isStillExpired(db, 2)).toBe(false); // future delete_after -> not expired\n    expect(isStillExpired(db, 3)).toBe(false); // null delete_after -> never expires\n    expect(isStillExpired(db, 999)).toBe(false); // missing row -> not expired\n  });\n\n  it('getCurrentExpiredRow re-reads protection metadata for the delete transaction', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true, includeRetentionColumns: true });\n    insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n    db.prepare(`\n      UPDATE memory_index\n      SET importance_tier = 'critical', is_pinned = 1\n      WHERE id = 1\n    `).run();\n\n    const row = __retentionSweepTestables.getCurrentExpiredRow(db, 1);\n\n    expect(row).toMatchObject({\n      id: 1,\n      importanceTier: 'critical',\n      isPinned: 1,\n    });\n  });\n\n  it('dry-run returns expired candidates without mutating rows or audit tables', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n    insertMemory(db, 1, isoOffset(-3_600_000), 'expired');\n    insertMemory(db, 2, isoOffset(3_600_000), 'future');\n\n    const result = runMemoryRetentionSweep(db, { dryRun: true });\n\n    expect(result.swept).toBe(0);\n    expect(result.retained).toBe(2);\n    expect(result.candidates.map((row) => row.id)).toEqual([1]);\n    expect(memoryIds(db)).toEqual([1, 2]);\n    expect(\n      (db.prepare('SELECT COUNT(*) AS count FROM governance_audit').get() as { count: number }).count,\n    ).toBe(0);\n  });\n\n  it('records audit rows with retention_expired reason and original delete_after', () => {\n    const db = createMemoryIndexTestDatabase({ includeContentColumns: true });\n    const deleteAfter = isoOffset(-3_600_000);\n    insertMemory(db, 1, deleteAfter, 'expired');\n\n    runMemoryRetentionSweep(db);\n\n    const audit = db.prepare(`\n      SELECT action, decision, memory_id, reason, metadata\n      FROM governance_audit\n      WHERE memory_id = 1\n    `).get() as {\n      action: string;\n      decision: string;\n      memory_id: number;","lineStart":1,"lineEnd":240,"totalLines":540,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/memory-retention-sweep.vitest.ts","time":{"start":1781762706585,"end":1781762706590}},"metadata":{"openai":{"itemId":"fc_09c9ded08b6f7f8c016a338a9272d8819195e4a0382f7c032d"}},"id":"prt_ed9554c9700106ydsupspVmOVt","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9551e550012uLA5CELRt7vzs"}}
