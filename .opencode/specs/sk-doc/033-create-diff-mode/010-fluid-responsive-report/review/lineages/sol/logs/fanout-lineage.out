lineage artifacts","status":"pending","priority":"high"}],"truncated":false},"title":"4 todos","time":{"start":1784210467749,"end":1784210467751}},"metadata":{"openai":{"itemId":"fc_0a0b0e091b35f496016a58e421c26c8191a111b4e3a080a9c3"}},"id":"prt_f6b3b240c001yYiEXNfleqDz9I","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b04160016UxBur4BvbSlS2"}}
{"type":"step_finish","timestamp":1784210469590,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"id":"prt_f6b3b32d20013MosDI5QcYzffE","reason":"tool-calls","snapshot":"fe03b20dde9c4dbba7dc0e6f79ecce2c3c838fcc","messageID":"msg_f6b3b04160016UxBur4BvbSlS2","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","type":"step-finish","tokens":{"total":31760,"input":7414,"output":121,"reasoning":161,"cache":{"write":0,"read":24064}},"cost":0}}
{"type":"step_start","timestamp":1784210482125,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"id":"prt_f6b3b63c9001rnrgHMsAmIksBv","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","snapshot":"fe03b20dde9c4dbba7dc0e6f79ecce2c3c838fcc","type":"step-start"}}
{"type":"tool_use","timestamp":1784210482162,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_mn6av5hfHJptlY4YBvn21OsJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: # DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n5: # ─────────────────────────────────────────────────────────────────\n6: role: Deep Review Loop Manager\n7: purpose: Iterative code/spec review with convergence detection across review dimensions\n8: action: Run deep-review loop from initialization through synthesis\n9: operating_mode:\n10:   workflow: iterative_loop\n11:   workflow_compliance: MANDATORY\n12:   workflow_execution: autonomous\n13:   approvals: none\n14:   tracking: progressive_review_state\n15:   validation: convergence_detection\n16: \n17: # ─────────────────────────────────────────────────────────────────\n18: # OPERATING PRINCIPLES\n19: # ─────────────────────────────────────────────────────────────────\n20: operating_principles:\n21:   core: \"Fresh context per iteration + externalized state = no context degradation\"\n22:   approach: \"Dispatch focused review agent per dimension, evaluate convergence, repeat or stop\"\n23:   mandate: \"Never hold findings in memory; write everything to files. Review target is READ-ONLY.\"\n24: \n25: # ─────────────────────────────────────────────────────────────────\n26: # USER INPUTS (from setup phase)\n27: # ─────────────────────────────────────────────────────────────────\n28: user_inputs:\n29:   review_target: \"[REVIEW_TARGET] - What to review. REQUIRED.\"\n30:   review_target_type: \"[spec-folder|skill|agent|track|files] - Target type for scope derivation. REQUIRED.\"\n31:   review_dimensions: \"[all|correctness,security,traceability,maintainability] - Dimensions to check. Default: all.\"\n32:   spec_folder: \"[SPEC_FOLDER] - Spec folder path for state files. REQUIRED.\"\n33:   session_id: \"[SESSION_ID] - Optional caller-supplied session id for fan-out lineages. Default: timestamp.\"\n34:   lineage_mode: \"[auto|resume|restart] - Session lifecycle intent. Default: auto. The runtime only persists lineage events for `resume` (same sessionId, no archive) and `restart` (new sessionId, generation+1, prior review/ archived). `fork` and `completed-continue` are deferred and no longer accepted — see deep-review/references/protocol/loop_protocol.md §Lifecycle Branches.\"\n35:   max_iterations: 7\n36:   convergence_threshold: 0.10\n37:   convergence_mode: \"[default|off|sliding-window|divergent] - Convergence policy modifier. Default: default.\"\n38:   stop_policy: \"[convergence|max-iterations] - Stop behavior. Default: convergence. max-iterations treats convergence as telemetry until the hard iteration ceiling.\"\n39:   config.fanout_lineage_artifact_dir: \"[optional internal path] - Fan-out lineage artifact override for command-owned single-lineage execution.\"\n40: \n41: # ─────────────────────────────────────────────────────────────────\n42: # CONTEXT LOADING\n43: # ─────────────────────────────────────────────────────────────────\n44: context_loading:\n45:   trigger: \"At workflow START, before phase_init\"\n46:   purpose: \"Load prior review context for the target and buffer it until strategy.md exists\"\n47:   mcp_integration:\n48:     tool: memory_context\n49:     note: \"Call MCP tools directly - NEVER through Code Mode\"\n50:     parameters: { input: \"{review_target}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n51:   when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n52:   behavior:\n53:     if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n54:     if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n55: \n56: # ─────────────────────────────────────────────────────────────────\n57: # SKILL REFERENCE\n58: # ─────────────────────────────────────────────────────────────────\n59: skill_reference:\n60:   skill: system-deep-loop\n61:   skill_md: .opencode/skills/system-deep-loop/deep-review/SKILL.md\n62:   references:\n63:     loop_protocol: .opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md\n64:     state_format: .opencode/skills/system-deep-loop/deep-review/references/state/state_format.md\n65:     convergence: .opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md\n66:   templates:\n67:     config: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json\n68:     strategy: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md\n69: \n70: # ─────────────────────────────────────────────────────────────────\n71: # AGENT CONFIGURATION\n72: # ─────────────────────────────────────────────────────────────────\n73: agent_config:\n74:   agent: deep-review\n75:   agent_file: \".opencode/agents/deep-review.md\"\n76:   # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n77:   mode: subagent\n78:   model: opus\n79:   leaf_only: true\n80:   tools: [Read, Write, Edit, Bash, Grep, Glob]\n81:   mcp_servers: [mk-spec-memory]\n82:   tool_call_budget: { target: 9, soft_max: 12, hard_max: 13 }\n83: \n84: # ─────────────────────────────────────────────────────────────────\n85: # STATE FILE PATHS\n86: # ─────────────────────────────────────────────────────────────────\n87: state_paths:\n88:   # Template paths document the canonical packet layout. Runtime resolution happens via\n89:   # step_resolve_artifact_root plus the shared resolver, so root specs keep\n90:   # root-local review/ and child phases keep local review/ packet dirs.\n91:   # Canonical root-spec write targets remain review/deep-review-config.json,\n92:   # review/deep-review-state.jsonl, and review/deep-review-findings-registry.json.\n93:   packet_dir: \"{artifact_dir}\"\n94:   local_packet_dir: \"{spec_folder}/review\"\n95:   legacy_root_report: \"{spec_folder}/review-report.md\"\n96:   config: \"{artifact_dir}/deep-review-config.json\"\n97:   state_log: \"{artifact_dir}/deep-review-state.jsonl\"\n98:   findings_registry: \"{artifact_dir}/deep-review-findings-registry.json\"\n99:   strategy: \"{artifact_dir}/deep-review-strategy.md\"\n100:   dashboard: \"{artifact_dir}/deep-review-dashboard.md\"\n101:   pause_sentinel: \"{artifact_dir}/.deep-review-pause\"\n102:   lock_file: \"{artifact_dir}/.deep-review.lock\"\n103:   prompt_dir: \"{artifact_dir}/prompts\"\n104:   iteration_dir: \"{artifact_dir}/iterations\"\n105:   iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n106:   # Per-iteration structured delta stream — complement to the canonical state_log\n107:   # append. MUST contain at least one record with `type === \"iteration\"`; variants\n108:   # like `\"iteration_delta\"` are silently dropped by the reducer.\n109:   delta_dir: \"{artifact_dir}/deltas\"\n110:   delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n111:   review_output: \"{artifact_dir}/review-report.md\"\n112:   resource_map_output: \"{artifact_dir}/resource-map.md\"\n113:   archive_root: \"{artifact_archive_root}\"\n114: \n115: # ─────────────────────────────────────────────────────────────────\n116: # WORKFLOW\n117: # ─────────────────────────────────────────────────────────────────\n118: workflow:\n119: \n120:   step_resolve_artifact_root:\n121:     description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n122:     note: \"Root specs keep review artifacts directly in {spec_folder}/review/. Child phases and sub-phases keep local packet directories in {spec_folder}/review/{packet}/, and archives stay local at {spec_folder}/review_archive/{packet}/.\"\n123:     branch_on: \"config.fanout_lineage_artifact_dir\"\n124:     if_present:\n125:       bind:\n126:         artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n127:         artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n128:         artifact_subfolder: null\n129:         artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n130:     if_absent:\n131:       command: \"node -e \\\"const { resolveArtifactRoot } = require('.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'review')));\\\"\"\n132:       outputs:\n133:         - artifact_root_dir: \"Resolved local review owner directory\"\n134:         - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n135:         - artifact_dir: \"Resolved review packet directory for this target\"\n136:         - artifact_archive_root: \"Resolved local review archive directory for this target\"\n137: \n138:   step_bind_reducer_artifact_arg:\n139:     description: \"Keep the reducer on the lineage-owned artifact directory during fan-out\"\n140:     branch_on: \"config.fanout_lineage_artifact_dir\"\n141:     if_present:\n142:       bind:\n143:         reducer_artifact_arg: \"--artifact-dir {artifact_dir}\"\n144:     if_absent:\n145:       bind:\n146:         reducer_artifact_arg: \"\"\n147: \n148:   step_apply_lifecycle_request:\n149:     description: \"Honor explicit auto-mode restart before fan-out or normal initialization\"\n150:     skip_when: \"lineage_mode != 'restart'\"\n151:     instructions: |\n152:       This is the autonomous equivalent of the confirm-mode restart choice. Run it\n153:       immediately after artifact resolution and before fan-out so old packet files\n154:       cannot be merged with fresh lineage outputs. A restart request must never\n155:       fall back to auto-resume. In auto mode, the explicit restart flag is operator\n156:       authorization to archive the resolved review packet, so do not ask for a\n157:       second confirmation. Rollback is to move the timestamped archive back to\n158:       the packet directory.\n159:     command: \"if [ -d \\\"{state_paths.packet_dir}\\\" ]; then mkdir -p \\\"{state_paths.archive_root}\\\" && mv \\\"{state_paths.packet_dir}\\\" \\\"{state_paths.archive_root}/{timestamp_slug}\\\"; fi; mkdir -p \\\"{state_paths.packet_dir}\\\"\"\n160:     outputs:\n161:       - archived_path: \"{state_paths.archive_root}/{timestamp_slug} when a prior packet existed, else null\"\n162:       - lineage_mode: \"restart\"\n163:     on_fail: \"Halt with STATUS=FAIL; do not continue as resume or auto.\"\n164: \n165:   step_fanout_spawn:\n166:     description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n167:     skip_when: \"config.fanout is absent\"\n168:     instructions: |\n169:       Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n170:       isolated sub-packet under {artifact_dir}/lineages/{label}/.\n171:       A cli-opencode lineage inside this fan-out is an explicit parallel-detached OpenCode\n172:       session with a separate lineage directory and session id; it is not the single-executor\n173:       self-invocation path. fanout-run.cjs owns the stack-only recursion guard for that\n174:       first-level detached lineage and still blocks recursive same-kind dispatch from inside it.\n175:       fanout-run.cjs owns native and CLI lineage execution; native is run through the\n176:       deep/review command surface with config.fanout_lineage_artifact_dir so the LEAF\n177:       deep-review agent is used only for individual iterations, never as a full-loop\n178:       sub-agent or pasted phase-running prompt.\n179:       After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n180:       phase_main_loop entirely (those are the single-executor path). The merge step in\n181:       phase_synthesis will consolidate results across all lineages.\n182:     sub_steps:\n183:       step_fanout_spawn_cli:\n184:         description: \"Spawn all native and CLI lineages in capped worker pool\"\n185:         skip_when: \"no entries in config.fanout.executors\"\n186:         command: |\n187:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs \\\n188:             --spec-folder {spec_folder} \\\n189:             --loop-type review \\\n190:             --fanout-config-json '{config.fanout_json}' \\\n191:             --base-artifact-dir {artifact_dir} \\\n192:             --convergence-threshold {convergence_threshold} \\\n193:             --stop-policy {stop_policy}\n194:         working_directory: \"{repo_root}\"\n195:         wait_for_completion: true\n196: \n197:   # ═══════════════════════════════════════════════════════════════\n198:   # PHASE 1: INITIALIZATION\n199:   # ═══════════════════════════════════════════════════════════════\n200:   phase_init:\n201:     purpose: Create all state files for the review session and resolve review scope\n202:     steps:\n203: \n204:       step_preflight_contract:\n205:         action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n206:         verify:\n207:           - required_values_present: [review_target, review_target_type, review_dimensions, spec_folder, lineage_mode, max_iterations, convergence_threshold, convergence_mode, stop_policy]\n208:           - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n209:           - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n210:           - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n211:         on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n212: \n213:       step_create_directories:\n214:         action: \"Create spec folder and canonical review packet directories if they don't exist\"\n215:         command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n216: \n217:       step_detect_resource_map:\n218:         action: \"Detect resource-map.md before config creation so init can persist coverage-gate state\"\n219:         inspect:\n220:           - \"{spec_folder}/resource-map.md\"\n221:         classify:\n222:           present: \"resource-map.md exists at init\"\n223:           absent: \"resource-map.md does not exist at init\"\n224:         outputs:\n225:           - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n226:           - resource_map_known_context: \"When present: concise resource-map snapshot for Known Context and charter framing. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n227: \n228:       step_migrate_legacy_review_state:\n229:         action: \"Rehome legacy review artifacts into review/iterations before session classification\"\n230:         detect:\n231:           canonical_review_state:\n232:             - \"{state_paths.config}\"\n233:             - \"{state_paths.state_log}\"\n234:             - \"{state_paths.findings_registry}\"\n235:             - \"{state_paths.strategy}\"\n236:           legacy_review_state:\n237:             - \"{spec_folder}/scratch/deep-research-config.json\"\n238:             - \"{spec_folder}/scratch/deep-research-state.jsonl\"\n239:             - \"{spec_folder}/scratch/deep-review-strategy.md\"\n240:             - \"{spec_folder}/scratch/deep-review-dashboard.md\"\n241:             - \"{spec_folder}/scratch/iteration-*.md\"\n242:             - \"{spec_folder}/scratch/.deep-research-pause\"\n243:             - \"{state_paths.local_packet_dir}/iteration-*.md\"\n244:             - \"{state_paths.legacy_root_report}\"\n245:           legacy_review_markers:\n246:             - \"scratch/deep-review-strategy.md exists\"\n247:             - \"scratch/deep-research-config.json declares mode == 'review' OR scratch/deep-research-state.jsonl contains mode == 'review'\"\n248:         migrate_only:\n249:           - \"{spec_folder}/scratch/deep-research-config.json -> {state_paths.config}\"\n250:           - \"{spec_folder}/scratch/deep-research-state.jsonl -> {state_paths.state_log}\"\n251:           - \"{spec_folder}/scratch/deep-review-strategy.md -> {state_paths.strategy}\"\n252:           - \"{spec_folder}/scratch/deep-review-dashboard.md -> {state_paths.dashboard}\"\n253:           - \"{spec_folder}/scratch/iteration-*.md -> {state_paths.iteration_dir}/\"\n254:           - \"{spec_folder}/scratch/.deep-research-pause -> {state_paths.pause_sentinel}\"\n255:           - \"{state_paths.local_packet_dir}/iteration-*.md -> {state_paths.iteration_dir}/\"\n256:           - \"{state_paths.legacy_root_report} -> {state_paths.review_output}\"\n257:         on_canonical_present: \"Leave canonical review/ state untouched and do not overwrite it with legacy scratch artifacts.\"\n258:         on_legacy_detected: \"Move only the review-specific whitelist, append a migration event to the canonical JSONL, and leave unrelated scratch files untouched.\"\n259:         on_conflict: \"If canonical review/ state and legacy scratch review state both exist but disagree, halt for operator repair instead of merging contradictory state.\"\n260:         command: \"mkdir -p {state_paths.iteration_dir} && if [ ! -e {state_paths.config} ] && [ ! -e {state_paths.state_log} ] && [ ! -e {state_paths.strategy} ] && [ -e {spec_folder}/scratch/deep-review-strategy.md ] && ( [ -e {spec_folder}/scratch/deep-research-config.json ] || [ -e {spec_folder}/scratch/deep-research-state.jsonl ] ); then [ -e {spec_folder}/scratch/deep-research-config.json ] && mv {spec_folder}/scratch/deep-research-config.json {state_paths.config}; [ -e {spec_folder}/scratch/deep-research-state.jsonl ] && mv {spec_folder}/scratch/deep-research-state.jsonl {state_paths.state_log}; [ -e {spec_folder}/scratch/deep-review-strategy.md ] && mv {spec_folder}/scratch/deep-review-strategy.md {state_paths.strategy}; [ -e {spec_folder}/scratch/deep-review-dashboard.md ] && mv {spec_folder}/scratch/deep-review-dashboard.md {state_paths.dashboard}; find {spec_folder}/scratch -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; ; [ -e {spec_folder}/scratch/.deep-research-pause ] && mv {spec_folder}/scratch/.deep-research-pause {state_paths.pause_sentinel}; [ -e {state_paths.legacy_root_report} ] && mv {state_paths.legacy_root_report} {state_paths.review_output}; if [ -e {state_paths.state_log} ]; then printf '%s\\n' '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"migration\\\",\\\"mode\\\":\\\"review\\\",\\\"legacyArtifacts\\\":[\\\"deep-research-config.json\\\",\\\"deep-research-state.jsonl\\\",\\\".deep-research-pause\\\"],\\\"canonicalArtifacts\\\":[\\\"deep-review-config.json\\\",\\\"deep-review-state.jsonl\\\",\\\".deep-review-pause\\\"],\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\"}' >> {state_paths.state_log}; fi; fi; find {state_paths.local_packet_dir} -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; 2>/dev/null || true\"\n261: \n262:       step_acquire_lock:\n263:         action: \"Acquire the single-writer advisory lock before session classification\"\n264:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n265:         on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-review run already holds this packet.\"\n266:         note: \"Uses the promoted runtime/ loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n267:         # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n268:         # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n269:         on_halt:\n270:           action: \"Release the lock before any terminal halt branch returns control\"\n271:           applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\"]\n272:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n273:         on_cancel:\n274:           action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n275:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n276:         on_workflow_exit:\n277:           action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n278:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n279: \n280:       step_classify_session:\n281:         action: \"Classify the session before writing files\"\n282:         inspect:\n283:           - \"{state_paths.config}\"\n284:           - \"{state_paths.state_log}\"\n285:           - \"{state_paths.findings_registry}\"\n286:           - \"{state_paths.strategy}\"\n287:         classify:\n288:           fresh: \"None of the three state artifacts exist\"\n289:           resume: \"Config, JSONL, and strategy all exist and config.mode == 'review' and agree on target/spec folder\"\n290:           completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n291:           invalid-state: \"Any partial, missing, or contradictory combination\"\n292:         outputs:\n293:           - session_state: \"fresh | resume | completed-session | invalid-state\"\n294:         lifecycle_routing:\n295:           - \"If lineage_mode == restart and session_state is resume or completed-session, execute on_restart before on_resume or on_completed_session.\"\n296:           - \"If lineage_mode == auto or lineage_mode == resume, preserve the existing resume/completed/fresh behavior.\"\n297:         on_resume:\n298:           log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n299:           append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n300:           skip_to: phase_loop\n301:         on_restart:\n302:           action: \"Archive the current review packet under the root-level review_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n303:           command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n304:           set:\n305:             lineage_mode: \"restart\"\n306:             parent_session_id: \"{prior_session_id}\"\n307:             generation: \"{prior_generation + 1}\"\n308:           append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n309:           skip_to: step_create_config\n310:         note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-review/references/protocol/loop_protocol.md §Lifecycle Branches for the one-session contract.\"\n311:         on_completed_session:\n312:           log: \"Prior session already completed. Either archive the completed review/ tree and start a fresh session, or jump straight to synthesis with the existing artifacts.\"\n313:           skip_to: phase_synthesis\n314:         on_invalid_state:\n315:           halt: true\n316:           message: \"Existing deep-review state in review/ is incomplete or contradictory. Repair or archive the invalid review packet before continuing.\"\n317:         on_fresh:\n318:           action: \"Proceed with a new session\"\n319: \n320:       step_scope_discovery:\n321:         action: \"Resolve review target to a concrete file list based on target type\"\n322:         resolve:\n323:           spec-folder: |\n324:             1. Inspect spec.md, plan.md, tasks.md, checklist.md, implementation-summary.md, and goal-file-manifest.txt when present\n325:             2. If goal-file-manifest.txt exists, parse one repo-relative path per non-empty, non-comment line; reject absolute paths, traversal outside repo_root, duplicates, missing paths, and non-file entries\n326:             3. Fail before dispatch with line-numbered validation errors when any manifest entry is invalid; otherwise set scope = the validated manifest paths in declared order\n327:             4. When no manifest exists, discover implementation files referenced in the canonical spec artifacts\n328:             5. Discover test files associated with the implementation files\n329:             6. Set scope = all discovered implementation and test files\n330:           skill: |\n331:             1. Read SKILL.md from .opencode/skills/{skill_name}/\n332:             2. Discover references/, assets/, scripts/ contents\n333:             3. Find agent definitions referencing this skill across runtimes\n334:             4. Find command entry points referencing this skill\n335:             5. Set scope = all discovered files\n336:           agent: |\n337:             1. Find agent definition across repo-managed runtimes (.claude/agents/, .opencode/agents/)\n338:             2. Compare agent definitions for consistency\n339:             3. Set scope = all discovered agent files\n340:           track: |\n341:             1. List all child spec folders under specs/{track}/ or .opencode/specs/{track}/\n342:             2. For each: read spec.md + checklist.md\n343:             3. Set scope = all child spec artifacts\n344:           files: |\n345:             1. Expand glob patterns from review_target\n346:             2. Validate all files exist\n347:             3. Discover immediate cross-references (imports, links)\n348:             4. Set scope = expanded file list + cross-references\n349:         outputs:\n350:           - review_scope_files: \"List of all files in review scope\"\n351:           - cross_reference_targets: \"{ spec_paths: [...], code_paths: [...], test_paths: [...] }\"\n352: \n353:       step_order_dimensions:\n354:         action: \"Order review dimensions based on risk priority\"\n355:         algorithm: |\n356:           1. Iteration 0 (inventory pass): Build artifact map, identify file types, estimate complexity\n357:           2. Subsequent iterations follow risk-ordered deep passes:\n358:              correctness → security → traceability → maintainability\n359:           3. If review_dimensions != \"all\", filter to only requested dimensions\n360:           4. Derive traceability protocol plan:\n361:              - core: spec_code, checklist_evidence\n362:              - overlay: skill_agent, agent_cross_runtime, feature_catalog_code, playbook_capability\n363:           5. If resource_map_present, reserve at least one traceability-oriented pass to cross-check target_files from applied/T-*.md against resource-map.md and classify touched / expected-by-scope / gap / absent-from-map outcomes\n364:           6. Store ordered list as dimension_queue\n365:         outputs:\n366:           - dimension_queue: \"Ordered list of dimensions to review\"\n367:           - inventory_pass: true\n368: \n369:       step_normalize_review_dimensions:\n370:         action: \"Normalize reviewDimensions once during init for config + JSONL reuse\"\n371:         outputs:\n372:           - review_dimensions_normalized: \"Canonical string[] for deep-review-config.json\"\n373:           - review_dimensions_json: \"JSON.stringify(review_dimensions_normalized) for JSONL config record\"\n374:         normalize: |\n375:           Accept {review_dimensions} in any of these shapes and convert once:\n376:             - \"all\" → [\"correctness\",\"security\",\"traceability\",\"maintainability\"]\n377:             - \"correctness,security\" → [\"correctness\",\"security\"]\n378:             - [\"correctness\"] → [\"correctness\"]\n379:           Every element MUST be one of the four canonical dimension names.\n380: \n381:       step_resolve_session_id:\n382:         action: \"Resolve init session id from caller when supplied, else preserve timestamp fallback\"\n383:         branch_on: \"session_id\"\n384:         if_present:\n385:           bind:\n386:             session_id_init: \"{session_id}\"\n387:         if_absent:\n388:           bind:\n389:             session_id_init: \"{ISO_8601_NOW}\"\n390: \n391:       step_create_config:\n392:         action: \"Create deep-review-config.json from template with review-specific fields\"\n393:         template: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json\n394:         populate:\n395:           topic: \"Review: {review_target}\"\n396:           mode: \"review\"\n397:           sessionId: \"{session_id_init}\"\n398:           parentSessionId: null\n399:           lineageMode: \"new\"\n400:           generation: 1\n401:           continuedFromRun: null\n402:           reviewTarget: \"{review_target}\"\n403:           reviewTargetType: \"{review_target_type}\"\n404:           # Reuse the single normalized init-time value from step_normalize_review_dimensions.\n405:           reviewDimensions: \"{review_dimensions_normalized}\"\n406:           resource_map_present: \"{resource_map_present}\"\n407:           reviewScopeFiles: \"{review_scope_files}\"\n408:           severityThreshold: \"P2\"\n409:           crossReference:\n410:             core: [\"spec_code\", \"checklist_evidence\"]\n411:             overlay: [\"skill_agent\", \"agent_cross_runtime\", \"feature_catalog_code\", \"playbook_capability\"]\n412:           maxIterations: \"{max_iterations}\"\n413:           # Semantic: weighted P0/P1/P2 severity ratio. See SKILL.md §\"Convergence Threshold Semantics\".\n414:           convergenceThreshold: \"{convergence_threshold}\"\n415:           antiConvergence.convergenceMode: \"{convergence_mode}\"\n416:           antiConvergence.divergent: {}\n417:           stopPolicy: \"{stop_policy}\"\n418:           stuckThreshold: 2\n419:           maxDurationMinutes: 120\n420:           specFolder: \"{spec_folder}\"\n421:           # Honor the parsed --no-resource-map flag from deep-review.md:71 (default true; false when flag is set).\n422:           # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n423:           resource_map.emit: \"{resource_map_emit}\"\n424:           createdAt: \"{ISO_8601_NOW}\"\n425:           status: \"initialized\"\n426:           releaseReadinessState: \"in-progress\"\n427:           executionMode: \"auto\"\n428:         output: \"{state_paths.config}\"\n429: \n430:       step_create_state_log:\n431:         action: \"Initialize JSONL state log with config record including review fields and lineage metadata\"\n432:         note: \"Reuse review_dimensions_json from step_normalize_review_dimensions. Never re-normalize or wrap the raw template value.\"\n433:         # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n434:         content: '{\"type\":\"config\",\"mode\":\"review\",\"reviewTarget\":\"{review_target}\",\"reviewTargetType\":\"{review_target_type}\",\"reviewDimensions\":{review_dimensions_json},\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"sessionId\":\"{session_id_init}\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":{max_iterations},\"convergenceThreshold\":{convergence_threshold},\"antiConvergence\":{\"convergenceMode\":\"{convergence_mode}\",\"divergent\":{}},\"stopPolicy\":\"{stop_policy}\",\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\"}'\n435:         output: \"{state_paths.state_log}\"\n436: \n437:       step_create_findings_registry:\n438:         action: \"Initialize reducer-owned review findings registry\"\n439:         content: '{\"sessionId\":\"{session_id_init}\",\"generation\":1,\"lineageMode\":\"new\",\"openFindings\":[],\"resolvedFindings\":[],\"repeatedFindings\":[],\"dimensionCoverage\":{\"correctness\":false,\"security\":false,\"traceability\":false,\"maintainability\":false},\"findingsBySeverity\":{\"P0\":0,\"P1\":0,\"P2\":0},\"openFindingsCount\":0,\"resolvedFindingsCount\":0,\"convergenceScore\":0.0}'\n440:         output: \"{state_paths.findings_registry}\"\n441: \n442:       step_create_strategy:\n443:         action: \"Create review strategy file from deep_review_strategy.md template\"\n444:         template: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md\n445:         populate:\n446:           review_target: \"{review_target}\"\n447:           review_target_type: \"{review_target_type}\"\n448:           dimensions: \"{dimension_queue}\"\n449:           scope_files: \"{review_scope_files}\"\n450:           cross_reference_targets: \"{cross_reference_targets}\"\n451:           max_iterations: \"{max_iterations}\"\n452:           convergence_threshold: \"{convergence_threshold}\"\n453:           stop_policy: \"{stop_policy}\"\n454:         output: \"{state_paths.strategy}\"\n455: \n456:       step_seed_coverage_graph:\n457:         action: \"Seed the review coverage graph before the first convergence check\"\n458:         transform: |\n459:           1. Convert review_scope_files into FILE nodes.\n460:           2. Convert review target groupings into coarse SLICE nodes only; do not expand SYMBOL\n461:              or DEPENDENCY nodes in review mode.\n462:           3. Emit COVERS edges from SLICE nodes to FILE nodes when the grouping is known.\n463:           4. Bind coverage_seed_source to \"scope_discovery\" and coverage_seed_confidence to 0.50.\n464:           5. When scope discovery yields no files, emit [] for both arrays; the upsert script\n465:              returns a warning and review continues with an empty graph.\n466:         bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{config.sessionId}\\\" --nodes '{coverage_seed_nodes_json}' --edges '{coverage_seed_edges_json}' --seed-source \\\"{coverage_seed_source}\\\" --seed-confidence \\\"{coverage_seed_confidence}\\\"\"\n467:         outputs:\n468:           - coverage_seed_nodes_json: \"Seed nodes for review SLICE and FILE kinds only\"\n469:           - coverage_seed_edges_json: \"Seed COVERS edges where review target groupings resolved\"\n470:           - coverage_seed_warning: \"Warning emitted when the seed batch inserts zero nodes, else empty\"\n471:         on_warning:\n472:           log: \"Coverage graph seed inserted zero nodes; continuing with an empty graph.\"\n473:           proceed: true\n474: \n475:       step_enrich_strategy_context:\n476:         action: \"Ensure Known Context is written only after strategy.md exists\"\n477:         condition: \"prior_context_found\"\n478:         edit: \"{state_paths.strategy}\"\n479:         note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n480: \n481:       step_enrich_strategy_resource_map:\n482:         action: \"Inject resource-map status into Known Context after strategy.md exists\"\n483:         edit: \"{state_paths.strategy}\"\n484:         note: \"When resource_map_present is true, append the resource_map_known_context snapshot and add Resource Map Coverage to the Review Charter. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n485: \n486:       step_init_complete:\n487:         log: \"Initialization complete. Config, state, and strategy files created. Review scope: {review_scope_files_count} files, {dimension_queue_count} dimensions.\"\n488:         set: { current_iteration: 1, stuck_count: 0, p0_count: 0, p1_count: 0, p2_count: 0 }\n489: \n490:   # ═══════════════════════════════════════════════════════════════\n491:   # PHASE 2: ITERATION LOOP\n492:   # ═══════════════════════════════════════════════════════════════\n493:   phase_loop:\n494:     purpose: Dispatch review agent iterations until convergence\n495:     repeat: true\n496:     max_repeats: \"{max_iterations}\"\n497:     steps:\n498: \n499:       step_read_state:\n500:         action: \"Read current state from JSONL, strategy, and config\"\n501:         read:\n502:           - \"{state_paths.state_log}\"\n503:           - \"{state_paths.findings_registry}\"\n504:           - \"{state_paths.strategy}\"\n505:           - \"{state_paths.config}\"\n506:         extract:\n507:           - iteration_count: \"Count lines where type === 'iteration'\"\n508:           - current_iteration: \"iteration_count + 1\"\n509:           - last_newFindingsRatio: \"Extract newFindingsRatio from last iteration record\"\n510:           - last_focus: \"Extract focus/dimension from latest iteration record, else 'none yet'\"\n511:           - ratio_prev: \"Extract newFindingsRatio from second-latest iteration record, else 'N/A'\"\n512:           - ratio_latest: \"Extract newFindingsRatio from latest iteration record, else 'N/A'\"\n513:           - next_dimension: \"Next uncovered dimension from dimension_queue in strategy.md\"\n514:           - dimensions_covered: \"List of dimensions already reviewed\"\n515:           - dimensions_remaining: \"List of dimensions not yet reviewed\"\n516:           - dimension_coverage: \"covered / total dimensions\"\n517:           - coverage_age: \"Iterations since dimension coverage last changed; require >= 1 before STOP\"\n518:           - p0_count: \"Count P0 findings across all iterations\"\n519:           - p1_count: \"Count P1 findings across all iterations\"\n520:           - p2_count: \"Count P2 findings across all iterations\"\n521:           - resource_map_present: \"Extract boolean from deep-review-config.json, default false\"\n522:           - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource Map Coverage: cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md and classify only missed coverage as gaps.' Else return 'Resource Map Coverage: resource-map.md not present; skipping coverage gate.'\"\n523:           - session_id: \"Extract sessionId from deep-review-config.json\"\n524:           - generation: \"Extract generation from deep-review-config.json, else 1\"\n525:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: dimension (ratio, P0/P1/P2)'\"\n526:           - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n527:           - last_claim_adjudication_passed: \"Scan state.jsonl for the most recent `claim_adjudication` event; use its `passed` boolean. Default true when no event exists or when activeP0 + activeP1 == 0 (gate is vacuous without adjudicable findings).\"\n528:           - claim_adjudication_active_count: \"Count of active P0/P1 findings at the time of the last claim_adjudication event; 0 when none exist\"\n529:           - security_sensitive_fix_scope: \"Boolean true when the current review is a rerun after fixes involving security, path disclosure, auth/authz, sandboxing, env precedence, public schemas, persistence, or user-visible error payloads; derive from the latest review report, remediation notes, or planning packet when present, else false.\"\n530:           - fix_completeness_replay_required_rows: \"Count prior active or remediated P0/P1 findings, plus any prior security/path P2 findings, that require closed-gate replay before STOP.\"\n531:           - fix_completeness_replay_passing_rows: \"Count required replay rows marked PASS with file:line or command evidence and producer/consumer/matrix coverage.\"\n532:           - stop_policy: \"Extract stopPolicy from deep-review-config.json, default 'convergence'. Valid values: convergence, max-iterations.\"\n533:           - convergence_mode: \"Extract antiConvergence.convergenceMode when it is one of 'default', 'off', 'sliding-window', or 'divergent'; default to 'default'\"\n534:           - convergence_mode_warning: \"Boolean true when antiConvergence.convergenceMode is present with an unsupported value; use 'default'\"\n535:           - pivot_lineage: \"Summarize registry.divergence.completed and registry.divergence.overrides with pivot ids, source iterations, and selected review direction; else 'none yet'\"\n536:           - saturated_directions: \"List registry.divergence.saturatedDirections; else 'none yet'\"\n537: \n538:       step_check_pause_sentinel:\n539:         action: \"Check for pause sentinel file\"\n540:         check: \"Does {state_paths.pause_sentinel} exist?\"\n541:         if_exists:\n542:           set:\n543:             pending_stop_event: \"paused\"\n544:             pending_stop_reason: \"userPaused\"\n545:             pending_stop_detail: \"sentinel file detected\"\n546:           skip_to: step_normalize_pause_events\n547:         if_not_exists:\n548:           proceed: true\n549: \n550:       step_validate_convergence_config:\n551:         action: \"Validate convergence mode when loading config\"\n552:         if_convergence_mode_invalid:\n553:           append_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"review\",\"field\":\"antiConvergence.convergenceMode\",\"fallback\":\"default\",\"message\":\"Unsupported convergenceMode; using default convergence behavior.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n554:           log: \"Unsupported convergenceMode; using default convergence behavior.\"\n555: \n556:       step_graph_convergence:\n557:         action: \"Evaluate coverage-graph convergence before the inline review convergence vote\"\n558:         inspect:\n559:           - \"{state_paths.state_log}\"\n560:           - \"{state_paths.findings_registry}\"\n561:         transform: |\n562:           1. Call graph convergence on the current review lineage before the inline 3-signal vote.\n563:           2. Record the decision as one of CONTINUE, STOP_ALLOWED, STOP_BLOCKED.\n564:           3. Preserve raw graph signals and blockers for reducer rollup and blocked-stop evidence.\n565:           4. Normalize blockers to both JSON array and CSV forms for downstream stop handling.\n566:           5. Set graph_stop_blocked = true only when graph_decision == \"STOP_BLOCKED\".\n567:         bash: 'node .opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"review\" --session-id \"{session_id}\" --convergence-mode \"{convergence_mode}\"'\n568:         note: \"Invoke the runtime script directly. Review-side graph convergence must run before the inline review stop vote.\"\n569:         append_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"review\",\"run\":{current_iteration},\"decision\":\"{graph_decision}\",\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n570:         outputs:\n571:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED\"\n572:           - graph_signals_json: \"JSON object returned by convergence.cjs\"\n573:           - graph_blockers_json: \"JSON array of graph blockers when present, else []\"\n574:           - graph_blockers_csv: \"Comma-separated blocker summary when graph blocks STOP, else empty string\"\n575:           - graph_stop_blocked: \"Boolean true when graph_decision == STOP_BLOCKED\"\n576: \n577:       step_check_convergence:\n578:         action: \"Evaluate graph-assisted review stop conditions and the legal-stop decision tree\"\n579:         algorithm: |\n580:           0. CLAIM-ADJUDICATION PRE-CHECK (universal STOP veto; runs before hard stops and composite convergence):\n581:              claim_adjudication_gate_pass = (last_claim_adjudication_passed != false) OR (p0_count + p1_count == 0)\n582:              If claim_adjudication_gate_pass == false:\n583:                candidate_decision = \"BLOCKED\"\n584:                stop_blocked = true\n585:                stopReason = \"blockedStop\"\n586:                blocked_gates = [\"claimAdjudicationGate\"]\n587:                recovery_strategy = \"Reviewer must add typed claim-adjudication packets (claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger) for every active P0/P1 finding before STOP is allowed.\"\n588:                Skip hard stops (1) and composite convergence (4); proceed directly to step 5 legal-stop decision-tree assembly so blocked_by_json, gate outputs, and the blocked_stop event still populate consistently.\n589:           1. HARD STOPS:\n590:              a) if iteration_count >= max_iterations: set decision = \"STOP\", stopReason = \"maxIterationsReached\", hard_stop_reason = \"max_iterations_reached\", preserve any failed legal-stop gates as terminal evidence, and proceed to synthesis without legal-stop veto\n591:              b) if stop_policy == \"max-iterations\" AND iteration_count < max_iterations: do not allow all-dimensions-clean or composite convergence to stop; treat convergence signals as telemetry, set decision = \"CONTINUE\", and broaden the next review angle.\n592:              c) if all dimensions clean AND required traceability protocols are covered AND p0_count == 0 AND p1_count == 0 AND coverage_age >= 1 AND all quality gates pass (evidence: every P0/P1 has file:line; scope: all findings within target; coverage: all dimensions reviewed): mark hard_stop_reason = \"all_dimensions_clean\" and promote to STOP candidate\n593:              Operator stop reasons (`maxIterationsReached`, `manualStop`, `userPaused`, unrecoverable `error`) are terminal ceilings. They do not hide failed gates; they record them in synthesis and stop dispatch.\n594:           2. STUCK DETECTION (threshold 2):\n595:              if stuck_count >= 2: STUCK_RECOVERY\n596:           3. GRAPH CONVERGENCE PREREQUISITE:\n597:                graph_decision, graph_signals_json, and graph_blockers_json are already populated by step_graph_convergence.\n598:                Final STOP is never legal unless the inline review vote says STOP AND graph_decision == \"STOP_ALLOWED\".\n599:                If graph_decision == \"STOP_BLOCKED\", set stop_blocked = true and route through blocked_stop emission instead of stopping.\n600:           4. COMPOSITE CONVERGENCE (3-signal weighted vote with split thresholds):\n601:                signals = []\n602:                a) Rolling average (w=0.30, window=2, needs 2+ iterations):\n603:                   avg = mean(last 2 newFindingsRatios)\n604:                   stop if avg <= 0.08\n605:                b) MAD noise floor (w=0.25, needs 3+ iterations):\n606:                   noiseFloor = MAD(all ratios) * 1.4826\n607:                   stop if latest ratio <= noiseFloor\n608:                c) Dimension coverage (w=0.45):\n609:                   coverage = dimensions_covered / total_dimensions\n610:                   stop if coverage >= 1.0 AND required traceability protocols are covered AND coverage_age >= 1\n611:                Redistribute weights for unavailable signals.\n612:                if latest ratio <= 0.05: mark no_progress_threshold_reached\n613:                if stop_policy == \"max-iterations\" AND iteration_count < max_iterations: convergence votes are telemetry only; set weighted_stop_score for diagnostics, keep decision = \"CONTINUE\", and choose a broader next focus.\n614:                else if weighted_stop_score >= 0.60: inline STOP becomes a candidate and binary gates must run\n615:           5. LEGAL-STOP DECISION TREE (review-specific gates; runs whenever step 0, all-dimensions-clean, or the composite vote promotes STOP to a candidate; terminal max-iteration/manual/error stops bypass veto and record failed gates as evidence):\n616:                a) convergenceGate: pass when a hard-stop condition is met OR weighted_stop_score >= 0.60; record score\n617:                b) dimensionCoverageGate: pass when configured dimensions and required traceability coverage are complete and coverage_age >= 1; record covered and missing dimensions\n618:                c) p0ResolutionGate: pass when activeP0 == 0; record activeP0\n619:                d) evidenceDensityGate: pass when every active P0/P1 has concrete file:line evidence and no active P0/P1 relies only on inference; record avgEvidencePerFinding\n620:                e) hotspotSaturationGate: pass when review hotspots have been revisited enough times to satisfy the saturation heuristic\n621:                f) claimAdjudicationGate: pass when claim_adjudication_gate_pass == true (i.e. last_claim_adjudication_passed != false OR there are no active P0/P1 findings to adjudicate); record last_claim_adjudication_passed and claim_adjudication_active_count\n622:                g) fixCompletenessReplayGate: pass when security_sensitive_fix_scope == false OR every required closed-gate replay row passes with file:line or command evidence and producer/consumer/matrix coverage; record security_sensitive_fix_scope, fix_completeness_replay_required_rows, and fix_completeness_replay_passing_rows\n623:                h) candidateCoverageGate: skip entirely when `reviewDepthSchemaVersion` is not 2 on the latest iteration. Otherwise pass when the current iteration's `reviewDepthApplicability.scopeClass` is `trivial` with `enforcement: \"skip\"` AND `reviewDepthApplicability.evidenceRefs` is non-empty, OR when the reducer registry's `searchDebt` is empty AND `candidateCoverage.covered` is a superset of `searchCoverage.requiredBugClasses` for the lineage. Otherwise pass = false; record `searchDebt` items as blocked-stop evidence; blocker name = \"candidateCoverageGate\"; recovery_strategy = \"Resolve deferred/blocked obligations in next iteration or downgrade scope explicitly to trivial with cited evidence.\"\n624:                i) graphlessFallbackGate: skip when `reviewDepthSchemaVersion` is not 2 OR the reducer registry's last-iteration `searchCoverage.graphCoverageMode` is `graph`. Applies when graphCoverageMode is `graphless_fallback` or `unavailable_blocked`. Pass when graphCoverageMode is `graphless_fallback` AND at least one `searchLedger` row exists for each entry in `searchCoverage.requiredBugClasses` with `searchActions[].method` in {\"direct_read\",\"exact_grep\",\"semantic_search\",\"code_graph_status_check\",\"producer_consumer_trace\",\"negative_test_inspection\"} AND non-empty `evidenceRefs`. Fail automatically when graphCoverageMode is `unavailable_blocked`; record the explicit unavailability reason. Otherwise pass = false; blocker name = \"graphlessFallbackGate\"; recovery_strategy = \"Add cited fallback ledger rows (direct read, exact search, producer/consumer trace, negative-test inspection) or set graphCoverageMode to 'graph' once graph data is available.\"\n625:              if STOP is a candidate and any gate fails:\n626:                decision = \"BLOCKED\"\n627:                stop_blocked = true\n628:                stopReason = \"blockedStop\"\n629:                blocked_by_json = JSON array of failing gate names (always include \"claimAdjudicationGate\" when claim_adjudication_gate_pass == false, \"fixCompletenessReplayGate\" when fix_completeness_replay_gate_pass == false, \"candidateCoverageGate\" when candidate_coverage_gate_pass == false, and \"graphlessFallbackGate\" when graphless_fallback_gate_pass == false)\n630:                blocked_by_csv = comma-separated list of failing gate names\n631:                convergence_gate_pass = boolean\n632:                convergence_gate_score = numeric convergence score\n633:                dimension_coverage_gate_pass = boolean\n634:                dimension_coverage_gate_covered_json = JSON array of covered review dimensions\n\n(Output capped at 50 KB. Showing lines 1-634. Use offset=635 to continue.)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Review Loop Manager\npurpose: Iterative code/spec review with convergence detection across review dimensions\naction: Run deep-review loop from initialization through synthesis\noperating_mode:\n  workflow: iterative_loop\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_review_state\n  validation: convergence_detection\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING PRINCIPLES\n# ─────────────────────────────────────────────────────────────────\noperating_principles:","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Review Loop Manager\npurpose: Iterative code/spec review with convergence detection across review dimensions\naction: Run deep-review loop from initialization through synthesis\noperating_mode:\n  workflow: iterative_loop\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_review_state\n  validation: convergence_detection\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING PRINCIPLES\n# ─────────────────────────────────────────────────────────────────\noperating_principles:\n  core: \"Fresh context per iteration + externalized state = no context degradation\"\n  approach: \"Dispatch focused review agent per dimension, evaluate convergence, repeat or stop\"\n  mandate: \"Never hold findings in memory; write everything to files. Review target is READ-ONLY.\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (from setup phase)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  review_target: \"[REVIEW_TARGET] - What to review. REQUIRED.\"\n  review_target_type: \"[spec-folder|skill|agent|track|files] - Target type for scope derivation. REQUIRED.\"\n  review_dimensions: \"[all|correctness,security,traceability,maintainability] - Dimensions to check. Default: all.\"\n  spec_folder: \"[SPEC_FOLDER] - Spec folder path for state files. REQUIRED.\"\n  session_id: \"[SESSION_ID] - Optional caller-supplied session id for fan-out lineages. Default: timestamp.\"\n  lineage_mode: \"[auto|resume|restart] - Session lifecycle intent. Default: auto. The runtime only persists lineage events for `resume` (same sessionId, no archive) and `restart` (new sessionId, generation+1, prior review/ archived). `fork` and `completed-continue` are deferred and no longer accepted — see deep-review/references/protocol/loop_protocol.md §Lifecycle Branches.\"\n  max_iterations: 7\n  convergence_threshold: 0.10\n  convergence_mode: \"[default|off|sliding-window|divergent] - Convergence policy modifier. Default: default.\"\n  stop_policy: \"[convergence|max-iterations] - Stop behavior. Default: convergence. max-iterations treats convergence as telemetry until the hard iteration ceiling.\"\n  config.fanout_lineage_artifact_dir: \"[optional internal path] - Fan-out lineage artifact override for command-owned single-lineage execution.\"\n\n# ─────────────────────────────────────────────────────────────────\n# CONTEXT LOADING\n# ─────────────────────────────────────────────────────────────────\ncontext_loading:\n  trigger: \"At workflow START, before phase_init\"\n  purpose: \"Load prior review context for the target and buffer it until strategy.md exists\"\n  mcp_integration:\n    tool: memory_context\n    note: \"Call MCP tools directly - NEVER through Code Mode\"\n    parameters: { input: \"{review_target}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n  when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n  behavior:\n    if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n    if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n\n# ─────────────────────────────────────────────────────────────────\n# SKILL REFERENCE\n# ─────────────────────────────────────────────────────────────────\nskill_reference:\n  skill: system-deep-loop\n  skill_md: .opencode/skills/system-deep-loop/deep-review/SKILL.md\n  references:\n    loop_protocol: .opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md\n    state_format: .opencode/skills/system-deep-loop/deep-review/references/state/state_format.md\n    convergence: .opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md\n  templates:\n    config: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json\n    strategy: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md\n\n# ─────────────────────────────────────────────────────────────────\n# AGENT CONFIGURATION\n# ─────────────────────────────────────────────────────────────────\nagent_config:\n  agent: deep-review\n  agent_file: \".opencode/agents/deep-review.md\"\n  # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n  mode: subagent\n  model: opus\n  leaf_only: true\n  tools: [Read, Write, Edit, Bash, Grep, Glob]\n  mcp_servers: [mk-spec-memory]\n  tool_call_budget: { target: 9, soft_max: 12, hard_max: 13 }\n\n# ─────────────────────────────────────────────────────────────────\n# STATE FILE PATHS\n# ─────────────────────────────────────────────────────────────────\nstate_paths:\n  # Template paths document the canonical packet layout. Runtime resolution happens via\n  # step_resolve_artifact_root plus the shared resolver, so root specs keep\n  # root-local review/ and child phases keep local review/ packet dirs.\n  # Canonical root-spec write targets remain review/deep-review-config.json,\n  # review/deep-review-state.jsonl, and review/deep-review-findings-registry.json.\n  packet_dir: \"{artifact_dir}\"\n  local_packet_dir: \"{spec_folder}/review\"\n  legacy_root_report: \"{spec_folder}/review-report.md\"\n  config: \"{artifact_dir}/deep-review-config.json\"\n  state_log: \"{artifact_dir}/deep-review-state.jsonl\"\n  findings_registry: \"{artifact_dir}/deep-review-findings-registry.json\"\n  strategy: \"{artifact_dir}/deep-review-strategy.md\"\n  dashboard: \"{artifact_dir}/deep-review-dashboard.md\"\n  pause_sentinel: \"{artifact_dir}/.deep-review-pause\"\n  lock_file: \"{artifact_dir}/.deep-review.lock\"\n  prompt_dir: \"{artifact_dir}/prompts\"\n  iteration_dir: \"{artifact_dir}/iterations\"\n  iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n  # Per-iteration structured delta stream — complement to the canonical state_log\n  # append. MUST contain at least one record with `type === \"iteration\"`; variants\n  # like `\"iteration_delta\"` are silently dropped by the reducer.\n  delta_dir: \"{artifact_dir}/deltas\"\n  delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n  review_output: \"{artifact_dir}/review-report.md\"\n  resource_map_output: \"{artifact_dir}/resource-map.md\"\n  archive_root: \"{artifact_archive_root}\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW\n# ─────────────────────────────────────────────────────────────────\nworkflow:\n\n  step_resolve_artifact_root:\n    description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n    note: \"Root specs keep review artifacts directly in {spec_folder}/review/. Child phases and sub-phases keep local packet directories in {spec_folder}/review/{packet}/, and archives stay local at {spec_folder}/review_archive/{packet}/.\"\n    branch_on: \"config.fanout_lineage_artifact_dir\"\n    if_present:\n      bind:\n        artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_subfolder: null\n        artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n    if_absent:\n      command: \"node -e \\\"const { resolveArtifactRoot } = require('.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'review')));\\\"\"\n      outputs:\n        - artifact_root_dir: \"Resolved local review owner directory\"\n        - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n        - artifact_dir: \"Resolved review packet directory for this target\"\n        - artifact_archive_root: \"Resolved local review archive directory for this target\"\n\n  step_bind_reducer_artifact_arg:\n    description: \"Keep the reducer on the lineage-owned artifact directory during fan-out\"\n    branch_on: \"config.fanout_lineage_artifact_dir\"\n    if_present:\n      bind:\n        reducer_artifact_arg: \"--artifact-dir {artifact_dir}\"\n    if_absent:\n      bind:\n        reducer_artifact_arg: \"\"\n\n  step_apply_lifecycle_request:\n    description: \"Honor explicit auto-mode restart before fan-out or normal initialization\"\n    skip_when: \"lineage_mode != 'restart'\"\n    instructions: |\n      This is the autonomous equivalent of the confirm-mode restart choice. Run it\n      immediately after artifact resolution and before fan-out so old packet files\n      cannot be merged with fresh lineage outputs. A restart request must never\n      fall back to auto-resume. In auto mode, the explicit restart flag is operator\n      authorization to archive the resolved review packet, so do not ask for a\n      second confirmation. Rollback is to move the timestamped archive back to\n      the packet directory.\n    command: \"if [ -d \\\"{state_paths.packet_dir}\\\" ]; then mkdir -p \\\"{state_paths.archive_root}\\\" && mv \\\"{state_paths.packet_dir}\\\" \\\"{state_paths.archive_root}/{timestamp_slug}\\\"; fi; mkdir -p \\\"{state_paths.packet_dir}\\\"\"\n    outputs:\n      - archived_path: \"{state_paths.archive_root}/{timestamp_slug} when a prior packet existed, else null\"\n      - lineage_mode: \"restart\"\n    on_fail: \"Halt with STATUS=FAIL; do not continue as resume or auto.\"\n\n  step_fanout_spawn:\n    description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n    skip_when: \"config.fanout is absent\"\n    instructions: |\n      Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n      isolated sub-packet under {artifact_dir}/lineages/{label}/.\n      A cli-opencode lineage inside this fan-out is an explicit parallel-detached OpenCode\n      session with a separate lineage directory and session id; it is not the single-executor\n      self-invocation path. fanout-run.cjs owns the stack-only recursion guard for that\n      first-level detached lineage and still blocks recursive same-kind dispatch from inside it.\n      fanout-run.cjs owns native and CLI lineage execution; native is run through the\n      deep/review command surface with config.fanout_lineage_artifact_dir so the LEAF\n      deep-review agent is used only for individual iterations, never as a full-loop\n      sub-agent or pasted phase-running prompt.\n      After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n      phase_main_loop entirely (those are the single-executor path). The merge step in\n      phase_synthesis will consolidate results across all lineages.\n    sub_steps:\n      step_fanout_spawn_cli:\n        description: \"Spawn all native and CLI lineages in capped worker pool\"\n        skip_when: \"no entries in config.fanout.executors\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs \\\n            --spec-folder {spec_folder} \\\n            --loop-type review \\\n            --fanout-config-json '{config.fanout_json}' \\\n            --base-artifact-dir {artifact_dir} \\\n            --convergence-threshold {convergence_threshold} \\\n            --stop-policy {stop_policy}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 1: INITIALIZATION\n  # ═══════════════════════════════════════════════════════════════\n  phase_init:\n    purpose: Create all state files for the review session and resolve review scope\n    steps:\n\n      step_preflight_contract:\n        action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n        verify:\n          - required_values_present: [review_target, review_target_type, review_dimensions, spec_folder, lineage_mode, max_iterations, convergence_threshold, convergence_mode, stop_policy]\n          - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n          - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n          - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n        on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n\n      step_create_directories:\n        action: \"Create spec folder and canonical review packet directories if they don't exist\"\n        command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n\n      step_detect_resource_map:\n        action: \"Detect resource-map.md before config creation so init can persist coverage-gate state\"\n        inspect:\n          - \"{spec_folder}/resource-map.md\"\n        classify:\n          present: \"resource-map.md exists at init\"\n          absent: \"resource-map.md does not exist at init\"\n        outputs:\n          - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n          - resource_map_known_context: \"When present: concise resource-map snapshot for Known Context and charter framing. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_migrate_legacy_review_state:\n        action: \"Rehome legacy review artifacts into review/iterations before session classification\"\n        detect:\n          canonical_review_state:\n            - \"{state_paths.config}\"\n            - \"{state_paths.state_log}\"\n            - \"{state_paths.findings_registry}\"\n            - \"{state_paths.strategy}\"\n          legacy_review_state:\n            - \"{spec_folder}/scratch/deep-research-config.json\"\n            - \"{spec_folder}/scratch/deep-research-state.jsonl\"\n            - \"{spec_folder}/scratch/deep-review-strategy.md\"\n            - \"{spec_folder}/scratch/deep-review-dashboard.md\"\n            - \"{spec_folder}/scratch/iteration-*.md\"\n            - \"{spec_folder}/scratch/.deep-research-pause\"\n            - \"{state_paths.local_packet_dir}/iteration-*.md\"\n            - \"{state_paths.legacy_root_report}\"\n          legacy_review_markers:\n            - \"scratch/deep-review-strategy.md exists\"\n            - \"scratch/deep-research-config.json declares mode == 'review' OR scratch/deep-research-state.jsonl contains mode == 'review'\"\n        migrate_only:\n          - \"{spec_folder}/scratch/deep-research-config.json -> {state_paths.config}\"\n          - \"{spec_folder}/scratch/deep-research-state.jsonl -> {state_paths.state_log}\"\n          - \"{spec_folder}/scratch/deep-review-strategy.md -> {state_paths.strategy}\"\n          - \"{spec_folder}/scratch/deep-review-dashboard.md -> {state_paths.dashboard}\"\n          - \"{spec_folder}/scratch/iteration-*.md -> {state_paths.iteration_dir}/\"\n          - \"{spec_folder}/scratch/.deep-research-pause -> {state_paths.pause_sentinel}\"\n          - \"{state_paths.local_packet_dir}/iteration-*.md -> {state_paths.iteration_dir}/\"\n          - \"{state_paths.legacy_root_report} -> {state_paths.review_output}\"\n        on_canonical_present: \"Leave canonical review/ state untouched and do not overwrite it with legacy scratch artifacts.\"\n        on_legacy_detected: \"Move only the review-specific whitelist, append a migration event to the canonical JSONL, and leave unrelated scratch files untouched.\"\n        on_conflict: \"If canonical review/ state and legacy scratch review state both exist but disagree, halt for operator repair instead of merging contradictory state.\"\n        command: \"mkdir -p {state_paths.iteration_dir} && if [ ! -e {state_paths.config} ] && [ ! -e {state_paths.state_log} ] && [ ! -e {state_paths.strategy} ] && [ -e {spec_folder}/scratch/deep-review-strategy.md ] && ( [ -e {spec_folder}/scratch/deep-research-config.json ] || [ -e {spec_folder}/scratch/deep-research-state.jsonl ] ); then [ -e {spec_folder}/scratch/deep-research-config.json ] && mv {spec_folder}/scratch/deep-research-config.json {state_paths.config}; [ -e {spec_folder}/scratch/deep-research-state.jsonl ] && mv {spec_folder}/scratch/deep-research-state.jsonl {state_paths.state_log}; [ -e {spec_folder}/scratch/deep-review-strategy.md ] && mv {spec_folder}/scratch/deep-review-strategy.md {state_paths.strategy}; [ -e {spec_folder}/scratch/deep-review-dashboard.md ] && mv {spec_folder}/scratch/deep-review-dashboard.md {state_paths.dashboard}; find {spec_folder}/scratch -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; ; [ -e {spec_folder}/scratch/.deep-research-pause ] && mv {spec_folder}/scratch/.deep-research-pause {state_paths.pause_sentinel}; [ -e {state_paths.legacy_root_report} ] && mv {state_paths.legacy_root_report} {state_paths.review_output}; if [ -e {state_paths.state_log} ]; then printf '%s\\n' '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"migration\\\",\\\"mode\\\":\\\"review\\\",\\\"legacyArtifacts\\\":[\\\"deep-research-config.json\\\",\\\"deep-research-state.jsonl\\\",\\\".deep-research-pause\\\"],\\\"canonicalArtifacts\\\":[\\\"deep-review-config.json\\\",\\\"deep-review-state.jsonl\\\",\\\".deep-review-pause\\\"],\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\"}' >> {state_paths.state_log}; fi; fi; find {state_paths.local_packet_dir} -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; 2>/dev/null || true\"\n\n      step_acquire_lock:\n        action: \"Acquire the single-writer advisory lock before session classification\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n        on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-review run already holds this packet.\"\n        note: \"Uses the promoted runtime/ loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n        # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n        # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n        on_halt:\n          action: \"Release the lock before any terminal halt branch returns control\"\n          applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\"]\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n        on_cancel:\n          action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n        on_workflow_exit:\n          action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n\n      step_classify_session:\n        action: \"Classify the session before writing files\"\n        inspect:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        classify:\n          fresh: \"None of the three state artifacts exist\"\n          resume: \"Config, JSONL, and strategy all exist and config.mode == 'review' and agree on target/spec folder\"\n          completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n          invalid-state: \"Any partial, missing, or contradictory combination\"\n        outputs:\n          - session_state: \"fresh | resume | completed-session | invalid-state\"\n        lifecycle_routing:\n          - \"If lineage_mode == restart and session_state is resume or completed-session, execute on_restart before on_resume or on_completed_session.\"\n          - \"If lineage_mode == auto or lineage_mode == resume, preserve the existing resume/completed/fresh behavior.\"\n        on_resume:\n          log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: phase_loop\n        on_restart:\n          action: \"Archive the current review packet under the root-level review_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n          command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n          set:\n            lineage_mode: \"restart\"\n            parent_session_id: \"{prior_session_id}\"\n            generation: \"{prior_generation + 1}\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: step_create_config\n        note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-review/references/protocol/loop_protocol.md §Lifecycle Branches for the one-session contract.\"\n        on_completed_session:\n          log: \"Prior session already completed. Either archive the completed review/ tree and start a fresh session, or jump straight to synthesis with the existing artifacts.\"\n          skip_to: phase_synthesis\n        on_invalid_state:\n          halt: true\n          message: \"Existing deep-review state in review/ is incomplete or contradictory. Repair or archive the invalid review packet before continuing.\"\n        on_fresh:\n          action: \"Proceed with a new session\"\n\n      step_scope_discovery:\n        action: \"Resolve review target to a concrete file list based on target type\"\n        resolve:\n          spec-folder: |\n            1. Inspect spec.md, plan.md, tasks.md, checklist.md, implementation-summary.md, and goal-file-manifest.txt when present\n            2. If goal-file-manifest.txt exists, parse one repo-relative path per non-empty, non-comment line; reject absolute paths, traversal outside repo_root, duplicates, missing paths, and non-file entries\n            3. Fail before dispatch with line-numbered validation errors when any manifest entry is invalid; otherwise set scope = the validated manifest paths in declared order\n            4. When no manifest exists, discover implementation files referenced in the canonical spec artifacts\n            5. Discover test files associated with the implementation files\n            6. Set scope = all discovered implementation and test files\n          skill: |\n            1. Read SKILL.md from .opencode/skills/{skill_name}/\n            2. Discover references/, assets/, scripts/ contents\n            3. Find agent definitions referencing this skill across runtimes\n            4. Find command entry points referencing this skill\n            5. Set scope = all discovered files\n          agent: |\n            1. Find agent definition across repo-managed runtimes (.claude/agents/, .opencode/agents/)\n            2. Compare agent definitions for consistency\n            3. Set scope = all discovered agent files\n          track: |\n            1. List all child spec folders under specs/{track}/ or .opencode/specs/{track}/\n            2. For each: read spec.md + checklist.md\n            3. Set scope = all child spec artifacts\n          files: |\n            1. Expand glob patterns from review_target\n            2. Validate all files exist\n            3. Discover immediate cross-references (imports, links)\n            4. Set scope = expanded file list + cross-references\n        outputs:\n          - review_scope_files: \"List of all files in review scope\"\n          - cross_reference_targets: \"{ spec_paths: [...], code_paths: [...], test_paths: [...] }\"\n\n      step_order_dimensions:\n        action: \"Order review dimensions based on risk priority\"\n        algorithm: |\n          1. Iteration 0 (inventory pass): Build artifact map, identify file types, estimate complexity\n          2. Subsequent iterations follow risk-ordered deep passes:\n             correctness → security → traceability → maintainability\n          3. If review_dimensions != \"all\", filter to only requested dimensions\n          4. Derive traceability protocol plan:\n             - core: spec_code, checklist_evidence\n             - overlay: skill_agent, agent_cross_runtime, feature_catalog_code, playbook_capability\n          5. If resource_map_present, reserve at least one traceability-oriented pass to cross-check target_files from applied/T-*.md against resource-map.md and classify touched / expected-by-scope / gap / absent-from-map outcomes\n          6. Store ordered list as dimension_queue\n        outputs:\n          - dimension_queue: \"Ordered list of dimensions to review\"\n          - inventory_pass: true\n\n      step_normalize_review_dimensions:\n        action: \"Normalize reviewDimensions once during init for config + JSONL reuse\"\n        outputs:\n          - review_dimensions_normalized: \"Canonical string[] for deep-review-config.json\"\n          - review_dimensions_json: \"JSON.stringify(review_dimensions_normalized) for JSONL config record\"\n        normalize: |\n          Accept {review_dimensions} in any of these shapes and convert once:\n            - \"all\" → [\"correctness\",\"security\",\"traceability\",\"maintainability\"]\n            - \"correctness,security\" → [\"correctness\",\"security\"]\n            - [\"correctness\"] → [\"correctness\"]\n          Every element MUST be one of the four canonical dimension names.\n\n      step_resolve_session_id:\n        action: \"Resolve init session id from caller when supplied, else preserve timestamp fallback\"\n        branch_on: \"session_id\"\n        if_present:\n          bind:\n            session_id_init: \"{session_id}\"\n        if_absent:\n          bind:\n            session_id_init: \"{ISO_8601_NOW}\"\n\n      step_create_config:\n        action: \"Create deep-review-config.json from template with review-specific fields\"\n        template: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json\n        populate:\n          topic: \"Review: {review_target}\"\n          mode: \"review\"\n          sessionId: \"{session_id_init}\"\n          parentSessionId: null\n          lineageMode: \"new\"\n          generation: 1\n          continuedFromRun: null\n          reviewTarget: \"{review_target}\"\n          reviewTargetType: \"{review_target_type}\"\n          # Reuse the single normalized init-time value from step_normalize_review_dimensions.\n          reviewDimensions: \"{review_dimensions_normalized}\"\n          resource_map_present: \"{resource_map_present}\"\n          reviewScopeFiles: \"{review_scope_files}\"\n          severityThreshold: \"P2\"\n          crossReference:\n            core: [\"spec_code\", \"checklist_evidence\"]\n            overlay: [\"skill_agent\", \"agent_cross_runtime\", \"feature_catalog_code\", \"playbook_capability\"]\n          maxIterations: \"{max_iterations}\"\n          # Semantic: weighted P0/P1/P2 severity ratio. See SKILL.md §\"Convergence Threshold Semantics\".\n          convergenceThreshold: \"{convergence_threshold}\"\n          antiConvergence.convergenceMode: \"{convergence_mode}\"\n          antiConvergence.divergent: {}\n          stopPolicy: \"{stop_policy}\"\n          stuckThreshold: 2\n          maxDurationMinutes: 120\n          specFolder: \"{spec_folder}\"\n          # Honor the parsed --no-resource-map flag from deep-review.md:71 (default true; false when flag is set).\n          # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n          resource_map.emit: \"{resource_map_emit}\"\n          createdAt: \"{ISO_8601_NOW}\"\n          status: \"initialized\"\n          releaseReadinessState: \"in-progress\"\n          executionMode: \"auto\"\n        output: \"{state_paths.config}\"\n\n      step_create_state_log:\n        action: \"Initialize JSONL state log with config record including review fields and lineage metadata\"\n        note: \"Reuse review_dimensions_json from step_normalize_review_dimensions. Never re-normalize or wrap the raw template value.\"\n        # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n        content: '{\"type\":\"config\",\"mode\":\"review\",\"reviewTarget\":\"{review_target}\",\"reviewTargetType\":\"{review_target_type}\",\"reviewDimensions\":{review_dimensions_json},\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"sessionId\":\"{session_id_init}\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":{max_iterations},\"convergenceThreshold\":{convergence_threshold},\"antiConvergence\":{\"convergenceMode\":\"{convergence_mode}\",\"divergent\":{}},\"stopPolicy\":\"{stop_policy}\",\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\"}'\n        output: \"{state_paths.state_log}\"\n\n      step_create_findings_registry:\n        action: \"Initialize reducer-owned review findings registry\"\n        content: '{\"sessionId\":\"{session_id_init}\",\"generation\":1,\"lineageMode\":\"new\",\"openFindings\":[],\"resolvedFindings\":[],\"repeatedFindings\":[],\"dimensionCoverage\":{\"correctness\":false,\"security\":false,\"traceability\":false,\"maintainability\":false},\"findingsBySeverity\":{\"P0\":0,\"P1\":0,\"P2\":0},\"openFindingsCount\":0,\"resolvedFindingsCount\":0,\"convergenceScore\":0.0}'\n        output: \"{state_paths.findings_registry}\"\n\n      step_create_strategy:\n        action: \"Create review strategy file from deep_review_strategy.md template\"\n        template: .opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md\n        populate:\n          review_target: \"{review_target}\"\n          review_target_type: \"{review_target_type}\"\n          dimensions: \"{dimension_queue}\"\n          scope_files: \"{review_scope_files}\"\n          cross_reference_targets: \"{cross_reference_targets}\"\n          max_iterations: \"{max_iterations}\"\n          convergence_threshold: \"{convergence_threshold}\"\n          stop_policy: \"{stop_policy}\"\n        output: \"{state_paths.strategy}\"\n\n      step_seed_coverage_graph:\n        action: \"Seed the review coverage graph before the first convergence check\"\n        transform: |\n          1. Convert review_scope_files into FILE nodes.\n          2. Convert review target groupings into coarse SLICE nodes only; do not expand SYMBOL\n             or DEPENDENCY nodes in review mode.\n          3. Emit COVERS edges from SLICE nodes to FILE nodes when the grouping is known.\n          4. Bind coverage_seed_source to \"scope_discovery\" and coverage_seed_confidence to 0.50.\n          5. When scope discovery yields no files, emit [] for both arrays; the upsert script\n             returns a warning and review continues with an empty graph.\n        bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{config.sessionId}\\\" --nodes '{coverage_seed_nodes_json}' --edges '{coverage_seed_edges_json}' --seed-source \\\"{coverage_seed_source}\\\" --seed-confidence \\\"{coverage_seed_confidence}\\\"\"\n        outputs:\n          - coverage_seed_nodes_json: \"Seed nodes for review SLICE and FILE kinds only\"\n          - coverage_seed_edges_json: \"Seed COVERS edges where review target groupings resolved\"\n          - coverage_seed_warning: \"Warning emitted when the seed batch inserts zero nodes, else empty\"\n        on_warning:\n          log: \"Coverage graph seed inserted zero nodes; continuing with an empty graph.\"\n          proceed: true\n\n      step_enrich_strategy_context:\n        action: \"Ensure Known Context is written only after strategy.md exists\"\n        condition: \"prior_context_found\"\n        edit: \"{state_paths.strategy}\"\n        note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n\n      step_enrich_strategy_resource_map:\n        action: \"Inject resource-map status into Known Context after strategy.md exists\"\n        edit: \"{state_paths.strategy}\"\n        note: \"When resource_map_present is true, append the resource_map_known_context snapshot and add Resource Map Coverage to the Review Charter. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_init_complete:\n        log: \"Initialization complete. Config, state, and strategy files created. Review scope: {review_scope_files_count} files, {dimension_queue_count} dimensions.\"\n        set: { current_iteration: 1, stuck_count: 0, p0_count: 0, p1_count: 0, p2_count: 0 }\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 2: ITERATION LOOP\n  # ═══════════════════════════════════════════════════════════════\n  phase_loop:\n    purpose: Dispatch review agent iterations until convergence\n    repeat: true\n    max_repeats: \"{max_iterations}\"\n    steps:\n\n      step_read_state:\n        action: \"Read current state from JSONL, strategy, and config\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.config}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - last_newFindingsRatio: \"Extract newFindingsRatio from last iteration record\"\n          - last_focus: \"Extract focus/dimension from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newFindingsRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newFindingsRatio from latest iteration record, else 'N/A'\"\n          - next_dimension: \"Next uncovered dimension from dimension_queue in strategy.md\"\n          - dimensions_covered: \"List of dimensions already reviewed\"\n          - dimensions_remaining: \"List of dimensions not yet reviewed\"\n          - dimension_coverage: \"covered / total dimensions\"\n          - coverage_age: \"Iterations since dimension coverage last changed; require >= 1 before STOP\"\n          - p0_count: \"Count P0 findings across all iterations\"\n          - p1_count: \"Count P1 findings across all iterations\"\n          - p2_count: \"Count P2 findings across all iterations\"\n          - resource_map_present: \"Extract boolean from deep-review-config.json, default false\"\n          - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource Map Coverage: cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md and classify only missed coverage as gaps.' Else return 'Resource Map Coverage: resource-map.md not present; skipping coverage gate.'\"\n          - session_id: \"Extract sessionId from deep-review-config.json\"\n          - generation: \"Extract generation from deep-review-config.json, else 1\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: dimension (ratio, P0/P1/P2)'\"\n          - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n          - last_claim_adjudication_passed: \"Scan state.jsonl for the most recent `claim_adjudication` event; use its `passed` boolean. Default true when no event exists or when activeP0 + activeP1 == 0 (gate is vacuous without adjudicable findings).\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings at the time of the last claim_adjudication event; 0 when none exist\"\n          - security_sensitive_fix_scope: \"Boolean true when the current review is a rerun after fixes involving security, path disclosure, auth/authz, sandboxing, env precedence, public schemas, persistence, or user-visible error payloads; derive from the latest review report, remediation notes, or planning packet when present, else false.\"\n          - fix_completeness_replay_required_rows: \"Count prior active or remediated P0/P1 findings, plus any prior security/path P2 findings, that require closed-gate replay before STOP.\"\n          - fix_completeness_replay_passing_rows: \"Count required replay rows marked PASS with file:line or command evidence and producer/consumer/matrix coverage.\"\n          - stop_policy: \"Extract stopPolicy from deep-review-config.json, default 'convergence'. Valid values: convergence, max-iterations.\"\n          - convergence_mode: \"Extract antiConvergence.convergenceMode when it is one of 'default', 'off', 'sliding-window', or 'divergent'; default to 'default'\"\n          - convergence_mode_warning: \"Boolean true when antiConvergence.convergenceMode is present with an unsupported value; use 'default'\"\n          - pivot_lineage: \"Summarize registry.divergence.completed and registry.divergence.overrides with pivot ids, source iterations, and selected review direction; else 'none yet'\"\n          - saturated_directions: \"List registry.divergence.saturatedDirections; else 'none yet'\"\n\n      step_check_pause_sentinel:\n        action: \"Check for pause sentinel file\"\n        check: \"Does {state_paths.pause_sentinel} exist?\"\n        if_exists:\n          set:\n            pending_stop_event: \"paused\"\n            pending_stop_reason: \"userPaused\"\n            pending_stop_detail: \"sentinel file detected\"\n          skip_to: step_normalize_pause_events\n        if_not_exists:\n          proceed: true\n\n      step_validate_convergence_config:\n        action: \"Validate convergence mode when loading config\"\n        if_convergence_mode_invalid:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"config_warning\",\"mode\":\"review\",\"field\":\"antiConvergence.convergenceMode\",\"fallback\":\"default\",\"message\":\"Unsupported convergenceMode; using default convergence behavior.\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Unsupported convergenceMode; using default convergence behavior.\"\n\n      step_graph_convergence:\n        action: \"Evaluate coverage-graph convergence before the inline review convergence vote\"\n        inspect:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Call graph convergence on the current review lineage before the inline 3-signal vote.\n          2. Record the decision as one of CONTINUE, STOP_ALLOWED, STOP_BLOCKED.\n          3. Preserve raw graph signals and blockers for reducer rollup and blocked-stop evidence.\n          4. Normalize blockers to both JSON array and CSV forms for downstream stop handling.\n          5. Set graph_stop_blocked = true only when graph_decision == \"STOP_BLOCKED\".\n        bash: 'node .opencode/skills/system-deep-loop/runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"review\" --session-id \"{session_id}\" --convergence-mode \"{convergence_mode}\"'\n        note: \"Invoke the runtime script directly. Review-side graph convergence must run before the inline review stop vote.\"\n        append_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"review\",\"run\":{current_iteration},\"decision\":\"{graph_decision}\",\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n        outputs:\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED\"\n          - graph_signals_json: \"JSON object returned by convergence.cjs\"\n          - graph_blockers_json: \"JSON array of graph blockers when present, else []\"\n          - graph_blockers_csv: \"Comma-separated blocker summary when graph blocks STOP, else empty string\"\n          - graph_stop_blocked: \"Boolean true when graph_decision == STOP_BLOCKED\"\n\n      step_check_convergence:\n        action: \"Evaluate graph-assisted review stop conditions and the legal-stop decision tree\"\n        algorithm: |\n          0. CLAIM-ADJUDICATION PRE-CHECK (universal STOP veto; runs before hard stops and composite convergence):\n             claim_adjudication_gate_pass = (last_claim_adjudication_passed != false) OR (p0_count + p1_count == 0)\n             If claim_adjudication_gate_pass == false:\n               candidate_decision = \"BLOCKED\"\n               stop_blocked = true\n               stopReason = \"blockedStop\"\n               blocked_gates = [\"claimAdjudicationGate\"]\n               recovery_strategy = \"Reviewer must add typed claim-adjudication packets (claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger) for every active P0/P1 finding before STOP is allowed.\"\n               Skip hard stops (1) and composite convergence (4); proceed directly to step 5 legal-stop decision-tree assembly so blocked_by_json, gate outputs, and the blocked_stop event still populate consistently.\n          1. HARD STOPS:\n             a) if iteration_count >= max_iterations: set decision = \"STOP\", stopReason = \"maxIterationsReached\", hard_stop_reason = \"max_iterations_reached\", preserve any failed legal-stop gates as terminal evidence, and proceed to synthesis without legal-stop veto\n             b) if stop_policy == \"max-iterations\" AND iteration_count < max_iterations: do not allow all-dimensions-clean or composite convergence to stop; treat convergence signals as telemetry, set decision = \"CONTINUE\", and broaden the next review angle.\n             c) if all dimensions clean AND required traceability protocols are covered AND p0_count == 0 AND p1_count == 0 AND coverage_age >= 1 AND all quality gates pass (evidence: every P0/P1 has file:line; scope: all findings within target; coverage: all dimensions reviewed): mark hard_stop_reason = \"all_dimensions_clean\" and promote to STOP candidate\n             Operator stop reasons (`maxIterationsReached`, `manualStop`, `userPaused`, unrecoverable `error`) are terminal ceilings. They do not hide failed gates; they record them in synthesis and stop dispatch.\n          2. STUCK DETECTION (threshold 2):\n             if stuck_count >= 2: STUCK_RECOVERY\n          3. GRAPH CONVERGENCE PREREQUISITE:\n               graph_decision, graph_signals_json, and graph_blockers_json are already populated by step_graph_convergence.\n               Final STOP is never legal unless the inline review vote says STOP AND graph_decision == \"STOP_ALLOWED\".\n               If graph_decision == \"STOP_BLOCKED\", set stop_blocked = true and route through blocked_stop emission instead of stopping.\n          4. COMPOSITE CONVERGENCE (3-signal weighted vote with split thresholds):\n               signals = []\n               a) Rolling average (w=0.30, window=2, needs 2+ iterations):\n                  avg = mean(last 2 newFindingsRatios)\n                  stop if avg <= 0.08\n               b) MAD noise floor (w=0.25, needs 3+ iterations):\n                  noiseFloor = MAD(all ratios) * 1.4826\n                  stop if latest ratio <= noiseFloor\n               c) Dimension coverage (w=0.45):\n                  coverage = dimensions_covered / total_dimensions\n                  stop if coverage >= 1.0 AND required traceability protocols are covered AND coverage_age >= 1\n               Redistribute weights for unavailable signals.\n               if latest ratio <= 0.05: mark no_progress_threshold_reached\n               if stop_policy == \"max-iterations\" AND iteration_count < max_iterations: convergence votes are telemetry only; set weighted_stop_score for diagnostics, keep decision = \"CONTINUE\", and choose a broader next focus.\n               else if weighted_stop_score >= 0.60: inline STOP becomes a candidate and binary gates must run\n          5. LEGAL-STOP DECISION TREE (review-specific gates; runs whenever step 0, all-dimensions-clean, or the composite vote promotes STOP to a candidate; terminal max-iteration/manual/error stops bypass veto and record failed gates as evidence):\n               a) convergenceGate: pass when a hard-stop condition is met OR weighted_stop_score >= 0.60; record score\n               b) dimensionCoverageGate: pass when configured dimensions and required traceability coverage are complete and coverage_age >= 1; record covered and missing dimensions\n               c) p0ResolutionGate: pass when activeP0 == 0; record activeP0\n               d) evidenceDensityGate: pass when every active P0/P1 has concrete file:line evidence and no active P0/P1 relies only on inference; record avgEvidencePerFinding\n               e) hotspotSaturationGate: pass when review hotspots have been revisited enough times to satisfy the saturation heuristic\n               f) claimAdjudicationGate: pass when claim_adjudication_gate_pass == true (i.e. last_claim_adjudication_passed != false OR there are no active P0/P1 findings to adjudicate); record last_claim_adjudication_passed and claim_adjudication_active_count\n               g) fixCompletenessReplayGate: pass when security_sensitive_fix_scope == false OR every required closed-gate replay row passes with file:line or command evidence and producer/consumer/matrix coverage; record security_sensitive_fix_scope, fix_completeness_replay_required_rows, and fix_completeness_replay_passing_rows\n               h) candidateCoverageGate: skip entirely when `reviewDepthSchemaVersion` is not 2 on the latest iteration. Otherwise pass when the current iteration's `reviewDepthApplicability.scopeClass` is `trivial` with `enforcement: \"skip\"` AND `reviewDepthApplicability.evidenceRefs` is non-empty, OR when the reducer registry's `searchDebt` is empty AND `candidateCoverage.covered` is a superset of `searchCoverage.requiredBugClasses` for the lineage. Otherwise pass = false; record `searchDebt` items as blocked-stop evidence; blocker name = \"candidateCoverageGate\"; recovery_strategy = \"Resolve deferred/blocked obligations in next iteration or downgrade scope explicitly to trivial with cited evidence.\"\n               i) graphlessFallbackGate: skip when `reviewDepthSchemaVersion` is not 2 OR the reducer registry's last-iteration `searchCoverage.graphCoverageMode` is `graph`. Applies when graphCoverageMode is `graphless_fallback` or `unavailable_blocked`. Pass when graphCoverageMode is `graphless_fallback` AND at least one `searchLedger` row exists for each entry in `searchCoverage.requiredBugClasses` with `searchActions[].method` in {\"direct_read\",\"exact_grep\",\"semantic_search\",\"code_graph_status_check\",\"producer_consumer_trace\",\"negative_test_inspection\"} AND non-empty `evidenceRefs`. Fail automatically when graphCoverageMode is `unavailable_blocked`; record the explicit unavailability reason. Otherwise pass = false; blocker name = \"graphlessFallbackGate\"; recovery_strategy = \"Add cited fallback ledger rows (direct read, exact search, producer/consumer trace, negative-test inspection) or set graphCoverageMode to 'graph' once graph data is available.\"\n             if STOP is a candidate and any gate fails:\n               decision = \"BLOCKED\"\n               stop_blocked = true\n               stopReason = \"blockedStop\"\n               blocked_by_json = JSON array of failing gate names (always include \"claimAdjudicationGate\" when claim_adjudication_gate_pass == false, \"fixCompletenessReplayGate\" when fix_completeness_replay_gate_pass == false, \"candidateCoverageGate\" when candidate_coverage_gate_pass == false, and \"graphlessFallbackGate\" when graphless_fallback_gate_pass == false)\n               blocked_by_csv = comma-separated list of failing gate names\n               convergence_gate_pass = boolean\n               convergence_gate_score = numeric convergence score\n               dimension_coverage_gate_pass = boolean\n               dimension_coverage_gate_covered_json = JSON array of covered review dimensions","lineStart":1,"lineEnd":634,"totalLines":635,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1784210482143,"end":1784210482158}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204d08194b501d6b67101948c"}},"id":"prt_f6b3b63cb001W3hzmrI3FcAAzH","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482270,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_wSvlH412uamzASeQ5eVbTXtN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/quick_reference.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/quick_reference.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Quick Reference\n3: description: One-page cheat sheet for the autonomous deep review loop.\n4: trigger_phrases:\n5:   - \"deep review quick reference\"\n6:   - \"review loop cheat sheet\"\n7:   - \"p0 p1 p2 severity ladder\"\n8:   - \"release readiness verdicts\"\n9:   - \"review loop troubleshooting\"\n10: importance_tier: normal\n11: contextType: general\n12: version: 1.11.0.16\n13: ---\n14: \n15: # Deep Review Quick Reference\n16: \n17: One-page cheat sheet for the autonomous deep review loop.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: ### Purpose\n24: \n25: Use this quick reference when you need the command shape, artifact names, convergence rules, and synthesis outputs for the autonomous deep-review loop without loading the full protocol references.\n26: \n27: ### When to Use\n28: \n29: - Looking up the canonical `/deep:review` invocation without re-reading the full SKILL.md.\n30: - Confirming default thresholds, verdicts, or release-readiness states at a glance.\n31: - Refreshing the artifact-name and packet-file checklist before a manual orchestration pass.\n32: - Triaging a stuck loop and need the fastest path to convergence semantics.\n33: \n34: ### Commands\n35: \n36: | Command | Description |\n37: |---------|-------------|\n38: | `/deep:review:auto \"target\"` | Run autonomous review (no approval gates) |\n39: | `/deep:review:confirm \"target\"` | Run review with approval gates at each iteration |\n40: | `/deep:review \"target\"` | Ask which mode to use |\n41: \n42: ### Parameters\n43: \n44: | Parameter | Default | Description |\n45: |-----------|---------|-------------|\n46: | `--max-iterations` | 7 | Maximum review iterations |\n47: | `--convergence` | 0.10 | Base sensitivity for review convergence |\n48: | `--stop-policy` | convergence | Use `max-iterations` when convergence must not end the run before the iteration ceiling |\n49: | `--spec-folder` | auto | Target spec folder path |\n50: | `--restart` | off | Archive the current review packet and start a fresh lineage |\n51: | `--severity-threshold` | P2 | Minimum severity to report |\n52: \n53: ---\n54: \n55: ## 2. WHEN TO USE\n56: \n57: | Scenario | Use |\n58: |----------|-----|\n59: | Multi-pass code quality audit | `/deep:review` |\n60: | Simple single-pass code review | `sk-code` (code-review mode) |\n61: | Pre-release readiness check | `/deep:review:auto \"spec folder\"` |\n62: | Spec/implementation alignment check | `/deep:review:auto \"skill sk-name\"` |\n63: | Deep technical investigation | `/deep:research` (different skill) |\n64: \n65: ---\n66: \n67: ## 3. ARCHITECTURE\n68: \n69: ```\n70: /deep:review  -->  YAML workflow  -->  @deep-review agent (LEAF)\n71:     |                    |                      |\n72:     |                    |                      +-- Read state\n73:     |                    |                      +-- Review (3-5 actions)\n74:     |                    |                      +-- Write findings (P0/P1/P2)\n75:     |                    |                      +-- Update state\n76:     |                    |\n77:     |                    +-- Init (config, strategy, state)\n78:     |                    +-- Loop (dispatch, evaluate, decide)\n79:     |                    +-- Synthesize (review-report.md)\n80:     |                    +-- Save (memory context)\n81: ```\n82: \n83: ---\n84: \n85: ## 4. STATE FILES\n86: \n87: Review mode stores its packet under the resolved local review path rooted at `{spec_folder}/review/`:\n88: \n89: | File | Location | Format | Purpose |\n90: |------|----------|--------|---------|\n91: | Config | `review/deep-review-config.json` | JSON | Review parameters (immutable) |\n92: | State | `review/deep-review-state.jsonl` | JSONL | Iteration log (append-only) |\n93: | Registry | `review/deep-review-findings-registry.json` | JSON | Reducer-owned finding registry |\n94: | Strategy | `review/deep-review-strategy.md` | Markdown | Dimensions, findings, next focus |\n95: | Dashboard | `review/deep-review-dashboard.md` | Markdown | Auto-generated review dashboard |\n96: | Iterations | `review/iterations/iteration-NNN.md` | Markdown | Per-iteration findings (write-once) |\n97: | Report | `review/review-report.md` | Markdown | Final 9-section review report |\n98: | Pause | `review/.deep-review-pause` | Sentinel | Pause between iterations |\n99: \n100: ### Lifecycle Modes\n101: \n102: | Mode | Effect |\n103: |------|--------|\n104: | `resume` | Continue the current review lineage without resetting generation |\n105: | `restart` | Archive current review state and start a new generation |\n106: | `fork` (deferred) | Reserved. Start a sibling lineage branch with explicit parent linkage. Not runtime-wired. |\n107: | `completed-continue` (deferred) | Reserved. Snapshot the completed review and reopen it for amendment-only review deltas. Not runtime-wired. |\n108: \n109: ---\n110: \n111: ## 5. REVIEW DIMENSIONS\n112: \n113: | ID | Dimension | Priority | Description |\n114: |----|-----------|----------|-------------|\n115: | D1 | Correctness | 1 | Logic errors, off-by-one, wrong return types, broken invariants |\n116: | D2 | Security | 2 | Injection, auth bypass, secrets exposure, unsafe deserialization |\n117: | D3 | Traceability | 3 | Spec/code alignment, checklist evidence, cross-reference integrity |\n118: | D4 | Maintainability | 4 | Patterns, clarity, documentation quality, ease of safe follow-on changes |\n119: \n120: ---\n121: \n122: ## 6. REVIEW VERDICTS\n123: \n124: | Verdict | Condition | Meaning | Next Command |\n125: |---------|-----------|---------|--------------|\n126: | FAIL | Active P0 findings remain OR any binary gate fails | Does not meet quality standards | `/speckit:plan` for remediation |\n127: | CONDITIONAL | No P0, but active P1 findings remain | Meets threshold but has required fixes | `/speckit:plan` for fixes |\n128: | PASS | No active P0/P1 findings | Shippable, set `hasAdvisories=true` when P2 findings remain | `/create:changelog` |\n129: \n130: ### Release Readiness\n131: \n132: `releaseReadinessState` is the canonical config/report field for review readiness tracking.\n133: \n134: | State | Meaning |\n135: |-------|---------|\n136: | `in-progress` | Review still running or required coverage incomplete |\n137: | `converged` | All 4 dimensions covered and the stabilization pass found no new P0/P1 findings |\n138: | `release-blocking` | At least one unresolved P0 remains active |\n139: \n140: ---\n141: \n142: ## 7. REVIEW QUALITY GUARDS\n143: \n144: | Gate | Rule |\n145: |------|------|\n146: | Evidence | Every active finding has file:line evidence and is not inference-only |\n147: | Scope | Findings and reviewed files stay within declared review scope |\n148: | Coverage | Configured dimensions plus required traceability protocols are covered before STOP |\n149: \n150: ---\n151: \n152: ## 8. REVIEW CONVERGENCE\n153: \n154: | Signal | Weight | Description |\n155: |--------|--------|-------------|\n156: | Rolling Average | 0.30 | Last 2 severity-weighted `newFindingsRatio` values average below `0.08` |\n157: | MAD Noise Floor | 0.25 | Latest ratio within noise floor |\n158: | Dimension Coverage | 0.45 | All 4 dimensions plus required traceability protocols covered, with `minStabilizationPasses >= 1` |\n159: \n160: **Key defaults:** `maxIterations=7`, `convergenceThreshold=0.10`, `rollingStopThreshold=0.08`, `noProgressThreshold=0.05`, `stuckThreshold=2`, `minStabilizationPasses=1`\n161: \n162: **P0 override:** Any new P0 finding sets `newFindingsRatio >= 0.50`, blocking convergence.\n163: \n164: ---\n165: \n166: ## 9. AGENT ITERATION CHECKLIST\n167: \n168: Each @deep-review iteration:\n169: 1. Read `deep-review-state.jsonl`, `deep-review-findings-registry.json`, and `deep-review-strategy.md`\n170: 2. Determine focus dimension from strategy \"Next Focus\"\n171: 3. Execute 3-5 review actions (Read, Grep, Glob, code_graph_query + Grep)\n172: 4. Write `review/iterations/iteration-NNN.md` with P0/P1/P2 findings\n173: 5. Run adversarial self-check on any P0 findings (Hunter/Skeptic/Referee)\n174: 6. Update `deep-review-strategy.md` (findings, coverage, next focus)\n175: 7. Append iteration record to `deep-review-state.jsonl`\n176: \n177: ---\n178: \n179: ## 10. REVIEW REPORT SECTIONS\n180: \n181: | # | Section | Purpose |\n182: |---|---------|---------|\n183: | 1 | Executive Summary | Verdict, active P0/P1/P2 counts, scope, `hasAdvisories` |\n184: | 2 | Planning Trigger | Why the verdict routes to planning or changelog follow-up |\n185: | 3 | Active Finding Registry | Deduped active findings with evidence and final severity |\n186: | 4 | Remediation Workstreams | Grouped action lanes derived from active findings |\n187: | 5 | Spec Seed | Minimal spec delta derived from review results |\n188: | 6 | Plan Seed | Action-ready plan starter for remediation |\n189: | 7 | Traceability Status | Core vs overlay protocol status and unresolved gaps |\n190: | 8 | Deferred Items | P2 advisories, blocked checks, and follow-up items |\n191: | 9 | Audit Appendix | Coverage, replay validation, and convergence evidence |\n192: \n193: ---\n194: \n195: ## 11. TUNING GUIDE\n196: \n197: | Goal | Adjustment |\n198: |------|------------|\n199: | Deeper review | Lower convergence (0.05), raise max iterations (10) |\n200: | Forced iteration ceiling | Set `--stop-policy=max-iterations` with the desired `--max-iterations` |\n201: | Faster completion | Raise convergence (0.15), lower max iterations (5) |\n202: | Focus on security | Specify `--dimensions security,correctness` |\n203: | Broad coverage | Use all 4 default dimensions and allow the stabilization pass to run |\n204: \n205: ---\n206: \n207: ## 12. TROUBLESHOOTING\n208: \n209: | Problem | Fix |\n210: |---------|-----|\n211: | Stops too early | Lower `--convergence` from 0.10 to 0.05, or use `--stop-policy=max-iterations` when early convergence is unacceptable |\n212: | Stuck on one dimension | Check strategy.md \"Next Focus\" rotation |\n213: | P0 findings blocking convergence | Expected behavior: P0 override prevents premature stop |\n214: | Review-report missing sections | Verify synthesis phase completed (check state.jsonl for synthesis event) |\n215: | Agent ignores state | Verify file paths in dispatch prompt |\n216: \n217: ---\n218: \n219: ## 13. RELATED\n220: \n221: | Resource | Purpose |\n222: |----------|---------|\n223: | `deep-research` | Investigation/research (not review) |\n224: | `sk-code` (code-review mode) | Single-pass code review |\n225: | `@deep-review` | Single review iteration agent (LEAF) |\n226: | `@context` | Single-pass codebase search |\n227: | `generate-context.js` | Memory save script |\n228: \n229: For review-specific protocol documentation, see local `references/`:\n230: - `loop_protocol.md`, Review loop lifecycle (4 phases)\n231: - `../state/state_format.md`, Review state file schemas\n232: - `../convergence/convergence.md`, Review convergence algorithms\n\n(End of file - total 232 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Quick Reference\ndescription: One-page cheat sheet for the autonomous deep review loop.\ntrigger_phrases:\n  - \"deep review quick reference\"\n  - \"review loop cheat sheet\"\n  - \"p0 p1 p2 severity ladder\"\n  - \"release readiness verdicts\"\n  - \"review loop troubleshooting\"\nimportance_tier: normal\ncontextType: general\nversion: 1.11.0.16\n---\n\n# Deep Review Quick Reference\n\nOne-page cheat sheet for the autonomous deep review loop.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/quick_reference.md","text":"---\ntitle: Deep Review Quick Reference\ndescription: One-page cheat sheet for the autonomous deep review loop.\ntrigger_phrases:\n  - \"deep review quick reference\"\n  - \"review loop cheat sheet\"\n  - \"p0 p1 p2 severity ladder\"\n  - \"release readiness verdicts\"\n  - \"review loop troubleshooting\"\nimportance_tier: normal\ncontextType: general\nversion: 1.11.0.16\n---\n\n# Deep Review Quick Reference\n\nOne-page cheat sheet for the autonomous deep review loop.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nUse this quick reference when you need the command shape, artifact names, convergence rules, and synthesis outputs for the autonomous deep-review loop without loading the full protocol references.\n\n### When to Use\n\n- Looking up the canonical `/deep:review` invocation without re-reading the full SKILL.md.\n- Confirming default thresholds, verdicts, or release-readiness states at a glance.\n- Refreshing the artifact-name and packet-file checklist before a manual orchestration pass.\n- Triaging a stuck loop and need the fastest path to convergence semantics.\n\n### Commands\n\n| Command | Description |\n|---------|-------------|\n| `/deep:review:auto \"target\"` | Run autonomous review (no approval gates) |\n| `/deep:review:confirm \"target\"` | Run review with approval gates at each iteration |\n| `/deep:review \"target\"` | Ask which mode to use |\n\n### Parameters\n\n| Parameter | Default | Description |\n|-----------|---------|-------------|\n| `--max-iterations` | 7 | Maximum review iterations |\n| `--convergence` | 0.10 | Base sensitivity for review convergence |\n| `--stop-policy` | convergence | Use `max-iterations` when convergence must not end the run before the iteration ceiling |\n| `--spec-folder` | auto | Target spec folder path |\n| `--restart` | off | Archive the current review packet and start a fresh lineage |\n| `--severity-threshold` | P2 | Minimum severity to report |\n\n---\n\n## 2. WHEN TO USE\n\n| Scenario | Use |\n|----------|-----|\n| Multi-pass code quality audit | `/deep:review` |\n| Simple single-pass code review | `sk-code` (code-review mode) |\n| Pre-release readiness check | `/deep:review:auto \"spec folder\"` |\n| Spec/implementation alignment check | `/deep:review:auto \"skill sk-name\"` |\n| Deep technical investigation | `/deep:research` (different skill) |\n\n---\n\n## 3. ARCHITECTURE\n\n```\n/deep:review  -->  YAML workflow  -->  @deep-review agent (LEAF)\n    |                    |                      |\n    |                    |                      +-- Read state\n    |                    |                      +-- Review (3-5 actions)\n    |                    |                      +-- Write findings (P0/P1/P2)\n    |                    |                      +-- Update state\n    |                    |\n    |                    +-- Init (config, strategy, state)\n    |                    +-- Loop (dispatch, evaluate, decide)\n    |                    +-- Synthesize (review-report.md)\n    |                    +-- Save (memory context)\n```\n\n---\n\n## 4. STATE FILES\n\nReview mode stores its packet under the resolved local review path rooted at `{spec_folder}/review/`:\n\n| File | Location | Format | Purpose |\n|------|----------|--------|---------|\n| Config | `review/deep-review-config.json` | JSON | Review parameters (immutable) |\n| State | `review/deep-review-state.jsonl` | JSONL | Iteration log (append-only) |\n| Registry | `review/deep-review-findings-registry.json` | JSON | Reducer-owned finding registry |\n| Strategy | `review/deep-review-strategy.md` | Markdown | Dimensions, findings, next focus |\n| Dashboard | `review/deep-review-dashboard.md` | Markdown | Auto-generated review dashboard |\n| Iterations | `review/iterations/iteration-NNN.md` | Markdown | Per-iteration findings (write-once) |\n| Report | `review/review-report.md` | Markdown | Final 9-section review report |\n| Pause | `review/.deep-review-pause` | Sentinel | Pause between iterations |\n\n### Lifecycle Modes\n\n| Mode | Effect |\n|------|--------|\n| `resume` | Continue the current review lineage without resetting generation |\n| `restart` | Archive current review state and start a new generation |\n| `fork` (deferred) | Reserved. Start a sibling lineage branch with explicit parent linkage. Not runtime-wired. |\n| `completed-continue` (deferred) | Reserved. Snapshot the completed review and reopen it for amendment-only review deltas. Not runtime-wired. |\n\n---\n\n## 5. REVIEW DIMENSIONS\n\n| ID | Dimension | Priority | Description |\n|----|-----------|----------|-------------|\n| D1 | Correctness | 1 | Logic errors, off-by-one, wrong return types, broken invariants |\n| D2 | Security | 2 | Injection, auth bypass, secrets exposure, unsafe deserialization |\n| D3 | Traceability | 3 | Spec/code alignment, checklist evidence, cross-reference integrity |\n| D4 | Maintainability | 4 | Patterns, clarity, documentation quality, ease of safe follow-on changes |\n\n---\n\n## 6. REVIEW VERDICTS\n\n| Verdict | Condition | Meaning | Next Command |\n|---------|-----------|---------|--------------|\n| FAIL | Active P0 findings remain OR any binary gate fails | Does not meet quality standards | `/speckit:plan` for remediation |\n| CONDITIONAL | No P0, but active P1 findings remain | Meets threshold but has required fixes | `/speckit:plan` for fixes |\n| PASS | No active P0/P1 findings | Shippable, set `hasAdvisories=true` when P2 findings remain | `/create:changelog` |\n\n### Release Readiness\n\n`releaseReadinessState` is the canonical config/report field for review readiness tracking.\n\n| State | Meaning |\n|-------|---------|\n| `in-progress` | Review still running or required coverage incomplete |\n| `converged` | All 4 dimensions covered and the stabilization pass found no new P0/P1 findings |\n| `release-blocking` | At least one unresolved P0 remains active |\n\n---\n\n## 7. REVIEW QUALITY GUARDS\n\n| Gate | Rule |\n|------|------|\n| Evidence | Every active finding has file:line evidence and is not inference-only |\n| Scope | Findings and reviewed files stay within declared review scope |\n| Coverage | Configured dimensions plus required traceability protocols are covered before STOP |\n\n---\n\n## 8. REVIEW CONVERGENCE\n\n| Signal | Weight | Description |\n|--------|--------|-------------|\n| Rolling Average | 0.30 | Last 2 severity-weighted `newFindingsRatio` values average below `0.08` |\n| MAD Noise Floor | 0.25 | Latest ratio within noise floor |\n| Dimension Coverage | 0.45 | All 4 dimensions plus required traceability protocols covered, with `minStabilizationPasses >= 1` |\n\n**Key defaults:** `maxIterations=7`, `convergenceThreshold=0.10`, `rollingStopThreshold=0.08`, `noProgressThreshold=0.05`, `stuckThreshold=2`, `minStabilizationPasses=1`\n\n**P0 override:** Any new P0 finding sets `newFindingsRatio >= 0.50`, blocking convergence.\n\n---\n\n## 9. AGENT ITERATION CHECKLIST\n\nEach @deep-review iteration:\n1. Read `deep-review-state.jsonl`, `deep-review-findings-registry.json`, and `deep-review-strategy.md`\n2. Determine focus dimension from strategy \"Next Focus\"\n3. Execute 3-5 review actions (Read, Grep, Glob, code_graph_query + Grep)\n4. Write `review/iterations/iteration-NNN.md` with P0/P1/P2 findings\n5. Run adversarial self-check on any P0 findings (Hunter/Skeptic/Referee)\n6. Update `deep-review-strategy.md` (findings, coverage, next focus)\n7. Append iteration record to `deep-review-state.jsonl`\n\n---\n\n## 10. REVIEW REPORT SECTIONS\n\n| # | Section | Purpose |\n|---|---------|---------|\n| 1 | Executive Summary | Verdict, active P0/P1/P2 counts, scope, `hasAdvisories` |\n| 2 | Planning Trigger | Why the verdict routes to planning or changelog follow-up |\n| 3 | Active Finding Registry | Deduped active findings with evidence and final severity |\n| 4 | Remediation Workstreams | Grouped action lanes derived from active findings |\n| 5 | Spec Seed | Minimal spec delta derived from review results |\n| 6 | Plan Seed | Action-ready plan starter for remediation |\n| 7 | Traceability Status | Core vs overlay protocol status and unresolved gaps |\n| 8 | Deferred Items | P2 advisories, blocked checks, and follow-up items |\n| 9 | Audit Appendix | Coverage, replay validation, and convergence evidence |\n\n---\n\n## 11. TUNING GUIDE\n\n| Goal | Adjustment |\n|------|------------|\n| Deeper review | Lower convergence (0.05), raise max iterations (10) |\n| Forced iteration ceiling | Set `--stop-policy=max-iterations` with the desired `--max-iterations` |\n| Faster completion | Raise convergence (0.15), lower max iterations (5) |\n| Focus on security | Specify `--dimensions security,correctness` |\n| Broad coverage | Use all 4 default dimensions and allow the stabilization pass to run |\n\n---\n\n## 12. TROUBLESHOOTING\n\n| Problem | Fix |\n|---------|-----|\n| Stops too early | Lower `--convergence` from 0.10 to 0.05, or use `--stop-policy=max-iterations` when early convergence is unacceptable |\n| Stuck on one dimension | Check strategy.md \"Next Focus\" rotation |\n| P0 findings blocking convergence | Expected behavior: P0 override prevents premature stop |\n| Review-report missing sections | Verify synthesis phase completed (check state.jsonl for synthesis event) |\n| Agent ignores state | Verify file paths in dispatch prompt |\n\n---\n\n## 13. RELATED\n\n| Resource | Purpose |\n|----------|---------|\n| `deep-research` | Investigation/research (not review) |\n| `sk-code` (code-review mode) | Single-pass code review |\n| `@deep-review` | Single review iteration agent (LEAF) |\n| `@context` | Single-pass codebase search |\n| `generate-context.js` | Memory save script |\n\nFor review-specific protocol documentation, see local `references/`:\n- `loop_protocol.md`, Review loop lifecycle (4 phases)\n- `../state/state_format.md`, Review state file schemas\n- `../convergence/convergence.md`, Review convergence algorithms","lineStart":1,"lineEnd":232,"totalLines":232,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/protocol/quick_reference.md","time":{"start":1784210482221,"end":1784210482236}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204e081948d7825af8b73093e"}},"id":"prt_f6b3b641a0012GW007zFQx9ju5","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482293,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_MB1BJJico858Ck6JWPz7yN9d","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence_signals.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence_signals.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Deep Review Convergence Signals\"\n3: description: \"Focused reference for severity-weighted stop signals, P0 overrides, quality gates, and graph-aware blocked-stop checks.\"\n4: trigger_phrases:\n5:   - \"deep review convergence signals\"\n6:   - \"review stop signals\"\n7:   - \"severity weighted convergence\"\n8:   - \"review blocked stop\"\n9: importance_tier: normal\n10: contextType: implementation\n11: version: 1.11.0.3\n12: ---\n13: \n14: # Deep Review Convergence Signals\n15: \n16: This reference names the live stop signals. Use `references/convergence/convergence.md` as the hub when you need algorithms, examples, and sibling threshold notes.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: Deep-review convergence is a release-readiness decision. The loop stops only when severity-weighted findings stabilize, dimension coverage is complete, quality gates pass, and no P0 override is active.\n23: \n24: ---\n25: \n26: ## 2. SIGNALS\n27: \n28: | Signal | Meaning | Blocks STOP When |\n29: |--------|---------|------------------|\n30: | Severity-weighted new findings | Weighted P0/P1/P2 discovery ratio for the latest iteration | Above the configured threshold |\n31: | Rolling stop average | Stabilized trend across recent iterations | Still above the stop band |\n32: | Dimension coverage | Required review dimensions and traceability overlays covered | Any required dimension is missing |\n33: | Quality-gate bundle | Evidence, scope, coverage, P0, density, hotspot, claim, candidate, graphless gates | Any required gate fails |\n34: | Graph-aware blind spot check | Coverage graph sees unresolved structural gaps | Graph blockers remain active |\n35: \n36: ---\n37: \n38: ## 3. P0 OVERRIDE\n39: \n40: Any new P0 forces at least one more iteration. The override exists because a new blocker changes the release verdict, even if the rest of the stop math appears stable.\n41: \n42: P0 handling requires:\n43: \n44: - File and line evidence.\n45: - Adversarial self-check.\n46: - Active registry update.\n47: - Replay in synthesis before PASS is legal.\n48: \n49: ---\n50: \n51: ## 4. LEGAL STOP\n52: \n53: STOP is legal only when all of these are true:\n54: \n55: 1. New findings are below threshold.\n56: 2. Rolling trend is stable.\n57: 3. All required dimensions are covered.\n58: 4. The quality-gate bundle passes.\n59: 5. No unresolved P0 remains.\n60: 6. Graph-aware blockers are absent or explicitly unavailable with fallback evidence.\n61: \n62: If any item fails, the workflow emits `blocked_stop` and continues or routes to recovery.\n63: \n64: ---\n65: \n66: ## 5. SIBLING CONTRAST\n67: \n68: Do not carry thresholds across deep skills:\n69: \n70: | Skill | Primary Signal | Default Threshold |\n71: |-------|----------------|-------------------|\n72: | `deep-review` | Severity-weighted P0/P1/P2 new findings | `0.10` |\n73: | `deep-research` | Novelty/newInfoRatio over research knowledge | `0.05` |\n74: | `deep-ai-council` | Planning agreement with critique blocker check | Council-specific, not interchangeable |\n75: \n76: ---\n77: \n78: ## 6. RELATED RESOURCES\n79: \n80: - `references/convergence/convergence.md` for the full stop contract.\n81: - `references/state/state_outputs.md` for dashboard and report fields that display convergence.\n82: - `references/state/state_reducer_registry.md` for reducer-owned gate state.\n\n(End of file - total 82 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Deep Review Convergence Signals\"\ndescription: \"Focused reference for severity-weighted stop signals, P0 overrides, quality gates, and graph-aware blocked-stop checks.\"\ntrigger_phrases:\n  - \"deep review convergence signals\"\n  - \"review stop signals\"\n  - \"severity weighted convergence\"\n  - \"review blocked stop\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.11.0.3\n---\n\n# Deep Review Convergence Signals\n\nThis reference names the live stop signals. Use `references/convergence/convergence.md` as the hub when you need algorithms, examples, and sibling threshold notes.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence_signals.md","text":"---\ntitle: \"Deep Review Convergence Signals\"\ndescription: \"Focused reference for severity-weighted stop signals, P0 overrides, quality gates, and graph-aware blocked-stop checks.\"\ntrigger_phrases:\n  - \"deep review convergence signals\"\n  - \"review stop signals\"\n  - \"severity weighted convergence\"\n  - \"review blocked stop\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.11.0.3\n---\n\n# Deep Review Convergence Signals\n\nThis reference names the live stop signals. Use `references/convergence/convergence.md` as the hub when you need algorithms, examples, and sibling threshold notes.\n\n---\n\n## 1. OVERVIEW\n\nDeep-review convergence is a release-readiness decision. The loop stops only when severity-weighted findings stabilize, dimension coverage is complete, quality gates pass, and no P0 override is active.\n\n---\n\n## 2. SIGNALS\n\n| Signal | Meaning | Blocks STOP When |\n|--------|---------|------------------|\n| Severity-weighted new findings | Weighted P0/P1/P2 discovery ratio for the latest iteration | Above the configured threshold |\n| Rolling stop average | Stabilized trend across recent iterations | Still above the stop band |\n| Dimension coverage | Required review dimensions and traceability overlays covered | Any required dimension is missing |\n| Quality-gate bundle | Evidence, scope, coverage, P0, density, hotspot, claim, candidate, graphless gates | Any required gate fails |\n| Graph-aware blind spot check | Coverage graph sees unresolved structural gaps | Graph blockers remain active |\n\n---\n\n## 3. P0 OVERRIDE\n\nAny new P0 forces at least one more iteration. The override exists because a new blocker changes the release verdict, even if the rest of the stop math appears stable.\n\nP0 handling requires:\n\n- File and line evidence.\n- Adversarial self-check.\n- Active registry update.\n- Replay in synthesis before PASS is legal.\n\n---\n\n## 4. LEGAL STOP\n\nSTOP is legal only when all of these are true:\n\n1. New findings are below threshold.\n2. Rolling trend is stable.\n3. All required dimensions are covered.\n4. The quality-gate bundle passes.\n5. No unresolved P0 remains.\n6. Graph-aware blockers are absent or explicitly unavailable with fallback evidence.\n\nIf any item fails, the workflow emits `blocked_stop` and continues or routes to recovery.\n\n---\n\n## 5. SIBLING CONTRAST\n\nDo not carry thresholds across deep skills:\n\n| Skill | Primary Signal | Default Threshold |\n|-------|----------------|-------------------|\n| `deep-review` | Severity-weighted P0/P1/P2 new findings | `0.10` |\n| `deep-research` | Novelty/newInfoRatio over research knowledge | `0.05` |\n| `deep-ai-council` | Planning agreement with critique blocker check | Council-specific, not interchangeable |\n\n---\n\n## 6. RELATED RESOURCES\n\n- `references/convergence/convergence.md` for the full stop contract.\n- `references/state/state_outputs.md` for dashboard and report fields that display convergence.\n- `references/state/state_reducer_registry.md` for reducer-owned gate state.","lineStart":1,"lineEnd":82,"totalLines":82,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/convergence/convergence_signals.md","time":{"start":1784210482250,"end":1784210482280}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204f48194ae02b287088673cd"}},"id":"prt_f6b3b6446001hG71nsw0V3rwdx","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482293,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_PWAfsIWBy0Lbk8SLfPnjYZDM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_format.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_format.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review State Format\n3: description: State file schemas for the autonomous deep review loop, config, JSONL log, strategy, iteration files, and review report.\n4: trigger_phrases:\n5:   - \"deep review state format\"\n6:   - \"deep review config schema\"\n7:   - \"review severity weights\"\n8:   - \"file protection levels\"\n9:   - \"review iteration file structure\"\n10: importance_tier: important\n11: contextType: implementation\n12: version: 1.11.0.28\n13: ---\n14: \n15: # Deep Review State Format\n16: \n17: State file schemas for the autonomous deep review loop.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: The deep review loop uses 8 state files under the resolved `{artifact_dir}/` owned by the target spec:\n24: \n25: | File | Format | Mutability |\n26: |------|--------|------------|\n27: | `deep-review-config.json` | JSON | Immutable after init |\n28: | `deep-review-state.jsonl` | JSON Lines | Append-only |\n29: | `deep-review-findings-registry.json` | JSON | Auto-generated reducer state |\n30: | `deep-review-strategy.md` | Markdown | Updated each iteration |\n31: | `deep-review-dashboard.md` | Markdown | Auto-generated (read-only) |\n32: | `.deep-review-pause` | Sentinel | Created/deleted by user |\n33: | `review-report.md` | Markdown | Updated at synthesis |\n34: | `iterations/iteration-NNN.md` | Markdown | Write-once |\n35: \n36: ```text\n37: {artifact_dir}/\n38:   deep-review-config.json\n39:   deep-review-state.jsonl\n40:   deep-review-findings-registry.json\n41:   deep-review-strategy.md\n42:   deep-review-dashboard.md\n43:   .deep-review-pause\n44:   review-report.md\n45:   iterations/\n46:     iteration-001.md\n47:     iteration-002.md\n48:     ...\n49: ```\n50: \n51: `{artifact_dir}` comes from `resolveArtifactRoot(specFolder, 'review')`. Root-spec runs resolve directly to `{spec_folder}/review/`. Child-phase and sub-phase runs use **flat-first**: a first run with an empty `review/` resolves directly to `{spec_folder}/review/` (no `pt-NN` wrapper). A `pt-NN` packet is allocated only when prior content for a non-matching target already exists. Continuation runs reuse the existing flat artifact (or matching `pt-NN` packet). This avoids the unnecessary `pt-01` wrapper on first runs.\n52: \n53: Example (first run on a child phase): `.../026-graph.../006-continuity-refactor-gates/003-gate-c-writer-ready/` → `003-gate-c-writer-ready/review/` (flat, no subfolder).\n54: \n55: Example (subsequent run with prior content for a different target): `003-gate-c-writer-ready/review/003-gate-c-writer-ready-pt-02/` (`pt-NN` allocated as a sibling to the prior content; subfolder name is `{basename(spec_folder)}-pt-{NN}`).\n56: \n57: ### When to Use\n58: \n59: - Validating deep-review state files emitted by an iteration or by the reducer.\n60: - Implementing a state consumer (e.g. dashboard, advisor probe, downstream packet).\n61: - Debugging JSONL reducer output or auditing schema-version transitions.\n62: - Authoring fixtures that need to round-trip through the reducer.\n63: \n64: ---\n65: \n66: ## 2. CONFIG FILE (deep-review-config.json)\n67: \n68: Created during initialization. Not modified after creation.\n69: \n70: ```json\n71: {\n72:   \"topic\": \"Review of deep-review skill package\",\n73:   \"mode\": \"review\",\n74:   \"reviewTarget\": \"specs/030-deep-review-review-mode\",\n75:   \"reviewTargetType\": \"spec-folder\",\n76:   \"reviewDimensions\": [\"correctness\", \"security\", \"traceability\", \"maintainability\"],\n77:   \"resource_map_present\": false,\n78:   \"sessionId\": \"rvw-2026-04-03T12-00-00Z\",\n79:   \"parentSessionId\": null,\n80:   \"lineageMode\": \"new\",\n81:   \"generation\": 1,\n82:   \"continuedFromRun\": null,\n83:   \"maxIterations\": 7,\n84:   \"convergenceThreshold\": 0.10,\n85:   \"stuckThreshold\": 2,\n86:   \"severityThreshold\": \"P2\",\n87:   \"crossReference\": {\n88:     \"core\": [\"spec_code\", \"checklist_evidence\"],\n89:     \"overlay\": [\"feature_catalog_code\", \"playbook_capability\"]\n90:   },\n91:   \"qualityGateThreshold\": true,\n92:   \"releaseReadinessState\": \"in-progress\",\n93:   \"specFolder\": \"030-deep-review-review-mode\",\n94:   \"createdAt\": \"2026-03-24T14:00:00Z\",\n95:   \"status\": \"initialized\",\n96:   \"executionMode\": \"auto\",\n97:   \"fileProtection\": {\n98:     \"deep-review-config.json\": \"immutable\",\n99:     \"deep-review-state.jsonl\": \"append-only\",\n100:     \"deep-review-findings-registry.json\": \"auto-generated\",\n101:     \"deep-review-strategy.md\": \"mutable\",\n102:     \"deep-review-dashboard.md\": \"auto-generated\",\n103:     \".deep-review-pause\": \"operator-controlled\",\n104:     \"review-report.md\": \"mutable\",\n105:     \"review-report-v*.md\": \"write-once\",\n106:     \"iteration-*.md\": \"write-once\"\n107:   },\n108:   \"reducer\": {\n109:     \"enabled\": true,\n110:     \"inputs\": [\"latestJSONLDelta\", \"newIterationFile\", \"priorReducedState\"],\n111:     \"outputs\": [\"findingsRegistry\", \"dashboardMetrics\", \"strategyUpdates\"],\n112:     \"metrics\": [\n113:       \"dimensionsCovered\",\n114:       \"findingsBySeverity\",\n115:       \"openFindings\",\n116:       \"resolvedFindings\",\n117:       \"convergenceScore\"\n118:     ]\n119:   }\n120: }\n121: ```\n122: \n123: ### Field Reference\n124: \n125: | Field | Type | Default | Description |\n126: |-------|------|---------|-------------|\n127: | mode | `\"review\"` | -- | Session mode discriminator (required) |\n128: | reviewTarget | string | -- | Path or identifier of the review target |\n129: | reviewTargetType | string | `\"spec-folder\"` | `spec-folder`, `skill`, `agent`, `track`, `files` |\n130: | reviewDimensions | string[] | all 4 | Dimensions to evaluate |\n131: | resource_map_present | boolean | false | True only when `{specFolder}/resource-map.md` existed during init, enables the Resource Map Coverage audit pass and conditional report section |\n132: | sessionId | string | -- | Stable identifier for the current review lineage |\n133: | parentSessionId | string \\| null | `null` | Parent lineage reference for restart flows |\n134: | lineageMode | string | `\"new\"` | `new`, `resume`, `restart`. `fork` and `completed-continue` are deferred and not emitted by the current runtime |\n135: | generation | number | 1 | Lineage generation number, incremented on `restart`, unchanged on `resume` |\n136: | continuedFromRun | number \\| null | `null` | Count of completed iteration records at the lifecycle boundary (set on `resume` and `restart`) |\n137: | maxIterations | number | 7 | Hard cap on loop iterations |\n138: | convergenceThreshold | number | 0.10 | Stop when severity-weighted new findings ratio below this |\n139: | stuckThreshold | number | 2 | Consecutive no-progress iterations before recovery |\n140: | severityThreshold | string | `\"P2\"` | Minimum severity to report: `P0`, `P1`, `P2` |\n141: | crossReference | object | -- | Core (hard-gated) and overlay (advisory) protocol sets |\n142: | qualityGateThreshold | boolean | true | Whether binary quality gates are enforced |\n143: | specFolder | string | -- | Spec folder path (relative to specs/) |\n144: | status | string | `\"initialized\"` | `initialized`, `running`, `converged`, `stuck`, `complete`, `error` |\n145: | releaseReadinessState | string | `\"in-progress\"` | `in-progress`, `converged`, `release-blocking` |\n146: | fileProtection | object | -- | Mutability declarations (see protection levels below) |\n147: | reducer | object | -- | Canonical reducer inputs, outputs, and metrics names |\n148: \n149: ### File Protection Levels\n150: \n151: | Level | Meaning |\n152: |-------|---------|\n153: | immutable | Cannot be modified after creation |\n154: | append-only | New content added at end only |\n155: | mutable | Can be read, edited, overwritten |\n156: | write-once | Created once, never modified |\n157: | auto-generated | System-managed, overwritten each refresh |\n158: | operator-controlled | Created or deleted only by the human/operator to control loop state |\n159: \n160: ### Review Dimensions\n161: \n162: | Dimension | Priority | Required for Coverage |\n163: |-----------|----------|---------------------|\n164: | correctness | 1 | Yes |\n165: | security | 2 | Yes |\n166: | traceability | 3 | Yes |\n167: | maintainability | 4 | Yes |\n168: \n169: ### Severity Weights\n170: \n171: | Severity | Weight | Label | Requires file:line |\n172: |----------|--------|-------|--------------------|\n173: | P0 | 10.0 | Blocker | Yes |\n174: | P1 | 5.0 | Required | Yes |\n175: | P2 | 1.0 | Suggestion | Yes |\n176: \n177: ---\n178: \n179: ## 3. STATE LOG\n180: \n181: The `deep-review-state.jsonl` record schemas (config, iteration, event, lineage) and the Review Depth Schema (v2) live in `state_jsonl.md` for navigability.\n182: \n183: ---\n184: \n185: ## 4. STRATEGY FILE (deep-review-strategy.md)\n186: \n187: Updated at the end of each iteration. Serves as the persistent brain across fresh-context iterations.\n188: \n189: ### Required Sections\n190: \n191: | Section | Updated By | Purpose |\n192: |---------|-----------|---------|\n193: | topic | Init only | Review topic from config |\n194: | review-dimensions | Each iteration | Unchecked dimensions drive next focus |\n195: | completed-dimensions | Each iteration | Checked dimensions with verdict summary |\n196: | running-findings | Each iteration | P0/P1/P2 active counts + deltas |\n197: | what-worked | Each iteration | Successful approaches for reuse |\n198: | what-failed | Each iteration | Failed approaches to avoid |\n199: | exhausted-approaches | When fully tried | \"Do not retry\" registry |\n200: | ruled-out-directions | Each iteration | Eliminated directions with reasons |\n201: | next-focus | Each iteration | Recommended direction for next iteration |\n202: | known-context | Init only | Prior work from memory context |\n203: | cross-reference-status | Each iteration | Core vs overlay protocol status |\n204: | files-under-review | Each iteration | Per-file coverage state table |\n205: | review-boundaries | Init only | Max iterations, thresholds, config |\n206: \n207: ### Mapping from Research Mode\n208: \n209: | Review Section | Research Equivalent |\n210: |---------------|-------------------|\n211: | review-dimensions | Key Questions (remaining) |\n212: | completed-dimensions | Answered Questions |\n213: | running-findings | _(none, review-specific)_ |\n214: | cross-reference-status | _(none, review-specific)_ |\n215: | files-under-review | _(none, review-specific)_ |\n216: | review-boundaries | Research Boundaries |\n217: \n218: Sections unchanged from research: topic, what-worked, what-failed, exhausted-approaches, ruled-out-directions, next-focus, known-context.\n219: \n220: ### Update Protocol\n221: \n222: 1. Read current strategy file\n223: 2. Move completed dimensions from \"remaining\" to \"completed\" with `[x]` and verdict\n224: 3. Update running-findings with P0/P1/P2 counts and deltas\n225: 4. Add to what-worked / what-failed with iteration number\n226: 5. Move exhausted approaches. Update cross-reference-status and files-under-review\n227: 6. Set next-focus based on remaining dimensions and open findings\n228: \n229: ---\n230: \n231: ## 5. FINDINGS REGISTRY (deep-review-findings-registry.json)\n232: \n233: Reducer-owned JSON document regenerated after every iteration and lifecycle transition.\n234: \n235: ```json\n236: {\n237:   \"sessionId\": \"rvw-2026-04-03T12-00-00Z\",\n238:   \"generation\": 1,\n239:   \"lineageMode\": \"resume\",\n240:   \"openFindings\": [],\n241:   \"resolvedFindings\": [],\n242:   \"blockedStopHistory\": [],\n243:   \"persistentSameSeverity\": [],\n244:   \"severityChanged\": [],\n245:   \"repeatedFindings\": [],\n246:   \"dimensionCoverage\": {\n247:     \"correctness\": true,\n248:     \"security\": true,\n249:     \"traceability\": false,\n250:     \"maintainability\": false\n251:   },\n252:   \"findingsBySeverity\": {\n253:     \"P0\": 0,\n254:     \"P1\": 1,\n255:     \"P2\": 2\n256:   },\n257:   \"openFindingsCount\": 3,\n258:   \"resolvedFindingsCount\": 1,\n259:   \"convergenceScore\": 0.44,\n260:   \"graphConvergenceScore\": 1.01,\n261:   \"graphDecision\": \"STOP_ALLOWED\",\n262:   \"graphBlockers\": [],\n263:   \"corruptionWarnings\": []\n264: }\n265: ```\n266: \n267: This file is machine-owned and must stay synchronized with the latest iteration delta, dashboard metrics, and synthesized review report.\n268: \n269: ### Blocked-Stop and Corruption-Tracking Additions\n270: \n271: | Field | Type | Description |\n272: |-------|------|-------------|\n273: | `blockedStopHistory` | array | One entry per `blocked_stop` JSONL event: `{run, blockedBy, gateResults, recoveryStrategy, timestamp}`. Rendered in the dashboard `BLOCKED STOPS` section and can drive the strategy `next-focus` anchor when blocked-stop is the most recent loop event. |\n274: | `persistentSameSeverity` | array | Findings observed in ≥2 iterations with NO severity transitions beyond initial discovery. REQ-018 split of the deprecated `repeatedFindings` bucket. |\n275: | `severityChanged` | array | Findings that went through at least one severity transition (P0↔P1↔P2) in their `transitions` history. |\n276: | `repeatedFindings` | array | **Deprecated.** Union of `persistentSameSeverity` and `severityChanged`. Retained for backward compatibility, new code should read the split arrays. |\n277: | `corruptionWarnings` | array | Per-line corruption reports from `parseJsonlDetailed()`: `{line, raw, error}`. Non-empty means the reducer detected malformed JSONL. |\n278: \n279: ### Default Values\n280: \n281: When no `graph_convergence` event has been recorded yet, defaults are `graphConvergenceScore: 0`, `graphDecision: null`, and `graphBlockers: []`.\n282: When no `blocked_stop` event has been recorded yet, `blockedStopHistory: []`.\n283: When JSONL parses cleanly, `corruptionWarnings: []`.\n284: \n285: ### Fail-Closed Semantics (REQ-015, REQ-016)\n286: \n287: - **Malformed JSONL**: The reducer CLI exits with code `2` and writes a warning to stderr when `corruptionWarnings.length > 0`. Pass `--lenient` (or `lenient:true` to `reduceReviewState`) to escape-hatch out and preserve the v1.2.0.0 fail-open behavior for legacy packets.\n288: - **Missing machine-owned anchors**: `replaceAnchorSection()` throws `Error('Missing machine-owned anchor \"<id>\" in deep-review strategy file.')` when the strategy file is present but lacks one of the required anchors. Pass `--create-missing-anchors` (or `createMissingAnchors:true`) to bootstrap empty strategy files by appending the missing anchor blocks.\n289: - **Dashboard surfaces**: `CORRUPTION WARNINGS` section lists detected lines. `BLOCKED STOPS` section lists `blockedStopHistory` entries. `GRAPH CONVERGENCE` section reports `graphConvergenceScore` / `graphDecision` / `graphBlockers`.\n290: - **Strategy next-focus override**: When the latest `blocked_stop` event timestamp is newer than the latest iteration timestamp, the reducer rewrites the strategy `next-focus` anchor to surface the blocking gates and recovery hint so operators see the blocker before choosing the next iteration direction.\n291: \n292: ---\n293: \n294: ## 6. ITERATION FILES (review/iterations/iteration-NNN.md)\n295: \n296: Write-once files. One per iteration, zero-padded 3-digit naming.\n297: \n298: ### Structure\n299: \n300: ```markdown\n301: # Iteration [N]: [Focus Area]\n302: \n303: ## Focus\n304: [Dimension(s), files, scope investigated]\n305: \n306: ## Scorecard\n307: - Dimensions covered: [list]\n308: - Files reviewed: [count]\n309: - New findings: P0=[n] P1=[n] P2=[n]\n310: - Refined findings: P0=[n] P1=[n] P2=[n]\n311: - New findings ratio: [0.0-1.0]\n312: \n313: ## Findings\n314: \n315: ### P0, Blocker\n316: - **F[NNN]**: [Title], `file:line`, [Description with evidence]\n317: \n318: ### P1, Required\n319: - **F[NNN]**: [Title], `file:line`, [Description with evidence]\n320: \n321: ### P2, Suggestion\n322: - **F[NNN]**: [Title], `file:line`, [Description with evidence]\n323: \n324: ## Cross-Reference Results\n325: | Protocol | Status | Gate | Evidence | Notes |\n326: |----------|--------|------|----------|-------|\n327: | spec_code | pass/partial/fail | hard | file:line | ... |\n328: \n329: ## Assessment\n330: - New findings ratio: [0.0-1.0]\n331: - Dimensions addressed: [list]\n332: - Novelty justification: [breakdown]\n333: \n334: ## Ruled Out\n335: - [Approach]: [Why], [Evidence]\n336: \n337: ## Dead Ends\n338: - [Direction]: [Why]\n339: \n340: ## Recommended Next Focus\n341: [What to investigate next]\n342: ```\n343: \n344: Every finding must include: unique ID (`F001`...), severity (`P0`/`P1`/`P2`), concrete `file:line` evidence, and dimension tag.\n345: \n346: ---\n347: \n348: ## 7. REVIEW REPORT (review/review-report.md)\n349: \n350: The review synthesis output contains 9 core sections plus a conditional `## Resource Map Coverage Gate` section when `resource_map_present` is true:\n351: \n352: | # | Section | Description |\n353: |---|---------|-------------|\n354: | 1 | Executive Summary | Verdict, active P0/P1/P2 counts, scope, `hasAdvisories` flag |\n355: | 2 | Planning Trigger | Why result routes to planning or changelog |\n356: | 3 | Active Finding Registry | Deduped active findings with evidence, severity, dimension |\n357: | 4 | Remediation Workstreams | Ordered lanes grouped by dependency or area |\n358: | 5 | Spec Seed | Minimal spec updates implied by findings |\n359: | 6 | Plan Seed | Initial remediation tasks from findings |\n360: | 7 | Traceability Status | Core vs overlay protocol outcomes and gaps |\n361: | 8 | Resource Map Coverage Gate | Present only when `{spec_folder}/resource-map.md` existed at init, contains touched entries, untouched entries (`expected-by-scope` vs `gap`), and implementation paths absent from the map |\n362: | 9 | Deferred Items | Advisory findings, blocked items, follow-up checks |\n363: | 10 | Audit Appendix | Coverage, convergence replay, audit detail |\n364: \n365: **Executive Summary** includes verdict (`PASS`/`CONDITIONAL`/`FAIL`), active finding counts, `hasAdvisories` boolean (PASS + P2 > 0), scope description, and convergence reason.\n366: \n367: **Planning Trigger** routes FAIL/CONDITIONAL to remediation planning, PASS to changelog creation.\n368: \n369: **Active Finding Registry** lists each active finding with findingId, severity, dimension, title, file:line evidence, first/last seen iteration, and status.\n370: \n371: **Remediation Workstreams** group related findings into ordered lanes with constituent finding IDs and execution order.\n372: \n373: **Spec Seed / Plan Seed** provide minimal spec updates and initial remediation tasks referencing finding IDs and target files.\n374: \n375: **Traceability Status** reports per-protocol pass/partial/fail with gating class and evidence.\n376: \n377: **Resource Map Coverage Gate** is emitted only when `resource_map_present` is true and MUST contain exactly three bullets: touched entries, untouched entries (`expected-by-scope` vs `gap`), and implementation paths absent from the map.\n378: \n379: **Deferred Items** captures advisory findings, blocked protocols, and future follow-up checks.\n380: \n381: **Audit Appendix** contains iteration table, convergence signal replay, file coverage matrix, and dimension breakdown.\n382: \n383: ---\n384: \n385: ## 8. DASHBOARD (review/deep-review-dashboard.md)\n386: \n387: Auto-generated summary. Never manually edited.\n388: \n389: - **Path**: `{artifact_dir}/deep-review-dashboard.md`\n390: - **Generated from**: JSONL state log + strategy + findings registry\n391: - **Refresh**: Regenerated after every iteration\n392: - **Protection**: `auto-generated` in fileProtection\n393: \n394: ### Sections\n395: \n396: | Section | Source | Description |\n397: |---------|--------|-------------|\n398: | Findings Summary | JSONL | Active P0/P1/P2 counts, new vs refined |\n399: | Progress Table | JSONL | Run, status, focus, dimensions, ratio, duration |\n400: | Coverage | Strategy + JSONL | Dimension completion, file coverage, protocol status |\n401: | Trend | JSONL signals | Rolling average, composite stop score, trajectory |\n402: \n403: **Rules:** Sole inputs are JSONL + strategy. Overwrite entirely on refresh. Read-only for all agents.\n404: \n405: ---\n406: \n407: ## 9. CLAIM ADJUDICATION\n408: \n409: Every new P0/P1 finding must carry a **typed claim-adjudication packet**. The packet is parsed by `step_post_iteration_claim_adjudication` in the review workflow and its pass/fail result is persisted as a `claim_adjudication` event in `deep-review-state.jsonl`. The next iteration's `step_check_convergence` legal-stop decision tree reads the latest event via `claimAdjudicationGate` (gate `f`), a missing or failed packet vetoes STOP even if every other gate passes. Prose-only adjudication blocks are no longer accepted.\n410: \n411: ### Typed Packet Schema (required)\n412: \n413: Embed the packet inside the iteration file for each new P0/P1 finding. The orchestrator parses it after evaluation and persists the validation result.\n414: \n415: ```json\n416: {\n417:   \"findingId\": \"F003\",\n418:   \"claim\": \"Coverage-graph upsert identity is bare `id`, so cross-session collisions overwrite prior rows.\",\n419:   \"evidenceRefs\": [\n420:     \".opencode/skills/system-deep-loop/runtime/lib/coverage-graph/coverage-graph-db.ts:154\",\n421:     \".opencode/skills/system-deep-loop/runtime/lib/coverage-graph/coverage-graph-db.ts:292-302\"\n422:   ],\n423:   \"counterevidenceSought\": \"Grepped the module for compound-key upserts, checked migration scripts, and inspected session-isolation.vitest.ts for a collision regression, none found.\",\n424:   \"alternativeExplanation\": \"Could be intentional single-tenant design, but REQ-024 explicitly requires session isolation, so this is rejected.\",\n425:   \"finalSeverity\": \"P1\",\n426:   \"confidence\": 0.86,\n427:   \"downgradeTrigger\": \"If a composite primary key `(spec_folder, loop_type, session_id, id)` lands and a collision regression covers the ID-reuse path, downgrade to P2 tech-debt.\",\n428:   \"transitions\": [\n429:     { \"iteration\": 2, \"from\": null, \"to\": \"P1\", \"reason\": \"Initial discovery\" }\n430:   ]\n431: }\n432: ```\n433: \n434: ### Required Fields\n435: \n436: | Field | Type | Description |\n437: |-------|------|-------------|\n438: | `findingId` | string | Must match the finding ID in the iteration body and registry |\n439: | `claim` | string | The single assertion the finding makes (one sentence, evidence-backed) |\n440: | `evidenceRefs` | string[] | `file:line` or `file:range` citations that substantiate the claim (at least one entry) |\n441: | `counterevidenceSought` | string | Where the reviewer looked for contradicting evidence (commands, paths, docs), blank string is not acceptable |\n442: | `alternativeExplanation` | string | An alternative reading of the evidence, even if the reviewer rejects it |\n443: | `finalSeverity` | `\"P0\"` \\| `\"P1\"` \\| `\"P2\"` | Severity after adjudication (may differ from the severity originally asserted) |\n444: | `confidence` | number `[0, 1]` | Reviewer confidence in `finalSeverity` |\n445: | `downgradeTrigger` | string | The concrete condition under which this finding should be downgraded in a future iteration |\n446: | `transitions` | object[] | Optional severity transition log, required when `finalSeverity` differs from the originally asserted severity |\n447: \n448: ### Validation Rules (enforced by `step_post_iteration_claim_adjudication`)\n449: \n450: 1. A packet MUST exist for every new P0/P1 finding introduced in this iteration. Carried-forward findings reuse the previous packet unless severity transitioned.\n451: 2. All required fields MUST be present and non-empty. `confidence` MUST be a number in `[0, 1]`.\n452: 3. Each `evidenceRefs` entry MUST contain a `:` separating the path from a line or range.\n453: 4. `finalSeverity` MUST match the severity the finding is registered under in the iteration's `Findings` section and in `deep-review-findings-registry.json`.\n454: 5. When any rule fails, the workflow appends `{\"event\":\"claim_adjudication\",\"passed\":false,\"missingPackets\":[...]}` to the state log. The next `step_check_convergence` call reads that event and sets `claimAdjudicationGate` = `false`, producing a `blockedStop` event with `blockedBy: [\"claimAdjudicationGate\"]` until a follow-up iteration rewrites the packet.\n455: \n456: ### Severity Transition Rules\n457: \n458: - **P2 → P1**: confirmed exploitable impact or spec violation with direct evidence\n459: - **P1 → P0**: demonstrated data loss, security breach, or hard-gate failure\n460: - **Downgrade**: requires explicit counterevidence or a confirmed alternative explanation\n461: - Every transition is recorded in the packet's `transitions` array and mirrored into the finding registry's `transitions` field\n462: \n463: ---\n464: \n465: ## 10. FINDING REGISTRY\n466: \n467: Each finding is tracked with a unique identifier enabling deduplication, severity transitions, and status lifecycle.\n468: \n469: ### Schema\n470: \n471: ```json\n472: {\n473:   \"findingId\": \"F003\",\n474:   \"severity\": \"P1\",\n475:   \"category\": \"resource-map-coverage\",\n476:   \"status\": \"active\",\n477:   \"dimension\": \"traceability\",\n478:   \"title\": \"Applied target file missing from resource-map inventory\",\n479:   \"file\": \".opencode/commands/deep/assets/deep_review_auto.yaml\",\n480:   \"line\": 955,\n481:   \"firstSeen\": 2,\n482:   \"lastSeen\": 4,\n483:   \"transitions\": [\n484:     { \"iteration\": 2, \"from\": null, \"to\": \"P2\", \"reason\": \"Initial discovery\" },\n485:     { \"iteration\": 4, \"from\": \"P2\", \"to\": \"P1\", \"reason\": \"Confirmed real coverage gap against applied target inventory\" }\n486:   ]\n487: }\n488: ```\n489: \n490: | Field | Type | Description |\n491: |-------|------|-------------|\n492: | findingId | string | Sequential unique ID: `F001`, `F002`, ... |\n493: | severity | `\"P0\"` / `\"P1\"` / `\"P2\"` | Current severity |\n494: | category | `\"correctness\"` / `\"security\"` / `\"traceability\"` / `\"maintainability\"` / `\"resource-map-coverage\"` | Primary audit category for the finding, `resource-map-coverage` is reserved for implementation-vs-map coverage gaps |\n495: | status | `\"active\"` / `\"resolved\"` / `\"deferred\"` / `\"disproved\"` | Current status |\n496: | dimension | string | Primary dimension: correctness, security, traceability, maintainability |\n497: | title | string | Short description |\n498: | file | string | File path |\n499: | line | number | Line number (approximate) |\n500: | firstSeen / lastSeen | number | Iteration where first discovered / last referenced |\n501: | transitions | array | Severity and status change history |\n502: \n503: ### Status Lifecycle\n504: \n505: ```text\n506: [discovered] --> active --> resolved    (fixed or confirmed non-issue)\n507:                   |\n508:                   +--> deferred    (advisory, below threshold)\n509:                   |\n510:                   +--> disproved   (counterevidence invalidated)\n511: ```\n512: \n513: | Status | Counts Toward Verdict |\n514: |--------|----------------------|\n515: | active | Yes |\n516: | resolved | No |\n517: | deferred | No (listed in Deferred Items) |\n518: | disproved | No |\n519: \n520: ### Deduplication\n521: \n522: Same file + line range + root cause as an existing finding = **refinement**, not new. The existing findingId is updated. Refinements count at half weight (`refinementMultiplier: 0.5`) and are tracked via `findingsRefined` in JSONL.\n523: \n524: ### Cross-Reference Protocols\n525: \n526: | Protocol | Level | Applies To | Gate |\n527: |----------|-------|------------|------|\n528: | spec_code | core | all types | hard |\n529: | checklist_evidence | core | all types | hard |\n530: | skill_agent | overlay | skill | advisory |\n531: | agent_cross_runtime | overlay | agent | advisory |\n532: | feature_catalog_code | overlay | skill, spec-folder, track, files | advisory |\n533: | playbook_capability | overlay | skill, agent, spec-folder | advisory |\n534: \n535: Severity for `resource-map-coverage` findings is calibrated to the coverage-gate outcome:\n536: - `P2` when an untouched map entry is explicitly `expected-by-scope`\n537: - `P1` when an untouched or absent path represents a real coverage gap\n538: - `P0` only when the missing coverage masks a release-blocking correctness or security risk\n539: \n540: ### Quality Gates\n541: \n542: | Gate | Rule |\n543: |------|------|\n544: | Evidence | Every active finding backed by concrete file:line evidence |\n545: | Scope | Reviewed files and conclusions stay inside declared scope |\n546: | Coverage | Required dimensions and required protocols covered |\n547: \n548: All three gates must pass before STOP. Gate failure forces `verdict: \"FAIL\"` regardless of finding counts.\n\n(End of file - total 548 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review State Format\ndescription: State file schemas for the autonomous deep review loop, config, JSONL log, strategy, iteration files, and review report.\ntrigger_phrases:\n  - \"deep review state format\"\n  - \"deep review config schema\"\n  - \"review severity weights\"\n  - \"file protection levels\"\n  - \"review iteration file structure\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.28\n---\n\n# Deep Review State Format\n\nState file schemas for the autonomous deep review loop.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_format.md","text":"---\ntitle: Deep Review State Format\ndescription: State file schemas for the autonomous deep review loop, config, JSONL log, strategy, iteration files, and review report.\ntrigger_phrases:\n  - \"deep review state format\"\n  - \"deep review config schema\"\n  - \"review severity weights\"\n  - \"file protection levels\"\n  - \"review iteration file structure\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.28\n---\n\n# Deep Review State Format\n\nState file schemas for the autonomous deep review loop.\n\n---\n\n## 1. OVERVIEW\n\nThe deep review loop uses 8 state files under the resolved `{artifact_dir}/` owned by the target spec:\n\n| File | Format | Mutability |\n|------|--------|------------|\n| `deep-review-config.json` | JSON | Immutable after init |\n| `deep-review-state.jsonl` | JSON Lines | Append-only |\n| `deep-review-findings-registry.json` | JSON | Auto-generated reducer state |\n| `deep-review-strategy.md` | Markdown | Updated each iteration |\n| `deep-review-dashboard.md` | Markdown | Auto-generated (read-only) |\n| `.deep-review-pause` | Sentinel | Created/deleted by user |\n| `review-report.md` | Markdown | Updated at synthesis |\n| `iterations/iteration-NNN.md` | Markdown | Write-once |\n\n```text\n{artifact_dir}/\n  deep-review-config.json\n  deep-review-state.jsonl\n  deep-review-findings-registry.json\n  deep-review-strategy.md\n  deep-review-dashboard.md\n  .deep-review-pause\n  review-report.md\n  iterations/\n    iteration-001.md\n    iteration-002.md\n    ...\n```\n\n`{artifact_dir}` comes from `resolveArtifactRoot(specFolder, 'review')`. Root-spec runs resolve directly to `{spec_folder}/review/`. Child-phase and sub-phase runs use **flat-first**: a first run with an empty `review/` resolves directly to `{spec_folder}/review/` (no `pt-NN` wrapper). A `pt-NN` packet is allocated only when prior content for a non-matching target already exists. Continuation runs reuse the existing flat artifact (or matching `pt-NN` packet). This avoids the unnecessary `pt-01` wrapper on first runs.\n\nExample (first run on a child phase): `.../026-graph.../006-continuity-refactor-gates/003-gate-c-writer-ready/` → `003-gate-c-writer-ready/review/` (flat, no subfolder).\n\nExample (subsequent run with prior content for a different target): `003-gate-c-writer-ready/review/003-gate-c-writer-ready-pt-02/` (`pt-NN` allocated as a sibling to the prior content; subfolder name is `{basename(spec_folder)}-pt-{NN}`).\n\n### When to Use\n\n- Validating deep-review state files emitted by an iteration or by the reducer.\n- Implementing a state consumer (e.g. dashboard, advisor probe, downstream packet).\n- Debugging JSONL reducer output or auditing schema-version transitions.\n- Authoring fixtures that need to round-trip through the reducer.\n\n---\n\n## 2. CONFIG FILE (deep-review-config.json)\n\nCreated during initialization. Not modified after creation.\n\n```json\n{\n  \"topic\": \"Review of deep-review skill package\",\n  \"mode\": \"review\",\n  \"reviewTarget\": \"specs/030-deep-review-review-mode\",\n  \"reviewTargetType\": \"spec-folder\",\n  \"reviewDimensions\": [\"correctness\", \"security\", \"traceability\", \"maintainability\"],\n  \"resource_map_present\": false,\n  \"sessionId\": \"rvw-2026-04-03T12-00-00Z\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"stuckThreshold\": 2,\n  \"severityThreshold\": \"P2\",\n  \"crossReference\": {\n    \"core\": [\"spec_code\", \"checklist_evidence\"],\n    \"overlay\": [\"feature_catalog_code\", \"playbook_capability\"]\n  },\n  \"qualityGateThreshold\": true,\n  \"releaseReadinessState\": \"in-progress\",\n  \"specFolder\": \"030-deep-review-review-mode\",\n  \"createdAt\": \"2026-03-24T14:00:00Z\",\n  \"status\": \"initialized\",\n  \"executionMode\": \"auto\",\n  \"fileProtection\": {\n    \"deep-review-config.json\": \"immutable\",\n    \"deep-review-state.jsonl\": \"append-only\",\n    \"deep-review-findings-registry.json\": \"auto-generated\",\n    \"deep-review-strategy.md\": \"mutable\",\n    \"deep-review-dashboard.md\": \"auto-generated\",\n    \".deep-review-pause\": \"operator-controlled\",\n    \"review-report.md\": \"mutable\",\n    \"review-report-v*.md\": \"write-once\",\n    \"iteration-*.md\": \"write-once\"\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"inputs\": [\"latestJSONLDelta\", \"newIterationFile\", \"priorReducedState\"],\n    \"outputs\": [\"findingsRegistry\", \"dashboardMetrics\", \"strategyUpdates\"],\n    \"metrics\": [\n      \"dimensionsCovered\",\n      \"findingsBySeverity\",\n      \"openFindings\",\n      \"resolvedFindings\",\n      \"convergenceScore\"\n    ]\n  }\n}\n```\n\n### Field Reference\n\n| Field | Type | Default | Description |\n|-------|------|---------|-------------|\n| mode | `\"review\"` | -- | Session mode discriminator (required) |\n| reviewTarget | string | -- | Path or identifier of the review target |\n| reviewTargetType | string | `\"spec-folder\"` | `spec-folder`, `skill`, `agent`, `track`, `files` |\n| reviewDimensions | string[] | all 4 | Dimensions to evaluate |\n| resource_map_present | boolean | false | True only when `{specFolder}/resource-map.md` existed during init, enables the Resource Map Coverage audit pass and conditional report section |\n| sessionId | string | -- | Stable identifier for the current review lineage |\n| parentSessionId | string \\| null | `null` | Parent lineage reference for restart flows |\n| lineageMode | string | `\"new\"` | `new`, `resume`, `restart`. `fork` and `completed-continue` are deferred and not emitted by the current runtime |\n| generation | number | 1 | Lineage generation number, incremented on `restart`, unchanged on `resume` |\n| continuedFromRun | number \\| null | `null` | Count of completed iteration records at the lifecycle boundary (set on `resume` and `restart`) |\n| maxIterations | number | 7 | Hard cap on loop iterations |\n| convergenceThreshold | number | 0.10 | Stop when severity-weighted new findings ratio below this |\n| stuckThreshold | number | 2 | Consecutive no-progress iterations before recovery |\n| severityThreshold | string | `\"P2\"` | Minimum severity to report: `P0`, `P1`, `P2` |\n| crossReference | object | -- | Core (hard-gated) and overlay (advisory) protocol sets |\n| qualityGateThreshold | boolean | true | Whether binary quality gates are enforced |\n| specFolder | string | -- | Spec folder path (relative to specs/) |\n| status | string | `\"initialized\"` | `initialized`, `running`, `converged`, `stuck`, `complete`, `error` |\n| releaseReadinessState | string | `\"in-progress\"` | `in-progress`, `converged`, `release-blocking` |\n| fileProtection | object | -- | Mutability declarations (see protection levels below) |\n| reducer | object | -- | Canonical reducer inputs, outputs, and metrics names |\n\n### File Protection Levels\n\n| Level | Meaning |\n|-------|---------|\n| immutable | Cannot be modified after creation |\n| append-only | New content added at end only |\n| mutable | Can be read, edited, overwritten |\n| write-once | Created once, never modified |\n| auto-generated | System-managed, overwritten each refresh |\n| operator-controlled | Created or deleted only by the human/operator to control loop state |\n\n### Review Dimensions\n\n| Dimension | Priority | Required for Coverage |\n|-----------|----------|---------------------|\n| correctness | 1 | Yes |\n| security | 2 | Yes |\n| traceability | 3 | Yes |\n| maintainability | 4 | Yes |\n\n### Severity Weights\n\n| Severity | Weight | Label | Requires file:line |\n|----------|--------|-------|--------------------|\n| P0 | 10.0 | Blocker | Yes |\n| P1 | 5.0 | Required | Yes |\n| P2 | 1.0 | Suggestion | Yes |\n\n---\n\n## 3. STATE LOG\n\nThe `deep-review-state.jsonl` record schemas (config, iteration, event, lineage) and the Review Depth Schema (v2) live in `state_jsonl.md` for navigability.\n\n---\n\n## 4. STRATEGY FILE (deep-review-strategy.md)\n\nUpdated at the end of each iteration. Serves as the persistent brain across fresh-context iterations.\n\n### Required Sections\n\n| Section | Updated By | Purpose |\n|---------|-----------|---------|\n| topic | Init only | Review topic from config |\n| review-dimensions | Each iteration | Unchecked dimensions drive next focus |\n| completed-dimensions | Each iteration | Checked dimensions with verdict summary |\n| running-findings | Each iteration | P0/P1/P2 active counts + deltas |\n| what-worked | Each iteration | Successful approaches for reuse |\n| what-failed | Each iteration | Failed approaches to avoid |\n| exhausted-approaches | When fully tried | \"Do not retry\" registry |\n| ruled-out-directions | Each iteration | Eliminated directions with reasons |\n| next-focus | Each iteration | Recommended direction for next iteration |\n| known-context | Init only | Prior work from memory context |\n| cross-reference-status | Each iteration | Core vs overlay protocol status |\n| files-under-review | Each iteration | Per-file coverage state table |\n| review-boundaries | Init only | Max iterations, thresholds, config |\n\n### Mapping from Research Mode\n\n| Review Section | Research Equivalent |\n|---------------|-------------------|\n| review-dimensions | Key Questions (remaining) |\n| completed-dimensions | Answered Questions |\n| running-findings | _(none, review-specific)_ |\n| cross-reference-status | _(none, review-specific)_ |\n| files-under-review | _(none, review-specific)_ |\n| review-boundaries | Research Boundaries |\n\nSections unchanged from research: topic, what-worked, what-failed, exhausted-approaches, ruled-out-directions, next-focus, known-context.\n\n### Update Protocol\n\n1. Read current strategy file\n2. Move completed dimensions from \"remaining\" to \"completed\" with `[x]` and verdict\n3. Update running-findings with P0/P1/P2 counts and deltas\n4. Add to what-worked / what-failed with iteration number\n5. Move exhausted approaches. Update cross-reference-status and files-under-review\n6. Set next-focus based on remaining dimensions and open findings\n\n---\n\n## 5. FINDINGS REGISTRY (deep-review-findings-registry.json)\n\nReducer-owned JSON document regenerated after every iteration and lifecycle transition.\n\n```json\n{\n  \"sessionId\": \"rvw-2026-04-03T12-00-00Z\",\n  \"generation\": 1,\n  \"lineageMode\": \"resume\",\n  \"openFindings\": [],\n  \"resolvedFindings\": [],\n  \"blockedStopHistory\": [],\n  \"persistentSameSeverity\": [],\n  \"severityChanged\": [],\n  \"repeatedFindings\": [],\n  \"dimensionCoverage\": {\n    \"correctness\": true,\n    \"security\": true,\n    \"traceability\": false,\n    \"maintainability\": false\n  },\n  \"findingsBySeverity\": {\n    \"P0\": 0,\n    \"P1\": 1,\n    \"P2\": 2\n  },\n  \"openFindingsCount\": 3,\n  \"resolvedFindingsCount\": 1,\n  \"convergenceScore\": 0.44,\n  \"graphConvergenceScore\": 1.01,\n  \"graphDecision\": \"STOP_ALLOWED\",\n  \"graphBlockers\": [],\n  \"corruptionWarnings\": []\n}\n```\n\nThis file is machine-owned and must stay synchronized with the latest iteration delta, dashboard metrics, and synthesized review report.\n\n### Blocked-Stop and Corruption-Tracking Additions\n\n| Field | Type | Description |\n|-------|------|-------------|\n| `blockedStopHistory` | array | One entry per `blocked_stop` JSONL event: `{run, blockedBy, gateResults, recoveryStrategy, timestamp}`. Rendered in the dashboard `BLOCKED STOPS` section and can drive the strategy `next-focus` anchor when blocked-stop is the most recent loop event. |\n| `persistentSameSeverity` | array | Findings observed in ≥2 iterations with NO severity transitions beyond initial discovery. REQ-018 split of the deprecated `repeatedFindings` bucket. |\n| `severityChanged` | array | Findings that went through at least one severity transition (P0↔P1↔P2) in their `transitions` history. |\n| `repeatedFindings` | array | **Deprecated.** Union of `persistentSameSeverity` and `severityChanged`. Retained for backward compatibility, new code should read the split arrays. |\n| `corruptionWarnings` | array | Per-line corruption reports from `parseJsonlDetailed()`: `{line, raw, error}`. Non-empty means the reducer detected malformed JSONL. |\n\n### Default Values\n\nWhen no `graph_convergence` event has been recorded yet, defaults are `graphConvergenceScore: 0`, `graphDecision: null`, and `graphBlockers: []`.\nWhen no `blocked_stop` event has been recorded yet, `blockedStopHistory: []`.\nWhen JSONL parses cleanly, `corruptionWarnings: []`.\n\n### Fail-Closed Semantics (REQ-015, REQ-016)\n\n- **Malformed JSONL**: The reducer CLI exits with code `2` and writes a warning to stderr when `corruptionWarnings.length > 0`. Pass `--lenient` (or `lenient:true` to `reduceReviewState`) to escape-hatch out and preserve the v1.2.0.0 fail-open behavior for legacy packets.\n- **Missing machine-owned anchors**: `replaceAnchorSection()` throws `Error('Missing machine-owned anchor \"<id>\" in deep-review strategy file.')` when the strategy file is present but lacks one of the required anchors. Pass `--create-missing-anchors` (or `createMissingAnchors:true`) to bootstrap empty strategy files by appending the missing anchor blocks.\n- **Dashboard surfaces**: `CORRUPTION WARNINGS` section lists detected lines. `BLOCKED STOPS` section lists `blockedStopHistory` entries. `GRAPH CONVERGENCE` section reports `graphConvergenceScore` / `graphDecision` / `graphBlockers`.\n- **Strategy next-focus override**: When the latest `blocked_stop` event timestamp is newer than the latest iteration timestamp, the reducer rewrites the strategy `next-focus` anchor to surface the blocking gates and recovery hint so operators see the blocker before choosing the next iteration direction.\n\n---\n\n## 6. ITERATION FILES (review/iterations/iteration-NNN.md)\n\nWrite-once files. One per iteration, zero-padded 3-digit naming.\n\n### Structure\n\n```markdown\n# Iteration [N]: [Focus Area]\n\n## Focus\n[Dimension(s), files, scope investigated]\n\n## Scorecard\n- Dimensions covered: [list]\n- Files reviewed: [count]\n- New findings: P0=[n] P1=[n] P2=[n]\n- Refined findings: P0=[n] P1=[n] P2=[n]\n- New findings ratio: [0.0-1.0]\n\n## Findings\n\n### P0, Blocker\n- **F[NNN]**: [Title], `file:line`, [Description with evidence]\n\n### P1, Required\n- **F[NNN]**: [Title], `file:line`, [Description with evidence]\n\n### P2, Suggestion\n- **F[NNN]**: [Title], `file:line`, [Description with evidence]\n\n## Cross-Reference Results\n| Protocol | Status | Gate | Evidence | Notes |\n|----------|--------|------|----------|-------|\n| spec_code | pass/partial/fail | hard | file:line | ... |\n\n## Assessment\n- New findings ratio: [0.0-1.0]\n- Dimensions addressed: [list]\n- Novelty justification: [breakdown]\n\n## Ruled Out\n- [Approach]: [Why], [Evidence]\n\n## Dead Ends\n- [Direction]: [Why]\n\n## Recommended Next Focus\n[What to investigate next]\n```\n\nEvery finding must include: unique ID (`F001`...), severity (`P0`/`P1`/`P2`), concrete `file:line` evidence, and dimension tag.\n\n---\n\n## 7. REVIEW REPORT (review/review-report.md)\n\nThe review synthesis output contains 9 core sections plus a conditional `## Resource Map Coverage Gate` section when `resource_map_present` is true:\n\n| # | Section | Description |\n|---|---------|-------------|\n| 1 | Executive Summary | Verdict, active P0/P1/P2 counts, scope, `hasAdvisories` flag |\n| 2 | Planning Trigger | Why result routes to planning or changelog |\n| 3 | Active Finding Registry | Deduped active findings with evidence, severity, dimension |\n| 4 | Remediation Workstreams | Ordered lanes grouped by dependency or area |\n| 5 | Spec Seed | Minimal spec updates implied by findings |\n| 6 | Plan Seed | Initial remediation tasks from findings |\n| 7 | Traceability Status | Core vs overlay protocol outcomes and gaps |\n| 8 | Resource Map Coverage Gate | Present only when `{spec_folder}/resource-map.md` existed at init, contains touched entries, untouched entries (`expected-by-scope` vs `gap`), and implementation paths absent from the map |\n| 9 | Deferred Items | Advisory findings, blocked items, follow-up checks |\n| 10 | Audit Appendix | Coverage, convergence replay, audit detail |\n\n**Executive Summary** includes verdict (`PASS`/`CONDITIONAL`/`FAIL`), active finding counts, `hasAdvisories` boolean (PASS + P2 > 0), scope description, and convergence reason.\n\n**Planning Trigger** routes FAIL/CONDITIONAL to remediation planning, PASS to changelog creation.\n\n**Active Finding Registry** lists each active finding with findingId, severity, dimension, title, file:line evidence, first/last seen iteration, and status.\n\n**Remediation Workstreams** group related findings into ordered lanes with constituent finding IDs and execution order.\n\n**Spec Seed / Plan Seed** provide minimal spec updates and initial remediation tasks referencing finding IDs and target files.\n\n**Traceability Status** reports per-protocol pass/partial/fail with gating class and evidence.\n\n**Resource Map Coverage Gate** is emitted only when `resource_map_present` is true and MUST contain exactly three bullets: touched entries, untouched entries (`expected-by-scope` vs `gap`), and implementation paths absent from the map.\n\n**Deferred Items** captures advisory findings, blocked protocols, and future follow-up checks.\n\n**Audit Appendix** contains iteration table, convergence signal replay, file coverage matrix, and dimension breakdown.\n\n---\n\n## 8. DASHBOARD (review/deep-review-dashboard.md)\n\nAuto-generated summary. Never manually edited.\n\n- **Path**: `{artifact_dir}/deep-review-dashboard.md`\n- **Generated from**: JSONL state log + strategy + findings registry\n- **Refresh**: Regenerated after every iteration\n- **Protection**: `auto-generated` in fileProtection\n\n### Sections\n\n| Section | Source | Description |\n|---------|--------|-------------|\n| Findings Summary | JSONL | Active P0/P1/P2 counts, new vs refined |\n| Progress Table | JSONL | Run, status, focus, dimensions, ratio, duration |\n| Coverage | Strategy + JSONL | Dimension completion, file coverage, protocol status |\n| Trend | JSONL signals | Rolling average, composite stop score, trajectory |\n\n**Rules:** Sole inputs are JSONL + strategy. Overwrite entirely on refresh. Read-only for all agents.\n\n---\n\n## 9. CLAIM ADJUDICATION\n\nEvery new P0/P1 finding must carry a **typed claim-adjudication packet**. The packet is parsed by `step_post_iteration_claim_adjudication` in the review workflow and its pass/fail result is persisted as a `claim_adjudication` event in `deep-review-state.jsonl`. The next iteration's `step_check_convergence` legal-stop decision tree reads the latest event via `claimAdjudicationGate` (gate `f`), a missing or failed packet vetoes STOP even if every other gate passes. Prose-only adjudication blocks are no longer accepted.\n\n### Typed Packet Schema (required)\n\nEmbed the packet inside the iteration file for each new P0/P1 finding. The orchestrator parses it after evaluation and persists the validation result.\n\n```json\n{\n  \"findingId\": \"F003\",\n  \"claim\": \"Coverage-graph upsert identity is bare `id`, so cross-session collisions overwrite prior rows.\",\n  \"evidenceRefs\": [\n    \".opencode/skills/system-deep-loop/runtime/lib/coverage-graph/coverage-graph-db.ts:154\",\n    \".opencode/skills/system-deep-loop/runtime/lib/coverage-graph/coverage-graph-db.ts:292-302\"\n  ],\n  \"counterevidenceSought\": \"Grepped the module for compound-key upserts, checked migration scripts, and inspected session-isolation.vitest.ts for a collision regression, none found.\",\n  \"alternativeExplanation\": \"Could be intentional single-tenant design, but REQ-024 explicitly requires session isolation, so this is rejected.\",\n  \"finalSeverity\": \"P1\",\n  \"confidence\": 0.86,\n  \"downgradeTrigger\": \"If a composite primary key `(spec_folder, loop_type, session_id, id)` lands and a collision regression covers the ID-reuse path, downgrade to P2 tech-debt.\",\n  \"transitions\": [\n    { \"iteration\": 2, \"from\": null, \"to\": \"P1\", \"reason\": \"Initial discovery\" }\n  ]\n}\n```\n\n### Required Fields\n\n| Field | Type | Description |\n|-------|------|-------------|\n| `findingId` | string | Must match the finding ID in the iteration body and registry |\n| `claim` | string | The single assertion the finding makes (one sentence, evidence-backed) |\n| `evidenceRefs` | string[] | `file:line` or `file:range` citations that substantiate the claim (at least one entry) |\n| `counterevidenceSought` | string | Where the reviewer looked for contradicting evidence (commands, paths, docs), blank string is not acceptable |\n| `alternativeExplanation` | string | An alternative reading of the evidence, even if the reviewer rejects it |\n| `finalSeverity` | `\"P0\"` \\| `\"P1\"` \\| `\"P2\"` | Severity after adjudication (may differ from the severity originally asserted) |\n| `confidence` | number `[0, 1]` | Reviewer confidence in `finalSeverity` |\n| `downgradeTrigger` | string | The concrete condition under which this finding should be downgraded in a future iteration |\n| `transitions` | object[] | Optional severity transition log, required when `finalSeverity` differs from the originally asserted severity |\n\n### Validation Rules (enforced by `step_post_iteration_claim_adjudication`)\n\n1. A packet MUST exist for every new P0/P1 finding introduced in this iteration. Carried-forward findings reuse the previous packet unless severity transitioned.\n2. All required fields MUST be present and non-empty. `confidence` MUST be a number in `[0, 1]`.\n3. Each `evidenceRefs` entry MUST contain a `:` separating the path from a line or range.\n4. `finalSeverity` MUST match the severity the finding is registered under in the iteration's `Findings` section and in `deep-review-findings-registry.json`.\n5. When any rule fails, the workflow appends `{\"event\":\"claim_adjudication\",\"passed\":false,\"missingPackets\":[...]}` to the state log. The next `step_check_convergence` call reads that event and sets `claimAdjudicationGate` = `false`, producing a `blockedStop` event with `blockedBy: [\"claimAdjudicationGate\"]` until a follow-up iteration rewrites the packet.\n\n### Severity Transition Rules\n\n- **P2 → P1**: confirmed exploitable impact or spec violation with direct evidence\n- **P1 → P0**: demonstrated data loss, security breach, or hard-gate failure\n- **Downgrade**: requires explicit counterevidence or a confirmed alternative explanation\n- Every transition is recorded in the packet's `transitions` array and mirrored into the finding registry's `transitions` field\n\n---\n\n## 10. FINDING REGISTRY\n\nEach finding is tracked with a unique identifier enabling deduplication, severity transitions, and status lifecycle.\n\n### Schema\n\n```json\n{\n  \"findingId\": \"F003\",\n  \"severity\": \"P1\",\n  \"category\": \"resource-map-coverage\",\n  \"status\": \"active\",\n  \"dimension\": \"traceability\",\n  \"title\": \"Applied target file missing from resource-map inventory\",\n  \"file\": \".opencode/commands/deep/assets/deep_review_auto.yaml\",\n  \"line\": 955,\n  \"firstSeen\": 2,\n  \"lastSeen\": 4,\n  \"transitions\": [\n    { \"iteration\": 2, \"from\": null, \"to\": \"P2\", \"reason\": \"Initial discovery\" },\n    { \"iteration\": 4, \"from\": \"P2\", \"to\": \"P1\", \"reason\": \"Confirmed real coverage gap against applied target inventory\" }\n  ]\n}\n```\n\n| Field | Type | Description |\n|-------|------|-------------|\n| findingId | string | Sequential unique ID: `F001`, `F002`, ... |\n| severity | `\"P0\"` / `\"P1\"` / `\"P2\"` | Current severity |\n| category | `\"correctness\"` / `\"security\"` / `\"traceability\"` / `\"maintainability\"` / `\"resource-map-coverage\"` | Primary audit category for the finding, `resource-map-coverage` is reserved for implementation-vs-map coverage gaps |\n| status | `\"active\"` / `\"resolved\"` / `\"deferred\"` / `\"disproved\"` | Current status |\n| dimension | string | Primary dimension: correctness, security, traceability, maintainability |\n| title | string | Short description |\n| file | string | File path |\n| line | number | Line number (approximate) |\n| firstSeen / lastSeen | number | Iteration where first discovered / last referenced |\n| transitions | array | Severity and status change history |\n\n### Status Lifecycle\n\n```text\n[discovered] --> active --> resolved    (fixed or confirmed non-issue)\n                  |\n                  +--> deferred    (advisory, below threshold)\n                  |\n                  +--> disproved   (counterevidence invalidated)\n```\n\n| Status | Counts Toward Verdict |\n|--------|----------------------|\n| active | Yes |\n| resolved | No |\n| deferred | No (listed in Deferred Items) |\n| disproved | No |\n\n### Deduplication\n\nSame file + line range + root cause as an existing finding = **refinement**, not new. The existing findingId is updated. Refinements count at half weight (`refinementMultiplier: 0.5`) and are tracked via `findingsRefined` in JSONL.\n\n### Cross-Reference Protocols\n\n| Protocol | Level | Applies To | Gate |\n|----------|-------|------------|------|\n| spec_code | core | all types | hard |\n| checklist_evidence | core | all types | hard |\n| skill_agent | overlay | skill | advisory |\n| agent_cross_runtime | overlay | agent | advisory |\n| feature_catalog_code | overlay | skill, spec-folder, track, files | advisory |\n| playbook_capability | overlay | skill, agent, spec-folder | advisory |\n\nSeverity for `resource-map-coverage` findings is calibrated to the coverage-gate outcome:\n- `P2` when an untouched map entry is explicitly `expected-by-scope`\n- `P1` when an untouched or absent path represents a real coverage gap\n- `P0` only when the missing coverage masks a release-blocking correctness or security risk\n\n### Quality Gates\n\n| Gate | Rule |\n|------|------|\n| Evidence | Every active finding backed by concrete file:line evidence |\n| Scope | Reviewed files and conclusions stay inside declared scope |\n| Coverage | Required dimensions and required protocols covered |\n\nAll three gates must pass before STOP. Gate failure forces `verdict: \"FAIL\"` regardless of finding counts.","lineStart":1,"lineEnd":548,"totalLines":548,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/state/state_format.md","time":{"start":1784210482255,"end":1784210482283}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204f88194bc69d0242ff7e7e1"}},"id":"prt_f6b3b644c001K6UB1vOkHnZGaB","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482293,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_ABq9zOkPV5VDeklesmvXaBRY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Convergence\n3: description: Stop condition algorithms, quality guards, and recovery strategies for the autonomous deep review loop.\n4: trigger_phrases:\n5:   - \"review convergence detection\"\n6:   - \"severity weighted stop ratio\"\n7:   - \"legal stop gate bundle\"\n8:   - \"review stuck detection\"\n9:   - \"composite convergence vote\"\n10: importance_tier: important\n11: contextType: implementation\n12: version: 1.11.0.22\n13: ---\n14: \n15: # Deep Review Convergence\n16: \n17: Stop condition algorithms, quality guards, and stuck recovery for the deep review loop.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: ### Purpose\n24: \n25: Convergence detection determines when the autonomous review loop should stop iterating. After every iteration the orchestrator evaluates three possible outcomes:\n26: \n27: | Outcome | Meaning |\n28: |---------|---------|\n29: | **CONTINUE** | More review work is expected to yield meaningful new findings. Dispatch the next iteration. |\n30: | **STOP** | The review has reached saturation. Proceed to synthesis and verdict. |\n31: | **STUCK_RECOVERY** | No progress detected for consecutive iterations. Attempt a recovery strategy before deciding. |\n32: \n33: Convergence is checked **after** each iteration completes and **before** the next iteration is dispatched. The check consumes the full JSONL state history and the current dimension coverage snapshot.\n34: \n35: Release-readiness states are derived alongside convergence:\n36: - `in-progress` while coverage is incomplete or new P0/P1 findings are still appearing\n37: - `converged` once coverage and stabilization pass without new P0/P1 findings\n38: - `release-blocking` whenever unresolved P0 findings remain active\n39: \n40: When the loop stops and enters synthesis, the workflow emits `{artifact_dir}/resource-map.md` from converged review deltas before compiling `review-report.md`. Operators can disable that write with `--no-resource-map`.\n41: \n42: ### When to Use\n43: \n44: - Evaluating whether the autonomous review loop should stop, continue, or recover.\n45: - Tuning convergence thresholds, stuck-recovery cadence, or stabilization windows.\n46: - Debugging a stuck-recovery escalation or a premature STOP vote.\n47: - Auditing the release-readiness classification logic before shipping.\n48: \n49: ### Key Defaults\n50: \n51: | Setting | Value | Purpose |\n52: |---------|-------|---------|\n53: | `maxIterations` | 7 | Hard ceiling on loop iterations |\n54: | `convergenceThreshold` | 0.10 | General convergence sensitivity |\n55: | `rollingStopThreshold` | 0.08 | Rolling-average STOP vote threshold |\n56: | `noProgressThreshold` | 0.05 | Stuck / no-progress classification threshold |\n57: | `stuckThreshold` | 2 | Consecutive no-progress iterations before recovery |\n58: | `minStabilizationPasses` | 1 | Coverage signal requires at least one stabilization pass |\n59: | `compositeStopScore` | 0.60 | Weighted stop-score needed before guard evaluation |\n60: \n61: ### Threshold Semantics and Sibling Parity\n62: \n63: `convergenceThreshold` (default 0.10) compares new severity-weighted findings (P0=10, P1=5, P2=1) against accumulated findings. Lower values demand more iterations and a higher signal threshold before STOP is legal.\n64: \n65: **Not interchangeable with sibling deep-loop skills:**\n66: \n67: | Skill | Default | Signal |\n68: |---|---|---|\n69: | `deep-review` | 0.10 | severity-weighted P0/P1/P2 ratio |\n70: | `deep-research` | 0.05 | newInfoRatio (negative-knowledge emphasis) |\n71: | `deep-ai-council` (proposed) | 0.20 | adjudicator-verdict stability |\n72: \n73: Carrying threshold expectations across siblings will cause unexpected iteration counts. Tune each skill against its own default and its own signal, not by analogy.\n74: \n75: ### Security-Sensitive Fix Overrides\n76: \n77: > **STATUS: SPEC ONLY (future implementation).** The override matrix below describes the contract that a future release should apply automatically when the review target involves security-sensitive surfaces. As of v1.9.0.0, the runtime does NOT auto-detect security-sensitivity and does NOT apply these overrides. `requiredClosedFindingReplay` and `requiredFixCompletenessGate` exist in no config / yaml / reducer surface (verified by grep). Operators running a security-sensitive review must manually tighten thresholds via `--convergence` + `--max-iterations` and manually maintain the closed-gate replay table. The contract below stands as the target spec for the next implementation pass. (Provenance for this deferred contract is recorded in this skill's changelog.)\n78: \n79: For review reruns after fixes involving security, path disclosure, auth/authz, sandboxing, env precedence, public schemas, persistence, or user-visible error payloads (intended contract, not yet runtime-enforced):\n80: \n81: | Setting | General Default | Security-Sensitive Fix Default |\n82: |---------|-----------------|--------------------------------|\n83: | `minStabilizationPasses` | 1 | 2 |\n84: | `requiredClosedFindingReplay` | false | true for prior P0/P1 and any prior security/path P2 |\n85: | `requiredFixCompletenessGate` | false | true |\n86: \n87: When implemented, STOP must not be legal until the review report contains a closed-gate replay table that marks each prior active or remediated P0/P1 as `PASS`, `FAIL`, or `carried forward`, with file:line or command evidence. Operators today must enforce this rule manually.\n88: \n89: ### Shared Stop Contract\n90: \n91: Every terminal stop and every blocked-stop vote MUST emit the shared stop contract from REQ-001: a named `stopReason` enum plus, when STOP is vetoed, a `blocked_stop` event written to `deep-review-state.jsonl`. There is no nested `legalStop` wrapper on the persisted path. Earlier drafts of this document implied one, and that drift was the source of F009 in the 042 closing audit.\n92: \n93: ### Convergence Modes\n94: \n95: The shared convergence runtime accepts four values. Review legality, security gates, target authority, and verdict derivation remain owned by the review workflow rather than the convergence mode.\n96: \n97: | Mode | Live Behavior |\n98: |------|---------------|\n99: | `default` | Uses normal full-history convergence signals and sends a legal STOP to synthesis and verdict derivation. This is the fallback when no mode is supplied. |\n100: | `off` | Is accepted and persisted, but the shipped review YAML has no `off` decision branch; review therefore follows the same legal-stop and synthesis path as `default`. Use `stopPolicy: \"max-iterations\"` when convergence must remain telemetry-only until the iteration ceiling. |\n101: | `sliding-window` | Is accepted and persisted, but windowed graph-novelty telemetry is research-only in the shared runtime; review therefore retains its ordinary full-history signals, legal-stop gates, and synthesis path. |\n102: | `divergent` | After all review gates pass, translates the eligible `all_dimensions_clean` STOP into a read-only three-seat direction-selection pivot and continues with the selected review direction. |\n103: \n104: #### Divergent Pivot Contract\n105: \n106: Review has one eligible reason: the exact internal reason `all_dimensions_clean` with decision `STOP`. The nine legal-stop gates run before the divergent branch and remain unchanged. `maxIterationsReached`, `blockedStop`, `stuckRecovery`, `error`, `manualStop`, and `userPaused` are explicitly excluded. Max iterations, pause or cancellation, manual stop, unrecoverable error, and any blocked security or quality gate therefore never dispatch a pivot Council.\n107: \n108: Each eligible pivot runs one native, in-process Council round with exactly three distinct seats: analytical, critical, and pragmatic. It does not use an external CLI. The transaction requires all three seat returns to be parse-valid and at least two seats to materially endorse the same candidate without a high-severity blocker. Candidate sources are persisted unswept dimensions, search debt, producer-consumer gaps, negative-test gaps, and traceability gaps. Candidate generation rejects directions without in-scope evidence and directions that imply implementation, a fix, mutation, writing, or target expansion.\n109: \n110: The guarantees are absolute: divergent mode never changes the PASS/CONDITIONAL/FAIL mapping, never authorizes a fix, and never makes the review target writable. A successful pivot returns to the loop before `phase_synthesis`; verdict computation exists only inside `phase_synthesis`, where active P0 yields FAIL, active P1 yields CONDITIONAL, and no active P0/P1 yields PASS. A failed pivot fails closed to that existing synthesis path.\n111: \n112: Every pivot dispatches three seats, so a run that pivots has proportionally higher model cost and duration than the same run under `default`, `off`, or `sliding-window`. Pivot evidence is isolated under `<artifactRoot>/divergent/pivots/<pivotId>/council/**`, including config, append-only state, three seat artifacts, deliberation, and report. This path is distinct from ordinary planning Council artifacts under a spec packet's `ai-council/**` tree.\n113: \n114: #### stopReason Enum\n115: \n116: | `stopReason` | Meaning |\n117: |--------------|---------|\n118: | `converged` | All convergence signals met and legal-stop gates passed. |\n119: | `maxIterationsReached` | Iteration limit hit before convergence. |\n120: | `userPaused` | User requested pause via sentinel. |\n121: | `blockedStop` | Convergence math voted stop but legal-stop gates failed. |\n122: | `stuckRecovery` | Stuck detection triggered recovery. |\n123: | `error` | Unrecoverable error during iteration or reducer flow. |\n124: | `manualStop` | Operator explicitly halted outside the pause sentinel path. |\n125: \n126: #### blocked_stop Event (canonical, persisted)\n127: \n128: `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml` appends the following record to `deep-review-state.jsonl` whenever the legal-stop decision tree vetoes STOP. The gate names and their shapes are load-bearing, the reducer reads them verbatim:\n129: \n130: ```json\n131: {\n132:   \"type\": \"event\",\n133:   \"event\": \"blocked_stop\",\n134:   \"mode\": \"review\",\n135:   \"run\": 5,\n136:   \"blockedBy\": [\"dimensionCoverageGate\", \"p0ResolutionGate\"],\n137:   \"gateResults\": {\n138:     \"convergenceGate\": { \"pass\": true, \"score\": 0.72 },\n139:     \"dimensionCoverageGate\": {\n140:       \"pass\": false,\n141:       \"covered\": [\"correctness\", \"security\", \"traceability\"],\n142:       \"missing\": [\"maintainability\"]\n143:     },\n144:     \"p0ResolutionGate\": { \"pass\": false, \"activeP0\": 1 },\n145:     \"evidenceDensityGate\": { \"pass\": true, \"avgEvidencePerFinding\": 1.6 },\n146:     \"hotspotSaturationGate\": { \"pass\": true },\n147:     \"claimAdjudicationGate\": { \"pass\": true, \"activeP0P1\": 2 },\n148:     \"fixCompletenessReplayGate\": { \"pass\": true, \"securitySensitive\": false, \"requiredRows\": 0, \"passingRows\": 0 },\n149:     \"candidateCoverageGate\": { \"pass\": true, \"searchDebt\": [], \"missing\": [] },\n150:     \"graphlessFallbackGate\": { \"pass\": true, \"mode\": \"graph_available\", \"missing\": [], \"unavailabilityReason\": \"\" }\n151:   },\n152:   \"graphBlockerDetail\": [],\n153:   \"recoveryStrategy\": \"Dispatch the next iteration at the maintainability dimension and re-check after resolving the remaining P0.\",\n154:   \"timestamp\": \"2026-03-24T15:02:00Z\",\n155:   \"sessionId\": \"rvw-2026-03-24T10-00-00Z\",\n156:   \"generation\": 1\n157: }\n158: ```\n159: \n160: - `blockedBy`: array of gate names that failed (string[], never structured objects). Empty when STOP is legal, in which case no `blocked_stop` event is emitted.\n161: - `gateResults`: named sub-records keyed by `convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, and `graphlessFallbackGate`. This is the full 9-gate set emitted by `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`. Each sub-record has a `pass` boolean plus gate-specific fields (score, covered/missing, activeP0, avgEvidencePerFinding, activeP0P1, securitySensitive, requiredRows, passingRows, searchDebt, mode, unavailabilityReason). The reducer reads these verbatim and does not coerce shapes. `candidateCoverageGate` and `graphlessFallbackGate` are v2-rollout gates, they pass trivially when the review-depth-v2 search path is inactive (no search debt, graph available).\n162: - `graphBlockerDetail`: array of structured graph blockers copied from the latest graph convergence decision. Empty when graph convergence did not veto STOP.\n163: - `recoveryStrategy`: human-readable one-liner describing what the next iteration should do before another stop attempt.\n164: - When the graph convergence verdict is `STOP_BLOCKED`, fold the graph blocker gate name into `blockedBy` and preserve the structured blocker objects under `graphBlockerDetail`.\n165: \n166: ### Decision Priority\n167: \n168: Checks are evaluated in this order (first match wins):\n169: \n170: 1. **Max iterations** -- hard cap, always checked first.\n171: 2. **All dimensions covered + clean** -- all 4 dimensions covered, no active P0/P1, stabilization passed, gates passed.\n172: 3. **Stuck detection** -- 2+ consecutive no-progress iterations.\n173: 4. **Composite convergence** -- 3-signal weighted vote with threshold 0.60.\n174: 5. **Legal-stop gate bundle** -- review-specific stop gates. If a stop vote fails any gate, persist `stopReason=blockedStop` and continue.\n175: 6. **Default CONTINUE** -- none of the above triggered.\n176: \n177: ---\n178: \n179: ## 2. HARD STOPS\n180: \n181: Hard stops are evaluated first and override all other signals.\n182: \n183: ### Max Iterations Reached\n184: \n185: ```\n186: if len(iterations) >= config.maxIterations:       // default 7\n187:   return { action: \"STOP\", stopReason: \"maxIterationsReached\" }\n188: ```\n189: \n190: The loop stops unconditionally. Synthesis runs with whatever findings exist.\n191: \n192: ### All Dimensions Covered with Stabilization\n193: \n194: ```\n195: if coverage.dimensionCoverage == 1.0 and activeP0 == 0 and activeP1 == 0:\n196:   if stabilizationPasses >= config.coverageAge.minStabilizationPasses:\n197:     if buildReviewLegalStop(state, config, coverage).passed:\n198:       return { action: \"STOP\", stopReason: \"converged\" }\n199: ```\n200: \n201: Triggers when all 4 dimensions (correctness, security, traceability, maintainability) are covered, no active P0/P1 remains, at least 1 stabilization pass has occurred, and the 5-gate legal-stop bundle passes. If gates fail, the loop records `stopReason=blockedStop` and continues despite full coverage.\n202: \n203: ---\n204: \n205: ## 3. STUCK DETECTION\n206: \n207: Identifies when the review loop makes no meaningful progress across consecutive iterations.\n208: \n209: ```\n210: function countConsecutiveStuck_review(evidenceIterations, noProgressThreshold):\n211:   count = 0\n212:   for i in reversed(evidenceIterations):\n213:     if i.status == \"thought\":   continue    // invisible to stuck counter\n214:     if i.status == \"insight\":   break       // resets stuck counter (genuine progress)\n215:     if i.newFindingsRatio < noProgressThreshold or i.status == \"stuck\":\n216:       count += 1\n217:     else:\n218:       break\n219:   return count\n220: ```\n221: \n222: **Threshold:** `stuckThreshold = 2` consecutive no-progress iterations (using `noProgressThreshold = 0.05`).\n223: \n224: **Status exclusions:**\n225: - `insight`: Resets stuck counter -- a conceptual breakthrough counts as progress even with a low ratio.\n226: - `thought`: Skipped entirely -- analytical iterations produce no evidence to measure.\n227: \n228: When `stuckCount >= stuckThreshold`, the orchestrator invokes the recovery protocol (Section 8) before deciding whether to continue or stop.\n229: \n230: The recovery entry uses `stopReason=stuckRecovery` while the loop is in recovery. If recovery later terminates the run, the terminal record keeps the same shared enum value instead of minting a review-only label.\n231: \n232: ---\n233: \n234: ## 4. COMPOSITE CONVERGENCE\n235: \n236: Three independent signals each cast a stop/continue vote. Stop when the weighted stop-score meets or exceeds the consensus threshold. The signal set below matches the authoritative 3-signal vote in `deep_review_{auto,confirm}.yaml` `step_check_convergence` and the quick-reference convergence table, the 3rd signal is **dimension coverage**, not a standalone novelty ratio.\n237: \n238: | Signal | Weight | Min Iterations | Measures |\n239: |--------|--------|---------------|----------|\n240: | Rolling Average | 0.30 | 2 | Recent severity-weighted finding yield |\n241: | MAD Noise Floor | 0.25 | 3 | Signal vs noise in newFindingsRatio |\n242: | Dimension Coverage | 0.45 | 1 | Configured review dimensions fully covered AND required traceability protocols covered AND `coverage_age >= minStabilizationPasses` |\n243: \n244: ### Signal 1: Rolling Average (weight 0.30)\n245: \n246: Averages the last 2 severity-weighted `newFindingsRatio` values from evidence-bearing iterations (excludes `thought` status). Votes STOP when the average drops below `rollingStopThreshold` (0.08).\n247: \n248: ```\n249: if len(evidenceIterations) >= 2:\n250:   recent = evidenceIterations[-2:]\n251:   avgRatio = mean(i.newFindingsRatio for i in recent)\n252:   rollingStop = avgRatio < 0.08\n253: ```\n254: \n255: ### Signal 2: MAD Noise Floor (weight 0.25)\n256: \n257: Robust statistical test using Median Absolute Deviation. Votes STOP when the latest ratio is at or below the computed noise floor.\n258: \n259: ```\n260: if len(evidenceIterations) >= 3:\n261:   allRatios = [i.newFindingsRatio for i in evidenceIterations]\n262:   med = median(allRatios)\n263:   mad = median([abs(r - med) for r in allRatios])\n264:   noiseFloor = mad * 1.4826     // normal distribution estimator\n265:   madStop = evidenceIterations[-1].newFindingsRatio <= noiseFloor\n266: ```\n267: \n268: ### Signal 3: Dimension Coverage (weight 0.45)\n269: \n270: Highest-weight signal. Votes STOP once every configured review dimension AND every required traceability protocol has been covered by at least one iteration, and the coverage set has been stable for at least `minStabilizationPasses` iterations (default 1). This is the signal the YAML workflow evaluates.\n271: \n272: ```\n273: dimensionStop =\n274:   dimensions_covered_count == configured_dimensions_count\n275:   AND required_traceability_protocols_covered\n276:   AND coverage_age >= config.minStabilizationPasses\n277: ```\n278: \n279: The latest severity-weighted newFindingsRatio is still tracked (the dashboard and registry surface it as `newFindingsRatio`), but it does NOT cast an independent stop vote, it feeds the rolling average and MAD noise-floor signals only.\n280: \n281: ### Weighted Vote\n282: \n283: ```\n284: stopScore = sum(s.weight * (1 if s.stop else 0) for s in signals) / totalWeight\n285: if stopScore >= 0.60:   // proceed to quality gate evaluation\n286: ```\n287: \n288: Weights are redistributed across active signals only. If only 2 signals have enough data, their weights are normalized to sum to 1.0.\n289: \n290: ### Semantic Convergence Signals\n291: \n292: Two additional signals provide deeper semantic analysis of review iteration quality. These signals are ADDITIONAL to the 3-signal composite vote above and participate in the legal-stop gate evaluation rather than the composite stop-score.\n293: \n294: #### semanticNovelty (0.0-1.0)\n295: \n296: Measures how much genuinely new review insight each iteration contributes beyond surface-level overlap with prior findings. Unlike `newFindingsRatio` (which is severity-weighted), `semanticNovelty` evaluates the conceptual novelty of findings independent of severity weighting.\n297: \n298: | Value | Meaning |\n299: |-------|---------|\n300: | 0.8-1.0 | Iteration uncovered substantially new defect patterns, architectural concerns, or review angles |\n301: | 0.4-0.7 | Mix of new review insights and restatements of prior findings |\n302: | 0.1-0.3 | Mostly refinements or rewordings of previously identified issues |\n303: | 0.0 | No semantically novel findings detected |\n304: \n305: Computation:\n306: ```\n307: function computeSemanticNovelty_review(currentFindings, priorCumulativeFindings):\n308:   newPatterns = extractDefectPatterns(currentFindings) - extractDefectPatterns(priorCumulativeFindings)\n309:   totalPatterns = extractDefectPatterns(currentFindings)\n310:   if len(totalPatterns) == 0: return 0.0\n311:   return len(newPatterns) / len(totalPatterns)\n312: ```\n313: \n314: When `semanticNovelty` drops below 0.15 for 2+ consecutive evidence iterations, it provides strong supporting evidence for a legal STOP decision. This signal catches cases where `newFindingsRatio` stays moderate (due to severity weighting of refinements) but the review has exhausted genuinely new defect categories.\n315: \n316: #### findingStability (0.0-1.0)\n317: \n318: Measures how stable the cumulative finding set is across iterations. A high stability score means the finding registry is not materially changing between iterations -- findings are not being added, upgraded, downgraded, or invalidated at a significant rate.\n319: \n320: | Value | Meaning |\n321: |-------|---------|\n322: | 0.9-1.0 | Finding set is highly stable, minimal churn between iterations |\n323: | 0.6-0.8 | Moderate stability, some findings still evolving |\n324: | 0.3-0.5 | Active churn, findings being added, merged, or reclassified frequently |\n325: | 0.0-0.2 | Highly unstable, the review is still in early discovery |\n326: \n327: Computation:\n328: ```\n329: function computeFindingStability(currentRegistry, priorRegistry):\n330:   if priorRegistry is null: return 0.0  // first iteration\n331:   unchangedFindings = count(f for f in currentRegistry\n332:     if f.id in priorRegistry and f.severity == priorRegistry[f.id].severity\n333:     and f.status == priorRegistry[f.id].status)\n334:   totalFindings = max(len(currentRegistry), len(priorRegistry))\n335:   if totalFindings == 0: return 1.0\n336:   return unchangedFindings / totalFindings\n337: ```\n338: \n339: Convergence behavior:\n340: - `findingStability >= 0.85` supports STOP: the finding set has stabilized and further iterations are unlikely to materially change the review outcome.\n341: - `findingStability < 0.50` prevents STOP: the finding set is still in flux and the review has not reached a stable assessment.\n342: \n343: #### Integration with Legal-Stop Gate Bundle\n344: \n345: The two semantic signals integrate with the existing 5-gate legal-stop bundle (Section 6):\n346: \n347: 1. **findingStability gate** (existing): The existing `findingStability` gate already evaluates rolling average, MAD noise floor, and novelty ratio. The new `semanticNovelty` signal adds a sub-check:\n348:    - `semanticNoveltyPlateau`: `semanticNovelty < 0.15` for 2+ consecutive evidence iterations\n349:    - When this sub-check fails while the existing churn signals pass, the gate records the mismatch as a diagnostic note but does not independently block STOP.\n350: \n351: 2. **findingStability signal** (new): The `findingStability` metric (0.0-1.0) is surfaced alongside the existing convergence signals. It supports the `findingStability` gate evaluation by providing a registry-level stability measure that complements the ratio-based churn signals.\n352: \n353: The gate passes only when both the existing churn-based checks AND the semantic stability checks agree. When a semantic check fails, the persisted `blocked_stop.gateResults.findingStability` payload includes the semantic signal values.\n354: \n355: #### Stop-Decision Trace\n356: \n357: The stop-decision event includes which semantic signals supported or prevented STOP:\n358: \n359: ```json\n360: {\n361:   \"type\": \"event\",\n362:   \"event\": \"stop_decision\",\n363:   \"semanticSignals\": {\n364:     \"semanticNovelty\": { \"value\": 0.06, \"consecutiveLow\": 3, \"supportsStop\": true },\n365:     \"findingStability\": { \"value\": 0.92, \"supportsStop\": true }\n366:   },\n367:   \"semanticVerdict\": \"all_support_stop\",\n368:   ...\n369: }\n370: ```\n371: \n372: | `semanticVerdict` | Meaning |\n373: |-------------------|---------|\n374: | `all_support_stop` | Both semantic signals support stopping |\n375: | `mixed` | One signal supports stop, the other does not |\n376: | `all_prevent_stop` | Both semantic signals indicate more work is needed |\n377: | `insufficient_data` | Not enough iterations to compute semantic signals |\n378: \n379: ### Graceful Degradation\n380: \n381: | Iterations Completed | Active Signals | Behavior |\n382: |---------------------|----------------|----------|\n383: | 1 | Novelty ratio only (weight 1.0) | Very unlikely to stop without later confirmation from rolling churn signals |\n384: | 2 | Rolling avg + novelty ratio | Two-signal vote, reweighted |\n385: | 3+ | All three signals | Full composite, most reliable |\n386: \n387: Semantic convergence signals (`semanticNovelty`, `findingStability`) require at least 2 evidence iterations to produce meaningful values. They are omitted from legal-stop evaluation when insufficient data exists.\n388: \n389: ---\n390: \n391: ## 5. SEVERITY-WEIGHTED RATIO\n392: \n393: The review loop uses `newFindingsRatio` instead of `newInfoRatio`. It weights findings by severity so that critical discoveries count far more than minor suggestions.\n394: \n395: ### Severity Weights\n396: \n397: | Severity | Weight | Description |\n398: |----------|--------|-------------|\n399: | **P0** (Blocker) | 10.0 | Correctness failures, security vulnerabilities, spec contradictions |\n400: | **P1** (Required) | 5.0 | Degraded behavior, incomplete implementation, missing validation |\n401: | **P2** (Suggestion) | 1.0 | Style, naming, minor improvements, documentation gaps |\n402: \n403: ### Computation\n404: \n405: ```\n406: SEVERITY_WEIGHTS = { P0: 10.0, P1: 5.0, P2: 1.0 }\n407: refinementMultiplier = 0.5\n408: \n409: weightedNew       = sum(SEVERITY_WEIGHTS[f.severity] for f in fully_new_findings)\n410: weightedRefinement = sum(SEVERITY_WEIGHTS[f.severity] * 0.5 for f in refinement_findings)\n411: weightedTotal     = sum(SEVERITY_WEIGHTS[f.severity] for f in all_findings_this_iteration)\n412: \n413: newFindingsRatio = (weightedNew + weightedRefinement) / weightedTotal\n414: ```\n415: \n416: - `fully_new_findings` -- findings not present in any prior iteration (new findingId).\n417: - `refinement_findings` -- findings that refine or upgrade an existing finding (same root cause, new evidence or severity change).\n418: - `refinementMultiplier = 0.5` -- refinements count at half weight.\n419: \n420: ### P0 Override Rule\n421: \n422: ```\n423: if ANY new P0 found this iteration:\n424:   newFindingsRatio = max(calculated, 0.50)\n425: \n426: if total_findings == 0:\n427:   newFindingsRatio = 0.0\n428: ```\n429: \n430: A new critical finding always signals significant remaining work. The 0.50 floor prevents premature convergence when critical issues are still being discovered.\n431: \n432: ---\n433: \n434: ## 6. LEGAL-STOP GATE BUNDLE\n435: \n436: > **GATE MODEL, two naming conventions mapped to one authoritative set.** The authoritative producer is `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`, which emits **9 gates** with the `Gate` suffix: `convergenceGate` / `dimensionCoverageGate` / `p0ResolutionGate` / `evidenceDensityGate` / `hotspotSaturationGate` / `claimAdjudicationGate` / `fixCompletenessReplayGate` / `candidateCoverageGate` / `graphlessFallbackGate`. The §Section-1 event shape (lines 98-119) mirrors this set verbatim and the reducer reads those names verbatim, so treat the event shape as authoritative when writing or reading JSONL state. The §6 table below is the high-level conceptual model and uses descriptive names WITHOUT the `Gate` suffix where one reads more naturally (for example `findingStability` maps to `convergenceGate`); each row carries its event-shape name so the mapping is explicit. `candidateCoverageGate` and `graphlessFallbackGate` are v2-rollout gates that pass trivially when the review-depth-v2 search path is inactive. The gate-model drift cluster (LG-0013, LG-0016, LG-0031, LG-0032) was reconciled in `006-gate-model-reconciliation`.\n437: \n438: Deep review treats STOP as legal only when the full review-specific gate bundle passes together. Convergence math may request STOP, but the workflow must still evaluate these 9 gates and persist a blocked-stop event when any gate fails.\n439: \n440: | Gate (§6 conceptual) | Event-shape name (§Section-1) | Rule | Fail Action |\n441: |------|------|------|-------------|\n442: | **findingStability** | `convergenceGate` | Rolling average, MAD noise floor, and novelty ratio must all indicate low-yield review churn | Block STOP, persist `blockedStop` |\n443: | **dimensionCoverage** | `dimensionCoverageGate` | Every configured review dimension must have been examined at least once, with required traceability coverage stabilized | Block STOP, persist `blockedStop` |\n444: | **p0Resolution** | `p0ResolutionGate` | No unresolved P0 findings may remain active at stop time | Block STOP, persist `blockedStop` |\n445: | **evidenceDensity** | `evidenceDensityGate` | Evidence density across active findings must meet the configured threshold | Block STOP, persist `blockedStop` |\n446: | **hotspotSaturation** | `hotspotSaturationGate` | Review hotspots must be revisited enough times to satisfy the saturation heuristic | Block STOP, persist `blockedStop` |\n447: | (no §6 counterpart) | `claimAdjudicationGate` | Each new P0/P1 finding must carry a typed adjudication packet, missing or failing packets veto STOP | Block STOP, persist `blockedStop` |\n448: | **fixCompletenessReplay** | `fixCompletenessReplayGate` | Security-sensitive fix reruns must replay previously closed P0/P1 gates and validate producer/consumer/matrix coverage from the remediation packet | Block STOP, persist `blockedStop` |\n449: | **candidateCoverage** (v2 rollout) | `candidateCoverageGate` | Search debt must be cleared and every required bug class must have candidate coverage before STOP, passes trivially when the v2 search path is inactive | Block STOP, persist `blockedStop` |\n450: | **graphlessFallback** (v2 rollout) | `graphlessFallbackGate` | When the code graph is unavailable, required bug classes must carry cited fallback ledger rows, passes trivially when the graph is available | Block STOP, persist `blockedStop` |\n451: \n452: ### Gate Evaluation\n453: \n454: ```\n455: function buildReviewLegalStop(state, config, coverage):\n456:   gateResults = {\n457:     findingStability: {\n458:       pass: rollingStop and madStop and state.latestNoveltyRatio <= config.convergenceThreshold,\n459:       detail: \"Rolling average, MAD noise floor, and novelty ratio are all below stop thresholds.\"\n460:     },\n461:     dimensionCoverage: {\n462:       pass: everyConfiguredDimensionExaminedAtLeastOnce(coverage, config.reviewDimensions) and\n463:             coverage.requiredProtocolsCovered and\n464:             coverage.stabilizationPasses >= 1,\n465:       detail: \"All configured review dimensions have been examined, required traceability protocols are covered, and stabilization has aged enough to stop.\"\n466:     },\n467:     p0Resolution: {\n468:       pass: countActiveFindings(state, [\"P0\"]) == 0 and state.claimAdjudicationPassed != false,\n469:       detail: \"No unresolved P0 findings remain and blocker adjudication is complete.\"\n470:     },\n471:     evidenceDensity: {\n472:       pass: computeEvidenceDensity(state.activeFindings) >= config.evidenceDensityThreshold,\n473:       detail: \"Evidence density meets the configured threshold for active findings.\"\n474:     },\n475:     hotspotSaturation: {\n476:       pass: computeHotspotSaturation(state.hotspots) >= config.hotspotSaturationThreshold,\n477:       detail: \"Priority hotspots received enough revisits to satisfy saturation.\"\n478:     },\n479:     fixCompletenessReplay: {\n480:       pass: not isSecuritySensitiveFixRerun(state, config) or allRequiredReplayRowsPass(state.reviewReport),\n481:       detail: \"Security-sensitive fix reruns include closed-gate replay evidence and producer/consumer/matrix coverage before STOP.\"\n482:     },\n483:     candidateCoverage: {\n484:       pass: not isReviewDepthV2Active(state, config) or (searchDebtCleared(state) and allRequiredBugClassesCovered(state)),\n485:       detail: \"Search debt is cleared and every required bug class has candidate coverage. Passes trivially when the v2 search path is inactive.\"\n486:     },\n487:     graphlessFallback: {\n488:       pass: state.searchCoverage.graphCoverageMode == \"graph_available\" or allRequiredBugClassesHaveFallbackRows(state),\n489:       detail: \"When the code graph is unavailable, required bug classes carry cited fallback ledger rows. Passes trivially when the graph is available.\"\n490:     }\n491:   }\n492: \n493:   blockedBy = [name for name, result in gateResults.items() if not result.pass]\n494:   return {\n495:     pass: len(blockedBy) == 0,\n496:     blockedBy,\n497:     gateResults\n498:   }\n499: ```\n500: \n501: When convergence math returns STOP, invoke `buildReviewLegalStop()`. If it returns `pass: false`, persist a first-class `blocked_stop` event with the failing `blockedBy` gates, the full `gateResults` bundle, a `recoveryStrategy`, and the normal run/timestamp/session lineage fields before overriding the decision to CONTINUE.\n502: \n503: ### Blocked-Stop Recovery Strategy\n504: \n505: | Failed Gate | Recovery Strategy |\n506: |-------------|-------------------|\n507: | `findingStability` | Revisit the noisiest recent dimension and reduce novelty by closing obvious follow-up loops before re-checking STOP. |\n508: | `dimensionCoverage` | Schedule the next uncovered review dimension immediately. |\n509: | `p0Resolution` | Re-open the active blocker path and verify whether the P0 is real, downgraded, or still unresolved. |\n510: | `evidenceDensity` | Re-read weakly supported findings and add concrete `file:line` citations before they count toward a stop decision. |\n511: | `hotspotSaturation` | Revisit undersampled hotspots or adjacent call sites until the saturation heuristic passes. |\n512: | `fixCompletenessReplay` | Replay prior active or remediated P0/P1 gates, then record producer, consumer, and matrix coverage evidence before re-checking STOP. |\n513: | `candidateCoverage` | Clear outstanding search debt and run candidate discovery for the missing bug classes before re-checking STOP. |\n514: | `graphlessFallback` | Add cited fallback ledger rows for the required bug classes, or restore graph availability, before re-checking STOP. |\n515: \n516: ### Legacy Stop-Reason Mapping\n517: \n518: Use this table when replaying old packets or translating older prose/docs into the shared stop contract.\n519: \n520: | Legacy label | New `stopReason` | Mapping note |\n521: |--------------|------------------|--------------|\n522: | `all_dimensions_clean` | `converged` | Legacy review-specific terminal label, now expressed by the shared enum. |\n523: | `composite_converged` | `converged` | Legacy convergence-math wording now rolls into shared terminal success. |\n524: | `all dimensions clean` | `converged` | Old operator-facing prose for the same successful stop. |\n525: | `max_iterations_reached` | `maxIterationsReached` | Legacy machine label for the hard iteration cap. |\n526: | `max iterations` | `maxIterationsReached` | Old operator-facing hard-stop wording. |\n527: | `pause sentinel detected` | `userPaused` | Sentinel pause is now a shared user-directed stop reason. |\n528: | `guard_override` | `blockedStop` | Legacy continue override when a stop vote failed legal gates. |\n529: | `quality guard failed` | `blockedStop` | Older prose for the same blocked-stop outcome. |\n530: | `P0 override blocks convergence` | `blockedStop` | Legacy review wording for a stop attempt that was not legal to finalize. |\n531: | `stuck_detected` | `stuckRecovery` | Legacy recovery trigger label. |\n532: | `stuck_unrecoverable` | `stuckRecovery` | Legacy terminal wording for the same recovery path family. |\n533: | `manual halt` | `manualStop` | Operator-directed halt outside normal pause sentinel flow. |\n534: \n535: ---\n536: \n537: ## 7. PROVISIONAL VERDICT\n538: \n539: The provisional verdict is determined from active findings at the time the loop stops. It appears in both the convergence report and the final `review-report.md`.\n540: \n541: | Verdict | Condition | Meaning |\n542: |---------|-----------|---------|\n543: | **FAIL** | `activeP0 > 0` OR any legal-stop gate fails at terminal stop time | Does not meet quality standards. Blocks release. |\n544: | **CONDITIONAL** | `activeP0 == 0` AND `activeP1 > 0` | Meets threshold but has required fixes before release. |\n545: | **PASS** | `activeP0 == 0` AND `activeP1 == 0` | Shippable. Set `hasAdvisories: true` when `activeP2 > 0`. |\n546: \n547: ### Determination\n548: \n549: ```\n550: function determineVerdict(state, gateResult):\n551:   activeP0 = countActiveFindings(state, [\"P0\"])\n552:   activeP1 = countActiveFindings(state, [\"P1\"])\n553:   activeP2 = countActiveFindings(state, [\"P2\"])\n554: \n555:   if activeP0 > 0 or not gateResult.passed:\n556:     return { verdict: \"FAIL\", nextCommand: \"/speckit:plan\" }\n557:   if activeP1 > 0:\n558:     return { verdict: \"CONDITIONAL\", nextCommand: \"/speckit:plan\" }\n559: \n560:   hasAdvisories = activeP2 > 0\n561:   return { verdict: \"PASS\", hasAdvisories, nextCommand: \"/create:changelog\" }\n562: ```\n563: \n564: ### Post-Verdict Routing\n565: \n566: | Verdict | Next Step |\n567: |---------|-----------|\n568: | FAIL | `/speckit:plan` -- create remediation plan from findings |\n569: | CONDITIONAL | `/speckit:plan` -- create fix plan for P1 findings |\n570: | PASS | `/create:changelog` -- record the clean audit |\n571: \n572: ---\n573: \n574: ## 8. RECOVERY, REPORTING, AND GRAPH-AWARE CONVERGENCE\n575: \n576: Stuck-recovery strategies, the convergence report format, and graph-aware review convergence live in `convergence_recovery.md` for navigability.\n577: \n578: ---\n579: \n580: ## OPTIMIZER-TUNABLE THRESHOLDS\n581: \n582: The following convergence thresholds are managed by the offline loop optimizer (042.004). Changes to these fields are proposed through the optimizer's advisory-only promotion gate and reviewed by humans before adoption.\n583: \n584: ### Tunable Fields (Optimizer-Managed)\n585: \n586: | Field | Default | Range | Description |\n587: |-------|---------|-------|-------------|\n588: | `convergenceThreshold` | 0.10 | 0.01-0.20 | General convergence sensitivity |\n589: | `stuckThreshold` | 2 | 1-5 | Consecutive no-progress iterations before recovery |\n590: | `maxIterations` | 7 | 3-20 | Hard iteration ceiling |\n591: | `compositeStopScore` | 0.60 | 0.40-0.80 | Weighted stop score needed before guard evaluation |\n592: \n593: ### Locked Fields (Not Optimizer-Tunable)\n594: \n595: The following fields are runtime contracts and MUST NOT be modified by the optimizer:\n596: \n597: - `stopReason` enum values and semantics\n598: - `blocked_stop` event structure and gate names\n599: - Lineage fields (`sessionId`, `lineageMode`, `generation`)\n600: - Reducer configuration and file protection policies\n601: - Review dimensions (`reviewDimensions`) and product mode (`mode`)\n602: \n603: ### Canonical Manifest\n604: \n605: The authoritative registry of tunable vs locked fields is maintained at:\n606: `.opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json`\n\n(End of file - total 606 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Convergence\ndescription: Stop condition algorithms, quality guards, and recovery strategies for the autonomous deep review loop.\ntrigger_phrases:\n  - \"review convergence detection\"\n  - \"severity weighted stop ratio\"\n  - \"legal stop gate bundle\"\n  - \"review stuck detection\"\n  - \"composite convergence vote\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.22\n---\n\n# Deep Review Convergence\n\nStop condition algorithms, quality guards, and stuck recovery for the deep review loop.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md","text":"---\ntitle: Deep Review Convergence\ndescription: Stop condition algorithms, quality guards, and recovery strategies for the autonomous deep review loop.\ntrigger_phrases:\n  - \"review convergence detection\"\n  - \"severity weighted stop ratio\"\n  - \"legal stop gate bundle\"\n  - \"review stuck detection\"\n  - \"composite convergence vote\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.22\n---\n\n# Deep Review Convergence\n\nStop condition algorithms, quality guards, and stuck recovery for the deep review loop.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nConvergence detection determines when the autonomous review loop should stop iterating. After every iteration the orchestrator evaluates three possible outcomes:\n\n| Outcome | Meaning |\n|---------|---------|\n| **CONTINUE** | More review work is expected to yield meaningful new findings. Dispatch the next iteration. |\n| **STOP** | The review has reached saturation. Proceed to synthesis and verdict. |\n| **STUCK_RECOVERY** | No progress detected for consecutive iterations. Attempt a recovery strategy before deciding. |\n\nConvergence is checked **after** each iteration completes and **before** the next iteration is dispatched. The check consumes the full JSONL state history and the current dimension coverage snapshot.\n\nRelease-readiness states are derived alongside convergence:\n- `in-progress` while coverage is incomplete or new P0/P1 findings are still appearing\n- `converged` once coverage and stabilization pass without new P0/P1 findings\n- `release-blocking` whenever unresolved P0 findings remain active\n\nWhen the loop stops and enters synthesis, the workflow emits `{artifact_dir}/resource-map.md` from converged review deltas before compiling `review-report.md`. Operators can disable that write with `--no-resource-map`.\n\n### When to Use\n\n- Evaluating whether the autonomous review loop should stop, continue, or recover.\n- Tuning convergence thresholds, stuck-recovery cadence, or stabilization windows.\n- Debugging a stuck-recovery escalation or a premature STOP vote.\n- Auditing the release-readiness classification logic before shipping.\n\n### Key Defaults\n\n| Setting | Value | Purpose |\n|---------|-------|---------|\n| `maxIterations` | 7 | Hard ceiling on loop iterations |\n| `convergenceThreshold` | 0.10 | General convergence sensitivity |\n| `rollingStopThreshold` | 0.08 | Rolling-average STOP vote threshold |\n| `noProgressThreshold` | 0.05 | Stuck / no-progress classification threshold |\n| `stuckThreshold` | 2 | Consecutive no-progress iterations before recovery |\n| `minStabilizationPasses` | 1 | Coverage signal requires at least one stabilization pass |\n| `compositeStopScore` | 0.60 | Weighted stop-score needed before guard evaluation |\n\n### Threshold Semantics and Sibling Parity\n\n`convergenceThreshold` (default 0.10) compares new severity-weighted findings (P0=10, P1=5, P2=1) against accumulated findings. Lower values demand more iterations and a higher signal threshold before STOP is legal.\n\n**Not interchangeable with sibling deep-loop skills:**\n\n| Skill | Default | Signal |\n|---|---|---|\n| `deep-review` | 0.10 | severity-weighted P0/P1/P2 ratio |\n| `deep-research` | 0.05 | newInfoRatio (negative-knowledge emphasis) |\n| `deep-ai-council` (proposed) | 0.20 | adjudicator-verdict stability |\n\nCarrying threshold expectations across siblings will cause unexpected iteration counts. Tune each skill against its own default and its own signal, not by analogy.\n\n### Security-Sensitive Fix Overrides\n\n> **STATUS: SPEC ONLY (future implementation).** The override matrix below describes the contract that a future release should apply automatically when the review target involves security-sensitive surfaces. As of v1.9.0.0, the runtime does NOT auto-detect security-sensitivity and does NOT apply these overrides. `requiredClosedFindingReplay` and `requiredFixCompletenessGate` exist in no config / yaml / reducer surface (verified by grep). Operators running a security-sensitive review must manually tighten thresholds via `--convergence` + `--max-iterations` and manually maintain the closed-gate replay table. The contract below stands as the target spec for the next implementation pass. (Provenance for this deferred contract is recorded in this skill's changelog.)\n\nFor review reruns after fixes involving security, path disclosure, auth/authz, sandboxing, env precedence, public schemas, persistence, or user-visible error payloads (intended contract, not yet runtime-enforced):\n\n| Setting | General Default | Security-Sensitive Fix Default |\n|---------|-----------------|--------------------------------|\n| `minStabilizationPasses` | 1 | 2 |\n| `requiredClosedFindingReplay` | false | true for prior P0/P1 and any prior security/path P2 |\n| `requiredFixCompletenessGate` | false | true |\n\nWhen implemented, STOP must not be legal until the review report contains a closed-gate replay table that marks each prior active or remediated P0/P1 as `PASS`, `FAIL`, or `carried forward`, with file:line or command evidence. Operators today must enforce this rule manually.\n\n### Shared Stop Contract\n\nEvery terminal stop and every blocked-stop vote MUST emit the shared stop contract from REQ-001: a named `stopReason` enum plus, when STOP is vetoed, a `blocked_stop` event written to `deep-review-state.jsonl`. There is no nested `legalStop` wrapper on the persisted path. Earlier drafts of this document implied one, and that drift was the source of F009 in the 042 closing audit.\n\n### Convergence Modes\n\nThe shared convergence runtime accepts four values. Review legality, security gates, target authority, and verdict derivation remain owned by the review workflow rather than the convergence mode.\n\n| Mode | Live Behavior |\n|------|---------------|\n| `default` | Uses normal full-history convergence signals and sends a legal STOP to synthesis and verdict derivation. This is the fallback when no mode is supplied. |\n| `off` | Is accepted and persisted, but the shipped review YAML has no `off` decision branch; review therefore follows the same legal-stop and synthesis path as `default`. Use `stopPolicy: \"max-iterations\"` when convergence must remain telemetry-only until the iteration ceiling. |\n| `sliding-window` | Is accepted and persisted, but windowed graph-novelty telemetry is research-only in the shared runtime; review therefore retains its ordinary full-history signals, legal-stop gates, and synthesis path. |\n| `divergent` | After all review gates pass, translates the eligible `all_dimensions_clean` STOP into a read-only three-seat direction-selection pivot and continues with the selected review direction. |\n\n#### Divergent Pivot Contract\n\nReview has one eligible reason: the exact internal reason `all_dimensions_clean` with decision `STOP`. The nine legal-stop gates run before the divergent branch and remain unchanged. `maxIterationsReached`, `blockedStop`, `stuckRecovery`, `error`, `manualStop`, and `userPaused` are explicitly excluded. Max iterations, pause or cancellation, manual stop, unrecoverable error, and any blocked security or quality gate therefore never dispatch a pivot Council.\n\nEach eligible pivot runs one native, in-process Council round with exactly three distinct seats: analytical, critical, and pragmatic. It does not use an external CLI. The transaction requires all three seat returns to be parse-valid and at least two seats to materially endorse the same candidate without a high-severity blocker. Candidate sources are persisted unswept dimensions, search debt, producer-consumer gaps, negative-test gaps, and traceability gaps. Candidate generation rejects directions without in-scope evidence and directions that imply implementation, a fix, mutation, writing, or target expansion.\n\nThe guarantees are absolute: divergent mode never changes the PASS/CONDITIONAL/FAIL mapping, never authorizes a fix, and never makes the review target writable. A successful pivot returns to the loop before `phase_synthesis`; verdict computation exists only inside `phase_synthesis`, where active P0 yields FAIL, active P1 yields CONDITIONAL, and no active P0/P1 yields PASS. A failed pivot fails closed to that existing synthesis path.\n\nEvery pivot dispatches three seats, so a run that pivots has proportionally higher model cost and duration than the same run under `default`, `off`, or `sliding-window`. Pivot evidence is isolated under `<artifactRoot>/divergent/pivots/<pivotId>/council/**`, including config, append-only state, three seat artifacts, deliberation, and report. This path is distinct from ordinary planning Council artifacts under a spec packet's `ai-council/**` tree.\n\n#### stopReason Enum\n\n| `stopReason` | Meaning |\n|--------------|---------|\n| `converged` | All convergence signals met and legal-stop gates passed. |\n| `maxIterationsReached` | Iteration limit hit before convergence. |\n| `userPaused` | User requested pause via sentinel. |\n| `blockedStop` | Convergence math voted stop but legal-stop gates failed. |\n| `stuckRecovery` | Stuck detection triggered recovery. |\n| `error` | Unrecoverable error during iteration or reducer flow. |\n| `manualStop` | Operator explicitly halted outside the pause sentinel path. |\n\n#### blocked_stop Event (canonical, persisted)\n\n`step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml` appends the following record to `deep-review-state.jsonl` whenever the legal-stop decision tree vetoes STOP. The gate names and their shapes are load-bearing, the reducer reads them verbatim:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"blocked_stop\",\n  \"mode\": \"review\",\n  \"run\": 5,\n  \"blockedBy\": [\"dimensionCoverageGate\", \"p0ResolutionGate\"],\n  \"gateResults\": {\n    \"convergenceGate\": { \"pass\": true, \"score\": 0.72 },\n    \"dimensionCoverageGate\": {\n      \"pass\": false,\n      \"covered\": [\"correctness\", \"security\", \"traceability\"],\n      \"missing\": [\"maintainability\"]\n    },\n    \"p0ResolutionGate\": { \"pass\": false, \"activeP0\": 1 },\n    \"evidenceDensityGate\": { \"pass\": true, \"avgEvidencePerFinding\": 1.6 },\n    \"hotspotSaturationGate\": { \"pass\": true },\n    \"claimAdjudicationGate\": { \"pass\": true, \"activeP0P1\": 2 },\n    \"fixCompletenessReplayGate\": { \"pass\": true, \"securitySensitive\": false, \"requiredRows\": 0, \"passingRows\": 0 },\n    \"candidateCoverageGate\": { \"pass\": true, \"searchDebt\": [], \"missing\": [] },\n    \"graphlessFallbackGate\": { \"pass\": true, \"mode\": \"graph_available\", \"missing\": [], \"unavailabilityReason\": \"\" }\n  },\n  \"graphBlockerDetail\": [],\n  \"recoveryStrategy\": \"Dispatch the next iteration at the maintainability dimension and re-check after resolving the remaining P0.\",\n  \"timestamp\": \"2026-03-24T15:02:00Z\",\n  \"sessionId\": \"rvw-2026-03-24T10-00-00Z\",\n  \"generation\": 1\n}\n```\n\n- `blockedBy`: array of gate names that failed (string[], never structured objects). Empty when STOP is legal, in which case no `blocked_stop` event is emitted.\n- `gateResults`: named sub-records keyed by `convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, and `graphlessFallbackGate`. This is the full 9-gate set emitted by `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`. Each sub-record has a `pass` boolean plus gate-specific fields (score, covered/missing, activeP0, avgEvidencePerFinding, activeP0P1, securitySensitive, requiredRows, passingRows, searchDebt, mode, unavailabilityReason). The reducer reads these verbatim and does not coerce shapes. `candidateCoverageGate` and `graphlessFallbackGate` are v2-rollout gates, they pass trivially when the review-depth-v2 search path is inactive (no search debt, graph available).\n- `graphBlockerDetail`: array of structured graph blockers copied from the latest graph convergence decision. Empty when graph convergence did not veto STOP.\n- `recoveryStrategy`: human-readable one-liner describing what the next iteration should do before another stop attempt.\n- When the graph convergence verdict is `STOP_BLOCKED`, fold the graph blocker gate name into `blockedBy` and preserve the structured blocker objects under `graphBlockerDetail`.\n\n### Decision Priority\n\nChecks are evaluated in this order (first match wins):\n\n1. **Max iterations** -- hard cap, always checked first.\n2. **All dimensions covered + clean** -- all 4 dimensions covered, no active P0/P1, stabilization passed, gates passed.\n3. **Stuck detection** -- 2+ consecutive no-progress iterations.\n4. **Composite convergence** -- 3-signal weighted vote with threshold 0.60.\n5. **Legal-stop gate bundle** -- review-specific stop gates. If a stop vote fails any gate, persist `stopReason=blockedStop` and continue.\n6. **Default CONTINUE** -- none of the above triggered.\n\n---\n\n## 2. HARD STOPS\n\nHard stops are evaluated first and override all other signals.\n\n### Max Iterations Reached\n\n```\nif len(iterations) >= config.maxIterations:       // default 7\n  return { action: \"STOP\", stopReason: \"maxIterationsReached\" }\n```\n\nThe loop stops unconditionally. Synthesis runs with whatever findings exist.\n\n### All Dimensions Covered with Stabilization\n\n```\nif coverage.dimensionCoverage == 1.0 and activeP0 == 0 and activeP1 == 0:\n  if stabilizationPasses >= config.coverageAge.minStabilizationPasses:\n    if buildReviewLegalStop(state, config, coverage).passed:\n      return { action: \"STOP\", stopReason: \"converged\" }\n```\n\nTriggers when all 4 dimensions (correctness, security, traceability, maintainability) are covered, no active P0/P1 remains, at least 1 stabilization pass has occurred, and the 5-gate legal-stop bundle passes. If gates fail, the loop records `stopReason=blockedStop` and continues despite full coverage.\n\n---\n\n## 3. STUCK DETECTION\n\nIdentifies when the review loop makes no meaningful progress across consecutive iterations.\n\n```\nfunction countConsecutiveStuck_review(evidenceIterations, noProgressThreshold):\n  count = 0\n  for i in reversed(evidenceIterations):\n    if i.status == \"thought\":   continue    // invisible to stuck counter\n    if i.status == \"insight\":   break       // resets stuck counter (genuine progress)\n    if i.newFindingsRatio < noProgressThreshold or i.status == \"stuck\":\n      count += 1\n    else:\n      break\n  return count\n```\n\n**Threshold:** `stuckThreshold = 2` consecutive no-progress iterations (using `noProgressThreshold = 0.05`).\n\n**Status exclusions:**\n- `insight`: Resets stuck counter -- a conceptual breakthrough counts as progress even with a low ratio.\n- `thought`: Skipped entirely -- analytical iterations produce no evidence to measure.\n\nWhen `stuckCount >= stuckThreshold`, the orchestrator invokes the recovery protocol (Section 8) before deciding whether to continue or stop.\n\nThe recovery entry uses `stopReason=stuckRecovery` while the loop is in recovery. If recovery later terminates the run, the terminal record keeps the same shared enum value instead of minting a review-only label.\n\n---\n\n## 4. COMPOSITE CONVERGENCE\n\nThree independent signals each cast a stop/continue vote. Stop when the weighted stop-score meets or exceeds the consensus threshold. The signal set below matches the authoritative 3-signal vote in `deep_review_{auto,confirm}.yaml` `step_check_convergence` and the quick-reference convergence table, the 3rd signal is **dimension coverage**, not a standalone novelty ratio.\n\n| Signal | Weight | Min Iterations | Measures |\n|--------|--------|---------------|----------|\n| Rolling Average | 0.30 | 2 | Recent severity-weighted finding yield |\n| MAD Noise Floor | 0.25 | 3 | Signal vs noise in newFindingsRatio |\n| Dimension Coverage | 0.45 | 1 | Configured review dimensions fully covered AND required traceability protocols covered AND `coverage_age >= minStabilizationPasses` |\n\n### Signal 1: Rolling Average (weight 0.30)\n\nAverages the last 2 severity-weighted `newFindingsRatio` values from evidence-bearing iterations (excludes `thought` status). Votes STOP when the average drops below `rollingStopThreshold` (0.08).\n\n```\nif len(evidenceIterations) >= 2:\n  recent = evidenceIterations[-2:]\n  avgRatio = mean(i.newFindingsRatio for i in recent)\n  rollingStop = avgRatio < 0.08\n```\n\n### Signal 2: MAD Noise Floor (weight 0.25)\n\nRobust statistical test using Median Absolute Deviation. Votes STOP when the latest ratio is at or below the computed noise floor.\n\n```\nif len(evidenceIterations) >= 3:\n  allRatios = [i.newFindingsRatio for i in evidenceIterations]\n  med = median(allRatios)\n  mad = median([abs(r - med) for r in allRatios])\n  noiseFloor = mad * 1.4826     // normal distribution estimator\n  madStop = evidenceIterations[-1].newFindingsRatio <= noiseFloor\n```\n\n### Signal 3: Dimension Coverage (weight 0.45)\n\nHighest-weight signal. Votes STOP once every configured review dimension AND every required traceability protocol has been covered by at least one iteration, and the coverage set has been stable for at least `minStabilizationPasses` iterations (default 1). This is the signal the YAML workflow evaluates.\n\n```\ndimensionStop =\n  dimensions_covered_count == configured_dimensions_count\n  AND required_traceability_protocols_covered\n  AND coverage_age >= config.minStabilizationPasses\n```\n\nThe latest severity-weighted newFindingsRatio is still tracked (the dashboard and registry surface it as `newFindingsRatio`), but it does NOT cast an independent stop vote, it feeds the rolling average and MAD noise-floor signals only.\n\n### Weighted Vote\n\n```\nstopScore = sum(s.weight * (1 if s.stop else 0) for s in signals) / totalWeight\nif stopScore >= 0.60:   // proceed to quality gate evaluation\n```\n\nWeights are redistributed across active signals only. If only 2 signals have enough data, their weights are normalized to sum to 1.0.\n\n### Semantic Convergence Signals\n\nTwo additional signals provide deeper semantic analysis of review iteration quality. These signals are ADDITIONAL to the 3-signal composite vote above and participate in the legal-stop gate evaluation rather than the composite stop-score.\n\n#### semanticNovelty (0.0-1.0)\n\nMeasures how much genuinely new review insight each iteration contributes beyond surface-level overlap with prior findings. Unlike `newFindingsRatio` (which is severity-weighted), `semanticNovelty` evaluates the conceptual novelty of findings independent of severity weighting.\n\n| Value | Meaning |\n|-------|---------|\n| 0.8-1.0 | Iteration uncovered substantially new defect patterns, architectural concerns, or review angles |\n| 0.4-0.7 | Mix of new review insights and restatements of prior findings |\n| 0.1-0.3 | Mostly refinements or rewordings of previously identified issues |\n| 0.0 | No semantically novel findings detected |\n\nComputation:\n```\nfunction computeSemanticNovelty_review(currentFindings, priorCumulativeFindings):\n  newPatterns = extractDefectPatterns(currentFindings) - extractDefectPatterns(priorCumulativeFindings)\n  totalPatterns = extractDefectPatterns(currentFindings)\n  if len(totalPatterns) == 0: return 0.0\n  return len(newPatterns) / len(totalPatterns)\n```\n\nWhen `semanticNovelty` drops below 0.15 for 2+ consecutive evidence iterations, it provides strong supporting evidence for a legal STOP decision. This signal catches cases where `newFindingsRatio` stays moderate (due to severity weighting of refinements) but the review has exhausted genuinely new defect categories.\n\n#### findingStability (0.0-1.0)\n\nMeasures how stable the cumulative finding set is across iterations. A high stability score means the finding registry is not materially changing between iterations -- findings are not being added, upgraded, downgraded, or invalidated at a significant rate.\n\n| Value | Meaning |\n|-------|---------|\n| 0.9-1.0 | Finding set is highly stable, minimal churn between iterations |\n| 0.6-0.8 | Moderate stability, some findings still evolving |\n| 0.3-0.5 | Active churn, findings being added, merged, or reclassified frequently |\n| 0.0-0.2 | Highly unstable, the review is still in early discovery |\n\nComputation:\n```\nfunction computeFindingStability(currentRegistry, priorRegistry):\n  if priorRegistry is null: return 0.0  // first iteration\n  unchangedFindings = count(f for f in currentRegistry\n    if f.id in priorRegistry and f.severity == priorRegistry[f.id].severity\n    and f.status == priorRegistry[f.id].status)\n  totalFindings = max(len(currentRegistry), len(priorRegistry))\n  if totalFindings == 0: return 1.0\n  return unchangedFindings / totalFindings\n```\n\nConvergence behavior:\n- `findingStability >= 0.85` supports STOP: the finding set has stabilized and further iterations are unlikely to materially change the review outcome.\n- `findingStability < 0.50` prevents STOP: the finding set is still in flux and the review has not reached a stable assessment.\n\n#### Integration with Legal-Stop Gate Bundle\n\nThe two semantic signals integrate with the existing 5-gate legal-stop bundle (Section 6):\n\n1. **findingStability gate** (existing): The existing `findingStability` gate already evaluates rolling average, MAD noise floor, and novelty ratio. The new `semanticNovelty` signal adds a sub-check:\n   - `semanticNoveltyPlateau`: `semanticNovelty < 0.15` for 2+ consecutive evidence iterations\n   - When this sub-check fails while the existing churn signals pass, the gate records the mismatch as a diagnostic note but does not independently block STOP.\n\n2. **findingStability signal** (new): The `findingStability` metric (0.0-1.0) is surfaced alongside the existing convergence signals. It supports the `findingStability` gate evaluation by providing a registry-level stability measure that complements the ratio-based churn signals.\n\nThe gate passes only when both the existing churn-based checks AND the semantic stability checks agree. When a semantic check fails, the persisted `blocked_stop.gateResults.findingStability` payload includes the semantic signal values.\n\n#### Stop-Decision Trace\n\nThe stop-decision event includes which semantic signals supported or prevented STOP:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"stop_decision\",\n  \"semanticSignals\": {\n    \"semanticNovelty\": { \"value\": 0.06, \"consecutiveLow\": 3, \"supportsStop\": true },\n    \"findingStability\": { \"value\": 0.92, \"supportsStop\": true }\n  },\n  \"semanticVerdict\": \"all_support_stop\",\n  ...\n}\n```\n\n| `semanticVerdict` | Meaning |\n|-------------------|---------|\n| `all_support_stop` | Both semantic signals support stopping |\n| `mixed` | One signal supports stop, the other does not |\n| `all_prevent_stop` | Both semantic signals indicate more work is needed |\n| `insufficient_data` | Not enough iterations to compute semantic signals |\n\n### Graceful Degradation\n\n| Iterations Completed | Active Signals | Behavior |\n|---------------------|----------------|----------|\n| 1 | Novelty ratio only (weight 1.0) | Very unlikely to stop without later confirmation from rolling churn signals |\n| 2 | Rolling avg + novelty ratio | Two-signal vote, reweighted |\n| 3+ | All three signals | Full composite, most reliable |\n\nSemantic convergence signals (`semanticNovelty`, `findingStability`) require at least 2 evidence iterations to produce meaningful values. They are omitted from legal-stop evaluation when insufficient data exists.\n\n---\n\n## 5. SEVERITY-WEIGHTED RATIO\n\nThe review loop uses `newFindingsRatio` instead of `newInfoRatio`. It weights findings by severity so that critical discoveries count far more than minor suggestions.\n\n### Severity Weights\n\n| Severity | Weight | Description |\n|----------|--------|-------------|\n| **P0** (Blocker) | 10.0 | Correctness failures, security vulnerabilities, spec contradictions |\n| **P1** (Required) | 5.0 | Degraded behavior, incomplete implementation, missing validation |\n| **P2** (Suggestion) | 1.0 | Style, naming, minor improvements, documentation gaps |\n\n### Computation\n\n```\nSEVERITY_WEIGHTS = { P0: 10.0, P1: 5.0, P2: 1.0 }\nrefinementMultiplier = 0.5\n\nweightedNew       = sum(SEVERITY_WEIGHTS[f.severity] for f in fully_new_findings)\nweightedRefinement = sum(SEVERITY_WEIGHTS[f.severity] * 0.5 for f in refinement_findings)\nweightedTotal     = sum(SEVERITY_WEIGHTS[f.severity] for f in all_findings_this_iteration)\n\nnewFindingsRatio = (weightedNew + weightedRefinement) / weightedTotal\n```\n\n- `fully_new_findings` -- findings not present in any prior iteration (new findingId).\n- `refinement_findings` -- findings that refine or upgrade an existing finding (same root cause, new evidence or severity change).\n- `refinementMultiplier = 0.5` -- refinements count at half weight.\n\n### P0 Override Rule\n\n```\nif ANY new P0 found this iteration:\n  newFindingsRatio = max(calculated, 0.50)\n\nif total_findings == 0:\n  newFindingsRatio = 0.0\n```\n\nA new critical finding always signals significant remaining work. The 0.50 floor prevents premature convergence when critical issues are still being discovered.\n\n---\n\n## 6. LEGAL-STOP GATE BUNDLE\n\n> **GATE MODEL, two naming conventions mapped to one authoritative set.** The authoritative producer is `step_emit_blocked_stop` in both `deep_review_{auto,confirm}.yaml`, which emits **9 gates** with the `Gate` suffix: `convergenceGate` / `dimensionCoverageGate` / `p0ResolutionGate` / `evidenceDensityGate` / `hotspotSaturationGate` / `claimAdjudicationGate` / `fixCompletenessReplayGate` / `candidateCoverageGate` / `graphlessFallbackGate`. The §Section-1 event shape (lines 98-119) mirrors this set verbatim and the reducer reads those names verbatim, so treat the event shape as authoritative when writing or reading JSONL state. The §6 table below is the high-level conceptual model and uses descriptive names WITHOUT the `Gate` suffix where one reads more naturally (for example `findingStability` maps to `convergenceGate`); each row carries its event-shape name so the mapping is explicit. `candidateCoverageGate` and `graphlessFallbackGate` are v2-rollout gates that pass trivially when the review-depth-v2 search path is inactive. The gate-model drift cluster (LG-0013, LG-0016, LG-0031, LG-0032) was reconciled in `006-gate-model-reconciliation`.\n\nDeep review treats STOP as legal only when the full review-specific gate bundle passes together. Convergence math may request STOP, but the workflow must still evaluate these 9 gates and persist a blocked-stop event when any gate fails.\n\n| Gate (§6 conceptual) | Event-shape name (§Section-1) | Rule | Fail Action |\n|------|------|------|-------------|\n| **findingStability** | `convergenceGate` | Rolling average, MAD noise floor, and novelty ratio must all indicate low-yield review churn | Block STOP, persist `blockedStop` |\n| **dimensionCoverage** | `dimensionCoverageGate` | Every configured review dimension must have been examined at least once, with required traceability coverage stabilized | Block STOP, persist `blockedStop` |\n| **p0Resolution** | `p0ResolutionGate` | No unresolved P0 findings may remain active at stop time | Block STOP, persist `blockedStop` |\n| **evidenceDensity** | `evidenceDensityGate` | Evidence density across active findings must meet the configured threshold | Block STOP, persist `blockedStop` |\n| **hotspotSaturation** | `hotspotSaturationGate` | Review hotspots must be revisited enough times to satisfy the saturation heuristic | Block STOP, persist `blockedStop` |\n| (no §6 counterpart) | `claimAdjudicationGate` | Each new P0/P1 finding must carry a typed adjudication packet, missing or failing packets veto STOP | Block STOP, persist `blockedStop` |\n| **fixCompletenessReplay** | `fixCompletenessReplayGate` | Security-sensitive fix reruns must replay previously closed P0/P1 gates and validate producer/consumer/matrix coverage from the remediation packet | Block STOP, persist `blockedStop` |\n| **candidateCoverage** (v2 rollout) | `candidateCoverageGate` | Search debt must be cleared and every required bug class must have candidate coverage before STOP, passes trivially when the v2 search path is inactive | Block STOP, persist `blockedStop` |\n| **graphlessFallback** (v2 rollout) | `graphlessFallbackGate` | When the code graph is unavailable, required bug classes must carry cited fallback ledger rows, passes trivially when the graph is available | Block STOP, persist `blockedStop` |\n\n### Gate Evaluation\n\n```\nfunction buildReviewLegalStop(state, config, coverage):\n  gateResults = {\n    findingStability: {\n      pass: rollingStop and madStop and state.latestNoveltyRatio <= config.convergenceThreshold,\n      detail: \"Rolling average, MAD noise floor, and novelty ratio are all below stop thresholds.\"\n    },\n    dimensionCoverage: {\n      pass: everyConfiguredDimensionExaminedAtLeastOnce(coverage, config.reviewDimensions) and\n            coverage.requiredProtocolsCovered and\n            coverage.stabilizationPasses >= 1,\n      detail: \"All configured review dimensions have been examined, required traceability protocols are covered, and stabilization has aged enough to stop.\"\n    },\n    p0Resolution: {\n      pass: countActiveFindings(state, [\"P0\"]) == 0 and state.claimAdjudicationPassed != false,\n      detail: \"No unresolved P0 findings remain and blocker adjudication is complete.\"\n    },\n    evidenceDensity: {\n      pass: computeEvidenceDensity(state.activeFindings) >= config.evidenceDensityThreshold,\n      detail: \"Evidence density meets the configured threshold for active findings.\"\n    },\n    hotspotSaturation: {\n      pass: computeHotspotSaturation(state.hotspots) >= config.hotspotSaturationThreshold,\n      detail: \"Priority hotspots received enough revisits to satisfy saturation.\"\n    },\n    fixCompletenessReplay: {\n      pass: not isSecuritySensitiveFixRerun(state, config) or allRequiredReplayRowsPass(state.reviewReport),\n      detail: \"Security-sensitive fix reruns include closed-gate replay evidence and producer/consumer/matrix coverage before STOP.\"\n    },\n    candidateCoverage: {\n      pass: not isReviewDepthV2Active(state, config) or (searchDebtCleared(state) and allRequiredBugClassesCovered(state)),\n      detail: \"Search debt is cleared and every required bug class has candidate coverage. Passes trivially when the v2 search path is inactive.\"\n    },\n    graphlessFallback: {\n      pass: state.searchCoverage.graphCoverageMode == \"graph_available\" or allRequiredBugClassesHaveFallbackRows(state),\n      detail: \"When the code graph is unavailable, required bug classes carry cited fallback ledger rows. Passes trivially when the graph is available.\"\n    }\n  }\n\n  blockedBy = [name for name, result in gateResults.items() if not result.pass]\n  return {\n    pass: len(blockedBy) == 0,\n    blockedBy,\n    gateResults\n  }\n```\n\nWhen convergence math returns STOP, invoke `buildReviewLegalStop()`. If it returns `pass: false`, persist a first-class `blocked_stop` event with the failing `blockedBy` gates, the full `gateResults` bundle, a `recoveryStrategy`, and the normal run/timestamp/session lineage fields before overriding the decision to CONTINUE.\n\n### Blocked-Stop Recovery Strategy\n\n| Failed Gate | Recovery Strategy |\n|-------------|-------------------|\n| `findingStability` | Revisit the noisiest recent dimension and reduce novelty by closing obvious follow-up loops before re-checking STOP. |\n| `dimensionCoverage` | Schedule the next uncovered review dimension immediately. |\n| `p0Resolution` | Re-open the active blocker path and verify whether the P0 is real, downgraded, or still unresolved. |\n| `evidenceDensity` | Re-read weakly supported findings and add concrete `file:line` citations before they count toward a stop decision. |\n| `hotspotSaturation` | Revisit undersampled hotspots or adjacent call sites until the saturation heuristic passes. |\n| `fixCompletenessReplay` | Replay prior active or remediated P0/P1 gates, then record producer, consumer, and matrix coverage evidence before re-checking STOP. |\n| `candidateCoverage` | Clear outstanding search debt and run candidate discovery for the missing bug classes before re-checking STOP. |\n| `graphlessFallback` | Add cited fallback ledger rows for the required bug classes, or restore graph availability, before re-checking STOP. |\n\n### Legacy Stop-Reason Mapping\n\nUse this table when replaying old packets or translating older prose/docs into the shared stop contract.\n\n| Legacy label | New `stopReason` | Mapping note |\n|--------------|------------------|--------------|\n| `all_dimensions_clean` | `converged` | Legacy review-specific terminal label, now expressed by the shared enum. |\n| `composite_converged` | `converged` | Legacy convergence-math wording now rolls into shared terminal success. |\n| `all dimensions clean` | `converged` | Old operator-facing prose for the same successful stop. |\n| `max_iterations_reached` | `maxIterationsReached` | Legacy machine label for the hard iteration cap. |\n| `max iterations` | `maxIterationsReached` | Old operator-facing hard-stop wording. |\n| `pause sentinel detected` | `userPaused` | Sentinel pause is now a shared user-directed stop reason. |\n| `guard_override` | `blockedStop` | Legacy continue override when a stop vote failed legal gates. |\n| `quality guard failed` | `blockedStop` | Older prose for the same blocked-stop outcome. |\n| `P0 override blocks convergence` | `blockedStop` | Legacy review wording for a stop attempt that was not legal to finalize. |\n| `stuck_detected` | `stuckRecovery` | Legacy recovery trigger label. |\n| `stuck_unrecoverable` | `stuckRecovery` | Legacy terminal wording for the same recovery path family. |\n| `manual halt` | `manualStop` | Operator-directed halt outside normal pause sentinel flow. |\n\n---\n\n## 7. PROVISIONAL VERDICT\n\nThe provisional verdict is determined from active findings at the time the loop stops. It appears in both the convergence report and the final `review-report.md`.\n\n| Verdict | Condition | Meaning |\n|---------|-----------|---------|\n| **FAIL** | `activeP0 > 0` OR any legal-stop gate fails at terminal stop time | Does not meet quality standards. Blocks release. |\n| **CONDITIONAL** | `activeP0 == 0` AND `activeP1 > 0` | Meets threshold but has required fixes before release. |\n| **PASS** | `activeP0 == 0` AND `activeP1 == 0` | Shippable. Set `hasAdvisories: true` when `activeP2 > 0`. |\n\n### Determination\n\n```\nfunction determineVerdict(state, gateResult):\n  activeP0 = countActiveFindings(state, [\"P0\"])\n  activeP1 = countActiveFindings(state, [\"P1\"])\n  activeP2 = countActiveFindings(state, [\"P2\"])\n\n  if activeP0 > 0 or not gateResult.passed:\n    return { verdict: \"FAIL\", nextCommand: \"/speckit:plan\" }\n  if activeP1 > 0:\n    return { verdict: \"CONDITIONAL\", nextCommand: \"/speckit:plan\" }\n\n  hasAdvisories = activeP2 > 0\n  return { verdict: \"PASS\", hasAdvisories, nextCommand: \"/create:changelog\" }\n```\n\n### Post-Verdict Routing\n\n| Verdict | Next Step |\n|---------|-----------|\n| FAIL | `/speckit:plan` -- create remediation plan from findings |\n| CONDITIONAL | `/speckit:plan` -- create fix plan for P1 findings |\n| PASS | `/create:changelog` -- record the clean audit |\n\n---\n\n## 8. RECOVERY, REPORTING, AND GRAPH-AWARE CONVERGENCE\n\nStuck-recovery strategies, the convergence report format, and graph-aware review convergence live in `convergence_recovery.md` for navigability.\n\n---\n\n## OPTIMIZER-TUNABLE THRESHOLDS\n\nThe following convergence thresholds are managed by the offline loop optimizer (042.004). Changes to these fields are proposed through the optimizer's advisory-only promotion gate and reviewed by humans before adoption.\n\n### Tunable Fields (Optimizer-Managed)\n\n| Field | Default | Range | Description |\n|-------|---------|-------|-------------|\n| `convergenceThreshold` | 0.10 | 0.01-0.20 | General convergence sensitivity |\n| `stuckThreshold` | 2 | 1-5 | Consecutive no-progress iterations before recovery |\n| `maxIterations` | 7 | 3-20 | Hard iteration ceiling |\n| `compositeStopScore` | 0.60 | 0.40-0.80 | Weighted stop score needed before guard evaluation |\n\n### Locked Fields (Not Optimizer-Tunable)\n\nThe following fields are runtime contracts and MUST NOT be modified by the optimizer:\n\n- `stopReason` enum values and semantics\n- `blocked_stop` event structure and gate names\n- Lineage fields (`sessionId`, `lineageMode`, `generation`)\n- Reducer configuration and file protection policies\n- Review dimensions (`reviewDimensions`) and product mode (`mode`)\n\n### Canonical Manifest\n\nThe authoritative registry of tunable vs locked fields is maintained at:\n`.opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json`","lineStart":1,"lineEnd":606,"totalLines":606,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/convergence/convergence.md","time":{"start":1784210482245,"end":1784210482287}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204ec819490568a3379355119"}},"id":"prt_f6b3b6442001lAjjTW7hjTIILr","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482294,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_hDMtjRqbkmizOWfJgFp6z90r","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Completion Criteria\n3: description: Full definition-of-done checklist for a deep-review loop -- loop completion conditions, the binary quality gates that must pass before STOP, and release-readiness validation success criteria.\n4: trigger_phrases:\n5:   - \"review loop completion criteria\"\n6:   - \"review success criteria\"\n7:   - \"review definition of done\"\n8:   - \"review release readiness validation\"\n9: importance_tier: important\n10: contextType: implementation\n11: version: 1.11.0.0\n12: ---\n13: \n14: # Deep Review Completion Criteria\n15: \n16: Full definition-of-done checklist for a deep-review loop: loop completion conditions, the binary quality gates STOP must clear, and release-readiness validation success criteria.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: This reference is the authoritative checklist for \"is this review loop actually done.\" SKILL.md §6 SUCCESS CRITERIA carries a condensed summary and links here for the full enumeration; use this file when verifying a completed run, debugging a premature STOP, or reconciling completion metadata against the loop's real state.\n25: \n26: ### When to Use\n27: \n28: - Verifying a review loop's completion before accepting its verdict.\n29: - Debugging why STOP was blocked or why synthesis produced an incomplete report.\n30: - Reconciling `review-report.md` claims against the canonical state files.\n31: - Auditing a run for the release-readiness handoff.\n32: \n33: ### Relationship to `loop_state_and_gates.md`\n34: \n35: `references/protocol/loop_state_and_gates.md` defines the three state-machine-level binary gates (Evidence, Scope, Coverage) that block a STOP *decision* inside the convergence check. This file is the broader definition-of-done: it also covers artifact existence, report structure, severity-field completeness, and the release-readiness handoff -- checked once the loop believes it has already reached STOP.\n36: \n37: ---\n38: \n39: ## 2. LOOP COMPLETION\n40: \n41: A review loop is considered complete when every item below holds:\n42: \n43: - The loop reached convergence (composite stop score above `compositeStopScore`, with required gates green) OR hit `maxIterations` without false-positive STOP.\n44: - Every configured review dimension has at least one full iteration of coverage recorded in `deep-review-state.jsonl` and reflected in `deep-review-strategy.md`.\n45: - Required traceability protocols (`spec_code`, `checklist_evidence`) executed at least once. Overlay protocols that apply to the target type ran or were explicitly marked N/A.\n46: - All canonical state files exist and parse cleanly: `deep-review-config.json`, `deep-review-state.jsonl`, `deep-review-findings-registry.json`, `deep-review-strategy.md`, `deep-review-dashboard.md`, and one `iterations/iteration-NNN.md` per dispatched iteration.\n47: - `review/resource-map.md` was emitted from converged delta evidence unless `config.resource_map.emit == false` (operator flag `--no-resource-map`).\n48: - `review/review-report.md` carries all 9 core sections (Executive Summary, Planning Trigger, Active Finding Registry, Remediation Workstreams, Spec Seed, Plan Seed, Traceability Status, Deferred Items, Audit Appendix) plus the conditional `## Resource Map Coverage Gate` section when `resource_map_present == true`.\n49: - Canonical continuity surfaces updated via `generate-context.js` (description.json, graph-metadata.json, indexed memory entries).\n50: \n51: ---\n52: \n53: ## 3. QUALITY GATES\n54: \n55: Each gate is binary: pass or block. STOP cannot be legal until every gate passes.\n56: \n57: - **Config validity**: `deep-review-config.json` parses, names every required field, and lineage block matches the current run (`sessionId`, `parentSessionId`, `lineageMode`, `generation`, `continuedFromRun`, `releaseReadinessState`).\n58: - **Strategy initialization**: `deep-review-strategy.md` carries the Files Under Review table, Cross-Reference Status grouped by core vs overlay, Known Context, and Review Boundaries.\n59: - **State consistency**: `deep-review-state.jsonl` opens with the config record and appends one iteration record per dispatched iteration. Reducer-owned fields in `deep-review-findings-registry.json` reconcile against JSONL totals.\n60: - **Iteration completeness**: every dispatched iteration produced both an `iterations/iteration-NNN.md` (non-empty, ending with the canonical `Review verdict: PASS|CONDITIONAL|FAIL` line) AND a JSONL delta record with `findingDetails[]`, `findingsSummary`, `newFindingsRatio`.\n61: - **Severity coverage**: every reported finding carries `severity` in {P0, P1, P2}, `category`, `file:line` evidence, `finding_class`, and a `content_hash` for synthesis dedup.\n62: - **Advisory numeric score**: `riskScore` may appear in finding details as non-gating context only; verdict logic must ignore it.\n63: - **Adversarial replay**: every P0 finding survived adversarial self-check. Rejected P0s downgraded with rationale recorded in the iteration narrative.\n64: - **Coverage threshold**: `dimensions_covered_count == configured_dimensions_count` AND required traceability protocols covered, stable for at least `minStabilizationPasses` iterations.\n65: - **Acceptance coverage**: when the spec-folder lifecycle predicate is active, the final report records `AC_COVERAGE` status, covered/total, floor, and next action; default-off INFO output is advisory and does not by itself block STOP.\n66: - **Security-sensitive override**: when the run targets security, path handling, env precedence, schema boundaries, persistence, or shared policy, the gates from `references/convergence/convergence.md` \"Security-Sensitive Fix Overrides\" apply (`minStabilizationPasses=2`, closed-finding replay required, fix-completeness gate enforced).\n67: \n68: ---\n69: \n70: ## 4. VALIDATION SUCCESS\n71: \n72: The release-readiness handoff is valid when:\n73: \n74: - The final report records stop reason, iteration count, dimension coverage, severity counts (P0/P1/P2), verdict (PASS / CONDITIONAL / FAIL), and release-readiness state (`in-progress`, `converged`, `release-blocking`).\n75: - Verdict logic matches: PASS = no P0/P1 findings (P2 advisories permitted with `hasAdvisories: true`). CONDITIONAL = P1 findings present with remediation plan. FAIL = any P0 confirmed after adversarial self-check.\n76: - `resource-map.md` Phase-5 Augmentation section (if present) lists novel logic gaps with iteration source links, or explicitly records the empty-result case.\n77: - `skill_advisor.py \"run a deep review loop\" --threshold 0.8` still surfaces the skill after any graph-metadata edits.\n78: - `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh <spec-folder> --strict` exits 0 on the target spec folder.\n79: \n80: ---\n81: \n82: ## 5. RELATED RESOURCES\n83: \n84: - `references/protocol/loop_state_and_gates.md` -- state transitions, error handling, and the Evidence/Scope/Coverage STOP-decision gates.\n85: - `references/state/state_outputs.md` -- packet file ownership and the `review-report.md` section list.\n86: - `references/state/state_format.md` -- schemas for every state file referenced above.\n87: - `references/convergence/convergence.md` -- composite stop score, `minStabilizationPasses`, and Security-Sensitive Fix Overrides.\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Completion Criteria\ndescription: Full definition-of-done checklist for a deep-review loop -- loop completion conditions, the binary quality gates that must pass before STOP, and release-readiness validation success criteria.\ntrigger_phrases:\n  - \"review loop completion criteria\"\n  - \"review success criteria\"\n  - \"review definition of done\"\n  - \"review release readiness validation\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.0\n---\n\n# Deep Review Completion Criteria\n\nFull definition-of-done checklist for a deep-review loop: loop completion conditions, the binary quality gates STOP must clear, and release-readiness validation success criteria.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md","text":"---\ntitle: Deep Review Completion Criteria\ndescription: Full definition-of-done checklist for a deep-review loop -- loop completion conditions, the binary quality gates that must pass before STOP, and release-readiness validation success criteria.\ntrigger_phrases:\n  - \"review loop completion criteria\"\n  - \"review success criteria\"\n  - \"review definition of done\"\n  - \"review release readiness validation\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.0\n---\n\n# Deep Review Completion Criteria\n\nFull definition-of-done checklist for a deep-review loop: loop completion conditions, the binary quality gates STOP must clear, and release-readiness validation success criteria.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis reference is the authoritative checklist for \"is this review loop actually done.\" SKILL.md §6 SUCCESS CRITERIA carries a condensed summary and links here for the full enumeration; use this file when verifying a completed run, debugging a premature STOP, or reconciling completion metadata against the loop's real state.\n\n### When to Use\n\n- Verifying a review loop's completion before accepting its verdict.\n- Debugging why STOP was blocked or why synthesis produced an incomplete report.\n- Reconciling `review-report.md` claims against the canonical state files.\n- Auditing a run for the release-readiness handoff.\n\n### Relationship to `loop_state_and_gates.md`\n\n`references/protocol/loop_state_and_gates.md` defines the three state-machine-level binary gates (Evidence, Scope, Coverage) that block a STOP *decision* inside the convergence check. This file is the broader definition-of-done: it also covers artifact existence, report structure, severity-field completeness, and the release-readiness handoff -- checked once the loop believes it has already reached STOP.\n\n---\n\n## 2. LOOP COMPLETION\n\nA review loop is considered complete when every item below holds:\n\n- The loop reached convergence (composite stop score above `compositeStopScore`, with required gates green) OR hit `maxIterations` without false-positive STOP.\n- Every configured review dimension has at least one full iteration of coverage recorded in `deep-review-state.jsonl` and reflected in `deep-review-strategy.md`.\n- Required traceability protocols (`spec_code`, `checklist_evidence`) executed at least once. Overlay protocols that apply to the target type ran or were explicitly marked N/A.\n- All canonical state files exist and parse cleanly: `deep-review-config.json`, `deep-review-state.jsonl`, `deep-review-findings-registry.json`, `deep-review-strategy.md`, `deep-review-dashboard.md`, and one `iterations/iteration-NNN.md` per dispatched iteration.\n- `review/resource-map.md` was emitted from converged delta evidence unless `config.resource_map.emit == false` (operator flag `--no-resource-map`).\n- `review/review-report.md` carries all 9 core sections (Executive Summary, Planning Trigger, Active Finding Registry, Remediation Workstreams, Spec Seed, Plan Seed, Traceability Status, Deferred Items, Audit Appendix) plus the conditional `## Resource Map Coverage Gate` section when `resource_map_present == true`.\n- Canonical continuity surfaces updated via `generate-context.js` (description.json, graph-metadata.json, indexed memory entries).\n\n---\n\n## 3. QUALITY GATES\n\nEach gate is binary: pass or block. STOP cannot be legal until every gate passes.\n\n- **Config validity**: `deep-review-config.json` parses, names every required field, and lineage block matches the current run (`sessionId`, `parentSessionId`, `lineageMode`, `generation`, `continuedFromRun`, `releaseReadinessState`).\n- **Strategy initialization**: `deep-review-strategy.md` carries the Files Under Review table, Cross-Reference Status grouped by core vs overlay, Known Context, and Review Boundaries.\n- **State consistency**: `deep-review-state.jsonl` opens with the config record and appends one iteration record per dispatched iteration. Reducer-owned fields in `deep-review-findings-registry.json` reconcile against JSONL totals.\n- **Iteration completeness**: every dispatched iteration produced both an `iterations/iteration-NNN.md` (non-empty, ending with the canonical `Review verdict: PASS|CONDITIONAL|FAIL` line) AND a JSONL delta record with `findingDetails[]`, `findingsSummary`, `newFindingsRatio`.\n- **Severity coverage**: every reported finding carries `severity` in {P0, P1, P2}, `category`, `file:line` evidence, `finding_class`, and a `content_hash` for synthesis dedup.\n- **Advisory numeric score**: `riskScore` may appear in finding details as non-gating context only; verdict logic must ignore it.\n- **Adversarial replay**: every P0 finding survived adversarial self-check. Rejected P0s downgraded with rationale recorded in the iteration narrative.\n- **Coverage threshold**: `dimensions_covered_count == configured_dimensions_count` AND required traceability protocols covered, stable for at least `minStabilizationPasses` iterations.\n- **Acceptance coverage**: when the spec-folder lifecycle predicate is active, the final report records `AC_COVERAGE` status, covered/total, floor, and next action; default-off INFO output is advisory and does not by itself block STOP.\n- **Security-sensitive override**: when the run targets security, path handling, env precedence, schema boundaries, persistence, or shared policy, the gates from `references/convergence/convergence.md` \"Security-Sensitive Fix Overrides\" apply (`minStabilizationPasses=2`, closed-finding replay required, fix-completeness gate enforced).\n\n---\n\n## 4. VALIDATION SUCCESS\n\nThe release-readiness handoff is valid when:\n\n- The final report records stop reason, iteration count, dimension coverage, severity counts (P0/P1/P2), verdict (PASS / CONDITIONAL / FAIL), and release-readiness state (`in-progress`, `converged`, `release-blocking`).\n- Verdict logic matches: PASS = no P0/P1 findings (P2 advisories permitted with `hasAdvisories: true`). CONDITIONAL = P1 findings present with remediation plan. FAIL = any P0 confirmed after adversarial self-check.\n- `resource-map.md` Phase-5 Augmentation section (if present) lists novel logic gaps with iteration source links, or explicitly records the empty-result case.\n- `skill_advisor.py \"run a deep review loop\" --threshold 0.8` still surfaces the skill after any graph-metadata edits.\n- `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh <spec-folder> --strict` exits 0 on the target spec folder.\n\n---\n\n## 5. RELATED RESOURCES\n\n- `references/protocol/loop_state_and_gates.md` -- state transitions, error handling, and the Evidence/Scope/Coverage STOP-decision gates.\n- `references/state/state_outputs.md` -- packet file ownership and the `review-report.md` section list.\n- `references/state/state_format.md` -- schemas for every state file referenced above.\n- `references/convergence/convergence.md` -- composite stop score, `minStabilizationPasses`, and Security-Sensitive Fix Overrides.","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/protocol/completion_criteria.md","time":{"start":1784210482264,"end":1784210482290}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43205048194a2995b8f2836b2ac"}},"id":"prt_f6b3b6455001jaKzBu4Q74VMME","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482317,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_IHidKSKqqah5TD3dZFl23jXn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_outputs.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_outputs.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Deep Review State Outputs\"\n3: description: \"Focused reference for deep-review packet files, markdown outputs, reducer-owned views, and synthesis artifacts.\"\n4: trigger_phrases:\n5:   - \"deep review state outputs\"\n6:   - \"review packet outputs\"\n7:   - \"review dashboard output\"\n8:   - \"review report output\"\n9: importance_tier: normal\n10: contextType: implementation\n11: version: 1.11.0.3\n12: ---\n13: \n14: # Deep Review State Outputs\n15: \n16: This reference explains the files operators read during and after a review loop. Use `references/state/state_format.md` for schemas and field-level contracts.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: Deep-review outputs are audit artifacts. Iteration agents write evidence, the reducer writes derived state, and synthesis writes the release-readiness report.\n23: \n24: ---\n25: \n26: ## 2. PACKET FILES\n27: \n28: | File | Owner | Mutability | Purpose |\n29: |------|-------|------------|---------|\n30: | `deep-review-config.json` | Workflow | Immutable after init | Run parameters, lineage, threshold settings |\n31: | `deep-review-state.jsonl` | Workflow and iteration contract | Append-only | Config, iteration, blocked-stop, pause, synthesis events |\n32: | `deep-review-findings-registry.json` | Reducer | Regenerated | Active, resolved, repeated, and blocked findings |\n33: | `deep-review-strategy.md` | Reducer with operator-readable sections | Regenerated/updated | Dimension order, known context, next focus |\n34: | `deep-review-dashboard.md` | Reducer | Regenerated | Current status, trend, verdict preview |\n35: | `iterations/iteration-NNN.md` | Iteration agent | Write-once | Detailed findings for one pass |\n36: | `review-report.md` | Synthesis | Final output | Findings-first release-readiness report |\n37: | `resource-map.md` | Synthesis | Final or disabled | Converged delta evidence map |\n38: \n39: ---\n40: \n41: ## 3. ITERATION MARKDOWN\n42: \n43: Each iteration file must be non-empty and end with exactly one final verdict line:\n44: \n45: ```text\n46: Review verdict: PASS\n47: ```\n48: \n49: ```text\n50: Review verdict: CONDITIONAL\n51: ```\n52: \n53: ```text\n54: Review verdict: FAIL\n55: ```\n56: \n57: The line maps to the findings in that iteration only. Synthesis computes the final release verdict from the full state.\n58: \n59: ---\n60: \n61: ## 4. DASHBOARD\n62: \n63: The dashboard is a status view, not the source of truth. It should display:\n64: \n65: - Current iteration and next focus.\n66: - Active P0/P1/P2 counts.\n67: - Dimension coverage.\n68: - Convergence trend.\n69: - Gate blockers.\n70: - Provisional verdict.\n71: \n72: If dashboard data disagrees with JSONL, JSONL wins and the reducer must regenerate the dashboard.\n73: \n74: ---\n75: \n76: ## 5. FINAL REPORT\n77: \n78: `review-report.md` is the handoff artifact. It carries:\n79: \n80: - Executive summary.\n81: - Planning trigger.\n82: - Active finding registry.\n83: - Remediation workstreams.\n84: - Spec seed.\n85: - Plan seed.\n86: - Traceability status.\n87: - Deferred items.\n88: - Audit appendix.\n89: - Optional Resource Map Coverage Gate section when a map existed at init.\n90: \n91: ---\n92: \n93: ## 6. RELATED RESOURCES\n94: \n95: - `references/state/state_format.md` for schemas.\n96: - `references/state/state_reducer_registry.md` for reducer ownership.\n97: - `references/convergence/convergence_signals.md` for STOP fields shown in dashboard/report.\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Deep Review State Outputs\"\ndescription: \"Focused reference for deep-review packet files, markdown outputs, reducer-owned views, and synthesis artifacts.\"\ntrigger_phrases:\n  - \"deep review state outputs\"\n  - \"review packet outputs\"\n  - \"review dashboard output\"\n  - \"review report output\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.11.0.3\n---\n\n# Deep Review State Outputs\n\nThis reference explains the files operators read during and after a review loop. Use `references/state/state_format.md` for schemas and field-level contracts.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/state/state_outputs.md","text":"---\ntitle: \"Deep Review State Outputs\"\ndescription: \"Focused reference for deep-review packet files, markdown outputs, reducer-owned views, and synthesis artifacts.\"\ntrigger_phrases:\n  - \"deep review state outputs\"\n  - \"review packet outputs\"\n  - \"review dashboard output\"\n  - \"review report output\"\nimportance_tier: normal\ncontextType: implementation\nversion: 1.11.0.3\n---\n\n# Deep Review State Outputs\n\nThis reference explains the files operators read during and after a review loop. Use `references/state/state_format.md` for schemas and field-level contracts.\n\n---\n\n## 1. OVERVIEW\n\nDeep-review outputs are audit artifacts. Iteration agents write evidence, the reducer writes derived state, and synthesis writes the release-readiness report.\n\n---\n\n## 2. PACKET FILES\n\n| File | Owner | Mutability | Purpose |\n|------|-------|------------|---------|\n| `deep-review-config.json` | Workflow | Immutable after init | Run parameters, lineage, threshold settings |\n| `deep-review-state.jsonl` | Workflow and iteration contract | Append-only | Config, iteration, blocked-stop, pause, synthesis events |\n| `deep-review-findings-registry.json` | Reducer | Regenerated | Active, resolved, repeated, and blocked findings |\n| `deep-review-strategy.md` | Reducer with operator-readable sections | Regenerated/updated | Dimension order, known context, next focus |\n| `deep-review-dashboard.md` | Reducer | Regenerated | Current status, trend, verdict preview |\n| `iterations/iteration-NNN.md` | Iteration agent | Write-once | Detailed findings for one pass |\n| `review-report.md` | Synthesis | Final output | Findings-first release-readiness report |\n| `resource-map.md` | Synthesis | Final or disabled | Converged delta evidence map |\n\n---\n\n## 3. ITERATION MARKDOWN\n\nEach iteration file must be non-empty and end with exactly one final verdict line:\n\n```text\nReview verdict: PASS\n```\n\n```text\nReview verdict: CONDITIONAL\n```\n\n```text\nReview verdict: FAIL\n```\n\nThe line maps to the findings in that iteration only. Synthesis computes the final release verdict from the full state.\n\n---\n\n## 4. DASHBOARD\n\nThe dashboard is a status view, not the source of truth. It should display:\n\n- Current iteration and next focus.\n- Active P0/P1/P2 counts.\n- Dimension coverage.\n- Convergence trend.\n- Gate blockers.\n- Provisional verdict.\n\nIf dashboard data disagrees with JSONL, JSONL wins and the reducer must regenerate the dashboard.\n\n---\n\n## 5. FINAL REPORT\n\n`review-report.md` is the handoff artifact. It carries:\n\n- Executive summary.\n- Planning trigger.\n- Active finding registry.\n- Remediation workstreams.\n- Spec seed.\n- Plan seed.\n- Traceability status.\n- Deferred items.\n- Audit appendix.\n- Optional Resource Map Coverage Gate section when a map existed at init.\n\n---\n\n## 6. RELATED RESOURCES\n\n- `references/state/state_format.md` for schemas.\n- `references/state/state_reducer_registry.md` for reducer ownership.\n- `references/convergence/convergence_signals.md` for STOP fields shown in dashboard/report.","lineStart":1,"lineEnd":97,"totalLines":97,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/state/state_outputs.md","time":{"start":1784210482259,"end":1784210482300}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204fc8194a0d19179b644deee"}},"id":"prt_f6b3b6450001vhfkkj6pc7CTa4","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482332,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_3CvTNjtOLlwidWvN1uqCIb79","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Loop Protocol\n3: description: Complete lifecycle specification for the autonomous deep review loop, initialization, iteration, convergence, synthesis, and save phases.\n4: trigger_phrases:\n5:   - \"deep review loop protocol\"\n6:   - \"review iteration lifecycle\"\n7:   - \"review loop initialization\"\n8:   - \"review auto resume\"\n9:   - \"review synthesis phase\"\n10: importance_tier: important\n11: contextType: implementation\n12: version: 1.11.0.29\n13: ---\n14: \n15: # Deep Review Loop Protocol\n16: \n17: Complete lifecycle specification for the autonomous deep review loop.\n18: \n19: ---\n20: \n21: ## 1. OVERVIEW\n22: \n23: ### Purpose\n24: \n25: The deep review loop has 4 phases: initialization, iteration (repeated), synthesis, and save. The YAML workflow manages the lifecycle. The `@deep-review` agent (LEAF-only, no WebFetch) executes individual review iterations with fresh context each time.\n26: \n27: ### When to Use\n28: \n29: - Initiating a deep-review loop on a spec folder, skill, agent, or track.\n30: - Resuming a paused or interrupted review session from prior state.\n31: - Validating the 4-phase lifecycle and lineage protocol against current behavior.\n32: - Auditing iteration-dispatch, convergence, or save-phase contracts before changes.\n33: \n34: ```\n35: ┌──────────────┐     ┌───────────────────────────────┐     ┌───────────────┐     ┌──────────┐\n36: │  INIT        │────>│  LOOP                         │────>│  SYNTHESIS    │────>│  SAVE    │\n37: │              │     │  ┌─────────────────────────┐  │     │               │     │          │\n38: │ Scope        │     │  │ Read State              │  │     │ Finding       │     │ Memory   │\n39: │ Discovery    │     │  │ Check Convergence       │  │     │ Registry      │     │ Context  │\n40: │ Dimension    │     │  │ Check Pause Sentinel    │  │     │ Dedup         │     │ Save     │\n41: │ Ordering     │     │  │ Generate State Summary  │  │     │               │     │          │\n42: │ Traceability │     │  │ Dispatch @deep-review   │  │     │ Severity      │     │          │\n43: │ Planning     │     │  │ Evaluate Results        │  │     │ Reconcile     │     │          │\n44: │ State Files  │     │  │ Claim Adjudication      │  │     │               │     │          │\n45: │              │     │  │ Dashboard Generation    │  │     │ Replay        │     │          │\n46: │              │     │  │ Loop Decision           │  │     │ Validation    │     │          │\n47: │              │     │  └────────┬────────────────┘  │     │               │     │          │\n48: │              │     │           │ repeat            │     │ review-report │     │          │\n49: │              │     │           │                   │     │ (9 core +     │     │          │\n50: │              │     │           │                   │     │  resource-map)│     │          │\n51: └──────────────┘     └───────────────────────────────┘     └───────────────┘     └──────────┘\n52: ```\n53: \n54: ### Core Innovation\n55: \n56: Each agent dispatch gets a fresh context window. State continuity comes from files on disk, not in-context memory. This eliminates context degradation in long review sessions where accumulated findings would otherwise bias subsequent dimensions.\n57: \n58: ### Key References\n59: \n60: | Resource | Path | Purpose |\n61: |----------|------|---------|\n62: | Review contract | `assets/review_mode_contract.yaml` | Dimensions, verdicts, gates, protocols |\n63: | Auto workflow | `.opencode/commands/deep/assets/deep_review_auto.yaml` | Unattended review loop |\n64: | Confirm workflow | `.opencode/commands/deep/assets/deep_review_confirm.yaml` | Step-by-step review with approval gates |\n65: | Agent | `@deep-review` (LEAF) | Single iteration executor, no sub-agents, no WebFetch |\n66: | Memory save | `generate-context.js` | Context preservation script |\n67: \n68: ---\n69: \n70: ## 2. PHASE 1: INITIALIZATION\n71: \n72: ### Purpose\n73: \n74: Set up all state files for a new review session. Discover the scope, order dimensions by risk priority, establish the traceability protocol plan, and create the review state packet.\n75: \n76: ### Steps\n77: \n78: 1. **Classify session state before writing**:\n79:    - `fresh`: no config/state/strategy files exist\n80:    - `resume`: config + state + strategy all exist and agree\n81:    - `completed-session`: consistent prior state with `config.status == \"complete\"`\n82:    - `invalid-state`: partial or contradictory artifacts\n83: \n84: 2. **Resolve local artifact owner**: `artifact_dir = resolveArtifactRoot(specFolder, 'review').artifactDir`, then `mkdir -p {artifact_dir}/iterations`\n85: \n86: 3. **Scope discovery**: Resolve the review target into a concrete file list using one of 5 target types:\n87: \n88:    | Target Type | CLI Value | Resolution Strategy |\n89:    |-------------|-----------|---------------------|\n90:    | **Spec Folder** | `spec-folder` | Read `spec.md`, `plan.md`, implementation files listed in `tasks.md` |\n91:    | **Skill** | `skill` | Read `SKILL.md`, `references/`, `assets/`, `scripts/`, find agent definitions and command entry points |\n92:    | **Agent** | `agent` | Find agent definitions across all runtimes, compare for consistency |\n93:    | **Track** | `track` | List all child spec folders under the track, read `spec.md` + `checklist.md` for each |\n94:    | **Files** | `files` | Expand glob patterns, validate existence, discover cross-references |\n95: \n96:    Store the resolved file list in strategy.md \"Files Under Review\".\n97: \n98: 4. **Dimension ordering**: Order the 4 review dimensions for iteration based on risk priority:\n99: \n100:    | Priority | Dimension | Rationale |\n101:    |----------|-----------|-----------|\n102:    | 1 | Correctness | Logic errors have the highest blast radius |\n103:    | 2 | Security | Vulnerabilities require immediate attention |\n104:    | 3 | Traceability | Spec/code alignment ensures completeness |\n105:    | 4 | Maintainability | Patterns and documentation quality (lowest immediate risk) |\n106: \n107:    Default order: D1 Correctness, D2 Security, D3 Traceability, D4 Maintainability. This order is configurable but the default prioritizes highest-impact dimensions first.\n108: \n109: 5. **Traceability protocol planning**: Partition the 6 cross-reference protocols into core vs overlay, and schedule only applicable overlays for the target type:\n110: \n111:    | Level | Protocol | Applies To | Gate Class | Purpose |\n112:    |-------|----------|------------|------------|---------|\n113:    | Core | `spec_code` | all targets | hard | Verify normative claims resolve to shipped behavior |\n114:    | Core | `checklist_evidence` | all targets | hard | Verify checked completion claims have evidence |\n115:    | Overlay | `skill_agent` | skill | advisory | Verify SKILL.md and runtime agents agree |\n116:    | Overlay | `agent_cross_runtime` | agent | advisory | Verify runtime agent parity |\n117:    | Overlay | `feature_catalog_code` | skill, spec-folder, track, files | advisory | Verify catalog claims match capability |\n118:    | Overlay | `playbook_capability` | skill, agent, spec-folder | advisory | Verify playbook scenarios match executable reality |\n119: \n120:    Only schedule overlay protocols that apply to the resolved target type.\n121: \n122: 6. **Write config**: `{artifact_dir}/deep-review-config.json` with `mode: \"review\"`, lineage metadata (`sessionId`, `parentSessionId`, `lineageMode`, `generation`, `continuedFromRun`, `releaseReadinessState`), and review-specific fields including target, target type, dimensions, protocol plan, and release-readiness state.\n123: \n124: 7. **Initialize state log**: First line of `{artifact_dir}/deep-review-state.jsonl` with config record including `mode: \"review\"` and the lineage fields.\n125: \n126: 8. **Initialize reducer state**: Create `{artifact_dir}/deep-review-findings-registry.json` with empty `openFindings`, `resolvedFindings`, `repeatedFindings`, `dimensionCoverage`, `findingsBySeverity`, and `convergenceScore`.\n127: \n128: 9. **Initialize strategy**: `{artifact_dir}/deep-review-strategy.md` from review template with:\n129:    - Topic (review target description)\n130:    - Review Dimensions checklist\n131:    - Files Under Review table\n132:    - Cross-Reference Status table grouped by core vs overlay\n133:    - Known Context from `memory_context()` results (if any)\n134:    - Resource-map snapshot when `{spec_folder}/resource-map.md` exists at init\n135:    - `resource-map.md not present. Skipping coverage gate` when it does not\n136:    - Review Boundaries from config\n137: 9a. **Initialize resource-map coverage state**:\n138:    - If `{spec_folder}/resource-map.md` exists at init: set `resource_map_present = true`, add `Resource Map Coverage` to the Review Charter, and persist a concise map summary in `Known Context`\n139:    - If absent: set `resource_map_present = false`, record the skip note in `Known Context`, and continue without failing\n140: \n141: 10. **Validate review charter**:\n142:    - Verify strategy.md contains Non-Goals and Stop Conditions sections (may be empty but must exist)\n143:    - In **confirm mode**: present the charter (target, dimensions, scope, non-goals) for user review before proceeding\n144:    - In **auto mode**: accept automatically and continue\n145: \n146: 11. **Resume only if config, JSONL, strategy, and findings registry agree**. Otherwise halt for repair instead of guessing.\n147: \n148: ### Outputs\n149: \n150: | File | Location | Purpose |\n151: |------|----------|---------|\n152: | Config | `{artifact_dir}/deep-review-config.json` | Review parameters (immutable after init) |\n153: | State | `{artifact_dir}/deep-review-state.jsonl` | Iteration log (1 initial line) |\n154: | Registry | `{artifact_dir}/deep-review-findings-registry.json` | Reducer-owned findings state |\n155: | Strategy | `{artifact_dir}/deep-review-strategy.md` | Dimensions, findings, next focus |\n156: \n157: ---\n158: \n159: ## 3. PHASE 2: ITERATION LOOP\n160: \n161: ### Loop Steps (repeated until convergence)\n162: \n163: #### Step 1: Read State\n164: \n165: - Read `deep-review-state.jsonl` -- count iterations, extract `newFindingsRatio`, `findingsSummary`, `findingsNew`, `traceabilityChecks`, and lineage data\n166: - Read `deep-review-findings-registry.json` -- extract `dimensionsCovered`, `findingsBySeverity`, `openFindings`, `resolvedFindings`, and `convergenceScore`\n167: - Read `{artifact_dir}/deep-review-strategy.md` -- get next focus dimension/files, remaining dimensions, and protocol gaps\n168: \n169: Reducer contract for every loop refresh:\n170: \n171: | Reducer Part | Canonical Value | Notes |\n172: |--------------|-----------------|-------|\n173: | Inputs | `fullJSONLHistory`, `iterationFiles`, `priorReducedState` | Normal loop refresh is full-history: replay the persisted JSONL state and current iteration corpus each refresh so reducer output stays deterministic across restart, compaction, and synthesis audit paths. |\n174: | Outputs | `findingsRegistry`, `dashboardMetrics`, `strategyUpdates` | The same refresh pass updates the canonical registry, refreshes dashboard metrics, and applies strategy updates. |\n175: | Metrics | `dimensionsCovered`, `findingsBySeverity`, `openFindings`, `resolvedFindings`, `convergenceScore` | These metrics drive convergence decisions, dashboard summaries, and synthesis readiness. |\n176: \n177: #### Step 2: Check Convergence\n178: \n179: Run `shouldContinue_review()` (see `../deep-research/references/convergence/convergence.md` Section 10.3):\n180: \n181: - Max iterations reached? `STOP`\n182: - Stuck count `>= 2` using `noProgressThreshold = 0.05`? `STUCK_RECOVERY`\n183: - Composite convergence votes `STOP` only after:\n184:   - Rolling average uses `rollingStopThreshold = 0.08`\n185:   - Dimension coverage reaches 100% across the 4-dimension model\n186:   - Coverage has aged through `minStabilizationPasses >= 1`\n187:   - Required traceability protocols are covered\n188:   - Evidence, scope, and coverage gates pass\n189: - Otherwise: `CONTINUE`\n190: \n191: If convergence math or a hard-stop candidate points to STOP, the workflow must run the review legal-stop decision tree before actually stopping. That decision tree records nine review-specific gates: `convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, and `graphlessFallbackGate` (see `../convergence/convergence.md` §Section-1 blocked_stop event example for the authoritative shape). The Step 4a claim-adjudication path treats `claimAdjudicationGate` as a hard STOP gate, so the count covers both the convergence decision tree and the adjudication enforcement path. `candidateCoverageGate` and `graphlessFallbackGate` are v2-rollout gates that pass trivially when the review-depth-v2 search path is inactive. If any gate fails, the loop does **not** stop. Instead it emits a first-class `blocked_stop` JSONL event with:\n192: \n193: - `blockedBy`: array of the failed review gate names\n194: - `gateResults`: per-gate pass/fail payloads using the review gate names above\n195: - `recoveryStrategy`: one-line hint describing the next review action\n196: \n197: The blocked-stop event is append-only evidence that legal-stop blocked the run. The loop then continues with the recovery or next-focus path rather than synthesizing.\n198: \n199: Convergence signals and weights:\n200: \n201: | Signal | Weight | Description |\n202: |--------|--------|-------------|\n203: | Rolling Average | 0.30 | Last 2 severity-weighted `newFindingsRatio` values average below `rollingStopThreshold` |\n204: | MAD Noise Floor | 0.25 | Latest ratio within noise floor derived from historical ratios |\n205: | Dimension Coverage | 0.45 | All 4 dimensions plus required traceability protocols covered, with stabilization |\n206: \n207: **P0 override**: Any new P0 finding sets `newFindingsRatio >= 0.50`, blocking convergence regardless of composite score.\n208: \n209: #### Step 2a: Check Pause Sentinel\n210: \n211: Before dispatching, check for a pause sentinel file:\n212: \n213: 1. Check if `review/.deep-review-pause` exists (note: the file name uses the shared `-pause` suffix)\n214: 2. If present:\n215:    - Log event to JSONL: `{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"sentinel file detected\"}`\n216:    - Halt the loop with message:\n217:      ```\n218:      Review paused. Delete review/.deep-review-pause to resume.\n219:      Current state: Iteration {N}, {reviewed}/{total} dimensions complete, {P0}/{P1}/{P2} findings.\n220:      ```\n221:    - Do NOT exit to synthesis -- the loop is suspended, not stopped\n222: 3. On resume (file deleted and loop restarted):\n223:    - Log event: `{\"type\":\"event\",\"event\":\"resumed\",\"fromIteration\":N}`\n224:    - Continue from step_read_state\n225: \n226: **Use case**: In autonomous mode, this provides the only graceful intervention mechanism short of killing the process. Users can create the sentinel file at any time to pause review between iterations.\n227: \n228: Normalization rule: if the runtime first observes a raw `paused` condition or a raw `stuck_recovery` condition, it MUST rewrite the emitted JSONL event names to `userPaused` and `stuckRecovery` before appending them. Persisted review JSONL should never contain raw `paused` or raw `stuck_recovery` rows after emission.\n229: \n230: #### Step 2b: Generate State Summary\n231: \n232: Generate a compact state summary (~200 tokens) for injection into the dispatch prompt:\n233: \n234: ```\n235: STATE SUMMARY (auto-generated, review mode):\n236: Iteration: {N} of {max} | Mode: review\n237: Target: {config.reviewTarget} ({config.reviewTargetType})\n238: Dimensions: {reviewed}/{total} complete | Next: {nextDimension}\n239: Findings: P0:{count} P1:{count} P2:{count} active\n240: Traceability: core={core_status} overlay={overlay_status}\n241: Last 2 ratios: {ratio_N-1} -> {ratio_N} | Stuck count: {stuck_count}\n242: Provisional verdict: {PASS|CONDITIONAL|FAIL|PENDING} | hasAdvisories={hasAdvisories}\n243: Next focus: {strategy.nextFocus}\n244: ```\n245: \n246: This summary is prepended to the dispatch context (Step 3) to ensure the agent has baseline context even if detailed strategy.md reading fails or is incomplete.\n247: \n248: #### Step 3: Dispatch Agent\n249: \n250: Dispatch `@deep-review` with review-specific context:\n251: \n252: ```\n253: {state_summary}  // Auto-generated (Step 2b)\n254: \n255: Review Target: {config.reviewTarget}\n256: Review Mode: {config.reviewTargetType}\n257: Iteration: {N} of {maxIterations}\n258: Focus Dimension: {strategy.nextFocus.dimension}\n259: Focus Files: {strategy.nextFocus.files}\n260: Remaining Dimensions: {strategy.remainingDimensions}\n261: Traceability Protocols:\n262:   - Core: {core_protocols}\n263:   - Overlay: {overlay_protocols}\n264: Active Findings: {findingsSummary}\n265: State Files:\n266:   - Config: {artifact_dir}/deep-review-config.json\n267:   - State: {artifact_dir}/deep-review-state.jsonl\n268:   - Registry: {artifact_dir}/deep-review-findings-registry.json\n269:   - Strategy: {artifact_dir}/deep-review-strategy.md\n270: Output: Write findings to {artifact_dir}/iterations/iteration-{NNN}.md\n271: CONSTRAINT: LEAF agent -- do NOT dispatch sub-agents\n272: CONSTRAINT: Target files are READ-ONLY -- never modify code under review\n273: ```\n274: \n275: #### Executor Resolution (spec 018 + 019)\n276: \n277: Before dispatching, the YAML resolves the executor via `parseExecutorConfig` from `.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts`. The resolved `config.executor.kind` selects the dispatch branch:\n278: \n279: - `native` (spec 018): dispatch `@deep-review` agent with model Opus.\n280: - `cli-opencode` (spec 018): pipe rendered prompt via stdin to `opencode run --model X --format json --dangerously-skip-permissions --pure --dir {repo_root} [--variant Y]`. **This grants full OS-level workspace write access.** There is no `--sandbox workspace-write` flag in the live command, and `sandboxMode='read-only'` is NOT currently honored/enforced by opencode (no opencode equivalent exists). The only real containment is (a) the prompt-level \"ALLOWED WRITE PATHS\" / \"BANNED OPERATIONS\" contract rendered into the iteration prompt (`assets/prompt_pack_iteration.md.tmpl`), which relies on the model obeying instructions rather than an OS-level sandbox, and (b) post-dispatch validation (`validateIterationOutputs`) catching some violations after the fact. Because review targets are arbitrary code/spec files, they MUST be treated as potentially adversarial content (untrusted) for prompt-injection purposes — the same containment posture as untrusted fetched content in deep-research.\n281: - `cli-claude-code` (spec 019): `claude -p \"$(cat prompt)\" --model X --permission-mode acceptEdits --output-format text` with optional `--effort Y`. Default permission-mode is `plan` (read-only). We override to `acceptEdits` so iteration writes succeed.\n282: \n283: All branches share:\n284: 1. Pre-dispatch prompt rendering via `renderPromptPack` (writes to `{artifact_dir}/prompts/iteration-{n}.md`).\n285: 2. Post-dispatch validation via `validateIterationOutputs` (asserts iteration file + JSONL delta + required fields).\n286: 3. Executor audit append via `appendExecutorAuditToLastRecord` (skipped when kind=='native').\n287: \n288: Per-kind flag-compatibility is enforced at config parse time by `EXECUTOR_KIND_FLAG_SUPPORT` in `executor-config.ts`. Setting a flag that the chosen kind does not support throws `ExecutorConfigError` before dispatch.\n289: \n290: Cross-CLI delegation (a running executor invoking other CLIs via its shell) is documented design intent. Runtime recursion detection is out of scope. See the SKILL.md Cross-CLI Delegation subsection.\n291: \n292: Failure handling remains unchanged from spec 018: `schema_mismatch` → conflict event → 3 consecutive failures → `stuck_recovery`.\n293: \n294: **Agent constraints**:\n295: - `@deep-review` is LEAF-only: it cannot dispatch sub-agents\n296: - No WebFetch: review is code-only and read-only\n297: - Target 8-11 tool calls per iteration (max 12). Breadth over depth per cycle\n298: - Tools available: Read, Grep, Glob, Edit (state files only), code_graph_query + Grep\n299: \n300: #### Step 3a: Cross-Reference Protocol Execution\n301: \n302: During iterations focused on the Traceability dimension, the agent executes applicable cross-reference protocols. Each protocol produces a structured result appended to the JSONL `traceabilityChecks.results[]` array.\n303: \n304: | Protocol | Execution | Expected Output |\n305: |----------|-----------|-----------------|\n306: | `spec_code` | Compare normative claims in spec.md against shipped implementation | Pass/partial/fail per claim with file:line evidence |\n307: | `checklist_evidence` | Verify every `[x]` mark in checklist.md has supporting evidence | Pass/partial/fail per checked item |\n308: | `skill_agent` | Compare SKILL.md contracts against runtime agent definitions | Agreement/drift/disagreement per capability |\n309: | `agent_cross_runtime` | Compare agent definitions across runtimes (.opencode, .claude, .opencode) | Parity/drift/divergence per runtime pair |\n310: | `feature_catalog_code` | Compare catalog claims against discoverable implementation | Match/stale/missing per feature |\n311: | `playbook_capability` | Validate playbook scenarios against executable reality | Executable/needs-update/impossible per scenario |\n312: \n313: Each protocol result includes:\n314: - `protocolId`: Protocol identifier\n315: - `status`: `pass`, `partial`, or `fail`\n316: - `gateClass`: `hard` or `advisory`\n317: - `applicable`: Whether the protocol applies to this target type\n318: - `counts`: `{ pass, partial, fail, skipped }`\n319: - `evidence`: Array of file:line citations\n320: - `findingRefs`: Array of finding IDs generated from this protocol\n321: - `summary`: Human-readable summary text\n322: \n323: #### Step 3b: Resource Map Coverage Audit\n324: \n325: When `config.resource_map_present == true`, at least one loop iteration MUST audit implementation-vs-resource-map coverage:\n326: \n327: 1. Read `{spec_folder}/resource-map.md`\n328: 2. Read applied reports under `{spec_folder}/applied/T-*.md`\n329: 3. Cross-check `target_files` from the applied reports against resource-map entries\n330: 4. Classify outcomes into:\n331:    - entries touched\n332:    - entries not touched (`expected-by-scope` vs `gap`)\n333:    - implementation paths absent from the map\n334: 5. Emit any resulting findings with category `resource-map-coverage`\n335: \n336: When `config.resource_map_present == false`, skip this audit and rely on the `Known Context` note: `resource-map.md not present. Skipping coverage gate`.\n337: \n338: #### Step 4: Evaluate Results\n339: \n340: After agent completes:\n341: \n342: 1. Verify `{artifact_dir}/iterations/iteration-{NNN}.md` was created\n343: 2. Verify JSONL was appended with review iteration fields:\n344:    - `dimensions` (array of dimensions covered)\n345:    - `filesReviewed` (array of file paths)\n346:    - `findingsSummary` (cumulative P0/P1/P2 counts)\n347:    - `findingsNew` (this iteration's new findings)\n348:    - `traceabilityChecks` (protocol results if applicable)\n349: 3. Verify strategy.md was updated (dimension progress, findings count, protocol status)\n350: 4. Extract `newFindingsRatio` from JSONL record\n351: 5. Update stuck tracking using `noProgressThreshold = 0.05`:\n352:    - Skip if `status == \"thought\"` (no change)\n353:    - Reset to 0 if `status == \"insight\"` (breakthrough counts as progress)\n354:    - Increment if `newFindingsRatio < noProgressThreshold`\n355:    - Reset otherwise\n356: \n357: #### Step 4a: Claim Adjudication\n358: \n359: Before the next convergence pass, the orchestrator adjudicates every new P0/P1 finding with a **typed claim-adjudication packet**. This step prevents false positives from inflating severity and distorting convergence, AND acts as a hard STOP gate: `step_post_iteration_claim_adjudication` appends a `claim_adjudication` event to `deep-review-state.jsonl`, and the next iteration's `step_check_convergence` legal-stop decision tree consults that event via `claimAdjudicationGate` (gate `f`). A missing or failing packet vetoes STOP even when every other gate passes.\n360: \n361: Each new P0/P1 must carry a typed packet with the following required fields (see `../state/state_format.md` §9 for the full schema and a worked example):\n362: \n363: | Field | Type | Description |\n364: |-------|------|-------------|\n365: | `findingId` | string | Matches the finding ID in the iteration body |\n366: | `claim` | string | The single assertion the finding makes |\n367: | `evidenceRefs` | string[] | `file:line` or `file:range` citations (≥ 1) |\n368: | `counterevidenceSought` | string | Where the orchestrator looked for contradicting evidence |\n369: | `alternativeExplanation` | string | An alternative explanation, even if rejected |\n370: | `finalSeverity` | `\"P0\"` \\| `\"P1\"` \\| `\"P2\"` | Severity after adjudication |\n371: | `confidence` | number `[0, 1]` | Orchestrator confidence in `finalSeverity` |\n372: | `downgradeTrigger` | string | Concrete condition that would cause a future downgrade |\n373: | `transitions` | object[] | Optional, required when `finalSeverity` differs from the originally asserted severity |\n374: \n375: **Protocol**:\n376: \n377: 1. Re-read the cited evidence at the referenced file:line locations.\n378: 2. Seek counterevidence in adjacent code, docs, or prior iteration history.\n379: 3. Record an alternative explanation even if it is rejected.\n380: 4. Confirm or downgrade severity before the finding becomes convergence-visible.\n381: 5. Emit the typed packet inside the iteration file so `step_post_iteration_claim_adjudication` can parse it.\n382: \n383: **Failure semantics**: when any new P0/P1 finding is missing a packet or a required field, the workflow records `{\"event\":\"claim_adjudication\",\"passed\":false,\"missingPackets\":[...]}` in `deep-review-state.jsonl`. On the next loop, `step_check_convergence` step 0 (universal pre-check) routes STOP to `BLOCKED` with `blockedBy: [\"claimAdjudicationGate\"]` until a follow-up iteration rewrites the packet. Downgraded findings have their `finalSeverity` updated. The original severity is preserved in the iteration file for audit trail.\n384: \n385: #### Step 4b: Generate Dashboard\n386: \n387: Generate `{artifact_dir}/deep-review-dashboard.md` with review-specific sections:\n388: \n389: | Section | Content |\n390: |---------|---------|\n391: | Status | Provisional verdict (`PASS`/`CONDITIONAL`/`FAIL`/`PENDING`) and `hasAdvisories` flag |\n392: | Findings Summary | P0/P1/P2 counts with deltas from previous iteration |\n393: | Progress Table | Iteration number, focus dimension, `newFindingsRatio`, findings count, status |\n394: | Coverage | Files reviewed, dimensions completed, traceability protocol status |\n395: | Trend | Last 3 `newFindingsRatio` values with direction indicator (ascending/descending/flat) |\n396: | Active Risks | Guard violations, stuck count, budget warnings |\n397: \n398: Dashboard behavior:\n399: - Auto-generated only -- never manually edited\n400: - Overwritten each iteration (not appended)\n401: - Non-blocking: if generation fails, log a warning and continue the loop\n402: - In **confirm mode**: displayed to the user at each iteration approval gate\n403: - In **auto mode**: written silently for post-hoc review\n404: \n405: #### Step 5: Loop Decision\n406: \n407: - If convergence check returns STOP: exit to synthesis\n408: - If STUCK_RECOVERY: apply review-specific recovery strategies (see Section 3a), reset stuck count, continue\n409: - Otherwise: increment iteration counter, go to Step 1\n410: \n411: ### Stuck Recovery (Review-Specific)\n412: \n413: **Threshold:** 2 consecutive no-progress iterations (`noProgressThreshold = 0.05`).\n414: \n415: | Failure Mode | Detection | Recovery Strategy |\n416: |-------------|-----------|-------------------|\n417: | Same dimension stuck | Last 2 iterations reviewed the same dimension with ratios `< 0.05` | **Change granularity**: if reviewing at file level, zoom into functions, if reviewing functions, zoom out to module level |\n418: | Traceability plateau | Required protocols remain partial while ratios stay `< 0.05` | **Protocol-first replay**: re-run the unresolved traceability protocol directly against the conflicting artifacts |\n419: | Low-value advisory churn | Last 2 iterations found only P2 work | **Escalate severity review**: explicitly search for P0/P1 patterns or downgrade unsupported severity claims |\n420: \n421: **Selection logic**:\n422: \n423: ```\n424: function selectReviewRecoveryStrategy(stuckIterations, state, config):\n425:   lastFocuses = [i.focus for i in stuckIterations[-2:]]\n426: \n427:   // Same dimension stuck? Change granularity\n428:   if len(set(lastFocuses)) <= 1:\n429:     return { strategy: \"change_granularity\", dimension: lastFocuses[0] }\n430: \n431:   // Required protocol plateau?\n432:   if hasRequiredProtocolPlateau(state.traceabilityChecks):\n433:     return { strategy: \"protocol_first_replay\" }\n434: \n435:   // Default: escalate severity\n436:   return { strategy: \"escalate_severity_review\" }\n437: ```\n438: \n439: **Recovery evaluation**:\n440: - If recovery iteration finds any new P0/P1 or materially advances required traceability coverage: recovery successful. Reset stuck count. Continue.\n441: - If recovery iteration finds only P2 or nothing: recovery failed. If all dimensions are already covered, exit to synthesis. Otherwise, move to the next unreviewed dimension.\n442: \n443: ---\n444: \n445: ## 4. PHASE 3: SYNTHESIS\n446: \n447: ### Purpose\n448: \n449: Compile all iteration findings into the final `{artifact_dir}/review-report.md`. The synthesis phase owns the canonical review report output.\n450: \n451: ### Steps\n452: \n453: #### Step 1: Finding Registry Deduplication\n454: \n455: Consolidate findings across all iterations:\n456: \n457: 1. Read all iteration files: `{artifact_dir}/iterations/iteration-*.md`\n458: 2. Group findings by file + line range + root cause\n459: 3. Merge duplicates, keeping the highest severity and all evidence\n460: 4. Assign final finding IDs: `F001`, `F002`, ...\n461: 5. Preserve the audit trail: note which iterations contributed to each merged finding\n462: \n463: #### Step 2: Severity Reconciliation\n464: \n465: Use adjudicated `finalSeverity` for any P0/P1 that was downgraded during claim adjudication (Step 4a of the iteration loop). The original severity from the iteration file is preserved in the audit appendix.\n466: \n467: #### Step 3: Replay Validation\n468: \n469: Recompute the convergence outcome from JSONL state before finalizing the report:\n470: \n471: 1. Read `deep-review-state.jsonl` and select review-mode iteration records in run order\n472: 2. Recompute `newFindingsRatio`, rolling-average votes, MAD votes, and coverage votes from stored JSONL fields only\n473: 3. Recompute `traceabilityChecks.summary` and confirm required protocol statuses match the recorded coverage vote\n474: 4. Re-run the evidence, scope, and coverage gates against stored findings and scope data\n475: 5. Compare the replayed decision and stop reason to the recorded synthesis event\n476: \n477: This synthesis-stage replay is a **full-history audit replay** over the stored JSONL state. It follows the same full-history replay discipline as the per-iteration reducer refresh above, but runs as an explicit pre-synthesis audit.\n478: \n479: Replay passes only when the recomputed decision, thresholds, and gate outcomes agree with the persisted result. If replay fails, log a warning in the audit appendix but proceed with synthesis.\n480: \n481: #### Step 4: Compile review-report.md\n482: \n483: Generate the 9 core review-report sections (defined in `review_mode_contract.yaml` under `outputs.reviewReport`) and insert `## Resource Map Coverage Gate` between `Traceability Status` and `Deferred Items` when `config.resource_map_present == true`:\n484: \n485: | # | Section | Purpose |\n486: |---|---------|---------|\n487: | 1 | Executive Summary | Verdict, active P0/P1/P2 counts, scope, `hasAdvisories` metadata |\n488: | 2 | Planning Trigger | Why the verdict routes to planning or changelog follow-up |\n489: | 3 | Active Finding Registry | Deduplicated active findings with evidence and final severity |\n490: | 4 | Remediation Workstreams | Grouped action lanes derived from active findings |\n491: | 5 | Spec Seed | Minimal spec delta derived from review results |\n492: | 6 | Plan Seed | Action-ready plan starter for remediation |\n493: | 7 | Traceability Status | Core vs overlay protocol status and unresolved gaps |\n494: | 8 | Resource Map Coverage Gate | Present only when `config.resource_map_present == true`, reports touched entries, untouched entries (`expected-by-scope` vs `gap`), and implementation paths absent from the map |\n495: | 9 | Deferred Items | P2 advisories, blocked checks, and follow-up items |\n496: | 10 | Audit Appendix | Coverage, replay validation, convergence evidence |\n497: \n498: #### Step 5: Verdict Determination\n499: \n500: Apply the verdict contract from `review_mode_contract.yaml`:\n501: \n502: | Verdict | Condition | Next Command |\n503: |---------|-----------|--------------|\n504: | **FAIL** | Active P0 remains OR any required binary gate fails | `/speckit:plan` for remediation |\n505: | **CONDITIONAL** | No active P0, but active P1 remains | `/speckit:plan` for fixes |\n506: | **PASS** | No active P0/P1 | `/create:changelog` |\n507: \n508: When `PASS` verdict is issued and active P2 findings remain, set `hasAdvisories = true` in the report metadata.\n509: \n510: #### Step 6: Finalize State\n511: \n512: 1. Update config status: Set `status: \"complete\"` in `deep-review-config.json`\n513: 2. Write final JSONL entry:\n514:    ```json\n515:    {\n516:      \"type\": \"event\",\n517:      \"event\": \"synthesis_complete\",\n518:      \"mode\": \"review\",\n519:      \"totalIterations\": N,\n520:      \"verdict\": \"PASS|CONDITIONAL|FAIL\",\n521:      \"activeP0\": N,\n522:      \"activeP1\": N,\n523:      \"activeP2\": N,\n524:      \"dimensionCoverage\": X,\n525:      \"stopReason\": \"...\",\n526:      \"timestamp\": \"...\"\n527:    }\n528:    ```\n529: \n530: ---\n531: \n532: ## 5. PHASE 4: SAVE\n533: \n534: ### Purpose\n535: \n536: Preserve review context to the memory system for future session recovery and cross-session continuity.\n537: \n538: ### Steps\n539: \n540: 1. **Compose context payload**: Create a structured JSON payload with the review summary, active findings, verdict, next action, and relevant artifacts. Use `specFolder` for the target packet and include curated `observations`, `recent_context`, `toolCalls`, and `exchanges` when available.\n541: \n542: 2. **Generate context**: Run the memory save script with structured JSON via `--stdin`, `--json`, or a session-scoped JSON file:\n543:    ```bash\n544:    node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --json '{\"specFolder\":\"{spec_folder}\",\"sessionSummary\":\"Deep review completed; see review/review-report.md for verdict and findings.\"}' {spec_folder}\n545:    ```\n546: \n547: 3. **No extra indexing step in the live contract**: `generate-context.js` is the supported save boundary for this workflow.\n548: \n549: 4. **Verify**: Confirm the routed canonical spec document carries the review continuity update. Expected targets are `implementation-summary.md`, `decision-record.md`, or `handover.md`; standalone `memory/*.md` files are retired and should not be created.\n550: \n551: ### On Save Failure\n552: \n553: If memory save fails:\n554: - Preserve the current `review/` packet as backup (the disk state is the ground truth)\n555: - Log the error\n556: - The review results remain intact in `{artifact_dir}/review-report.md` regardless of memory save status\n557: \n558: ---\n559: \n560: ## 6. AUTO-RESUME PROTOCOL\n561: \n562: ### Purpose\n563: \n564: Enable review sessions to resume cleanly from prior state when interrupted by context compaction, process termination, or intentional pause.\n565: \n566: ### Resume Detection\n567: \n568: If state files already exist from a prior session:\n569: \n570: 1. **Verify agreement**: Confirm config, JSONL, findings registry, and strategy all exist and agree on target/spec folder\n571: 2. **Count progress**: Read JSONL, count iteration records, determine last completed iteration\n572: 3. **Read strategy**: Load current dimension progress, findings, and next focus from `deep-review-strategy.md`\n573: 4. **Set counter**: Set iteration counter to last completed + 1\n574: 5. **Log resume**: Append the canonical resume event to `deep-review-state.jsonl`. The reducer requires every field below:\n575:    ```json\n576:    {\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"rvw-2026-03-24T10-00-00Z\",\"parentSessionId\":\"rvw-2026-03-24T10-00-00Z\",\"lineageMode\":\"resume\",\"continuedFromRun\":4,\"generation\":1,\"archivedPath\":null,\"timestamp\":\"2026-03-24T14:05:00Z\"}\n577:    ```\n578: 6. **Continue**: Enter the iteration loop from step_read_state\n579: \n580: ### Lifecycle Branches (current release)\n581: \n582: The runtime supports three lineage modes today. `fork` and `completed-continue` were described in earlier drafts but have no workflow wiring in this release, so they MUST NOT be exposed to operators. If the long-form lineage feature is picked up later it will arrive with first-class event emission, reducer ancestry handling, and replay fixtures. Until then treat the contract below as canonical.\n583: \n584: | Mode | Session id | Generation | Archive | JSONL event | When to pick |\n585: |------|-----------|-----------|---------|-------------|--------------|\n586: | `new` | fresh | 1 | n/a | implicit (config record) | no existing state |\n587: | `resume` | same | same | none | `resumed` (see example above) | operator wants to continue the current lineage boundary |\n588: | `restart` | fresh | `prior + 1` | prior `review/` tree moved under `review_archive/{timestamp}/` | `restarted` (same field set plus non-null `archivedPath`) | operator wants to clear the workspace and replay with a new angle |\n589: \n590: **Contract for every persisted lifecycle event**:\n591: \n592: ```json\n593: {\n594:   \"type\": \"event\",\n595:   \"event\": \"resumed | restarted\",\n596:   \"mode\": \"review\",\n597:   \"sessionId\": \"<session id of the new or continuing lineage>\",\n598:   \"parentSessionId\": \"<session id of the prior lineage (equals sessionId on resume)>\",\n599:   \"lineageMode\": \"resume | restart\",\n600:   \"generation\": <number>,\n601:   \"continuedFromRun\": <number or null>,\n602:   \"archivedPath\": \"<path or null>\",\n603:   \"timestamp\": \"<ISO 8601>\"\n604: }\n605: ```\n606: \n607: Every field in the contract MUST be present on every persisted lifecycle event. `archivedPath` is null for `resumed` and set to the archive destination for `restarted`. `continuedFromRun` is the number of completed iteration records before the lifecycle boundary. Reducer parity tests ensure the dashboard `Lifecycle` section reads exactly those fields.\n608: \n609: ### State Validation on Resume\n610: \n611: | Condition | Classification | Action |\n612: |-----------|---------------|--------|\n613: | Config + JSONL + strategy all exist and agree | `resume` | Continue from last iteration + 1 |\n614: | All exist, config says `status: \"complete\"` | `completed-session` | Report completion, ask user if re-review desired |\n615: | Partial files or contradictions | `invalid-state` | Halt for repair, do not guess |\n616: | No files exist | `fresh` | Start new initialization |\n617: \n618: ### State Recovery Cascade\n619: \n620: When state files are missing or corrupted, apply this priority cascade:\n621: \n622: | Priority | Condition | Recovery Action |\n623: |----------|-----------|----------------|\n624: | 1 | JSONL exists and parseable | Normal operation |\n625: | 2 | JSONL exists, strategy.md missing | Reconstruct strategy from JSONL: extract dimensions, findings, coverage |\n626: | 3 | JSONL missing, iteration files exist | Scan `review/iterations/iteration-*.md`, reconstruct JSONL with `status: \"reconstructed\"` |\n627: | 4 | Only config.json remains | Restart from initialization phase |\n628: | 5 | Config.json also missing | Cannot recover. Report error and halt. |\n629: \n630: Each priority level is attempted in order. If a level fails, fall through to the next.\n631: \n632: ---\n633: \n634: ## 7. PAUSE/RESUME\n635: \n636: ### Pause Sentinel Behavior\n637: \n638: The pause sentinel provides graceful loop suspension in autonomous mode without killing the process.\n639: \n640: ### Creating a Pause\n641: \n642: Create the sentinel file at any time:\n643: \n644: ```bash\n645: touch {artifact_dir}/.deep-review-pause\n646: ```\n647: \n648: The orchestrator checks for this file between iterations (Step 2a). When detected:\n649: - The current iteration is allowed to complete\n650: - The loop halts before dispatching the next iteration\n651: - A paused event is logged to JSONL\n652: - The user is notified with current state (iteration count, dimensions covered, findings)\n653: \n654: ### Resuming After Pause\n655: \n656: Delete the sentinel file and restart the workflow:\n657: \n658: ```bash\n659: rm {artifact_dir}/.deep-review-pause\n660: ```\n661: \n662: On the next invocation:\n663: - The auto-resume protocol (Section 6) detects the existing state\n664: - A resumed event is logged to JSONL\n665: - The loop continues from the next iteration\n666: \n667: ### Confirm Mode Approval Gates\n668: \n669: In confirm mode (`deep_review_confirm.yaml`), the workflow adds explicit approval gates instead of relying on the pause sentinel:\n670: \n671: | Gate Location | Behavior |\n672: |---------------|----------|\n673: | After initialization | Show config, strategy, and scope. Wait for approval |\n674: | After each iteration | Show iteration findings, dashboard, and convergence status. Options: Continue, Adjust Focus, Stop |\n675: | Before synthesis | Show summary of all iterations. Wait for approval to synthesize |\n676: | After synthesis | Show final review-report.md summary. Approve or request revisions |\n677: \n678: ---\n679: \n680: ## 8. STATE TRANSITIONS, ERROR HANDLING, AND QUALITY GATES\n681: \n682: State-transition rules, error handling, and the review quality gates live in `loop_state_and_gates.md` for navigability.\n683: \n684: ---\n685: \n686: ## 11. RELATED RESOURCES\n687: \n688: ### Shared Protocol Documentation\n689: \n690: Protocol documents from `deep-research` are cross-referenced, not duplicated:\n691: \n692: | Document | Path | Purpose |\n693: |----------|------|---------|\n694: | Loop Protocol (research) | `../deep-research/references/protocol/loop_protocol.md` | Research loop lifecycle (this file adapts Section 9) |\n695: | State Format | `../deep-research/references/state/state_format.md` | JSONL, strategy, and config schemas |\n696: | Convergence | `../deep-research/references/convergence/convergence.md` | `shouldContinue_review()` (Section 10), stuck recovery, quality guards |\n697: \n698: ### Review-Specific Resources\n699: \n700: | Resource | Path | Purpose |\n701: |----------|------|---------|\n702: | Review Contract | `assets/review_mode_contract.yaml` | Single source of truth for dimensions, verdicts, gates, protocols |\n703: | Quick Reference | `references/protocol/quick_reference.md` | One-page review cheat sheet |\n704: | Strategy Template | `assets/deep_review_strategy.md` | Template for review strategy files |\n705: | Config Template | `assets/deep_review_config.json` | Template for review config files |\n706: | Dashboard Template | `assets/deep_review_dashboard.md` | Template for auto-generated dashboard |\n707: \n708: ### Workflow Files\n709: \n710: | Mode | Path |\n711: |------|------|\n712: | Auto (unattended) | `.opencode/commands/deep/assets/deep_review_auto.yaml` |\n713: | Confirm (step-by-step) | `.opencode/commands/deep/assets/deep_review_confirm.yaml` |\n714: \n715: ### Agent\n716: \n717: | Agent | Path Pattern | Constraint |\n718: |-------|-------------|------------|\n719: | `@deep-review` | `{runtime_dir}/deep-review.{ext}` | LEAF-only, no sub-agents, no WebFetch, target files read-only |\n720: \n721: Runtime paths:\n722: - OpenCode / Copilot: `.opencode/agents/deep-review.md`\n723: - Claude: `.claude/agents/deep-review.md`\n724: \n725: ---\n726: \n727: ## Executor Selection Contract\n728: \n729: Executor settings are owned by the YAML workflow and rendered prompt pack. Do not bypass the workflow by hand-dispatching review iterations; each iteration stays LEAF-only and produces the required markdown plus JSONL delta.\n730: \n731: ### Invariants\n732: \n733: Every executor path MUST satisfy:\n734: \n735: 1. Produce an iteration markdown file at `{state_paths.iteration_pattern}` (non-empty).\n736: 2. Append a JSONL delta record to `{state_paths.state_log}` with required fields: `type`, `iteration`, `dimensions`, `filesReviewed`, `findingsSummary`, `findingsNew`, `findingDetails`, `newFindingsRatio`.\n737: 3. Respect the LEAF-agent constraint: no sub-dispatch, no nested loops. Max 12 tool calls per iteration.\n738: \n739: ### Failure Modes\n740: \n741: - Missing iteration file: `iteration_file_missing` from `post-dispatch-validate.ts`, emits a `schema_mismatch` conflict event.\n742: - Empty iteration file: `iteration_file_empty`, same downstream.\n743: - JSONL not appended: `jsonl_not_appended`.\n744: - JSONL missing required fields: `jsonl_missing_fields`.\n745: - JSONL malformed: `jsonl_parse_error`.\n746: - 3 consecutive failures: existing `stuck_recovery` event (unchanged).\n747: \n748: ### JSONL Audit Field\n749: \n750: Non-native executor runs append an `executor` block with model and runtime settings to the iteration's JSONL record via `executor-audit.ts`. Native runs are recoverable from YAML alone.\n751: \n752: ### Template And Config Surface\n753: \n754: The executor-agnostic iteration prompt lives at `assets/prompt_pack_iteration.md.tmpl`, rendered by `prompt-pack.ts` before dispatch and either injected as the agent's context (native) or piped to `opencode run` stdin (cli-opencode). Config is in `assets/deep_review_config.json` under the `executor` key; schema in `runtime//lib/deep-loop/executor-config.ts`. CLI flag precedence: `--executor/--model/--reasoning-effort/--service-tier/--executor-timeout > config file > schema default`.\n755: \n756: ### What Never Changes Regardless Of Executor Route\n757: \n758: - YAML owns state (`deep-review-state.jsonl`, strategy.md, registry, dashboard).\n759: - `reduce-state.cjs` is the single state writer.\n760: - Convergence detection, lifecycle events (new/resume/restart), the review dimensions pass, and stuck_recovery stay YAML-driven.\n761: - The `@deep-review` LEAF agent definition is untouched: it is the native executor, not the only one.\n762: \n763: ### Code-Graph Readiness TrustState Surface\n764: \n765: On this skill surface, the live code-graph readiness contract only reaches four TrustState values: `live`, `stale`, `absent`, and `unavailable`. The values `cached`, `imported`, `rebuilt`, and `rehomed` remain declared in the shared TrustState type for compatibility and downstream schema stability, but the seven code-graph handlers and readiness helpers used here do not emit them today.\n\n(End of file - total 765 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Loop Protocol\ndescription: Complete lifecycle specification for the autonomous deep review loop, initialization, iteration, convergence, synthesis, and save phases.\ntrigger_phrases:\n  - \"deep review loop protocol\"\n  - \"review iteration lifecycle\"\n  - \"review loop initialization\"\n  - \"review auto resume\"\n  - \"review synthesis phase\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.29\n---\n\n# Deep Review Loop Protocol\n\nComplete lifecycle specification for the autonomous deep review loop.\n\n---\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md","text":"---\ntitle: Deep Review Loop Protocol\ndescription: Complete lifecycle specification for the autonomous deep review loop, initialization, iteration, convergence, synthesis, and save phases.\ntrigger_phrases:\n  - \"deep review loop protocol\"\n  - \"review iteration lifecycle\"\n  - \"review loop initialization\"\n  - \"review auto resume\"\n  - \"review synthesis phase\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.11.0.29\n---\n\n# Deep Review Loop Protocol\n\nComplete lifecycle specification for the autonomous deep review loop.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nThe deep review loop has 4 phases: initialization, iteration (repeated), synthesis, and save. The YAML workflow manages the lifecycle. The `@deep-review` agent (LEAF-only, no WebFetch) executes individual review iterations with fresh context each time.\n\n### When to Use\n\n- Initiating a deep-review loop on a spec folder, skill, agent, or track.\n- Resuming a paused or interrupted review session from prior state.\n- Validating the 4-phase lifecycle and lineage protocol against current behavior.\n- Auditing iteration-dispatch, convergence, or save-phase contracts before changes.\n\n```\n┌──────────────┐     ┌───────────────────────────────┐     ┌───────────────┐     ┌──────────┐\n│  INIT        │────>│  LOOP                         │────>│  SYNTHESIS    │────>│  SAVE    │\n│              │     │  ┌─────────────────────────┐  │     │               │     │          │\n│ Scope        │     │  │ Read State              │  │     │ Finding       │     │ Memory   │\n│ Discovery    │     │  │ Check Convergence       │  │     │ Registry      │     │ Context  │\n│ Dimension    │     │  │ Check Pause Sentinel    │  │     │ Dedup         │     │ Save     │\n│ Ordering     │     │  │ Generate State Summary  │  │     │               │     │          │\n│ Traceability │     │  │ Dispatch @deep-review   │  │     │ Severity      │     │          │\n│ Planning     │     │  │ Evaluate Results        │  │     │ Reconcile     │     │          │\n│ State Files  │     │  │ Claim Adjudication      │  │     │               │     │          │\n│              │     │  │ Dashboard Generation    │  │     │ Replay        │     │          │\n│              │     │  │ Loop Decision           │  │     │ Validation    │     │          │\n│              │     │  └────────┬────────────────┘  │     │               │     │          │\n│              │     │           │ repeat            │     │ review-report │     │          │\n│              │     │           │                   │     │ (9 core +     │     │          │\n│              │     │           │                   │     │  resource-map)│     │          │\n└──────────────┘     └───────────────────────────────┘     └───────────────┘     └──────────┘\n```\n\n### Core Innovation\n\nEach agent dispatch gets a fresh context window. State continuity comes from files on disk, not in-context memory. This eliminates context degradation in long review sessions where accumulated findings would otherwise bias subsequent dimensions.\n\n### Key References\n\n| Resource | Path | Purpose |\n|----------|------|---------|\n| Review contract | `assets/review_mode_contract.yaml` | Dimensions, verdicts, gates, protocols |\n| Auto workflow | `.opencode/commands/deep/assets/deep_review_auto.yaml` | Unattended review loop |\n| Confirm workflow | `.opencode/commands/deep/assets/deep_review_confirm.yaml` | Step-by-step review with approval gates |\n| Agent | `@deep-review` (LEAF) | Single iteration executor, no sub-agents, no WebFetch |\n| Memory save | `generate-context.js` | Context preservation script |\n\n---\n\n## 2. PHASE 1: INITIALIZATION\n\n### Purpose\n\nSet up all state files for a new review session. Discover the scope, order dimensions by risk priority, establish the traceability protocol plan, and create the review state packet.\n\n### Steps\n\n1. **Classify session state before writing**:\n   - `fresh`: no config/state/strategy files exist\n   - `resume`: config + state + strategy all exist and agree\n   - `completed-session`: consistent prior state with `config.status == \"complete\"`\n   - `invalid-state`: partial or contradictory artifacts\n\n2. **Resolve local artifact owner**: `artifact_dir = resolveArtifactRoot(specFolder, 'review').artifactDir`, then `mkdir -p {artifact_dir}/iterations`\n\n3. **Scope discovery**: Resolve the review target into a concrete file list using one of 5 target types:\n\n   | Target Type | CLI Value | Resolution Strategy |\n   |-------------|-----------|---------------------|\n   | **Spec Folder** | `spec-folder` | Read `spec.md`, `plan.md`, implementation files listed in `tasks.md` |\n   | **Skill** | `skill` | Read `SKILL.md`, `references/`, `assets/`, `scripts/`, find agent definitions and command entry points |\n   | **Agent** | `agent` | Find agent definitions across all runtimes, compare for consistency |\n   | **Track** | `track` | List all child spec folders under the track, read `spec.md` + `checklist.md` for each |\n   | **Files** | `files` | Expand glob patterns, validate existence, discover cross-references |\n\n   Store the resolved file list in strategy.md \"Files Under Review\".\n\n4. **Dimension ordering**: Order the 4 review dimensions for iteration based on risk priority:\n\n   | Priority | Dimension | Rationale |\n   |----------|-----------|-----------|\n   | 1 | Correctness | Logic errors have the highest blast radius |\n   | 2 | Security | Vulnerabilities require immediate attention |\n   | 3 | Traceability | Spec/code alignment ensures completeness |\n   | 4 | Maintainability | Patterns and documentation quality (lowest immediate risk) |\n\n   Default order: D1 Correctness, D2 Security, D3 Traceability, D4 Maintainability. This order is configurable but the default prioritizes highest-impact dimensions first.\n\n5. **Traceability protocol planning**: Partition the 6 cross-reference protocols into core vs overlay, and schedule only applicable overlays for the target type:\n\n   | Level | Protocol | Applies To | Gate Class | Purpose |\n   |-------|----------|------------|------------|---------|\n   | Core | `spec_code` | all targets | hard | Verify normative claims resolve to shipped behavior |\n   | Core | `checklist_evidence` | all targets | hard | Verify checked completion claims have evidence |\n   | Overlay | `skill_agent` | skill | advisory | Verify SKILL.md and runtime agents agree |\n   | Overlay | `agent_cross_runtime` | agent | advisory | Verify runtime agent parity |\n   | Overlay | `feature_catalog_code` | skill, spec-folder, track, files | advisory | Verify catalog claims match capability |\n   | Overlay | `playbook_capability` | skill, agent, spec-folder | advisory | Verify playbook scenarios match executable reality |\n\n   Only schedule overlay protocols that apply to the resolved target type.\n\n6. **Write config**: `{artifact_dir}/deep-review-config.json` with `mode: \"review\"`, lineage metadata (`sessionId`, `parentSessionId`, `lineageMode`, `generation`, `continuedFromRun`, `releaseReadinessState`), and review-specific fields including target, target type, dimensions, protocol plan, and release-readiness state.\n\n7. **Initialize state log**: First line of `{artifact_dir}/deep-review-state.jsonl` with config record including `mode: \"review\"` and the lineage fields.\n\n8. **Initialize reducer state**: Create `{artifact_dir}/deep-review-findings-registry.json` with empty `openFindings`, `resolvedFindings`, `repeatedFindings`, `dimensionCoverage`, `findingsBySeverity`, and `convergenceScore`.\n\n9. **Initialize strategy**: `{artifact_dir}/deep-review-strategy.md` from review template with:\n   - Topic (review target description)\n   - Review Dimensions checklist\n   - Files Under Review table\n   - Cross-Reference Status table grouped by core vs overlay\n   - Known Context from `memory_context()` results (if any)\n   - Resource-map snapshot when `{spec_folder}/resource-map.md` exists at init\n   - `resource-map.md not present. Skipping coverage gate` when it does not\n   - Review Boundaries from config\n9a. **Initialize resource-map coverage state**:\n   - If `{spec_folder}/resource-map.md` exists at init: set `resource_map_present = true`, add `Resource Map Coverage` to the Review Charter, and persist a concise map summary in `Known Context`\n   - If absent: set `resource_map_present = false`, record the skip note in `Known Context`, and continue without failing\n\n10. **Validate review charter**:\n   - Verify strategy.md contains Non-Goals and Stop Conditions sections (may be empty but must exist)\n   - In **confirm mode**: present the charter (target, dimensions, scope, non-goals) for user review before proceeding\n   - In **auto mode**: accept automatically and continue\n\n11. **Resume only if config, JSONL, strategy, and findings registry agree**. Otherwise halt for repair instead of guessing.\n\n### Outputs\n\n| File | Location | Purpose |\n|------|----------|---------|\n| Config | `{artifact_dir}/deep-review-config.json` | Review parameters (immutable after init) |\n| State | `{artifact_dir}/deep-review-state.jsonl` | Iteration log (1 initial line) |\n| Registry | `{artifact_dir}/deep-review-findings-registry.json` | Reducer-owned findings state |\n| Strategy | `{artifact_dir}/deep-review-strategy.md` | Dimensions, findings, next focus |\n\n---\n\n## 3. PHASE 2: ITERATION LOOP\n\n### Loop Steps (repeated until convergence)\n\n#### Step 1: Read State\n\n- Read `deep-review-state.jsonl` -- count iterations, extract `newFindingsRatio`, `findingsSummary`, `findingsNew`, `traceabilityChecks`, and lineage data\n- Read `deep-review-findings-registry.json` -- extract `dimensionsCovered`, `findingsBySeverity`, `openFindings`, `resolvedFindings`, and `convergenceScore`\n- Read `{artifact_dir}/deep-review-strategy.md` -- get next focus dimension/files, remaining dimensions, and protocol gaps\n\nReducer contract for every loop refresh:\n\n| Reducer Part | Canonical Value | Notes |\n|--------------|-----------------|-------|\n| Inputs | `fullJSONLHistory`, `iterationFiles`, `priorReducedState` | Normal loop refresh is full-history: replay the persisted JSONL state and current iteration corpus each refresh so reducer output stays deterministic across restart, compaction, and synthesis audit paths. |\n| Outputs | `findingsRegistry`, `dashboardMetrics`, `strategyUpdates` | The same refresh pass updates the canonical registry, refreshes dashboard metrics, and applies strategy updates. |\n| Metrics | `dimensionsCovered`, `findingsBySeverity`, `openFindings`, `resolvedFindings`, `convergenceScore` | These metrics drive convergence decisions, dashboard summaries, and synthesis readiness. |\n\n#### Step 2: Check Convergence\n\nRun `shouldContinue_review()` (see `../deep-research/references/convergence/convergence.md` Section 10.3):\n\n- Max iterations reached? `STOP`\n- Stuck count `>= 2` using `noProgressThreshold = 0.05`? `STUCK_RECOVERY`\n- Composite convergence votes `STOP` only after:\n  - Rolling average uses `rollingStopThreshold = 0.08`\n  - Dimension coverage reaches 100% across the 4-dimension model\n  - Coverage has aged through `minStabilizationPasses >= 1`\n  - Required traceability protocols are covered\n  - Evidence, scope, and coverage gates pass\n- Otherwise: `CONTINUE`\n\nIf convergence math or a hard-stop candidate points to STOP, the workflow must run the review legal-stop decision tree before actually stopping. That decision tree records nine review-specific gates: `convergenceGate`, `dimensionCoverageGate`, `p0ResolutionGate`, `evidenceDensityGate`, `hotspotSaturationGate`, `claimAdjudicationGate`, `fixCompletenessReplayGate`, `candidateCoverageGate`, and `graphlessFallbackGate` (see `../convergence/convergence.md` §Section-1 blocked_stop event example for the authoritative shape). The Step 4a claim-adjudication path treats `claimAdjudicationGate` as a hard STOP gate, so the count covers both the convergence decision tree and the adjudication enforcement path. `candidateCoverageGate` and `graphlessFallbackGate` are v2-rollout gates that pass trivially when the review-depth-v2 search path is inactive. If any gate fails, the loop does **not** stop. Instead it emits a first-class `blocked_stop` JSONL event with:\n\n- `blockedBy`: array of the failed review gate names\n- `gateResults`: per-gate pass/fail payloads using the review gate names above\n- `recoveryStrategy`: one-line hint describing the next review action\n\nThe blocked-stop event is append-only evidence that legal-stop blocked the run. The loop then continues with the recovery or next-focus path rather than synthesizing.\n\nConvergence signals and weights:\n\n| Signal | Weight | Description |\n|--------|--------|-------------|\n| Rolling Average | 0.30 | Last 2 severity-weighted `newFindingsRatio` values average below `rollingStopThreshold` |\n| MAD Noise Floor | 0.25 | Latest ratio within noise floor derived from historical ratios |\n| Dimension Coverage | 0.45 | All 4 dimensions plus required traceability protocols covered, with stabilization |\n\n**P0 override**: Any new P0 finding sets `newFindingsRatio >= 0.50`, blocking convergence regardless of composite score.\n\n#### Step 2a: Check Pause Sentinel\n\nBefore dispatching, check for a pause sentinel file:\n\n1. Check if `review/.deep-review-pause` exists (note: the file name uses the shared `-pause` suffix)\n2. If present:\n   - Log event to JSONL: `{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"sentinel file detected\"}`\n   - Halt the loop with message:\n     ```\n     Review paused. Delete review/.deep-review-pause to resume.\n     Current state: Iteration {N}, {reviewed}/{total} dimensions complete, {P0}/{P1}/{P2} findings.\n     ```\n   - Do NOT exit to synthesis -- the loop is suspended, not stopped\n3. On resume (file deleted and loop restarted):\n   - Log event: `{\"type\":\"event\",\"event\":\"resumed\",\"fromIteration\":N}`\n   - Continue from step_read_state\n\n**Use case**: In autonomous mode, this provides the only graceful intervention mechanism short of killing the process. Users can create the sentinel file at any time to pause review between iterations.\n\nNormalization rule: if the runtime first observes a raw `paused` condition or a raw `stuck_recovery` condition, it MUST rewrite the emitted JSONL event names to `userPaused` and `stuckRecovery` before appending them. Persisted review JSONL should never contain raw `paused` or raw `stuck_recovery` rows after emission.\n\n#### Step 2b: Generate State Summary\n\nGenerate a compact state summary (~200 tokens) for injection into the dispatch prompt:\n\n```\nSTATE SUMMARY (auto-generated, review mode):\nIteration: {N} of {max} | Mode: review\nTarget: {config.reviewTarget} ({config.reviewTargetType})\nDimensions: {reviewed}/{total} complete | Next: {nextDimension}\nFindings: P0:{count} P1:{count} P2:{count} active\nTraceability: core={core_status} overlay={overlay_status}\nLast 2 ratios: {ratio_N-1} -> {ratio_N} | Stuck count: {stuck_count}\nProvisional verdict: {PASS|CONDITIONAL|FAIL|PENDING} | hasAdvisories={hasAdvisories}\nNext focus: {strategy.nextFocus}\n```\n\nThis summary is prepended to the dispatch context (Step 3) to ensure the agent has baseline context even if detailed strategy.md reading fails or is incomplete.\n\n#### Step 3: Dispatch Agent\n\nDispatch `@deep-review` with review-specific context:\n\n```\n{state_summary}  // Auto-generated (Step 2b)\n\nReview Target: {config.reviewTarget}\nReview Mode: {config.reviewTargetType}\nIteration: {N} of {maxIterations}\nFocus Dimension: {strategy.nextFocus.dimension}\nFocus Files: {strategy.nextFocus.files}\nRemaining Dimensions: {strategy.remainingDimensions}\nTraceability Protocols:\n  - Core: {core_protocols}\n  - Overlay: {overlay_protocols}\nActive Findings: {findingsSummary}\nState Files:\n  - Config: {artifact_dir}/deep-review-config.json\n  - State: {artifact_dir}/deep-review-state.jsonl\n  - Registry: {artifact_dir}/deep-review-findings-registry.json\n  - Strategy: {artifact_dir}/deep-review-strategy.md\nOutput: Write findings to {artifact_dir}/iterations/iteration-{NNN}.md\nCONSTRAINT: LEAF agent -- do NOT dispatch sub-agents\nCONSTRAINT: Target files are READ-ONLY -- never modify code under review\n```\n\n#### Executor Resolution (spec 018 + 019)\n\nBefore dispatching, the YAML resolves the executor via `parseExecutorConfig` from `.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts`. The resolved `config.executor.kind` selects the dispatch branch:\n\n- `native` (spec 018): dispatch `@deep-review` agent with model Opus.\n- `cli-opencode` (spec 018): pipe rendered prompt via stdin to `opencode run --model X --format json --dangerously-skip-permissions --pure --dir {repo_root} [--variant Y]`. **This grants full OS-level workspace write access.** There is no `--sandbox workspace-write` flag in the live command, and `sandboxMode='read-only'` is NOT currently honored/enforced by opencode (no opencode equivalent exists). The only real containment is (a) the prompt-level \"ALLOWED WRITE PATHS\" / \"BANNED OPERATIONS\" contract rendered into the iteration prompt (`assets/prompt_pack_iteration.md.tmpl`), which relies on the model obeying instructions rather than an OS-level sandbox, and (b) post-dispatch validation (`validateIterationOutputs`) catching some violations after the fact. Because review targets are arbitrary code/spec files, they MUST be treated as potentially adversarial content (untrusted) for prompt-injection purposes — the same containment posture as untrusted fetched content in deep-research.\n- `cli-claude-code` (spec 019): `claude -p \"$(cat prompt)\" --model X --permission-mode acceptEdits --output-format text` with optional `--effort Y`. Default permission-mode is `plan` (read-only). We override to `acceptEdits` so iteration writes succeed.\n\nAll branches share:\n1. Pre-dispatch prompt rendering via `renderPromptPack` (writes to `{artifact_dir}/prompts/iteration-{n}.md`).\n2. Post-dispatch validation via `validateIterationOutputs` (asserts iteration file + JSONL delta + required fields).\n3. Executor audit append via `appendExecutorAuditToLastRecord` (skipped when kind=='native').\n\nPer-kind flag-compatibility is enforced at config parse time by `EXECUTOR_KIND_FLAG_SUPPORT` in `executor-config.ts`. Setting a flag that the chosen kind does not support throws `ExecutorConfigError` before dispatch.\n\nCross-CLI delegation (a running executor invoking other CLIs via its shell) is documented design intent. Runtime recursion detection is out of scope. See the SKILL.md Cross-CLI Delegation subsection.\n\nFailure handling remains unchanged from spec 018: `schema_mismatch` → conflict event → 3 consecutive failures → `stuck_recovery`.\n\n**Agent constraints**:\n- `@deep-review` is LEAF-only: it cannot dispatch sub-agents\n- No WebFetch: review is code-only and read-only\n- Target 8-11 tool calls per iteration (max 12). Breadth over depth per cycle\n- Tools available: Read, Grep, Glob, Edit (state files only), code_graph_query + Grep\n\n#### Step 3a: Cross-Reference Protocol Execution\n\nDuring iterations focused on the Traceability dimension, the agent executes applicable cross-reference protocols. Each protocol produces a structured result appended to the JSONL `traceabilityChecks.results[]` array.\n\n| Protocol | Execution | Expected Output |\n|----------|-----------|-----------------|\n| `spec_code` | Compare normative claims in spec.md against shipped implementation | Pass/partial/fail per claim with file:line evidence |\n| `checklist_evidence` | Verify every `[x]` mark in checklist.md has supporting evidence | Pass/partial/fail per checked item |\n| `skill_agent` | Compare SKILL.md contracts against runtime agent definitions | Agreement/drift/disagreement per capability |\n| `agent_cross_runtime` | Compare agent definitions across runtimes (.opencode, .claude, .opencode) | Parity/drift/divergence per runtime pair |\n| `feature_catalog_code` | Compare catalog claims against discoverable implementation | Match/stale/missing per feature |\n| `playbook_capability` | Validate playbook scenarios against executable reality | Executable/needs-update/impossible per scenario |\n\nEach protocol result includes:\n- `protocolId`: Protocol identifier\n- `status`: `pass`, `partial`, or `fail`\n- `gateClass`: `hard` or `advisory`\n- `applicable`: Whether the protocol applies to this target type\n- `counts`: `{ pass, partial, fail, skipped }`\n- `evidence`: Array of file:line citations\n- `findingRefs`: Array of finding IDs generated from this protocol\n- `summary`: Human-readable summary text\n\n#### Step 3b: Resource Map Coverage Audit\n\nWhen `config.resource_map_present == true`, at least one loop iteration MUST audit implementation-vs-resource-map coverage:\n\n1. Read `{spec_folder}/resource-map.md`\n2. Read applied reports under `{spec_folder}/applied/T-*.md`\n3. Cross-check `target_files` from the applied reports against resource-map entries\n4. Classify outcomes into:\n   - entries touched\n   - entries not touched (`expected-by-scope` vs `gap`)\n   - implementation paths absent from the map\n5. Emit any resulting findings with category `resource-map-coverage`\n\nWhen `config.resource_map_present == false`, skip this audit and rely on the `Known Context` note: `resource-map.md not present. Skipping coverage gate`.\n\n#### Step 4: Evaluate Results\n\nAfter agent completes:\n\n1. Verify `{artifact_dir}/iterations/iteration-{NNN}.md` was created\n2. Verify JSONL was appended with review iteration fields:\n   - `dimensions` (array of dimensions covered)\n   - `filesReviewed` (array of file paths)\n   - `findingsSummary` (cumulative P0/P1/P2 counts)\n   - `findingsNew` (this iteration's new findings)\n   - `traceabilityChecks` (protocol results if applicable)\n3. Verify strategy.md was updated (dimension progress, findings count, protocol status)\n4. Extract `newFindingsRatio` from JSONL record\n5. Update stuck tracking using `noProgressThreshold = 0.05`:\n   - Skip if `status == \"thought\"` (no change)\n   - Reset to 0 if `status == \"insight\"` (breakthrough counts as progress)\n   - Increment if `newFindingsRatio < noProgressThreshold`\n   - Reset otherwise\n\n#### Step 4a: Claim Adjudication\n\nBefore the next convergence pass, the orchestrator adjudicates every new P0/P1 finding with a **typed claim-adjudication packet**. This step prevents false positives from inflating severity and distorting convergence, AND acts as a hard STOP gate: `step_post_iteration_claim_adjudication` appends a `claim_adjudication` event to `deep-review-state.jsonl`, and the next iteration's `step_check_convergence` legal-stop decision tree consults that event via `claimAdjudicationGate` (gate `f`). A missing or failing packet vetoes STOP even when every other gate passes.\n\nEach new P0/P1 must carry a typed packet with the following required fields (see `../state/state_format.md` §9 for the full schema and a worked example):\n\n| Field | Type | Description |\n|-------|------|-------------|\n| `findingId` | string | Matches the finding ID in the iteration body |\n| `claim` | string | The single assertion the finding makes |\n| `evidenceRefs` | string[] | `file:line` or `file:range` citations (≥ 1) |\n| `counterevidenceSought` | string | Where the orchestrator looked for contradicting evidence |\n| `alternativeExplanation` | string | An alternative explanation, even if rejected |\n| `finalSeverity` | `\"P0\"` \\| `\"P1\"` \\| `\"P2\"` | Severity after adjudication |\n| `confidence` | number `[0, 1]` | Orchestrator confidence in `finalSeverity` |\n| `downgradeTrigger` | string | Concrete condition that would cause a future downgrade |\n| `transitions` | object[] | Optional, required when `finalSeverity` differs from the originally asserted severity |\n\n**Protocol**:\n\n1. Re-read the cited evidence at the referenced file:line locations.\n2. Seek counterevidence in adjacent code, docs, or prior iteration history.\n3. Record an alternative explanation even if it is rejected.\n4. Confirm or downgrade severity before the finding becomes convergence-visible.\n5. Emit the typed packet inside the iteration file so `step_post_iteration_claim_adjudication` can parse it.\n\n**Failure semantics**: when any new P0/P1 finding is missing a packet or a required field, the workflow records `{\"event\":\"claim_adjudication\",\"passed\":false,\"missingPackets\":[...]}` in `deep-review-state.jsonl`. On the next loop, `step_check_convergence` step 0 (universal pre-check) routes STOP to `BLOCKED` with `blockedBy: [\"claimAdjudicationGate\"]` until a follow-up iteration rewrites the packet. Downgraded findings have their `finalSeverity` updated. The original severity is preserved in the iteration file for audit trail.\n\n#### Step 4b: Generate Dashboard\n\nGenerate `{artifact_dir}/deep-review-dashboard.md` with review-specific sections:\n\n| Section | Content |\n|---------|---------|\n| Status | Provisional verdict (`PASS`/`CONDITIONAL`/`FAIL`/`PENDING`) and `hasAdvisories` flag |\n| Findings Summary | P0/P1/P2 counts with deltas from previous iteration |\n| Progress Table | Iteration number, focus dimension, `newFindingsRatio`, findings count, status |\n| Coverage | Files reviewed, dimensions completed, traceability protocol status |\n| Trend | Last 3 `newFindingsRatio` values with direction indicator (ascending/descending/flat) |\n| Active Risks | Guard violations, stuck count, budget warnings |\n\nDashboard behavior:\n- Auto-generated only -- never manually edited\n- Overwritten each iteration (not appended)\n- Non-blocking: if generation fails, log a warning and continue the loop\n- In **confirm mode**: displayed to the user at each iteration approval gate\n- In **auto mode**: written silently for post-hoc review\n\n#### Step 5: Loop Decision\n\n- If convergence check returns STOP: exit to synthesis\n- If STUCK_RECOVERY: apply review-specific recovery strategies (see Section 3a), reset stuck count, continue\n- Otherwise: increment iteration counter, go to Step 1\n\n### Stuck Recovery (Review-Specific)\n\n**Threshold:** 2 consecutive no-progress iterations (`noProgressThreshold = 0.05`).\n\n| Failure Mode | Detection | Recovery Strategy |\n|-------------|-----------|-------------------|\n| Same dimension stuck | Last 2 iterations reviewed the same dimension with ratios `< 0.05` | **Change granularity**: if reviewing at file level, zoom into functions, if reviewing functions, zoom out to module level |\n| Traceability plateau | Required protocols remain partial while ratios stay `< 0.05` | **Protocol-first replay**: re-run the unresolved traceability protocol directly against the conflicting artifacts |\n| Low-value advisory churn | Last 2 iterations found only P2 work | **Escalate severity review**: explicitly search for P0/P1 patterns or downgrade unsupported severity claims |\n\n**Selection logic**:\n\n```\nfunction selectReviewRecoveryStrategy(stuckIterations, state, config):\n  lastFocuses = [i.focus for i in stuckIterations[-2:]]\n\n  // Same dimension stuck? Change granularity\n  if len(set(lastFocuses)) <= 1:\n    return { strategy: \"change_granularity\", dimension: lastFocuses[0] }\n\n  // Required protocol plateau?\n  if hasRequiredProtocolPlateau(state.traceabilityChecks):\n    return { strategy: \"protocol_first_replay\" }\n\n  // Default: escalate severity\n  return { strategy: \"escalate_severity_review\" }\n```\n\n**Recovery evaluation**:\n- If recovery iteration finds any new P0/P1 or materially advances required traceability coverage: recovery successful. Reset stuck count. Continue.\n- If recovery iteration finds only P2 or nothing: recovery failed. If all dimensions are already covered, exit to synthesis. Otherwise, move to the next unreviewed dimension.\n\n---\n\n## 4. PHASE 3: SYNTHESIS\n\n### Purpose\n\nCompile all iteration findings into the final `{artifact_dir}/review-report.md`. The synthesis phase owns the canonical review report output.\n\n### Steps\n\n#### Step 1: Finding Registry Deduplication\n\nConsolidate findings across all iterations:\n\n1. Read all iteration files: `{artifact_dir}/iterations/iteration-*.md`\n2. Group findings by file + line range + root cause\n3. Merge duplicates, keeping the highest severity and all evidence\n4. Assign final finding IDs: `F001`, `F002`, ...\n5. Preserve the audit trail: note which iterations contributed to each merged finding\n\n#### Step 2: Severity Reconciliation\n\nUse adjudicated `finalSeverity` for any P0/P1 that was downgraded during claim adjudication (Step 4a of the iteration loop). The original severity from the iteration file is preserved in the audit appendix.\n\n#### Step 3: Replay Validation\n\nRecompute the convergence outcome from JSONL state before finalizing the report:\n\n1. Read `deep-review-state.jsonl` and select review-mode iteration records in run order\n2. Recompute `newFindingsRatio`, rolling-average votes, MAD votes, and coverage votes from stored JSONL fields only\n3. Recompute `traceabilityChecks.summary` and confirm required protocol statuses match the recorded coverage vote\n4. Re-run the evidence, scope, and coverage gates against stored findings and scope data\n5. Compare the replayed decision and stop reason to the recorded synthesis event\n\nThis synthesis-stage replay is a **full-history audit replay** over the stored JSONL state. It follows the same full-history replay discipline as the per-iteration reducer refresh above, but runs as an explicit pre-synthesis audit.\n\nReplay passes only when the recomputed decision, thresholds, and gate outcomes agree with the persisted result. If replay fails, log a warning in the audit appendix but proceed with synthesis.\n\n#### Step 4: Compile review-report.md\n\nGenerate the 9 core review-report sections (defined in `review_mode_contract.yaml` under `outputs.reviewReport`) and insert `## Resource Map Coverage Gate` between `Traceability Status` and `Deferred Items` when `config.resource_map_present == true`:\n\n| # | Section | Purpose |\n|---|---------|---------|\n| 1 | Executive Summary | Verdict, active P0/P1/P2 counts, scope, `hasAdvisories` metadata |\n| 2 | Planning Trigger | Why the verdict routes to planning or changelog follow-up |\n| 3 | Active Finding Registry | Deduplicated active findings with evidence and final severity |\n| 4 | Remediation Workstreams | Grouped action lanes derived from active findings |\n| 5 | Spec Seed | Minimal spec delta derived from review results |\n| 6 | Plan Seed | Action-ready plan starter for remediation |\n| 7 | Traceability Status | Core vs overlay protocol status and unresolved gaps |\n| 8 | Resource Map Coverage Gate | Present only when `config.resource_map_present == true`, reports touched entries, untouched entries (`expected-by-scope` vs `gap`), and implementation paths absent from the map |\n| 9 | Deferred Items | P2 advisories, blocked checks, and follow-up items |\n| 10 | Audit Appendix | Coverage, replay validation, convergence evidence |\n\n#### Step 5: Verdict Determination\n\nApply the verdict contract from `review_mode_contract.yaml`:\n\n| Verdict | Condition | Next Command |\n|---------|-----------|--------------|\n| **FAIL** | Active P0 remains OR any required binary gate fails | `/speckit:plan` for remediation |\n| **CONDITIONAL** | No active P0, but active P1 remains | `/speckit:plan` for fixes |\n| **PASS** | No active P0/P1 | `/create:changelog` |\n\nWhen `PASS` verdict is issued and active P2 findings remain, set `hasAdvisories = true` in the report metadata.\n\n#### Step 6: Finalize State\n\n1. Update config status: Set `status: \"complete\"` in `deep-review-config.json`\n2. Write final JSONL entry:\n   ```json\n   {\n     \"type\": \"event\",\n     \"event\": \"synthesis_complete\",\n     \"mode\": \"review\",\n     \"totalIterations\": N,\n     \"verdict\": \"PASS|CONDITIONAL|FAIL\",\n     \"activeP0\": N,\n     \"activeP1\": N,\n     \"activeP2\": N,\n     \"dimensionCoverage\": X,\n     \"stopReason\": \"...\",\n     \"timestamp\": \"...\"\n   }\n   ```\n\n---\n\n## 5. PHASE 4: SAVE\n\n### Purpose\n\nPreserve review context to the memory system for future session recovery and cross-session continuity.\n\n### Steps\n\n1. **Compose context payload**: Create a structured JSON payload with the review summary, active findings, verdict, next action, and relevant artifacts. Use `specFolder` for the target packet and include curated `observations`, `recent_context`, `toolCalls`, and `exchanges` when available.\n\n2. **Generate context**: Run the memory save script with structured JSON via `--stdin`, `--json`, or a session-scoped JSON file:\n   ```bash\n   node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --json '{\"specFolder\":\"{spec_folder}\",\"sessionSummary\":\"Deep review completed; see review/review-report.md for verdict and findings.\"}' {spec_folder}\n   ```\n\n3. **No extra indexing step in the live contract**: `generate-context.js` is the supported save boundary for this workflow.\n\n4. **Verify**: Confirm the routed canonical spec document carries the review continuity update. Expected targets are `implementation-summary.md`, `decision-record.md`, or `handover.md`; standalone `memory/*.md` files are retired and should not be created.\n\n### On Save Failure\n\nIf memory save fails:\n- Preserve the current `review/` packet as backup (the disk state is the ground truth)\n- Log the error\n- The review results remain intact in `{artifact_dir}/review-report.md` regardless of memory save status\n\n---\n\n## 6. AUTO-RESUME PROTOCOL\n\n### Purpose\n\nEnable review sessions to resume cleanly from prior state when interrupted by context compaction, process termination, or intentional pause.\n\n### Resume Detection\n\nIf state files already exist from a prior session:\n\n1. **Verify agreement**: Confirm config, JSONL, findings registry, and strategy all exist and agree on target/spec folder\n2. **Count progress**: Read JSONL, count iteration records, determine last completed iteration\n3. **Read strategy**: Load current dimension progress, findings, and next focus from `deep-review-strategy.md`\n4. **Set counter**: Set iteration counter to last completed + 1\n5. **Log resume**: Append the canonical resume event to `deep-review-state.jsonl`. The reducer requires every field below:\n   ```json\n   {\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"rvw-2026-03-24T10-00-00Z\",\"parentSessionId\":\"rvw-2026-03-24T10-00-00Z\",\"lineageMode\":\"resume\",\"continuedFromRun\":4,\"generation\":1,\"archivedPath\":null,\"timestamp\":\"2026-03-24T14:05:00Z\"}\n   ```\n6. **Continue**: Enter the iteration loop from step_read_state\n\n### Lifecycle Branches (current release)\n\nThe runtime supports three lineage modes today. `fork` and `completed-continue` were described in earlier drafts but have no workflow wiring in this release, so they MUST NOT be exposed to operators. If the long-form lineage feature is picked up later it will arrive with first-class event emission, reducer ancestry handling, and replay fixtures. Until then treat the contract below as canonical.\n\n| Mode | Session id | Generation | Archive | JSONL event | When to pick |\n|------|-----------|-----------|---------|-------------|--------------|\n| `new` | fresh | 1 | n/a | implicit (config record) | no existing state |\n| `resume` | same | same | none | `resumed` (see example above) | operator wants to continue the current lineage boundary |\n| `restart` | fresh | `prior + 1` | prior `review/` tree moved under `review_archive/{timestamp}/` | `restarted` (same field set plus non-null `archivedPath`) | operator wants to clear the workspace and replay with a new angle |\n\n**Contract for every persisted lifecycle event**:\n\n```json\n{\n  \"type\": \"event\",\n  \"event\": \"resumed | restarted\",\n  \"mode\": \"review\",\n  \"sessionId\": \"<session id of the new or continuing lineage>\",\n  \"parentSessionId\": \"<session id of the prior lineage (equals sessionId on resume)>\",\n  \"lineageMode\": \"resume | restart\",\n  \"generation\": <number>,\n  \"continuedFromRun\": <number or null>,\n  \"archivedPath\": \"<path or null>\",\n  \"timestamp\": \"<ISO 8601>\"\n}\n```\n\nEvery field in the contract MUST be present on every persisted lifecycle event. `archivedPath` is null for `resumed` and set to the archive destination for `restarted`. `continuedFromRun` is the number of completed iteration records before the lifecycle boundary. Reducer parity tests ensure the dashboard `Lifecycle` section reads exactly those fields.\n\n### State Validation on Resume\n\n| Condition | Classification | Action |\n|-----------|---------------|--------|\n| Config + JSONL + strategy all exist and agree | `resume` | Continue from last iteration + 1 |\n| All exist, config says `status: \"complete\"` | `completed-session` | Report completion, ask user if re-review desired |\n| Partial files or contradictions | `invalid-state` | Halt for repair, do not guess |\n| No files exist | `fresh` | Start new initialization |\n\n### State Recovery Cascade\n\nWhen state files are missing or corrupted, apply this priority cascade:\n\n| Priority | Condition | Recovery Action |\n|----------|-----------|----------------|\n| 1 | JSONL exists and parseable | Normal operation |\n| 2 | JSONL exists, strategy.md missing | Reconstruct strategy from JSONL: extract dimensions, findings, coverage |\n| 3 | JSONL missing, iteration files exist | Scan `review/iterations/iteration-*.md`, reconstruct JSONL with `status: \"reconstructed\"` |\n| 4 | Only config.json remains | Restart from initialization phase |\n| 5 | Config.json also missing | Cannot recover. Report error and halt. |\n\nEach priority level is attempted in order. If a level fails, fall through to the next.\n\n---\n\n## 7. PAUSE/RESUME\n\n### Pause Sentinel Behavior\n\nThe pause sentinel provides graceful loop suspension in autonomous mode without killing the process.\n\n### Creating a Pause\n\nCreate the sentinel file at any time:\n\n```bash\ntouch {artifact_dir}/.deep-review-pause\n```\n\nThe orchestrator checks for this file between iterations (Step 2a). When detected:\n- The current iteration is allowed to complete\n- The loop halts before dispatching the next iteration\n- A paused event is logged to JSONL\n- The user is notified with current state (iteration count, dimensions covered, findings)\n\n### Resuming After Pause\n\nDelete the sentinel file and restart the workflow:\n\n```bash\nrm {artifact_dir}/.deep-review-pause\n```\n\nOn the next invocation:\n- The auto-resume protocol (Section 6) detects the existing state\n- A resumed event is logged to JSONL\n- The loop continues from the next iteration\n\n### Confirm Mode Approval Gates\n\nIn confirm mode (`deep_review_confirm.yaml`), the workflow adds explicit approval gates instead of relying on the pause sentinel:\n\n| Gate Location | Behavior |\n|---------------|----------|\n| After initialization | Show config, strategy, and scope. Wait for approval |\n| After each iteration | Show iteration findings, dashboard, and convergence status. Options: Continue, Adjust Focus, Stop |\n| Before synthesis | Show summary of all iterations. Wait for approval to synthesize |\n| After synthesis | Show final review-report.md summary. Approve or request revisions |\n\n---\n\n## 8. STATE TRANSITIONS, ERROR HANDLING, AND QUALITY GATES\n\nState-transition rules, error handling, and the review quality gates live in `loop_state_and_gates.md` for navigability.\n\n---\n\n## 11. RELATED RESOURCES\n\n### Shared Protocol Documentation\n\nProtocol documents from `deep-research` are cross-referenced, not duplicated:\n\n| Document | Path | Purpose |\n|----------|------|---------|\n| Loop Protocol (research) | `../deep-research/references/protocol/loop_protocol.md` | Research loop lifecycle (this file adapts Section 9) |\n| State Format | `../deep-research/references/state/state_format.md` | JSONL, strategy, and config schemas |\n| Convergence | `../deep-research/references/convergence/convergence.md` | `shouldContinue_review()` (Section 10), stuck recovery, quality guards |\n\n### Review-Specific Resources\n\n| Resource | Path | Purpose |\n|----------|------|---------|\n| Review Contract | `assets/review_mode_contract.yaml` | Single source of truth for dimensions, verdicts, gates, protocols |\n| Quick Reference | `references/protocol/quick_reference.md` | One-page review cheat sheet |\n| Strategy Template | `assets/deep_review_strategy.md` | Template for review strategy files |\n| Config Template | `assets/deep_review_config.json` | Template for review config files |\n| Dashboard Template | `assets/deep_review_dashboard.md` | Template for auto-generated dashboard |\n\n### Workflow Files\n\n| Mode | Path |\n|------|------|\n| Auto (unattended) | `.opencode/commands/deep/assets/deep_review_auto.yaml` |\n| Confirm (step-by-step) | `.opencode/commands/deep/assets/deep_review_confirm.yaml` |\n\n### Agent\n\n| Agent | Path Pattern | Constraint |\n|-------|-------------|------------|\n| `@deep-review` | `{runtime_dir}/deep-review.{ext}` | LEAF-only, no sub-agents, no WebFetch, target files read-only |\n\nRuntime paths:\n- OpenCode / Copilot: `.opencode/agents/deep-review.md`\n- Claude: `.claude/agents/deep-review.md`\n\n---\n\n## Executor Selection Contract\n\nExecutor settings are owned by the YAML workflow and rendered prompt pack. Do not bypass the workflow by hand-dispatching review iterations; each iteration stays LEAF-only and produces the required markdown plus JSONL delta.\n\n### Invariants\n\nEvery executor path MUST satisfy:\n\n1. Produce an iteration markdown file at `{state_paths.iteration_pattern}` (non-empty).\n2. Append a JSONL delta record to `{state_paths.state_log}` with required fields: `type`, `iteration`, `dimensions`, `filesReviewed`, `findingsSummary`, `findingsNew`, `findingDetails`, `newFindingsRatio`.\n3. Respect the LEAF-agent constraint: no sub-dispatch, no nested loops. Max 12 tool calls per iteration.\n\n### Failure Modes\n\n- Missing iteration file: `iteration_file_missing` from `post-dispatch-validate.ts`, emits a `schema_mismatch` conflict event.\n- Empty iteration file: `iteration_file_empty`, same downstream.\n- JSONL not appended: `jsonl_not_appended`.\n- JSONL missing required fields: `jsonl_missing_fields`.\n- JSONL malformed: `jsonl_parse_error`.\n- 3 consecutive failures: existing `stuck_recovery` event (unchanged).\n\n### JSONL Audit Field\n\nNon-native executor runs append an `executor` block with model and runtime settings to the iteration's JSONL record via `executor-audit.ts`. Native runs are recoverable from YAML alone.\n\n### Template And Config Surface\n\nThe executor-agnostic iteration prompt lives at `assets/prompt_pack_iteration.md.tmpl`, rendered by `prompt-pack.ts` before dispatch and either injected as the agent's context (native) or piped to `opencode run` stdin (cli-opencode). Config is in `assets/deep_review_config.json` under the `executor` key; schema in `runtime//lib/deep-loop/executor-config.ts`. CLI flag precedence: `--executor/--model/--reasoning-effort/--service-tier/--executor-timeout > config file > schema default`.\n\n### What Never Changes Regardless Of Executor Route\n\n- YAML owns state (`deep-review-state.jsonl`, strategy.md, registry, dashboard).\n- `reduce-state.cjs` is the single state writer.\n- Convergence detection, lifecycle events (new/resume/restart), the review dimensions pass, and stuck_recovery stay YAML-driven.\n- The `@deep-review` LEAF agent definition is untouched: it is the native executor, not the only one.\n\n### Code-Graph Readiness TrustState Surface\n\nOn this skill surface, the live code-graph readiness contract only reaches four TrustState values: `live`, `stale`, `absent`, and `unavailable`. The values `cached`, `imported`, `rebuilt`, and `rehomed` remain declared in the shared TrustState type for compatibility and downstream schema stability, but the seven code-graph handlers and readiness helpers used here do not emit them today.","lineStart":1,"lineEnd":765,"totalLines":765,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/references/protocol/loop_protocol.md","time":{"start":1784210482239,"end":1784210482323}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e43204e8819488d4374a51ab0f57"}},"id":"prt_f6b3b6436001gc2FOc6S51C7PD","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
{"type":"tool_use","timestamp":1784210482339,"sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","part":{"type":"tool","tool":"read","callID":"call_IxioMjFB3YpX2JyackEGISvJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: cli-opencode\n3: description: \"OpenCode CLI orchestrator: external dispatch, in-OpenCode parallel sessions, cross-AI handback with full runtime context.\"\n4: allowed-tools: [Bash, Read, Glob, Grep]\n5: version: 1.3.15.3\n6: hard_rules:\n7:   - id: stdin-redirect-required\n8:     check: stdin-redirect-required\n9:     message: \"Ad-hoc `opencode run` MUST close/redirect stdin (`</dev/null`) — omitting it can hang indefinitely at 0% CPU with zero output.\"\n10:     severity: warn\n11:   - id: no-bare-agent-general\n12:     check: no-bare-agent-general\n13:     message: \"Never pass a bare top-level `--agent general`; opencode rejects it on run.\"\n14:     severity: warn\n15:   - id: command-flag-for-slash-prompt\n16:     check: command-flag-for-slash-prompt\n17:     message: \"A slash-command-shaped prompt (`/family:name ...`) needs `--command <family>/<name>`, else opencode silently delivers the slash text as raw prose.\"\n18:     severity: warn\n19:   - id: share-requires-confirmation\n20:     check: share-requires-confirmation\n21:     message: \"`--share` publishes the session and requires prior operator confirmation.\"\n22:     severity: warn\n23: ---\n24: \n25: <!-- Keywords: opencode, opencode-cli, opencode-run, cross-ai, spec-kit-runtime, plugin-runtime, parallel-sessions, share-url, detached-session, agent-delegation, deepseek, openai, minimax, minimax-coding-plan, minimax-m3, token-plan, xiaomi, xiaomi-token-plan, xiaomi-token-plan-ams, xiaomi-api, xiaomi-direct, mimo, mimo-v2.5-pro, mimo-v2.5-pro-ultraspeed, ultraspeed, glm-5.2, zai-coding-plan, z.ai-coding-plan, glm-coding-plan -->\n26: \n27: # OpenCode CLI Orchestrator - Full-Runtime Cross-AI Dispatch\n28: \n29: > **CRITICAL — SELF-INVOCATION PROHIBITED**\n30: >\n31: > This skill dispatches to the OpenCode CLI binary (`opencode`). If the agent currently reading this skill is itself running inside OpenCode (TUI / acp / serve / run modes — detection signals listed in §2), the skill MUST refuse to load and return the documented error message instead of generating any `opencode` invocation. The only exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session with its own session id and state directory.\n32: >\n33: > A running CLI skill never dispatches itself. The cli-X skills are for **cross-AI delegation only** — never self-invocation.\n34: \n35: Orchestrate OpenCode's `opencode run` from external AI assistants (Claude Code, OpenCode, raw shell) AND from inside an existing OpenCode session for parallel detached workers. Three documented use cases keep the cycle risk explicit while giving every dispatch path a copy-paste invocation shape.\n36: \n37: **Core Principle**: The calling AI stays the conductor. Delegate to OpenCode for what it does best — full plugin, skill, MCP, and Spec Kit Memory runtime in a one-shot dispatch. Validate and integrate the output.\n38: \n39: ---\n40: \n41: ## 1. WHEN TO USE\n42: \n43: ### Activation Triggers\n44: \n45: - **Full plugin / skill / MCP runtime** (use case 1) — calling AI is Claude Code / OpenCode / Copilot / raw shell AND the task needs the project's full Spec Kit Memory database, Code Graph semantic index, structural code graph, or every plugin/skill/MCP tool in a one-shot dispatch. Includes `@deep-research` / `@deep-review` agent loops with externalized state under `.opencode/specs/`.\n46: - **Parallel detached session** (use case 2) — operator already inside OpenCode (TUI / web / serve / acp) AND wants a SEPARATE session with its own session id and state directory for ablation, worker farm, or parallel research. Prompt explicitly mentions \"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", or \"share URL\".\n47: - **Cross-AI orchestration handback** (use case 3) — calling AI is non-Anthropic (OpenCode / Copilot), task targets a project-specific subsystem (spec-kit, memory, code-graph, advisor), and the non-Anthropic CLI cannot load the project's plugin/skill/MCP runtime on its own and needs OpenCode as a bridge. When the caller only needs a daemon-backed tool call, prefer the shipped front doors (`spec-memory.cjs`, `code-index.cjs`, `skill-advisor.cjs`) over a full `opencode run` delegation.\n48: - **Agent dispatch** — task matches a specialized OpenCode agent. Primary agents (directly invokable via `--agent`): `general`, `plan` (built-in), `orchestrate`. Generic subagents fully dispatched via the orchestrate primary: `context`, `review`, `write`, `debug`, `ai-council`. Command-owned loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are owned end-to-end by their parent `/deep:*` command; `orchestrate` may perform exactly one bounded hand-off dispatch to a recognized loop request, but never manages the loop itself. See §3 \"OpenCode Agent Delegation\" for the full contract.\n49: - **Cross-repo dispatch** — session in repo A dispatches into repo B's plugin/skill/MCP runtime via `--dir <path>` or remote OpenCode server via `--attach <url>`.\n50: \n51: ### When NOT to Use\n52: \n53: - **You ARE OpenCode already.** If your runtime is OpenCode (detection signal: `$OPENCODE_CONFIG_DIR` or any `OPENCODE_*` env var set, `opencode` in process ancestry, or `~/.opencode/state/<id>/lock` present), this skill refuses to load. Self-invocation creates a circular dispatch loop and burns tokens for no value. The cli-X family is exclusively for cross-AI delegation. The single legitimate exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session id and state directory (use case 2); without that qualifier, the smart router refuses per ADR-001.\n54: - Simple, quick tasks where `opencode run` overhead is not worth it.\n55: - Tasks that only need a raw model dispatch — use a sibling cli-* skill.\n56: - Tasks requiring interactive TUI or web UI (use `opencode` directly instead of `opencode run`).\n57: - Context already loaded and understood by the calling AI.\n58: - Tasks where the OpenCode binary is not installed at the expected path.\n59: \n60: ---\n61: \n62: ## 2. SMART ROUTING\n63: \n64: \n65: ### Prerequisite Detection\n66: \n67: ```bash\n68: # Verify OpenCode CLI is available\n69: command -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n70: ```\n71: \n72: ### Self-Invocation Guard (ADR-001)\n73: \n74: Before any dispatch, run the layered ADR-001 detection: Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for an `opencode` parent, Layer 3 a best-effort `~/.opencode/state/<id>/lock` probe. A positive on any layer refuses the dispatch unless the prompt carries explicit parallel-session keywords (use case 2), which permits a SEPARATE session id and state directory instead. Full bash + python detection: [`references/self_invocation_guard.md`](./references/self_invocation_guard.md). Decision tree + refusal text: [`references/integration_patterns.md`](./references/integration_patterns.md) §5.\n75: \n76: ### Resource Loading Levels\n77: \n78: | Level       | When to Load            | Resources                      |\n79: | ----------- | ----------------------- | ------------------------------ |\n80: | ALWAYS      | Every skill invocation  | `references/cli_reference.md`, `assets/prompt_quality_card.md` |\n81: | CONDITIONAL | If intent signals match | Intent-mapped reference docs   |\n82: | ON_DEMAND   | Only on explicit request| Extended templates and patterns |\n83: \n84: ### Smart Router\n85: \n86: Intent-specific dictionaries (used by the shared helper functions in [`system-spec-kit/references/cli/shared_smart_router.md`](../../system-spec-kit/references/cli/shared_smart_router.md)):\n87: \n88: - Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans existing `references/` and `assets/` folders with `base.exists()` safeguards.\n89: - Pattern 2: Existence-Check Before Load - `load_if_available()` uses `_guard_in_skill()`, `inventory`, and `seen` so raw loads, missing files, duplicate loads, and path escapes are rejected.\n90: - Pattern 3: Not applicable here - `cli-opencode` has flat resource folders, not keyed `references/<key>/` or `assets/<key>/` subdirectories. Routing selects from `RESOURCE_MAP` by intent signal rather than by runtime resource key.\n91: - Pattern 4: Multi-Tier Graceful Fallback - low-confidence intent scores return `UNKNOWN_FALLBACK` with a disambiguation checklist; missing intent resources still return always-load baseline docs plus a clear notice.\n92: \n93: ```python\n94: INTENT_SIGNALS = {\n95:     \"EXTERNAL_DISPATCH\":  {\"weight\": 4, \"keywords\": [\"delegate to opencode\", \"opencode run\", \"from claude code\", \"from opencode\", \"from copilot\", \"external runtime\", \"full plugin runtime\", \"hand this off to opencode\", \"hand off to opencode\", \"send this to opencode\", \"dispatch to opencode\", \"run this through opencode\", \"let opencode handle this\", \"opencode's full runtime\", \"full runtime dispatch\", \"one-shot dispatch\", \"invoke opencode\", \"kick this off in opencode\", \"have opencode take care of this\", \"get opencode to run this\", \"pass this over to opencode\", \"opencode has access to every tool\", \"opencode has the whole toolchain\", \"since opencode has all the plugins\", \"opencode can load every skill\", \"ask opencode to handle this\", \"opencode should handle this\", \"offload this to opencode\", \"outsource this to opencode\", \"forward this to opencode\", \"route this to opencode\", \"push this to opencode\", \"opencode has everything loaded\", \"opencode has the whole toolset\", \"opencode cli\", \"run externally\", \"full toolset\", \"handle this externally\", \"external ai assistant\", \"run in opencode\", \"hand off externally\"]},\n96:     \"PARALLEL_DETACHED\":  {\"weight\": 4, \"keywords\": [\"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", \"share url\", \"share-url\", \"detached session\", \"separate session id\", \"own state directory\", \"spin up a new session\", \"background opencode session\", \"run this in the background\", \"fan out workers\", \"concurrent sessions\", \"isolated session\", \"run these in parallel\", \"spin off a few workers\", \"kick off several sessions at once\", \"run copies side by side\", \"fire off multiple runs at the same time\", \"farm this out to multiple workers\", \"run a bunch of these concurrently\", \"distribute the work across sessions\", \"batch this across sessions\", \"start several sessions at once\", \"spin up another instance\", \"new opencode instance\", \"run it as its own session\", \"own separate session\", \"side session\", \"run this independently\", \"additional worker\", \"background job\", \"separate instance\", \"own instance\", \"parallel run\", \"concurrent run\", \"session of its own\", \"spin up a worker\", \"worker pool\", \"run in parallel\"]},\n97:     \"CROSS_AI_HANDBACK\":  {\"weight\": 4, \"keywords\": [\"spec kit\", \"spec-kit\", \"spec_kit\", \"code graph\", \"memory_search\", \"session_bootstrap\", \"skill advisor\", \"cross-ai handback\", \"hand back to opencode\", \"bridge back to opencode\", \"opencode as a bridge\", \"non-anthropic cli\", \"project's memory database\", \"structural code index\", \"use the skill advisor\"]},\n98:     \"AGENT_DISPATCH\":     {\"weight\": 4, \"keywords\": [\"delegate\", \"agent\", \"deep-research\", \"deep-review\", \"ai-council\", \"review agent\", \"context agent\", \"dispatch an agent\", \"spawn an agent\", \"run a subagent\", \"invoke a subagent\", \"specialized subagent\", \"debug agent\", \"write agent\"]},\n99:     \"CROSS_REPO\":         {\"weight\": 3, \"keywords\": [\"cross-repo\", \"different repo\", \"--dir\", \"another repository\", \"remote opencode\", \"different repository\", \"target repo\", \"other codebase\", \"separate repository\", \"remote opencode server\", \"--attach\"]},\n100:     \"TEMPLATES\":          {\"weight\": 3, \"keywords\": [\"template\", \"prompt\", \"how to ask\", \"opencode prompt\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\", \"prompt framework\", \"prompt template\", \"how do i phrase this\", \"copy-paste template\", \"prompt quality\", \"prompt craft\", \"costar framework\", \"example prompt\"]},\n101:     \"PATTERNS\":           {\"weight\": 3, \"keywords\": [\"pattern\", \"workflow\", \"orchestrate\", \"session continue\", \"resume session\", \"integration pattern\", \"dispatch pattern\", \"continue the session\", \"resume a session\", \"session continuation\"]},\n102:     # WHY: DESIGN is an intent signal only — a deliberate cross-skill handoff to sk-design,\n103:     # not a same-skill resource bundle. It intentionally has NO RESOURCE_MAP entry: this skill\n104:     # hands design work off rather than owning design reference docs. The durable sk-design\n105:     # loading contract lives in the always-fires Design Standards Loading rule and the dispatch\n106:     # manifest (see ALWAYS rules 13-14); RESOURCE_MAP stays limited to same-skill markdown paths.\n107:     \"DESIGN\":             {\"weight\": 4, \"keywords\": [\"sk-design\", \"interface design\", \"frontend design\", \"visual design\", \"redesign the ui\", \"design foundations\", \"design tokens\", \"motion design\", \"micro-interactions\", \"design audit\", \"ui critique\", \"extract design system\", \"generate design.md\"]},\n108: }\n109: \n110: RESOURCE_MAP = {\n111:     \"EXTERNAL_DISPATCH\":  [\"references/cli_reference.md\", \"references/integration_patterns.md\"],\n112:     \"PARALLEL_DETACHED\":  [\"references/integration_patterns.md\", \"assets/prompt_templates.md\"],\n113:     \"CROSS_AI_HANDBACK\":  [\"references/integration_patterns.md\", \"references/opencode_tools.md\"],\n114:     \"AGENT_DISPATCH\":     [\"references/agent_delegation.md\", \"assets/prompt_templates.md\"],\n115:     \"CROSS_REPO\":         [\"references/cli_reference.md\", \"references/opencode_tools.md\"],\n116:     \"TEMPLATES\":          [\"assets/prompt_templates.md\", \"references/cli_reference.md\"],\n117:     \"PATTERNS\":           [\"references/integration_patterns.md\", \"references/cli_reference.md\"],\n118: }\n119: \n120: LOADING_LEVELS = {\n121:     \"ALWAYS\": [\"references/cli_reference.md\", \"assets/prompt_quality_card.md\"],\n122:     \"ON_DEMAND_KEYWORDS\": [\"full reference\", \"all templates\", \"deep dive\", \"complete guide\", \"opencode agent\", \"opencode prompt\", \"share url\", \"ablation\", \"worker farm\", \"self-invocation\", \"memory handback\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\"],\n123:     \"ON_DEMAND\": [\"references/opencode_tools.md\", \"assets/prompt_templates.md\"],\n124: }\n125: \n126: UNKNOWN_FALLBACK_CHECKLIST = [\n127:     \"Is the user asking about OpenCode CLI specifically?\",\n128:     \"Does the task need the project's full plugin / skill / MCP runtime?\",\n129:     \"Is a parallel detached session what they want?\",\n130:     \"Is a non-Anthropic CLI handing back to OpenCode for a spec-kit workflow?\",\n131: ]\n132: ```\n133: \n134: **Call sequence** (using shared helpers from `shared_smart_router.md`):\n135: \n136: 1. `discover_markdown_resources()` — recursively enumerate current `.md` files under existing `references/` and `assets/` folders at routing time.\n137: 2. `_guard_in_skill()` + `load_if_available()` — sandbox paths to this skill, reject non-markdown loads, skip missing files, and suppress duplicates.\n138: 3. `score_intents(task)` and `select_intents(scores, ambiguity_delta=1.0)` — preserve provider-specific weighted intent scoring and top-2 ambiguity handling.\n139: 4. ALWAYS-load `LOADING_LEVELS[\"ALWAYS\"]`, then return `UNKNOWN_FALLBACK` with `UNKNOWN_FALLBACK_CHECKLIST` when max score is 0.\n140: 5. CONDITIONAL-load existing `RESOURCE_MAP[intent]` entries via `load_if_available()`, ON_DEMAND-load keyword matches, and return a notice when no intent-specific knowledge base is available beyond always-load resources.\n141: \n142: The `route_opencode_resources(task)` function body lives in [`shared_smart_router.md`](../../system-spec-kit/references/cli/shared_smart_router.md) — substitute `<PROVIDER>` = `opencode`.\n143: \n144: ---\n145: \n146: ## 3. HOW IT WORKS\n147: \n148: ### Prerequisites\n149: \n150: ```bash\n151: # Verify installation (cli-opencode v1.0.0 is pinned to opencode v1.3.17)\n152: opencode --version | grep -q '^1\\.' || echo \"Not installed or version drift. See references/cli_reference.md §9.\"\n153: \n154: # Self-invocation guard\n155: env | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n156: \n157: # Authentication — providers configured via opencode providers (alias auth)\n158: opencode providers\n159: ```\n160: \n161: **Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans). Full per-provider login shapes and the configured-provider list: `references/cli_reference.md` §4.\n162: \n163: ### Provider Auth Pre-Flight (Smart Fallback)\n164: \n165: **MANDATORY before any first dispatch in a session.** The default provider may not be logged in — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run the pre-flight once per session, cache the result, and re-run only on an auth failure.\n166: \n167: The one-shot pre-flight bash, the per-provider decision trees, the user-facing prompt templates for missing providers, and the error-recovery contract live in [`references/cli_reference.md`](./references/cli_reference.md) §4 — do not duplicate them here. Never substitute a model the user didn't approve; ASK when the default is unavailable.\n168: \n169: ### Default Invocation (Skill Default)\n170: \n171: **Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>` (pinned to avoid CWD ambiguity). Direct DeepSeek is the default provider — elevated reasoning at low cost for routine dispatches.\n172: \n173: Use `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n174: \n175: > **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run` — current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails outright. The default agent runs when `--agent` is omitted, which is correct for almost every dispatch. **To target a specific agent profile, describe the role in the prompt body instead** (e.g. open with \"Act as a code-review agent: …\"); only pass `--agent <name>` after confirming acceptance via `opencode run --help` on the installed version.\n176: \n177: Honor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n178: \n179: ### Core Invocation Pattern\n180: \n181: Core flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n182: \n183: > **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation — without it, opencode can inherit parent-terminal stdin and hang. See `references/integration_patterns.md` §6.\n184: \n185: > **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text as raw prose. Execute a registered command via `opencode run --command <family>/<name> [flags] \"<args>\"` (becomes `$ARGUMENTS`; e.g. `memory/search` for `/memory:search`). Full semantics: `references/cli_reference.md` §4.\n186: \n187: ### Model Selection\n188: \n189: Run `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default: `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API). Alternates (all omit `--agent`): MiniMax Token Plan/Direct API `MiniMax-M3`, Xiaomi Token Plan/Direct API `mimo-v2.5-pro` (+ low-latency `-ultraspeed`), Kimi For Coding `k2p7` (256k, subscription), Z.AI GLM Coding Plan `glm-5.2` (1M, subscription), and the OpenAI GPT-5.6 catalog (`gpt-5.6-sol` flagship default; bare/Sol/Terra/Luna x base/Fast/Pro, `--variant` up to `xhigh`). Full model table, per-provider `--variant` mapping, and model-specific operational caveats: `references/cli_reference.md` §5.\n190: \n191: Shared small-model facts, context defaults, quota pools, and fallback targets live in `../../sk-prompt/prompt-models/assets/model_profiles.json`.\n192: \n193: ### OpenCode Agent Delegation\n194: \n195: The calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n196: \n197: #### Primary agents — directly invokable via `--agent`\n198: \n199: OpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Never pass `--agent general`** — it is rejected at the top level; the default agent (used when `--agent` is omitted) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` confirms top-level acceptance; otherwise state the role in the prompt body.\n200: \n201: #### Subagents — dispatched as Task subagents from a primary\n202: \n203: These live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n204: \n205: 1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by `orchestrate` via the Task tool. Route through `--agent orchestrate` and let it dispatch the relevant subagent.\n206: 2. **`ai-council`** — dispatched via `/deep:ai-council` or `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`).\n207: 3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>`. `orchestrate` is an authorized **caller/coordinator only** — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop.\n208: \n209: See [agent_delegation.md](./references/agent_delegation.md) for the complete agent roster and dispatch patterns.\n210: \n211: ### Unique OpenCode Strengths\n212: \n213: Full project runtime loading, detached sessions, JSON event streams, agent routing, cross-repo/server dispatch, session continuation, and plugin-disable debugging.\n214: \n215: ### Essential Commands\n216: \n217: Default invocation for external runtime handback; `--share --port <N>` only for explicit detached sessions; `--agent orchestrate` for generic subagent routing; `--dir` for cross-repo dispatch.\n218: \n219: ### Error Handling\n220: \n221: Install missing binaries, refuse ambiguous self-invocation, run provider pre-flight for model/auth errors, check version drift for unknown flags, force `--format json` for empty streams, add `</dev/null` for background loops, confirm `--share`, use `--pure` only for plugin crashes, inspect state logs for stuck sessions.\n222: \n223: ---\n224: \n225: ## 4. RULES\n226: \n227: ### ✅ ALWAYS\n228: \n229: 1. Verify OpenCode CLI is installed before first invocation; confirm version baseline against v1.3.17 (drift handling per `references/cli_reference.md` §9).\n230: 2. **Run the self-invocation guard before dispatch** (ADR-001): Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for `opencode` parent, Layer 3 `~/.opencode/state/<id>/lock` probe. Trip on ANY positive — refuse unless prompt has explicit parallel-session keywords.\n231: 3. Pin model + variant + format + dir explicitly — **no `--agent`** (see the Default Invocation note: current opencode rejects a top-level `--agent general`; put any agent-profile request in the prompt body). Default: `--model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root>`. Honor user overrides verbatim (e.g. `deepseek/deepseek-v4-pro`, `minimax-coding-plan/MiniMax-M3`, `minimax/MiniMax-M3`, `xiaomi-token-plan-ams/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro-ultraspeed`, `openai/gpt-5.6-sol-pro`).\n232: 4. Pass `--format json` unless the calling AI explicitly wants formatted output — JSON event stream is what external runtimes parse incrementally.\n233: 5. **Append `</dev/null` to every non-interactive `opencode run` invocation** that redirects stdout and/or stderr to files OR runs inside `while read` loops. opencode v1.14.39 reads stdin at startup before session creation; without explicit closed stdin, automation hangs forever at 0% CPU after the `+60s service=snapshot prune=7.days cleanup` log line. Position: AFTER the prompt positional argument, BEFORE the `> stdout 2> stderr` redirects. Foreground `| tail` happens to provide closed stdin (pipe stage upstream is empty) and accidentally bypasses the bug, but `> stdout.log 2> stderr.log` does not. The 9-character `</dev/null` redirect provides immediate EOF on stdin, unblocking the dispatch. **DO NOT auto-kill external operator-owned opencode sessions** when sweeping orphans between dispatches; exclude `opencode run` from pkill (per 2026-05-23 operator directive captured in memory `feedback_proactive_orphan_cleanup.md`). See `references/integration_patterns.md` §6 + memory `feedback_opencode_run_requires_dev_null_stdin.md` + CHANGELOG-2026-05-08-tool-name-regex-fix.md §Fix 4.\n234: 6. **Pass the spec folder to the dispatched session** in the prompt: if the calling AI has an active Gate-3 spec folder, include `Spec folder: <path> (pre-approved, skip Gate 3)`. If none, ASK the user before delegating — the dispatched session cannot answer Gate 3 interactively in non-interactive `run` mode.\n235: 7. **Prompt construction & model-craft (cli-* family precedence).** Compose every dispatch prompt via the 3-tier rule canonical in `../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md`:\n236:    1. **Fast path (default).** Build from the local `assets/prompt_quality_card.md`, which delegates the framework table + CLEAR check to the canonical card.\n237:    2. **Model override (mandatory for a profiled model).** If the target model has a profile at `../../sk-prompt/prompt-models/references/models/<id>.md`, that profile OVERRIDES the cross-model default. The **sk-prompt/prompt-models** hub owns per-model prompt-craft (framework + scaffold + gotchas, mirroring `sk-prompt/prompt-models/assets/model_profiles.json` `recommended_frameworks`); consult it before composing for any small model.\n238:    3. **Deep path (escalation).** Dispatch `@prompt-improver` via the Task tool (never load full `sk-prompt` inline) when any canonical **Tier 3** trigger applies — the trigger list lives in `../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` under \"Tier 3 — Deep path\"; do not re-enumerate it here.\n239: 8. Validate dispatched session output: parse JSON events incrementally (tool calls, partial messages, final summary), run syntax checks if code generated, and cross-reference against project standards via `sk-code` surface detection plus its code-review mode when findings-first review is requested (see ALWAYS rule 12).\n240: 9. Capture stderr (`2>&1`) to catch tool errors and warnings.\n241: 10. Classify the use case (1 / 2 / 3) before dispatching — the smart router refuses dispatches that do not map to one of the three.\n242: 11. **Run the Provider Auth Pre-Flight once per session** (see §3 Provider Auth Pre-Flight). Cache the configured-providers list. If the default `deepseek` is missing, ASK the user — never silently substitute the model. If a later dispatch returns an auth error, invalidate the cache and rerun the pre-flight before retrying.\n243: 12. **Code Standards Loading (surface-aware contract)** — When dispatching for code review or code generation, instruct the dispatched session to: (1) load `sk-code`; (2) let `sk-code` emit a surface tag matching the detected stack from markers and target files; (3) load the selected surface resources and run its verification commands; (4) load `sk-code`'s code-review mode only for formal findings-first review output. Fallback: if the surface cannot be determined confidently, ask for the runtime surface and verification command set. NEVER hardcode obsolete sibling code skills in dispatch prompts.\n244: 13. **Design Standards Loading (surface-aware contract)** — When dispatching for design or UI work, instruct the dispatched session to: (1) load `sk-design` (the hub); (2) let the hub resolve a `workflowMode` through `mode-registry.json` (interface / foundations / motion / audit / md-generator / design-mcp-open-design); (3) load the selected mode packet, set the design register, and run that mode's design verification; (4) if the work feeds Open Design, carry the `design-mcp-open-design` pairing (a nested transport packet of the hub) — the transport never decides taste. Fallback: if the design mode cannot be determined confidently, ask for the surface and design intent. NEVER treat `mcp-figma` or `design-mcp-open-design` as the taste authority, or hardcode obsolete flat design skills in dispatch prompts.\n245: 14. **Pass the design dispatch manifest to the dispatched session** — when dispatching design or UI work, inline a `DESIGN_DISPATCH_MANIFEST v1` block in the prompt (the child cannot resolve skill paths, so the manifest travels in the payload, not by reference): `skDesignLoaded` true, `register` resolved to `Brand` or `Product` (never `unknown`), registry-valid `workflowModes`, `dials`, `loadedFiles`, and `proofDemandBack`. If the manifest cannot be assembled — `sk-design` not loaded, register unresolved, or no registry-valid mode — ASK before launching the child rather than starting a silent design dispatch. The child returns the demanded proof; the parent reconciles it on the return path.\n246: 15. **Destructive-scope-violation prevention (RM-8) for deep-loop dispatches** — The structured permissions-matrix gate (`permissions-gate.ts`; schema and design in `references/permissions_matrix.md`) is built and unit-tested but has ZERO production callers today — no `opencode run` dispatch path invokes it, so a loaded `--permissions-matrix <path>` config or recipe field is NOT currently enforced and does NOT bypass anything. Regardless of whether a matrix config is present, any non-interactive `opencode run` with `--dangerously-skip-permissions` against a populated worktree MUST apply the four-layer mitigation — it is the only active protection today: (L1) rendered prompt contains literal `BANNED OPERATIONS` and `ALLOWED WRITE PATHS`; (L2) `--dir` points at a fresh `git worktree`; (L3) main `git status` clean OR committed, recovery-baseline commit hash recorded; (L4) for multi-phase / phase-parent targets, prefer `cli-copilot` + `gpt-5.6-sol --reasoning-effort high` (verify `gpt-5.6-sol` availability on the Copilot surface — unverified, carried over from a gpt-5.5-era check; if absent, pick an available Copilot model, don't silently fall back to the risky default) over `deepseek-v4-pro`. Background: on 2026-05-04 an `opencode-go/deepseek-v4-pro` dispatch under `/deep:review:auto` deleted 44 files across two phase folders because the only safeguard was prose and `--dangerously-skip-permissions` granted unrestricted FS write. Full incident + root cause + checklist: `references/destructive_scope_violations.md`.\n247: 16. **Single-dispatch discipline (operator-gated, session-scoped)** — Default: launch ONE cli-* dispatch at a time across the cli-* family (cli-opencode, cli-claude-code). Wait for the dispatched agent's work to return, verify outputs exist, then SIGKILL only the dispatch THIS skill started: capture its PID at launch (`opencode run ... & OC_PID=$!`) and kill that captured PID directly plus its own orphan children (`kill -9 \"$OC_PID\" 2>/dev/null; pkill -9 -P \"$OC_PID\" 2>/dev/null`), then apply the same PID-scoped `gtimeout` / `positional_scoring_fallback:app` cleanup. (A backgrounded `opencode run &` is NOT a process-group leader unless launched with `setsid`/`set -m`, so a negative-PID group kill would target a nonexistent group and miss the process — kill the captured PID directly.) **Kill only the dispatch you started, by captured PID; never a blanket `pkill -9 -f \"opencode run\"` pattern — see Rule 5** (a blanket match kills operator-owned `opencode run` sessions too). Only launch the next dispatch (this skill OR a sibling) after the prior one is dead and RSS has dropped. **Within a deep-flow session** (deep-review / deep-research): the operator authorizes the whole multi-iteration session at start — iterations chain back-to-back with kill-between as the safety mechanism, NOT a per-iteration operator confirmation prompt. **Exception (cross-skill parallel)**: when the operator explicitly authorizes N parallel dispatches, run N concurrently — but still SIGKILL each by its own captured PID as its work returns.\n248: 17. **Set `AI_SESSION_CHILD=1` in the dispatched session's env** when sessions may be launched through the per-session worktree wrapper (`.opencode/bin/worktree-session.sh`). A dispatched `opencode run` is an orchestrated sub-session, not a new top-level session, so it must SHARE the parent's worktree rather than allocate its own. The wrapper checks `AI_SESSION_CHILD` (plus a `git --git-common-dir` structural backstop) and exec's in place when set. Pattern: `AI_SESSION_CHILD=1 opencode run ... </dev/null`. Harmless when the wrapper is not in use. See `.opencode/bin/README.md` → \"Worktree session isolation\". Prepend `MK_SPEC_GATE_ENFORCE=0` next to it so a dispatched child never inherits an enforced spec-gate from the parent shell (belt-and-suspenders alongside the wrapper's own neutralization and the core's `AI_SESSION_CHILD` deny-narrowing): `MK_SPEC_GATE_ENFORCE=0 AI_SESSION_CHILD=1 opencode run ... </dev/null`.\n249: \n250: ### ⛔ NEVER\n251: \n252: 1. Invoke this skill from within OpenCode itself for a self-dispatch — refuse with the documented error message; use a sibling cli-* / fresh shell / parallel-session keywords.\n253: 2. Pass `--share` without operator confirmation (CHK-033) — share URL exposes session contents.\n254: 3. Trust dispatched session output blindly for security-sensitive code, send sensitive data (API keys, passwords, credentials) in prompts, or hammer the API with rapid sequential calls.\n255: 4. Use `--pure` outside of plugin debugging (disabling plugins removes the entire point of cli-opencode dispatch).\n256: 5. Nest `opencode run` inside a dispatched session's tool calls — use OpenCode's native Task tool for sub-agent dispatch.\n257: \n258: ### ⚠️ ESCALATE IF\n259: \n260: 1. OpenCode CLI is not installed and user has not acknowledged (provide `brew install opencode` or `curl -fsSL https://opencode.ai/install | bash`).\n261: 2. Operator wants to publish a `--share` URL — get explicit confirmation per CHK-033.\n262: 3. Binary version differs from the v1.3.17 baseline — run `opencode --version` and `opencode run --help`; surface drift and fall back or require approval.\n263: 4. Smart router cannot map the prompt to one of the three use cases — surface the disambiguation checklist from UNKNOWN_FALLBACK.\n264: 5. Self-invocation guard trips AND the prompt is ambiguous — surface the refusal with three remediation options (sibling cli-* / fresh shell / parallel-session keywords).\n265: \n266: ### Memory Handback Protocol\n267: \n268: When the calling AI needs to preserve session context from an OpenCode CLI delegation, run the canonical 7-step procedure (extract `MEMORY_HANDBACK` section → build structured JSON → scrub secrets → invoke `generate-context.js` via `--stdin`/`--json`/temp-file → `memory_index_scan`). Full procedure and caveats: [`system-spec-kit/references/cli/memory_handback.md`](../../system-spec-kit/references/cli/memory_handback.md).\n269: \n270: For read-only or hook-style recovery, use the daemon-backed CLI front doors instead of spawning OpenCode: `node .opencode/bin/spec-memory.cjs <tool>`, `node .opencode/bin/code-index.cjs <tool>`, or `node .opencode/bin/skill-advisor.cjs <tool>`. Prompt-time paths must probe warm sockets or pass `--warm-only`; exit `75` is retryable daemon/IPC unavailability, not a model failure.\n271: \n272: OpenCode-specific Memory Epilogue template: see [assets/prompt_templates.md](./assets/prompt_templates.md) §14.\n273: \n274: Example invocation:\n275: ```bash\n276: printf '%s' \"$JSON_PAYLOAD\" | node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --stdin [spec-folder]\n277: ```\n278: \n279: ---\n280: \n281: ## 5. REFERENCES AND RELATED RESOURCES\n282: \n283: ### Core References\n284: \n285: - [cli_reference.md](./references/cli_reference.md) - Full subcommand/flag reference, provider auth pre-flight, models, version drift\n286: - [integration_patterns.md](./references/integration_patterns.md) - 3 use cases, decision tree, silent stdin\n287: - [self_invocation_guard.md](./references/self_invocation_guard.md) - ADR-001 layered bash + python detection contract\n288: - [opencode_tools.md](./references/opencode_tools.md) - Unique value props vs sibling cli-* skills\n289: - [agent_delegation.md](./references/agent_delegation.md) - Agent routing matrix, leaf-agent constraints\n290: - [destructive_scope_violations.md](./references/destructive_scope_violations.md) - RM-8 incident, root cause, four-layer prevention playbook\n291: \n292: ### Templates and Assets\n293: \n294: - [prompt_templates.md](./assets/prompt_templates.md) - Copy-paste templates per use case + agent + handback\n295: - [prompt_quality_card.md](./assets/prompt_quality_card.md) - Executor-specific model overrides; delegates framework/CLEAR check to canonical card\n296: \n297: ### Shared (cli-* family)\n298: - [shared_smart_router.md](../../system-spec-kit/references/cli/shared_smart_router.md) - Helper-function bodies for the smart router.\n299: - [memory_handback.md](../../system-spec-kit/references/cli/memory_handback.md) - Canonical 7-step Memory Handback procedure.\n300: \n301: ### External\n302: - [OpenCode GitHub](https://github.com/sst/opencode) - Official repository\n303: - [OpenCode Install](https://opencode.ai/install) - Standalone installer entry point\n304: - [OpenCode Documentation](https://opencode.ai/docs) - Official docs\n305: \n306: ### Reference Loading Notes\n307: \n308: - Load only references needed for current intent.\n309: - Smart Routing (Section 2) is the single routing authority.\n310: - `cli_reference.md` and `prompt_quality_card.md` are ALWAYS loaded as baseline.\n311: - The router discovers reference, asset, and script docs dynamically — task-specific resources from `references/`, templates from `assets/`, and automation from `scripts/` when present.\n312: \n313: ### Related Skills\n314: \n315: `cli-claude-code` and `cli-opencode` for sibling cross-AI dispatch; `system-spec-kit` for handback; `sk-code` plus the selected overlay for generated code; `system-deep-loop` for loop execution (its `research` and `review` modes); and `mcp-code-mode` for MCP-backed tools.\n316: \n317: ---\n318: \n319: ## 6. SUCCESS CRITERIA\n320: \n321: ### Task Completion\n322: \n323: - OpenCode CLI invoked with the correct subcommand, flags, model, agent, variant, format, and dir.\n324: - Self-invocation guard checked before dispatch — refused when appropriate.\n325: - Use case (1 / 2 / 3) classified explicitly before invocation.\n326: - JSON event stream captured, parsed incrementally, validated, integrated.\n327: - No security vulnerabilities introduced from generated code.\n328: - `--share` URLs opt-in with operator confirmation per CHK-033.\n329: - Background dispatches in `while read` loops include `</dev/null` redirect.\n330: - Memory Handback extracted and saved through `generate-context.js` when applicable.\n331: \n332: ### Skill Quality\n333: \n334: - All numbered sections present and correctly ordered.\n335: - Smart routing covers all intent signals with UNKNOWN_FALLBACK.\n336: - Reference files provide deep-dive content without duplication.\n337: - Self-invocation guard pseudocode reproduced in Section 2 mirrors ADR-001.\n338: \n339: ---\n340: \n341: ## 7. INTEGRATION POINTS\n342: \n343: ### Framework Integration\n344: \n345: This skill operates within the behavioral framework defined in [AGENTS.md](../../../../AGENTS.md).\n346: \n347: Key integrations:\n348: - **Gate 2**: Skill routing via the Skill Advisor Hook (or `skill_advisor.py` fallback)\n349: - **Tool Routing**: Per AGENTS.md Section 6 decision tree\n350: - **Memory**: Context preserved via Spec Kit Memory MCP (`generate-context.js`)\n351: - **Validation**: `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh` for spec-folder workflows\n352: \n353: **Tool roles**: Bash dispatches the CLI; Read/Glob/Grep validate output and probe `~/.opencode/state/` for session locks.\n\n(End of file - total 353 lines)\n</content>","metadata":{"preview":"---\nname: cli-opencode\ndescription: \"OpenCode CLI orchestrator: external dispatch, in-OpenCode parallel sessions, cross-AI handback with full runtime context.\"\nallowed-tools: [Bash, Read, Glob, Grep]\nversion: 1.3.15.3\nhard_rules:\n  - id: stdin-redirect-required\n    check: stdin-redirect-required\n    message: \"Ad-hoc `opencode run` MUST close/redirect stdin (`</dev/null`) — omitting it can hang indefinitely at 0% CPU with zero output.\"\n    severity: warn\n  - id: no-bare-agent-general\n    check: no-bare-agent-general\n    message: \"Never pass a bare top-level `--agent general`; opencode rejects it on run.\"\n    severity: warn\n  - id: command-flag-for-slash-prompt\n    check: command-flag-for-slash-prompt\n    message: \"A slash-command-shaped prompt (`/family:name ...`) needs `--command <family>/<name>`, else opencode silently delivers the slash text as raw prose.\"\n    severity: warn\n  - id: share-requires-confirmation\n    check: share-requires-confirmation","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md","text":"---\nname: cli-opencode\ndescription: \"OpenCode CLI orchestrator: external dispatch, in-OpenCode parallel sessions, cross-AI handback with full runtime context.\"\nallowed-tools: [Bash, Read, Glob, Grep]\nversion: 1.3.15.3\nhard_rules:\n  - id: stdin-redirect-required\n    check: stdin-redirect-required\n    message: \"Ad-hoc `opencode run` MUST close/redirect stdin (`</dev/null`) — omitting it can hang indefinitely at 0% CPU with zero output.\"\n    severity: warn\n  - id: no-bare-agent-general\n    check: no-bare-agent-general\n    message: \"Never pass a bare top-level `--agent general`; opencode rejects it on run.\"\n    severity: warn\n  - id: command-flag-for-slash-prompt\n    check: command-flag-for-slash-prompt\n    message: \"A slash-command-shaped prompt (`/family:name ...`) needs `--command <family>/<name>`, else opencode silently delivers the slash text as raw prose.\"\n    severity: warn\n  - id: share-requires-confirmation\n    check: share-requires-confirmation\n    message: \"`--share` publishes the session and requires prior operator confirmation.\"\n    severity: warn\n---\n\n<!-- Keywords: opencode, opencode-cli, opencode-run, cross-ai, spec-kit-runtime, plugin-runtime, parallel-sessions, share-url, detached-session, agent-delegation, deepseek, openai, minimax, minimax-coding-plan, minimax-m3, token-plan, xiaomi, xiaomi-token-plan, xiaomi-token-plan-ams, xiaomi-api, xiaomi-direct, mimo, mimo-v2.5-pro, mimo-v2.5-pro-ultraspeed, ultraspeed, glm-5.2, zai-coding-plan, z.ai-coding-plan, glm-coding-plan -->\n\n# OpenCode CLI Orchestrator - Full-Runtime Cross-AI Dispatch\n\n> **CRITICAL — SELF-INVOCATION PROHIBITED**\n>\n> This skill dispatches to the OpenCode CLI binary (`opencode`). If the agent currently reading this skill is itself running inside OpenCode (TUI / acp / serve / run modes — detection signals listed in §2), the skill MUST refuse to load and return the documented error message instead of generating any `opencode` invocation. The only exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session with its own session id and state directory.\n>\n> A running CLI skill never dispatches itself. The cli-X skills are for **cross-AI delegation only** — never self-invocation.\n\nOrchestrate OpenCode's `opencode run` from external AI assistants (Claude Code, OpenCode, raw shell) AND from inside an existing OpenCode session for parallel detached workers. Three documented use cases keep the cycle risk explicit while giving every dispatch path a copy-paste invocation shape.\n\n**Core Principle**: The calling AI stays the conductor. Delegate to OpenCode for what it does best — full plugin, skill, MCP, and Spec Kit Memory runtime in a one-shot dispatch. Validate and integrate the output.\n\n---\n\n## 1. WHEN TO USE\n\n### Activation Triggers\n\n- **Full plugin / skill / MCP runtime** (use case 1) — calling AI is Claude Code / OpenCode / Copilot / raw shell AND the task needs the project's full Spec Kit Memory database, Code Graph semantic index, structural code graph, or every plugin/skill/MCP tool in a one-shot dispatch. Includes `@deep-research` / `@deep-review` agent loops with externalized state under `.opencode/specs/`.\n- **Parallel detached session** (use case 2) — operator already inside OpenCode (TUI / web / serve / acp) AND wants a SEPARATE session with its own session id and state directory for ablation, worker farm, or parallel research. Prompt explicitly mentions \"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", or \"share URL\".\n- **Cross-AI orchestration handback** (use case 3) — calling AI is non-Anthropic (OpenCode / Copilot), task targets a project-specific subsystem (spec-kit, memory, code-graph, advisor), and the non-Anthropic CLI cannot load the project's plugin/skill/MCP runtime on its own and needs OpenCode as a bridge. When the caller only needs a daemon-backed tool call, prefer the shipped front doors (`spec-memory.cjs`, `code-index.cjs`, `skill-advisor.cjs`) over a full `opencode run` delegation.\n- **Agent dispatch** — task matches a specialized OpenCode agent. Primary agents (directly invokable via `--agent`): `general`, `plan` (built-in), `orchestrate`. Generic subagents fully dispatched via the orchestrate primary: `context`, `review`, `write`, `debug`, `ai-council`. Command-owned loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are owned end-to-end by their parent `/deep:*` command; `orchestrate` may perform exactly one bounded hand-off dispatch to a recognized loop request, but never manages the loop itself. See §3 \"OpenCode Agent Delegation\" for the full contract.\n- **Cross-repo dispatch** — session in repo A dispatches into repo B's plugin/skill/MCP runtime via `--dir <path>` or remote OpenCode server via `--attach <url>`.\n\n### When NOT to Use\n\n- **You ARE OpenCode already.** If your runtime is OpenCode (detection signal: `$OPENCODE_CONFIG_DIR` or any `OPENCODE_*` env var set, `opencode` in process ancestry, or `~/.opencode/state/<id>/lock` present), this skill refuses to load. Self-invocation creates a circular dispatch loop and burns tokens for no value. The cli-X family is exclusively for cross-AI delegation. The single legitimate exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session id and state directory (use case 2); without that qualifier, the smart router refuses per ADR-001.\n- Simple, quick tasks where `opencode run` overhead is not worth it.\n- Tasks that only need a raw model dispatch — use a sibling cli-* skill.\n- Tasks requiring interactive TUI or web UI (use `opencode` directly instead of `opencode run`).\n- Context already loaded and understood by the calling AI.\n- Tasks where the OpenCode binary is not installed at the expected path.\n\n---\n\n## 2. SMART ROUTING\n\n\n### Prerequisite Detection\n\n```bash\n# Verify OpenCode CLI is available\ncommand -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n```\n\n### Self-Invocation Guard (ADR-001)\n\nBefore any dispatch, run the layered ADR-001 detection: Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for an `opencode` parent, Layer 3 a best-effort `~/.opencode/state/<id>/lock` probe. A positive on any layer refuses the dispatch unless the prompt carries explicit parallel-session keywords (use case 2), which permits a SEPARATE session id and state directory instead. Full bash + python detection: [`references/self_invocation_guard.md`](./references/self_invocation_guard.md). Decision tree + refusal text: [`references/integration_patterns.md`](./references/integration_patterns.md) §5.\n\n### Resource Loading Levels\n\n| Level       | When to Load            | Resources                      |\n| ----------- | ----------------------- | ------------------------------ |\n| ALWAYS      | Every skill invocation  | `references/cli_reference.md`, `assets/prompt_quality_card.md` |\n| CONDITIONAL | If intent signals match | Intent-mapped reference docs   |\n| ON_DEMAND   | Only on explicit request| Extended templates and patterns |\n\n### Smart Router\n\nIntent-specific dictionaries (used by the shared helper functions in [`system-spec-kit/references/cli/shared_smart_router.md`](../../system-spec-kit/references/cli/shared_smart_router.md)):\n\n- Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans existing `references/` and `assets/` folders with `base.exists()` safeguards.\n- Pattern 2: Existence-Check Before Load - `load_if_available()` uses `_guard_in_skill()`, `inventory`, and `seen` so raw loads, missing files, duplicate loads, and path escapes are rejected.\n- Pattern 3: Not applicable here - `cli-opencode` has flat resource folders, not keyed `references/<key>/` or `assets/<key>/` subdirectories. Routing selects from `RESOURCE_MAP` by intent signal rather than by runtime resource key.\n- Pattern 4: Multi-Tier Graceful Fallback - low-confidence intent scores return `UNKNOWN_FALLBACK` with a disambiguation checklist; missing intent resources still return always-load baseline docs plus a clear notice.\n\n```python\nINTENT_SIGNALS = {\n    \"EXTERNAL_DISPATCH\":  {\"weight\": 4, \"keywords\": [\"delegate to opencode\", \"opencode run\", \"from claude code\", \"from opencode\", \"from copilot\", \"external runtime\", \"full plugin runtime\", \"hand this off to opencode\", \"hand off to opencode\", \"send this to opencode\", \"dispatch to opencode\", \"run this through opencode\", \"let opencode handle this\", \"opencode's full runtime\", \"full runtime dispatch\", \"one-shot dispatch\", \"invoke opencode\", \"kick this off in opencode\", \"have opencode take care of this\", \"get opencode to run this\", \"pass this over to opencode\", \"opencode has access to every tool\", \"opencode has the whole toolchain\", \"since opencode has all the plugins\", \"opencode can load every skill\", \"ask opencode to handle this\", \"opencode should handle this\", \"offload this to opencode\", \"outsource this to opencode\", \"forward this to opencode\", \"route this to opencode\", \"push this to opencode\", \"opencode has everything loaded\", \"opencode has the whole toolset\", \"opencode cli\", \"run externally\", \"full toolset\", \"handle this externally\", \"external ai assistant\", \"run in opencode\", \"hand off externally\"]},\n    \"PARALLEL_DETACHED\":  {\"weight\": 4, \"keywords\": [\"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", \"share url\", \"share-url\", \"detached session\", \"separate session id\", \"own state directory\", \"spin up a new session\", \"background opencode session\", \"run this in the background\", \"fan out workers\", \"concurrent sessions\", \"isolated session\", \"run these in parallel\", \"spin off a few workers\", \"kick off several sessions at once\", \"run copies side by side\", \"fire off multiple runs at the same time\", \"farm this out to multiple workers\", \"run a bunch of these concurrently\", \"distribute the work across sessions\", \"batch this across sessions\", \"start several sessions at once\", \"spin up another instance\", \"new opencode instance\", \"run it as its own session\", \"own separate session\", \"side session\", \"run this independently\", \"additional worker\", \"background job\", \"separate instance\", \"own instance\", \"parallel run\", \"concurrent run\", \"session of its own\", \"spin up a worker\", \"worker pool\", \"run in parallel\"]},\n    \"CROSS_AI_HANDBACK\":  {\"weight\": 4, \"keywords\": [\"spec kit\", \"spec-kit\", \"spec_kit\", \"code graph\", \"memory_search\", \"session_bootstrap\", \"skill advisor\", \"cross-ai handback\", \"hand back to opencode\", \"bridge back to opencode\", \"opencode as a bridge\", \"non-anthropic cli\", \"project's memory database\", \"structural code index\", \"use the skill advisor\"]},\n    \"AGENT_DISPATCH\":     {\"weight\": 4, \"keywords\": [\"delegate\", \"agent\", \"deep-research\", \"deep-review\", \"ai-council\", \"review agent\", \"context agent\", \"dispatch an agent\", \"spawn an agent\", \"run a subagent\", \"invoke a subagent\", \"specialized subagent\", \"debug agent\", \"write agent\"]},\n    \"CROSS_REPO\":         {\"weight\": 3, \"keywords\": [\"cross-repo\", \"different repo\", \"--dir\", \"another repository\", \"remote opencode\", \"different repository\", \"target repo\", \"other codebase\", \"separate repository\", \"remote opencode server\", \"--attach\"]},\n    \"TEMPLATES\":          {\"weight\": 3, \"keywords\": [\"template\", \"prompt\", \"how to ask\", \"opencode prompt\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\", \"prompt framework\", \"prompt template\", \"how do i phrase this\", \"copy-paste template\", \"prompt quality\", \"prompt craft\", \"costar framework\", \"example prompt\"]},\n    \"PATTERNS\":           {\"weight\": 3, \"keywords\": [\"pattern\", \"workflow\", \"orchestrate\", \"session continue\", \"resume session\", \"integration pattern\", \"dispatch pattern\", \"continue the session\", \"resume a session\", \"session continuation\"]},\n    # WHY: DESIGN is an intent signal only — a deliberate cross-skill handoff to sk-design,\n    # not a same-skill resource bundle. It intentionally has NO RESOURCE_MAP entry: this skill\n    # hands design work off rather than owning design reference docs. The durable sk-design\n    # loading contract lives in the always-fires Design Standards Loading rule and the dispatch\n    # manifest (see ALWAYS rules 13-14); RESOURCE_MAP stays limited to same-skill markdown paths.\n    \"DESIGN\":             {\"weight\": 4, \"keywords\": [\"sk-design\", \"interface design\", \"frontend design\", \"visual design\", \"redesign the ui\", \"design foundations\", \"design tokens\", \"motion design\", \"micro-interactions\", \"design audit\", \"ui critique\", \"extract design system\", \"generate design.md\"]},\n}\n\nRESOURCE_MAP = {\n    \"EXTERNAL_DISPATCH\":  [\"references/cli_reference.md\", \"references/integration_patterns.md\"],\n    \"PARALLEL_DETACHED\":  [\"references/integration_patterns.md\", \"assets/prompt_templates.md\"],\n    \"CROSS_AI_HANDBACK\":  [\"references/integration_patterns.md\", \"references/opencode_tools.md\"],\n    \"AGENT_DISPATCH\":     [\"references/agent_delegation.md\", \"assets/prompt_templates.md\"],\n    \"CROSS_REPO\":         [\"references/cli_reference.md\", \"references/opencode_tools.md\"],\n    \"TEMPLATES\":          [\"assets/prompt_templates.md\", \"references/cli_reference.md\"],\n    \"PATTERNS\":           [\"references/integration_patterns.md\", \"references/cli_reference.md\"],\n}\n\nLOADING_LEVELS = {\n    \"ALWAYS\": [\"references/cli_reference.md\", \"assets/prompt_quality_card.md\"],\n    \"ON_DEMAND_KEYWORDS\": [\"full reference\", \"all templates\", \"deep dive\", \"complete guide\", \"opencode agent\", \"opencode prompt\", \"share url\", \"ablation\", \"worker farm\", \"self-invocation\", \"memory handback\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\"],\n    \"ON_DEMAND\": [\"references/opencode_tools.md\", \"assets/prompt_templates.md\"],\n}\n\nUNKNOWN_FALLBACK_CHECKLIST = [\n    \"Is the user asking about OpenCode CLI specifically?\",\n    \"Does the task need the project's full plugin / skill / MCP runtime?\",\n    \"Is a parallel detached session what they want?\",\n    \"Is a non-Anthropic CLI handing back to OpenCode for a spec-kit workflow?\",\n]\n```\n\n**Call sequence** (using shared helpers from `shared_smart_router.md`):\n\n1. `discover_markdown_resources()` — recursively enumerate current `.md` files under existing `references/` and `assets/` folders at routing time.\n2. `_guard_in_skill()` + `load_if_available()` — sandbox paths to this skill, reject non-markdown loads, skip missing files, and suppress duplicates.\n3. `score_intents(task)` and `select_intents(scores, ambiguity_delta=1.0)` — preserve provider-specific weighted intent scoring and top-2 ambiguity handling.\n4. ALWAYS-load `LOADING_LEVELS[\"ALWAYS\"]`, then return `UNKNOWN_FALLBACK` with `UNKNOWN_FALLBACK_CHECKLIST` when max score is 0.\n5. CONDITIONAL-load existing `RESOURCE_MAP[intent]` entries via `load_if_available()`, ON_DEMAND-load keyword matches, and return a notice when no intent-specific knowledge base is available beyond always-load resources.\n\nThe `route_opencode_resources(task)` function body lives in [`shared_smart_router.md`](../../system-spec-kit/references/cli/shared_smart_router.md) — substitute `<PROVIDER>` = `opencode`.\n\n---\n\n## 3. HOW IT WORKS\n\n### Prerequisites\n\n```bash\n# Verify installation (cli-opencode v1.0.0 is pinned to opencode v1.3.17)\nopencode --version | grep -q '^1\\.' || echo \"Not installed or version drift. See references/cli_reference.md §9.\"\n\n# Self-invocation guard\nenv | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n\n# Authentication — providers configured via opencode providers (alias auth)\nopencode providers\n```\n\n**Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans). Full per-provider login shapes and the configured-provider list: `references/cli_reference.md` §4.\n\n### Provider Auth Pre-Flight (Smart Fallback)\n\n**MANDATORY before any first dispatch in a session.** The default provider may not be logged in — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run the pre-flight once per session, cache the result, and re-run only on an auth failure.\n\nThe one-shot pre-flight bash, the per-provider decision trees, the user-facing prompt templates for missing providers, and the error-recovery contract live in [`references/cli_reference.md`](./references/cli_reference.md) §4 — do not duplicate them here. Never substitute a model the user didn't approve; ASK when the default is unavailable.\n\n### Default Invocation (Skill Default)\n\n**Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>` (pinned to avoid CWD ambiguity). Direct DeepSeek is the default provider — elevated reasoning at low cost for routine dispatches.\n\nUse `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n\n> **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run` — current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails outright. The default agent runs when `--agent` is omitted, which is correct for almost every dispatch. **To target a specific agent profile, describe the role in the prompt body instead** (e.g. open with \"Act as a code-review agent: …\"); only pass `--agent <name>` after confirming acceptance via `opencode run --help` on the installed version.\n\nHonor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n\n### Core Invocation Pattern\n\nCore flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n\n> **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation — without it, opencode can inherit parent-terminal stdin and hang. See `references/integration_patterns.md` §6.\n\n> **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text as raw prose. Execute a registered command via `opencode run --command <family>/<name> [flags] \"<args>\"` (becomes `$ARGUMENTS`; e.g. `memory/search` for `/memory:search`). Full semantics: `references/cli_reference.md` §4.\n\n### Model Selection\n\nRun `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default: `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API). Alternates (all omit `--agent`): MiniMax Token Plan/Direct API `MiniMax-M3`, Xiaomi Token Plan/Direct API `mimo-v2.5-pro` (+ low-latency `-ultraspeed`), Kimi For Coding `k2p7` (256k, subscription), Z.AI GLM Coding Plan `glm-5.2` (1M, subscription), and the OpenAI GPT-5.6 catalog (`gpt-5.6-sol` flagship default; bare/Sol/Terra/Luna x base/Fast/Pro, `--variant` up to `xhigh`). Full model table, per-provider `--variant` mapping, and model-specific operational caveats: `references/cli_reference.md` §5.\n\nShared small-model facts, context defaults, quota pools, and fallback targets live in `../../sk-prompt/prompt-models/assets/model_profiles.json`.\n\n### OpenCode Agent Delegation\n\nThe calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n\n#### Primary agents — directly invokable via `--agent`\n\nOpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Never pass `--agent general`** — it is rejected at the top level; the default agent (used when `--agent` is omitted) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` confirms top-level acceptance; otherwise state the role in the prompt body.\n\n#### Subagents — dispatched as Task subagents from a primary\n\nThese live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n\n1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by `orchestrate` via the Task tool. Route through `--agent orchestrate` and let it dispatch the relevant subagent.\n2. **`ai-council`** — dispatched via `/deep:ai-council` or `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`).\n3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>`. `orchestrate` is an authorized **caller/coordinator only** — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop.\n\nSee [agent_delegation.md](./references/agent_delegation.md) for the complete agent roster and dispatch patterns.\n\n### Unique OpenCode Strengths\n\nFull project runtime loading, detached sessions, JSON event streams, agent routing, cross-repo/server dispatch, session continuation, and plugin-disable debugging.\n\n### Essential Commands\n\nDefault invocation for external runtime handback; `--share --port <N>` only for explicit detached sessions; `--agent orchestrate` for generic subagent routing; `--dir` for cross-repo dispatch.\n\n### Error Handling\n\nInstall missing binaries, refuse ambiguous self-invocation, run provider pre-flight for model/auth errors, check version drift for unknown flags, force `--format json` for empty streams, add `</dev/null` for background loops, confirm `--share`, use `--pure` only for plugin crashes, inspect state logs for stuck sessions.\n\n---\n\n## 4. RULES\n\n### ✅ ALWAYS\n\n1. Verify OpenCode CLI is installed before first invocation; confirm version baseline against v1.3.17 (drift handling per `references/cli_reference.md` §9).\n2. **Run the self-invocation guard before dispatch** (ADR-001): Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for `opencode` parent, Layer 3 `~/.opencode/state/<id>/lock` probe. Trip on ANY positive — refuse unless prompt has explicit parallel-session keywords.\n3. Pin model + variant + format + dir explicitly — **no `--agent`** (see the Default Invocation note: current opencode rejects a top-level `--agent general`; put any agent-profile request in the prompt body). Default: `--model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root>`. Honor user overrides verbatim (e.g. `deepseek/deepseek-v4-pro`, `minimax-coding-plan/MiniMax-M3`, `minimax/MiniMax-M3`, `xiaomi-token-plan-ams/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro-ultraspeed`, `openai/gpt-5.6-sol-pro`).\n4. Pass `--format json` unless the calling AI explicitly wants formatted output — JSON event stream is what external runtimes parse incrementally.\n5. **Append `</dev/null` to every non-interactive `opencode run` invocation** that redirects stdout and/or stderr to files OR runs inside `while read` loops. opencode v1.14.39 reads stdin at startup before session creation; without explicit closed stdin, automation hangs forever at 0% CPU after the `+60s service=snapshot prune=7.days cleanup` log line. Position: AFTER the prompt positional argument, BEFORE the `> stdout 2> stderr` redirects. Foreground `| tail` happens to provide closed stdin (pipe stage upstream is empty) and accidentally bypasses the bug, but `> stdout.log 2> stderr.log` does not. The 9-character `</dev/null` redirect provides immediate EOF on stdin, unblocking the dispatch. **DO NOT auto-kill external operator-owned opencode sessions** when sweeping orphans between dispatches; exclude `opencode run` from pkill (per 2026-05-23 operator directive captured in memory `feedback_proactive_orphan_cleanup.md`). See `references/integration_patterns.md` §6 + memory `feedback_opencode_run_requires_dev_null_stdin.md` + CHANGELOG-2026-05-08-tool-name-regex-fix.md §Fix 4.\n6. **Pass the spec folder to the dispatched session** in the prompt: if the calling AI has an active Gate-3 spec folder, include `Spec folder: <path> (pre-approved, skip Gate 3)`. If none, ASK the user before delegating — the dispatched session cannot answer Gate 3 interactively in non-interactive `run` mode.\n7. **Prompt construction & model-craft (cli-* family precedence).** Compose every dispatch prompt via the 3-tier rule canonical in `../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md`:\n   1. **Fast path (default).** Build from the local `assets/prompt_quality_card.md`, which delegates the framework table + CLEAR check to the canonical card.\n   2. **Model override (mandatory for a profiled model).** If the target model has a profile at `../../sk-prompt/prompt-models/references/models/<id>.md`, that profile OVERRIDES the cross-model default. The **sk-prompt/prompt-models** hub owns per-model prompt-craft (framework + scaffold + gotchas, mirroring `sk-prompt/prompt-models/assets/model_profiles.json` `recommended_frameworks`); consult it before composing for any small model.\n   3. **Deep path (escalation).** Dispatch `@prompt-improver` via the Task tool (never load full `sk-prompt` inline) when any canonical **Tier 3** trigger applies — the trigger list lives in `../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` under \"Tier 3 — Deep path\"; do not re-enumerate it here.\n8. Validate dispatched session output: parse JSON events incrementally (tool calls, partial messages, final summary), run syntax checks if code generated, and cross-reference against project standards via `sk-code` surface detection plus its code-review mode when findings-first review is requested (see ALWAYS rule 12).\n9. Capture stderr (`2>&1`) to catch tool errors and warnings.\n10. Classify the use case (1 / 2 / 3) before dispatching — the smart router refuses dispatches that do not map to one of the three.\n11. **Run the Provider Auth Pre-Flight once per session** (see §3 Provider Auth Pre-Flight). Cache the configured-providers list. If the default `deepseek` is missing, ASK the user — never silently substitute the model. If a later dispatch returns an auth error, invalidate the cache and rerun the pre-flight before retrying.\n12. **Code Standards Loading (surface-aware contract)** — When dispatching for code review or code generation, instruct the dispatched session to: (1) load `sk-code`; (2) let `sk-code` emit a surface tag matching the detected stack from markers and target files; (3) load the selected surface resources and run its verification commands; (4) load `sk-code`'s code-review mode only for formal findings-first review output. Fallback: if the surface cannot be determined confidently, ask for the runtime surface and verification command set. NEVER hardcode obsolete sibling code skills in dispatch prompts.\n13. **Design Standards Loading (surface-aware contract)** — When dispatching for design or UI work, instruct the dispatched session to: (1) load `sk-design` (the hub); (2) let the hub resolve a `workflowMode` through `mode-registry.json` (interface / foundations / motion / audit / md-generator / design-mcp-open-design); (3) load the selected mode packet, set the design register, and run that mode's design verification; (4) if the work feeds Open Design, carry the `design-mcp-open-design` pairing (a nested transport packet of the hub) — the transport never decides taste. Fallback: if the design mode cannot be determined confidently, ask for the surface and design intent. NEVER treat `mcp-figma` or `design-mcp-open-design` as the taste authority, or hardcode obsolete flat design skills in dispatch prompts.\n14. **Pass the design dispatch manifest to the dispatched session** — when dispatching design or UI work, inline a `DESIGN_DISPATCH_MANIFEST v1` block in the prompt (the child cannot resolve skill paths, so the manifest travels in the payload, not by reference): `skDesignLoaded` true, `register` resolved to `Brand` or `Product` (never `unknown`), registry-valid `workflowModes`, `dials`, `loadedFiles`, and `proofDemandBack`. If the manifest cannot be assembled — `sk-design` not loaded, register unresolved, or no registry-valid mode — ASK before launching the child rather than starting a silent design dispatch. The child returns the demanded proof; the parent reconciles it on the return path.\n15. **Destructive-scope-violation prevention (RM-8) for deep-loop dispatches** — The structured permissions-matrix gate (`permissions-gate.ts`; schema and design in `references/permissions_matrix.md`) is built and unit-tested but has ZERO production callers today — no `opencode run` dispatch path invokes it, so a loaded `--permissions-matrix <path>` config or recipe field is NOT currently enforced and does NOT bypass anything. Regardless of whether a matrix config is present, any non-interactive `opencode run` with `--dangerously-skip-permissions` against a populated worktree MUST apply the four-layer mitigation — it is the only active protection today: (L1) rendered prompt contains literal `BANNED OPERATIONS` and `ALLOWED WRITE PATHS`; (L2) `--dir` points at a fresh `git worktree`; (L3) main `git status` clean OR committed, recovery-baseline commit hash recorded; (L4) for multi-phase / phase-parent targets, prefer `cli-copilot` + `gpt-5.6-sol --reasoning-effort high` (verify `gpt-5.6-sol` availability on the Copilot surface — unverified, carried over from a gpt-5.5-era check; if absent, pick an available Copilot model, don't silently fall back to the risky default) over `deepseek-v4-pro`. Background: on 2026-05-04 an `opencode-go/deepseek-v4-pro` dispatch under `/deep:review:auto` deleted 44 files across two phase folders because the only safeguard was prose and `--dangerously-skip-permissions` granted unrestricted FS write. Full incident + root cause + checklist: `references/destructive_scope_violations.md`.\n16. **Single-dispatch discipline (operator-gated, session-scoped)** — Default: launch ONE cli-* dispatch at a time across the cli-* family (cli-opencode, cli-claude-code). Wait for the dispatched agent's work to return, verify outputs exist, then SIGKILL only the dispatch THIS skill started: capture its PID at launch (`opencode run ... & OC_PID=$!`) and kill that captured PID directly plus its own orphan children (`kill -9 \"$OC_PID\" 2>/dev/null; pkill -9 -P \"$OC_PID\" 2>/dev/null`), then apply the same PID-scoped `gtimeout` / `positional_scoring_fallback:app` cleanup. (A backgrounded `opencode run &` is NOT a process-group leader unless launched with `setsid`/`set -m`, so a negative-PID group kill would target a nonexistent group and miss the process — kill the captured PID directly.) **Kill only the dispatch you started, by captured PID; never a blanket `pkill -9 -f \"opencode run\"` pattern — see Rule 5** (a blanket match kills operator-owned `opencode run` sessions too). Only launch the next dispatch (this skill OR a sibling) after the prior one is dead and RSS has dropped. **Within a deep-flow session** (deep-review / deep-research): the operator authorizes the whole multi-iteration session at start — iterations chain back-to-back with kill-between as the safety mechanism, NOT a per-iteration operator confirmation prompt. **Exception (cross-skill parallel)**: when the operator explicitly authorizes N parallel dispatches, run N concurrently — but still SIGKILL each by its own captured PID as its work returns.\n17. **Set `AI_SESSION_CHILD=1` in the dispatched session's env** when sessions may be launched through the per-session worktree wrapper (`.opencode/bin/worktree-session.sh`). A dispatched `opencode run` is an orchestrated sub-session, not a new top-level session, so it must SHARE the parent's worktree rather than allocate its own. The wrapper checks `AI_SESSION_CHILD` (plus a `git --git-common-dir` structural backstop) and exec's in place when set. Pattern: `AI_SESSION_CHILD=1 opencode run ... </dev/null`. Harmless when the wrapper is not in use. See `.opencode/bin/README.md` → \"Worktree session isolation\". Prepend `MK_SPEC_GATE_ENFORCE=0` next to it so a dispatched child never inherits an enforced spec-gate from the parent shell (belt-and-suspenders alongside the wrapper's own neutralization and the core's `AI_SESSION_CHILD` deny-narrowing): `MK_SPEC_GATE_ENFORCE=0 AI_SESSION_CHILD=1 opencode run ... </dev/null`.\n\n### ⛔ NEVER\n\n1. Invoke this skill from within OpenCode itself for a self-dispatch — refuse with the documented error message; use a sibling cli-* / fresh shell / parallel-session keywords.\n2. Pass `--share` without operator confirmation (CHK-033) — share URL exposes session contents.\n3. Trust dispatched session output blindly for security-sensitive code, send sensitive data (API keys, passwords, credentials) in prompts, or hammer the API with rapid sequential calls.\n4. Use `--pure` outside of plugin debugging (disabling plugins removes the entire point of cli-opencode dispatch).\n5. Nest `opencode run` inside a dispatched session's tool calls — use OpenCode's native Task tool for sub-agent dispatch.\n\n### ⚠️ ESCALATE IF\n\n1. OpenCode CLI is not installed and user has not acknowledged (provide `brew install opencode` or `curl -fsSL https://opencode.ai/install | bash`).\n2. Operator wants to publish a `--share` URL — get explicit confirmation per CHK-033.\n3. Binary version differs from the v1.3.17 baseline — run `opencode --version` and `opencode run --help`; surface drift and fall back or require approval.\n4. Smart router cannot map the prompt to one of the three use cases — surface the disambiguation checklist from UNKNOWN_FALLBACK.\n5. Self-invocation guard trips AND the prompt is ambiguous — surface the refusal with three remediation options (sibling cli-* / fresh shell / parallel-session keywords).\n\n### Memory Handback Protocol\n\nWhen the calling AI needs to preserve session context from an OpenCode CLI delegation, run the canonical 7-step procedure (extract `MEMORY_HANDBACK` section → build structured JSON → scrub secrets → invoke `generate-context.js` via `--stdin`/`--json`/temp-file → `memory_index_scan`). Full procedure and caveats: [`system-spec-kit/references/cli/memory_handback.md`](../../system-spec-kit/references/cli/memory_handback.md).\n\nFor read-only or hook-style recovery, use the daemon-backed CLI front doors instead of spawning OpenCode: `node .opencode/bin/spec-memory.cjs <tool>`, `node .opencode/bin/code-index.cjs <tool>`, or `node .opencode/bin/skill-advisor.cjs <tool>`. Prompt-time paths must probe warm sockets or pass `--warm-only`; exit `75` is retryable daemon/IPC unavailability, not a model failure.\n\nOpenCode-specific Memory Epilogue template: see [assets/prompt_templates.md](./assets/prompt_templates.md) §14.\n\nExample invocation:\n```bash\nprintf '%s' \"$JSON_PAYLOAD\" | node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --stdin [spec-folder]\n```\n\n---\n\n## 5. REFERENCES AND RELATED RESOURCES\n\n### Core References\n\n- [cli_reference.md](./references/cli_reference.md) - Full subcommand/flag reference, provider auth pre-flight, models, version drift\n- [integration_patterns.md](./references/integration_patterns.md) - 3 use cases, decision tree, silent stdin\n- [self_invocation_guard.md](./references/self_invocation_guard.md) - ADR-001 layered bash + python detection contract\n- [opencode_tools.md](./references/opencode_tools.md) - Unique value props vs sibling cli-* skills\n- [agent_delegation.md](./references/agent_delegation.md) - Agent routing matrix, leaf-agent constraints\n- [destructive_scope_violations.md](./references/destructive_scope_violations.md) - RM-8 incident, root cause, four-layer prevention playbook\n\n### Templates and Assets\n\n- [prompt_templates.md](./assets/prompt_templates.md) - Copy-paste templates per use case + agent + handback\n- [prompt_quality_card.md](./assets/prompt_quality_card.md) - Executor-specific model overrides; delegates framework/CLEAR check to canonical card\n\n### Shared (cli-* family)\n- [shared_smart_router.md](../../system-spec-kit/references/cli/shared_smart_router.md) - Helper-function bodies for the smart router.\n- [memory_handback.md](../../system-spec-kit/references/cli/memory_handback.md) - Canonical 7-step Memory Handback procedure.\n\n### External\n- [OpenCode GitHub](https://github.com/sst/opencode) - Official repository\n- [OpenCode Install](https://opencode.ai/install) - Standalone installer entry point\n- [OpenCode Documentation](https://opencode.ai/docs) - Official docs\n\n### Reference Loading Notes\n\n- Load only references needed for current intent.\n- Smart Routing (Section 2) is the single routing authority.\n- `cli_reference.md` and `prompt_quality_card.md` are ALWAYS loaded as baseline.\n- The router discovers reference, asset, and script docs dynamically — task-specific resources from `references/`, templates from `assets/`, and automation from `scripts/` when present.\n\n### Related Skills\n\n`cli-claude-code` and `cli-opencode` for sibling cross-AI dispatch; `system-spec-kit` for handback; `sk-code` plus the selected overlay for generated code; `system-deep-loop` for loop execution (its `research` and `review` modes); and `mcp-code-mode` for MCP-backed tools.\n\n---\n\n## 6. SUCCESS CRITERIA\n\n### Task Completion\n\n- OpenCode CLI invoked with the correct subcommand, flags, model, agent, variant, format, and dir.\n- Self-invocation guard checked before dispatch — refused when appropriate.\n- Use case (1 / 2 / 3) classified explicitly before invocation.\n- JSON event stream captured, parsed incrementally, validated, integrated.\n- No security vulnerabilities introduced from generated code.\n- `--share` URLs opt-in with operator confirmation per CHK-033.\n- Background dispatches in `while read` loops include `</dev/null` redirect.\n- Memory Handback extracted and saved through `generate-context.js` when applicable.\n\n### Skill Quality\n\n- All numbered sections present and correctly ordered.\n- Smart routing covers all intent signals with UNKNOWN_FALLBACK.\n- Reference files provide deep-dive content without duplication.\n- Self-invocation guard pseudocode reproduced in Section 2 mirrors ADR-001.\n\n---\n\n## 7. INTEGRATION POINTS\n\n### Framework Integration\n\nThis skill operates within the behavioral framework defined in [AGENTS.md](../../../../AGENTS.md).\n\nKey integrations:\n- **Gate 2**: Skill routing via the Skill Advisor Hook (or `skill_advisor.py` fallback)\n- **Tool Routing**: Per AGENTS.md Section 6 decision tree\n- **Memory**: Context preserved via Spec Kit Memory MCP (`generate-context.js`)\n- **Validation**: `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh` for spec-folder workflows\n\n**Tool roles**: Bash dispatches the CLI; Read/Glob/Grep validate output and probe `~/.opencode/state/` for session locks.","lineStart":1,"lineEnd":353,"totalLines":353,"truncated":false}},"title":".opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md","time":{"start":1784210482329,"end":1784210482336}},"metadata":{"openai":{"itemId":"fc_064be4f4737f386a016a58e4320508819493f89c58106fc4d9"}},"id":"prt_f6b3b645a001sYZJA1a4dhV8Bh","sessionID":"ses_094c57e18ffemFIYitl0QMkdbq","messageID":"msg_f6b3b3834001EaP0rqt9trJmH4"}}
