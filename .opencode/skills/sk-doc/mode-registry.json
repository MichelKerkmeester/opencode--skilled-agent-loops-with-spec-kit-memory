    "workflowMode": "Public hub/mode key; stable identity used by the hub router and this registry.",
    "packetKind": "Axis discriminator: workflow for all sk-doc packets (no surface packets).",
    "backendKind": "template-scaffold for the create-* document generators; doc-quality for the validate/score/optimize-existing-doc workflow."
  },
