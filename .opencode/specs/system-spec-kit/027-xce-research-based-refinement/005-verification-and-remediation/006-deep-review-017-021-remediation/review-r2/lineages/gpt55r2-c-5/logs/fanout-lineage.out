 = Date.now();\n\n  Line 736:     state.loadProgressAt = state.loadStartedAt;\n\n  Line 737:     state.loadingPromise = (async () => {\n\n  Line 738:       const start = state.loadStartedAt;\n\n  Line 741:           modelName: state.modelName,\n\n  Line 742:           dtype: state.dtype,\n\n  Line 746:             state.loadProgressAt = startedAt;\n\n  Line 750:         state.extractor = normalized.extractor;\n\n  Line 751:         state.device = normalized.device;\n\n  Line 752:         state.loadTimeMs = normalized.loadTimeMs;\n\n  Line 756:             await runExtractor(state.extractor, selfWarmInput);\n\n  Line 765:         state.serverState = 'ready';\n\n  Line 766:         return state.extractor;\n\n  Line 768:         state.loadingPromise = null;\n\n  Line 769:         state.serverState = 'error';\n\n  Line 770:         state.lastError = error;\n\n  Line 775:     return state.loadingPromise;\n\n  Line 780:       state: state.serverState,\n\n  Line 781:       model: state.modelName,\n\n  Line 782:       dim: state.dim > 0 ? state.dim : null,\n\n  Line 783:       device: state.device,\n\n  Line 784:       loadTimeMs: state.loadTimeMs,\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"context-server|model-server-supervision|socketPath|socket|lease|owner|EADDRINUSE|chmod|unlink|lstat|stat|realpath|mkdtemp|tmpdir|process\\.kill|spawn","time":{"start":1781762572289,"end":1781762572344}},"metadata":{"openai":{"itemId":"fc_07da6bf364891ccd016a338a0c298481918f032e1d4854a44f"}},"id":"prt_ed9533fff001FCgYh8Kv6F4hFB","sessionID":"ses_126ae8584ffeIHNv72WQpy5bXJ","messageID":"msg_ed9531946001U8f8bpFlrAGpWX"}}
