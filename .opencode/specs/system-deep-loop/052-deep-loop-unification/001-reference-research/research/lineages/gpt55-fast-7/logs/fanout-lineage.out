{"type":"tool_use","timestamp":1783487503686,"sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","part":{"type":"tool","tool":"read","callID":"call_cbuet9Kg0C4qOH1glvCgajKl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","offset":250,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js</path>\n<type>file</type>\n<content>\n250:   }\n251: }\n252: \n253: function ensureLoopGuardArchiveDir(stateDir) {\n254:   const archiveDir = join(stateDir, LOOP_GUARD_ARCHIVE_DIR_NAME);\n255:   try {\n256:     mkdirSync(archiveDir, { recursive: true, mode: 0o700 });\n257:   } catch (_) {\n258:     return null;\n259:   }\n260:   return archiveDir;\n261: }\n262: \n263: // Deletes archived per-session state files whose mtime exceeds the archive\n264: // retention window. Called only from within the already-throttled sweep below,\n265: // so it does not need its own separate throttle.\n266: function pruneLoopGuardArchive(stateDir) {\n267:   const archiveDir = join(stateDir, LOOP_GUARD_ARCHIVE_DIR_NAME);\n268:   let entries;\n269:   try {\n270:     entries = readdirSync(archiveDir, { withFileTypes: true });\n271:   } catch (_) {\n272:     return;\n273:   }\n274:   const retentionMs = positiveIntFromEnv(LOOP_GUARD_ARCHIVE_RETENTION_DAYS_ENV, DEFAULT_ARCHIVE_RETENTION_DAYS) * MS_PER_DAY;\n275:   const now = Date.now();\n276:   for (const entry of entries) {\n277:     if (!entry.isFile()) continue;\n278:     const filePath = join(archiveDir, entry.name);\n279:     try {\n280:       const fileStats = statSync(filePath);\n281:       if (now - fileStats.mtimeMs > retentionMs) unlinkSync(filePath);\n282:     } catch (_) {\n283:       // Fail open on a single entry; the rest of the prune pass still runs.\n284:     }\n285:   }\n286: }\n287: \n288: /**\n289:  * Archive per-session loop-guard state files that have gone untouched past the\n290:  * active-retention window, then prune the archive itself. Throttled to once\n291:  * per sweep interval via runtimeState, mirroring mk-goal.js's\n292:  * sweepOrphanedActiveStates/maybePruneArchive pair.\n293:  *\n294:  * Every operation here is synchronous (readdirSync/statSync/renameSync), and\n295:  * this plugin's only other hook (tool.execute.before) is likewise free of any\n296:  * `await` before it touches loop-guard state files. Node runs synchronous code\n297:  * to completion before yielding the event loop, so a sweep in progress cannot\n298:  * interleave with a concurrent dispatch's state write -- no separate mutation\n299:  * queue is needed the way mk-goal.js's fully-async I/O requires.\n300:  *\n301:  * @param {string} stateDir - loop-guard state directory\n302:  * @param {{ lastLoopGuardSweepAtMs?: number }} runtimeState - per-plugin-instance throttle state\n303:  */\n304: function sweepStaleLoopGuardStates(stateDir, runtimeState) {\n305:   try {\n306:     const intervalMs = positiveIntFromEnv(LOOP_GUARD_SWEEP_INTERVAL_MS_ENV, DEFAULT_SWEEP_INTERVAL_MS);\n307:     const now = Date.now();\n308:     if (now - (runtimeState.lastLoopGuardSweepAtMs || 0) <= intervalMs) return;\n309:     runtimeState.lastLoopGuardSweepAtMs = now;\n310: \n311:     let entries;\n312:     try {\n313:       entries = readdirSync(stateDir, { withFileTypes: true });\n314:     } catch (_) {\n315:       return;\n316:     }\n317:     const archiveDir = ensureLoopGuardArchiveDir(stateDir);\n318:     if (!archiveDir) return;\n319: \n320:     const activeRetentionMs = positiveIntFromEnv(LOOP_GUARD_ACTIVE_RETENTION_DAYS_ENV, DEFAULT_ACTIVE_RETENTION_DAYS) * MS_PER_DAY;\n321:     for (const entry of entries) {\n322:       if (!entry.isFile() || !entry.name.endsWith('.json')) continue;\n323:       const sourcePath = join(stateDir, entry.name);\n324:       try {\n325:         const fileStats = statSync(sourcePath);\n326:         if (now - fileStats.mtimeMs <= activeRetentionMs) continue;\n327:         renameSync(sourcePath, join(archiveDir, entry.name));\n328:       } catch (_) {\n329:         // Fail open on a single entry; the rest of the sweep pass still runs.\n330:       }\n331:     }\n332: \n333:     pruneLoopGuardArchive(stateDir);\n334:   } catch (_) {\n335:     // Fail open: a sweep error must never affect session startup.\n336:   }\n337: }\n338: \n339: // ─────────────────────────────────────────────────────────────────────────────\n340: // 6. PLUGIN FACTORY\n341: // ─────────────────────────────────────────────────────────────────────────────\n342: \n343: /**\n344:  * Create the mk-deep-loop-guard OpenCode plugin hooks.\n345:  *\n346:  * Hard limits (by design, not oversight):\n347:  * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n348:  * - Does not catch a schema-valid, route-matched artifact that internally\n349:  *   does semantically wrong-mode work.\n350:  * - Loop-repeat detection is session-scoped and per-target-agent; it cannot\n351:  *   detect a cross-executor meta-loop (e.g. deep-research, deep-review,\n352:  *   deep-research again) -- only repeated hand-offs to the SAME executor.\n353:  * - Fails open on its own errors (missing/unreadable registry or state,\n354:  *   unexpected arg shapes) so a bug here never blocks unrelated, correctly-\n355:  *   routed work.\n356:  *\n357:  * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n358:  * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n359:  */\n360: export default async function MkDeepLoopGuardPlugin(ctx) {\n361:   const projectDir = ctx?.directory || process.cwd();\n362:   const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n363:   const loopStateDir = join(projectDir, LOOP_GUARD_STATE_DIR_RELATIVE_PATH);\n364:   const runtimeState = { lastLoopGuardSweepAtMs: 0 };\n365: \n366:   return {\n367:     async event(input = {}) {\n368:       try {\n369:         const type = input?.event?.type || input?.type;\n370:         if (type === 'session.created') sweepStaleLoopGuardStates(loopStateDir, runtimeState);\n371:       } catch (_) {\n372:         // Fail open: a sweep error must never affect session startup.\n373:       }\n374:     },\n375:     async 'tool.execute.before'(input, output) {\n376:       try {\n377:         if (!input || input.tool !== 'task') return;\n378:         const args = output && output.args;\n379:         if (!args || typeof args !== 'object') return;\n380: \n381:         const rawSubagentType = args.subagent_type || args.subagentType;\n382:         const targetAgent = resolveTargetIdentity(rawSubagentType, args.prompt);\n383:         if (!targetAgent) return;\n384: \n385:         // -- Check 1: Deep Route mode mismatch (existing behavior, identity-fixed) --\n386:         const registry = loadRegistryAgents(registryPath);\n387:         if (registry) {\n388:           const entry = registry.get(targetAgent);\n389:           if (entry) {\n390:             const declaredMode = declaredModeFromPrompt(args.prompt);\n391:             if (declaredMode && declaredMode !== entry.workflowMode) {\n392:               const detail = mismatchDetail(targetAgent, entry.workflowMode, declaredMode);\n393:               if (process.env[REJECT_MODE_ENV] === '1') throw new Error(detail);\n394:               appendWarningLog(loopStateDir, detail);\n395:             }\n396:           }\n397:         }\n398: \n399:         // -- Check 2: loop-like repeated hand-off to a command-owned loop executor --\n400:         if (LOOP_EXECUTOR_AGENTS.has(targetAgent) && input.sessionID) {\n401:           const commandDriven = ITERATION_MARKER_REGEX.test(args.prompt || '');\n402:           const count = recordLoopDispatch(loopStateDir, input.sessionID, targetAgent, commandDriven);\n403: \n404:           if (!commandDriven && count >= WARN_AT_COUNT) {\n405:             const detail = loopRepeatDetail(targetAgent, count);\n406:             if (count >= BLOCK_AT_COUNT && process.env[REJECT_LOOP_ENV] === '1') {\n407:               throw new Error(detail);\n408:             }\n409:             appendWarningLog(loopStateDir, detail);\n410:           }\n411:         }\n412:       } catch (err) {\n413:         if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n414:         // Fail open on any unexpected internal error -- never block unrelated dispatches.\n415:       }\n416:     },\n417:   };\n418: }\n\n(End of file - total 418 lines)\n</content>","metadata":{"preview":"  }\n}\n\nfunction ensureLoopGuardArchiveDir(stateDir) {\n  const archiveDir = join(stateDir, LOOP_GUARD_ARCHIVE_DIR_NAME);\n  try {\n    mkdirSync(archiveDir, { recursive: true, mode: 0o700 });\n  } catch (_) {\n    return null;\n  }\n  return archiveDir;\n}\n\n// Deletes archived per-session state files whose mtime exceeds the archive\n// retention window. Called only from within the already-throttled sweep below,\n// so it does not need its own separate throttle.\nfunction pruneLoopGuardArchive(stateDir) {\n  const archiveDir = join(stateDir, LOOP_GUARD_ARCHIVE_DIR_NAME);\n  let entries;\n  try {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","text":"  }\n}\n\nfunction ensureLoopGuardArchiveDir(stateDir) {\n  const archiveDir = join(stateDir, LOOP_GUARD_ARCHIVE_DIR_NAME);\n  try {\n    mkdirSync(archiveDir, { recursive: true, mode: 0o700 });\n  } catch (_) {\n    return null;\n  }\n  return archiveDir;\n}\n\n// Deletes archived per-session state files whose mtime exceeds the archive\n// retention window. Called only from within the already-throttled sweep below,\n// so it does not need its own separate throttle.\nfunction pruneLoopGuardArchive(stateDir) {\n  const archiveDir = join(stateDir, LOOP_GUARD_ARCHIVE_DIR_NAME);\n  let entries;\n  try {\n    entries = readdirSync(archiveDir, { withFileTypes: true });\n  } catch (_) {\n    return;\n  }\n  const retentionMs = positiveIntFromEnv(LOOP_GUARD_ARCHIVE_RETENTION_DAYS_ENV, DEFAULT_ARCHIVE_RETENTION_DAYS) * MS_PER_DAY;\n  const now = Date.now();\n  for (const entry of entries) {\n    if (!entry.isFile()) continue;\n    const filePath = join(archiveDir, entry.name);\n    try {\n      const fileStats = statSync(filePath);\n      if (now - fileStats.mtimeMs > retentionMs) unlinkSync(filePath);\n    } catch (_) {\n      // Fail open on a single entry; the rest of the prune pass still runs.\n    }\n  }\n}\n\n/**\n * Archive per-session loop-guard state files that have gone untouched past the\n * active-retention window, then prune the archive itself. Throttled to once\n * per sweep interval via runtimeState, mirroring mk-goal.js's\n * sweepOrphanedActiveStates/maybePruneArchive pair.\n *\n * Every operation here is synchronous (readdirSync/statSync/renameSync), and\n * this plugin's only other hook (tool.execute.before) is likewise free of any\n * `await` before it touches loop-guard state files. Node runs synchronous code\n * to completion before yielding the event loop, so a sweep in progress cannot\n * interleave with a concurrent dispatch's state write -- no separate mutation\n * queue is needed the way mk-goal.js's fully-async I/O requires.\n *\n * @param {string} stateDir - loop-guard state directory\n * @param {{ lastLoopGuardSweepAtMs?: number }} runtimeState - per-plugin-instance throttle state\n */\nfunction sweepStaleLoopGuardStates(stateDir, runtimeState) {\n  try {\n    const intervalMs = positiveIntFromEnv(LOOP_GUARD_SWEEP_INTERVAL_MS_ENV, DEFAULT_SWEEP_INTERVAL_MS);\n    const now = Date.now();\n    if (now - (runtimeState.lastLoopGuardSweepAtMs || 0) <= intervalMs) return;\n    runtimeState.lastLoopGuardSweepAtMs = now;\n\n    let entries;\n    try {\n      entries = readdirSync(stateDir, { withFileTypes: true });\n    } catch (_) {\n      return;\n    }\n    const archiveDir = ensureLoopGuardArchiveDir(stateDir);\n    if (!archiveDir) return;\n\n    const activeRetentionMs = positiveIntFromEnv(LOOP_GUARD_ACTIVE_RETENTION_DAYS_ENV, DEFAULT_ACTIVE_RETENTION_DAYS) * MS_PER_DAY;\n    for (const entry of entries) {\n      if (!entry.isFile() || !entry.name.endsWith('.json')) continue;\n      const sourcePath = join(stateDir, entry.name);\n      try {\n        const fileStats = statSync(sourcePath);\n        if (now - fileStats.mtimeMs <= activeRetentionMs) continue;\n        renameSync(sourcePath, join(archiveDir, entry.name));\n      } catch (_) {\n        // Fail open on a single entry; the rest of the sweep pass still runs.\n      }\n    }\n\n    pruneLoopGuardArchive(stateDir);\n  } catch (_) {\n    // Fail open: a sweep error must never affect session startup.\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. PLUGIN FACTORY\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Create the mk-deep-loop-guard OpenCode plugin hooks.\n *\n * Hard limits (by design, not oversight):\n * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n * - Does not catch a schema-valid, route-matched artifact that internally\n *   does semantically wrong-mode work.\n * - Loop-repeat detection is session-scoped and per-target-agent; it cannot\n *   detect a cross-executor meta-loop (e.g. deep-research, deep-review,\n *   deep-research again) -- only repeated hand-offs to the SAME executor.\n * - Fails open on its own errors (missing/unreadable registry or state,\n *   unexpected arg shapes) so a bug here never blocks unrelated, correctly-\n *   routed work.\n *\n * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n */\nexport default async function MkDeepLoopGuardPlugin(ctx) {\n  const projectDir = ctx?.directory || process.cwd();\n  const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n  const loopStateDir = join(projectDir, LOOP_GUARD_STATE_DIR_RELATIVE_PATH);\n  const runtimeState = { lastLoopGuardSweepAtMs: 0 };\n\n  return {\n    async event(input = {}) {\n      try {\n        const type = input?.event?.type || input?.type;\n        if (type === 'session.created') sweepStaleLoopGuardStates(loopStateDir, runtimeState);\n      } catch (_) {\n        // Fail open: a sweep error must never affect session startup.\n      }\n    },\n    async 'tool.execute.before'(input, output) {\n      try {\n        if (!input || input.tool !== 'task') return;\n        const args = output && output.args;\n        if (!args || typeof args !== 'object') return;\n\n        const rawSubagentType = args.subagent_type || args.subagentType;\n        const targetAgent = resolveTargetIdentity(rawSubagentType, args.prompt);\n        if (!targetAgent) return;\n\n        // -- Check 1: Deep Route mode mismatch (existing behavior, identity-fixed) --\n        const registry = loadRegistryAgents(registryPath);\n        if (registry) {\n          const entry = registry.get(targetAgent);\n          if (entry) {\n            const declaredMode = declaredModeFromPrompt(args.prompt);\n            if (declaredMode && declaredMode !== entry.workflowMode) {\n              const detail = mismatchDetail(targetAgent, entry.workflowMode, declaredMode);\n              if (process.env[REJECT_MODE_ENV] === '1') throw new Error(detail);\n              appendWarningLog(loopStateDir, detail);\n            }\n          }\n        }\n\n        // -- Check 2: loop-like repeated hand-off to a command-owned loop executor --\n        if (LOOP_EXECUTOR_AGENTS.has(targetAgent) && input.sessionID) {\n          const commandDriven = ITERATION_MARKER_REGEX.test(args.prompt || '');\n          const count = recordLoopDispatch(loopStateDir, input.sessionID, targetAgent, commandDriven);\n\n          if (!commandDriven && count >= WARN_AT_COUNT) {\n            const detail = loopRepeatDetail(targetAgent, count);\n            if (count >= BLOCK_AT_COUNT && process.env[REJECT_LOOP_ENV] === '1') {\n              throw new Error(detail);\n            }\n            appendWarningLog(loopStateDir, detail);\n          }\n        }\n      } catch (err) {\n        if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n        // Fail open on any unexpected internal error -- never block unrelated dispatches.\n      }\n    },\n  };\n}","lineStart":250,"lineEnd":418,"totalLines":418,"truncated":false}},"title":".opencode/plugins/mk-deep-loop-guard.js","time":{"start":1783487503681,"end":1783487503685}},"metadata":{"openai":{"itemId":"fc_0b96a31162c00165016a4ddc0f5b948191ba6d3305e6015d49"}},"id":"prt_f40239bfa001QTTy6OrearKdd9","sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","messageID":"msg_f40238b18001epY22vL8JteT8M"}}
