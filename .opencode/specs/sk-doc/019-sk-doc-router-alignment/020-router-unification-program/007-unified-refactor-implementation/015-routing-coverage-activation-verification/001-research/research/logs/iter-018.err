   308	  if (report.verdict === 'BLOCKED-BY-STRUCTURE'
   309	      || report.verdict === 'BLOCKED-BY-REGISTRY'
   310	      || report.verdict === 'BLOCKED-BY-ROUTE-GOLD') return 3;
