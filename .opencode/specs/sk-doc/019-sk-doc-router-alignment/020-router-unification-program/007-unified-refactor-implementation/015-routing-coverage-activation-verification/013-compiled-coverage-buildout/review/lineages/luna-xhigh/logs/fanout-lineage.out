both sides without editing\n\n  Line 205: // gate at all -- it unconditionally unions ANY near-tied (ambiguity-delta)\n\n  Line 208: // multi-target route must match a pre-declared, exactly-ordered composition\n\n  Line 209: // in policy.compositionRules, so an undeclared near-tie fails closed to\n\n  Line 218: // by the generic tie-break map: a generic score/tie-break sort cannot express\n\n  Line 256: function compileRegistry(input) {\n\n  Line 323:       ambiguityDelta: String(input.hubRouter.routerPolicy.ambiguityDelta),\n\n  Line 344:     ambiguityDelta: input.hubRouter.routerPolicy.ambiguityDelta,\n\n  Line 355:     tieBreak: scoreTieBreakOrder(input.hubRouter),\n\n  Line 358:     admissionLabels: ['positive-signal', 'zero-signal-defer', 'exclude:forbidden'],\n\n  Line 360:     effectivePolicyHash: policy.effectivePolicyHash,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/005-sk-prompt/lib/registry-compiler.cjs:\n  Line 96:     fail('ROUTER_MODE_DRIFT', 'router signal keys must match registry modes');\n\n  Line 102:   if (!Array.isArray(policy.tieBreak)\n\n  Line 103:     || canonicalize([...policy.tieBreak].sort(compareText)) !== canonicalize([...modeNames].sort(compareText))) {\n\n  Line 104:     fail('TIE_BREAK_INVALID', 'tie break must list each registered workflow exactly once');\n\n  Line 106:   if (!Number.isSafeInteger(policy.ambiguityDelta) || policy.ambiguityDelta < 0) {\n\n  Line 107:     fail('AMBIGUITY_DELTA_INVALID', 'ambiguity delta must be a non-negative integer');\n\n  Line 109:   for (const outcome of ['single', 'orderedBundle', 'defer']) {\n\n  Line 124: function compileRoutingModel(registry, hubRouter) {\n\n  Line 153:     ambiguityDelta: hubRouter.routerPolicy.ambiguityDelta,\n\n  Line 156:     tieBreak: [...hubRouter.routerPolicy.tieBreak],\n\n  Line 162:   const rows = routingModel.tieBreak.map((workflowMode) => {\n\n  Line 199: function compileRegistry(input) {\n\n  Line 225:   const destinations = routingModel.tieBreak.map((workflowMode) => {\n\n  Line 262:       targetWorkflowModes: [...routingModel.tieBreak],\n\n  Line 276:     referencedModes: [...routingModel.tieBreak],\n\n  Line 280:       ambiguityDelta: String(routingModel.ambiguityDelta),\n\n  Line 300:     effectivePolicyHash: policy.effectivePolicyHash,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/007-sk-doc/harness/build-artifacts.cjs:\n  Line 105: function compiledLeafPairsForDecision(snapshot, decision) {\n\n  Line 110:   return decision.route.targets.flatMap((entry) => {\n\n  Line 137:         rankCalls: evaluated.trace.matchedScores.length > 1 ? 1 : 0,\n\n  Line 140:       effectivePolicyHash: snapshot.policy.effectivePolicyHash,\n\n  Line 150:         ? evaluated.decision.route.targets.map((entryTarget) => (\n\n  Line 187:       effectivePolicyHash: snapshot.policy.effectivePolicyHash,\n\n  Line 217:     effectivePolicyHash: snapshot.policy.effectivePolicyHash,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/007-sk-doc/lib/router.cjs:\n  Line 35:   const matches = advisor.trust === 'live'\n\n  Line 37:     && advisor.effectivePolicyHash === policy.effectivePolicyHash\n\n  Line 39:   if (!matches) {\n\n  Line 63:         effectivePolicyHash: policy.effectivePolicyHash,\n\n  Line 68:     reason: 'advisor-live-identity-match',\n\n  Line 91:       effectivePolicyHash: snapshot.policy.effectivePolicyHash,\n\n  Line 115: function route(snapshot, selectionKind, modes) {\n\n  Line 126:       targets: modes.map((mode) => target(byMode.get(mode))),\n\n  Line 141:   const order = new Map(snapshot.routingModel.tieBreak.map((mode, index) => [mode, index]));\n\n  Line 187: // Mirrors router-replay.cjs's selectIntents (the legacy replay's own ambiguity\n\n  Line 188: // gate): keep only the modes within ambiguityDelta of the top score. `scores`\n\n  Line 189: // is already sorted (score desc, tie-break sub-order) by the caller, so the\n\n  Line 191: function contendingModes(scores, ambiguityDelta) {\n\n  Line 194:   return scores.filter((entry) => top - entry.score <= ambiguityDelta).map((entry) => entry.mode);\n\n  Line 206:     decision = negative('defer', { reason: 'dependency-failure', recovery: ['defer'] });\n\n  Line 208:     const matches = explicitMode(snapshot.routingModel, input.explicitMode);\n\n  Line 209:     if (matches.length === 1) decision = route(snapshot, 'single', [matches[0].workflowMode]);\n\n  Line 210:     else if (constraints.has('clarify') || matches.length > 1) {\n\n  Line 211:       decision = clarify(snapshot, built.request, matches.map((mode) => mode.workflowMode));\n\n  Line 212:     } else decision = negative('defer', { reason: 'no-match', recovery: [] });\n\n  Line 215:     const order = new Map(snapshot.routingModel.tieBreak.map((mode, index) => [mode, index]));\n\n  Line 224:         ? negative('defer', { reason: 'no-match', recovery: [] })\n\n  Line 227:       const contending = contendingModes(scores, snapshot.routingModel.ambiguityDelta);\n\n  Line 232:         || scores[0].score - scores[1].score > snapshot.routingModel.ambiguityDelta) {\n\n  Line 236:         // a \"known\" bundle combination -- every near-tied (ambiguity-delta)\n\n  Line 237:         // multi-intent match is unconditionally unioned into one route. The\n\n  Line 241:         // an undeclared near-tie cannot route here without a schema change\n\n  Line 243:         // .cjs's SUPPLEMENTAL_BUNDLE_RULES is where a genuinely near-tied\n\n  Line 256:       matchedScores: scores,\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"function (compile|det