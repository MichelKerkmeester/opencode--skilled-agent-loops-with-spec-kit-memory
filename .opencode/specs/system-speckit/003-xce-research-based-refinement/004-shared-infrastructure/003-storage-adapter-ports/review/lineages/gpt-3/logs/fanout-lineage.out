{"type":"tool_use","timestamp":1781144194818,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_O5kDQmcrcIQv5dnBaB4CEfxr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Graph Traversal\n3: // -------------------------------------------------------------------\n4: \n5: import type Database from 'better-sqlite3';\n6: import {\n7:   collectCausalWeightedNeighbors,\n8:   collectDependencyReachability,\n9:   collectDirectedReachability,\n10:   collectWeightedWalk,\n11:   type DirectedReachabilityOptions,\n12:   type WeightedWalkOptions,\n13:   type WeightedWalkResult,\n14: } from '../../graph/bfs-traversal.js';\n15: \n16: /** Node identifier accepted by graph traversal ports. */\n17: export type GraphTraversalNode = number | string;\n18: \n19: export type {\n20:   DirectedReachabilityOptions,\n21:   DirectedTraversalEdge,\n22:   WeightedTraversalEdge,\n23:   WeightedWalkOptions,\n24:   WeightedWalkResult,\n25: } from '../../graph/bfs-traversal.js';\n26: \n27: /**\n28:  * Traverses graph-shaped storage data without exposing the caller to the\n29:  * underlying database driver.\n30:  */\n31: export interface GraphTraversal {\n32:   /** Run a generic hop-capped weighted walk. */\n33:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n34:     options: WeightedWalkOptions<TNode>,\n35:   ): Map<TNode, WeightedWalkResult<TNode>>;\n36: \n37:   /** Collect all nodes reachable through directed edges from the roots. */\n38:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n39:     options: DirectedReachabilityOptions<TNode>,\n40:   ): TNode[];\n41: \n42:   /** Traverse causal-neighbor edges from memory IDs. */\n43:   collectCausalWeightedNeighbors(\n44:     seeds: readonly number[],\n45:     maxHops: number,\n46:     relationWeights: Readonly<Record<string, number>>,\n47:   ): Map<number, WeightedWalkResult<number>>;\n48: \n49:   /** Traverse dependency edges from parent paths to transitive children. */\n50:   collectDependencyReachability(roots: readonly string[]): string[];\n51: }\n52: \n53: /** better-sqlite3-backed graph traversal adapter. */\n54: export class BetterSqliteGraphTraversal implements GraphTraversal {\n55:   constructor(private readonly database: Database.Database) {}\n56: \n57:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n58:     options: WeightedWalkOptions<TNode>,\n59:   ): Map<TNode, WeightedWalkResult<TNode>> {\n60:     return collectWeightedWalk(options);\n61:   }\n62: \n63:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n64:     options: DirectedReachabilityOptions<TNode>,\n65:   ): TNode[] {\n66:     return collectDirectedReachability(options);\n67:   }\n68: \n69:   collectCausalWeightedNeighbors(\n70:     seeds: readonly number[],\n71:     maxHops: number,\n72:     relationWeights: Readonly<Record<string, number>>,\n73:   ): Map<number, WeightedWalkResult<number>> {\n74:     return collectCausalWeightedNeighbors(this.database, seeds, maxHops, relationWeights);\n75:   }\n76: \n77:   collectDependencyReachability(roots: readonly string[]): string[] {\n78:     return collectDependencyReachability(this.database, roots);\n79:   }\n80: }\n\n(End of file - total 80 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Graph Traversal\n// -------------------------------------------------------------------\n\nimport type Database from 'better-sqlite3';\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/** Node identifier accepted by graph traversal ports. */\nexport type GraphTraversalNode = number | string;\n\nexport type {\n  DirectedReachabilityOptions,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Graph Traversal\n// -------------------------------------------------------------------\n\nimport type Database from 'better-sqlite3';\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/** Node identifier accepted by graph traversal ports. */\nexport type GraphTraversalNode = number | string;\n\nexport type {\n  DirectedReachabilityOptions,\n  DirectedTraversalEdge,\n  WeightedTraversalEdge,\n  WeightedWalkOptions,\n  WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/**\n * Traverses graph-shaped storage data without exposing the caller to the\n * underlying database driver.\n */\nexport interface GraphTraversal {\n  /** Run a generic hop-capped weighted walk. */\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>>;\n\n  /** Collect all nodes reachable through directed edges from the roots. */\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[];\n\n  /** Traverse causal-neighbor edges from memory IDs. */\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>>;\n\n  /** Traverse dependency edges from parent paths to transitive children. */\n  collectDependencyReachability(roots: readonly string[]): string[];\n}\n\n/** better-sqlite3-backed graph traversal adapter. */\nexport class BetterSqliteGraphTraversal implements GraphTraversal {\n  constructor(private readonly database: Database.Database) {}\n\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>> {\n    return collectWeightedWalk(options);\n  }\n\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[] {\n    return collectDirectedReachability(options);\n  }\n\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>> {\n    return collectCausalWeightedNeighbors(this.database, seeds, maxHops, relationWeights);\n  }\n\n  collectDependencyReachability(roots: readonly string[]): string[] {\n    return collectDependencyReachability(this.database, roots);\n  }\n}","lineStart":1,"lineEnd":80,"totalLines":80,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","time":{"start":1781144194812,"end":1781144194817}},"metadata":{"openai":{"itemId":"fc_0448bb83f4aedebb016a2a1a82bbf88191a13da477a0d5672a"}},"id":"prt_eb4778ed4001VGBl57AYc1h7Xn","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477504d001YpWrWEAoItsibb"}}
{"type":"tool_use","timestamp":1781144194848,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_hUbYSH5W61CqJWOXeAXPlCcQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memo Storage\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type Database from 'better-sqlite3';\n6: import { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n7: \n8: export interface MemoRecordInput {\n9:   componentPath: string;\n10:   inputFingerprint: string;\n11:   codeHash: string;\n12:   outputBlob: string;\n13:   computedAt?: string;\n14: }\n15: \n16: export interface MemoRecord extends MemoRecordInput {\n17:   computedAt: string;\n18: }\n19: \n20: export interface DependencyEdgeInput {\n21:   parentPath: string;\n22:   childPath: string;\n23:   kind: string;\n24: }\n25: \n26: export interface DependencyEdge extends DependencyEdgeInput {\n27:   createdAt: string;\n28: }\n29: \n30: export interface InvalidationResult {\n31:   invalidatedPaths: string[];\n32:   deletedMemoRecords: number;\n33: }\n34: \n35: function assertPath(value: string, label: string): void {\n36:   if (typeof value !== 'string' || value.trim().length === 0) {\n37:     throw new Error(`${label} must be a non-empty string`);\n38:   }\n39: }\n40: \n41: export function ensureMemoStorageSchema(database: Database.Database): void {\n42:   database.exec(`\n43:     CREATE TABLE IF NOT EXISTS memoization_records (\n44:       component_path TEXT NOT NULL,\n45:       input_fingerprint TEXT NOT NULL,\n46:       code_hash TEXT NOT NULL,\n47:       output_blob TEXT NOT NULL,\n48:       computed_at TEXT NOT NULL DEFAULT (datetime('now')),\n49:       PRIMARY KEY (component_path, input_fingerprint, code_hash)\n50:     );\n51: \n52:     CREATE TABLE IF NOT EXISTS dependency_edges (\n53:       parent_path TEXT NOT NULL,\n54:       child_path TEXT NOT NULL,\n55:       kind TEXT NOT NULL,\n56:       created_at TEXT NOT NULL DEFAULT (datetime('now')),\n57:       PRIMARY KEY (parent_path, child_path, kind),\n58:       CHECK(parent_path != child_path)\n59:     );\n60: \n61:     CREATE INDEX IF NOT EXISTS idx_memoization_records_component\n62:       ON memoization_records(component_path);\n63:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_parent\n64:       ON dependency_edges(parent_path);\n65:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_child\n66:       ON dependency_edges(child_path);\n67:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_kind\n68:       ON dependency_edges(kind);\n69:   `);\n70: }\n71: \n72: function mapMemoRow(row: {\n73:   component_path: string;\n74:   input_fingerprint: string;\n75:   code_hash: string;\n76:   output_blob: string;\n77:   computed_at: string;\n78: }): MemoRecord {\n79:   return {\n80:     componentPath: row.component_path,\n81:     inputFingerprint: row.input_fingerprint,\n82:     codeHash: row.code_hash,\n83:     outputBlob: row.output_blob,\n84:     computedAt: row.computed_at,\n85:   };\n86: }\n87: \n88: function mapEdgeRow(row: {\n89:   parent_path: string;\n90:   child_path: string;\n91:   kind: string;\n92:   created_at: string;\n93: }): DependencyEdge {\n94:   return {\n95:     parentPath: row.parent_path,\n96:     childPath: row.child_path,\n97:     kind: row.kind,\n98:     createdAt: row.created_at,\n99:   };\n100: }\n101: \n102: export class MemoStore {\n103:   private dependencyEdgeCount: number;\n104:   private readonly graphTraversal: GraphTraversal;\n105: \n106:   constructor(\n107:     private readonly database: Database.Database,\n108:     graphTraversal: GraphTraversal = new BetterSqliteGraphTraversal(database),\n109:   ) {\n110:     ensureMemoStorageSchema(database);\n111:     this.graphTraversal = graphTraversal;\n112:     this.dependencyEdgeCount = this.countDependencyEdges();\n113:   }\n114: \n115:   private countDependencyEdges(): number {\n116:     const row = this.database.prepare(`\n117:       SELECT COUNT(*) AS edge_count\n118:       FROM dependency_edges\n119:     `).get() as { edge_count: number } | undefined;\n120:     return row?.edge_count ?? 0;\n121:   }\n122: \n123:   private insertDependencyEdge(edge: DependencyEdgeInput): void {\n124:     const result = this.database.prepare(`\n125:       INSERT OR IGNORE INTO dependency_edges (parent_path, child_path, kind)\n126:       VALUES (?, ?, ?)\n127:     `).run(edge.parentPath, edge.childPath, edge.kind) as { changes: number };\n128:     if (result.changes > 0) {\n129:       this.dependencyEdgeCount += result.changes;\n130:     }\n131:   }\n132: \n133:   getMemoRecord(componentPath: string, inputFingerprint: string, codeHash: string): MemoRecord | null {\n134:     const row = this.database.prepare(`\n135:       SELECT component_path, input_fingerprint, code_hash, output_blob, computed_at\n136:       FROM memoization_records\n137:       WHERE component_path = ?\n138:         AND input_fingerprint = ?\n139:         AND code_hash = ?\n140:       LIMIT 1\n141:     `).get(componentPath, inputFingerprint, codeHash) as Parameters<typeof mapMemoRow>[0] | undefined;\n142: \n143:     return row ? mapMemoRow(row) : null;\n144:   }\n145: \n146:   upsertMemoRecord(record: MemoRecordInput): void {\n147:     assertPath(record.componentPath, 'componentPath');\n148:     assertPath(record.inputFingerprint, 'inputFingerprint');\n149:     assertPath(record.codeHash, 'codeHash');\n150:     this.database.prepare(`\n151:       INSERT INTO memoization_records (\n152:         component_path,\n153:         input_fingerprint,\n154:         code_hash,\n155:         output_blob,\n156:         computed_at\n157:       ) VALUES (?, ?, ?, ?, COALESCE(?, datetime('now')))\n158:       ON CONFLICT(component_path, input_fingerprint, code_hash) DO UPDATE SET\n159:         output_blob = excluded.output_blob,\n160:         computed_at = excluded.computed_at\n161:     `).run(\n162:       record.componentPath,\n163:       record.inputFingerprint,\n164:       record.codeHash,\n165:       record.outputBlob,\n166:       record.computedAt ?? null,\n167:     );\n168:   }\n169: \n170:   deleteMemoRecords(componentPaths: readonly string[]): number {\n171:     const paths = Array.from(new Set(componentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n172:     if (paths.length === 0) {\n173:       return 0;\n174:     }\n175: \n176:     const placeholders = paths.map(() => '?').join(', ');\n177:     const result = this.database.prepare(`\n178:       DELETE FROM memoization_records\n179:       WHERE component_path IN (${placeholders})\n180:     `).run(...paths) as { changes: number };\n181:     return result.changes;\n182:   }\n183: \n184:   listDependencyEdges(parentPath?: string): DependencyEdge[] {\n185:     const rows = parentPath\n186:       ? this.database.prepare(`\n187:           SELECT parent_path, child_path, kind, created_at\n188:           FROM dependency_edges\n189:           WHERE parent_path = ?\n190:           ORDER BY parent_path, child_path, kind\n191:         `).all(parentPath) as Parameters<typeof mapEdgeRow>[0][]\n192:       : this.database.prepare(`\n193:           SELECT parent_path, child_path, kind, created_at\n194:           FROM dependency_edges\n195:           ORDER BY parent_path, child_path, kind\n196:         `).all() as Parameters<typeof mapEdgeRow>[0][];\n197: \n198:     return rows.map(mapEdgeRow);\n199:   }\n200: \n201:   addDependencyEdge(edge: DependencyEdgeInput): void {\n202:     assertPath(edge.parentPath, 'parentPath');\n203:     assertPath(edge.childPath, 'childPath');\n204:     assertPath(edge.kind, 'kind');\n205:     if (edge.parentPath === edge.childPath) {\n206:       throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n207:     }\n208:     if (this.dependencyEdgeCount > 0 && this.wouldCreateCycle(edge.parentPath, edge.childPath)) {\n209:       throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n210:     }\n211: \n212:     this.insertDependencyEdge(edge);\n213:   }\n214: \n215:   collectDependents(parentPaths: readonly string[]): string[] {\n216:     const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n217:     if (roots.length === 0 || this.dependencyEdgeCount === 0) {\n218:       return [];\n219:     }\n220: \n221:     return this.graphTraversal.collectDependencyReachability(roots).sort();\n222:   }\n223: \n224:   invalidateDependents(parentPaths: readonly string[], includeSources = false): InvalidationResult {\n225:     const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n226:     const invalidatedPaths = this.collectDependents(roots);\n227:     const deleteTargets = includeSources ? Array.from(new Set([...roots, ...invalidatedPaths])) : invalidatedPaths;\n228:     const deletedMemoRecords = this.deleteMemoRecords(deleteTargets);\n229:     return { invalidatedPaths, deletedMemoRecords };\n230:   }\n231: \n232:   private wouldCreateCycle(parentPath: string, childPath: string): boolean {\n233:     if (parentPath === childPath) {\n234:       return true;\n235:     }\n236: \n237:     return this.collectDependents([childPath]).includes(parentPath);\n238:   }\n239: }\n240: \n241: export function createMemoStore(\n242:   database: Database.Database,\n243:   graphTraversal?: GraphTraversal,\n244: ): MemoStore {\n245:   return new MemoStore(database, graphTraversal);\n246: }\n\n(End of file - total 246 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memo Storage\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n\nexport interface MemoRecordInput {\n  componentPath: string;\n  inputFingerprint: string;\n  codeHash: string;\n  outputBlob: string;\n  computedAt?: string;\n}\n\nexport interface MemoRecord extends MemoRecordInput {\n  computedAt: string;\n}\n\nexport interface DependencyEdgeInput {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memo Storage\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n\nexport interface MemoRecordInput {\n  componentPath: string;\n  inputFingerprint: string;\n  codeHash: string;\n  outputBlob: string;\n  computedAt?: string;\n}\n\nexport interface MemoRecord extends MemoRecordInput {\n  computedAt: string;\n}\n\nexport interface DependencyEdgeInput {\n  parentPath: string;\n  childPath: string;\n  kind: string;\n}\n\nexport interface DependencyEdge extends DependencyEdgeInput {\n  createdAt: string;\n}\n\nexport interface InvalidationResult {\n  invalidatedPaths: string[];\n  deletedMemoRecords: number;\n}\n\nfunction assertPath(value: string, label: string): void {\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    throw new Error(`${label} must be a non-empty string`);\n  }\n}\n\nexport function ensureMemoStorageSchema(database: Database.Database): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS memoization_records (\n      component_path TEXT NOT NULL,\n      input_fingerprint TEXT NOT NULL,\n      code_hash TEXT NOT NULL,\n      output_blob TEXT NOT NULL,\n      computed_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (component_path, input_fingerprint, code_hash)\n    );\n\n    CREATE TABLE IF NOT EXISTS dependency_edges (\n      parent_path TEXT NOT NULL,\n      child_path TEXT NOT NULL,\n      kind TEXT NOT NULL,\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (parent_path, child_path, kind),\n      CHECK(parent_path != child_path)\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_memoization_records_component\n      ON memoization_records(component_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_parent\n      ON dependency_edges(parent_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_child\n      ON dependency_edges(child_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_kind\n      ON dependency_edges(kind);\n  `);\n}\n\nfunction mapMemoRow(row: {\n  component_path: string;\n  input_fingerprint: string;\n  code_hash: string;\n  output_blob: string;\n  computed_at: string;\n}): MemoRecord {\n  return {\n    componentPath: row.component_path,\n    inputFingerprint: row.input_fingerprint,\n    codeHash: row.code_hash,\n    outputBlob: row.output_blob,\n    computedAt: row.computed_at,\n  };\n}\n\nfunction mapEdgeRow(row: {\n  parent_path: string;\n  child_path: string;\n  kind: string;\n  created_at: string;\n}): DependencyEdge {\n  return {\n    parentPath: row.parent_path,\n    childPath: row.child_path,\n    kind: row.kind,\n    createdAt: row.created_at,\n  };\n}\n\nexport class MemoStore {\n  private dependencyEdgeCount: number;\n  private readonly graphTraversal: GraphTraversal;\n\n  constructor(\n    private readonly database: Database.Database,\n    graphTraversal: GraphTraversal = new BetterSqliteGraphTraversal(database),\n  ) {\n    ensureMemoStorageSchema(database);\n    this.graphTraversal = graphTraversal;\n    this.dependencyEdgeCount = this.countDependencyEdges();\n  }\n\n  private countDependencyEdges(): number {\n    const row = this.database.prepare(`\n      SELECT COUNT(*) AS edge_count\n      FROM dependency_edges\n    `).get() as { edge_count: number } | undefined;\n    return row?.edge_count ?? 0;\n  }\n\n  private insertDependencyEdge(edge: DependencyEdgeInput): void {\n    const result = this.database.prepare(`\n      INSERT OR IGNORE INTO dependency_edges (parent_path, child_path, kind)\n      VALUES (?, ?, ?)\n    `).run(edge.parentPath, edge.childPath, edge.kind) as { changes: number };\n    if (result.changes > 0) {\n      this.dependencyEdgeCount += result.changes;\n    }\n  }\n\n  getMemoRecord(componentPath: string, inputFingerprint: string, codeHash: string): MemoRecord | null {\n    const row = this.database.prepare(`\n      SELECT component_path, input_fingerprint, code_hash, output_blob, computed_at\n      FROM memoization_records\n      WHERE component_path = ?\n        AND input_fingerprint = ?\n        AND code_hash = ?\n      LIMIT 1\n    `).get(componentPath, inputFingerprint, codeHash) as Parameters<typeof mapMemoRow>[0] | undefined;\n\n    return row ? mapMemoRow(row) : null;\n  }\n\n  upsertMemoRecord(record: MemoRecordInput): void {\n    assertPath(record.componentPath, 'componentPath');\n    assertPath(record.inputFingerprint, 'inputFingerprint');\n    assertPath(record.codeHash, 'codeHash');\n    this.database.prepare(`\n      INSERT INTO memoization_records (\n        component_path,\n        input_fingerprint,\n        code_hash,\n        output_blob,\n        computed_at\n      ) VALUES (?, ?, ?, ?, COALESCE(?, datetime('now')))\n      ON CONFLICT(component_path, input_fingerprint, code_hash) DO UPDATE SET\n        output_blob = excluded.output_blob,\n        computed_at = excluded.computed_at\n    `).run(\n      record.componentPath,\n      record.inputFingerprint,\n      record.codeHash,\n      record.outputBlob,\n      record.computedAt ?? null,\n    );\n  }\n\n  deleteMemoRecords(componentPaths: readonly string[]): number {\n    const paths = Array.from(new Set(componentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    if (paths.length === 0) {\n      return 0;\n    }\n\n    const placeholders = paths.map(() => '?').join(', ');\n    const result = this.database.prepare(`\n      DELETE FROM memoization_records\n      WHERE component_path IN (${placeholders})\n    `).run(...paths) as { changes: number };\n    return result.changes;\n  }\n\n  listDependencyEdges(parentPath?: string): DependencyEdge[] {\n    const rows = parentPath\n      ? this.database.prepare(`\n          SELECT parent_path, child_path, kind, created_at\n          FROM dependency_edges\n          WHERE parent_path = ?\n          ORDER BY parent_path, child_path, kind\n        `).all(parentPath) as Parameters<typeof mapEdgeRow>[0][]\n      : this.database.prepare(`\n          SELECT parent_path, child_path, kind, created_at\n          FROM dependency_edges\n          ORDER BY parent_path, child_path, kind\n        `).all() as Parameters<typeof mapEdgeRow>[0][];\n\n    return rows.map(mapEdgeRow);\n  }\n\n  addDependencyEdge(edge: DependencyEdgeInput): void {\n    assertPath(edge.parentPath, 'parentPath');\n    assertPath(edge.childPath, 'childPath');\n    assertPath(edge.kind, 'kind');\n    if (edge.parentPath === edge.childPath) {\n      throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n    }\n    if (this.dependencyEdgeCount > 0 && this.wouldCreateCycle(edge.parentPath, edge.childPath)) {\n      throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n    }\n\n    this.insertDependencyEdge(edge);\n  }\n\n  collectDependents(parentPaths: readonly string[]): string[] {\n    const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    if (roots.length === 0 || this.dependencyEdgeCount === 0) {\n      return [];\n    }\n\n    return this.graphTraversal.collectDependencyReachability(roots).sort();\n  }\n\n  invalidateDependents(parentPaths: readonly string[], includeSources = false): InvalidationResult {\n    const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    const invalidatedPaths = this.collectDependents(roots);\n    const deleteTargets = includeSources ? Array.from(new Set([...roots, ...invalidatedPaths])) : invalidatedPaths;\n    const deletedMemoRecords = this.deleteMemoRecords(deleteTargets);\n    return { invalidatedPaths, deletedMemoRecords };\n  }\n\n  private wouldCreateCycle(parentPath: string, childPath: string): boolean {\n    if (parentPath === childPath) {\n      return true;\n    }\n\n    return this.collectDependents([childPath]).includes(parentPath);\n  }\n}\n\nexport function createMemoStore(\n  database: Database.Database,\n  graphTraversal?: GraphTraversal,\n): MemoStore {\n  return new MemoStore(database, graphTraversal);\n}","lineStart":1,"lineEnd":246,"totalLines":246,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","time":{"start":1781144194842,"end":1781144194846}},"metadata":{"openai":{"itemId":"fc_0448bb83f4aedebb016a2a1a82bc04819185275c214ba0ffac"}},"id":"prt_eb4778eff001uqYKRsy1GCEHzY","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477504d001YpWrWEAoItsibb"}}
{"type":"tool_use","timestamp":1781144194883,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_CtWGg0g8thoU6h2S57DkkVbL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Causal Boost\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Causal neighbor boost and injection\n5: // Graph-traversal score boosting via causal edge relationships.\n6: // Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n7: // For results related to top seed results via weighted CTE.\n8: //\n9: // Sparse-First + Intent-Aware Traversal:\n10: // - Sparse-first policy — density < 0.5 disables community\n11: //   detection and constrains traversal to typed 1-hop expansion only.\n12: // - Intent-aware edge traversal — maps classified query intents\n13: //   to edge-type priority orderings; computes traversal score as:\n14: //   score = seedScore * edgePrior * hopDecay * freshness\n15: // Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\n16: import { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\n17: import { routeQueryConcepts } from './entity-linker.js';\n18: import { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n19: \n20: import type Database from 'better-sqlite3';\n21: \n22: /** Maximum graph traversal depth. Beyond 2 hops, signal degrades and queries become expensive. */\n23: const MAX_HOPS = 2;\n24: /** Per-hop boost cap. 0.05 keeps causal nudge subtle relative to semantic scores (~0.5–1.0). */\n25: const MAX_BOOST_PER_HOP = 0.05;\n26: /** Combined causal + session boost ceiling to prevent runaway amplification. */\n27: const MAX_COMBINED_BOOST = 0.20;\n28: /** Top fraction of result set used as graph walk seed nodes. */\n29: const SEED_FRACTION = 0.25;\n30: /** Absolute cap on seed nodes regardless of result set size. */\n31: const MAX_SEED_RESULTS = 5;\n32: \n33: // ───────────────────────────────────────────────────────────────\n34: // SPARSE-FIRST POLICY CONSTANTS\n35: // ───────────────────────────────────────────────────────────────\n36: /** Graph density threshold below which community detection is disabled\n37:  * and traversal is constrained to typed 1-hop expansion only.\n38:  * Density = edgeCount / totalMemories (see edge-density.ts). */\n39: const SPARSE_DENSITY_THRESHOLD = 0.5;\n40: \n41: /** Traversal depth used in sparse mode (1-hop typed expansion). */\n42: const SPARSE_MAX_HOPS = 1;\n43: \n44: /** Default traversal depth for typed traversal helper policies. */\n45: const DEFAULT_TYPED_TRAVERSAL_DEPTH = SPARSE_MAX_HOPS;\n46: \n47: // ───────────────────────────────────────────────────────────────\n48: // INTENT-AWARE EDGE TRAVERSAL\n49: // ───────────────────────────────────────────────────────────────\n50: /** Per-hop decay factor applied to traversal score. 1-hop = 1.0, 2-hop = 0.5. */\n51: const HOP_DECAY_BASE = 1.0;\n52: \n53: /**\n54:  * Intent-to-edge-type priority ordering.\n55:  * Maps each query intent to an ordered list of edge relation types.\n56:  * Earlier entries in the list receive higher edge prior scores.\n57:  *\n58:  * Scores are normalized: first-listed relation = 1.0, second = 0.75, remaining = 0.5.\n59:  */\n60: const INTENT_EDGE_PRIORITY: Record<string, string[]> = {\n61:   fix_bug:        ['CORRECTION', 'DEPENDS_ON', 'supersedes', 'caused'],\n62:   add_feature:    ['EXTENDS', 'DEPENDS_ON', 'enabled', 'derived_from'],\n63:   find_decision:  ['PREFERENCE', 'CORRECTION', 'supersedes', 'contradicts'],\n64:   // Defaults for other intents — use existing relation-weight ordering\n65:   understand:     ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n66:   find_spec:      ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n67:   refactor:       ['caused', 'derived_from', 'enabled', 'supports', 'supersedes', 'contradicts'],\n68:   security_audit: ['caused', 'contradicts', 'supersedes', 'enabled', 'supports', 'derived_from'],\n69: };\n70: \n71: /** Fallback priority list when intent is unrecognized. */\n72: const DEFAULT_EDGE_PRIORITY = ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'];\n73: \n74: /** Edge prior score tiers: 1st priority = 1.0, 2nd = 0.75, remaining = 0.5. */\n75: const EDGE_PRIOR_TIERS = [1.0, 0.75, 0.5];\n76: const DEFAULT_EDGE_PRIOR = 1.0;\n77: const FRESHNESS_DECAY_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;\n78: \n79: /**\n80:  * Relation-type weight multipliers for causal edge traversal.\n81:  * Applied during CTE accumulation so stronger relation types (supersedes)\n82:  * amplify the boost while weaker ones (contradicts) attenuate it.\n83:  *\n84:  * These multipliers serve a DIFFERENT purpose from RELATION_WEIGHTS in\n85:  * causal-edges.ts. causal-edges weights are applied during chain traversal\n86:  * scoring (getCausalChain), while these are applied during the causal-boost\n87:  * CTE walk (getNeighborBoosts) for search result amplification. The value\n88:  * ranges overlap but are tuned independently for their respective contexts:\n89:  *   - causal-edges: traversal strength propagation (range 0.8–1.5)\n90:  *   - causal-boost: search result boost amplitude (range 0.8–1.5)\n91:  */\n92: const RELATION_WEIGHT_MULTIPLIERS: Record<string, number> = {\n93:   supersedes: 1.5,\n94:   contradicts: 0.8,\n95:   caused: 1.0,\n96:   enabled: 1.0,\n97:   derived_from: 1.0,\n98:   supports: 1.0,\n99: };\n100: \n101: interface RankedSearchResult extends Record<string, unknown> {\n102:   id: number;\n103:   score?: number;\n104:   rrfScore?: number;\n105:   intentAdjustedScore?: number;\n106:   attentionScore?: number;\n107:   similarity?: number;\n108:   sessionBoost?: number;\n109:   baseScore?: number;\n110:   causalBoost?: number;\n111:   injectedByCausalBoost?: boolean;\n112: }\n113: \n114: interface CausalBoostMetadata {\n115:   enabled: boolean;\n116:   applied: boolean;\n117:   boostedCount: number;\n118:   injectedCount: number;\n119:   maxBoostApplied: number;\n120:   traversalDepth: number;\n121:   /** True when sparse-first policy was active (density < threshold) */\n122:   sparseModeActive?: boolean;\n123:   /** Intent used for edge traversal scoring (if typed traversal enabled) */\n124:   intentUsed?: string;\n125: }\n126: \n127: /** Options for applyCausalBoost — extended with sparse-first parameters. */\n128: interface CausalBoostOptions {\n129:   /** Graph density (edgeCount / totalMemories). Used for sparse-first gate. */\n130:   graphDensity?: number;\n131:   /** Classified query intent. Used for intent-aware edge priority mapping. */\n132:   intent?: string;\n133:   /** Freshness factor [0,1] applied to traversal scoring. Defaults to 1.0. */\n134:   freshness?: number;\n135: }\n136: \n137: interface NeighborBoost {\n138:   boost: number;\n139:   hopCount: number;\n140: }\n141: \n142: let db: Database.Database | null = null;\n143: let graphTraversal: GraphTraversal | null = null;\n144: \n145: /**\n146:  * Check whether the causal boost feature flag is enabled.\n147:  * Default: ON (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n148:  * When enabled, causal graph traversal amplifies scores for results\n149:  * connected to top-ranked results via causal edges.\n150:  *\n151:  * Delegates to the canonical flag check in search-flags.ts.\n152:  */\n153: function isEnabled(): boolean {\n154:   return isCausalBoostEnabled();\n155: }\n156: \n157: /**\n158:  * Check whether the typed traversal feature flag is enabled.\n159:  * Default: ON (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n160:  * Activates sparse-first + intent-aware traversal.\n161:  */\n162: function isTypedTraversalEnabled(): boolean {\n163:   return _isTypedTraversalEnabled();\n164: }\n165: \n166: /** Store the database reference used by causal edge traversal queries. */\n167: function init(database: Database.Database): void {\n168:   db = database;\n169:   graphTraversal = new BetterSqliteGraphTraversal(database);\n170: }\n171: \n172: // ───────────────────────────────────────────────────────────────\n173: // SPARSE-FIRST POLICY\n174: // ───────────────────────────────────────────────────────────────\n175: \n176: /**\n177:  * Determine whether sparse mode should be active for this traversal pass.\n178:  * Sparse mode is active when:\n179:  *   - SPECKIT_TYPED_TRAVERSAL is enabled, AND\n180:  *   - graphDensity is a finite number below SPARSE_DENSITY_THRESHOLD (0.5)\n181:  *\n182:  * When sparse mode is active:\n183:  *   - Community detection is suppressed (caller must respect this)\n184:  *   - Traversal is constrained to SPARSE_MAX_HOPS (1)\n185:  */\n186: function isSparseMode(graphDensity: number | undefined): boolean {\n187:   if (!isTypedTraversalEnabled()) return false;\n188:   if (typeof graphDensity !== 'number' || !Number.isFinite(graphDensity)) return false;\n189:   return graphDensity < SPARSE_DENSITY_THRESHOLD;\n190: }\n191: \n192: interface SparseFirstTraversalPolicy {\n193:   sparseModeActive: boolean;\n194:   communityDetectionEnabled: boolean;\n195: }\n196: \n197: /**\n198:  * Resolve the sparse-first policy gate for callers that need a simple\n199:  * community-detection decision without running the full boost pipeline.\n200:  */\n201: function resolveSparseFirstTraversalPolicy(graphDensity: number | undefined): SparseFirstTraversalPolicy {\n202:   const sparseModeActive = isSparseMode(graphDensity);\n203:   return {\n204:     sparseModeActive,\n205:     communityDetectionEnabled: !sparseModeActive,\n206:   };\n207: }\n208: \n209: /**\n210:  * Resolve traversal depth for typed traversal helper callers.\n211:  * Typed traversal defaults to 1-hop and stays within the supported range.\n212:  * When the flag is off, preserve the legacy MAX_HOPS behavior.\n213:  */\n214: function resolveTraversalDepth(depth: number = DEFAULT_TYPED_TRAVERSAL_DEPTH): number {\n215:   if (!isTypedTraversalEnabled()) {\n216:     return MAX_HOPS;\n217:   }\n218: \n219:   if (!Number.isFinite(depth)) {\n220:     return DEFAULT_TYPED_TRAVERSAL_DEPTH;\n221:   }\n222: \n223:   return Math.max(DEFAULT_TYPED_TRAVERSAL_DEPTH, Math.min(MAX_HOPS, Math.trunc(depth)));\n224: }\n225: \n226: // ───────────────────────────────────────────────────────────────\n227: // INTENT-AWARE EDGE TRAVERSAL HELPERS\n228: // ───────────────────────────────────────────────────────────────\n229: \n230: /**\n231:  * Compute the edge prior score for a given relation type and intent.\n232:  * Returns a normalized score in [0.5, 1.0] based on priority position.\n233:  *\n234:  * Canonical relation names from causal-boost are lower-cased (e.g. 'supersedes').\n235:  * Intent priority lists may include upper-case semantic labels (e.g. 'CORRECTION').\n236:  * Matching is case-insensitive against both the label and any alias.\n237:  *\n238:  * Alias map: CORRECTION → supersedes | contradicts\n239:  *            DEPENDS_ON → caused | enabled | derived_from\n240:  *            EXTENDS    → enabled | derived_from\n241:  *            PREFERENCE → supports\n242:  */\n243: const EDGE_LABEL_ALIASES: Record<string, string[]> = {\n244:   CORRECTION:  ['supersedes', 'contradicts'],\n245:   DEPENDS_ON:  ['caused', 'enabled', 'derived_from'],\n246:   EXTENDS:     ['enabled', 'derived_from'],\n247:   PREFERENCE:  ['supports'],\n248: };\n249: \n250: function resolveEdgePrior(relation: string, intent: string): number {\n251:   if (!isTypedTraversalEnabled()) return 1.0;\n252: \n253:   const priority = INTENT_EDGE_PRIORITY[intent] ?? DEFAULT_EDGE_PRIORITY;\n254:   const relLower = relation.toLowerCase();\n255: \n256:   for (let i = 0; i < priority.length; i++) {\n257:     const entry = priority[i];\n258:     if (!entry) continue;\n259:     // Exact match (case-insensitive)\n260:     if (entry.toLowerCase() === relLower) {\n\n(Showing lines 1-260 of 773. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Boost\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal neighbor boost and injection\n// Graph-traversal score boosting via causal edge relationships.\n// Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n// For results related to top seed results via weighted CTE.\n//\n// Sparse-First + Intent-Aware Traversal:\n// - Sparse-first policy — density < 0.5 disables community\n//   detection and constrains traversal to typed 1-hop expansion only.\n// - Intent-aware edge traversal — maps classified query intents\n//   to edge-type priority orderings; computes traversal score as:\n//   score = seedScore * edgePrior * hopDecay * freshness\n// Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\nimport { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n\nimport type Database from 'better-sqlite3';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Boost\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal neighbor boost and injection\n// Graph-traversal score boosting via causal edge relationships.\n// Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n// For results related to top seed results via weighted CTE.\n//\n// Sparse-First + Intent-Aware Traversal:\n// - Sparse-first policy — density < 0.5 disables community\n//   detection and constrains traversal to typed 1-hop expansion only.\n// - Intent-aware edge traversal — maps classified query intents\n//   to edge-type priority orderings; computes traversal score as:\n//   score = seedScore * edgePrior * hopDecay * freshness\n// Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\nimport { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Maximum graph traversal depth. Beyond 2 hops, signal degrades and queries become expensive. */\nconst MAX_HOPS = 2;\n/** Per-hop boost cap. 0.05 keeps causal nudge subtle relative to semantic scores (~0.5–1.0). */\nconst MAX_BOOST_PER_HOP = 0.05;\n/** Combined causal + session boost ceiling to prevent runaway amplification. */\nconst MAX_COMBINED_BOOST = 0.20;\n/** Top fraction of result set used as graph walk seed nodes. */\nconst SEED_FRACTION = 0.25;\n/** Absolute cap on seed nodes regardless of result set size. */\nconst MAX_SEED_RESULTS = 5;\n\n// ───────────────────────────────────────────────────────────────\n// SPARSE-FIRST POLICY CONSTANTS\n// ───────────────────────────────────────────────────────────────\n/** Graph density threshold below which community detection is disabled\n * and traversal is constrained to typed 1-hop expansion only.\n * Density = edgeCount / totalMemories (see edge-density.ts). */\nconst SPARSE_DENSITY_THRESHOLD = 0.5;\n\n/** Traversal depth used in sparse mode (1-hop typed expansion). */\nconst SPARSE_MAX_HOPS = 1;\n\n/** Default traversal depth for typed traversal helper policies. */\nconst DEFAULT_TYPED_TRAVERSAL_DEPTH = SPARSE_MAX_HOPS;\n\n// ───────────────────────────────────────────────────────────────\n// INTENT-AWARE EDGE TRAVERSAL\n// ───────────────────────────────────────────────────────────────\n/** Per-hop decay factor applied to traversal score. 1-hop = 1.0, 2-hop = 0.5. */\nconst HOP_DECAY_BASE = 1.0;\n\n/**\n * Intent-to-edge-type priority ordering.\n * Maps each query intent to an ordered list of edge relation types.\n * Earlier entries in the list receive higher edge prior scores.\n *\n * Scores are normalized: first-listed relation = 1.0, second = 0.75, remaining = 0.5.\n */\nconst INTENT_EDGE_PRIORITY: Record<string, string[]> = {\n  fix_bug:        ['CORRECTION', 'DEPENDS_ON', 'supersedes', 'caused'],\n  add_feature:    ['EXTENDS', 'DEPENDS_ON', 'enabled', 'derived_from'],\n  find_decision:  ['PREFERENCE', 'CORRECTION', 'supersedes', 'contradicts'],\n  // Defaults for other intents — use existing relation-weight ordering\n  understand:     ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n  find_spec:      ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n  refactor:       ['caused', 'derived_from', 'enabled', 'supports', 'supersedes', 'contradicts'],\n  security_audit: ['caused', 'contradicts', 'supersedes', 'enabled', 'supports', 'derived_from'],\n};\n\n/** Fallback priority list when intent is unrecognized. */\nconst DEFAULT_EDGE_PRIORITY = ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'];\n\n/** Edge prior score tiers: 1st priority = 1.0, 2nd = 0.75, remaining = 0.5. */\nconst EDGE_PRIOR_TIERS = [1.0, 0.75, 0.5];\nconst DEFAULT_EDGE_PRIOR = 1.0;\nconst FRESHNESS_DECAY_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;\n\n/**\n * Relation-type weight multipliers for causal edge traversal.\n * Applied during CTE accumulation so stronger relation types (supersedes)\n * amplify the boost while weaker ones (contradicts) attenuate it.\n *\n * These multipliers serve a DIFFERENT purpose from RELATION_WEIGHTS in\n * causal-edges.ts. causal-edges weights are applied during chain traversal\n * scoring (getCausalChain), while these are applied during the causal-boost\n * CTE walk (getNeighborBoosts) for search result amplification. The value\n * ranges overlap but are tuned independently for their respective contexts:\n *   - causal-edges: traversal strength propagation (range 0.8–1.5)\n *   - causal-boost: search result boost amplitude (range 0.8–1.5)\n */\nconst RELATION_WEIGHT_MULTIPLIERS: Record<string, number> = {\n  supersedes: 1.5,\n  contradicts: 0.8,\n  caused: 1.0,\n  enabled: 1.0,\n  derived_from: 1.0,\n  supports: 1.0,\n};\n\ninterface RankedSearchResult extends Record<string, unknown> {\n  id: number;\n  score?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  attentionScore?: number;\n  similarity?: number;\n  sessionBoost?: number;\n  baseScore?: number;\n  causalBoost?: number;\n  injectedByCausalBoost?: boolean;\n}\n\ninterface CausalBoostMetadata {\n  enabled: boolean;\n  applied: boolean;\n  boostedCount: number;\n  injectedCount: number;\n  maxBoostApplied: number;\n  traversalDepth: number;\n  /** True when sparse-first policy was active (density < threshold) */\n  sparseModeActive?: boolean;\n  /** Intent used for edge traversal scoring (if typed traversal enabled) */\n  intentUsed?: string;\n}\n\n/** Options for applyCausalBoost — extended with sparse-first parameters. */\ninterface CausalBoostOptions {\n  /** Graph density (edgeCount / totalMemories). Used for sparse-first gate. */\n  graphDensity?: number;\n  /** Classified query intent. Used for intent-aware edge priority mapping. */\n  intent?: string;\n  /** Freshness factor [0,1] applied to traversal scoring. Defaults to 1.0. */\n  freshness?: number;\n}\n\ninterface NeighborBoost {\n  boost: number;\n  hopCount: number;\n}\n\nlet db: Database.Database | null = null;\nlet graphTraversal: GraphTraversal | null = null;\n\n/**\n * Check whether the causal boost feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n * When enabled, causal graph traversal amplifies scores for results\n * connected to top-ranked results via causal edges.\n *\n * Delegates to the canonical flag check in search-flags.ts.\n */\nfunction isEnabled(): boolean {\n  return isCausalBoostEnabled();\n}\n\n/**\n * Check whether the typed traversal feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n * Activates sparse-first + intent-aware traversal.\n */\nfunction isTypedTraversalEnabled(): boolean {\n  return _isTypedTraversalEnabled();\n}\n\n/** Store the database reference used by causal edge traversal queries. */\nfunction init(database: Database.Database): void {\n  db = database;\n  graphTraversal = new BetterSqliteGraphTraversal(database);\n}\n\n// ───────────────────────────────────────────────────────────────\n// SPARSE-FIRST POLICY\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Determine whether sparse mode should be active for this traversal pass.\n * Sparse mode is active when:\n *   - SPECKIT_TYPED_TRAVERSAL is enabled, AND\n *   - graphDensity is a finite number below SPARSE_DENSITY_THRESHOLD (0.5)\n *\n * When sparse mode is active:\n *   - Community detection is suppressed (caller must respect this)\n *   - Traversal is constrained to SPARSE_MAX_HOPS (1)\n */\nfunction isSparseMode(graphDensity: number | undefined): boolean {\n  if (!isTypedTraversalEnabled()) return false;\n  if (typeof graphDensity !== 'number' || !Number.isFinite(graphDensity)) return false;\n  return graphDensity < SPARSE_DENSITY_THRESHOLD;\n}\n\ninterface SparseFirstTraversalPolicy {\n  sparseModeActive: boolean;\n  communityDetectionEnabled: boolean;\n}\n\n/**\n * Resolve the sparse-first policy gate for callers that need a simple\n * community-detection decision without running the full boost pipeline.\n */\nfunction resolveSparseFirstTraversalPolicy(graphDensity: number | undefined): SparseFirstTraversalPolicy {\n  const sparseModeActive = isSparseMode(graphDensity);\n  return {\n    sparseModeActive,\n    communityDetectionEnabled: !sparseModeActive,\n  };\n}\n\n/**\n * Resolve traversal depth for typed traversal helper callers.\n * Typed traversal defaults to 1-hop and stays within the supported range.\n * When the flag is off, preserve the legacy MAX_HOPS behavior.\n */\nfunction resolveTraversalDepth(depth: number = DEFAULT_TYPED_TRAVERSAL_DEPTH): number {\n  if (!isTypedTraversalEnabled()) {\n    return MAX_HOPS;\n  }\n\n  if (!Number.isFinite(depth)) {\n    return DEFAULT_TYPED_TRAVERSAL_DEPTH;\n  }\n\n  return Math.max(DEFAULT_TYPED_TRAVERSAL_DEPTH, Math.min(MAX_HOPS, Math.trunc(depth)));\n}\n\n// ───────────────────────────────────────────────────────────────\n// INTENT-AWARE EDGE TRAVERSAL HELPERS\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Compute the edge prior score for a given relation type and intent.\n * Returns a normalized score in [0.5, 1.0] based on priority position.\n *\n * Canonical relation names from causal-boost are lower-cased (e.g. 'supersedes').\n * Intent priority lists may include upper-case semantic labels (e.g. 'CORRECTION').\n * Matching is case-insensitive against both the label and any alias.\n *\n * Alias map: CORRECTION → supersedes | contradicts\n *            DEPENDS_ON → caused | enabled | derived_from\n *            EXTENDS    → enabled | derived_from\n *            PREFERENCE → supports\n */\nconst EDGE_LABEL_ALIASES: Record<string, string[]> = {\n  CORRECTION:  ['supersedes', 'contradicts'],\n  DEPENDS_ON:  ['caused', 'enabled', 'derived_from'],\n  EXTENDS:     ['enabled', 'derived_from'],\n  PREFERENCE:  ['supports'],\n};\n\nfunction resolveEdgePrior(relation: string, intent: string): number {\n  if (!isTypedTraversalEnabled()) return 1.0;\n\n  const priority = INTENT_EDGE_PRIORITY[intent] ?? DEFAULT_EDGE_PRIORITY;\n  const relLower = relation.toLowerCase();\n\n  for (let i = 0; i < priority.length; i++) {\n    const entry = priority[i];\n    if (!entry) continue;\n    // Exact match (case-insensitive)\n    if (entry.toLowerCase() === relLower) {","lineStart":1,"lineEnd":260,"totalLines":773,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","time":{"start":1781144194880,"end":1781144194882}},"metadata":{"openai":{"itemId":"fc_0448bb83f4aedebb016a2a1a82bc0c8191ba252155ca3d7c65"}},"id":"prt_eb4778f1f001kq14BMGcWoJxVy","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477504d001YpWrWEAoItsibb"}}
{"type":"tool_use","timestamp":1781144194892,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_i0jL0mjKvudLsbHEgkBke9t7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts","offset":1,"limit":150},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { describe, expect, it } from 'vitest';\n2: import Database from 'better-sqlite3';\n3: \n4: import { createMemoStore, MemoStore } from '../lib/storage/memo';\n5: import { FakeGraphTraversal } from './fakes/storage-ports';\n6: \n7: describe('memo storage foundation', () => {\n8:   it('upserts memo records and reads them by input and code hash', () => {\n9:     const db = new Database(':memory:');\n10:     try {\n11:       const store = createMemoStore(db);\n12:       store.upsertMemoRecord({\n13:         componentPath: '/workspace/spec.md',\n14:         inputFingerprint: 'input-a',\n15:         codeHash: 'code-a',\n16:         outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n17:       });\n18: \n19:       expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-a')).toMatchObject({\n20:         componentPath: '/workspace/spec.md',\n21:         inputFingerprint: 'input-a',\n22:         codeHash: 'code-a',\n23:         outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n24:       });\n25:       expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-b')).toBeNull();\n26:     } finally {\n27:       db.close();\n28:     }\n29:   });\n30: \n31:   it('walks dependency edges transitively and invalidates dependent memo rows only', () => {\n32:     const db = new Database(':memory:');\n33:     try {\n34:       const store = createMemoStore(db);\n35:       store.addDependencyEdge({ parentPath: 'source', childPath: 'child-a', kind: 'derived' });\n36:       store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n37:       store.upsertMemoRecord({ componentPath: 'source', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n38:       store.upsertMemoRecord({ componentPath: 'child-a', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n39:       store.upsertMemoRecord({ componentPath: 'child-b', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n40:       store.upsertMemoRecord({ componentPath: 'unrelated', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n41: \n42:       const result = store.invalidateDependents(['source']);\n43: \n44:       expect(result.invalidatedPaths).toEqual(['child-a', 'child-b']);\n45:       expect(result.deletedMemoRecords).toBe(2);\n46:       expect(store.getMemoRecord('source', 'i', 'c')).not.toBeNull();\n47:       expect(store.getMemoRecord('child-a', 'i', 'c')).toBeNull();\n48:       expect(store.getMemoRecord('child-b', 'i', 'c')).toBeNull();\n49:       expect(store.getMemoRecord('unrelated', 'i', 'c')).not.toBeNull();\n50:     } finally {\n51:       db.close();\n52:     }\n53:   });\n54: \n55:   it('rejects dependency cycles', () => {\n56:     const db = new Database(':memory:');\n57:     try {\n58:       const store = createMemoStore(db);\n59:       store.addDependencyEdge({ parentPath: 'a', childPath: 'b', kind: 'derived' });\n60:       store.addDependencyEdge({ parentPath: 'b', childPath: 'c', kind: 'derived' });\n61: \n62:       expect(() => store.addDependencyEdge({ parentPath: 'c', childPath: 'a', kind: 'derived' }))\n63:         .toThrow(/cycle/);\n64:     } finally {\n65:       db.close();\n66:     }\n67:   });\n68: \n69:   it('uses an injected graph traversal port without opening SQLite', () => {\n70:     const fakeDatabase = {\n71:       exec: () => undefined,\n72:       prepare: () => ({\n73:         get: () => ({ edge_count: 1 }),\n74:       }),\n75:     } as unknown as Database.Database;\n76:     const graphTraversal = new FakeGraphTraversal({\n77:       dependencyEdges: [\n78:         { parentPath: 'root', childPath: 'child' },\n79:         { parentPath: 'child', childPath: 'grandchild' },\n80:       ],\n81:     });\n82: \n83:     const store = new MemoStore(fakeDatabase, graphTraversal);\n84: \n85:     expect(store.collectDependents(['root'])).toEqual(['child', 'grandchild']);\n86:   });\n87: });\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"import { describe, expect, it } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport { createMemoStore, MemoStore } from '../lib/storage/memo';\nimport { FakeGraphTraversal } from './fakes/storage-ports';\n\ndescribe('memo storage foundation', () => {\n  it('upserts memo records and reads them by input and code hash', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.upsertMemoRecord({\n        componentPath: '/workspace/spec.md',\n        inputFingerprint: 'input-a',\n        codeHash: 'code-a',\n        outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n      });\n\n      expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-a')).toMatchObject({\n        componentPath: '/workspace/spec.md',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts","text":"import { describe, expect, it } from 'vitest';\nimport Database from 'better-sqlite3';\n\nimport { createMemoStore, MemoStore } from '../lib/storage/memo';\nimport { FakeGraphTraversal } from './fakes/storage-ports';\n\ndescribe('memo storage foundation', () => {\n  it('upserts memo records and reads them by input and code hash', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.upsertMemoRecord({\n        componentPath: '/workspace/spec.md',\n        inputFingerprint: 'input-a',\n        codeHash: 'code-a',\n        outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n      });\n\n      expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-a')).toMatchObject({\n        componentPath: '/workspace/spec.md',\n        inputFingerprint: 'input-a',\n        codeHash: 'code-a',\n        outputBlob: JSON.stringify({ rowIds: [1, 2] }),\n      });\n      expect(store.getMemoRecord('/workspace/spec.md', 'input-a', 'code-b')).toBeNull();\n    } finally {\n      db.close();\n    }\n  });\n\n  it('walks dependency edges transitively and invalidates dependent memo rows only', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.addDependencyEdge({ parentPath: 'source', childPath: 'child-a', kind: 'derived' });\n      store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n      store.upsertMemoRecord({ componentPath: 'source', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n      store.upsertMemoRecord({ componentPath: 'child-a', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n      store.upsertMemoRecord({ componentPath: 'child-b', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n      store.upsertMemoRecord({ componentPath: 'unrelated', inputFingerprint: 'i', codeHash: 'c', outputBlob: '{}' });\n\n      const result = store.invalidateDependents(['source']);\n\n      expect(result.invalidatedPaths).toEqual(['child-a', 'child-b']);\n      expect(result.deletedMemoRecords).toBe(2);\n      expect(store.getMemoRecord('source', 'i', 'c')).not.toBeNull();\n      expect(store.getMemoRecord('child-a', 'i', 'c')).toBeNull();\n      expect(store.getMemoRecord('child-b', 'i', 'c')).toBeNull();\n      expect(store.getMemoRecord('unrelated', 'i', 'c')).not.toBeNull();\n    } finally {\n      db.close();\n    }\n  });\n\n  it('rejects dependency cycles', () => {\n    const db = new Database(':memory:');\n    try {\n      const store = createMemoStore(db);\n      store.addDependencyEdge({ parentPath: 'a', childPath: 'b', kind: 'derived' });\n      store.addDependencyEdge({ parentPath: 'b', childPath: 'c', kind: 'derived' });\n\n      expect(() => store.addDependencyEdge({ parentPath: 'c', childPath: 'a', kind: 'derived' }))\n        .toThrow(/cycle/);\n    } finally {\n      db.close();\n    }\n  });\n\n  it('uses an injected graph traversal port without opening SQLite', () => {\n    const fakeDatabase = {\n      exec: () => undefined,\n      prepare: () => ({\n        get: () => ({ edge_count: 1 }),\n      }),\n    } as unknown as Database.Database;\n    const graphTraversal = new FakeGraphTraversal({\n      dependencyEdges: [\n        { parentPath: 'root', childPath: 'child' },\n        { parentPath: 'child', childPath: 'grandchild' },\n      ],\n    });\n\n    const store = new MemoStore(fakeDatabase, graphTraversal);\n\n    expect(store.collectDependents(['root'])).toEqual(['child', 'grandchild']);\n  });\n});","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/memo-storage.vitest.ts","time":{"start":1781144194887,"end":1781144194891}},"metadata":{"openai":{"itemId":"fc_0448bb83f4aedebb016a2a1a82bc14819182b3f6011deb1828"}},"id":"prt_eb4778f46001l8ZUyXPHFWbFWk","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477504d001YpWrWEAoItsibb"}}
{"type":"tool_use","timestamp":1781144194893,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_LMCZn9enwfOoIJgz5V5BXhD5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts","offset":180,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts</path>\n<type>file</type>\n<content>\n180: \n181:       for (const [nodeId, row] of cteRows) {\n182:         const walkMultiplier = Math.max(0.1, Math.min(2.0, row.maxWalkScore));\n183:         const expectedBoost = Math.min(0.05, 0.05 / row.minHop) * walkMultiplier;\n184:         expect(boosts.get(nodeId)?.boost).toBe(expectedBoost);\n185:         expect(boosts.get(nodeId)?.hopCount).toBe(row.minHop);\n186:       }\n187:     } finally {\n188:       db.close();\n189:     }\n190:   });\n191: \n192:   it('matches recursive CTE directed reachability and skips cycle checks for an empty edge table', () => {\n193:     const db = createMemoDb();\n194:     try {\n195:       const store = createMemoStore(db);\n196:       const prepareSpy = vi.spyOn(db, 'prepare');\n197: \n198:       store.addDependencyEdge({ parentPath: 'root', childPath: 'child-a', kind: 'derived' });\n199: \n200:       const selectAfterConstruction = prepareSpy.mock.calls\n201:         .map(([source]) => String(source))\n202:         .filter((source) => /^\\s*SELECT/i.test(source));\n203:       expect(selectAfterConstruction).toHaveLength(0);\n204: \n205:       store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n206:       store.addDependencyEdge({ parentPath: 'root', childPath: 'child-c', kind: 'derived' });\n207: \n208:       const expected = cteDependents(db, ['root']);\n209:       const actual = collectDependencyReachability(db, ['root']).sort();\n210:       expect(actual).toEqual(expected);\n211:       expect(store.collectDependents(['root'])).toEqual(expected);\n212:       expect(() => store.addDependencyEdge({ parentPath: 'child-b', childPath: 'root', kind: 'derived' }))\n213:         .toThrow(/cycle/);\n214:     } finally {\n215:       db.close();\n216:     }\n217:   });\n218: \n219:   it('records BFS latency at or below the recursive CTE on the live-shaped fixture', () => {\n220:     const db = createCausalDb();\n221:     try {\n222:       insertFixtureEdges(db);\n223:       const seeds = [1, 8, 33, 144, 377];\n224:       const iterations = 25;\n225: \n226:       const cteMs = measureMs(() => cteCausalWalk(db, seeds, 2), iterations);\n227:       const bfsMs = measureMs(\n228:         () => collectCausalWeightedNeighbors(db, seeds, 2, RELATION_WEIGHT_MULTIPLIERS),\n229:         iterations,\n230:       );\n231: \n232:       console.info(`BFS traversal benchmark: fixture_edges=10240 max_degree=20 seeds=5 hops=2 cte_ms=${cteMs} bfs_ms=${bfsMs}`);\n233:       expect(bfsMs).toBeLessThanOrEqual(cteMs);\n234:     } finally {\n235:       db.close();\n236:     }\n237:   });\n238: });\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"\n      for (const [nodeId, row] of cteRows) {\n        const walkMultiplier = Math.max(0.1, Math.min(2.0, row.maxWalkScore));\n        const expectedBoost = Math.min(0.05, 0.05 / row.minHop) * walkMultiplier;\n        expect(boosts.get(nodeId)?.boost).toBe(expectedBoost);\n        expect(boosts.get(nodeId)?.hopCount).toBe(row.minHop);\n      }\n    } finally {\n      db.close();\n    }\n  });\n\n  it('matches recursive CTE directed reachability and skips cycle checks for an empty edge table', () => {\n    const db = createMemoDb();\n    try {\n      const store = createMemoStore(db);\n      const prepareSpy = vi.spyOn(db, 'prepare');\n\n      store.addDependencyEdge({ parentPath: 'root', childPath: 'child-a', kind: 'derived' });\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts","text":"\n      for (const [nodeId, row] of cteRows) {\n        const walkMultiplier = Math.max(0.1, Math.min(2.0, row.maxWalkScore));\n        const expectedBoost = Math.min(0.05, 0.05 / row.minHop) * walkMultiplier;\n        expect(boosts.get(nodeId)?.boost).toBe(expectedBoost);\n        expect(boosts.get(nodeId)?.hopCount).toBe(row.minHop);\n      }\n    } finally {\n      db.close();\n    }\n  });\n\n  it('matches recursive CTE directed reachability and skips cycle checks for an empty edge table', () => {\n    const db = createMemoDb();\n    try {\n      const store = createMemoStore(db);\n      const prepareSpy = vi.spyOn(db, 'prepare');\n\n      store.addDependencyEdge({ parentPath: 'root', childPath: 'child-a', kind: 'derived' });\n\n      const selectAfterConstruction = prepareSpy.mock.calls\n        .map(([source]) => String(source))\n        .filter((source) => /^\\s*SELECT/i.test(source));\n      expect(selectAfterConstruction).toHaveLength(0);\n\n      store.addDependencyEdge({ parentPath: 'child-a', childPath: 'child-b', kind: 'derived' });\n      store.addDependencyEdge({ parentPath: 'root', childPath: 'child-c', kind: 'derived' });\n\n      const expected = cteDependents(db, ['root']);\n      const actual = collectDependencyReachability(db, ['root']).sort();\n      expect(actual).toEqual(expected);\n      expect(store.collectDependents(['root'])).toEqual(expected);\n      expect(() => store.addDependencyEdge({ parentPath: 'child-b', childPath: 'root', kind: 'derived' }))\n        .toThrow(/cycle/);\n    } finally {\n      db.close();\n    }\n  });\n\n  it('records BFS latency at or below the recursive CTE on the live-shaped fixture', () => {\n    const db = createCausalDb();\n    try {\n      insertFixtureEdges(db);\n      const seeds = [1, 8, 33, 144, 377];\n      const iterations = 25;\n\n      const cteMs = measureMs(() => cteCausalWalk(db, seeds, 2), iterations);\n      const bfsMs = measureMs(\n        () => collectCausalWeightedNeighbors(db, seeds, 2, RELATION_WEIGHT_MULTIPLIERS),\n        iterations,\n      );\n\n      console.info(`BFS traversal benchmark: fixture_edges=10240 max_degree=20 seeds=5 hops=2 cte_ms=${cteMs} bfs_ms=${bfsMs}`);\n      expect(bfsMs).toBeLessThanOrEqual(cteMs);\n    } finally {\n      db.close();\n    }\n  });\n});","lineStart":180,"lineEnd":238,"totalLines":238,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/causal-traversal-bfs-equivalence.vitest.ts","time":{"start":1781144194889,"end":1781144194892}},"metadata":{"openai":{"itemId":"fc_0448bb83f4aedebb016a2a1a82bc1c81919f81d1a7031f8eb7"}},"id":"prt_eb4778f48001kQ47lJ049ntOro","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477504d001YpWrWEAoItsibb"}}
