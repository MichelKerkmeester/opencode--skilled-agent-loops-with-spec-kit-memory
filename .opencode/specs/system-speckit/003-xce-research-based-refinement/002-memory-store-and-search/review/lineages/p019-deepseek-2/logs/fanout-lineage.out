{"type":"tool_use","timestamp":1781719582501,"sessionID":"ses_1293d8f5cffeM0kbBvfYyfngHB","part":{"type":"tool","tool":"read","callID":"call_00_s5eGtAHkwrXvMegyfpXP6078","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance-Active Marker\n3: // ───────────────────────────────────────────────────────────────\n4: // Signals the launcher that this daemon is busy-by-design (a background index\n5: // scan or a background-embedding burst) so a competing launcher adopts it\n6: // instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n7: // and refuses to reap a live daemon that holds a fresh marker (see the\n8: // shouldAdoptDespiteProbe guard in the launcher supervision lib).\n9: //\n10: // Reference-counted: the scan and the embedding queue can overlap (the scan\n11: // defers embeddings the queue then drains), so the marker stays present while\n12: // ANY maintenance source is active and is removed only when the last one ends.\n13: // A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n14: // becomes reapable again.\n15: \n16: import { rmSync } from 'node:fs';\n17: import path from 'node:path';\n18: \n19: import { DATABASE_DIR } from '../../core/config.js';\n20: import { atomicWriteFile } from './transaction-manager.js';\n21: \n22: const MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n23: // The TTL must exceed the longest single synchronous phase that cannot fire the\n24: // refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\n25: const MAINTENANCE_MARKER_TTL_MS = 180_000;\n26: const MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n27: \n28: export interface MaintenanceMarkerHandle {\n29:   // Refresh at a known progress point too: a non-yielding phase cannot fire the\n30:   // interval timer, so it only gets the refresh its caller makes explicitly.\n31:   refresh(): void;\n32:   // Idempotent. Decrements the active count and removes the marker at zero.\n33:   end(): void;\n34: }\n35: \n36: let activeCount = 0;\n37: let refreshTimer: ReturnType<typeof setInterval> | null = null;\n38: let activeLabels: string[] = [];\n39: \n40: function markerPath(): string {\n41:   return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n42: }\n43: \n44: function writeMarker(): void {\n45:   atomicWriteFile(markerPath(), `${JSON.stringify({\n46:     childPid: process.pid,\n47:     activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n48:     labels: activeLabels,\n49:     refreshedAtIso: new Date().toISOString(),\n50:   }, null, 2)}\\n`);\n51: }\n52: \n53: /**\n54:  * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n55:  * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n56:  * overlap with other maintenance sources.\n57:  */\n58: export function beginMaintenance(label: string): MaintenanceMarkerHandle {\n59:   activeCount += 1;\n60:   activeLabels.push(label);\n61:   writeMarker();\n62:   if (!refreshTimer) {\n63:     refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n64:     refreshTimer.unref?.();\n65:   }\n66: \n67:   let ended = false;\n68:   return {\n69:     refresh(): void {\n70:       if (!ended && activeCount > 0) writeMarker();\n71:     },\n72:     end(): void {\n73:       if (ended) return;\n74:       ended = true;\n75:       activeCount = Math.max(0, activeCount - 1);\n76:       const idx = activeLabels.indexOf(label);\n77:       if (idx >= 0) activeLabels.splice(idx, 1);\n78:       if (activeCount === 0) {\n79:         if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n80:         try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n81:       }\n82:     },\n83:   };\n84: }\n85: \n86: // Test-only: reset module state between cases.\n87: export function __resetMaintenanceMarkerForTest(): void {\n88:   if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n89:   activeCount = 0;\n90:   activeLabels = [];\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance-Active Marker\n// ───────────────────────────────────────────────────────────────\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance-Active Marker\n// ───────────────────────────────────────────────────────────────\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';\n\nconst MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n// The TTL must exceed the longest single synchronous phase that cannot fire the\n// refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\nconst MAINTENANCE_MARKER_TTL_MS = 180_000;\nconst MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n\nexport interface MaintenanceMarkerHandle {\n  // Refresh at a known progress point too: a non-yielding phase cannot fire the\n  // interval timer, so it only gets the refresh its caller makes explicitly.\n  refresh(): void;\n  // Idempotent. Decrements the active count and removes the marker at zero.\n  end(): void;\n}\n\nlet activeCount = 0;\nlet refreshTimer: ReturnType<typeof setInterval> | null = null;\nlet activeLabels: string[] = [];\n\nfunction markerPath(): string {\n  return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n}\n\nfunction writeMarker(): void {\n  atomicWriteFile(markerPath(), `${JSON.stringify({\n    childPid: process.pid,\n    activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n    labels: activeLabels,\n    refreshedAtIso: new Date().toISOString(),\n  }, null, 2)}\\n`);\n}\n\n/**\n * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n * overlap with other maintenance sources.\n */\nexport function beginMaintenance(label: string): MaintenanceMarkerHandle {\n  activeCount += 1;\n  activeLabels.push(label);\n  writeMarker();\n  if (!refreshTimer) {\n    refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n    refreshTimer.unref?.();\n  }\n\n  let ended = false;\n  return {\n    refresh(): void {\n      if (!ended && activeCount > 0) writeMarker();\n    },\n    end(): void {\n      if (ended) return;\n      ended = true;\n      activeCount = Math.max(0, activeCount - 1);\n      const idx = activeLabels.indexOf(label);\n      if (idx >= 0) activeLabels.splice(idx, 1);\n      if (activeCount === 0) {\n        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n        try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n      }\n    },\n  };\n}\n\n// Test-only: reset module state between cases.\nexport function __resetMaintenanceMarkerForTest(): void {\n  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n  activeCount = 0;\n  activeLabels = [];\n}","lineStart":1,"lineEnd":91,"totalLines":91,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","time":{"start":1781719582497,"end":1781719582500}},"id":"prt_ed6c345ae001Rx0DpSZsAeELBc","sessionID":"ses_1293d8f5cffeM0kbBvfYyfngHB","messageID":"msg_ed6c336ef001I0rKYUIOI5aA9b"}}
{"type":"tool_use","timestamp":1781719582909,"sessionID":"ses_1293d8f5cffeM0kbBvfYyfngHB","part":{"type":"tool","tool":"read","callID":"call_01_924Y993NOJdshTnzCtgU4063","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { createRequire } from 'node:module';\n2: \n3: import { describe, expect, it } from 'vitest';\n4: \n5: type MaintenanceMarker = {\n6:   childPid: number;\n7:   activeUntilMs: number;\n8:   jobId?: string;\n9:   refreshedAtIso?: string;\n10: };\n11: \n12: const require = createRequire(import.meta.url);\n13: const launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n14:   readMaintenanceMarker: (\n15:     dbDir: string,\n16:     options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n17:   ) => MaintenanceMarker | null;\n18:   shouldAdoptDespiteProbe: (options?: {\n19:     marker?: MaintenanceMarker | null;\n20:     childPid?: number;\n21:     childLiveness?: string;\n22:     nowMs?: number | (() => number);\n23:   }) => boolean;\n24: };\n25: \n26: describe('launcher maintenance-active adopt guard', () => {\n27:   const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n28:   const freshMarker = (childPid: number): MaintenanceMarker => ({\n29:     childPid,\n30:     activeUntilMs: NOW + 30_000,\n31:     jobId: 'index-scan-1',\n32:     refreshedAtIso: '2026-06-09T00:00:00.000Z',\n33:   });\n34: \n35:   it('adopts a fresh marker that names this exact live child (a)', () => {\n36:     // Busy-by-design: the marker is unexpired, names the probed child, and the\n37:     // child is alive — the only case where adoption beats reaping.\n38:     expect(\n39:       launcher.shouldAdoptDespiteProbe({\n40:         marker: freshMarker(4242),\n41:         childPid: 4242,\n42:         childLiveness: 'alive',\n43:         nowMs: NOW,\n44:       }),\n45:     ).toBe(true);\n46:   });\n47: \n48:   it('reaps once the marker has expired (b)', () => {\n49:     // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n50:     // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n51:     expect(\n52:       launcher.shouldAdoptDespiteProbe({\n53:         marker: { ...freshMarker(4242), activeUntilMs: NOW },\n54:         childPid: 4242,\n55:         childLiveness: 'alive',\n56:         nowMs: NOW,\n57:       }),\n58:     ).toBe(false);\n59:   });\n60: \n61:   it('reaps when the marker names a different child (c)', () => {\n62:     // A marker left over from a prior daemon child must never pin the current\n63:     // one; a childPid mismatch falls through to the reap path.\n64:     expect(\n65:       launcher.shouldAdoptDespiteProbe({\n66:         marker: freshMarker(4242),\n67:         childPid: 9999,\n68:         childLiveness: 'alive',\n69:         nowMs: NOW,\n70:       }),\n71:     ).toBe(false);\n72:   });\n73: \n74:   it('reaps when the probed child is dead (d)', () => {\n75:     expect(\n76:       launcher.shouldAdoptDespiteProbe({\n77:         marker: freshMarker(4242),\n78:         childPid: 4242,\n79:         childLiveness: 'dead',\n80:         nowMs: NOW,\n81:       }),\n82:     ).toBe(false);\n83:   });\n84: \n85:   it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n86:     // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n87:     // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n88:     expect(\n89:       launcher.shouldAdoptDespiteProbe({\n90:         marker: freshMarker(4242),\n91:         childPid: 4242,\n92:         childLiveness: 'unknown-eperm',\n93:         nowMs: NOW,\n94:       }),\n95:     ).toBe(false);\n96:   });\n97: \n98:   it('reaps when there is no marker at all (f)', () => {\n99:     expect(\n100:       launcher.shouldAdoptDespiteProbe({\n101:         marker: null,\n102:         childPid: 4242,\n103:         childLiveness: 'alive',\n104:         nowMs: NOW,\n105:       }),\n106:     ).toBe(false);\n107:   });\n108: \n109:   it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n110:     for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n111:       expect(\n112:         launcher.shouldAdoptDespiteProbe({\n113:           marker: freshMarker(4242),\n114:           childPid,\n115:           childLiveness: 'alive',\n116:           nowMs: NOW,\n117:         }),\n118:       ).toBe(false);\n119:     }\n120:   });\n121: });\n122: \n123: describe('launcher maintenance marker reader (injected fs)', () => {\n124:   const injectFs = (readFileSync: (path: string) => string) =>\n125:     ({ fs: { readFileSync } });\n126: \n127:   it('returns the parsed object for a valid marker (a)', () => {\n128:     const marker = {\n129:       childPid: 4242,\n130:       activeUntilMs: 1_700_000_000_000,\n131:       jobId: 'index-scan-1',\n132:       refreshedAtIso: '2026-06-09T00:00:00.000Z',\n133:     };\n134:     expect(\n135:       launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n136:     ).toEqual(marker);\n137:   });\n138: \n139:   it('returns null when the marker file is missing (ENOENT) (b)', () => {\n140:     expect(\n141:       launcher.readMaintenanceMarker('/db', injectFs(() => {\n142:         throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n143:       })),\n144:     ).toBeNull();\n145:   });\n146: \n147:   it('returns null for corrupt JSON (c)', () => {\n148:     expect(\n149:       launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n150:     ).toBeNull();\n151:   });\n152: \n153:   it('returns null when childPid is missing (d)', () => {\n154:     expect(\n155:       launcher.readMaintenanceMarker(\n156:         '/db',\n157:         injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n158:       ),\n159:     ).toBeNull();\n160:   });\n161: \n162:   it('returns null when activeUntilMs is non-finite (e)', () => {\n163:     expect(\n164:       launcher.readMaintenanceMarker(\n165:         '/db',\n166:         // JSON.stringify turns Infinity into null, which is non-finite by the\n167:         // reader's Number.isFinite gate — the canonical corrupt-time shape.\n168:         injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n169:       ),\n170:     ).toBeNull();\n171:   });\n172: });\n\n(End of file - total 172 lines)\n</content>","metadata":{"preview":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","text":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;\n    childLiveness?: string;\n    nowMs?: number | (() => number);\n  }) => boolean;\n};\n\ndescribe('launcher maintenance-active adopt guard', () => {\n  const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n  const freshMarker = (childPid: number): MaintenanceMarker => ({\n    childPid,\n    activeUntilMs: NOW + 30_000,\n    jobId: 'index-scan-1',\n    refreshedAtIso: '2026-06-09T00:00:00.000Z',\n  });\n\n  it('adopts a fresh marker that names this exact live child (a)', () => {\n    // Busy-by-design: the marker is unexpired, names the probed child, and the\n    // child is alive — the only case where adoption beats reaping.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(true);\n  });\n\n  it('reaps once the marker has expired (b)', () => {\n    // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n    // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: { ...freshMarker(4242), activeUntilMs: NOW },\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the marker names a different child (c)', () => {\n    // A marker left over from a prior daemon child must never pin the current\n    // one; a childPid mismatch falls through to the reap path.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 9999,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the probed child is dead (d)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'dead',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n    // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n    // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'unknown-eperm',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when there is no marker at all (f)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: null,\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n    for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n      expect(\n        launcher.shouldAdoptDespiteProbe({\n          marker: freshMarker(4242),\n          childPid,\n          childLiveness: 'alive',\n          nowMs: NOW,\n        }),\n      ).toBe(false);\n    }\n  });\n});\n\ndescribe('launcher maintenance marker reader (injected fs)', () => {\n  const injectFs = (readFileSync: (path: string) => string) =>\n    ({ fs: { readFileSync } });\n\n  it('returns the parsed object for a valid marker (a)', () => {\n    const marker = {\n      childPid: 4242,\n      activeUntilMs: 1_700_000_000_000,\n      jobId: 'index-scan-1',\n      refreshedAtIso: '2026-06-09T00:00:00.000Z',\n    };\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n    ).toEqual(marker);\n  });\n\n  it('returns null when the marker file is missing (ENOENT) (b)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => {\n        throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n      })),\n    ).toBeNull();\n  });\n\n  it('returns null for corrupt JSON (c)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n    ).toBeNull();\n  });\n\n  it('returns null when childPid is missing (d)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n      ),\n    ).toBeNull();\n  });\n\n  it('returns null when activeUntilMs is non-finite (e)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        // JSON.stringify turns Infinity into null, which is non-finite by the\n        // reader's Number.isFinite gate — the canonical corrupt-time shape.\n        injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n      ),\n    ).toBeNull();\n  });\n});","lineStart":1,"lineEnd":172,"totalLines":172,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","time":{"start":1781719582901,"end":1781719582907}},"id":"prt_ed6c34762001sFNgFi9WKPHwv1","sessionID":"ses_1293d8f5cffeM0kbBvfYyfngHB","messageID":"msg_ed6c336ef001I0rKYUIOI5aA9b"}}
{"type":"tool_use","timestamp":1781719583359,"sessionID":"ses_1293d8f5cffeM0kbBvfYyfngHB","part":{"type":"tool","tool":"read","callID":"call_02_XgVq71rw2wxR0kpI5ahf0591","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2: import fs from 'fs';\n3: import path from 'path';\n4: import os from 'os';\n5: \n6: import {\n7:   beginMaintenance,\n8:   __resetMaintenanceMarkerForTest,\n9: } from '../lib/storage/maintenance-marker';\n10: import { resolveDatabasePaths } from '../core/config';\n11: \n12: const MARKER_FILE = '.maintenance-active.json';\n13: \n14: interface MarkerShape {\n15:   childPid: number;\n16:   activeUntilMs: number;\n17:   labels: string[];\n18:   refreshedAtIso: string;\n19: }\n20: \n21: let tmpDir: string;\n22: const originalSpecKitDbDir = process.env.SPEC_KIT_DB_DIR;\n23: const originalSpeckitDbDir = process.env.SPECKIT_DB_DIR;\n24: \n25: function markerPath(): string {\n26:   return path.join(tmpDir, MARKER_FILE);\n27: }\n28: \n29: function markerExists(): boolean {\n30:   return fs.existsSync(markerPath());\n31: }\n32: \n33: function readMarker(): MarkerShape {\n34:   return JSON.parse(fs.readFileSync(markerPath(), 'utf8')) as MarkerShape;\n35: }\n36: \n37: beforeEach(() => {\n38:   // Point DATABASE_DIR at a throwaway directory so the marker module's real-fs\n39:   // writes never touch a live database. The marker reads DATABASE_DIR as a live\n40:   // ESM binding, so reassigning it via resolveDatabasePaths() redirects writes.\n41:   tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintmarker.'));\n42:   process.env.SPEC_KIT_DB_DIR = tmpDir;\n43:   delete process.env.SPECKIT_DB_DIR;\n44:   resolveDatabasePaths();\n45: });\n46: \n47: afterEach(() => {\n48:   __resetMaintenanceMarkerForTest();\n49:   try {\n50:     fs.rmSync(tmpDir, { recursive: true, force: true });\n51:   } catch {\n52:     // Best-effort cleanup\n53:   }\n54:   if (originalSpecKitDbDir === undefined) {\n55:     delete process.env.SPEC_KIT_DB_DIR;\n56:   } else {\n57:     process.env.SPEC_KIT_DB_DIR = originalSpecKitDbDir;\n58:   }\n59:   if (originalSpeckitDbDir === undefined) {\n60:     delete process.env.SPECKIT_DB_DIR;\n61:   } else {\n62:     process.env.SPECKIT_DB_DIR = originalSpeckitDbDir;\n63:   }\n64:   // Re-resolve so a subsequent suite/test sees a consistent DATABASE_DIR.\n65:   resolveDatabasePaths();\n66: });\n67: \n68: describe('maintenance-marker', () => {\n69:   it('beginMaintenance writes a marker with this pid, a future TTL, and the label', () => {\n70:     const before = Date.now();\n71:     const handle = beginMaintenance('scan');\n72: \n73:     expect(markerExists()).toBe(true);\n74:     const marker = readMarker();\n75:     expect(marker.childPid).toBe(process.pid);\n76:     expect(marker.activeUntilMs).toBeGreaterThan(before);\n77:     expect(marker.labels).toContain('scan');\n78: \n79:     handle.end();\n80:   });\n81: \n82:   it('is reference-counted: marker persists until the LAST holder ends', () => {\n83:     const first = beginMaintenance('scan');\n84:     const second = beginMaintenance('embedding-queue');\n85: \n86:     expect(markerExists()).toBe(true);\n87:     let marker = readMarker();\n88:     expect(marker.labels).toContain('scan');\n89:     expect(marker.labels).toContain('embedding-queue');\n90: \n91:     // Ending the FIRST holder: marker must STILL exist (second is active).\n92:     // The on-disk file is only rewritten on a write event (begin/refresh/timer),\n93:     // so end() does NOT itself re-serialize the pruned label set — it just\n94:     // decrements the in-memory ref count. The reference-counting contract under\n95:     // test is file PERSISTENCE while >=1 holder remains.\n96:     first.end();\n97:     expect(markerExists()).toBe(true);\n98: \n99:     // The next write (refresh on the surviving holder) reflects the pruned label\n100:     // set, confirming the first holder's label was decremented from live state.\n101:     second.refresh();\n102:     marker = readMarker();\n103:     expect(marker.labels).toContain('embedding-queue');\n104:     expect(marker.labels).not.toContain('scan');\n105: \n106:     // Ending the SECOND (last) holder: marker is REMOVED.\n107:     second.end();\n108:     expect(markerExists()).toBe(false);\n109:   });\n110: \n111:   it('end() is idempotent: calling twice on the sole holder removes the file once and does not throw', () => {\n112:     const handle = beginMaintenance('scan');\n113:     expect(markerExists()).toBe(true);\n114: \n115:     expect(() => {\n116:       handle.end();\n117:       handle.end();\n118:     }).not.toThrow();\n119: \n120:     expect(markerExists()).toBe(false);\n121:   });\n122: \n123:   it('refresh() rewrites the marker with a non-decreasing activeUntilMs and a refreshed timestamp', () => {\n124:     const handle = beginMaintenance('scan');\n125:     const first = readMarker();\n126: \n127:     handle.refresh();\n128:     const second = readMarker();\n129: \n130:     // TTL is recomputed from Date.now(); never goes backwards on refresh.\n131:     expect(second.activeUntilMs).toBeGreaterThanOrEqual(first.activeUntilMs);\n132:     // refreshedAtIso must be a valid ISO timestamp and not predate the first write.\n133:     expect(Date.parse(second.refreshedAtIso)).toBeGreaterThanOrEqual(\n134:       Date.parse(first.refreshedAtIso),\n135:     );\n136:     expect(Number.isNaN(Date.parse(second.refreshedAtIso))).toBe(false);\n137: \n138:     handle.end();\n139:   });\n140: \n141:   it('removes the marker once all handles have ended', () => {\n142:     const a = beginMaintenance('scan');\n143:     const b = beginMaintenance('embedding-queue');\n144:     const c = beginMaintenance('checkpoint');\n145:     expect(markerExists()).toBe(true);\n146: \n147:     a.end();\n148:     b.end();\n149:     expect(markerExists()).toBe(true);\n150: \n151:     c.end();\n152:     expect(markerExists()).toBe(false);\n153:   });\n154: });\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\nimport {\n  beginMaintenance,\n  __resetMaintenanceMarkerForTest,\n} from '../lib/storage/maintenance-marker';\nimport { resolveDatabasePaths } from '../core/config';\n\nconst MARKER_FILE = '.maintenance-active.json';\n\ninterface MarkerShape {\n  childPid: number;\n  activeUntilMs: number;\n  labels: string[];\n  refreshedAtIso: string;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","text":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\nimport {\n  beginMaintenance,\n  __resetMaintenanceMarkerForTest,\n} from '../lib/storage/maintenance-marker';\nimport { resolveDatabasePaths } from '../core/config';\n\nconst MARKER_FILE = '.maintenance-active.json';\n\ninterface MarkerShape {\n  childPid: number;\n  activeUntilMs: number;\n  labels: string[];\n  refreshedAtIso: string;\n}\n\nlet tmpDir: string;\nconst originalSpecKitDbDir = process.env.SPEC_KIT_DB_DIR;\nconst originalSpeckitDbDir = process.env.SPECKIT_DB_DIR;\n\nfunction markerPath(): string {\n  return path.join(tmpDir, MARKER_FILE);\n}\n\nfunction markerExists(): boolean {\n  return fs.existsSync(markerPath());\n}\n\nfunction readMarker(): MarkerShape {\n  return JSON.parse(fs.readFileSync(markerPath(), 'utf8')) as MarkerShape;\n}\n\nbeforeEach(() => {\n  // Point DATABASE_DIR at a throwaway directory so the marker module's real-fs\n  // writes never touch a live database. The marker reads DATABASE_DIR as a live\n  // ESM binding, so reassigning it via resolveDatabasePaths() redirects writes.\n  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintmarker.'));\n  process.env.SPEC_KIT_DB_DIR = tmpDir;\n  delete process.env.SPECKIT_DB_DIR;\n  resolveDatabasePaths();\n});\n\nafterEach(() => {\n  __resetMaintenanceMarkerForTest();\n  try {\n    fs.rmSync(tmpDir, { recursive: true, force: true });\n  } catch {\n    // Best-effort cleanup\n  }\n  if (originalSpecKitDbDir === undefined) {\n    delete process.env.SPEC_KIT_DB_DIR;\n  } else {\n    process.env.SPEC_KIT_DB_DIR = originalSpecKitDbDir;\n  }\n  if (originalSpeckitDbDir === undefined) {\n    delete process.env.SPECKIT_DB_DIR;\n  } else {\n    process.env.SPECKIT_DB_DIR = originalSpeckitDbDir;\n  }\n  // Re-resolve so a subsequent suite/test sees a consistent DATABASE_DIR.\n  resolveDatabasePaths();\n});\n\ndescribe('maintenance-marker', () => {\n  it('beginMaintenance writes a marker with this pid, a future TTL, and the label', () => {\n    const before = Date.now();\n    const handle = beginMaintenance('scan');\n\n    expect(markerExists()).toBe(true);\n    const marker = readMarker();\n    expect(marker.childPid).toBe(process.pid);\n    expect(marker.activeUntilMs).toBeGreaterThan(before);\n    expect(marker.labels).toContain('scan');\n\n    handle.end();\n  });\n\n  it('is reference-counted: marker persists until the LAST holder ends', () => {\n    const first = beginMaintenance('scan');\n    const second = beginMaintenance('embedding-queue');\n\n    expect(markerExists()).toBe(true);\n    let marker = readMarker();\n    expect(marker.labels).toContain('scan');\n    expect(marker.labels).toContain('embedding-queue');\n\n    // Ending the FIRST holder: marker must STILL exist (second is active).\n    // The on-disk file is only rewritten on a write event (begin/refresh/timer),\n    // so end() does NOT itself re-serialize the pruned label set — it just\n    // decrements the in-memory ref count. The reference-counting contract under\n    // test is file PERSISTENCE while >=1 holder remains.\n    first.end();\n    expect(markerExists()).toBe(true);\n\n    // The next write (refresh on the surviving holder) reflects the pruned label\n    // set, confirming the first holder's label was decremented from live state.\n    second.refresh();\n    marker = readMarker();\n    expect(marker.labels).toContain('embedding-queue');\n    expect(marker.labels).not.toContain('scan');\n\n    // Ending the SECOND (last) holder: marker is REMOVED.\n    second.end();\n    expect(markerExists()).toBe(false);\n  });\n\n  it('end() is idempotent: calling twice on the sole holder removes the file once and does not throw', () => {\n    const handle = beginMaintenance('scan');\n    expect(markerExists()).toBe(true);\n\n    expect(() => {\n      handle.end();\n      handle.end();\n    }).not.toThrow();\n\n    expect(markerExists()).toBe(false);\n  });\n\n  it('refresh() rewrites the marker with a non-decreasing activeUntilMs and a refreshed timestamp', () => {\n    const handle = beginMaintenance('scan');\n    const first = readMarker();\n\n    handle.refresh();\n    const second = readMarker();\n\n    // TTL is recomputed from Date.now(); never goes backwards on refresh.\n    expect(second.activeUntilMs).toBeGreaterThanOrEqual(first.activeUntilMs);\n    // refreshedAtIso must be a valid ISO timestamp and not predate the first write.\n    expect(Date.parse(second.refreshedAtIso)).toBeGreaterThanOrEqual(\n      Date.parse(first.refreshedAtIso),\n    );\n    expect(Number.isNaN(Date.parse(second.refreshedAtIso))).toBe(false);\n\n    handle.end();\n  });\n\n  it('removes the marker once all handles have ended', () => {\n    const a = beginMaintenance('scan');\n    const b = beginMaintenance('embedding-queue');\n    const c = beginMaintenance('checkpoint');\n    expect(markerExists()).toBe(true);\n\n    a.end();\n    b.end();\n    expect(markerExists()).toBe(true);\n\n    c.end();\n    expect(markerExists()).toBe(false);\n  });\n});","lineStart":1,"lineEnd":154,"totalLines":154,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","time":{"start":1781719583350,"end":1781719583357}},"id":"prt_ed6c348fc00103r5i8DslavoRy","sessionID":"ses_1293d8f5cffeM0kbBvfYyfngHB","messageID":"msg_ed6c336ef001I0rKYUIOI5aA9b"}}
