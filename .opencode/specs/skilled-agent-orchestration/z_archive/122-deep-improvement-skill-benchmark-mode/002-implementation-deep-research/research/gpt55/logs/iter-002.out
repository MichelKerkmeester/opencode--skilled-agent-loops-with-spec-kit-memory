   462	    const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (
   463	      recommendation.laneContributions.some((contribution) => (
   464	        (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')
   465	        && contribution.evidence.some((entry) => entry.includes(' '))
   466	      ))
   467	    ));
   468	    if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {
   469	      const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;
   470	      const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;
   471	      const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;
   472	      ranked = ranked.map((recommendation) => {
   473	        if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;
   474	        const uncertainty = Math.max(recommendation.uncertainty, floor);
   475	        return {
   476	          ...recommendation,
   477	          uncertainty,
   478	          passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,
   479	        };
   480	      });
   481	    }
   482	  }
   483	
   484	  // Class C: breadth / multi-concern abstention. A broad greenfield build
   485	  // ("build full stack typescript service") or a multi-concern optimization
   486	  // ("optimize X execution speed and recommendation quality") is under-specified
   487	  // for single-skill routing. When the top code-like candidate carries that
   488	  // shape, floor every passing candidate's uncertainty so strict callers abstain.
   489	  // Narrow anchors (a file, failing test, named component/route, benchmark, or
   490	  // review intent) bypass the broad-build branch; the multi-concern branch
   491	  // requires two distinct concern classes, so a file + single concern still routes.
   492	  if (!promptLower.includes('/')) {
   493	    const concernClasses = (CONCERN_PERF.test(promptLower) ? 1 : 0) + (CONCERN_QUALITY.test(promptLower) ? 1 : 0);
