{"type":"tool_use","timestamp":1783489678662,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"type":"tool","tool":"read","callID":"call_H627UzIaAYtdwbjDaewGPwgt","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json","offset":1,"limit":200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"skill\": \"deep-loop-workflows\",\n3:   \"version\": \"1.1.0.0\",\n4:   \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n5:   \"discriminator\": {\n6:     \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n7:     \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n8:     \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n9:   },\n10:   \"advisorRoutingContract\": {\n11:     \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n12:     \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n13:     \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n14:     \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n15:     \"packetSkillName\": \"The packet's SKILL.md name. Most packets use folder == packetSkillName == deep-<mode> (e.g. deep-ai-council). Exception: the four improvement lanes (agent/skill/model/ai-system-improvement) multiplex onto one shared packet 'deep-improvement', so several workflowModes map to that single folder/packetSkillName. The legacy public key 'ai-council' is preserved only on the command/agent surfaces, not on the packet folder/name.\",\n16:     \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts\"\n17:   },\n18:   \"extensions\": {\n19:     \"runtime-loop\": {\n20:       \"description\": \"Declares the runtime-loop backend: modes with backendKind 'runtime-loop-type' converge over deep-loop-runtime, keyed by runtimeLoopType (research|review|council). runtimeLoopType is explicit null for improvement-host and external-adapter modes and is never inferred from workflowMode.\",\n21:       \"runtimeLoopTypes\": [\"research\", \"review\", \"council\"]\n22:     },\n23:     \"advisor-projection\": {\n24:       \"description\": \"Declares that the advisor keeps hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry's advisorRouting projection. The advisor does not read this file at runtime; a CI drift-guard asserts maps == registry projection.\",\n25:       \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts\"\n26:     }\n27:   },\n28:   \"deprecatedModes\": [],\n29:   \"modes\": [\n30:     {\n31:       \"workflowMode\": \"research\",\n32:       \"runtimeLoopType\": \"research\",\n33:       \"backendKind\": \"runtime-loop-type\",\n34:       \"packetKind\": \"workflow\",\n35:       \"grandfatheredFolderMismatch\": false,\n36:       \"toolSurface\": {\n37:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\", \"WebFetch\"],\n38:         \"forbidden\": [],\n39:         \"mutatesWorkspace\": true,\n40:         \"bashAllowlist\": []\n41:       },\n42:       \"packet\": \"deep-research\",\n43:       \"command\": \"/deep:research\",\n44:       \"agent\": \"deep-research\",\n45:       \"artifactRoot\": \"research/\",\n46:       \"aliases\": [\"deep-research\", \"research loop\", \"iterative investigation workflow\", \"research convergence detection\", \"autoresearch\", \"iterative-research\"],\n47:       \"advisorRouting\": {\n48:         \"routingClass\": \"lexical\",\n49:         \"legacyAdvisorId\": \"deep-research\",\n50:         \"legacyAliases\": [\"command-spec-kit-deep-research\", \"/deep:start-research-loop\", \"spec_kit:deep-research\", \"deep-research\", \"sk-deep-research\"],\n51:         \"packetSkillName\": \"deep-research\"\n52:       }\n53:     },\n54:     {\n55:       \"workflowMode\": \"review\",\n56:       \"runtimeLoopType\": \"review\",\n57:       \"backendKind\": \"runtime-loop-type\",\n58:       \"packetKind\": \"workflow\",\n59:       \"grandfatheredFolderMismatch\": false,\n60:       \"toolSurface\": {\n61:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n62:         \"forbidden\": [],\n63:         \"mutatesWorkspace\": true,\n64:         \"bashAllowlist\": []\n65:       },\n66:       \"packet\": \"deep-review\",\n67:       \"command\": \"/deep:review\",\n68:       \"agent\": \"deep-review\",\n69:       \"artifactRoot\": \"review/\",\n70:       \"aliases\": [\"deep-review\", \"review loop\", \"iterative review loop\", \"severity weighted findings\", \"convergence review\", \"release-readiness\", \"deep-review wave\"],\n71:       \"advisorRouting\": {\n72:         \"routingClass\": \"lexical\",\n73:         \"legacyAdvisorId\": \"deep-review\",\n74:         \"legacyAliases\": [\"command-spec-kit-deep-review\", \"/deep:start-review-loop\", \"spec_kit:deep-review\", \"deep-review\", \"sk-deep-review\"],\n75:         \"packetSkillName\": \"deep-review\"\n76:       }\n77:     },\n78:     {\n79:       \"workflowMode\": \"ai-council\",\n80:       \"runtimeLoopType\": \"council\",\n81:       \"backendKind\": \"runtime-loop-type\",\n82:       \"packetKind\": \"workflow\",\n83:       \"grandfatheredFolderMismatch\": false,\n84:       \"toolSurface\": {\n85:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n86:         \"forbidden\": [],\n87:         \"mutatesWorkspace\": true,\n88:         \"bashAllowlist\": []\n89:       },\n90:       \"packet\": \"deep-ai-council\",\n91:       \"command\": \"/deep:ai-council\",\n92:       \"agent\": \"ai-council\",\n93:       \"artifactRoot\": \"ai-council/\",\n94:       \"aliases\": [\"deep-ai-council\", \"ai council deliberation\", \"multi-seat planning council\", \"council convergence\", \"planning council\"],\n95:       \"advisorRouting\": {\n96:         \"routingClass\": \"lexical\",\n97:         \"legacyAdvisorId\": \"deep-ai-council\",\n98:         \"legacyAliases\": [\"@deep-ai-council\", \"deep-ai-council\", \"deep ai council\", \"ai council\", \"planning council\", \"council deliberation\", \"multi-ai-council\"],\n99:         \"packetSkillName\": \"deep-ai-council\"\n100:       }\n101:     },\n102:     {\n103:       \"workflowMode\": \"agent-improvement\",\n104:       \"runtimeLoopType\": null,\n105:       \"backendKind\": \"improvement-host\",\n106:       \"packetKind\": \"workflow\",\n107:       \"grandfatheredFolderMismatch\": false,\n108:       \"toolSurface\": {\n109:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n110:         \"forbidden\": [],\n111:         \"mutatesWorkspace\": true,\n112:         \"bashAllowlist\": []\n113:       },\n114:       \"packet\": \"deep-improvement\",\n115:       \"loopHostMode\": \"agent-improvement\",\n116:       \"command\": \"/deep:agent-improvement\",\n117:       \"agent\": \"deep-improvement\",\n118:       \"artifactRoot\": \"improvement/\",\n119:       \"aliases\": [\"improve agent\", \"evaluate agent\", \"agent scoring\", \"score agent candidate\", \"promote or rollback agent change\", \"agent-improvement\"],\n120:       \"advisorRouting\": {\n121:         \"routingClass\": \"alias-fold\",\n122:         \"legacyAdvisorId\": \"deep-improvement\",\n123:         \"advisorDefaultMode\": true,\n124:         \"legacyAliases\": [\"command-spec-kit-deep-agent-improvement\", \"/deep:start-agent-improvement-loop\", \"deep-agent-improvement\", \"sk-deep-agent-improvement\"],\n125:         \"packetSkillName\": \"deep-improvement\"\n126:       }\n127:     },\n128:     {\n129:       \"workflowMode\": \"model-benchmark\",\n130:       \"runtimeLoopType\": null,\n131:       \"backendKind\": \"improvement-host\",\n132:       \"packetKind\": \"workflow\",\n133:       \"grandfatheredFolderMismatch\": false,\n134:       \"toolSurface\": {\n135:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n136:         \"forbidden\": [],\n137:         \"mutatesWorkspace\": true,\n138:         \"bashAllowlist\": []\n139:       },\n140:       \"packet\": \"deep-improvement\",\n141:       \"loopHostMode\": \"model-benchmark\",\n142:       \"command\": \"/deep:model-benchmark\",\n143:       \"agent\": \"deep-improvement\",\n144:       \"artifactRoot\": \"improvement/\",\n145:       \"aliases\": [\"model benchmark\", \"benchmark a model\", \"prompt framework benchmark\", \"benchmark-harness\"],\n146:       \"advisorRouting\": {\n147:         \"routingClass\": \"command-bridge\",\n148:         \"packetSkillName\": \"deep-improvement\"\n149:       }\n150:     },\n151:     {\n152:       \"workflowMode\": \"skill-benchmark\",\n153:       \"runtimeLoopType\": null,\n154:       \"backendKind\": \"improvement-host\",\n155:       \"packetKind\": \"workflow\",\n156:       \"grandfatheredFolderMismatch\": false,\n157:       \"toolSurface\": {\n158:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n159:         \"forbidden\": [],\n160:         \"mutatesWorkspace\": true,\n161:         \"bashAllowlist\": []\n162:       },\n163:       \"packet\": \"deep-improvement\",\n164:       \"loopHostMode\": \"skill-benchmark\",\n165:       \"command\": \"/deep:skill-benchmark\",\n166:       \"agent\": \"deep-improvement\",\n167:       \"artifactRoot\": \"improvement/\",\n168:       \"aliases\": [\"skill benchmark\", \"benchmark a skill\", \"skill routing benchmark\"],\n169:       \"advisorRouting\": {\n170:         \"routingClass\": \"command-bridge\",\n171:         \"packetSkillName\": \"deep-improvement\"\n172:       }\n173:     },\n174:     {\n175:       \"workflowMode\": \"ai-system-improvement\",\n176:       \"runtimeLoopType\": null,\n177:       \"backendKind\": \"external-adapter\",\n178:       \"packetKind\": \"workflow\",\n179:       \"grandfatheredFolderMismatch\": false,\n180:       \"toolSurface\": {\n181:         \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n182:         \"forbidden\": [],\n183:         \"mutatesWorkspace\": true,\n184:         \"bashAllowlist\": []\n185:       },\n186:       \"packet\": \"deep-improvement\",\n187:       \"loopHostMode\": \"non-dev-ai-system-refine\",\n188:       \"command\": \"/deep:ai-system-improvement\",\n189:       \"agent\": \"deep-improvement\",\n190:       \"artifactRoot\": \"improvement/\",\n191:       \"externalLoopOwner\": \"external packaging (e.g. Barter Copywriter) owns the Python loop, gates, scoring, and kill-switches\",\n192:       \"aliases\": [\"non-dev ai system\", \"non-dev-ai-system\", \"package ai system benchmark\"],\n193:       \"advisorRouting\": {\n194:         \"routingClass\": \"command-bridge\",\n195:         \"packetSkillName\": \"deep-improvement\"\n196:       }\n197:     }\n198:   ]\n199: }\n\n(End of file - total 199 lines)\n</content>","metadata":{"preview":"{\n  \"skill\": \"deep-loop-workflows\",\n  \"version\": \"1.1.0.0\",\n  \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n  \"discriminator\": {\n    \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n    \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n    \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n  },\n  \"advisorRoutingContract\": {\n    \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n    \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n    \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n    \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n    \"packetSkillName\": \"The packet's SKILL.md name. Most packets use folder == packetSkillName == deep-<mode> (e.g. deep-ai-council). Exception: the four improvement lanes (agent/skill/model/ai-system-improvement) multiplex onto one shared packet 'deep-improvement', so several workflowModes map to that single folder/packetSkillName. The legacy public key 'ai-council' is preserved only on the command/agent surfaces, not on the packet folder/name.\",\n    \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts\"\n  },\n  \"extensions\": {\n    \"runtime-loop\": {\n      \"description\": \"Declares the runtime-loop backend: modes with backendKind 'runtime-loop-type' converge over deep-loop-runtime, keyed by runtimeLoopType (research|review|council). runtimeLoopType is explicit null for improvement-host and external-adapter modes and is never inferred from workflowMode.\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json","text":"{\n  \"skill\": \"deep-loop-workflows\",\n  \"version\": \"1.1.0.0\",\n  \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n  \"discriminator\": {\n    \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n    \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n    \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n  },\n  \"advisorRoutingContract\": {\n    \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n    \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n    \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n    \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n    \"packetSkillName\": \"The packet's SKILL.md name. Most packets use folder == packetSkillName == deep-<mode> (e.g. deep-ai-council). Exception: the four improvement lanes (agent/skill/model/ai-system-improvement) multiplex onto one shared packet 'deep-improvement', so several workflowModes map to that single folder/packetSkillName. The legacy public key 'ai-council' is preserved only on the command/agent surfaces, not on the packet folder/name.\",\n    \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts\"\n  },\n  \"extensions\": {\n    \"runtime-loop\": {\n      \"description\": \"Declares the runtime-loop backend: modes with backendKind 'runtime-loop-type' converge over deep-loop-runtime, keyed by runtimeLoopType (research|review|council). runtimeLoopType is explicit null for improvement-host and external-adapter modes and is never inferred from workflowMode.\",\n      \"runtimeLoopTypes\": [\"research\", \"review\", \"council\"]\n    },\n    \"advisor-projection\": {\n      \"description\": \"Declares that the advisor keeps hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry's advisorRouting projection. The advisor does not read this file at runtime; a CI drift-guard asserts maps == registry projection.\",\n      \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts\"\n    }\n  },\n  \"deprecatedModes\": [],\n  \"modes\": [\n    {\n      \"workflowMode\": \"research\",\n      \"runtimeLoopType\": \"research\",\n      \"backendKind\": \"runtime-loop-type\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\", \"WebFetch\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-research\",\n      \"command\": \"/deep:research\",\n      \"agent\": \"deep-research\",\n      \"artifactRoot\": \"research/\",\n      \"aliases\": [\"deep-research\", \"research loop\", \"iterative investigation workflow\", \"research convergence detection\", \"autoresearch\", \"iterative-research\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"lexical\",\n        \"legacyAdvisorId\": \"deep-research\",\n        \"legacyAliases\": [\"command-spec-kit-deep-research\", \"/deep:start-research-loop\", \"spec_kit:deep-research\", \"deep-research\", \"sk-deep-research\"],\n        \"packetSkillName\": \"deep-research\"\n      }\n    },\n    {\n      \"workflowMode\": \"review\",\n      \"runtimeLoopType\": \"review\",\n      \"backendKind\": \"runtime-loop-type\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-review\",\n      \"command\": \"/deep:review\",\n      \"agent\": \"deep-review\",\n      \"artifactRoot\": \"review/\",\n      \"aliases\": [\"deep-review\", \"review loop\", \"iterative review loop\", \"severity weighted findings\", \"convergence review\", \"release-readiness\", \"deep-review wave\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"lexical\",\n        \"legacyAdvisorId\": \"deep-review\",\n        \"legacyAliases\": [\"command-spec-kit-deep-review\", \"/deep:start-review-loop\", \"spec_kit:deep-review\", \"deep-review\", \"sk-deep-review\"],\n        \"packetSkillName\": \"deep-review\"\n      }\n    },\n    {\n      \"workflowMode\": \"ai-council\",\n      \"runtimeLoopType\": \"council\",\n      \"backendKind\": \"runtime-loop-type\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-ai-council\",\n      \"command\": \"/deep:ai-council\",\n      \"agent\": \"ai-council\",\n      \"artifactRoot\": \"ai-council/\",\n      \"aliases\": [\"deep-ai-council\", \"ai council deliberation\", \"multi-seat planning council\", \"council convergence\", \"planning council\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"lexical\",\n        \"legacyAdvisorId\": \"deep-ai-council\",\n        \"legacyAliases\": [\"@deep-ai-council\", \"deep-ai-council\", \"deep ai council\", \"ai council\", \"planning council\", \"council deliberation\", \"multi-ai-council\"],\n        \"packetSkillName\": \"deep-ai-council\"\n      }\n    },\n    {\n      \"workflowMode\": \"agent-improvement\",\n      \"runtimeLoopType\": null,\n      \"backendKind\": \"improvement-host\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-improvement\",\n      \"loopHostMode\": \"agent-improvement\",\n      \"command\": \"/deep:agent-improvement\",\n      \"agent\": \"deep-improvement\",\n      \"artifactRoot\": \"improvement/\",\n      \"aliases\": [\"improve agent\", \"evaluate agent\", \"agent scoring\", \"score agent candidate\", \"promote or rollback agent change\", \"agent-improvement\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"alias-fold\",\n        \"legacyAdvisorId\": \"deep-improvement\",\n        \"advisorDefaultMode\": true,\n        \"legacyAliases\": [\"command-spec-kit-deep-agent-improvement\", \"/deep:start-agent-improvement-loop\", \"deep-agent-improvement\", \"sk-deep-agent-improvement\"],\n        \"packetSkillName\": \"deep-improvement\"\n      }\n    },\n    {\n      \"workflowMode\": \"model-benchmark\",\n      \"runtimeLoopType\": null,\n      \"backendKind\": \"improvement-host\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-improvement\",\n      \"loopHostMode\": \"model-benchmark\",\n      \"command\": \"/deep:model-benchmark\",\n      \"agent\": \"deep-improvement\",\n      \"artifactRoot\": \"improvement/\",\n      \"aliases\": [\"model benchmark\", \"benchmark a model\", \"prompt framework benchmark\", \"benchmark-harness\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"command-bridge\",\n        \"packetSkillName\": \"deep-improvement\"\n      }\n    },\n    {\n      \"workflowMode\": \"skill-benchmark\",\n      \"runtimeLoopType\": null,\n      \"backendKind\": \"improvement-host\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-improvement\",\n      \"loopHostMode\": \"skill-benchmark\",\n      \"command\": \"/deep:skill-benchmark\",\n      \"agent\": \"deep-improvement\",\n      \"artifactRoot\": \"improvement/\",\n      \"aliases\": [\"skill benchmark\", \"benchmark a skill\", \"skill routing benchmark\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"command-bridge\",\n        \"packetSkillName\": \"deep-improvement\"\n      }\n    },\n    {\n      \"workflowMode\": \"ai-system-improvement\",\n      \"runtimeLoopType\": null,\n      \"backendKind\": \"external-adapter\",\n      \"packetKind\": \"workflow\",\n      \"grandfatheredFolderMismatch\": false,\n      \"toolSurface\": {\n        \"allowed\": [\"Read\", \"Write\", \"Edit\", \"Bash\", \"Grep\", \"Glob\", \"Task\"],\n        \"forbidden\": [],\n        \"mutatesWorkspace\": true,\n        \"bashAllowlist\": []\n      },\n      \"packet\": \"deep-improvement\",\n      \"loopHostMode\": \"non-dev-ai-system-refine\",\n      \"command\": \"/deep:ai-system-improvement\",\n      \"agent\": \"deep-improvement\",\n      \"artifactRoot\": \"improvement/\",\n      \"externalLoopOwner\": \"external packaging (e.g. Barter Copywriter) owns the Python loop, gates, scoring, and kill-switches\",\n      \"aliases\": [\"non-dev ai system\", \"non-dev-ai-system\", \"package ai system benchmark\"],\n      \"advisorRouting\": {\n        \"routingClass\": \"command-bridge\",\n        \"packetSkillName\": \"deep-improvement\"\n      }\n    }\n  ]\n}","lineStart":1,"lineEnd":199,"totalLines":199,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/mode-registry.json","time":{"start":1783489678651,"end":1783489678658}},"metadata":{"openai":{"itemId":"fc_02b62f9ddc1234f6016a4de48e8ff081918fa416458856e9bb"}},"id":"prt_f4044ccfd001On4dgfVXqYSej2","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f4044af1d001Uy1B3fTllXTgEt"}}
{"type":"tool_use","timestamp":1783489678673,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"type":"tool","tool":"read","callID":"call_7dWMes56lK3KjdWtDgX6Kp7q","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/SKILL.md","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/SKILL.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: deep-research\n3: description: \"Autonomous deep-research loop: iterative investigation, externalized state, convergence detection, fresh context per pass.\"\n4: allowed-tools: [Read, Write, Edit, Bash, Grep, Glob, Task, WebFetch, memory_context, memory_search]\n5: argument-hint: \"[topic] [:auto|:confirm] [--max-iterations=N] [--convergence=N]\"\n6: version: 1.14.0.0\n7: ---\n8: \n9: <!-- Keywords: autoresearch, deep-research, iterative-research, autonomous-loop, convergence-detection, externalized-state, fresh-context, research-agent, JSONL-state, strategy-file -->\n10: \n11: # Autonomous Deep Research Loop\n12: \n13: Note: `Task` is allowed for the command executor that manages the loop. The `@deep-research` agent itself is LEAF-only and does not dispatch sub-agents.\n14: \n15: Iterative research protocol with fresh context per iteration, externalized state, and convergence detection for deep technical investigation.\n16: \n17: Runtime path resolution:\n18: - OpenCode/Copilot runtime: `.opencode/agents/*.md`\n19: - Claude runtime: `.claude/agents/*.md`\n20: \n21: Operator contract precedence for this skill surface:\n22: - Command entrypoint syntax in `.opencode/commands/deep/research.md`\n23: - Convergence math in `references/convergence/convergence.md` and the deep-research YAML workflow\n24: - Runtime agent inventories from the checked-in runtime directories above\n25: \n26: ### Convergence Threshold Semantics\n27: \n28: **Default:** 0.05 on newInfoRatio (fully-new=1.0, partially-new=0.5, +0.10 simplicity bonus, capped 1.0)\n29: \n30: **Semantic:** `convergenceThreshold` compares newly discovered information against accumulated research knowledge with negative-knowledge emphasis. Lower = more iterations / higher signal threshold.\n31: \n32: **NOT INTERCHANGEABLE with siblings:**\n33: - `deep-review` uses 0.10 default on weighted P0/P1/P2 severity ratio\n34: - `deep-ai-council` uses 0.20 default on adjudicator-verdict stability\n35: \n36: Carrying threshold expectations across siblings will cause unexpected iteration counts. See this skill's changelog and decision records for the cross-sibling threshold research and parity invariants that confirm thresholds do not carry across siblings.\n37: \n38: ## 1. WHEN TO USE\n39: \n40: ### Activation Triggers\n41: \n42: Use this skill when:\n43: - Deep investigation requiring multiple rounds of discovery\n44: - Topic spans 3+ technical domains or sources\n45: - Initial findings need progressive refinement\n46: - Overnight or unattended research sessions\n47: - Research where prior findings inform subsequent queries\n48: \n49: Keyword triggers:\n50: \n51: - `autoresearch`\n52: - `deep research`\n53: - `autonomous research`\n54: - `research loop`\n55: - `iterative research`\n56: - `multi-round research`\n57: - `deep investigation`\n58: - `comprehensive research`\n59: \n60: ### Use Cases\n61: \n62: Use deep-research for multi-round technical investigation, source triangulation, repeated exploration with fresh context, and research sessions where prior findings should shape the next focus.\n63: \n64: ### When NOT to Use\n65: \n66: - Simple, single-question research (use direct codebase search or `/speckit:plan`)\n67: - Known-solution documentation (use `/speckit:plan`)\n68: - Implementation tasks (use `/speckit:implement`)\n69: - Quick codebase searches (use `@context` or direct Grep/Glob)\n70: - Fewer than 3 sources needed (single-pass research suffices)\n71: \n72: ---\n73: \n74: ## 2. SMART ROUTING\n75: \n76: > Pattern: aligned with the [sk-doc smart-router resilience template](../../sk-doc/create-skill/assets/skill/skill_smart_router.md).\n77: \n78: ### Resource Domains\n79: \n80: The router discovers markdown resources recursively from `references/` and `assets/`, then applies intent scoring from `RESOURCE_MAP`. Keep routing domain-focused rather than hardcoding exhaustive inventories.\n81: \n82: - `references/guides/quick_reference.md` for the first-touch operator cheat sheet.\n83: - `references/protocol/loop_protocol.md` for lifecycle, dispatch, reducer sequencing, and command-owned state flow.\n84: - `references/protocol/spec_check_protocol.md` for bounded `spec.md` anchoring and generated-fence write-back.\n85: - `references/convergence*.md` for stop contracts, signals, recovery, graph gates, and reference-only convergence ideas.\n86: - `references/state*.md` for packet layout, JSONL records, markdown outputs, reducer ownership, and reconstruction.\n87: - `references/guides/capability_matrix.md` for runtime parity.\n88: - `assets/*.md` for markdown templates and prompt assets that are safe to route through guarded markdown loading.\n89: \n90: ### Resource Loading Levels\n91: \n92: | Level | When to Load | Resources |\n93: |-------|--------------|-----------|\n94: | ALWAYS | Every skill invocation | Quick reference baseline |\n95: | CONDITIONAL | If intent signals match | Loop, convergence, state, spec anchoring, runtime parity references |\n96: | ON_DEMAND | Only on explicit request | Full reference set and markdown assets |\n97: \n98: ### Phase Signals\n99: \n100: | Phase | Signal | Primary Resources |\n101: |-------|--------|-------------------|\n102: | Init | No JSONL exists or setup context | `loop_protocol.md`, `state_format.md`, `state_jsonl.md` |\n103: | Iteration | Dispatch context includes iteration number | `loop_protocol.md`, `state_outputs.md`, `convergence_signals.md` |\n104: | Stuck | Dispatch context includes recovery language | `convergence_recovery.md`, `state_reducer_registry.md` |\n105: | Synthesis | STOP candidate or final report | `convergence.md`, `state_outputs.md`, `spec_check_protocol.md` |\n106: \n107: ### Smart Router Pseudocode\n108: \n109: The authoritative routing logic for scoped loading, weighted intent scoring, ambiguity handling, and graceful fallback.\n110: \n111: - Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans `references/` and `assets/`.\n112: - Pattern 2: Existence-Check Before Load - `load_if_available()` guards paths, checks `inventory`, and suppresses repeats with `seen`.\n113: - Pattern 3: Extensible Routing Key - intent labels route to loop resource families without static file inventories.\n114: - Pattern 4: Multi-Tier Graceful Fallback - `UNKNOWN_FALLBACK_CHECKLIST` requests disambiguation and missing families return a helpful notice.\n115: \n116: ```python\n117: from pathlib import Path\n118: \n119: SKILL_ROOT = Path(__file__).resolve().parent\n120: RESOURCE_BASES = (SKILL_ROOT / \"references\", SKILL_ROOT / \"assets\")\n121: DEFAULT_RESOURCE = \"references/guides/quick_reference.md\"\n122: \n123: INTENT_SIGNALS = {\n124:     \"LOOP_SETUP\": {\"weight\": 4, \"keywords\": [\"autoresearch\", \"deep research\", \"research loop\", \"autonomous research\", \"setup\", \"init\"]},\n125:     \"ITERATION\": {\"weight\": 4, \"keywords\": [\"iteration\", \"next round\", \"continue research\", \"research cycle\", \"delta\", \"focus\"]},\n126:     \"CONVERGENCE\": {\"weight\": 4, \"keywords\": [\"convergence\", \"stop condition\", \"diminishing returns\", \"legal stop\", \"newInfoRatio\"]},\n127:     \"RECOVERY\": {\"weight\": 4, \"keywords\": [\"stuck\", \"recovery\", \"timeout\", \"reconstruct\", \"blocked stop\", \"blocked_stop\"]},\n128:     \"STATE\": {\"weight\": 4, \"keywords\": [\"state file\", \"jsonl\", \"strategy\", \"dashboard\", \"registry\", \"lineage\"]},\n129:     \"SPEC_ANCHORING\": {\"weight\": 3, \"keywords\": [\"spec.md\", \"generated fence\", \"folder_state\", \"lock\", \"spec anchoring\"]},\n130:     \"RUNTIME_PARITY\": {\"weight\": 3, \"keywords\": [\"runtime\", \"capability\", \"parity\", \"opencode\", \"claude\"]},\n131:     \"RESOURCE_MAP\": {\"weight\": 3, \"keywords\": [\"resource map\", \"resource-map\", \"inventory\", \"coverage gate\"]},\n132: }\n133: \n134: RESOURCE_MAP = {\n135:     \"LOOP_SETUP\": [\"references/protocol/loop_protocol.md\", \"references/state/state_format.md\", \"references/state/state_jsonl.md\", \"references/protocol/spec_check_protocol.md\"],\n136:     \"ITERATION\": [\"references/protocol/loop_protocol.md\", \"references/state/state_outputs.md\", \"references/convergence/convergence_signals.md\"],\n137:     \"CONVERGENCE\": [\"references/convergence/convergence.md\", \"references/convergence/convergence_signals.md\", \"references/convergence/convergence_graph.md\"],\n138:     \"RECOVERY\": [\"references/convergence/convergence_recovery.md\", \"references/state/state_reducer_registry.md\"],\n139:     \"STATE\": [\"references/state/state_format.md\", \"references/state/state_jsonl.md\", \"references/state/state_outputs.md\", \"references/state/state_reducer_registry.md\"],\n140:     \"SPEC_ANCHORING\": [\"references/protocol/spec_check_protocol.md\", \"references/state/state_outputs.md\"],\n141:     \"RUNTIME_PARITY\": [\"references/guides/capability_matrix.md\"],\n142:     \"RESOURCE_MAP\": [\"references/protocol/loop_protocol.md\", \"references/state/state_outputs.md\"],\n143: }\n144: \n145: LOADING_LEVELS = {\n146:     \"ALWAYS\": [DEFAULT_RESOURCE],\n147:     \"ON_DEMAND_KEYWORDS\": [\"full protocol\", \"all references\", \"complete reference\", \"resume deep research\", \"state log\", \"research/iterations\", \"deltas\", \"overnight research\", \"active lineage\", \"reference-only\", \"optimizer\"],\n148:     \"ON_DEMAND\": [\n149:         \"references/protocol/loop_protocol.md\",\n150:         \"references/protocol/spec_check_protocol.md\",\n151:         \"references/convergence/convergence.md\",\n152:         \"references/convergence/convergence_signals.md\",\n153:         \"references/convergence/convergence_recovery.md\",\n154:         \"references/convergence/convergence_graph.md\",\n155:         \"references/convergence/convergence_reference_only.md\",\n156:         \"references/state/state_format.md\",\n157:         \"references/state/state_jsonl.md\",\n158:         \"references/state/state_outputs.md\",\n159:         \"references/state/state_reducer_registry.md\",\n160:         \"references/guides/capability_matrix.md\",\n161:     ],\n162: }\n163: \n164: UNKNOWN_FALLBACK_CHECKLIST = [\n165:     \"Confirm setup vs iteration vs convergence vs state recovery\",\n166:     \"Confirm the target spec folder and research packet\",\n167:     \"Provide the current phase, latest iteration, or failing state file\",\n168:     \"Confirm whether full references or quick routing guidance are needed\",\n169: ]\n170: \n171: def _task_text(task) -> str:\n172:     return \" \".join([\n173:         str(getattr(task, \"text\", \"\")),\n174:         str(getattr(task, \"query\", \"\")),\n175:         \" \".join(getattr(task, \"keywords\", []) or []),\n176:     ]).lower()\n177: \n178: def _guard_in_skill(relative_path: str) -> str:\n179:     resolved = (SKILL_ROOT / relative_path).resolve()\n180:     resolved.relative_to(SKILL_ROOT)\n181:     if resolved.suffix.lower() != \".md\":\n182:         raise ValueError(f\"Only markdown resources are routable: {relative_path}\")\n183:     return resolved.relative_to(SKILL_ROOT).as_posix()\n184: \n185: def _guard_resource_map(resource_map: dict[str, list[str]]) -> None:\n186:     for intent, resources in resource_map.items():\n187:         for relative_path in resources:\n188:             guarded = _guard_in_skill(relative_path)\n189:             if guarded.startswith(\"references/\"):\n190:                 tail = guarded.removeprefix(\"references/\")\n191:                 if \"/\" not in tail and \"-\" in Path(tail).stem:\n192:                     raise ValueError(f\"RESOURCE_MAP must target canonical references, not compatibility stubs: {intent} -> {guarded}\")\n193: \n194: def discover_markdown_resources() -> set[str]:\n195:     docs = []\n196:     for base in RESOURCE_BASES:\n197:         if base.exists():\n198:             docs.extend(path for path in base.rglob(\"*.md\") if path.is_file())\n199:     return {doc.relative_to(SKILL_ROOT).as_posix() for doc in docs}\n200: \n201: def score_intents(task) -> dict[str, float]:\n202:     text = _task_text(task)\n203:     scores = {intent: 0.0 for intent in INTENT_SIGNALS}\n204:     for intent, cfg in INTENT_SIGNALS.items():\n205:         for keyword in cfg[\"keywords\"]:\n206:             if keyword in text:\n207:                 scores[intent] += cfg[\"weight\"]\n208:     return scores\n209: \n210: def select_intents(scores: dict[str, float], ambiguity_delta: float = 1.0, max_intents: int = 2) -> list[str]:\n211:     ranked = sorted(scores.items(), key=lambda item: item[1], reverse=True)\n212:     if not ranked or ranked[0][1] <= 0:\n213:         return [\"LOOP_SETUP\"]\n214:     selected = [ranked[0][0]]\n215:     if len(ranked) > 1 and ranked[1][1] > 0 and (ranked[0][1] - ranked[1][1]) <= ambiguity_delta:\n216:         selected.append(ranked[1][0])\n217:     return selected[:max_intents]\n218: \n219: def route_deep_research_resources(task):\n220:     _guard_resource_map(RESOURCE_MAP)\n221:     _guard_resource_map({\"ALWAYS\": LOADING_LEVELS[\"ALWAYS\"], \"ON_DEMAND\": LOADING_LEVELS[\"ON_DEMAND\"]})\n222:     inventory = discover_markdown_resources()\n223:     scores = score_intents(task)\n224:     intents = select_intents(scores)\n225:     loaded = []\n226:     seen = set()\n227: \n228:     def load_if_available(relative_path: str) -> None:\n229:         guarded = _guard_in_skill(relative_path)\n230:         if guarded in inventory and guarded not in seen:\n231:             load(guarded)\n232:             loaded.append(guarded)\n233:             seen.add(guarded)\n234: \n235:     for relative_path in LOADING_LEVELS[\"ALWAYS\"]:\n236:         load_if_available(relative_path)\n237: \n238:     if max(scores.values() or [0]) < 0.5:\n239:         return {\n240:             \"intents\": intents,\n\n(Showing lines 1-240 of 511. Use offset=241 to continue.)\n</content>","metadata":{"preview":"---\nname: deep-research\ndescription: \"Autonomous deep-research loop: iterative investigation, externalized state, convergence detection, fresh context per pass.\"\nallowed-tools: [Read, Write, Edit, Bash, Grep, Glob, Task, WebFetch, memory_context, memory_search]\nargument-hint: \"[topic] [:auto|:confirm] [--max-iterations=N] [--convergence=N]\"\nversion: 1.14.0.0\n---\n\n<!-- Keywords: autoresearch, deep-research, iterative-research, autonomous-loop, convergence-detection, externalized-state, fresh-context, research-agent, JSONL-state, strategy-file -->\n\n# Autonomous Deep Research Loop\n\nNote: `Task` is allowed for the command executor that manages the loop. The `@deep-research` agent itself is LEAF-only and does not dispatch sub-agents.\n\nIterative research protocol with fresh context per iteration, externalized state, and convergence detection for deep technical investigation.\n\nRuntime path resolution:\n- OpenCode/Copilot runtime: `.opencode/agents/*.md`\n- Claude runtime: `.claude/agents/*.md`\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/SKILL.md","text":"---\nname: deep-research\ndescription: \"Autonomous deep-research loop: iterative investigation, externalized state, convergence detection, fresh context per pass.\"\nallowed-tools: [Read, Write, Edit, Bash, Grep, Glob, Task, WebFetch, memory_context, memory_search]\nargument-hint: \"[topic] [:auto|:confirm] [--max-iterations=N] [--convergence=N]\"\nversion: 1.14.0.0\n---\n\n<!-- Keywords: autoresearch, deep-research, iterative-research, autonomous-loop, convergence-detection, externalized-state, fresh-context, research-agent, JSONL-state, strategy-file -->\n\n# Autonomous Deep Research Loop\n\nNote: `Task` is allowed for the command executor that manages the loop. The `@deep-research` agent itself is LEAF-only and does not dispatch sub-agents.\n\nIterative research protocol with fresh context per iteration, externalized state, and convergence detection for deep technical investigation.\n\nRuntime path resolution:\n- OpenCode/Copilot runtime: `.opencode/agents/*.md`\n- Claude runtime: `.claude/agents/*.md`\n\nOperator contract precedence for this skill surface:\n- Command entrypoint syntax in `.opencode/commands/deep/research.md`\n- Convergence math in `references/convergence/convergence.md` and the deep-research YAML workflow\n- Runtime agent inventories from the checked-in runtime directories above\n\n### Convergence Threshold Semantics\n\n**Default:** 0.05 on newInfoRatio (fully-new=1.0, partially-new=0.5, +0.10 simplicity bonus, capped 1.0)\n\n**Semantic:** `convergenceThreshold` compares newly discovered information against accumulated research knowledge with negative-knowledge emphasis. Lower = more iterations / higher signal threshold.\n\n**NOT INTERCHANGEABLE with siblings:**\n- `deep-review` uses 0.10 default on weighted P0/P1/P2 severity ratio\n- `deep-ai-council` uses 0.20 default on adjudicator-verdict stability\n\nCarrying threshold expectations across siblings will cause unexpected iteration counts. See this skill's changelog and decision records for the cross-sibling threshold research and parity invariants that confirm thresholds do not carry across siblings.\n\n## 1. WHEN TO USE\n\n### Activation Triggers\n\nUse this skill when:\n- Deep investigation requiring multiple rounds of discovery\n- Topic spans 3+ technical domains or sources\n- Initial findings need progressive refinement\n- Overnight or unattended research sessions\n- Research where prior findings inform subsequent queries\n\nKeyword triggers:\n\n- `autoresearch`\n- `deep research`\n- `autonomous research`\n- `research loop`\n- `iterative research`\n- `multi-round research`\n- `deep investigation`\n- `comprehensive research`\n\n### Use Cases\n\nUse deep-research for multi-round technical investigation, source triangulation, repeated exploration with fresh context, and research sessions where prior findings should shape the next focus.\n\n### When NOT to Use\n\n- Simple, single-question research (use direct codebase search or `/speckit:plan`)\n- Known-solution documentation (use `/speckit:plan`)\n- Implementation tasks (use `/speckit:implement`)\n- Quick codebase searches (use `@context` or direct Grep/Glob)\n- Fewer than 3 sources needed (single-pass research suffices)\n\n---\n\n## 2. SMART ROUTING\n\n> Pattern: aligned with the [sk-doc smart-router resilience template](../../sk-doc/create-skill/assets/skill/skill_smart_router.md).\n\n### Resource Domains\n\nThe router discovers markdown resources recursively from `references/` and `assets/`, then applies intent scoring from `RESOURCE_MAP`. Keep routing domain-focused rather than hardcoding exhaustive inventories.\n\n- `references/guides/quick_reference.md` for the first-touch operator cheat sheet.\n- `references/protocol/loop_protocol.md` for lifecycle, dispatch, reducer sequencing, and command-owned state flow.\n- `references/protocol/spec_check_protocol.md` for bounded `spec.md` anchoring and generated-fence write-back.\n- `references/convergence*.md` for stop contracts, signals, recovery, graph gates, and reference-only convergence ideas.\n- `references/state*.md` for packet layout, JSONL records, markdown outputs, reducer ownership, and reconstruction.\n- `references/guides/capability_matrix.md` for runtime parity.\n- `assets/*.md` for markdown templates and prompt assets that are safe to route through guarded markdown loading.\n\n### Resource Loading Levels\n\n| Level | When to Load | Resources |\n|-------|--------------|-----------|\n| ALWAYS | Every skill invocation | Quick reference baseline |\n| CONDITIONAL | If intent signals match | Loop, convergence, state, spec anchoring, runtime parity references |\n| ON_DEMAND | Only on explicit request | Full reference set and markdown assets |\n\n### Phase Signals\n\n| Phase | Signal | Primary Resources |\n|-------|--------|-------------------|\n| Init | No JSONL exists or setup context | `loop_protocol.md`, `state_format.md`, `state_jsonl.md` |\n| Iteration | Dispatch context includes iteration number | `loop_protocol.md`, `state_outputs.md`, `convergence_signals.md` |\n| Stuck | Dispatch context includes recovery language | `convergence_recovery.md`, `state_reducer_registry.md` |\n| Synthesis | STOP candidate or final report | `convergence.md`, `state_outputs.md`, `spec_check_protocol.md` |\n\n### Smart Router Pseudocode\n\nThe authoritative routing logic for scoped loading, weighted intent scoring, ambiguity handling, and graceful fallback.\n\n- Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans `references/` and `assets/`.\n- Pattern 2: Existence-Check Before Load - `load_if_available()` guards paths, checks `inventory`, and suppresses repeats with `seen`.\n- Pattern 3: Extensible Routing Key - intent labels route to loop resource families without static file inventories.\n- Pattern 4: Multi-Tier Graceful Fallback - `UNKNOWN_FALLBACK_CHECKLIST` requests disambiguation and missing families return a helpful notice.\n\n```python\nfrom pathlib import Path\n\nSKILL_ROOT = Path(__file__).resolve().parent\nRESOURCE_BASES = (SKILL_ROOT / \"references\", SKILL_ROOT / \"assets\")\nDEFAULT_RESOURCE = \"references/guides/quick_reference.md\"\n\nINTENT_SIGNALS = {\n    \"LOOP_SETUP\": {\"weight\": 4, \"keywords\": [\"autoresearch\", \"deep research\", \"research loop\", \"autonomous research\", \"setup\", \"init\"]},\n    \"ITERATION\": {\"weight\": 4, \"keywords\": [\"iteration\", \"next round\", \"continue research\", \"research cycle\", \"delta\", \"focus\"]},\n    \"CONVERGENCE\": {\"weight\": 4, \"keywords\": [\"convergence\", \"stop condition\", \"diminishing returns\", \"legal stop\", \"newInfoRatio\"]},\n    \"RECOVERY\": {\"weight\": 4, \"keywords\": [\"stuck\", \"recovery\", \"timeout\", \"reconstruct\", \"blocked stop\", \"blocked_stop\"]},\n    \"STATE\": {\"weight\": 4, \"keywords\": [\"state file\", \"jsonl\", \"strategy\", \"dashboard\", \"registry\", \"lineage\"]},\n    \"SPEC_ANCHORING\": {\"weight\": 3, \"keywords\": [\"spec.md\", \"generated fence\", \"folder_state\", \"lock\", \"spec anchoring\"]},\n    \"RUNTIME_PARITY\": {\"weight\": 3, \"keywords\": [\"runtime\", \"capability\", \"parity\", \"opencode\", \"claude\"]},\n    \"RESOURCE_MAP\": {\"weight\": 3, \"keywords\": [\"resource map\", \"resource-map\", \"inventory\", \"coverage gate\"]},\n}\n\nRESOURCE_MAP = {\n    \"LOOP_SETUP\": [\"references/protocol/loop_protocol.md\", \"references/state/state_format.md\", \"references/state/state_jsonl.md\", \"references/protocol/spec_check_protocol.md\"],\n    \"ITERATION\": [\"references/protocol/loop_protocol.md\", \"references/state/state_outputs.md\", \"references/convergence/convergence_signals.md\"],\n    \"CONVERGENCE\": [\"references/convergence/convergence.md\", \"references/convergence/convergence_signals.md\", \"references/convergence/convergence_graph.md\"],\n    \"RECOVERY\": [\"references/convergence/convergence_recovery.md\", \"references/state/state_reducer_registry.md\"],\n    \"STATE\": [\"references/state/state_format.md\", \"references/state/state_jsonl.md\", \"references/state/state_outputs.md\", \"references/state/state_reducer_registry.md\"],\n    \"SPEC_ANCHORING\": [\"references/protocol/spec_check_protocol.md\", \"references/state/state_outputs.md\"],\n    \"RUNTIME_PARITY\": [\"references/guides/capability_matrix.md\"],\n    \"RESOURCE_MAP\": [\"references/protocol/loop_protocol.md\", \"references/state/state_outputs.md\"],\n}\n\nLOADING_LEVELS = {\n    \"ALWAYS\": [DEFAULT_RESOURCE],\n    \"ON_DEMAND_KEYWORDS\": [\"full protocol\", \"all references\", \"complete reference\", \"resume deep research\", \"state log\", \"research/iterations\", \"deltas\", \"overnight research\", \"active lineage\", \"reference-only\", \"optimizer\"],\n    \"ON_DEMAND\": [\n        \"references/protocol/loop_protocol.md\",\n        \"references/protocol/spec_check_protocol.md\",\n        \"references/convergence/convergence.md\",\n        \"references/convergence/convergence_signals.md\",\n        \"references/convergence/convergence_recovery.md\",\n        \"references/convergence/convergence_graph.md\",\n        \"references/convergence/convergence_reference_only.md\",\n        \"references/state/state_format.md\",\n        \"references/state/state_jsonl.md\",\n        \"references/state/state_outputs.md\",\n        \"references/state/state_reducer_registry.md\",\n        \"references/guides/capability_matrix.md\",\n    ],\n}\n\nUNKNOWN_FALLBACK_CHECKLIST = [\n    \"Confirm setup vs iteration vs convergence vs state recovery\",\n    \"Confirm the target spec folder and research packet\",\n    \"Provide the current phase, latest iteration, or failing state file\",\n    \"Confirm whether full references or quick routing guidance are needed\",\n]\n\ndef _task_text(task) -> str:\n    return \" \".join([\n        str(getattr(task, \"text\", \"\")),\n        str(getattr(task, \"query\", \"\")),\n        \" \".join(getattr(task, \"keywords\", []) or []),\n    ]).lower()\n\ndef _guard_in_skill(relative_path: str) -> str:\n    resolved = (SKILL_ROOT / relative_path).resolve()\n    resolved.relative_to(SKILL_ROOT)\n    if resolved.suffix.lower() != \".md\":\n        raise ValueError(f\"Only markdown resources are routable: {relative_path}\")\n    return resolved.relative_to(SKILL_ROOT).as_posix()\n\ndef _guard_resource_map(resource_map: dict[str, list[str]]) -> None:\n    for intent, resources in resource_map.items():\n        for relative_path in resources:\n            guarded = _guard_in_skill(relative_path)\n            if guarded.startswith(\"references/\"):\n                tail = guarded.removeprefix(\"references/\")\n                if \"/\" not in tail and \"-\" in Path(tail).stem:\n                    raise ValueError(f\"RESOURCE_MAP must target canonical references, not compatibility stubs: {intent} -> {guarded}\")\n\ndef discover_markdown_resources() -> set[str]:\n    docs = []\n    for base in RESOURCE_BASES:\n        if base.exists():\n            docs.extend(path for path in base.rglob(\"*.md\") if path.is_file())\n    return {doc.relative_to(SKILL_ROOT).as_posix() for doc in docs}\n\ndef score_intents(task) -> dict[str, float]:\n    text = _task_text(task)\n    scores = {intent: 0.0 for intent in INTENT_SIGNALS}\n    for intent, cfg in INTENT_SIGNALS.items():\n        for keyword in cfg[\"keywords\"]:\n            if keyword in text:\n                scores[intent] += cfg[\"weight\"]\n    return scores\n\ndef select_intents(scores: dict[str, float], ambiguity_delta: float = 1.0, max_intents: int = 2) -> list[str]:\n    ranked = sorted(scores.items(), key=lambda item: item[1], reverse=True)\n    if not ranked or ranked[0][1] <= 0:\n        return [\"LOOP_SETUP\"]\n    selected = [ranked[0][0]]\n    if len(ranked) > 1 and ranked[1][1] > 0 and (ranked[0][1] - ranked[1][1]) <= ambiguity_delta:\n        selected.append(ranked[1][0])\n    return selected[:max_intents]\n\ndef route_deep_research_resources(task):\n    _guard_resource_map(RESOURCE_MAP)\n    _guard_resource_map({\"ALWAYS\": LOADING_LEVELS[\"ALWAYS\"], \"ON_DEMAND\": LOADING_LEVELS[\"ON_DEMAND\"]})\n    inventory = discover_markdown_resources()\n    scores = score_intents(task)\n    intents = select_intents(scores)\n    loaded = []\n    seen = set()\n\n    def load_if_available(relative_path: str) -> None:\n        guarded = _guard_in_skill(relative_path)\n        if guarded in inventory and guarded not in seen:\n            load(guarded)\n            loaded.append(guarded)\n            seen.add(guarded)\n\n    for relative_path in LOADING_LEVELS[\"ALWAYS\"]:\n        load_if_available(relative_path)\n\n    if max(scores.values() or [0]) < 0.5:\n        return {\n            \"intents\": intents,","lineStart":1,"lineEnd":240,"totalLines":511,"truncated":true}},"title":".opencode/skills/deep-loop-workflows/deep-research/SKILL.md","time":{"start":1783489678668,"end":1783489678672}},"metadata":{"openai":{"itemId":"fc_02b62f9ddc1234f6016a4de48e90048191b06073cf748b345c"}},"id":"prt_f4044cd44001oNsoLEMHkQRH7u","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f4044af1d001Uy1B3fTllXTgEt"}}
