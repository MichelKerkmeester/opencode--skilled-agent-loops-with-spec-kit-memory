   165	/**
   166	 * D4 grader factory (research iteration 3, F5 step 2). Returns an async grader
   167	 * function (virtualFixture, outputText, opts) -> { score, confidence, parse_status, ... }.
   168	 *   - 'llm'  : real claude grader via the ported harness
   169	 *   - 'mock' : deterministic stub via the harness mock path (default)
   170	 *   - 'noop' : D4 contributes a constant 1.0 (deterministic-only scoring)
   171	 */
   172	function buildGraderFn(graderKind) {
   173	  if (graderKind === 'noop') {
   174	    return async () => ({ score: 1.0, confidence: 1.0, parse_status: 'noop', dim_id: 'D4', rationale: 'grader disabled (noop)', evidence: [] });
   175	  }
   176	  const mode = graderKind === 'llm' ? 'real' : 'mock';
   177	  return async (virtualFixture, outputText, opts) => {
   178	    try {
   179	      return await harness.gradeD4({
   180	        fixture: virtualFixture,
   181	        swe16_output_text: outputText,
   182	        variant_hash: opts.candidateHash,
   183	        rubric_version: opts.rubricVersion || 'v1.0.0',
   184	        mode,
   185	        mock_mode: opts.mockMode || 'default',
   186	      });
   187	    } catch (err) {
   188	      return { score: 0.0, confidence: 0.0, parse_status: 'failed', dim_id: 'D4', error: err.message, evidence: [] };
   189	    }
   190	  };
   191	}
   192	
   193	async function score(opts) {
   194	  const {
   195	    candidateId,
   196	    candidateHash,
   197	    outputText,
   198	    criteria = {},
   199	    rubric = DEFAULT_RUBRIC,
   200	    cwd,
   201	    graderKind = 'mock',
   202	  } = opts;
   203	
   204	  if (!cwd || !path.isAbsolute(cwd)) {
   205	    throw new Error('score(): `cwd` must be an absolute path (decoupled scorer requires absolute scope.cwd)');
   206	  }
   207	
   208	  const fixtureId = opts.fixtureId || candidateId || 'virtual-fixture';
   209	  // Synthesize the in-memory virtual fixture with an ABSOLUTE cwd so the legacy
   210	  // det-check subprocesses (which path.resolve(PACKET_ROOT, scope.cwd)) decouple.
   211	  const virtualFixture = {
   212	    id: fixtureId,
   213	    scope: { cwd },
   214	    acceptance: criteria.acceptance || [],
   215	    grading: criteria.grading || [],
   216	    requiredHeadings: criteria.requiredHeadings || [],
   217	    requiredPatterns: criteria.requiredPatterns || [],
   218	    allowlist: criteria.allowlist || {},
   219	  };
   220	
   221	  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'dai-scorer-'));
   222	  const fixturePath = path.join(tmpDir, `fixture-${fixtureId}.json`);
   223	  const outputFile = path.join(tmpDir, `output-${candidateId || fixtureId}.md`);
   224	  try {
   225	    fs.writeFileSync(fixturePath, JSON.stringify(virtualFixture));
   226	    fs.writeFileSync(outputFile, outputText);
   227	
   228	    const acceptance = scoreAcceptanceDeterministic(virtualFixture.acceptance, cwd);
   229	    const bundleGate = runDetCheck('bundle-gate', fixturePath, outputFile);
   230	    const cwdCheck = runDetCheck('cwd-check', fixturePath, outputFile);
   231	    const preplanning = runDetCheck('preplanning-regex', fixturePath, outputFile);
   232	    const hallucinationDet = runDetCheck('hallucination-flag', fixturePath, outputFile);
   233	
   234	    const gate = applyHardGate(acceptance, bundleGate);
   235	    const finalAcc = gate.d1_capped;
   236	
   237	    const graderFn = buildGraderFn(graderKind);
   238	    const grader = await graderFn(virtualFixture, outputText, {
   239	      candidateHash: candidateHash || sha256Hex(outputText).slice(0, 16),
   240	      rubricVersion: opts.rubricVersion,
   241	      mockMode: opts.mockMode,
   242	    });
   243	
   244	    const dimScore = (id) => {
   245	      if (id === 'D1') return finalAcc.score;
   246	      if (id === 'D2') return bundleGate.score;
   247	      if (id === 'D3') return cwdCheck.score;
   248	      if (id === 'D4') return grader.score;
   249	      if (id === 'D5') return preplanning.score;
   250	      return 0;
   251	    };
   252	    let weighted = 0;
   253	    for (const d of rubric.dims) weighted += d.weight * dimScore(d.id);
   254	
   255	    return {
   256	      fixtureId,
   257	      candidateId: candidateId || null,
   258	      weightedScore: Math.round(weighted * 10000) / 10000,
   259	      hard_gate_failed: gate.hard_gate_failed,
   260	      dimensions: {
   261	        D1: finalAcc.score,
   262	        D2: bundleGate.score,
   263	        D3: cwdCheck.score,
   264	        D4: grader.score,
   265	        D5: preplanning.score,
   266	      },
   267	      deterministic: { acceptance: finalAcc, bundleGate, cwdCheck, preplanning, hallucinationDet },
   268	      grader,
   269	      interaction_terms: {
   270	        d2_x_d1_decoupled: bundleGate.score >= 0.8 && finalAcc.score <= 0.4,
   271	        d4_x_d1_inverse: grader.score >= 0.9 && finalAcc.score <= 0.4,
   272	        d5_x_d1_inverse: preplanning.score >= 0.8 && finalAcc.score <= 0.4,
   273	      },
   274	    };
   275	  } finally {
   276	    fs.rmSync(tmpDir, { recursive: true, force: true });
   277	  }
   278	}
   279	
   280	module.exports = { score, buildGraderFn, scoreAcceptanceDeterministic, DEFAULT_RUBRIC };
   281	
   282	async function main() {
   283	  const [outputFile, cwdArg] = process.argv.slice(2);
   284	  if (!outputFile || !cwdArg) {
   285	    process.stderr.write('usage: score-model-variant.cjs <output.md> <absolute-cwd> [--grader=mock|llm|noop]\n');
   286	    process.exit(2);
   287	  }
   288	  const graderArg = process.argv.find((a) => a.startsWith('--grader='));
   289	  const result = await score({
   290	    candidateId: path.basename(outputFile, '.md'),
   291	    outputText: fs.readFileSync(outputFile, 'utf8'),
   292	    criteria: {},
   293	    cwd: path.resolve(cwdArg),
   294	    graderKind: graderArg ? graderArg.slice('--grader='.length) : 'mock',
   295	  });
   296	  process.stdout.write(JSON.stringify(result, null, 2) + '\n');
   297	}
   298	
   299	if (require.main === module) main().catch((err) => { process.stderr.write(err.stack + '\n'); process.exit(1); });
