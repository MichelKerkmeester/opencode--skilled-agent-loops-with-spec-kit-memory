```python
def select_transport(request, scores, runtime):
    # CLI is default because figma-cli owns author/modify/export flows.
    if scores["MCP_CONTEXT"] > 0 and "mcp" in request.lower():
        return "OPTIONAL_MCP"
    if runtime.get("figma_cli_available"):
        return "CLI_PRIMARY"
    if scores["MCP_CONTEXT"] > 0 and runtime.get("code_mode_available"):
        return "OPTIONAL_MCP"
    return "CLI_PRIMARY_NEEDS_SETUP"
```

