{"type":"tool_use","timestamp":1780728101055,"sessionID":"ses_164567595ffekYKAW3lqY5njlC","part":{"type":"tool","tool":"read","callID":"call_qiO15JjaU5qILCRF6W9jqKeb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/pubsub.py","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/pubsub.py</path>\n<type>file</type>\n<content>\n1: \"\"\"GCP Pub/Sub event bus — used in SaaS deployments.\n2: \n3: Publishers push JSON-encoded `Event` payloads to per-topic Pub/Sub\n4: topics; subscribers pull messages from per-subscriber subscriptions and\n5: dispatch to async handlers.\n6: \n7: Topic + subscription provisioning is *not* done here — it's expected to\n8: be managed via Terraform / gcloud at deploy time so subscription\n9: configuration (ack deadlines, retry policies, dead-letter topics) lives\n10: with infra. This class assumes the topics/subscriptions already exist.\n11: \n12: Import is lazy so `common.events` can be imported in OSS standalone\n13: installs that don't have `google-cloud-pubsub` installed.\n14: \"\"\"\n15: \n16: from __future__ import annotations\n17: \n18: import asyncio\n19: import concurrent.futures\n20: import functools\n21: import json\n22: import logging\n23: from collections import defaultdict\n24: from typing import Any\n25: \n26: from pydantic import ValidationError\n27: \n28: from common.events.base import Event, EventBus, EventHandler\n29: \n30: logger = logging.getLogger(__name__)\n31: \n32: \n33: class PubSubEventBus(EventBus):\n34:     \"\"\"Pub/Sub-backed bus.\n35: \n36:     Construction args:\n37:         project_id: GCP project that owns the topics/subscriptions.\n38:         subscription_prefix: Applied to the *handler side* when we call\n39:             `subscribe(topic, handler)`. Subscriptions are named\n40:             ``f\"{subscription_prefix}--{topic}\"`` so a single topic can\n41:             have multiple distinct consumers (each service gets its own\n42:             subscription_prefix).\n43: \n44:     The handler side spawns one async pull task per subscription when\n45:     `start()` is called. Each pull task receives a message, runs the\n46:     handler, and ack/nacks based on the outcome. Pub/Sub handles redelivery\n47:     on nack.\n48: \n49:     **At-least-once delivery**: handlers registered against this bus\n50:     *must* be idempotent. Pub/Sub redelivers on ack failure and on\n51:     handler exceptions; a handler that already ran can be invoked again\n52:     for the same event. Use `event.event_id` as a natural dedup key.\n53:     \"\"\"\n54: \n55:     def __init__(\n56:         self,\n57:         project_id: str,\n58:         subscription_prefix: str,\n59:         *,\n60:         # Batch size per pull. Caps ``workers × max_messages``\n61:         # concurrent embed calls across the deployed pool, so 25\n62:         # balances drain throughput against the OpenAI per-org\n63:         # rate limit and the blast radius of a single wedged\n64:         # dispatch cycle.\n65:         max_messages: int = 25,\n66:         pull_timeout: float = 20.0,\n67:         error_backoff: float = 5.0,\n68:         publish_concurrency: int = 32,\n69:     ) -> None:\n70:         # No SDK import at construction: the factory can return this\n71:         # instance even in environments where google-cloud-pubsub isn't\n72:         # installed. The ImportError surfaces on first `publish` /\n73:         # `start` — see `_ensure_pubsub_sdk` below.\n74:         self._project_id = project_id\n75:         self._subscription_prefix = subscription_prefix\n76:         self._max_messages = max_messages\n77:         self._pull_timeout = pull_timeout\n78:         self._error_backoff = error_backoff\n79:         self._handlers: dict[str, list[EventHandler]] = defaultdict(list)\n80:         self._publisher: Any = None\n81:         self._subscriber: Any = None\n82:         self._pull_tasks: list[asyncio.Task[None]] = []\n83:         self._stopping = False\n84:         self._publish_concurrency = publish_concurrency\n85:         # One-shot flag so the \"subscribe without start()\" warning fires\n86:         # on the first publish only — otherwise we'd spam the log under\n87:         # sustained traffic. Reset in stop() so restarts reuse the same\n88:         # one-shot.\n89:         self._warned_missing_start = False\n90:         # Bounded executors for blocking SDK calls — lazy-init so stop()\n91:         # can shut them down and a subsequent start()/publish() gets a\n92:         # fresh one. asyncio's default executor is effectively unbounded\n93:         # per event loop; capping keeps a publish burst's blast radius\n94:         # predictable. Separate pools per role (publish vs pull) so a\n95:         # publish saturation can't starve message consumption and vice\n96:         # versa, and so stop() can close the subscriber first (waking\n97:         # blocked pull threads immediately via the gRPC channel error)\n98:         # then drain the pool, without the publish pool stalling that\n99:         # teardown sequence.\n100:         self._publish_executor: concurrent.futures.ThreadPoolExecutor | None = None\n101:         self._pull_executor: concurrent.futures.ThreadPoolExecutor | None = None\n102:         # Subscriptions whose pull loop halted on a permanent error\n103:         # (NotFound/PermissionDenied/InvalidArgument). Exposed via\n104:         # `is_healthy` so a health endpoint can mark the service unhealthy\n105:         # when consumption has stopped without crashing the process.\n106:         self._failed_subscriptions: set[str] = set()\n107:         # Set at the top of stop() before any executor teardown begins,\n108:         # so a concurrent publish() that raced through can't lazy-init\n109:         # a fresh executor that stop() never joins. Reset at the end of\n110:         # stop() so the bus can be restarted cleanly.\n111:         self._stopped: bool = False\n112:         # Monotonic counter incremented at the top of every ``stop()``.\n113:         # Lets ``start()`` detect a stop() that ran to FULL completion\n114:         # while it was suspended on an executor await — a clean teardown\n115:         # resets both ``_stopped`` and ``_stopping`` to False in stop()'s\n116:         # finally, so a flag-only check would miss the race. ``start()``\n117:         # captures this counter before the shielded await and bails if\n118:         # it changed afterwards.\n119:         self._stop_generation: int = 0\n120:         # Tracks whether start() has been awaited. Used by publish() to\n121:         # warn when subscribers are registered but start() was never\n122:         # called. Cleaner than inferring from `_pull_tasks`, which can\n123:         # also be empty after permanent pull errors or a clean stop().\n124:         self._started: bool = False\n125:         # Strong references for fire-and-forget background tasks\n126:         # (TOCTOU loser-close, post-stop candidate-close, cancelled-\n127:         # construction close). Without this set, ``asyncio.create_task``\n128:         # only stores its task in ``asyncio._all_tasks`` (a WeakSet)\n129:         # and the GC can collect it mid-await — Python docs explicitly\n130:         # warn against bare ``create_task(coro)``. The done-callback\n131:         # auto-discards on completion so the set stays bounded.\n132:         self._background_tasks: set[asyncio.Task[Any]] = set()\n133: \n134:     def _spawn_background_task(self, coro: Any) -> asyncio.Task[Any]:\n135:         \"\"\"Schedule a fire-and-forget task; see ``_background_tasks`` for why.\"\"\"\n136:         task = asyncio.create_task(coro)\n137:         self._background_tasks.add(task)\n138:         task.add_done_callback(self._background_tasks.discard)\n139:         return task\n140: \n141:     # ── publisher ──────────────────────────────────────────────────\n142: \n143:     @staticmethod\n144:     def _ensure_pubsub_sdk() -> Any:\n145:         try:\n146:             from google.cloud import pubsub_v1  # type: ignore[import-untyped]\n147: \n148:             return pubsub_v1\n149:         except ImportError as exc:\n150:             raise RuntimeError(\n151:                 \"PubSubEventBus requires `google-cloud-pubsub`. \"\n152:                 \"Install with: pip install 'google-cloud-pubsub>=2.23,<3'\"\n153:             ) from exc\n154: \n155:     async def _ensure_publisher(self) -> Any:\n156:         # Off-loop construction so a Workload Identity credential\n157:         # refresh inside the SDK doesn't pin the event loop on the\n158:         # first publish. TOCTOU-safe: if a concurrent caller\n159:         # populates ``_publisher`` while this one is awaiting the\n160:         # executor, the losing candidate is explicitly closed —\n161:         # ``PublisherClient`` wraps a gRPC channel and a background\n162:         # batch-flush thread, so leaving it for GC is non-deterministic\n163:         # (no documented ``__del__`` contract).\n164:         # Fast-path stop guard — symmetric with ``_get_publish_executor``.\n165:         # Refuse to even start construction work when the bus is\n166:         # already stopped (or stopping); the post-await guard below\n167:         # catches the same conditions when ``stop()`` races during\n168:         # the shielded await, but a synchronous bail-out before the\n169:         # SDK import avoids unnecessary executor + gRPC churn.\n170:         if self._stopped or self._stopping:\n171:             raise RuntimeError(\"PubSubEventBus is stopped\")\n172:         if self._publisher is not None:\n173:             return self._publisher\n174:         pubsub_v1 = self._ensure_pubsub_sdk()\n175:         loop = asyncio.get_running_loop()\n176:         # Generation snapshot so we can detect a ``stop()`` that ran to\n177:         # full completion during the executor await — clean teardown\n178:         # resets ``_stopped`` to False, so a flag-only check would miss\n179:         # the race. Without this, a fresh client gets installed into a\n180:         # bus that ``stop()`` already walked past, orphaning both the\n181:         # publisher and the executor it triggers in ``_get_publish_executor``.\n182:         stop_generation_before = self._stop_generation\n183:         # ``asyncio.shield`` so a task cancellation here doesn't strand\n184:         # the in-flight ``PublisherClient()`` inside the executor — the\n185:         # SDK call doesn't honour cancellation, so without the shield\n186:         # the future completes anyway but the caller never captures it,\n187:         # leaking the gRPC channel + flush thread.\n188:         ctor_fut = loop.run_in_executor(None, pubsub_v1.PublisherClient)\n189:         try:\n190:             candidate = await asyncio.shield(ctor_fut)\n191:         except asyncio.CancelledError:\n192:             # Cancelled mid-construction. Spawn a background closer for\n193:             # the still-pending future so the leaked client gets\n194:             # released; re-raise so the caller's cancellation\n195:             # propagates.\n196:             async def _close_pending() -> None:\n197:                 try:\n198:                     client = await ctor_fut\n199:                     await loop.run_in_executor(None, client.close)\n200:                 except BaseException:\n201:                     # ``BaseException`` (not ``Exception``) — this is a\n202:                     # fire-and-forget background task; if the event loop\n203:                     # cancels it during shutdown, the resulting\n204:                     # ``CancelledError`` would otherwise surface as\n205:                     # \"Task exception was never retrieved\" log noise.\n206:                     logger.debug(\n207:                         \"pubsub: cancelled-publisher close failed\", exc_info=True\n208:                     )\n209: \n210:             self._spawn_background_task(_close_pending())\n211:             raise\n212:         # Post-stop guard: if a concurrent ``stop()`` ran to completion\n213:         # during the await, installing the candidate would leak — the\n214:         # bus is \"stopped\" again only because stop()'s finally reset\n215:         # the flags after its cleanup. Close the candidate in the\n216:         # background and bail; ``publish()`` will get a RuntimeError\n217:         # which is the right shape for \"bus was stopped\".\n218:         if (\n219:             self._stopped\n220:             or self._stopping\n221:             or self._stop_generation != stop_generation_before\n222:         ):\n223: \n224:             async def _close_post_stop() -> None:\n225:                 try:\n226:                     await loop.run_in_executor(None, candidate.close)\n227:                 except BaseException:\n228:                     logger.debug(\n229:                         \"pubsub: post-stop candidate close failed\", exc_info=True\n230:                     )\n231: \n232:             self._spawn_background_task(_close_post_stop())\n233:             raise RuntimeError(\n234:                 \"PubSubEventBus was stopped during publisher construction\"\n235:             )\n236:         if self._publisher is None:\n237:             self._publisher = candidate\n238:             return self._publisher\n239:         if candidate is not self._publisher:\n240:             # Fire-and-forget close of the TOCTOU loser. Awaiting here\n241:             # would let an outer ``task.cancel()`` bleed into a pure\n242:             # cleanup branch; catching ``CancelledError`` to suppress\n243:             # it would clear the task's cancel-request (Py 3.9+) and\n244:             # let ``publish()`` continue to send the message even\n245:             # though the caller cancelled — a real bug. Schedule the\n246:             # close, return the cached publisher, and let any outer\n247:             # cancel propagate normally. (No interleaving risk between\n248:             # the create_task and the return: ``asyncio.create_task``\n249:             # is synchronous and doesn't yield.)\n250:             async def _close_loser() -> None:\n251:                 try:\n252:                     await loop.run_in_executor(None, candidate.close)\n253:                 except BaseException:\n254:                     # ``BaseException`` so a shutdown-time cancellation\n255:                     # of this background task doesn't surface as \"Task\n256:                     # exception was never retrieved\".\n257:                     logger.debug(\n258:                         \"pubsub: discarded duplicate PublisherClient.close() failed\",\n259:                         exc_info=True,\n260:                     )\n261: \n262:             self._spawn_background_task(_close_loser())\n263:         return self._publisher\n264: \n265:     @property\n266:     def is_healthy(self) -> bool:\n267:         \"\"\"True when the bus is in a state where it can still deliver\n268:         events end-to-end.\n269: \n270:         False in three cases:\n271: \n272:         1. ``stop()`` is in progress. The ``_stopped`` flag flips True\n273:            at the top of ``stop()`` (before any await point) and resets\n274:            False only at the very end — while True the bus has already\n275:            cancelled its pull tasks and is actively tearing down.\n276:            Checking this first means the graceful-shutdown window\n277:            starts when ``stop()`` is *called*, not when it *completes*.\n278:         2. Handlers were registered via ``subscribe()`` but ``start()``\n279:            was never awaited — the pull loops don't exist, so every\n280:            inbound event is silently dropped. ``_failed_subscriptions``\n281:            is empty in this case (the loops never ran) so we rely on\n282:            ``_started`` to distinguish \"deliberately publisher-only\"\n283:            (no handlers, healthy) from \"forgot to call start()\" (has\n284:            handlers but unstarted, unhealthy). This case also carries\n285:            the post-``stop()`` state: once ``_stopped`` resets to\n286:            False, a bus with handlers still reports unhealthy until\n287:            ``start()`` is (re-)called.\n288:         3. Any pull loop has halted on a permanent error (subscription\n289:            missing, SA permission revoked) — recorded in\n290:            ``_failed_subscriptions`` by ``_pull_loop``.\n291: \n292:         All three windows report unhealthy intentionally — the pod is\n293:         not consuming events during them, so it should not claim it is.\n294: \n295:         Surface this on the service's `/health` endpoint so a\n296:         misconfigured pod is marked unhealthy instead of silently\n297:         dropping events while the HTTP surface stays green.\n298:         \"\"\"\n299:         if self._stopped:\n300:             return False\n301:         if self._handlers and not self._started:\n302:             return False\n303:         return not self._failed_subscriptions\n304: \n305:     def _get_publish_executor(self) -> concurrent.futures.ThreadPoolExecutor:\n306:         # Refuse to spin up a fresh executor during stop()'s teardown\n307:         # window — otherwise a concurrent publish() could create a pool\n308:         # that stop() has already walked past and will never join.\n309:         if self._stopped:\n310:             raise RuntimeError(\"PubSubEventBus is stopped\")\n311:         if self._publish_executor is None:\n312:             self._publish_executor = concurrent.futures.ThreadPoolExecutor(\n313:                 max_workers=self._publish_concurrency,\n314:                 thread_name_prefix=\"pubsub-publish\",\n315:             )\n316:         return self._publish_executor\n317: \n318:     async def publish(self, topic: str, event: Event) -> None:\n319:         # Misconfiguration signal: handlers were registered but start()\n320:         # was never called, so no pull loop exists. Publishing still\n\n(Showing lines 1-320 of 874. Use offset=321 to continue.)\n</content>","metadata":{"preview":"\"\"\"GCP Pub/Sub event bus — used in SaaS deployments.\n\nPublishers push JSON-encoded `Event` payloads to per-topic Pub/Sub\ntopics; subscribers pull messages from per-subscriber subscriptions and\ndispatch to async handlers.\n\nTopic + subscription provisioning is *not* done here — it's expected to\nbe managed via Terraform / gcloud at deploy time so subscription\nconfiguration (ack deadlines, retry policies, dead-letter topics) lives\nwith infra. This class assumes the topics/subscriptions already exist.\n\nImport is lazy so `common.events` can be imported in OSS standalone\ninstalls that don't have `google-cloud-pubsub` installed.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport concurrent.futures\nimport functools","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/pubsub.py","text":"\"\"\"GCP Pub/Sub event bus — used in SaaS deployments.\n\nPublishers push JSON-encoded `Event` payloads to per-topic Pub/Sub\ntopics; subscribers pull messages from per-subscriber subscriptions and\ndispatch to async handlers.\n\nTopic + subscription provisioning is *not* done here — it's expected to\nbe managed via Terraform / gcloud at deploy time so subscription\nconfiguration (ack deadlines, retry policies, dead-letter topics) lives\nwith infra. This class assumes the topics/subscriptions already exist.\n\nImport is lazy so `common.events` can be imported in OSS standalone\ninstalls that don't have `google-cloud-pubsub` installed.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport concurrent.futures\nimport functools\nimport json\nimport logging\nfrom collections import defaultdict\nfrom typing import Any\n\nfrom pydantic import ValidationError\n\nfrom common.events.base import Event, EventBus, EventHandler\n\nlogger = logging.getLogger(__name__)\n\n\nclass PubSubEventBus(EventBus):\n    \"\"\"Pub/Sub-backed bus.\n\n    Construction args:\n        project_id: GCP project that owns the topics/subscriptions.\n        subscription_prefix: Applied to the *handler side* when we call\n            `subscribe(topic, handler)`. Subscriptions are named\n            ``f\"{subscription_prefix}--{topic}\"`` so a single topic can\n            have multiple distinct consumers (each service gets its own\n            subscription_prefix).\n\n    The handler side spawns one async pull task per subscription when\n    `start()` is called. Each pull task receives a message, runs the\n    handler, and ack/nacks based on the outcome. Pub/Sub handles redelivery\n    on nack.\n\n    **At-least-once delivery**: handlers registered against this bus\n    *must* be idempotent. Pub/Sub redelivers on ack failure and on\n    handler exceptions; a handler that already ran can be invoked again\n    for the same event. Use `event.event_id` as a natural dedup key.\n    \"\"\"\n\n    def __init__(\n        self,\n        project_id: str,\n        subscription_prefix: str,\n        *,\n        # Batch size per pull. Caps ``workers × max_messages``\n        # concurrent embed calls across the deployed pool, so 25\n        # balances drain throughput against the OpenAI per-org\n        # rate limit and the blast radius of a single wedged\n        # dispatch cycle.\n        max_messages: int = 25,\n        pull_timeout: float = 20.0,\n        error_backoff: float = 5.0,\n        publish_concurrency: int = 32,\n    ) -> None:\n        # No SDK import at construction: the factory can return this\n        # instance even in environments where google-cloud-pubsub isn't\n        # installed. The ImportError surfaces on first `publish` /\n        # `start` — see `_ensure_pubsub_sdk` below.\n        self._project_id = project_id\n        self._subscription_prefix = subscription_prefix\n        self._max_messages = max_messages\n        self._pull_timeout = pull_timeout\n        self._error_backoff = error_backoff\n        self._handlers: dict[str, list[EventHandler]] = defaultdict(list)\n        self._publisher: Any = None\n        self._subscriber: Any = None\n        self._pull_tasks: list[asyncio.Task[None]] = []\n        self._stopping = False\n        self._publish_concurrency = publish_concurrency\n        # One-shot flag so the \"subscribe without start()\" warning fires\n        # on the first publish only — otherwise we'd spam the log under\n        # sustained traffic. Reset in stop() so restarts reuse the same\n        # one-shot.\n        self._warned_missing_start = False\n        # Bounded executors for blocking SDK calls — lazy-init so stop()\n        # can shut them down and a subsequent start()/publish() gets a\n        # fresh one. asyncio's default executor is effectively unbounded\n        # per event loop; capping keeps a publish burst's blast radius\n        # predictable. Separate pools per role (publish vs pull) so a\n        # publish saturation can't starve message consumption and vice\n        # versa, and so stop() can close the subscriber first (waking\n        # blocked pull threads immediately via the gRPC channel error)\n        # then drain the pool, without the publish pool stalling that\n        # teardown sequence.\n        self._publish_executor: concurrent.futures.ThreadPoolExecutor | None = None\n        self._pull_executor: concurrent.futures.ThreadPoolExecutor | None = None\n        # Subscriptions whose pull loop halted on a permanent error\n        # (NotFound/PermissionDenied/InvalidArgument). Exposed via\n        # `is_healthy` so a health endpoint can mark the service unhealthy\n        # when consumption has stopped without crashing the process.\n        self._failed_subscriptions: set[str] = set()\n        # Set at the top of stop() before any executor teardown begins,\n        # so a concurrent publish() that raced through can't lazy-init\n        # a fresh executor that stop() never joins. Reset at the end of\n        # stop() so the bus can be restarted cleanly.\n        self._stopped: bool = False\n        # Monotonic counter incremented at the top of every ``stop()``.\n        # Lets ``start()`` detect a stop() that ran to FULL completion\n        # while it was suspended on an executor await — a clean teardown\n        # resets both ``_stopped`` and ``_stopping`` to False in stop()'s\n        # finally, so a flag-only check would miss the race. ``start()``\n        # captures this counter before the shielded await and bails if\n        # it changed afterwards.\n        self._stop_generation: int = 0\n        # Tracks whether start() has been awaited. Used by publish() to\n        # warn when subscribers are registered but start() was never\n        # called. Cleaner than inferring from `_pull_tasks`, which can\n        # also be empty after permanent pull errors or a clean stop().\n        self._started: bool = False\n        # Strong references for fire-and-forget background tasks\n        # (TOCTOU loser-close, post-stop candidate-close, cancelled-\n        # construction close). Without this set, ``asyncio.create_task``\n        # only stores its task in ``asyncio._all_tasks`` (a WeakSet)\n        # and the GC can collect it mid-await — Python docs explicitly\n        # warn against bare ``create_task(coro)``. The done-callback\n        # auto-discards on completion so the set stays bounded.\n        self._background_tasks: set[asyncio.Task[Any]] = set()\n\n    def _spawn_background_task(self, coro: Any) -> asyncio.Task[Any]:\n        \"\"\"Schedule a fire-and-forget task; see ``_background_tasks`` for why.\"\"\"\n        task = asyncio.create_task(coro)\n        self._background_tasks.add(task)\n        task.add_done_callback(self._background_tasks.discard)\n        return task\n\n    # ── publisher ──────────────────────────────────────────────────\n\n    @staticmethod\n    def _ensure_pubsub_sdk() -> Any:\n        try:\n            from google.cloud import pubsub_v1  # type: ignore[import-untyped]\n\n            return pubsub_v1\n        except ImportError as exc:\n            raise RuntimeError(\n                \"PubSubEventBus requires `google-cloud-pubsub`. \"\n                \"Install with: pip install 'google-cloud-pubsub>=2.23,<3'\"\n            ) from exc\n\n    async def _ensure_publisher(self) -> Any:\n        # Off-loop construction so a Workload Identity credential\n        # refresh inside the SDK doesn't pin the event loop on the\n        # first publish. TOCTOU-safe: if a concurrent caller\n        # populates ``_publisher`` while this one is awaiting the\n        # executor, the losing candidate is explicitly closed —\n        # ``PublisherClient`` wraps a gRPC channel and a background\n        # batch-flush thread, so leaving it for GC is non-deterministic\n        # (no documented ``__del__`` contract).\n        # Fast-path stop guard — symmetric with ``_get_publish_executor``.\n        # Refuse to even start construction work when the bus is\n        # already stopped (or stopping); the post-await guard below\n        # catches the same conditions when ``stop()`` races during\n        # the shielded await, but a synchronous bail-out before the\n        # SDK import avoids unnecessary executor + gRPC churn.\n        if self._stopped or self._stopping:\n            raise RuntimeError(\"PubSubEventBus is stopped\")\n        if self._publisher is not None:\n            return self._publisher\n        pubsub_v1 = self._ensure_pubsub_sdk()\n        loop = asyncio.get_running_loop()\n        # Generation snapshot so we can detect a ``stop()`` that ran to\n        # full completion during the executor await — clean teardown\n        # resets ``_stopped`` to False, so a flag-only check would miss\n        # the race. Without this, a fresh client gets installed into a\n        # bus that ``stop()`` already walked past, orphaning both the\n        # publisher and the executor it triggers in ``_get_publish_executor``.\n        stop_generation_before = self._stop_generation\n        # ``asyncio.shield`` so a task cancellation here doesn't strand\n        # the in-flight ``PublisherClient()`` inside the executor — the\n        # SDK call doesn't honour cancellation, so without the shield\n        # the future completes anyway but the caller never captures it,\n        # leaking the gRPC channel + flush thread.\n        ctor_fut = loop.run_in_executor(None, pubsub_v1.PublisherClient)\n        try:\n            candidate = await asyncio.shield(ctor_fut)\n        except asyncio.CancelledError:\n            # Cancelled mid-construction. Spawn a background closer for\n            # the still-pending future so the leaked client gets\n            # released; re-raise so the caller's cancellation\n            # propagates.\n            async def _close_pending() -> None:\n                try:\n                    client = await ctor_fut\n                    await loop.run_in_executor(None, client.close)\n                except BaseException:\n                    # ``BaseException`` (not ``Exception``) — this is a\n                    # fire-and-forget background task; if the event loop\n                    # cancels it during shutdown, the resulting\n                    # ``CancelledError`` would otherwise surface as\n                    # \"Task exception was never retrieved\" log noise.\n                    logger.debug(\n                        \"pubsub: cancelled-publisher close failed\", exc_info=True\n                    )\n\n            self._spawn_background_task(_close_pending())\n            raise\n        # Post-stop guard: if a concurrent ``stop()`` ran to completion\n        # during the await, installing the candidate would leak — the\n        # bus is \"stopped\" again only because stop()'s finally reset\n        # the flags after its cleanup. Close the candidate in the\n        # background and bail; ``publish()`` will get a RuntimeError\n        # which is the right shape for \"bus was stopped\".\n        if (\n            self._stopped\n            or self._stopping\n            or self._stop_generation != stop_generation_before\n        ):\n\n            async def _close_post_stop() -> None:\n                try:\n                    await loop.run_in_executor(None, candidate.close)\n                except BaseException:\n                    logger.debug(\n                        \"pubsub: post-stop candidate close failed\", exc_info=True\n                    )\n\n            self._spawn_background_task(_close_post_stop())\n            raise RuntimeError(\n                \"PubSubEventBus was stopped during publisher construction\"\n            )\n        if self._publisher is None:\n            self._publisher = candidate\n            return self._publisher\n        if candidate is not self._publisher:\n            # Fire-and-forget close of the TOCTOU loser. Awaiting here\n            # would let an outer ``task.cancel()`` bleed into a pure\n            # cleanup branch; catching ``CancelledError`` to suppress\n            # it would clear the task's cancel-request (Py 3.9+) and\n            # let ``publish()`` continue to send the message even\n            # though the caller cancelled — a real bug. Schedule the\n            # close, return the cached publisher, and let any outer\n            # cancel propagate normally. (No interleaving risk between\n            # the create_task and the return: ``asyncio.create_task``\n            # is synchronous and doesn't yield.)\n            async def _close_loser() -> None:\n                try:\n                    await loop.run_in_executor(None, candidate.close)\n                except BaseException:\n                    # ``BaseException`` so a shutdown-time cancellation\n                    # of this background task doesn't surface as \"Task\n                    # exception was never retrieved\".\n                    logger.debug(\n                        \"pubsub: discarded duplicate PublisherClient.close() failed\",\n                        exc_info=True,\n                    )\n\n            self._spawn_background_task(_close_loser())\n        return self._publisher\n\n    @property\n    def is_healthy(self) -> bool:\n        \"\"\"True when the bus is in a state where it can still deliver\n        events end-to-end.\n\n        False in three cases:\n\n        1. ``stop()`` is in progress. The ``_stopped`` flag flips True\n           at the top of ``stop()`` (before any await point) and resets\n           False only at the very end — while True the bus has already\n           cancelled its pull tasks and is actively tearing down.\n           Checking this first means the graceful-shutdown window\n           starts when ``stop()`` is *called*, not when it *completes*.\n        2. Handlers were registered via ``subscribe()`` but ``start()``\n           was never awaited — the pull loops don't exist, so every\n           inbound event is silently dropped. ``_failed_subscriptions``\n           is empty in this case (the loops never ran) so we rely on\n           ``_started`` to distinguish \"deliberately publisher-only\"\n           (no handlers, healthy) from \"forgot to call start()\" (has\n           handlers but unstarted, unhealthy). This case also carries\n           the post-``stop()`` state: once ``_stopped`` resets to\n           False, a bus with handlers still reports unhealthy until\n           ``start()`` is (re-)called.\n        3. Any pull loop has halted on a permanent error (subscription\n           missing, SA permission revoked) — recorded in\n           ``_failed_subscriptions`` by ``_pull_loop``.\n\n        All three windows report unhealthy intentionally — the pod is\n        not consuming events during them, so it should not claim it is.\n\n        Surface this on the service's `/health` endpoint so a\n        misconfigured pod is marked unhealthy instead of silently\n        dropping events while the HTTP surface stays green.\n        \"\"\"\n        if self._stopped:\n            return False\n        if self._handlers and not self._started:\n            return False\n        return not self._failed_subscriptions\n\n    def _get_publish_executor(self) -> concurrent.futures.ThreadPoolExecutor:\n        # Refuse to spin up a fresh executor during stop()'s teardown\n        # window — otherwise a concurrent publish() could create a pool\n        # that stop() has already walked past and will never join.\n        if self._stopped:\n            raise RuntimeError(\"PubSubEventBus is stopped\")\n        if self._publish_executor is None:\n            self._publish_executor = concurrent.futures.ThreadPoolExecutor(\n                max_workers=self._publish_concurrency,\n                thread_name_prefix=\"pubsub-publish\",\n            )\n        return self._publish_executor\n\n    async def publish(self, topic: str, event: Event) -> None:\n        # Misconfiguration signal: handlers were registered but start()\n        # was never called, so no pull loop exists. Publishing still","lineStart":1,"lineEnd":320,"totalLines":874,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/pubsub.py","time":{"start":1780728101028,"end":1780728101054}},"metadata":{"openai":{"itemId":"fc_0ee41bda9f90bad4016a23c124eb088191a9319c3df6d6f961"}},"id":"prt_e9baa789f001ccqbtD3l2Yrwmh","sessionID":"ses_164567595ffekYKAW3lqY5njlC","messageID":"msg_e9baa405b001y8u6gbQAgsZ4K6"}}
{"type":"tool_use","timestamp":1780728101057,"sessionID":"ses_164567595ffekYKAW3lqY5njlC","part":{"type":"tool","tool":"read","callID":"call_48S4ybKLRRcpu22nqPEQtkMl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_enrich_publisher.py","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_enrich_publisher.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish ``Topics.Memory.ENRICH_REQUESTED`` events.\n2: \n3: Convenience wrapper that resolves the tenant's enrichment provider /\n4: model / credentials / fallback target and packs them into the\n5: :class:`~common.events.memory_enrich_request.MemoryEnrichRequest`\n6: payload. Mirrors :func:`common.events.memory_embed_publisher.publish_memory_embed_request`\n7: in shape; the extra surface area is the tenant-config plumbing the\n8: enricher needs (CAURA-595 Q1=C: tenant_config travels in the payload).\n9: \n10: Schema-drift between this caller and\n11: ``core_worker.consumer.handle_enrich_request`` surfaces here at publish\n12: time (Pydantic ``ValidationError``) rather than as a runtime error\n13: inside the worker.\n14: \"\"\"\n15: \n16: from __future__ import annotations\n17: \n18: from datetime import datetime\n19: from uuid import UUID\n20: \n21: from common.events.base import Event\n22: from common.events.factory import get_event_bus\n23: from common.events.memory_enrich_request import MemoryEnrichRequest\n24: from common.events.topics import Topics\n25: \n26: \n27: async def publish_memory_enrich_request(\n28:     *,\n29:     memory_id: UUID,\n30:     content: str,\n31:     tenant_id: str,\n32:     tenant_config: object | None = None,\n33:     reference_datetime: datetime | None = None,\n34:     agent_provided_fields: list[str] | None = None,\n35: ) -> None:\n36:     \"\"\"Publish one enrich-request event for a memory persisted without inline enrichment.\n37: \n38:     ``tenant_config`` is a ``ResolvedConfig``-shaped object (or ``None``).\n39:     The publisher reads the enrichment-relevant attributes off it and\n40:     packs them into the payload so the worker doesn't need to import\n41:     ``core_api.services.organization_settings``.\n42: \n43:     ``agent_provided_fields`` lists the row's columns the agent set\n44:     explicitly at write time. The worker uses it to skip overwriting\n45:     those fields on PATCH so agent intent always wins (same gating the\n46:     synchronous path does inline). Pass ``None`` only when the\n47:     publisher genuinely has no idea — defaults to \"trust enrichment for\n48:     everything\", which is the current pre-PR-C behaviour.\n49: \n50:     Fire-and-forget: ``bus.publish`` returns once the transport has\n51:     accepted the message (Pub/Sub) or the in-process subscriber has been\n52:     invoked. Callers wrap the call in\n53:     ``track_task(tracked_task(...))`` so a transport error doesn't bubble\n54:     out of the request handler.\n55:     \"\"\"\n56:     fallback_provider: str | None = None\n57:     fallback_model: str | None = None\n58:     if tenant_config is not None and hasattr(tenant_config, \"resolve_fallback\"):\n59:         # ``resolve_fallback()`` reads the resolver's own attribute\n60:         # tuples — only ``AttributeError`` / ``KeyError`` / ``TypeError``\n61:         # are plausible. Anything else is a real bug; let it surface\n62:         # to the caller's ``track_task`` wrapper instead of silently\n63:         # demoting to \"no fallback\".\n64:         try:\n65:             fallback_provider, fallback_model = tenant_config.resolve_fallback()\n66:         except (AttributeError, KeyError, TypeError):\n67:             fallback_provider, fallback_model = None, None\n68: \n69:     payload = MemoryEnrichRequest(\n70:         memory_id=memory_id,\n71:         tenant_id=tenant_id,\n72:         content=content,\n73:         reference_datetime=(\n74:             reference_datetime.isoformat() if reference_datetime else None\n75:         ),\n76:         enrichment_provider=getattr(tenant_config, \"enrichment_provider\", None),\n77:         enrichment_model=getattr(tenant_config, \"enrichment_model\", None),\n78:         openai_api_key=getattr(tenant_config, \"openai_api_key\", None),\n79:         anthropic_api_key=getattr(tenant_config, \"anthropic_api_key\", None),\n80:         openrouter_api_key=getattr(tenant_config, \"openrouter_api_key\", None),\n81:         gemini_api_key=getattr(tenant_config, \"gemini_api_key\", None),\n82:         fallback_provider=fallback_provider,\n83:         fallback_model=fallback_model,\n84:         agent_provided_fields=agent_provided_fields,\n85:     )\n86:     event = Event(\n87:         event_type=Topics.Memory.ENRICH_REQUESTED,\n88:         tenant_id=tenant_id,\n89:         # ``include_secrets=True`` opts out of the\n90:         # ``MemoryEnrichRequest._redact_secrets`` field-serializer so\n91:         # the wire payload carries the raw API keys (the worker needs\n92:         # them to resolve the tenant's LLM provider). Every other\n93:         # ``model_dump()`` call site — logging, audit, ad-hoc\n94:         # ``json.dumps`` — gets ``\"***\"`` for those fields.\n95:         payload=payload.model_dump(mode=\"json\", context={\"include_secrets\": True}),\n96:     )\n97:     bus = get_event_bus()\n98:     await bus.publish(Topics.Memory.ENRICH_REQUESTED, event)\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"\"\"\"Publish ``Topics.Memory.ENRICH_REQUESTED`` events.\n\nConvenience wrapper that resolves the tenant's enrichment provider /\nmodel / credentials / fallback target and packs them into the\n:class:`~common.events.memory_enrich_request.MemoryEnrichRequest`\npayload. Mirrors :func:`common.events.memory_embed_publisher.publish_memory_embed_request`\nin shape; the extra surface area is the tenant-config plumbing the\nenricher needs (CAURA-595 Q1=C: tenant_config travels in the payload).\n\nSchema-drift between this caller and\n``core_worker.consumer.handle_enrich_request`` surfaces here at publish\ntime (Pydantic ``ValidationError``) rather than as a runtime error\ninside the worker.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom uuid import UUID\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_enrich_publisher.py","text":"\"\"\"Publish ``Topics.Memory.ENRICH_REQUESTED`` events.\n\nConvenience wrapper that resolves the tenant's enrichment provider /\nmodel / credentials / fallback target and packs them into the\n:class:`~common.events.memory_enrich_request.MemoryEnrichRequest`\npayload. Mirrors :func:`common.events.memory_embed_publisher.publish_memory_embed_request`\nin shape; the extra surface area is the tenant-config plumbing the\nenricher needs (CAURA-595 Q1=C: tenant_config travels in the payload).\n\nSchema-drift between this caller and\n``core_worker.consumer.handle_enrich_request`` surfaces here at publish\ntime (Pydantic ``ValidationError``) rather than as a runtime error\ninside the worker.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom uuid import UUID\n\nfrom common.events.base import Event\nfrom common.events.factory import get_event_bus\nfrom common.events.memory_enrich_request import MemoryEnrichRequest\nfrom common.events.topics import Topics\n\n\nasync def publish_memory_enrich_request(\n    *,\n    memory_id: UUID,\n    content: str,\n    tenant_id: str,\n    tenant_config: object | None = None,\n    reference_datetime: datetime | None = None,\n    agent_provided_fields: list[str] | None = None,\n) -> None:\n    \"\"\"Publish one enrich-request event for a memory persisted without inline enrichment.\n\n    ``tenant_config`` is a ``ResolvedConfig``-shaped object (or ``None``).\n    The publisher reads the enrichment-relevant attributes off it and\n    packs them into the payload so the worker doesn't need to import\n    ``core_api.services.organization_settings``.\n\n    ``agent_provided_fields`` lists the row's columns the agent set\n    explicitly at write time. The worker uses it to skip overwriting\n    those fields on PATCH so agent intent always wins (same gating the\n    synchronous path does inline). Pass ``None`` only when the\n    publisher genuinely has no idea — defaults to \"trust enrichment for\n    everything\", which is the current pre-PR-C behaviour.\n\n    Fire-and-forget: ``bus.publish`` returns once the transport has\n    accepted the message (Pub/Sub) or the in-process subscriber has been\n    invoked. Callers wrap the call in\n    ``track_task(tracked_task(...))`` so a transport error doesn't bubble\n    out of the request handler.\n    \"\"\"\n    fallback_provider: str | None = None\n    fallback_model: str | None = None\n    if tenant_config is not None and hasattr(tenant_config, \"resolve_fallback\"):\n        # ``resolve_fallback()`` reads the resolver's own attribute\n        # tuples — only ``AttributeError`` / ``KeyError`` / ``TypeError``\n        # are plausible. Anything else is a real bug; let it surface\n        # to the caller's ``track_task`` wrapper instead of silently\n        # demoting to \"no fallback\".\n        try:\n            fallback_provider, fallback_model = tenant_config.resolve_fallback()\n        except (AttributeError, KeyError, TypeError):\n            fallback_provider, fallback_model = None, None\n\n    payload = MemoryEnrichRequest(\n        memory_id=memory_id,\n        tenant_id=tenant_id,\n        content=content,\n        reference_datetime=(\n            reference_datetime.isoformat() if reference_datetime else None\n        ),\n        enrichment_provider=getattr(tenant_config, \"enrichment_provider\", None),\n        enrichment_model=getattr(tenant_config, \"enrichment_model\", None),\n        openai_api_key=getattr(tenant_config, \"openai_api_key\", None),\n        anthropic_api_key=getattr(tenant_config, \"anthropic_api_key\", None),\n        openrouter_api_key=getattr(tenant_config, \"openrouter_api_key\", None),\n        gemini_api_key=getattr(tenant_config, \"gemini_api_key\", None),\n        fallback_provider=fallback_provider,\n        fallback_model=fallback_model,\n        agent_provided_fields=agent_provided_fields,\n    )\n    event = Event(\n        event_type=Topics.Memory.ENRICH_REQUESTED,\n        tenant_id=tenant_id,\n        # ``include_secrets=True`` opts out of the\n        # ``MemoryEnrichRequest._redact_secrets`` field-serializer so\n        # the wire payload carries the raw API keys (the worker needs\n        # them to resolve the tenant's LLM provider). Every other\n        # ``model_dump()`` call site — logging, audit, ad-hoc\n        # ``json.dumps`` — gets ``\"***\"`` for those fields.\n        payload=payload.model_dump(mode=\"json\", context={\"include_secrets\": True}),\n    )\n    bus = get_event_bus()\n    await bus.publish(Topics.Memory.ENRICH_REQUESTED, event)","lineStart":1,"lineEnd":98,"totalLines":98,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/memory_enrich_publisher.py","time":{"start":1780728101045,"end":1780728101056}},"metadata":{"openai":{"itemId":"fc_0ee41bda9f90bad4016a23c124eb20819196dd6ab2d12d68cb"}},"id":"prt_e9baa78ad001ZxI70tB03qirrl","sessionID":"ses_164567595ffekYKAW3lqY5njlC","messageID":"msg_e9baa405b001y8u6gbQAgsZ4K6"}}
{"type":"tool_use","timestamp":1780728101059,"sessionID":"ses_164567595ffekYKAW3lqY5njlC","part":{"type":"tool","tool":"read","callID":"call_Ak4sTeMsHcoh5dBQvJcs6Ic5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Consumers for ``memclaw.lifecycle.<action>-requested`` topics\n2: (CAURA-655 archive ops, CAURA-656 purge, CAURA-657 pipeline ops).\n3: \n4: Lives in ``common/`` rather than under either service so the same code\n5: runs in both deployments. Two registration entry points reflect the\n6: split between SQL-only and pipeline-machinery ops:\n7: \n8: * :func:`register_archive_consumers` — archive + purge ops. Subscriber\n9:   is core-worker on SaaS; in OSS standalone core-api also subscribes\n10:   (no separate worker process).\n11: * :func:`register_pipeline_consumers` — crystallize + entity-link.\n12:   Subscriber is ALWAYS core-api because the consumer needs core-api's\n13:   pipeline machinery (run_crystallization, build_full_entity_linking_pipeline).\n14: \n15: The handler delegates the storage round-trips it needs (run the\n16: primitive, finalise the audit row, optionally check the dedup gate)\n17: to a small adapter the host service supplies. Per-action ops bind\n18: their own primitive callable + payload class at registration time so\n19: the dispatch never branches on a string.\n20: \"\"\"\n21: \n22: from __future__ import annotations\n23: \n24: import logging\n25: from collections.abc import Awaitable, Callable\n26: from functools import partial\n27: from typing import Protocol\n28: \n29: from pydantic import ValidationError\n30: \n31: from common.events.base import Event\n32: from common.events.factory import get_event_bus\n33: from common.events.lifecycle_archive_request import (\n34:     LifecycleArchiveRequest,\n35:     LifecycleRequestBase,\n36: )\n37: from common.events.lifecycle_purge_request import LifecyclePurgeRequest\n38: from common.events.topics import Topics\n39: \n40: logger = logging.getLogger(__name__)\n41: \n42: \n43: class ArchiveStorageAdapter(Protocol):\n44:     \"\"\"Methods the SQL-only lifecycle consumers (archive + purge) need.\"\"\"\n45: \n46:     async def archive_expired(self, *, org_id: str, fleet_id: str | None) -> int: ...\n47: \n48:     async def archive_stale(self, *, org_id: str, fleet_id: str | None) -> int: ...\n49: \n50:     async def purge_soft_deleted(\n51:         self, *, org_id: str, fleet_id: str | None, retention_days: int\n52:     ) -> int: ...\n53: \n54:     async def update_lifecycle_audit_row(\n55:         self,\n56:         audit_id: int,\n57:         *,\n58:         status: str,\n59:         stats: dict | None = None,\n60:         error_message: str | None = None,\n61:     ) -> None: ...\n62: \n63: \n64: class PipelineStorageAdapter(Protocol):\n65:     \"\"\"Methods the LLM-heavy lifecycle consumers (crystallize +\n66:     entity-link) need. Wider than :class:`ArchiveStorageAdapter` —\n67:     adds the dedup gate (``has_recent_lifecycle_success``) plus the\n68:     two pipeline primitives. Both consumers live in core-api because\n69:     they need its pipeline machinery; this protocol exists so the\n70:     handler module stays free of core-api imports.\n71:     \"\"\"\n72: \n73:     async def crystallize(self, *, org_id: str, fleet_id: str | None) -> int: ...\n74: \n75:     async def entity_link(self, *, org_id: str, fleet_id: str | None) -> int: ...\n76: \n77:     async def insights(self, *, org_id: str, fleet_id: str | None) -> int: ...\n78: \n79:     async def has_recent_lifecycle_success(\n80:         self, *, org_id: str, action: str, since_hours: int\n81:     ) -> bool: ...\n82: \n83:     async def update_lifecycle_audit_row(\n84:         self,\n85:         audit_id: int,\n86:         *,\n87:         status: str,\n88:         stats: dict | None = None,\n89:         error_message: str | None = None,\n90:     ) -> None: ...\n91: \n92: \n93: # Back-compat alias so existing core-api/core-worker adapter code that\n94: # imports ``LifecycleStorageAdapter`` keeps type-checking. The shared\n95: # object on both sides actually implements both protocols today; the\n96: # split is at the registration boundary, not the adapter side.\n97: LifecycleStorageAdapter = ArchiveStorageAdapter\n98: \n99: \n100: # Pipeline ops dedup window. Cron fires daily, so 23 hours catches\n101: # \"fired twice within an hour due to a redeploy\" while still letting\n102: # the legitimate next-day tick through.\n103: _PIPELINE_DEDUP_WINDOW_HOURS = 23\n104: \n105: \n106: # Callable parameters are contravariant: an op that accepts a\n107: # ``LifecycleArchiveRequest`` (subclass) is NOT assignable to a\n108: # ``Callable[[LifecycleRequestBase], ...]``. Use ``...`` so the\n109: # registered closures (each with its own subclass-typed argument)\n110: # satisfy the alias without a ``# type: ignore``. ``_run_action``\n111: # never inspects ``run_op``'s parameter type itself — the caller\n112: # always passes the correctly-shaped request — so the looser alias\n113: # carries no runtime risk.\n114: _OpFn = Callable[..., Awaitable[int]]\n115: \n116: \n117: async def _run_action(\n118:     event: Event,\n119:     *,\n120:     adapter: ArchiveStorageAdapter | PipelineStorageAdapter,\n121:     payload_cls: type[LifecycleRequestBase],\n122:     run_op: _OpFn,\n123:     stats_key: str,\n124:     action: str,\n125:     dedup_window_hours: int | None = None,\n126: ) -> None:\n127:     \"\"\"Shared body for every lifecycle action — bound to a specific\n128:     primitive at registration time so this function never branches on\n129:     a string. SQL ops are naturally idempotent so Pub/Sub redelivery\n130:     is safe; each delivery attempt updates the SAME audit row (the\n131:     row id rides in the payload, pre-created by the fanout endpoint).\n132: \n133:     ``dedup_window_hours`` is set for pipeline ops only (CAURA-657):\n134:     if a successful run for the same org+action exists within the\n135:     window, this delivery is a no-op (audit row marked success with\n136:     ``stats.skipped`` so observers can distinguish \"did the work\" from\n137:     \"skipped because already done\"). Filtering on ``finished_at``\n138:     naturally excludes the in-progress row pre-published moments ago.\n139:     \"\"\"\n140:     try:\n141:         request = payload_cls(**event.payload)\n142:     except ValidationError:\n143:         logger.exception(\n144:             \"dropping malformed lifecycle-request payload\",\n145:             extra={\n146:                 \"event_type\": event.event_type,\n147:                 \"event_id\": str(event.event_id),\n148:                 \"dropped\": True,\n149:             },\n150:         )\n151:         return\n152: \n153:     audit_id = request.audit_id\n154:     org_id = request.org_id\n155:     triggered_by = request.triggered_by\n156: \n157:     # Dedup gate (pipeline ops only). Runs BEFORE the in_progress mark\n158:     # so the audit row's life cycle stays clean — pending → success\n159:     # with skipped=true, no in_progress flicker.\n160:     if dedup_window_hours is not None:\n161:         try:\n162:             already_done = await adapter.has_recent_lifecycle_success(  # type: ignore[union-attr]\n163:                 org_id=org_id, action=action, since_hours=dedup_window_hours\n164:             )\n165:         except Exception:\n166:             # Failed dedup check shouldn't block the op — better to run\n167:             # twice than skip a legitimate request because the gate\n168:             # endpoint flaked. Log and proceed.\n169:             logger.warning(\n170:                 \"lifecycle dedup check failed; proceeding without skip\",\n171:                 exc_info=True,\n172:                 extra={\"audit_id\": audit_id, \"action\": action},\n173:             )\n174:             already_done = False\n175:         if already_done:\n176:             # Same best-effort treatment as the in_progress mark\n177:             # below: the skip record is observability data, and a\n178:             # raise here would nack the message into a redeliver\n179:             # loop that re-checks the gate, fails the same write,\n180:             # and eventually DLQs a legitimate skip.\n181:             try:\n182:                 await adapter.update_lifecycle_audit_row(\n183:                     audit_id,\n184:                     status=\"success\",\n185:                     stats={\"skipped\": True, \"reason\": \"recent_success\"},\n186:                 )\n187:             except Exception:\n188:                 logger.warning(\n189:                     \"lifecycle audit skip update failed; acking anyway\",\n190:                     exc_info=True,\n191:                     extra={\"audit_id\": audit_id, \"action\": action},\n192:                 )\n193:             logger.info(\n194:                 \"lifecycle %s skipped — recent successful run exists\",\n195:                 action,\n196:                 extra={\n197:                     \"audit_id\": audit_id,\n198:                     \"org_id\": org_id,\n199:                     \"triggered_by\": triggered_by,\n200:                 },\n201:             )\n202:             return\n203: \n204:     # Best-effort in_progress mark: 404 means the audit row was pruned\n205:     # between fanout and consume. Continue anyway so the primitive\n206:     # still runs — dropping would silently skip an op the operator\n207:     # asked for.\n208:     try:\n209:         await adapter.update_lifecycle_audit_row(audit_id, status=\"in_progress\")\n210:     except Exception:\n211:         logger.warning(\n212:             \"lifecycle audit in_progress update failed; continuing\",\n213:             exc_info=True,\n214:             extra={\"audit_id\": audit_id, \"action\": action},\n215:         )\n216: \n217:     try:\n218:         count = await run_op(request)\n219:     except Exception as exc:\n220:         # Wrap the failure update in its own guard: if it raises, the\n221:         # outer ``raise`` below would never run and the original op\n222:         # exception would be silently replaced by the audit error,\n223:         # leaving the row stuck in ``in_progress`` indistinguishable\n224:         # from a crashed worker.\n225:         try:\n226:             await adapter.update_lifecycle_audit_row(\n227:                 audit_id,\n228:                 status=\"failure\",\n229:                 error_message=str(exc)[:500],\n230:             )\n231:         except Exception:\n232:             logger.warning(\n233:                 \"lifecycle audit failure update failed; row stuck in_progress\",\n234:                 exc_info=True,\n235:                 extra={\"audit_id\": audit_id, \"action\": action},\n236:             )\n237:         # Re-raise so the bus nacks → Pub/Sub redelivers (subject to\n238:         # max-delivery-attempts → DLQ). The ``failure`` row above is\n239:         # the durable record (when the update succeeded).\n240:         raise\n241: \n242:     await adapter.update_lifecycle_audit_row(\n243:         audit_id,\n244:         status=\"success\",\n245:         stats={stats_key: count},\n246:     )\n247: \n248:     logger.info(\n249:         \"lifecycle %s processed\",\n250:         action,\n251:         extra={\n252:             \"audit_id\": audit_id,\n253:             \"org_id\": org_id,\n254:             \"triggered_by\": triggered_by,\n255:             stats_key: count,\n256:         },\n257:     )\n258: \n259: \n260: def register_archive_consumers(adapter: ArchiveStorageAdapter) -> None:\n261:     \"\"\"Subscribe the SQL-only lifecycle handlers (archive + purge).\n262:     Called by core-worker (SaaS) and core-api (OSS standalone).\n263:     \"\"\"\n264: \n265:     async def archive_expired_op(req: LifecycleArchiveRequest) -> int:\n266:         return await adapter.archive_expired(org_id=req.org_id, fleet_id=req.fleet_id)\n267: \n268:     async def archive_stale_op(req: LifecycleArchiveRequest) -> int:\n269:         return await adapter.archive_stale(org_id=req.org_id, fleet_id=req.fleet_id)\n270: \n271:     async def purge_op(req: LifecyclePurgeRequest) -> int:\n272:         return await adapter.purge_soft_deleted(\n273:             org_id=req.org_id,\n274:             fleet_id=req.fleet_id,\n275:             retention_days=req.retention_days,\n276:         )\n277: \n278:     bus = get_event_bus()\n279:     bus.subscribe(\n280:         Topics.Lifecycle.ARCHIVE_EXPIRED_REQUESTED,\n281:         partial(\n282:             _run_action,\n283:             adapter=adapter,\n284:             payload_cls=LifecycleArchiveRequest,\n285:             run_op=archive_expired_op,\n286:             stats_key=\"archived\",\n287:             action=\"archive-expired\",\n288:         ),\n289:     )\n290:     bus.subscribe(\n291:         Topics.Lifecycle.ARCHIVE_STALE_REQUESTED,\n292:         partial(\n293:             _run_action,\n294:             adapter=adapter,\n295:             payload_cls=LifecycleArchiveRequest,\n296:             run_op=archive_stale_op,\n297:             stats_key=\"archived\",\n298:             action=\"archive-stale\",\n299:         ),\n300:     )\n301:     bus.subscribe(\n302:         Topics.Lifecycle.PURGE_SOFT_DELETED_REQUESTED,\n303:         partial(\n304:             _run_action,\n305:             adapter=adapter,\n306:             payload_cls=LifecyclePurgeRequest,\n307:             run_op=purge_op,\n308:             stats_key=\"deleted\",\n309:             action=\"purge-soft-deleted\",\n310:         ),\n311:     )\n312: \n313: \n314: def register_pipeline_consumers(adapter: PipelineStorageAdapter) -> None:\n315:     \"\"\"Subscribe the LLM-heavy lifecycle handlers (crystallize +\n316:     entity-link). Called ONLY by core-api — these consumers need\n317:     core-api's pipeline machinery and can't run in core-worker today.\n318: \n319:     Both ops use the dedup gate: a successful run within the last 23\n320:     hours short-circuits a re-trigger to a no-op success record. The\n321:     daily cron interval gives a 1-hour slack window before the next\n322:     legitimate tick clears the dedup.\n323:     \"\"\"\n324: \n325:     async def crystallize_op(req: LifecycleArchiveRequest) -> int:\n326:         return await adapter.crystallize(org_id=req.org_id, fleet_id=req.fleet_id)\n327: \n328:     async def entity_link_op(req: LifecycleArchiveRequest) -> int:\n329:         return await adapter.entity_link(org_id=req.org_id, fleet_id=req.fleet_id)\n330: \n331:     async def insights_op(req: LifecycleArchiveRequest) -> int:\n332:         return await adapter.insights(org_id=req.org_id, fleet_id=req.fleet_id)\n333: \n334:     bus = get_event_bus()\n335:     bus.subscribe(\n336:         Topics.Lifecycle.CRYSTALLIZE_REQUESTED,\n337:         partial(\n338:             _run_action,\n339:             adapter=adapter,\n340:             payload_cls=LifecycleArchiveRequest,\n341:             run_op=crystallize_op,\n342:             stats_key=\"links_or_clusters\",\n343:             action=\"crystallize\",\n344:             dedup_window_hours=_PIPELINE_DEDUP_WINDOW_HOURS,\n345:         ),\n346:     )\n347:     bus.subscribe(\n348:         Topics.Lifecycle.ENTITY_LINK_REQUESTED,\n349:         partial(\n350:             _run_action,\n351:             adapter=adapter,\n352:             payload_cls=LifecycleArchiveRequest,\n353:             run_op=entity_link_op,\n354:             stats_key=\"links_created\",\n355:             action=\"entity-link\",\n356:             dedup_window_hours=_PIPELINE_DEDUP_WINDOW_HOURS,\n357:         ),\n358:     )\n359:     bus.subscribe(\n360:         Topics.Lifecycle.INSIGHTS_REQUESTED,\n\n(Showing lines 1-360 of 378. Use offset=361 to continue.)\n</content>","metadata":{"preview":"\"\"\"Consumers for ``memclaw.lifecycle.<action>-requested`` topics\n(CAURA-655 archive ops, CAURA-656 purge, CAURA-657 pipeline ops).\n\nLives in ``common/`` rather than under either service so the same code\nruns in both deployments. Two registration entry points reflect the\nsplit between SQL-only and pipeline-machinery ops:\n\n* :func:`register_archive_consumers` — archive + purge ops. Subscriber\n  is core-worker on SaaS; in OSS standalone core-api also subscribes\n  (no separate worker process).\n* :func:`register_pipeline_consumers` — crystallize + entity-link.\n  Subscriber is ALWAYS core-api because the consumer needs core-api's\n  pipeline machinery (run_crystallization, build_full_entity_linking_pipeline).\n\nThe handler delegates the storage round-trips it needs (run the\nprimitive, finalise the audit row, optionally check the dedup gate)\nto a small adapter the host service supplies. Per-action ops bind\ntheir own primitive callable + payload class at registration time so\nthe dispatch never branches on a string.\n\"\"\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py","text":"\"\"\"Consumers for ``memclaw.lifecycle.<action>-requested`` topics\n(CAURA-655 archive ops, CAURA-656 purge, CAURA-657 pipeline ops).\n\nLives in ``common/`` rather than under either service so the same code\nruns in both deployments. Two registration entry points reflect the\nsplit between SQL-only and pipeline-machinery ops:\n\n* :func:`register_archive_consumers` — archive + purge ops. Subscriber\n  is core-worker on SaaS; in OSS standalone core-api also subscribes\n  (no separate worker process).\n* :func:`register_pipeline_consumers` — crystallize + entity-link.\n  Subscriber is ALWAYS core-api because the consumer needs core-api's\n  pipeline machinery (run_crystallization, build_full_entity_linking_pipeline).\n\nThe handler delegates the storage round-trips it needs (run the\nprimitive, finalise the audit row, optionally check the dedup gate)\nto a small adapter the host service supplies. Per-action ops bind\ntheir own primitive callable + payload class at registration time so\nthe dispatch never branches on a string.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections.abc import Awaitable, Callable\nfrom functools import partial\nfrom typing import Protocol\n\nfrom pydantic import ValidationError\n\nfrom common.events.base import Event\nfrom common.events.factory import get_event_bus\nfrom common.events.lifecycle_archive_request import (\n    LifecycleArchiveRequest,\n    LifecycleRequestBase,\n)\nfrom common.events.lifecycle_purge_request import LifecyclePurgeRequest\nfrom common.events.topics import Topics\n\nlogger = logging.getLogger(__name__)\n\n\nclass ArchiveStorageAdapter(Protocol):\n    \"\"\"Methods the SQL-only lifecycle consumers (archive + purge) need.\"\"\"\n\n    async def archive_expired(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def archive_stale(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def purge_soft_deleted(\n        self, *, org_id: str, fleet_id: str | None, retention_days: int\n    ) -> int: ...\n\n    async def update_lifecycle_audit_row(\n        self,\n        audit_id: int,\n        *,\n        status: str,\n        stats: dict | None = None,\n        error_message: str | None = None,\n    ) -> None: ...\n\n\nclass PipelineStorageAdapter(Protocol):\n    \"\"\"Methods the LLM-heavy lifecycle consumers (crystallize +\n    entity-link) need. Wider than :class:`ArchiveStorageAdapter` —\n    adds the dedup gate (``has_recent_lifecycle_success``) plus the\n    two pipeline primitives. Both consumers live in core-api because\n    they need its pipeline machinery; this protocol exists so the\n    handler module stays free of core-api imports.\n    \"\"\"\n\n    async def crystallize(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def entity_link(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def insights(self, *, org_id: str, fleet_id: str | None) -> int: ...\n\n    async def has_recent_lifecycle_success(\n        self, *, org_id: str, action: str, since_hours: int\n    ) -> bool: ...\n\n    async def update_lifecycle_audit_row(\n        self,\n        audit_id: int,\n        *,\n        status: str,\n        stats: dict | None = None,\n        error_message: str | None = None,\n    ) -> None: ...\n\n\n# Back-compat alias so existing core-api/core-worker adapter code that\n# imports ``LifecycleStorageAdapter`` keeps type-checking. The shared\n# object on both sides actually implements both protocols today; the\n# split is at the registration boundary, not the adapter side.\nLifecycleStorageAdapter = ArchiveStorageAdapter\n\n\n# Pipeline ops dedup window. Cron fires daily, so 23 hours catches\n# \"fired twice within an hour due to a redeploy\" while still letting\n# the legitimate next-day tick through.\n_PIPELINE_DEDUP_WINDOW_HOURS = 23\n\n\n# Callable parameters are contravariant: an op that accepts a\n# ``LifecycleArchiveRequest`` (subclass) is NOT assignable to a\n# ``Callable[[LifecycleRequestBase], ...]``. Use ``...`` so the\n# registered closures (each with its own subclass-typed argument)\n# satisfy the alias without a ``# type: ignore``. ``_run_action``\n# never inspects ``run_op``'s parameter type itself — the caller\n# always passes the correctly-shaped request — so the looser alias\n# carries no runtime risk.\n_OpFn = Callable[..., Awaitable[int]]\n\n\nasync def _run_action(\n    event: Event,\n    *,\n    adapter: ArchiveStorageAdapter | PipelineStorageAdapter,\n    payload_cls: type[LifecycleRequestBase],\n    run_op: _OpFn,\n    stats_key: str,\n    action: str,\n    dedup_window_hours: int | None = None,\n) -> None:\n    \"\"\"Shared body for every lifecycle action — bound to a specific\n    primitive at registration time so this function never branches on\n    a string. SQL ops are naturally idempotent so Pub/Sub redelivery\n    is safe; each delivery attempt updates the SAME audit row (the\n    row id rides in the payload, pre-created by the fanout endpoint).\n\n    ``dedup_window_hours`` is set for pipeline ops only (CAURA-657):\n    if a successful run for the same org+action exists within the\n    window, this delivery is a no-op (audit row marked success with\n    ``stats.skipped`` so observers can distinguish \"did the work\" from\n    \"skipped because already done\"). Filtering on ``finished_at``\n    naturally excludes the in-progress row pre-published moments ago.\n    \"\"\"\n    try:\n        request = payload_cls(**event.payload)\n    except ValidationError:\n        logger.exception(\n            \"dropping malformed lifecycle-request payload\",\n            extra={\n                \"event_type\": event.event_type,\n                \"event_id\": str(event.event_id),\n                \"dropped\": True,\n            },\n        )\n        return\n\n    audit_id = request.audit_id\n    org_id = request.org_id\n    triggered_by = request.triggered_by\n\n    # Dedup gate (pipeline ops only). Runs BEFORE the in_progress mark\n    # so the audit row's life cycle stays clean — pending → success\n    # with skipped=true, no in_progress flicker.\n    if dedup_window_hours is not None:\n        try:\n            already_done = await adapter.has_recent_lifecycle_success(  # type: ignore[union-attr]\n                org_id=org_id, action=action, since_hours=dedup_window_hours\n            )\n        except Exception:\n            # Failed dedup check shouldn't block the op — better to run\n            # twice than skip a legitimate request because the gate\n            # endpoint flaked. Log and proceed.\n            logger.warning(\n                \"lifecycle dedup check failed; proceeding without skip\",\n                exc_info=True,\n                extra={\"audit_id\": audit_id, \"action\": action},\n            )\n            already_done = False\n        if already_done:\n            # Same best-effort treatment as the in_progress mark\n            # below: the skip record is observability data, and a\n            # raise here would nack the message into a redeliver\n            # loop that re-checks the gate, fails the same write,\n            # and eventually DLQs a legitimate skip.\n            try:\n                await adapter.update_lifecycle_audit_row(\n                    audit_id,\n                    status=\"success\",\n                    stats={\"skipped\": True, \"reason\": \"recent_success\"},\n                )\n            except Exception:\n                logger.warning(\n                    \"lifecycle audit skip update failed; acking anyway\",\n                    exc_info=True,\n                    extra={\"audit_id\": audit_id, \"action\": action},\n                )\n            logger.info(\n                \"lifecycle %s skipped — recent successful run exists\",\n                action,\n                extra={\n                    \"audit_id\": audit_id,\n                    \"org_id\": org_id,\n                    \"triggered_by\": triggered_by,\n                },\n            )\n            return\n\n    # Best-effort in_progress mark: 404 means the audit row was pruned\n    # between fanout and consume. Continue anyway so the primitive\n    # still runs — dropping would silently skip an op the operator\n    # asked for.\n    try:\n        await adapter.update_lifecycle_audit_row(audit_id, status=\"in_progress\")\n    except Exception:\n        logger.warning(\n            \"lifecycle audit in_progress update failed; continuing\",\n            exc_info=True,\n            extra={\"audit_id\": audit_id, \"action\": action},\n        )\n\n    try:\n        count = await run_op(request)\n    except Exception as exc:\n        # Wrap the failure update in its own guard: if it raises, the\n        # outer ``raise`` below would never run and the original op\n        # exception would be silently replaced by the audit error,\n        # leaving the row stuck in ``in_progress`` indistinguishable\n        # from a crashed worker.\n        try:\n            await adapter.update_lifecycle_audit_row(\n                audit_id,\n                status=\"failure\",\n                error_message=str(exc)[:500],\n            )\n        except Exception:\n            logger.warning(\n                \"lifecycle audit failure update failed; row stuck in_progress\",\n                exc_info=True,\n                extra={\"audit_id\": audit_id, \"action\": action},\n            )\n        # Re-raise so the bus nacks → Pub/Sub redelivers (subject to\n        # max-delivery-attempts → DLQ). The ``failure`` row above is\n        # the durable record (when the update succeeded).\n        raise\n\n    await adapter.update_lifecycle_audit_row(\n        audit_id,\n        status=\"success\",\n        stats={stats_key: count},\n    )\n\n    logger.info(\n        \"lifecycle %s processed\",\n        action,\n        extra={\n            \"audit_id\": audit_id,\n            \"org_id\": org_id,\n            \"triggered_by\": triggered_by,\n            stats_key: count,\n        },\n    )\n\n\ndef register_archive_consumers(adapter: ArchiveStorageAdapter) -> None:\n    \"\"\"Subscribe the SQL-only lifecycle handlers (archive + purge).\n    Called by core-worker (SaaS) and core-api (OSS standalone).\n    \"\"\"\n\n    async def archive_expired_op(req: LifecycleArchiveRequest) -> int:\n        return await adapter.archive_expired(org_id=req.org_id, fleet_id=req.fleet_id)\n\n    async def archive_stale_op(req: LifecycleArchiveRequest) -> int:\n        return await adapter.archive_stale(org_id=req.org_id, fleet_id=req.fleet_id)\n\n    async def purge_op(req: LifecyclePurgeRequest) -> int:\n        return await adapter.purge_soft_deleted(\n            org_id=req.org_id,\n            fleet_id=req.fleet_id,\n            retention_days=req.retention_days,\n        )\n\n    bus = get_event_bus()\n    bus.subscribe(\n        Topics.Lifecycle.ARCHIVE_EXPIRED_REQUESTED,\n        partial(\n            _run_action,\n            adapter=adapter,\n            payload_cls=LifecycleArchiveRequest,\n            run_op=archive_expired_op,\n            stats_key=\"archived\",\n            action=\"archive-expired\",\n        ),\n    )\n    bus.subscribe(\n        Topics.Lifecycle.ARCHIVE_STALE_REQUESTED,\n        partial(\n            _run_action,\n            adapter=adapter,\n            payload_cls=LifecycleArchiveRequest,\n            run_op=archive_stale_op,\n            stats_key=\"archived\",\n            action=\"archive-stale\",\n        ),\n    )\n    bus.subscribe(\n        Topics.Lifecycle.PURGE_SOFT_DELETED_REQUESTED,\n        partial(\n            _run_action,\n            adapter=adapter,\n            payload_cls=LifecyclePurgeRequest,\n            run_op=purge_op,\n            stats_key=\"deleted\",\n            action=\"purge-soft-deleted\",\n        ),\n    )\n\n\ndef register_pipeline_consumers(adapter: PipelineStorageAdapter) -> None:\n    \"\"\"Subscribe the LLM-heavy lifecycle handlers (crystallize +\n    entity-link). Called ONLY by core-api — these consumers need\n    core-api's pipeline machinery and can't run in core-worker today.\n\n    Both ops use the dedup gate: a successful run within the last 23\n    hours short-circuits a re-trigger to a no-op success record. The\n    daily cron interval gives a 1-hour slack window before the next\n    legitimate tick clears the dedup.\n    \"\"\"\n\n    async def crystallize_op(req: LifecycleArchiveRequest) -> int:\n        return await adapter.crystallize(org_id=req.org_id, fleet_id=req.fleet_id)\n\n    async def entity_link_op(req: LifecycleArchiveRequest) -> int:\n        return await adapter.entity_link(org_id=req.org_id, fleet_id=req.fleet_id)\n\n    async def insights_op(req: LifecycleArchiveRequest) -> int:\n        return await adapter.insights(org_id=req.org_id, fleet_id=req.fleet_id)\n\n    bus = get_event_bus()\n    bus.subscribe(\n        Topics.Lifecycle.CRYSTALLIZE_REQUESTED,\n        partial(\n            _run_action,\n            adapter=adapter,\n            payload_cls=LifecycleArchiveRequest,\n            run_op=crystallize_op,\n            stats_key=\"links_or_clusters\",\n            action=\"crystallize\",\n            dedup_window_hours=_PIPELINE_DEDUP_WINDOW_HOURS,\n        ),\n    )\n    bus.subscribe(\n        Topics.Lifecycle.ENTITY_LINK_REQUESTED,\n        partial(\n            _run_action,\n            adapter=adapter,\n            payload_cls=LifecycleArchiveRequest,\n            run_op=entity_link_op,\n            stats_key=\"links_created\",\n            action=\"entity-link\",\n            dedup_window_hours=_PIPELINE_DEDUP_WINDOW_HOURS,\n        ),\n    )\n    bus.subscribe(\n        Topics.Lifecycle.INSIGHTS_REQUESTED,","lineStart":1,"lineEnd":360,"totalLines":378,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/common/events/lifecycle_handlers.py","time":{"start":1780728101050,"end":1780728101058}},"metadata":{"openai":{"itemId":"fc_0ee41bda9f90bad4016a23c124eb288191a19d820e0b947b6a"}},"id":"prt_e9baa78b6001fPjMRAqKevMAGb","sessionID":"ses_164567595ffekYKAW3lqY5njlC","messageID":"msg_e9baa405b001y8u6gbQAgsZ4K6"}}
