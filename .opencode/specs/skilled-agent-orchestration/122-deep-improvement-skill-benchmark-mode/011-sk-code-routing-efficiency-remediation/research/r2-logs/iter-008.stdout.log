           \"glob\",\n264:           \"glob\",\n265:           \"read\",\n266:           \"read\"\n267:         ],\n268:         \"observedReads\": [\n269:           \"references/**/*.md\",\n270:           \"assets/**/*.md\",\n271:           \"references/smart_routing.md\"\n272:         ],\n273:         \"statedRoutingParsed\": true,\n274:         \"responseHead\": \"```json\\n{\\\"surface\\\":\\\"OPENCODE\\\",\\\"subLanguage\\\":\\\"none\\\",\\\"resources\\\":[\\\"references/stack_detection.md\\\",\\\"references/phase_detection.md\\\",\\\"references/smart_routing.md\\\",\\\"references/universal/code_quality_standards.md\\\",\\\"references/opencode/shared/universal_patterns.md\\\",\\\"references/opencode/shared/code_organizat\"\n275:       }\n276:     },\n277:     {\n278:       \"mode\": \"browser\",\n279:       \"classKind\": \"browser\",\n280:       \"scenarioId\": \"MR-001\",\n281:       \"tier\": \"browser-gated\",\n282:       \"modeAScore\": 100,\n283:       \"firstFailingStage\": null,\n284:       \"dims\": {\n285:         \"d1intra\": {\n286:           \"score\": 1\n287:         },\n288:         \"d2\": {\n289:           \"score\": 1\n290:         },\n291:         \"d3\": {\n292:           \"score\": 1\n293:         },\n294:         \"d1inter\": {\n295:           \"score\": null,\n296:           \"unscored\": \"browser scenario\"\n297:         },\n298:         \"d4\": {\n299:           \"score\": null,\n300:           \"unscored\": \"browser scenario\"\n301:         }\n302:       },\n303:       \"browser\": {\n304:         \"verdict\": \"PASS\",\n305:         \"signalsObserved\": {\n306:           \"exportsOk\": true,\n307:           \"animateDone\": true,\n308:           \"error\": null,\n309:           \"consoleErrors\": 0\n310:         },\n311:         \"evidence\": [\n312:           \"/tmp/claude-501/skc-browser-AB4XzI/skc-MR-001.html\"\n313:         ]\n314:       }\n315:     },\n316:     {\n317:       \"scenarioId\": \"CS-001\",\n318:       \"tier\": \"l