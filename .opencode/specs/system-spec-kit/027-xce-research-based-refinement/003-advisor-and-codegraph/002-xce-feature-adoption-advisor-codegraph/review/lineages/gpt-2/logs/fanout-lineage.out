pe<typeof buildReadinessBlock> },\n513:     structuralTrust,\n514:     { label },\n515:   );\n516: \n517:   return graphEdgeEnrichment\n518:     ? attachGraphEdgeEnrichment(withTrust, graphEdgeEnrichment, {\n519:       label: `${label} graph edge enrichment`,\n520:     })\n521:     : withTrust;\n522: }\n523: \n524: type OutboundEdgeEntry = ReturnType<typeof graphDb.queryEdgesFrom>[number];\n525: type InboundEdgeEntry = ReturnType<typeof graphDb.queryEdgesTo>[number];\n526: \n527: interface DanglingEdgeWarning {\n528:   code: 'dangling_edge';\n529:   operation: QueryArgs['operation'];\n530:   missingEndpoint: 'source' | 'target';\n531:   count: number;\n532:   danglingSymbolIds: string[];\n533:   message: string;\n534: }\n535: \n536: type QueryWarning = AmbiguousSubjectWarning | DanglingEdgeWarning;\n537: \n538: function mergeWarnings(...warningSets: Array<QueryWarning[] | undefined>): QueryWarning[] | undefined {\n539:   const warnings = warningSets.flatMap((warningSet) => warningSet ?? []);\n540:   return warnings.length > 0 ? warnings : undefined;\n541: }\n542: \n543: function excludeDanglingEdges<TEntry>(\n544:   entries: TEntry[],\n545:   limit: number,\n546:   operation: QueryArgs['operation'],\n547:   missingEndpoint: DanglingEdgeWarning['missingEndpoint'],\n548:   isResolved: (entry: TEntry) => boolean,\n549:   getDanglingId: (entry: TEntry) => string,\n550: ): { resolvedEntries: TEntry[]; warnings?: DanglingEdgeWarning[] } {\n551:   const resolvedEntries: TEntry[] = [];\n552:   const danglingSymbolIds: string[] = [];\n553: \n554:   for (const entry of entries) {\n555:     if (!isResolved(entry)) {\n556:       danglingSymbolIds.push(getDanglingId(entry));\n557:       continue;\n558:     }\n559:     if (resolvedEntries.length < limit) {\n560:       resolvedEntries.push(entry);\n561:     }\n562:   }\n563: \n564:   if (danglingSymbolIds.length === 0) {\n565:     return { resolvedEntries };\n566:   }\n567: \n568:   return {\n569:     resolvedEntries,\n570:     warnings: [{\n571:       code: 'dangling_edge',\n572:       operation,\n573:       missingEndpoint,\n574:       count: danglingSymbolIds.length,\n575:       danglingSymbolIds: [...new Set(danglingSymbolIds)],\n576:       message: `Excluded ${danglingSymbolIds.length} dangling ${operation} edge(s) because the ${missingEndpoint} node could not be resolved. Reindex the code graph to repair the missing node references.`,\n577:     }],\n578:   };\n579: }\n580: \n581: /**\n582:  * BFS transitive traversal from a symbolId via the given edge type.\n583:  *\n584:  * Dangling nodes (where queryEdgesFrom/To returns an edge whose endpoint has\n585:  * no node row) were previously surfaced as\n586:  * successful traversal results with null fqName/filePath. They are now\n587:  * flagged as corruption alongside the resolved results so callers can\n588:  * trust the absence of `warnings` as \"no dangling references\".\n589:  */\n590: interface TransitiveTraversalResult {\n591:   nodes: Array<{\n592:     symbolId: string;\n593:     fqName: string | null;\n594:     filePath: string | null;\n595:     line: number | null;\n596:     depth: number;\n597:   }>;\n598:   warnings?: DanglingEdgeWarning[];\n599: }\n600: \n601: interface TransitiveTraversalNeighbor {\n602:   readonly symbolId: string;\n603:   readonly node: CodeNode | null;\n604: }\n605: \n606: function transitiveTraversal(\n607:   startId: string,\n608:   edgeType: string,\n609:   direction: 'from' | 'to',\n\n(Showing lines 480-609 of 1766. Use offset=610 to continue.)\n</content>","metadata":{"preview":"        : {}),\n    };\n  }\n\n  return { symbolId: null, suggestions: querySymbolBm25Suggestions(subject) };\n}\n\n// Readiness helpers extracted to lib/code-graph/readiness-contract.ts so the\n// sibling code-graph handlers (scan, status, context) can share one\n// vocabulary. See that module for durable mapping notes.\n\nfunction buildGraphQueryPayload<T extends Record<string, unknown>>(\n  payload: T,\n  readiness: ReadyResult,\n  label: string,\n  graphEdgeEnrichment?: {\n    edgeEvidenceClass: EdgeEvidenceClass;\n    numericConfidence: number;\n  } | null,\n) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/handlers/query.ts","text":"        : {}),\n    };\n  }\n\n  return { symbolId: null, suggestions: querySymbolBm25Suggestions(subject) };\n}\n\n// Readiness helpers extracted to lib/code-graph/readiness-contract.ts so the\n// sibling code-graph handlers (scan, status, context) can share one\n// vocabulary. See that module for durable mapping notes.\n\nfunction buildGraphQueryPayload<T extends Record<string, unknown>>(\n  payload: T,\n  readiness: ReadyResult,\n  label: string,\n  graphEdgeEnrichment?: {\n    edgeEvidenceClass: EdgeEvidenceClass;\n    numericConfidence: number;\n  } | null,\n) {\n  const { readiness: _incomingReadiness, ...rest } = payload as Record<string, unknown>;\n  const { graphMetadata, structuralTrust } = buildQueryTrustMetadata(readiness);\n  const fallbackDecision = Object.prototype.hasOwnProperty.call(rest, 'fallbackDecision')\n    ? null\n    : buildFallbackDecision(readiness);\n  const payloadWithFallback = fallbackDecision\n    ? { ...rest, fallbackDecision }\n    : rest;\n  const base = graphMetadata\n    ? { ...payloadWithFallback, graphMetadata, readiness: buildReadinessBlock(readiness) }\n    : { ...payloadWithFallback, readiness: buildReadinessBlock(readiness) };\n  const withTrust = attachStructuralTrustFields(\n    base as T & { readiness: ReturnType<typeof buildReadinessBlock> },\n    structuralTrust,\n    { label },\n  );\n\n  return graphEdgeEnrichment\n    ? attachGraphEdgeEnrichment(withTrust, graphEdgeEnrichment, {\n      label: `${label} graph edge enrichment`,\n    })\n    : withTrust;\n}\n\ntype OutboundEdgeEntry = ReturnType<typeof graphDb.queryEdgesFrom>[number];\ntype InboundEdgeEntry = ReturnType<typeof graphDb.queryEdgesTo>[number];\n\ninterface DanglingEdgeWarning {\n  code: 'dangling_edge';\n  operation: QueryArgs['operation'];\n  missingEndpoint: 'source' | 'target';\n  count: number;\n  danglingSymbolIds: string[];\n  message: string;\n}\n\ntype QueryWarning = AmbiguousSubjectWarning | DanglingEdgeWarning;\n\nfunction mergeWarnings(...warningSets: Array<QueryWarning[] | undefined>): QueryWarning[] | undefined {\n  const warnings = warningSets.flatMap((warningSet) => warningSet ?? []);\n  return warnings.length > 0 ? warnings : undefined;\n}\n\nfunction excludeDanglingEdges<TEntry>(\n  entries: TEntry[],\n  limit: number,\n  operation: QueryArgs['operation'],\n  missingEndpoint: DanglingEdgeWarning['missingEndpoint'],\n  isResolved: (entry: TEntry) => boolean,\n  getDanglingId: (entry: TEntry) => string,\n): { resolvedEntries: TEntry[]; warnings?: DanglingEdgeWarning[] } {\n  const resolvedEntries: TEntry[] = [];\n  const danglingSymbolIds: string[] = [];\n\n  for (const entry of entries) {\n    if (!isResolved(entry)) {\n      danglingSymbolIds.push(getDanglingId(entry));\n      continue;\n    }\n    if (resolvedEntries.length < limit) {\n      resolvedEntries.push(entry);\n    }\n  }\n\n  if (danglingSymbolIds.length === 0) {\n    return { resolvedEntries };\n  }\n\n  return {\n    resolvedEntries,\n    warnings: [{\n      code: 'dangling_edge',\n      operation,\n      missingEndpoint,\n      count: danglingSymbolIds.length,\n      danglingSymbolIds: [...new Set(danglingSymbolIds)],\n      message: `Excluded ${danglingSymbolIds.length} dangling ${operation} edge(s) because the ${missingEndpoint} node could not be resolved. Reindex the code graph to repair the missing node references.`,\n    }],\n  };\n}\n\n/**\n * BFS transitive traversal from a symbolId via the given edge type.\n *\n * Dangling nodes (where queryEdgesFrom/To returns an edge whose endpoint has\n * no node row) were previously surfaced as\n * successful traversal results with null fqName/filePath. They are now\n * flagged as corruption alongside the resolved results so callers can\n * trust the absence of `warnings` as \"no dangling references\".\n */\ninterface TransitiveTraversalResult {\n  nodes: Array<{\n    symbolId: string;\n    fqName: string | null;\n    filePath: string | null;\n    line: number | null;\n    depth: number;\n  }>;\n  warnings?: DanglingEdgeWarning[];\n}\n\ninterface TransitiveTraversalNeighbor {\n  readonly symbolId: string;\n  readonly node: CodeNode | null;\n}\n\nfunction transitiveTraversal(\n  startId: string,\n  edgeType: string,\n  direction: 'from' | 'to',","lineStart":480,"lineEnd":609,"totalLines":1766,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781128801827,"end":1781128801830}},"metadata":{"openai":{"itemId":"fc_0de84d22e6b25ca4016a29de61d06081918766d12f6456a83a"}},"id":"prt_eb38cae1d001L4R0YLv56Ea4aj","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38c8794001TXsDqjeu810rkF"}}
