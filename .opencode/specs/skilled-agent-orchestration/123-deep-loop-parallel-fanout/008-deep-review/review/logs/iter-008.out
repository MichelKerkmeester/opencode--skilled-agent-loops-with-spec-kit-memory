   411	  ).get(node.specFolder, node.loopType, node.sessionId, node.id) as { id: string } | undefined;
   412	  if (existing) {
   413	    prepareStatement(`
   414	      UPDATE coverage_nodes SET
   415	        kind = ?, name = ?, content_hash = ?, iteration = ?,
   416	        metadata = ?, updated_at = ?
   417	      WHERE spec_folder = ? AND loop_type = ? AND session_id = ? AND id = ?
   418	    `).run(
   419	      node.kind, node.name, node.contentHash ?? null, node.iteration ?? null,
   420	      metadataStr, now,
   421	      node.specFolder, node.loopType, node.sessionId, node.id,
   422	    );
   423	    return node.id;
   424	  }
   425	
   426	  prepareStatement(`
   427	    INSERT INTO coverage_nodes (
   428	      spec_folder, loop_type, session_id, id, kind, name,
   429	      content_hash, iteration, metadata, created_at, updated_at
   430	    )
   431	    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
   432	  `).run(
