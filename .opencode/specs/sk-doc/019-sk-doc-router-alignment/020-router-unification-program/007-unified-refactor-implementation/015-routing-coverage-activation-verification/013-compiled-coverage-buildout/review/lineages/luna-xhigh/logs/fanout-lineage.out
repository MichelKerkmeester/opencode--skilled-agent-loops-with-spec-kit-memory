{"type":"text","timestamp":1784692724507,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"id":"prt_f87f9ad840015OckdoOp1Gxlxu","messageID":"msg_f87f99f08001AvBeT65Y6behcJ","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","type":"text","text":"Iteration 1 passed output validation and reducer synchronization. It recorded one adjudicated P1 correctness finding: refresh replacement is not serialized, unlike mint creation. Iteration 2 broadens correctness to per-hub policy selection and parity classification.","time":{"start":1784692714884,"end":1784692724504},"metadata":{"openai":{"itemId":"msg_0e768169a8311c2d016a603feaea288191963417acf2875094","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1784692724575,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_QBFvne2bzDyZDTuIC2w5zKRs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/001-sk-code/lib/registry-compiler.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/001-sk-code/lib/registry-compiler.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ LIBRARY: REGISTRY-DRIVEN PARENT-HUB COMPILER                            ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: 'use strict';\n5: \n6: // ─────────────────────────────────────────────────────────────────────────────\n7: // 1. IMPORTS\n8: // ─────────────────────────────────────────────────────────────────────────────\n9: \n10: const crypto = require('node:crypto');\n11: \n12: const {\n13:   canonicalize,\n14:   computeBasePolicyHash,\n15:   computeEffectivePolicyHash,\n16:   computeProjectionHash,\n17: } = require('../../../000-contract-schemas/lib/canonical.cjs');\n18: const {\n19:   destinationKey,\n20:   qualifiedDestinationId,\n21:   validateReferenceClosure,\n22: } = require('../../../001-compiler-n1-shadow/compiler/compiler.cjs');\n23: \n24: // ─────────────────────────────────────────────────────────────────────────────\n25: // 2. CONSTANTS\n26: // ─────────────────────────────────────────────────────────────────────────────\n27: \n28: const PACKET_AUTHORITY = Object.freeze({\n29:   workflow: Object.freeze({ role: 'actor', mutatesWorkspace: true }),\n30:   surface: Object.freeze({ role: 'evidence', mutatesWorkspace: false }),\n31: });\n32: \n33: // ─────────────────────────────────────────────────────────────────────────────\n34: // 3. HELPERS\n35: // ─────────────────────────────────────────────────────────────────────────────\n36: \n37: function fail(code, message) {\n38:   const error = new TypeError(message);\n39:   error.code = code;\n40:   throw error;\n41: }\n42: \n43: function assertObject(value, label) {\n44:   if (!value || typeof value !== 'object' || Array.isArray(value)) {\n45:     fail('AUTHORED_INPUT_INVALID', `${label} must be an object`);\n46:   }\n47: }\n48: \n49: function assertString(value, label) {\n50:   if (typeof value !== 'string' || !/\\S/.test(value)) {\n51:     fail('AUTHORED_INPUT_INVALID', `${label} must be a non-empty string`);\n52:   }\n53: }\n54: \n55: function sha256(bytes) {\n56:   return crypto.createHash('sha256').update(bytes).digest('hex');\n57: }\n58: \n59: function compareText(left, right) {\n60:   return left < right ? -1 : left > right ? 1 : 0;\n61: }\n62: \n63: function destinationId(skillId, mode) {\n64:   return {\n65:     backendKind: mode.backendKind,\n66:     packetId: mode.packet,\n67:     packetKind: mode.packetKind,\n68:     skillId,\n69:     workflowMode: mode.workflowMode,\n70:   };\n71: }\n72: \n73: function qualifiedAuthority(prefix, id) {\n74:   return `authority:${prefix}:${qualifiedDestinationId(id)}`;\n75: }\n76: \n77: function nonEmptySubsets(values) {\n78:   const subsets = [];\n79:   for (let mask = 1; mask < (1 << values.length); mask += 1) {\n80:     subsets.push(values.filter((_, index) => Boolean(mask & (1 << index))));\n81:   }\n82:   return subsets;\n83: }\n84: \n85: function extractFallbackChecklist(skillMarkdown) {\n86:   const match = /UNKNOWN_FALLBACK_CHECKLIST\\s*=\\s*\\[([\\s\\S]*?)\\]/m.exec(skillMarkdown);\n87:   if (!match) fail('FALLBACK_CHECKLIST_MISSING', 'fallback checklist is absent from authored skill');\n88:   const items = [...match[1].matchAll(/[\"']([^\"']+)[\"']/g)].map((entry) => entry[1]);\n89:   if (items.length < 3) {\n90:     fail('FALLBACK_CHECKLIST_INVALID', 'fallback checklist must contain at least three items');\n91:   }\n92:   return items;\n93: }\n94: \n95: function vocabularyByMode(registry, hubRouter) {\n96:   const classes = hubRouter.vocabularyClasses || {};\n97:   const signals = hubRouter.routerSignals || {};\n98:   const raw = new Map();\n99:   for (const mode of registry.modes) {\n100:     const values = new Set([mode.workflowMode, ...(mode.aliases || [])]);\n101:     for (const className of signals[mode.workflowMode]?.classes || []) {\n102:       for (const keyword of classes[className]?.keywords || []) values.add(keyword);\n103:     }\n104:     raw.set(mode.workflowMode, [...values].map((value) => value.toLowerCase()));\n105:   }\n106:   const owners = new Map();\n107:   for (const [mode, values] of raw) {\n108:     for (const value of values) {\n109:       if (!owners.has(value)) owners.set(value, new Set());\n110:       owners.get(value).add(mode);\n111:     }\n112:   }\n113:   return new Map([...raw].map(([mode, values]) => [\n114:     mode,\n115:     [...new Set(values.filter((value) => owners.get(value).size === 1))].sort(compareText),\n116:   ]));\n117: }\n118: \n119: function buildDestinationGraph(registry) {\n120:   const destinations = registry.modes.map((mode) => {\n121:     const authority = PACKET_AUTHORITY[mode.packetKind];\n122:     if (!authority) {\n123:       fail('PACKET_KIND_UNSUPPORTED', `unsupported packet kind: ${String(mode.packetKind)}`);\n124:     }\n125:     const id = destinationId(registry.skill, mode);\n126:     return {\n127:       authorityRef: qualifiedAuthority(\n128:         authority.role === 'actor' ? 'actor' : 'evidence-only',\n129:         id,\n130:       ),\n131:       id,\n132:       mutatesWorkspace: authority.mutatesWorkspace,\n133:       role: authority.role,\n134:     };\n135:   });\n136:   const keys = destinations.map((destination) => destinationKey(destination.id));\n137:   if (new Set(keys).size !== keys.length) {\n138:     fail('DESTINATION_DUPLICATE', 'destination compound identities must be unique');\n139:   }\n140:   return destinations;\n141: }\n142: \n143: function buildSelectors(registry, hubRouter, destinations) {\n144:   const vocabulary = vocabularyByMode(registry, hubRouter);\n145:   const byMode = new Map(destinations.map((destination) => [\n146:     destination.id.workflowMode,\n147:     destination,\n148:   ]));\n149:   const detectors = [];\n150:   const selectors = [];\n151:   for (const mode of registry.modes) {\n152:     const destination = byMode.get(mode.workflowMode);\n153:     const words = vocabulary.get(mode.workflowMode) || [];\n154:     words.forEach((word, index) => {\n155:       const detectorId = `detector:signal:${mode.workflowMode}:${index}`;\n156:       detectors.push({ id: detectorId, kind: 'alias', value: word });\n157:       selectors.push({\n158:         destinationId: destination.id,\n159:         detectorIds: [detectorId],\n160:         id: `selector:${mode.workflowMode}:${index}`,\n161:       });\n162:     });\n163:   }\n164:   detectors.push({ id: 'detector:negative:forbidden', kind: 'negative', value: 'forbidden' });\n165:   detectors.sort((left, right) => compareText(left.id, right.id));\n166:   selectors.sort((left, right) => compareText(left.id, right.id));\n167:   return { detectors, selectors, vocabulary };\n168: }\n169: \n170: // A bundle is `surfaceBundle` only when it carries exactly one actor alongside\n171: // one or more evidence destinations (the decision-contract's own definition\n172: // in 002-decision-evaluator/lib/evaluator.cjs's isValidPolicy). Every other\n173: // multi-target tie (two-or-more actors, or evidence with no actor at all) is\n174: // `orderedBundle`, which carries no role restriction.\n175: function bundleKindForModes(modeWorkflowModes, byMode) {\n176:   const roles = modeWorkflowModes.map((mode) => byMode.get(mode).role);\n177:   const actors = roles.filter((role) => role === 'actor').length;\n178:   const evidence = roles.filter((role) => role === 'evidence').length;\n179:   return (actors === 1 && evidence === roles.length - 1) ? 'surfaceBundle' : 'orderedBundle';\n180: }\n181: \n182: // Every non-empty two-or-more subset of the tie-break order (not just the\n183: // authored actor-plus-evidence-subset shapes): a near-tied keyword score can\n184: // legally land on any subset — two actors, evidence alone, or a mixed set —\n185: // so the router needs a valid, order-matching composition rule for each one,\n186: // or parseRouteDecision's BUNDLE_NOT_IN_POLICY check rejects a real tie.\n187: function buildCompositionRules(destinations, tieBreak) {\n188:   const byMode = new Map(destinations.map((destination) => [destination.id.workflowMode, destination]));\n189:   const modes = [...tieBreak];\n190:   const rules = [];\n191:   for (let mask = 1; mask < (1 << modes.length); mask += 1) {\n192:     const bits = [];\n193:     for (let index = 0; index < modes.length; index += 1) {\n194:       if (mask & (1 << index)) bits.push(modes[index]);\n195:     }\n196:     if (bits.length < 2) continue;\n197:     rules.push({\n198:       kind: bundleKindForModes(bits, byMode),\n199:       targetIds: bits.map((mode) => byMode.get(mode).id),\n200:     });\n201:   }\n202:   return rules;\n203: }\n204: \n205: // Union every keyword the hub-router assigns to a mode's classes, unfiltered\n206: // by any cross-mode overlap. This mirrors the frozen legacy replay's own\n207: // hub-router projection exactly (router-replay.cjs's projectHubRouter): each\n208: // mode scores independently off its own keyword set, so a keyword shared by\n209: // two modes (e.g. a hub-identity term) still counts as a positive signal for\n210: // both, never dropped the way the detector-vocabulary ownership filter below\n211: // drops it.\n212: function modeVocabulary(hubRouter, workflowMode) {\n213:   const signal = hubRouter.routerSignals[workflowMode];\n214:   const words = new Set();\n215:   for (const className of signal.classes || []) {\n216:     const vocabulary = hubRouter.vocabularyClasses[className];\n217:     for (const keyword of (vocabulary && vocabulary.keywords) || []) {\n218:       words.add(String(keyword).toLowerCase());\n219:     }\n220:   }\n221:   return [...words].sort(compareText);\n222: }\n223: \n224: // Bundle targets for the bespoke routing model below, expressed as\n225: // workflowMode strings (not destinationId objects) so the router can look one\n226: // up directly off a scored, ordered mode list without a destination round-trip.\n227: function buildBundleRules(tieBreak, destinations) {\n228:   const byMode = new Map(destinations.map((destination) => [destination.id.workflowMode, destination]));\n229:   const modes = [...tieBreak];\n230:   const rules = [];\n231:   for (let mask = 1; mask < (1 << modes.length); mask += 1) {\n232:     const bits = [];\n233:     for (let index = 0; index < modes.length; index += 1) {\n234:       if (mask & (1 << index)) bits.push(modes[index]);\n235:     }\n236:     if (bits.length < 2) continue;\n237:     rules.push({ kind: bundleKindForModes(bits, byMode), targetWorkflowModes: bits });\n238:   }\n239:   return rules;\n240: }\n241: \n242: // The bespoke, hub-specific routing model the compiled router scores against\n243: // directly (mirrors sk-design's registry-compiler.cjs routingModel). This\n244: // sits alongside the generic detector/selector policy above rather than\n245: // replacing it: the policy still carries the authority graph, composition\n246: // rules, and hashing that policy-card.cjs and the projector read.\n247: function buildRoutingModel(registry, hubRouter, destinations) {\n248:   const byMode = new Map(destinations.map((destination) => [destination.id.workflowMode, destination]));\n249:   const modes = registry.modes.map((mode) => {\n250:     const signal = hubRouter.routerSignals[mode.workflowMode];\n251:     return {\n252:       command: mode.command,\n253:       destinationId: byMode.get(mode.workflowMode).id,\n254:       keywords: modeVocabulary(hubRouter, mode.workflowMode),\n255:       weight: signal.weight,\n256:       workflowMode: mode.workflowMode,\n257:     };\n258:   });\n259:   return {\n260:     ambiguityDelta: hubRouter.routerPolicy.ambiguityDelta,\n\n(Showing lines 1-260 of 409. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ LIBRARY: REGISTRY-DRIVEN PARENT-HUB COMPILER                            ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst crypto = require('node:crypto');\n\nconst {\n  canonicalize,\n  computeBasePolicyHash,\n  computeEffectivePolicyHash,\n  computeProjectionHash,\n} = require('../../../000-contract-schemas/lib/canonical.cjs');\nconst {\n  destinationKey,\n  qualifiedDestinationId,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/001-sk-code/lib/registry-compiler.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ LIBRARY: REGISTRY-DRIVEN PARENT-HUB COMPILER                            ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst crypto = require('node:crypto');\n\nconst {\n  canonicalize,\n  computeBasePolicyHash,\n  computeEffectivePolicyHash,\n  computeProjectionHash,\n} = require('../../../000-contract-schemas/lib/canonical.cjs');\nconst {\n  destinationKey,\n  qualifiedDestinationId,\n  validateReferenceClosure,\n} = require('../../../001-compiler-n1-shadow/compiler/compiler.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst PACKET_AUTHORITY = Object.freeze({\n  workflow: Object.freeze({ role: 'actor', mutatesWorkspace: true }),\n  surface: Object.freeze({ role: 'evidence', mutatesWorkspace: false }),\n});\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction fail(code, message) {\n  const error = new TypeError(message);\n  error.code = code;\n  throw error;\n}\n\nfunction assertObject(value, label) {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) {\n    fail('AUTHORED_INPUT_INVALID', `${label} must be an object`);\n  }\n}\n\nfunction assertString(value, label) {\n  if (typeof value !== 'string' || !/\\S/.test(value)) {\n    fail('AUTHORED_INPUT_INVALID', `${label} must be a non-empty string`);\n  }\n}\n\nfunction sha256(bytes) {\n  return crypto.createHash('sha256').update(bytes).digest('hex');\n}\n\nfunction compareText(left, right) {\n  return left < right ? -1 : left > right ? 1 : 0;\n}\n\nfunction destinationId(skillId, mode) {\n  return {\n    backendKind: mode.backendKind,\n    packetId: mode.packet,\n    packetKind: mode.packetKind,\n    skillId,\n    workflowMode: mode.workflowMode,\n  };\n}\n\nfunction qualifiedAuthority(prefix, id) {\n  return `authority:${prefix}:${qualifiedDestinationId(id)}`;\n}\n\nfunction nonEmptySubsets(values) {\n  const subsets = [];\n  for (let mask = 1; mask < (1 << values.length); mask += 1) {\n    subsets.push(values.filter((_, index) => Boolean(mask & (1 << index))));\n  }\n  return subsets;\n}\n\nfunction extractFallbackChecklist(skillMarkdown) {\n  const match = /UNKNOWN_FALLBACK_CHECKLIST\\s*=\\s*\\[([\\s\\S]*?)\\]/m.exec(skillMarkdown);\n  if (!match) fail('FALLBACK_CHECKLIST_MISSING', 'fallback checklist is absent from authored skill');\n  const items = [...match[1].matchAll(/[\"']([^\"']+)[\"']/g)].map((entry) => entry[1]);\n  if (items.length < 3) {\n    fail('FALLBACK_CHECKLIST_INVALID', 'fallback checklist must contain at least three items');\n  }\n  return items;\n}\n\nfunction vocabularyByMode(registry, hubRouter) {\n  const classes = hubRouter.vocabularyClasses || {};\n  const signals = hubRouter.routerSignals || {};\n  const raw = new Map();\n  for (const mode of registry.modes) {\n    const values = new Set([mode.workflowMode, ...(mode.aliases || [])]);\n    for (const className of signals[mode.workflowMode]?.classes || []) {\n      for (const keyword of classes[className]?.keywords || []) values.add(keyword);\n    }\n    raw.set(mode.workflowMode, [...values].map((value) => value.toLowerCase()));\n  }\n  const owners = new Map();\n  for (const [mode, values] of raw) {\n    for (const value of values) {\n      if (!owners.has(value)) owners.set(value, new Set());\n      owners.get(value).add(mode);\n    }\n  }\n  return new Map([...raw].map(([mode, values]) => [\n    mode,\n    [...new Set(values.filter((value) => owners.get(value).size === 1))].sort(compareText),\n  ]));\n}\n\nfunction buildDestinationGraph(registry) {\n  const destinations = registry.modes.map((mode) => {\n    const authority = PACKET_AUTHORITY[mode.packetKind];\n    if (!authority) {\n      fail('PACKET_KIND_UNSUPPORTED', `unsupported packet kind: ${String(mode.packetKind)}`);\n    }\n    const id = destinationId(registry.skill, mode);\n    return {\n      authorityRef: qualifiedAuthority(\n        authority.role === 'actor' ? 'actor' : 'evidence-only',\n        id,\n      ),\n      id,\n      mutatesWorkspace: authority.mutatesWorkspace,\n      role: authority.role,\n    };\n  });\n  const keys = destinations.map((destination) => destinationKey(destination.id));\n  if (new Set(keys).size !== keys.length) {\n    fail('DESTINATION_DUPLICATE', 'destination compound identities must be unique');\n  }\n  return destinations;\n}\n\nfunction buildSelectors(registry, hubRouter, destinations) {\n  const vocabulary = vocabularyByMode(registry, hubRouter);\n  const byMode = new Map(destinations.map((destination) => [\n    destination.id.workflowMode,\n    destination,\n  ]));\n  const detectors = [];\n  const selectors = [];\n  for (const mode of registry.modes) {\n    const destination = byMode.get(mode.workflowMode);\n    const words = vocabulary.get(mode.workflowMode) || [];\n    words.forEach((word, index) => {\n      const detectorId = `detector:signal:${mode.workflowMode}:${index}`;\n      detectors.push({ id: detectorId, kind: 'alias', value: word });\n      selectors.push({\n        destinationId: destination.id,\n        detectorIds: [detectorId],\n        id: `selector:${mode.workflowMode}:${index}`,\n      });\n    });\n  }\n  detectors.push({ id: 'detector:negative:forbidden', kind: 'negative', value: 'forbidden' });\n  detectors.sort((left, right) => compareText(left.id, right.id));\n  selectors.sort((left, right) => compareText(left.id, right.id));\n  return { detectors, selectors, vocabulary };\n}\n\n// A bundle is `surfaceBundle` only when it carries exactly one actor alongside\n// one or more evidence destinations (the decision-contract's own definition\n// in 002-decision-evaluator/lib/evaluator.cjs's isValidPolicy). Every other\n// multi-target tie (two-or-more actors, or evidence with no actor at all) is\n// `orderedBundle`, which carries no role restriction.\nfunction bundleKindForModes(modeWorkflowModes, byMode) {\n  const roles = modeWorkflowModes.map((mode) => byMode.get(mode).role);\n  const actors = roles.filter((role) => role === 'actor').length;\n  const evidence = roles.filter((role) => role === 'evidence').length;\n  return (actors === 1 && evidence === roles.length - 1) ? 'surfaceBundle' : 'orderedBundle';\n}\n\n// Every non-empty two-or-more subset of the tie-break order (not just the\n// authored actor-plus-evidence-subset shapes): a near-tied keyword score can\n// legally land on any subset — two actors, evidence alone, or a mixed set —\n// so the router needs a valid, order-matching composition rule for each one,\n// or parseRouteDecision's BUNDLE_NOT_IN_POLICY check rejects a real tie.\nfunction buildCompositionRules(destinations, tieBreak) {\n  const byMode = new Map(destinations.map((destination) => [destination.id.workflowMode, destination]));\n  const modes = [...tieBreak];\n  const rules = [];\n  for (let mask = 1; mask < (1 << modes.length); mask += 1) {\n    const bits = [];\n    for (let index = 0; index < modes.length; index += 1) {\n      if (mask & (1 << index)) bits.push(modes[index]);\n    }\n    if (bits.length < 2) continue;\n    rules.push({\n      kind: bundleKindForModes(bits, byMode),\n      targetIds: bits.map((mode) => byMode.get(mode).id),\n    });\n  }\n  return rules;\n}\n\n// Union every keyword the hub-router assigns to a mode's classes, unfiltered\n// by any cross-mode overlap. This mirrors the frozen legacy replay's own\n// hub-router projection exactly (router-replay.cjs's projectHubRouter): each\n// mode scores independently off its own keyword set, so a keyword shared by\n// two modes (e.g. a hub-identity term) still counts as a positive signal for\n// both, never dropped the way the detector-vocabulary ownership filter below\n// drops it.\nfunction modeVocabulary(hubRouter, workflowMode) {\n  const signal = hubRouter.routerSignals[workflowMode];\n  const words = new Set();\n  for (const className of signal.classes || []) {\n    const vocabulary = hubRouter.vocabularyClasses[className];\n    for (const keyword of (vocabulary && vocabulary.keywords) || []) {\n      words.add(String(keyword).toLowerCase());\n    }\n  }\n  return [...words].sort(compareText);\n}\n\n// Bundle targets for the bespoke routing model below, expressed as\n// workflowMode strings (not destinationId objects) so the router can look one\n// up directly off a scored, ordered mode list without a destination round-trip.\nfunction buildBundleRules(tieBreak, destinations) {\n  const byMode = new Map(destinations.map((destination) => [destination.id.workflowMode, destination]));\n  const modes = [...tieBreak];\n  const rules = [];\n  for (let mask = 1; mask < (1 << modes.length); mask += 1) {\n    const bits = [];\n    for (let index = 0; index < modes.length; index += 1) {\n      if (mask & (1 << index)) bits.push(modes[index]);\n    }\n    if (bits.length < 2) continue;\n    rules.push({ kind: bundleKindForModes(bits, byMode), targetWorkflowModes: bits });\n  }\n  return rules;\n}\n\n// The bespoke, hub-specific routing model the compiled router scores against\n// directly (mirrors sk-design's registry-compiler.cjs routingModel). This\n// sits alongside the generic detector/selector policy above rather than\n// replacing it: the policy still carries the authority graph, composition\n// rules, and hashing that policy-card.cjs and the projector read.\nfunction buildRoutingModel(registry, hubRouter, destinations) {\n  const byMode = new Map(destinations.map((destination) => [destination.id.workflowMode, destination]));\n  const modes = registry.modes.map((mode) => {\n    const signal = hubRouter.routerSignals[mode.workflowMode];\n    return {\n      command: mode.command,\n      destinationId: byMode.get(mode.workflowMode).id,\n      keywords: modeVocabulary(hubRouter, mode.workflowMode),\n      weight: signal.weight,\n      workflowMode: mode.workflowMode,\n    };\n  });\n  return {\n    ambiguityDelta: hubRouter.routerPolicy.ambiguityDelta,","lineStart":1,"lineEnd":260,"totalLines":409,"truncated":true}},"title":".opencode/bin/lib/compiled-routing/006-parent-hub-rollout/001-sk-code/lib/registry-compiler.cjs","time":{"start":1784692724563,"end":1784692724573}},"metadata":{"openai":{"itemId":"fc_0e768169a8311c2d016a603ff4830081919394c4241ff95a88"}},"id":"prt_f87f9d34f001oLvKcbO4j4KatC","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f99f08001AvBeT65Y6behcJ"}}
