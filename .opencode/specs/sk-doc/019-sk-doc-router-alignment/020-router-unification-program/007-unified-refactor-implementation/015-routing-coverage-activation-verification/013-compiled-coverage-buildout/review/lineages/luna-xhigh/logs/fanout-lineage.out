{"type":"tool_use","timestamp":1784692724603,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_N8eqitTxoj89RYdRnAA8MmU4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/006-sk-design/lib/router.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/006-sk-design/lib/router.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const {\n4:   canonicalize,\n5:   computeRequestFactsHash,\n6: } = require('../../../000-contract-schemas/lib/canonical.cjs');\n7: const {\n8:   parseRouteDecision,\n9: } = require('../../../002-decision-evaluator/lib/decision-contract.cjs');\n10: \n11: function clone(value) {\n12:   return JSON.parse(canonicalize(value));\n13: }\n14: \n15: function normalize(value) {\n16:   return String(value).trim().toLowerCase();\n17: }\n18: \n19: function escapePattern(value) {\n20:   return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n21: }\n22: \n23: function containsSignal(text, value) {\n24:   const signal = normalize(value);\n25:   if (signal.startsWith('/')) {\n26:     return new RegExp(`${escapePattern(signal)}(?![a-z0-9-])`, 'i').test(text);\n27:   }\n28:   return text.includes(signal);\n29: }\n30: \n31: function advisorDisposition(advisor, projection, policy) {\n32:   if (!advisor || ['absent', 'unavailable'].includes(advisor.trust)) {\n33:     return { contributes: false, evidence: null, reason: 'advisor-zero-evidence' };\n34:   }\n35:   const matches = advisor.trust === 'live'\n36:     && advisor.hubId === projection.hubId\n37:     && advisor.effectivePolicyHash === policy.effectivePolicyHash\n38:     && advisor.projectionHash === projection.projectionHash;\n39:   if (!matches) {\n40:     return {\n41:       contributes: false,\n42:       evidence: {\n43:         id: 'advisor:annotation',\n44:         kind: 'advisor',\n45:         provenance: { capturedAtEpoch: policy.activationGeneration, source: 'advisor-projection' },\n46:         trust: 'stale',\n47:         value: canonicalize({ annotationOnly: true }),\n48:       },\n49:       reason: advisor.trust === 'stale'\n50:         ? 'advisor-stale-annotation-only'\n51:         : 'advisor-projection-drift-annotation-only',\n52:     };\n53:   }\n54:   return {\n55:     contributes: true,\n56:     evidence: {\n57:       id: 'advisor:rank',\n58:       kind: 'advisor',\n59:       provenance: { capturedAtEpoch: policy.activationGeneration, source: 'advisor-projection' },\n60:       trust: 'live',\n61:       value: canonicalize({\n62:         activationGeneration: policy.activationGeneration,\n63:         effectivePolicyHash: policy.effectivePolicyHash,\n64:         rankScore: advisor.rankScore || '0',\n65:         scoreMargin: advisor.scoreMargin || '0',\n66:       }),\n67:     },\n68:     reason: 'advisor-live-identity-match',\n69:   };\n70: }\n71: \n72: function buildRequest(snapshot, input) {\n73:   const disposition = advisorDisposition(input.advisor, snapshot.advisorProjection, snapshot.policy);\n74:   const observations = [];\n75:   if (typeof input.prompt === 'string' && /\\S/.test(input.prompt)) {\n76:     observations.push({ kind: 'intent', value: input.prompt });\n77:   }\n78:   for (const constraint of input.constraints || []) {\n79:     observations.push({ kind: 'constraint', value: constraint });\n80:   }\n81:   const evidence = [{\n82:     id: 'runtime:activation',\n83:     kind: 'runtime',\n84:     provenance: {\n85:       capturedAtEpoch: snapshot.policy.activationGeneration,\n86:       source: 'fenced-selector',\n87:     },\n88:     trust: 'live',\n89:     value: canonicalize({\n90:       activationGeneration: snapshot.policy.activationGeneration,\n91:       effectivePolicyHash: snapshot.policy.effectivePolicyHash,\n92:     }),\n93:   }];\n94:   if (disposition.evidence) evidence.push(disposition.evidence);\n95:   const request = {\n96:     evidence,\n97:     ...(input.explicitMode ? { explicitMode: input.explicitMode } : {}),\n98:     observations,\n99:     pinnedActivationGeneration: snapshot.policy.activationGeneration,\n100:     schemaVersion: 'V1',\n101:   };\n102:   request.requestFactsHash = computeRequestFactsHash(request);\n103:   return { disposition, request };\n104: }\n105: \n106: function target(destination) {\n107:   return {\n108:     authorityRef: destination.authorityRef,\n109:     destinationId: clone(destination.id),\n110:     mutatesWorkspace: destination.mutatesWorkspace,\n111:     role: destination.role,\n112:   };\n113: }\n114: \n115: function route(snapshot, selectionKind, modes) {\n116:   const byMode = new Map(snapshot.policy.destinations.map((destination) => (\n117:     [destination.id.workflowMode, destination]\n118:   )));\n119:   return parseRouteDecision({\n120:     action: 'route',\n121:     route: {\n122:       authority: 'WithheldUntilVerify',\n123:       basis: { kind: 'signal' },\n124:       evidence: [],\n125:       selectionKind,\n126:       targets: modes.map((mode) => target(byMode.get(mode))),\n127:     },\n128:     schemaVersion: 'V1',\n129:   }, snapshot.policy);\n130: }\n131: \n132: function negative(action, payload) {\n133:   return parseRouteDecision({\n134:     action,\n135:     [action]: { ...payload, authority: 'Withheld' },\n136:     schemaVersion: 'V1',\n137:   });\n138: }\n139: \n140: function clarify(snapshot, request, modes) {\n141:   const order = new Map(snapshot.routingModel.tieBreak.map((mode, index) => [mode, index]));\n142:   const alternatives = [...modes]\n143:     .sort((left, right) => order.get(left) - order.get(right))\n144:     .slice(0, 3);\n145:   alternatives.push('none_of_these');\n146:   return parseRouteDecision({\n147:     action: 'clarify',\n148:     clarify: {\n149:       alternatives,\n150:       authority: 'Withheld',\n151:       budgetRef: `budget:${request.requestFactsHash.slice(0, 16)}`,\n152:       question: snapshot.fallbackChecklist[0],\n153:     },\n154:     schemaVersion: 'V1',\n155:   });\n156: }\n157: \n158: function exactBundle(routingModel, modes) {\n159:   const candidate = new Set(modes);\n160:   return routingModel.bundleRules.find((rule) => (\n161:     rule.whenAll.length === candidate.size\n162:     && rule.whenAll.every((mode) => candidate.has(mode))\n163:   )) || null;\n164: }\n165: \n166: function explicitMode(routingModel, value) {\n167:   const normalized = normalize(value);\n168:   return routingModel.modes.filter((mode) => (\n169:     normalize(mode.workflowMode) === normalized\n170:     || normalize(`sk-design/${mode.workflowMode}`) === normalized\n171:   ));\n172: }\n173: \n174: function scoreModes(routingModel, text) {\n175:   const direct = routingModel.modes.filter((mode) => (\n176:     typeof mode.command === 'string' && containsSignal(text, mode.command)\n177:   ));\n178:   if (direct.length > 0) {\n179:     return direct.map((mode) => ({ mode: mode.workflowMode, score: Number.MAX_SAFE_INTEGER }));\n180:   }\n181:   return routingModel.modes.map((mode) => ({\n182:     mode: mode.workflowMode,\n183:     score: mode.keywords.filter((keyword) => containsSignal(text, keyword)).length * mode.weight,\n184:   })).filter((entry) => entry.score > 0);\n185: }\n186: \n187: // Caller contract: `modes` must already be the ambiguityDelta-filtered\n188: // contending set (see contendingModes), never the raw positive-score list.\n189: // An and/plus/then conjunction names two AXES the prompt asked for -- it is\n190: // not itself evidence that a below-delta co-hit deserves promotion, so this\n191: // heuristic has to sit on the same co-dominance bar exactBundle uses instead\n192: // of bypassing it. Given the wrong (unfiltered) list it would force-bundle a\n193: // mode legacy would have dropped, exactly the compiled-over-legacy drift this\n194: // contract exists to prevent.\n195: function clearlySeparateAxes(text, modes) {\n196:   return modes.length === 2 && /\\b(?:and|plus|then)\\b/.test(text);\n197: }\n198: \n199: // Mirrors router-replay.cjs's selectIntents (the legacy replay's own ambiguity\n200: // gate): keep only the modes within ambiguityDelta of the top score. Both an\n201: // authored bundle rule (see exactBundle) and the and/plus/then conjunction\n202: // heuristic (see clearlySeparateAxes) read this same contending set, never\n203: // the raw score list -- neither has a textual signal strong enough to justify\n204: // overriding a clear score winner, so both must only fire when their modes\n205: // are genuinely co-dominant, the same bar legacy applies before it ever\n206: // selects more than one intent.\n207: function contendingModes(scores, ambiguityDelta) {\n208:   if (scores.length === 0) return [];\n209:   const top = scores[0].score;\n210:   return scores.filter((entry) => top - entry.score <= ambiguityDelta).map((entry) => entry.mode);\n211: }\n212: \n213: function evaluateCanary(snapshot, input) {\n214:   const built = buildRequest(snapshot, input);\n215:   const text = normalize(input.prompt || '');\n216:   const constraints = new Set((input.constraints || []).map(normalize));\n217:   let decision;\n218:   let scores = [];\n219:   if (constraints.has('forbidden') || text.includes('forbidden')) {\n220:     decision = negative('reject', { reason: 'forbidden' });\n221:   } else if (constraints.has('dependency-failure')) {\n222:     decision = negative('defer', { reason: 'dependency-failure', recovery: ['defer'] });\n223:   } else if (input.explicitMode) {\n224:     const matches = explicitMode(snapshot.routingModel, input.explicitMode);\n225:     if (matches.length === 1) decision = route(snapshot, 'single', [matches[0].workflowMode]);\n226:     else if (constraints.has('clarify') || matches.length > 1) {\n227:       decision = clarify(snapshot, built.request, matches.map((mode) => mode.workflowMode));\n228:     } else decision = negative('defer', { reason: 'no-match', recovery: [] });\n229:   } else {\n230:     scores = scoreModes(snapshot.routingModel, text);\n231:     const order = new Map(snapshot.routingModel.tieBreak.map((mode, index) => [mode, index]));\n232:     scores.sort((left, right) => (\n233:       right.score - left.score || order.get(left.mode) - order.get(right.mode)\n234:     ));\n235:     const modes = scores.map((entry) => entry.mode);\n236:     if (constraints.has('clarify')) {\n237:       decision = clarify(snapshot, built.request, modes);\n238:     } else if (modes.length === 0) {\n239:       decision = snapshot.routingModel.defaultMode === null\n240:         ? negative('defer', { reason: 'no-match', recovery: [] })\n241:         : route(snapshot, 'single', [snapshot.routingModel.defaultMode]);\n242:     } else {\n243:       const contending = contendingModes(scores, snapshot.routingModel.ambiguityDelta);\n244:       const bundle = exactBundle(snapshot.routingModel, contending);\n245:       if (bundle) {\n246:         decision = route(snapshot, 'orderedBundle', bundle.targetWorkflowModes);\n247:       } else if (clearlySeparateAxes(text, contending)) {\n248:         decision = route(snapshot, 'orderedBundle', contending.sort((left, right) => (\n249:           order.get(left) - order.get(right)\n250:         )));\n251:       } else if (scores.length === 1\n252:         || scores[0].score - scores[1].score > snapshot.routingModel.ambiguityDelta) {\n253:         decision = route(snapshot, 'single', [scores[0].mode]);\n254:       } else {\n255:         decision = clarify(snapshot, built.request, modes);\n256:       }\n257:     }\n258:   }\n259:   return {\n260:     advisorDisposition: built.disposition,\n\n(Showing lines 1-260 of 307. Use offset=261 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst {\n  canonicalize,\n  computeRequestFactsHash,\n} = require('../../../000-contract-schemas/lib/canonical.cjs');\nconst {\n  parseRouteDecision,\n} = require('../../../002-decision-evaluator/lib/decision-contract.cjs');\n\nfunction clone(value) {\n  return JSON.parse(canonicalize(value));\n}\n\nfunction normalize(value) {\n  return String(value).trim().toLowerCase();\n}\n\nfunction escapePattern(value) {\n  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/006-parent-hub-rollout/006-sk-design/lib/router.cjs","text":"'use strict';\n\nconst {\n  canonicalize,\n  computeRequestFactsHash,\n} = require('../../../000-contract-schemas/lib/canonical.cjs');\nconst {\n  parseRouteDecision,\n} = require('../../../002-decision-evaluator/lib/decision-contract.cjs');\n\nfunction clone(value) {\n  return JSON.parse(canonicalize(value));\n}\n\nfunction normalize(value) {\n  return String(value).trim().toLowerCase();\n}\n\nfunction escapePattern(value) {\n  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\nfunction containsSignal(text, value) {\n  const signal = normalize(value);\n  if (signal.startsWith('/')) {\n    return new RegExp(`${escapePattern(signal)}(?![a-z0-9-])`, 'i').test(text);\n  }\n  return text.includes(signal);\n}\n\nfunction advisorDisposition(advisor, projection, policy) {\n  if (!advisor || ['absent', 'unavailable'].includes(advisor.trust)) {\n    return { contributes: false, evidence: null, reason: 'advisor-zero-evidence' };\n  }\n  const matches = advisor.trust === 'live'\n    && advisor.hubId === projection.hubId\n    && advisor.effectivePolicyHash === policy.effectivePolicyHash\n    && advisor.projectionHash === projection.projectionHash;\n  if (!matches) {\n    return {\n      contributes: false,\n      evidence: {\n        id: 'advisor:annotation',\n        kind: 'advisor',\n        provenance: { capturedAtEpoch: policy.activationGeneration, source: 'advisor-projection' },\n        trust: 'stale',\n        value: canonicalize({ annotationOnly: true }),\n      },\n      reason: advisor.trust === 'stale'\n        ? 'advisor-stale-annotation-only'\n        : 'advisor-projection-drift-annotation-only',\n    };\n  }\n  return {\n    contributes: true,\n    evidence: {\n      id: 'advisor:rank',\n      kind: 'advisor',\n      provenance: { capturedAtEpoch: policy.activationGeneration, source: 'advisor-projection' },\n      trust: 'live',\n      value: canonicalize({\n        activationGeneration: policy.activationGeneration,\n        effectivePolicyHash: policy.effectivePolicyHash,\n        rankScore: advisor.rankScore || '0',\n        scoreMargin: advisor.scoreMargin || '0',\n      }),\n    },\n    reason: 'advisor-live-identity-match',\n  };\n}\n\nfunction buildRequest(snapshot, input) {\n  const disposition = advisorDisposition(input.advisor, snapshot.advisorProjection, snapshot.policy);\n  const observations = [];\n  if (typeof input.prompt === 'string' && /\\S/.test(input.prompt)) {\n    observations.push({ kind: 'intent', value: input.prompt });\n  }\n  for (const constraint of input.constraints || []) {\n    observations.push({ kind: 'constraint', value: constraint });\n  }\n  const evidence = [{\n    id: 'runtime:activation',\n    kind: 'runtime',\n    provenance: {\n      capturedAtEpoch: snapshot.policy.activationGeneration,\n      source: 'fenced-selector',\n    },\n    trust: 'live',\n    value: canonicalize({\n      activationGeneration: snapshot.policy.activationGeneration,\n      effectivePolicyHash: snapshot.policy.effectivePolicyHash,\n    }),\n  }];\n  if (disposition.evidence) evidence.push(disposition.evidence);\n  const request = {\n    evidence,\n    ...(input.explicitMode ? { explicitMode: input.explicitMode } : {}),\n    observations,\n    pinnedActivationGeneration: snapshot.policy.activationGeneration,\n    schemaVersion: 'V1',\n  };\n  request.requestFactsHash = computeRequestFactsHash(request);\n  return { disposition, request };\n}\n\nfunction target(destination) {\n  return {\n    authorityRef: destination.authorityRef,\n    destinationId: clone(destination.id),\n    mutatesWorkspace: destination.mutatesWorkspace,\n    role: destination.role,\n  };\n}\n\nfunction route(snapshot, selectionKind, modes) {\n  const byMode = new Map(snapshot.policy.destinations.map((destination) => (\n    [destination.id.workflowMode, destination]\n  )));\n  return parseRouteDecision({\n    action: 'route',\n    route: {\n      authority: 'WithheldUntilVerify',\n      basis: { kind: 'signal' },\n      evidence: [],\n      selectionKind,\n      targets: modes.map((mode) => target(byMode.get(mode))),\n    },\n    schemaVersion: 'V1',\n  }, snapshot.policy);\n}\n\nfunction negative(action, payload) {\n  return parseRouteDecision({\n    action,\n    [action]: { ...payload, authority: 'Withheld' },\n    schemaVersion: 'V1',\n  });\n}\n\nfunction clarify(snapshot, request, modes) {\n  const order = new Map(snapshot.routingModel.tieBreak.map((mode, index) => [mode, index]));\n  const alternatives = [...modes]\n    .sort((left, right) => order.get(left) - order.get(right))\n    .slice(0, 3);\n  alternatives.push('none_of_these');\n  return parseRouteDecision({\n    action: 'clarify',\n    clarify: {\n      alternatives,\n      authority: 'Withheld',\n      budgetRef: `budget:${request.requestFactsHash.slice(0, 16)}`,\n      question: snapshot.fallbackChecklist[0],\n    },\n    schemaVersion: 'V1',\n  });\n}\n\nfunction exactBundle(routingModel, modes) {\n  const candidate = new Set(modes);\n  return routingModel.bundleRules.find((rule) => (\n    rule.whenAll.length === candidate.size\n    && rule.whenAll.every((mode) => candidate.has(mode))\n  )) || null;\n}\n\nfunction explicitMode(routingModel, value) {\n  const normalized = normalize(value);\n  return routingModel.modes.filter((mode) => (\n    normalize(mode.workflowMode) === normalized\n    || normalize(`sk-design/${mode.workflowMode}`) === normalized\n  ));\n}\n\nfunction scoreModes(routingModel, text) {\n  const direct = routingModel.modes.filter((mode) => (\n    typeof mode.command === 'string' && containsSignal(text, mode.command)\n  ));\n  if (direct.length > 0) {\n    return direct.map((mode) => ({ mode: mode.workflowMode, score: Number.MAX_SAFE_INTEGER }));\n  }\n  return routingModel.modes.map((mode) => ({\n    mode: mode.workflowMode,\n    score: mode.keywords.filter((keyword) => containsSignal(text, keyword)).length * mode.weight,\n  })).filter((entry) => entry.score > 0);\n}\n\n// Caller contract: `modes` must already be the ambiguityDelta-filtered\n// contending set (see contendingModes), never the raw positive-score list.\n// An and/plus/then conjunction names two AXES the prompt asked for -- it is\n// not itself evidence that a below-delta co-hit deserves promotion, so this\n// heuristic has to sit on the same co-dominance bar exactBundle uses instead\n// of bypassing it. Given the wrong (unfiltered) list it would force-bundle a\n// mode legacy would have dropped, exactly the compiled-over-legacy drift this\n// contract exists to prevent.\nfunction clearlySeparateAxes(text, modes) {\n  return modes.length === 2 && /\\b(?:and|plus|then)\\b/.test(text);\n}\n\n// Mirrors router-replay.cjs's selectIntents (the legacy replay's own ambiguity\n// gate): keep only the modes within ambiguityDelta of the top score. Both an\n// authored bundle rule (see exactBundle) and the and/plus/then conjunction\n// heuristic (see clearlySeparateAxes) read this same contending set, never\n// the raw score list -- neither has a textual signal strong enough to justify\n// overriding a clear score winner, so both must only fire when their modes\n// are genuinely co-dominant, the same bar legacy applies before it ever\n// selects more than one intent.\nfunction contendingModes(scores, ambiguityDelta) {\n  if (scores.length === 0) return [];\n  const top = scores[0].score;\n  return scores.filter((entry) => top - entry.score <= ambiguityDelta).map((entry) => entry.mode);\n}\n\nfunction evaluateCanary(snapshot, input) {\n  const built = buildRequest(snapshot, input);\n  const text = normalize(input.prompt || '');\n  const constraints = new Set((input.constraints || []).map(normalize));\n  let decision;\n  let scores = [];\n  if (constraints.has('forbidden') || text.includes('forbidden')) {\n    decision = negative('reject', { reason: 'forbidden' });\n  } else if (constraints.has('dependency-failure')) {\n    decision = negative('defer', { reason: 'dependency-failure', recovery: ['defer'] });\n  } else if (input.explicitMode) {\n    const matches = explicitMode(snapshot.routingModel, input.explicitMode);\n    if (matches.length === 1) decision = route(snapshot, 'single', [matches[0].workflowMode]);\n    else if (constraints.has('clarify') || matches.length > 1) {\n      decision = clarify(snapshot, built.request, matches.map((mode) => mode.workflowMode));\n    } else decision = negative('defer', { reason: 'no-match', recovery: [] });\n  } else {\n    scores = scoreModes(snapshot.routingModel, text);\n    const order = new Map(snapshot.routingModel.tieBreak.map((mode, index) => [mode, index]));\n    scores.sort((left, right) => (\n      right.score - left.score || order.get(left.mode) - order.get(right.mode)\n    ));\n    const modes = scores.map((entry) => entry.mode);\n    if (constraints.has('clarify')) {\n      decision = clarify(snapshot, built.request, modes);\n    } else if (modes.length === 0) {\n      decision = snapshot.routingModel.defaultMode === null\n        ? negative('defer', { reason: 'no-match', recovery: [] })\n        : route(snapshot, 'single', [snapshot.routingModel.defaultMode]);\n    } else {\n      const contending = contendingModes(scores, snapshot.routingModel.ambiguityDelta);\n      const bundle = exactBundle(snapshot.routingModel, contending);\n      if (bundle) {\n        decision = route(snapshot, 'orderedBundle', bundle.targetWorkflowModes);\n      } else if (clearlySeparateAxes(text, contending)) {\n        decision = route(snapshot, 'orderedBundle', contending.sort((left, right) => (\n          order.get(left) - order.get(right)\n        )));\n      } else if (scores.length === 1\n        || scores[0].score - scores[1].score > snapshot.routingModel.ambiguityDelta) {\n        decision = route(snapshot, 'single', [scores[0].mode]);\n      } else {\n        decision = clarify(snapshot, built.request, modes);\n      }\n    }\n  }\n  return {\n    advisorDisposition: built.disposition,","lineStart":1,"lineEnd":260,"totalLines":307,"truncated":true}},"title":".opencode/bin/lib/compiled-routing/006-parent-hub-rollout/006-sk-design/lib/router.cjs","time":{"start":1784692724597,"end":1784692724602}},"metadata":{"openai":{"itemId":"fc_0e768169a8311c2d016a603ff483088191ad2469c7a499ae14"}},"id":"prt_f87f9d353001myzEDhBlcqtm8F","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f99f08001AvBeT65Y6behcJ"}}
{"type":"tool_use","timestamp":1784692724644,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_i35euuVltd43vC8eqUunKor5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs","offset":180,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs</path>\n<type>file</type>\n<content>\n180:     {\n181:       env: { ...process.env, ...envOverrides },\n182:       encoding: 'utf8',\n183:       shell: false,\n184:     },\n185:   );\n186:   if (process.env.SPECKIT_COMPILED_ROUTING !== parentFlag) {\n187:     throw new Error('compiled child mutated the parent routing flag');\n188:   }\n189:   if (result.error) throw result.error;\n190:   if (result.status !== 0) {\n191:     throw new Error(result.stderr.trim() || `child exited ${result.status}`);\n192:   }\n193:   try {\n194:     return JSON.parse(result.stdout);\n195:   } catch {\n196:     throw new Error(`invalid JSON from ${path.basename(scriptPath)}`);\n197:   }\n198: }\n199: \n200: /**\n201:  * Produce the compiled routing decision for a hub + prompt through the promoted\n202:  * runtime engine. A load or route throw is surfaced (not swallowed) so the\n203:  * caller can classify it as a broken compiled path rather than a false pass.\n204:  *\n205:  * @param {string} hubId - Hub id.\n206:  * @param {string} taskText - Scenario prompt.\n207:  * @returns {Object} Normalized compiled decision ({ action, targets, ... }).\n208:  */\n209: function defaultCompiledDecision(hubId, taskText) {\n210:   return runJsonChild(\n211:     PUBLIC_FRONT_DOOR,\n212:     ['--hub', hubId, '--prompt', taskText],\n213:     { SPECKIT_COMPILED_ROUTING: '1' },\n214:   );\n215: }\n216: \n217: function defaultProbeStatus(hubId) {\n218:   return runJsonChild(\n219:     STATUS_PROBE,\n220:     ['--hub', hubId, '--no-probe'],\n221:     { SPECKIT_COMPILED_ROUTING: '1' },\n222:   );\n223: }\n224: \n225: const modeIndexCache = new Map();\n226: \n227: /**\n228:  * Build a hub's manifest mode index (workflowMode -> mode entry with its leaves)\n229:  * from its committed leaf-manifest, keyed by hub id. A compiled target names its\n230:  * destination hub, which may differ from the benchmarked hub (a hub legitimately\n231:  * routes across to another hub's mode), so the index is resolved per target hub,\n232:  * never assumed to be the benchmarked skill's. Returns an empty index when the\n233:  * hub ships no manifest.\n234:  *\n235:  * @param {string} hubId - Destination hub id.\n236:  * @returns {Object<string,Object>} workflowMode -> mode entry.\n237:  */\n238: function defaultLoadModeIndex(hubId) {\n239:   if (modeIndexCache.has(hubId)) return modeIndexCache.get(hubId);\n240:   const index = {};\n241:   try {\n242:     const manifest = JSON.parse(fs.readFileSync(path.join(SKILLS_ROOT, hubId, 'leaf-manifest.json'), 'utf8'));\n243:     for (const mode of manifest.modes || []) {\n244:       if (mode && mode.workflowMode) index[mode.workflowMode] = mode;\n245:     }\n246:   } catch {\n247:     // No manifest for this hub: leave the index empty so its targets fail closed.\n248:   }\n249:   try {\n250:     const registry = JSON.parse(fs.readFileSync(path.join(SKILLS_ROOT, hubId, 'mode-registry.json'), 'utf8'));\n251:     for (const mode of registry.modes || []) {\n252:       if (!mode || !mode.workflowMode) continue;\n253:       index[mode.workflowMode] = { ...(index[mode.workflowMode] || {}), ...mode };\n254:     }\n255:   } catch {\n256:     // A missing registry leaves the leaf-only index intact.\n257:   }\n258:   modeIndexCache.set(hubId, index);\n259:   return index;\n260: }\n261: \n262: /**\n263:  * Compose a compiled target's qualified id string. A target is either an\n264:  * already-qualified string or a decomposed object; both encode the same\n265:  * `<hub>/<workflowMode>/<packet>/<kind>/<slug>` identity.\n266:  *\n267:  * @param {(string|Object)} target - Compiled decision target.\n268:  * @returns {string} Qualified id.\n269:  */\n270: function qualifiedIdOf(target) {\n271:   if (typeof target === 'string') return target;\n272:   if (target && typeof target === 'object') {\n273:     if (typeof target.qualifiedId === 'string' && target.qualifiedId) return target.qualifiedId;\n274:     return [target.skillId, target.workflowMode, target.packetId, target.packetKind, target.backendKind]\n275:       .filter((segment) => segment != null && segment !== '')\n276:       .join('/');\n277:   }\n278:   return String(target);\n279: }\n280: \n281: /**\n282:  * Translate compiled decision targets into a legacy-shaped observed decision by\n283:  * resolving each qualified id through the shared contract. The observed intents\n284:  * are the resolved workflow modes; the observed resources are the manifest\n285:  * leaves those modes declare, packet-qualified (`<packet>/<leaf>`) to match\n286:  * legacy's own hub-relative addressing -- a leaf-manifest records leaves\n287:  * packet-root-relative (`references/...`), but every router resource map in\n288:  * this codebase (hub-router.json pointers, a retained smart-routing.md\n289:  * RESOURCE_MAP) addresses the same leaf hub-relative with the packet name as a\n290:  * literal prefix, so an unqualified leaf would never string-match legacy's own\n291:  * observed resources or a scenario's authored gold. A target that resolves to\n292:  * no manifest mode is collected as unresolved (a broken bridge), never\n293:  * silently dropped.\n294:  *\n295:  * @param {Array<(string|Object)>} targets - Compiled decision targets.\n296:  * @param {function(string): Object<string,Object>} loadModeIndex - hubId -> mode index.\n297:  * @returns {{observedIntents:string[], observedResources:string[], unresolved:string[]}} Translated observed.\n298:  */\n299: function translateTargetsToObserved(targets, loadModeIndex) {\n300:   const observedIntents = [];\n301:   const seenIntent = new Set();\n302:   const resources = new Set();\n303:   const unresolved = [];\n304:   const normalizedTargets = [];\n305:   for (const target of targets || []) {\n306:     const qualifiedId = qualifiedIdOf(target);\n307:     // A target resolves against its own destination hub's manifest, which may\n308:     // differ from the benchmarked hub.\n309:     const targetHub = String(qualifiedId).split('/')[0];\n310:     const modeIndex = (typeof loadModeIndex === 'function' ? loadModeIndex(targetHub) : loadModeIndex) || {};\n311:     const resolved = qualifiedIdToLeaf(qualifiedId, { modeIndex });\n312:     if (!resolved.ok) {\n313:       unresolved.push(qualifiedId);\n314:       continue;\n315:     }\n316:     if (!seenIntent.has(resolved.workflowMode)) {\n317:       seenIntent.add(resolved.workflowMode);\n318:       observedIntents.push(resolved.workflowMode);\n319:     }\n320:     normalizedTargets.push({\n321:       hubId: resolved.hub,\n322:       workflowMode: resolved.workflowMode,\n323:       packetKind: resolved.mode.packetKind || resolved.kind,\n324:     });\n325:     const leaves = resolved.mode && Array.isArray(resolved.mode.leaves) ? resolved.mode.leaves : [];\n326:     const packet = resolved.mode && typeof resolved.mode.packet === 'string' ? resolved.mode.packet : '';\n327:     const packetPrefix = packet ? `${packet}/` : '';\n328:     for (const leaf of leaves) resources.add(`${packetPrefix}${leaf}`);\n329:   }\n330:   return {\n331:     observedIntents,\n332:     observedResources: [...resources],\n333:     unresolved,\n334:     normalizedTargets,\n335:   };\n336: }\n337: \n338: /**\n339:  * Collect the set of packet ids a hub's mode index declares. Used to classify\n340:  * a legacy-observed resource as packet-qualified (subject to compiled's own\n341:  * per-target leaf declaration) versus hub-level/unconditional (belongs to no\n342:  * packet at all, e.g. the always-loaded routing preamble) -- a distinction the\n343:  * shared `<packet>/<leaf>` string convention makes purely lexical: a\n344:  * packet-qualified resource's first path segment names a declared packet, a\n345:  * hub-level resource's does not.\n346:  *\n347:  * @param {Map<string,Object>|Object<string,Object>} modeIndex - workflowMode -> mode entry ({ packet, ... }).\n348:  * @returns {Set<string>} Declared packet ids.\n349:  */\n350: function packetIdsForModeIndex(modeIndex) {\n351:   const ids = new Set();\n352:   const entries = modeIndex instanceof Map ? modeIndex.values() : Object.values(modeIndex || {});\n353:   for (const mode of entries) {\n354:     if (mode && typeof mode.packet === 'string' && mode.packet) ids.add(mode.packet);\n355:   }\n356:   return ids;\n357: }\n358: \n359: /**\n360:  * Project compiled's per-target leaf declaration down to legacy's own observed\n361:  * granularity for the route-gold comparison. A leaf-manifest declares the FULL\n362:  * leaf set a workflow mode could ever serve (mode granularity, every\n363:  * language/surface it could ever need); legacy's own observed resources are\n364:  * the finer, task-scoped subset the retained surface router actually replayed\n365:  * for THIS scenario -- a layer compiled routing does not replace, so it is\n366:  * byte-identical regardless of which engine picked the mode. An unconditional\n367:  * hub-level resource (the always-loaded routing preamble) belongs to no\n368:  * packet's leaf declaration at all, so it could never appear in ANY per-target\n369:  * leaf set even when correctly declared. Comparing compiled's raw, unfiltered\n370:  * declaration straight against a task-scoped, hub-level-inclusive gold is\n371:  * apples-to-oranges.\n372:  *\n373:  * The fix is NOT to trust compiled's claim wholesale (that would make a real\n374:  * compiled leaf-manifest gap unobservable) and NOT to trust legacy's claim\n375:  * wholesale either (same reason, inverted): legacy's own observed set is kept\n376:  * ONLY for the resources compiled's declared leaves confirm (packet-qualified)\n377:  * or that sit outside any packet's declaration entirely (hub-level,\n378:  * unconditional, hence never gated by which target was selected). A genuine\n379:  * compiled per-target leaf gap -- a packet-qualified resource legacy selected\n380:  * that compiled's manifest never declares for that target -- cannot survive\n381:  * this filter, so it still fails the must-include/forbidden-prefix gold check\n382:  * and still reports as drift.\n383:  *\n384:  * @param {Object} args - Projection inputs.\n385:  * @param {string[]} args.legacyResources - Legacy's own observed resources for this scenario.\n386:  * @param {string[]} args.compiledResources - Compiled's declared, packet-qualified resources.\n387:  * @param {Set<string>} args.hubPacketIds - Packet ids the benchmarked hub declares.\n388:  * @returns {string[]} Legacy's observed resources, narrowed to what compiled's declaration can support.\n389:  */\n390: function projectCompiledResourcesToLegacyGranularity({ legacyResources, compiledResources, hubPacketIds }) {\n391:   const compiledSet = new Set(compiledResources || []);\n392:   const packetIds = hubPacketIds || new Set();\n393:   return (legacyResources || []).filter((resource) => {\n394:     const firstSegment = String(resource).split('/')[0];\n395:     const packetQualified = packetIds.has(firstSegment);\n396:     return !packetQualified || compiledSet.has(resource);\n397:   });\n398: }\n399: \n400: function selectionKindForTargets(targets) {\n401:   if (!targets.length) return null;\n402:   if (targets.length === 1) return 'single';\n403:   // Mirrors registry-compiler.cjs's bundleKindForModes (the compiler's own\n404:   // authority for this classification) and decision-contract.cjs's\n405:   // assertComposition: surfaceBundle requires EXACTLY one actor-role target\n406:   // plus one-or-more evidence-role targets. `packetKind === 'surface'` is the\n407:   // evidence marker (PACKET_AUTHORITY); every other packetKind is actor. Any\n408:   // other tie shape -- two-or-more actors (even alongside a surface target),\n409:   // or evidence with no actor at all -- is orderedBundle, which carries no\n410:   // role restriction.\n411:   const actors = targets.filter((target) => target.packetKind !== 'surface').length;\n412:   const evidence = targets.length - actors;\n413:   return (actors === 1 && evidence === targets.length - 1) ? 'surfaceBundle' : 'orderedBundle';\n414: }\n415: \n416: function normalizeLegacyProjection(legacyObserved, hubId, loadModeIndex) {\n417:   if (legacyObserved && legacyObserved.routingProjection) {\n418:     return legacyObserved.routingProjection;\n419:   }\n420:   const telemetry = legacyObserved && legacyObserved.raw && legacyObserved.raw.routeTelemetry;\n421:   const rawModes = telemetry && Array.isArray(telemetry.workflowMode)\n422:     ? telemetry.workflowMode\n423:     : (Array.isArray(legacyObserved && legacyObserved.observedIntents)\n424:       ? legacyObserved.observedIntents\n425:       : []);\n426:   const index = loadModeIndex(hubId) || {};\n427:   const targets = rawModes.map((workflowMode) => ({\n428:     hubId,\n429:     workflowMode,\n430:     packetKind: index[workflowMode] && index[workflowMode].packetKind\n431:       ? index[workflowMode].packetKind\n432:       : 'workflow',\n433:   }));\n434:   const action = targets.length ? 'route' : 'defer';\n435:   return { action, selectionKind: selectionKindForTargets(targets), targets };\n436: }\n437: \n438: function normalizeCompiledProjection(decision, bridged) {\n439:   const action = decision && typeof decision.action === 'string'\n440:     ? decision.action\n441:     : 'defer';\n442:   const targets = bridged ? bridged.normalizedTargets : [];\n443:   return {\n444:     action,\n445:     selectionKind: action === 'route'\n446:       ? (decision.selectionKind || selectionKindForTargets(targets))\n447:       : null,\n448:     targets,\n449:   };\n450: }\n451: \n452: function firstProjectionDifference(legacyProjection, compiledProjection) {\n453:   for (const field of ['action', 'selectionKind']) {\n454:     if (legacyProjection[field] !== compiledProjection[field]) {\n455:       return { field, legacy: legacyProjection[field], compiled: compiledProjection[field] };\n456:     }\n457:   }\n458:   if (legacyProjection.targets.length !== compiledProjection.targets.length) {\n459:     return {\n\n(Showing lines 180-459 of 842. Use offset=460 to continue.)\n</content>","metadata":{"preview":"    {\n      env: { ...process.env, ...envOverrides },\n      encoding: 'utf8',\n      shell: false,\n    },\n  );\n  if (process.env.SPECKIT_COMPILED_ROUTING !== parentFlag) {\n    throw new Error('compiled child mutated the parent routing flag');\n  }\n  if (result.error) throw result.error;\n  if (result.status !== 0) {\n    throw new Error(result.stderr.trim() || `child exited ${result.status}`);\n  }\n  try {\n    return JSON.parse(result.stdout);\n  } catch {\n    throw new Error(`invalid JSON from ${path.basename(scriptPath)}`);\n  }\n}\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs","text":"    {\n      env: { ...process.env, ...envOverrides },\n      encoding: 'utf8',\n      shell: false,\n    },\n  );\n  if (process.env.SPECKIT_COMPILED_ROUTING !== parentFlag) {\n    throw new Error('compiled child mutated the parent routing flag');\n  }\n  if (result.error) throw result.error;\n  if (result.status !== 0) {\n    throw new Error(result.stderr.trim() || `child exited ${result.status}`);\n  }\n  try {\n    return JSON.parse(result.stdout);\n  } catch {\n    throw new Error(`invalid JSON from ${path.basename(scriptPath)}`);\n  }\n}\n\n/**\n * Produce the compiled routing decision for a hub + prompt through the promoted\n * runtime engine. A load or route throw is surfaced (not swallowed) so the\n * caller can classify it as a broken compiled path rather than a false pass.\n *\n * @param {string} hubId - Hub id.\n * @param {string} taskText - Scenario prompt.\n * @returns {Object} Normalized compiled decision ({ action, targets, ... }).\n */\nfunction defaultCompiledDecision(hubId, taskText) {\n  return runJsonChild(\n    PUBLIC_FRONT_DOOR,\n    ['--hub', hubId, '--prompt', taskText],\n    { SPECKIT_COMPILED_ROUTING: '1' },\n  );\n}\n\nfunction defaultProbeStatus(hubId) {\n  return runJsonChild(\n    STATUS_PROBE,\n    ['--hub', hubId, '--no-probe'],\n    { SPECKIT_COMPILED_ROUTING: '1' },\n  );\n}\n\nconst modeIndexCache = new Map();\n\n/**\n * Build a hub's manifest mode index (workflowMode -> mode entry with its leaves)\n * from its committed leaf-manifest, keyed by hub id. A compiled target names its\n * destination hub, which may differ from the benchmarked hub (a hub legitimately\n * routes across to another hub's mode), so the index is resolved per target hub,\n * never assumed to be the benchmarked skill's. Returns an empty index when the\n * hub ships no manifest.\n *\n * @param {string} hubId - Destination hub id.\n * @returns {Object<string,Object>} workflowMode -> mode entry.\n */\nfunction defaultLoadModeIndex(hubId) {\n  if (modeIndexCache.has(hubId)) return modeIndexCache.get(hubId);\n  const index = {};\n  try {\n    const manifest = JSON.parse(fs.readFileSync(path.join(SKILLS_ROOT, hubId, 'leaf-manifest.json'), 'utf8'));\n    for (const mode of manifest.modes || []) {\n      if (mode && mode.workflowMode) index[mode.workflowMode] = mode;\n    }\n  } catch {\n    // No manifest for this hub: leave the index empty so its targets fail closed.\n  }\n  try {\n    const registry = JSON.parse(fs.readFileSync(path.join(SKILLS_ROOT, hubId, 'mode-registry.json'), 'utf8'));\n    for (const mode of registry.modes || []) {\n      if (!mode || !mode.workflowMode) continue;\n      index[mode.workflowMode] = { ...(index[mode.workflowMode] || {}), ...mode };\n    }\n  } catch {\n    // A missing registry leaves the leaf-only index intact.\n  }\n  modeIndexCache.set(hubId, index);\n  return index;\n}\n\n/**\n * Compose a compiled target's qualified id string. A target is either an\n * already-qualified string or a decomposed object; both encode the same\n * `<hub>/<workflowMode>/<packet>/<kind>/<slug>` identity.\n *\n * @param {(string|Object)} target - Compiled decision target.\n * @returns {string} Qualified id.\n */\nfunction qualifiedIdOf(target) {\n  if (typeof target === 'string') return target;\n  if (target && typeof target === 'object') {\n    if (typeof target.qualifiedId === 'string' && target.qualifiedId) return target.qualifiedId;\n    return [target.skillId, target.workflowMode, target.packetId, target.packetKind, target.backendKind]\n      .filter((segment) => segment != null && segment !== '')\n      .join('/');\n  }\n  return String(target);\n}\n\n/**\n * Translate compiled decision targets into a legacy-shaped observed decision by\n * resolving each qualified id through the shared contract. The observed intents\n * are the resolved workflow modes; the observed resources are the manifest\n * leaves those modes declare, packet-qualified (`<packet>/<leaf>`) to match\n * legacy's own hub-relative addressing -- a leaf-manifest records leaves\n * packet-root-relative (`references/...`), but every router resource map in\n * this codebase (hub-router.json pointers, a retained smart-routing.md\n * RESOURCE_MAP) addresses the same leaf hub-relative with the packet name as a\n * literal prefix, so an unqualified leaf would never string-match legacy's own\n * observed resources or a scenario's authored gold. A target that resolves to\n * no manifest mode is collected as unresolved (a broken bridge), never\n * silently dropped.\n *\n * @param {Array<(string|Object)>} targets - Compiled decision targets.\n * @param {function(string): Object<string,Object>} loadModeIndex - hubId -> mode index.\n * @returns {{observedIntents:string[], observedResources:string[], unresolved:string[]}} Translated observed.\n */\nfunction translateTargetsToObserved(targets, loadModeIndex) {\n  const observedIntents = [];\n  const seenIntent = new Set();\n  const resources = new Set();\n  const unresolved = [];\n  const normalizedTargets = [];\n  for (const target of targets || []) {\n    const qualifiedId = qualifiedIdOf(target);\n    // A target resolves against its own destination hub's manifest, which may\n    // differ from the benchmarked hub.\n    const targetHub = String(qualifiedId).split('/')[0];\n    const modeIndex = (typeof loadModeIndex === 'function' ? loadModeIndex(targetHub) : loadModeIndex) || {};\n    const resolved = qualifiedIdToLeaf(qualifiedId, { modeIndex });\n    if (!resolved.ok) {\n      unresolved.push(qualifiedId);\n      continue;\n    }\n    if (!seenIntent.has(resolved.workflowMode)) {\n      seenIntent.add(resolved.workflowMode);\n      observedIntents.push(resolved.workflowMode);\n    }\n    normalizedTargets.push({\n      hubId: resolved.hub,\n      workflowMode: resolved.workflowMode,\n      packetKind: resolved.mode.packetKind || resolved.kind,\n    });\n    const leaves = resolved.mode && Array.isArray(resolved.mode.leaves) ? resolved.mode.leaves : [];\n    const packet = resolved.mode && typeof resolved.mode.packet === 'string' ? resolved.mode.packet : '';\n    const packetPrefix = packet ? `${packet}/` : '';\n    for (const leaf of leaves) resources.add(`${packetPrefix}${leaf}`);\n  }\n  return {\n    observedIntents,\n    observedResources: [...resources],\n    unresolved,\n    normalizedTargets,\n  };\n}\n\n/**\n * Collect the set of packet ids a hub's mode index declares. Used to classify\n * a legacy-observed resource as packet-qualified (subject to compiled's own\n * per-target leaf declaration) versus hub-level/unconditional (belongs to no\n * packet at all, e.g. the always-loaded routing preamble) -- a distinction the\n * shared `<packet>/<leaf>` string convention makes purely lexical: a\n * packet-qualified resource's first path segment names a declared packet, a\n * hub-level resource's does not.\n *\n * @param {Map<string,Object>|Object<string,Object>} modeIndex - workflowMode -> mode entry ({ packet, ... }).\n * @returns {Set<string>} Declared packet ids.\n */\nfunction packetIdsForModeIndex(modeIndex) {\n  const ids = new Set();\n  const entries = modeIndex instanceof Map ? modeIndex.values() : Object.values(modeIndex || {});\n  for (const mode of entries) {\n    if (mode && typeof mode.packet === 'string' && mode.packet) ids.add(mode.packet);\n  }\n  return ids;\n}\n\n/**\n * Project compiled's per-target leaf declaration down to legacy's own observed\n * granularity for the route-gold comparison. A leaf-manifest declares the FULL\n * leaf set a workflow mode could ever serve (mode granularity, every\n * language/surface it could ever need); legacy's own observed resources are\n * the finer, task-scoped subset the retained surface router actually replayed\n * for THIS scenario -- a layer compiled routing does not replace, so it is\n * byte-identical regardless of which engine picked the mode. An unconditional\n * hub-level resource (the always-loaded routing preamble) belongs to no\n * packet's leaf declaration at all, so it could never appear in ANY per-target\n * leaf set even when correctly declared. Comparing compiled's raw, unfiltered\n * declaration straight against a task-scoped, hub-level-inclusive gold is\n * apples-to-oranges.\n *\n * The fix is NOT to trust compiled's claim wholesale (that would make a real\n * compiled leaf-manifest gap unobservable) and NOT to trust legacy's claim\n * wholesale either (same reason, inverted): legacy's own observed set is kept\n * ONLY for the resources compiled's declared leaves confirm (packet-qualified)\n * or that sit outside any packet's declaration entirely (hub-level,\n * unconditional, hence never gated by which target was selected). A genuine\n * compiled per-target leaf gap -- a packet-qualified resource legacy selected\n * that compiled's manifest never declares for that target -- cannot survive\n * this filter, so it still fails the must-include/forbidden-prefix gold check\n * and still reports as drift.\n *\n * @param {Object} args - Projection inputs.\n * @param {string[]} args.legacyResources - Legacy's own observed resources for this scenario.\n * @param {string[]} args.compiledResources - Compiled's declared, packet-qualified resources.\n * @param {Set<string>} args.hubPacketIds - Packet ids the benchmarked hub declares.\n * @returns {string[]} Legacy's observed resources, narrowed to what compiled's declaration can support.\n */\nfunction projectCompiledResourcesToLegacyGranularity({ legacyResources, compiledResources, hubPacketIds }) {\n  const compiledSet = new Set(compiledResources || []);\n  const packetIds = hubPacketIds || new Set();\n  return (legacyResources || []).filter((resource) => {\n    const firstSegment = String(resource).split('/')[0];\n    const packetQualified = packetIds.has(firstSegment);\n    return !packetQualified || compiledSet.has(resource);\n  });\n}\n\nfunction selectionKindForTargets(targets) {\n  if (!targets.length) return null;\n  if (targets.length === 1) return 'single';\n  // Mirrors registry-compiler.cjs's bundleKindForModes (the compiler's own\n  // authority for this classification) and decision-contract.cjs's\n  // assertComposition: surfaceBundle requires EXACTLY one actor-role target\n  // plus one-or-more evidence-role targets. `packetKind === 'surface'` is the\n  // evidence marker (PACKET_AUTHORITY); every other packetKind is actor. Any\n  // other tie shape -- two-or-more actors (even alongside a surface target),\n  // or evidence with no actor at all -- is orderedBundle, which carries no\n  // role restriction.\n  const actors = targets.filter((target) => target.packetKind !== 'surface').length;\n  const evidence = targets.length - actors;\n  return (actors === 1 && evidence === targets.length - 1) ? 'surfaceBundle' : 'orderedBundle';\n}\n\nfunction normalizeLegacyProjection(legacyObserved, hubId, loadModeIndex) {\n  if (legacyObserved && legacyObserved.routingProjection) {\n    return legacyObserved.routingProjection;\n  }\n  const telemetry = legacyObserved && legacyObserved.raw && legacyObserved.raw.routeTelemetry;\n  const rawModes = telemetry && Array.isArray(telemetry.workflowMode)\n    ? telemetry.workflowMode\n    : (Array.isArray(legacyObserved && legacyObserved.observedIntents)\n      ? legacyObserved.observedIntents\n      : []);\n  const index = loadModeIndex(hubId) || {};\n  const targets = rawModes.map((workflowMode) => ({\n    hubId,\n    workflowMode,\n    packetKind: index[workflowMode] && index[workflowMode].packetKind\n      ? index[workflowMode].packetKind\n      : 'workflow',\n  }));\n  const action = targets.length ? 'route' : 'defer';\n  return { action, selectionKind: selectionKindForTargets(targets), targets };\n}\n\nfunction normalizeCompiledProjection(decision, bridged) {\n  const action = decision && typeof decision.action === 'string'\n    ? decision.action\n    : 'defer';\n  const targets = bridged ? bridged.normalizedTargets : [];\n  return {\n    action,\n    selectionKind: action === 'route'\n      ? (decision.selectionKind || selectionKindForTargets(targets))\n      : null,\n    targets,\n  };\n}\n\nfunction firstProjectionDifference(legacyProjection, compiledProjection) {\n  for (const field of ['action', 'selectionKind']) {\n    if (legacyProjection[field] !== compiledProjection[field]) {\n      return { field, legacy: legacyProjection[field], compiled: compiledProjection[field] };\n    }\n  }\n  if (legacyProjection.targets.length !== compiledProjection.targets.length) {\n    return {","lineStart":180,"lineEnd":459,"totalLines":842,"truncated":true}},"title":".opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs","time":{"start":1784692724632,"end":1784692724642}},"metadata":{"openai":{"itemId":"fc_0e768169a8311c2d016a603ff483108191a283eaeeda437462"}},"id":"prt_f87f9d394001om42VsSP984JYq","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87f99f08001AvBeT65Y6behcJ"}}
