":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: File Watcher\n// ───────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport fs from 'node:fs/promises';\nimport path from 'node:path';\nimport { createHash } from 'node:crypto';\nimport { BetterSqliteContentionPolicy } from '../storage/ports/contention-policy.js';\n\n// Feature catalog: Real-time filesystem watching with chokidar\n// Feature catalog: Watcher delete/rename cleanup\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Describes the WatcherConfig shape.\n */\nexport interface WatcherConfig {\n  paths: string[];\n  reindexFn: (filePath: string) => Promise<unknown>;\n  removeFn?: (filePath: string) => Promise<unknown>;\n  debounceMs?: number;\n  watchFactory?: (paths: string[], options: Record<string, unknown>) => FSWatcher;\n}\n\n/**\n * Describes the FSWatcher shape.\n */\nexport interface FSWatcher {\n  on: (event: string, listener: (...args: unknown[]) => void) => FSWatcher;\n  close: () => Promise<void>;\n}\n\ninterface ChokidarModule {\n  default: {\n    watch: (paths: string[], options: Record<string, unknown>) => FSWatcher;\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_DEBOUNCE_MS = 2000;\nconst RETRY_DELAYS_MS = [1000, 2000, 4000];\nconst MAX_BUSY_RETRIES = RETRY_DELAYS_MS.length;\nconst busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n\n// Watcher metrics counters\nlet filesReindexed = 0;\nlet totalReindexTimeMs = 0;\nlet chokidarModule: ChokidarModule | null = null;\nlet chokidarModulePromise: Promise<ChokidarModule | null> | null = null;\nlet chokidarModuleLoadError: string | null = null;\n\n/** Return accumulated watcher metrics for diagnostics. */\nexport function getWatcherMetrics(): { filesReindexed: number; avgReindexTimeMs: number } {\n  return {\n    filesReindexed,\n    avgReindexTimeMs: filesReindexed > 0 ? Math.round(totalReindexTimeMs / filesReindexed) : 0,\n  };\n}\n\nexport function resetWatcherMetrics(): void {\n  filesReindexed = 0;\n  totalReindexTimeMs = 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n/**\n * Coordinates early wake-up of in-flight retry sleeps so a watcher shutdown\n * never has to wait for a pending backoff timer to expire. A retry sleep\n * registers a `wake` callback; `wakeAll()` settles every outstanding sleep\n * immediately, letting each one re-check its abort condition. This keeps\n * `close()` from blocking on a non-cancellable timer (and from deadlocking\n * under fake timers, where the backoff timeout would otherwise never fire).\n */\ninterface RetryWaker {\n  register(wake: () => void): () => void;\n  wakeAll(): void;\n}\n\nfunction createRetryWaker(): RetryWaker {\n  const waiters = new Set<() => void>();\n  let woken = false;\n  return {\n    register(wake: () => void): () => void {\n      // Sticky after wakeAll(): a sleep entered after shutdown began is woken\n      // at once, so a task that hits SQLITE_BUSY mid-close still exits promptly\n      // instead of stalling close() on a fresh retry timer.\n      if (woken) {\n        wake();\n        return () => undefined;\n      }\n      waiters.add(wake);\n      return () => { waiters.delete(wake); };\n    },\n    wakeAll(): void {\n      woken = true;\n      const pending = Array.from(waiters);\n      waiters.clear();\n      for (const wake of pending) {\n        wake();\n      }\n    },\n  };\n}\n\n/**\n * Sleep that resolves either when `ms` elapses or when woken early via the\n * supplied waker. On early wake the backoff timer is cleared so no stray timer\n * survives shutdown.\n */\nfunction abortableSleep(ms: number, waker?: RetryWaker): Promise<void> {\n  if (!waker) {\n    return sleep(ms);\n  }\n  return new Promise((resolve) => {\n    let settled = false;\n    let unregister = (): void => undefined;\n    const finish = (): void => {\n      if (settled) return;\n      settled = true;\n      clearTimeout(timer);\n      unregister();\n      resolve();\n    };\n    const timer = setTimeout(finish, ms);\n    unregister = waker.register(finish);\n  });\n}\n\nasync function loadChokidarModule(): Promise<ChokidarModule | null> {\n  if (chokidarModule !== null) {\n    return chokidarModule;\n  }\n  if (chokidarModulePromise !== null) {\n    return chokidarModulePromise;\n  }\n\n  const loadPromise = (async (): Promise<ChokidarModule | null> => {\n    try {\n      chokidarModule = await import('chokidar') as ChokidarModule;\n      chokidarModuleLoadError = null;\n      return chokidarModule;\n    } catch (error: unknown) {\n      chokidarModuleLoadError = error instanceof Error ? error.message : String(error);\n      return null;\n    }\n  })();\n\n  chokidarModulePromise = loadPromise;\n  try {\n    return await loadPromise;\n  } finally {\n    if (chokidarModulePromise === loadPromise) {\n      chokidarModulePromise = null;\n    }\n  }\n}\n\nfunction getWatchFactory(): (paths: string[], options: Record<string, unknown>) => FSWatcher {\n  if (chokidarModule?.default?.watch) {\n    return chokidarModule.default.watch;\n  }\n\n  if (chokidarModulePromise === null) {","lineStart":1,"lineEnd":180,"totalLines":616,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts","time":{"start":1781144210818,"end":1781144210826}},"metadata":{"openai":{"itemId":"fc_00ef7a07dc6fe920016a2a1a92bc748191a84b464ccf697557"}},"id":"prt_eb477cd81001omTsFW6xz72iGB","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477aa88001NMcYgqsMCxrANg"}}
{"type":"tool_use","timestamp":1781144210854,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_U1ZdJ0cJcXdMccZyFFMM6UCR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Job Queue\n3: // ───────────────────────────────────────────────────────────────\n4: // True sequential worker, meaningful state transitions,\n5: // Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n6: // Crash recovery with re-enqueue, and original-path progress tracking.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import path from 'node:path';\n13: import { requireDb, toErrorMessage } from '../../utils/index.js';\n14: import type { GovernanceDecision } from '../governance/scope-governance.js';\n15: import { BetterSqliteContentionPolicy } from '../storage/ports/contention-policy.js';\n16: \n17: // Feature catalog: Async ingestion job lifecycle\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. TYPES\n21: ──────────────────────────────────────────────────────────────── */\n22: \n23: /**\n24:  * Defines the IngestJobState type.\n25:  */\n26: export type IngestJobState =\n27:   | 'queued'\n28:   | 'parsing'\n29:   | 'embedding'\n30:   | 'indexing'\n31:   | 'complete'\n32:   | 'failed'\n33:   | 'cancelled';\n34: \n35: /**\n36:  * Describes the IngestJobError shape.\n37:  */\n38: export interface IngestJobError {\n39:   filePath: string;\n40:   message: string;\n41:   timestamp: string;\n42: }\n43: \n44: /**\n45:  * Describes the IngestJob shape.\n46:  */\n47: export interface IngestJob {\n48:   id: string;\n49:   state: IngestJobState;\n50:   specFolder: string | null;\n51:   paths: string[];\n52:   filesTotal: number;\n53:   filesProcessed: number;\n54:   errors: IngestJobError[];\n55:   createdAt: string;\n56:   updatedAt: string;\n57:   // Validated governance decision captured at enqueue time so the worker\n58:   // re-indexes each path under the same provenance/retention/scope the\n59:   // synchronous save path applies. Null for ungoverned jobs (the default).\n60:   governance: GovernanceDecision | null;\n61: }\n62: \n63: export interface IngestJobForecast {\n64:   etaSeconds: number | null;\n65:   etaConfidence: number | null;\n66:   failureRisk: number | null;\n67:   riskSignals: string[];\n68:   caveat: string | null;\n69: }\n70: \n71: interface IngestJobRow {\n72:   id: string;\n73:   state: IngestJobState;\n74:   spec_folder: string | null;\n75:   paths_json: string;\n76:   files_total: number;\n77:   files_processed: number;\n78:   errors_json: string;\n79:   created_at: string;\n80:   updated_at: string;\n81:   governance_json?: string | null;\n82: }\n83: \n84: interface JobQueueConfig {\n85:   processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n86: }\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    3. CONSTANTS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: const ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\n93: const TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n94: \n95: const ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n96:   queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n97:   parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n98:   embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n99:   indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n100:   complete: new Set<IngestJobState>([]),\n101:   failed: new Set<IngestJobState>([]),\n102:   cancelled: new Set<IngestJobState>([]),\n103: };\n104: \n105: // SQLITE_BUSY retry delays that match the file-watcher pattern.\n106: const RETRY_DELAYS_MS = [50, 200, 500];\n107: \n108: /* ───────────────────────────────────────────────────────────────\n109:    5. STATE MANAGEMENT\n110: ──────────────────────────────────────────────────────────────── */\n111: \n112: // True sequential queue — only one job processes at a time.\n113: const pendingQueue: string[] = [];\n114: let workerActive = false;\n115: // Drain fence. Once set, the worker stops draining and refuses to touch the\n116: // database. This prevents the worker from reopening a connection that shutdown\n117: // has already checkpointed and closed, which would otherwise re-dirty the WAL\n118: // and the unclean-shutdown marker at rest.\n119: let shuttingDown = false;\n120: let processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\n121: const MAX_STORED_ERRORS = 50;\n122: const MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n123: const busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n124: \n125: /* ───────────────────────────────────────────────────────────────\n126:    4. HELPERS\n127: ──────────────────────────────────────────────────────────────── */\n128: \n129: function toPublicPathLabel(filePath: string): string {\n130:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n131: }\n132: \n133: function sleep(ms: number): Promise<void> {\n134:   return new Promise((resolve) => setTimeout(resolve, ms));\n135: }\n136: \n137: function parsePositiveIntEnv(name: string, fallback: number): number {\n138:   const raw = process.env[name];\n139:   if (!raw) return fallback;\n140: \n141:   const parsed = Number.parseInt(raw, 10);\n142:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n143: }\n144: \n145: function isSqliteBusyError(error: unknown): boolean {\n146:   const message = error instanceof Error ? error.message : String(error);\n147:   const code = (error as { code?: unknown })?.code;\n148:   return code === 'SQLITE_BUSY' || /SQLITE_BUSY/i.test(message);\n149: }\n150: \n151: async function withBusyRetry<T>(operation: () => T): Promise<T> {\n152:   return busyRetryPolicy.withRetry(operation, { retryDelaysMs: RETRY_DELAYS_MS }) as Promise<T>;\n153: }\n154: \n155: function withBusyRetrySync<T>(operation: () => T): T {\n156:   return busyRetryPolicy.withRetry(operation, {\n157:     retryDelaysMs: RETRY_DELAYS_MS,\n158:     sleepSync: busyWait,\n159:     sync: true,\n160:   }) as T;\n161: }\n162: \n163: function busyWait(ms: number): void {\n164:   const end = Date.now() + ms;\n165:   while (Date.now() < end) { /* busy-wait */ }\n166: }\n167: \n168: function parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n169:   if (!value) return fallback;\n170:   try {\n171:     const parsed = JSON.parse(value) as unknown;\n172:     return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n173:   } catch (_error: unknown) {\n174:     return fallback;\n175:   }\n176: }\n177: \n178: function parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n179:   if (!value) return null;\n180:   try {\n181:     const parsed = JSON.parse(value) as unknown;\n182:     if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n183:       return parsed as GovernanceDecision;\n184:     }\n185:     return null;\n186:   } catch (_error: unknown) {\n187:     return null;\n188:   }\n189: }\n190: \n191: function mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n192:   if (!row) return null;\n193:   return {\n194:     id: row.id,\n195:     state: row.state,\n196:     specFolder: row.spec_folder,\n197:     paths: parseJsonArray<string>(row.paths_json, []),\n198:     filesTotal: row.files_total,\n199:     filesProcessed: row.files_processed,\n200:     errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n201:     createdAt: row.created_at,\n202:     updatedAt: row.updated_at,\n203:     governance: parseGovernanceJson(row.governance_json),\n204:   };\n205: }\n206: \n207: function nowIso(): string {\n208:   return new Date().toISOString();\n209: }\n210: \n211: function isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n212:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n213: }\n214: \n215: // DB accessor for the worker path. While shutting down it refuses to acquire a\n216: // connection so the worker can never travel the requireDb -> getDb -> reopen\n217: // path after shutdown has closed the database. The throw is caught by the\n218: // worker's surrounding error handling and the drain unwinds cleanly.\n219: function acquireWorkerDb(): ReturnType<typeof requireDb> {\n220:   if (shuttingDown) {\n\n(Showing lines 1-220 of 818. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Job Queue\n// ───────────────────────────────────────────────────────────────\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { BetterSqliteContentionPolicy } from '../storage/ports/contention-policy.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Job Queue\n// ───────────────────────────────────────────────────────────────\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { BetterSqliteContentionPolicy } from '../storage/ports/contention-policy.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Defines the IngestJobState type.\n */\nexport type IngestJobState =\n  | 'queued'\n  | 'parsing'\n  | 'embedding'\n  | 'indexing'\n  | 'complete'\n  | 'failed'\n  | 'cancelled';\n\n/**\n * Describes the IngestJobError shape.\n */\nexport interface IngestJobError {\n  filePath: string;\n  message: string;\n  timestamp: string;\n}\n\n/**\n * Describes the IngestJob shape.\n */\nexport interface IngestJob {\n  id: string;\n  state: IngestJobState;\n  specFolder: string | null;\n  paths: string[];\n  filesTotal: number;\n  filesProcessed: number;\n  errors: IngestJobError[];\n  createdAt: string;\n  updatedAt: string;\n  // Validated governance decision captured at enqueue time so the worker\n  // re-indexes each path under the same provenance/retention/scope the\n  // synchronous save path applies. Null for ungoverned jobs (the default).\n  governance: GovernanceDecision | null;\n}\n\nexport interface IngestJobForecast {\n  etaSeconds: number | null;\n  etaConfidence: number | null;\n  failureRisk: number | null;\n  riskSignals: string[];\n  caveat: string | null;\n}\n\ninterface IngestJobRow {\n  id: string;\n  state: IngestJobState;\n  spec_folder: string | null;\n  paths_json: string;\n  files_total: number;\n  files_processed: number;\n  errors_json: string;\n  created_at: string;\n  updated_at: string;\n  governance_json?: string | null;\n}\n\ninterface JobQueueConfig {\n  processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\nconst TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n\nconst ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n  queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n  parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n  embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n  indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n// SQLITE_BUSY retry delays that match the file-watcher pattern.\nconst RETRY_DELAYS_MS = [50, 200, 500];\n\n/* ───────────────────────────────────────────────────────────────\n   5. STATE MANAGEMENT\n──────────────────────────────────────────────────────────────── */\n\n// True sequential queue — only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;\nlet processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\nconst MAX_STORED_ERRORS = 50;\nconst MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\nconst busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isSqliteBusyError(error: unknown): boolean {\n  const message = error instanceof Error ? error.message : String(error);\n  const code = (error as { code?: unknown })?.code;\n  return code === 'SQLITE_BUSY' || /SQLITE_BUSY/i.test(message);\n}\n\nasync function withBusyRetry<T>(operation: () => T): Promise<T> {\n  return busyRetryPolicy.withRetry(operation, { retryDelaysMs: RETRY_DELAYS_MS }) as Promise<T>;\n}\n\nfunction withBusyRetrySync<T>(operation: () => T): T {\n  return busyRetryPolicy.withRetry(operation, {\n    retryDelaysMs: RETRY_DELAYS_MS,\n    sleepSync: busyWait,\n    sync: true,\n  }) as T;\n}\n\nfunction busyWait(ms: number): void {\n  const end = Date.now() + ms;\n  while (Date.now() < end) { /* busy-wait */ }\n}\n\nfunction parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n  if (!value) return fallback;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n  if (!value) return null;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n      return parsed as GovernanceDecision;\n    }\n    return null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    state: row.state,\n    specFolder: row.spec_folder,\n    paths: parseJsonArray<string>(row.paths_json, []),\n    filesTotal: row.files_total,\n    filesProcessed: row.files_processed,\n    errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    governance: parseGovernanceJson(row.governance_json),\n  };\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\n// DB accessor for the worker path. While shutting down it refuses to acquire a\n// connection so the worker can never travel the requireDb -> getDb -> reopen\n// path after shutdown has closed the database. The throw is caught by the\n// worker's surrounding error handling and the drain unwinds cleanly.\nfunction acquireWorkerDb(): ReturnType<typeof requireDb> {\n  if (shuttingDown) {","lineStart":1,"lineEnd":220,"totalLines":818,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","time":{"start":1781144210850,"end":1781144210853}},"metadata":{"openai":{"itemId":"fc_00ef7a07dc6fe920016a2a1a92bc7c8191bf6301ce1a2078d9"}},"id":"prt_eb477cd83001yL9MIIN6i4OICL","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477aa88001NMcYgqsMCxrANg"}}
{"type":"tool_use","timestamp":1781144210902,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_DXCTNM75IzAPJhlVnXTM3mcE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/analytics/session-analytics-db.ts","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/analytics/session-analytics-db.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Session Analytics Db\n3: // ───────────────────────────────────────────────────────────────\n4: // Reader-owned normalized analytics store for replaying Stop-hook\n5: // producer metadata into queryable session and turn tables.\n6: \n7: import * as fs from 'node:fs';\n8: import * as path from 'node:path';\n9: \n10: import Database from 'better-sqlite3';\n11: \n12: import { DATABASE_DIR } from '../../core/config.js';\n13: import { parseTranscriptTurns, type TranscriptTurn } from '../../hooks/claude/claude-transcript.js';\n14: import type { HookState } from '../../hooks/claude/hook-state.js';\n15: import { BetterSqliteContentionPolicy } from '../storage/ports/index.js';\n16: \n17: export const SESSION_ANALYTICS_DB_FILENAME = 'speckit-session-analytics.db';\n18: \n19: const CACHE_WRITE_MULTIPLIER = 1.25;\n20: const CACHE_READ_MULTIPLIER = 0.1;\n21: \n22: interface SeedModelPricingRow {\n23:   pricing_key: string;\n24:   model_family: string;\n25:   match_pattern: string;\n26:   effective_from: string;\n27:   effective_to: string | null;\n28:   prompt_price_per_million_usd: number;\n29:   completion_price_per_million_usd: number;\n30:   cache_write_price_per_million_usd: number;\n31:   cache_read_price_per_million_usd: number;\n32:   source: string;\n33:   notes: string;\n34: }\n35: \n36: // Single source of truth for family-level pricing used by all internal cost calculations.\n37: // Pricing is intentionally hardcoded here rather than read from a DB table because the\n38: // values are compile-time constants tied to the estimateCost() family rates — keeping\n39: // them in-process eliminates a redundant DB round-trip and a divergence surface.\n40: const SEEDED_MODEL_PRICING_ROWS: SeedModelPricingRow[] = [\n41:   {\n42:     pricing_key: 'claude-opus-family-default',\n43:     model_family: 'opus',\n44:     match_pattern: 'opus',\n45:     effective_from: '2026-04-08T00:00:00.000Z',\n46:     effective_to: null,\n47:     prompt_price_per_million_usd: 15,\n48:     completion_price_per_million_usd: 75,\n49:     cache_write_price_per_million_usd: 15 * CACHE_WRITE_MULTIPLIER,\n50:     cache_read_price_per_million_usd: 15 * CACHE_READ_MULTIPLIER,\n51:     source: 'hooks/claude/claude-transcript.ts',\n52:     notes: 'Mirrors existing family-level estimateCost() prompt/output rates with cache multipliers applied.',\n53:   },\n54:   {\n55:     pricing_key: 'claude-sonnet-family-default',\n56:     model_family: 'sonnet',\n57:     match_pattern: 'sonnet',\n58:     effective_from: '2026-04-08T00:00:00.000Z',\n59:     effective_to: null,\n60:     prompt_price_per_million_usd: 3,\n61:     completion_price_per_million_usd: 15,\n62:     cache_write_price_per_million_usd: 3 * CACHE_WRITE_MULTIPLIER,\n63:     cache_read_price_per_million_usd: 3 * CACHE_READ_MULTIPLIER,\n64:     source: 'hooks/claude/claude-transcript.ts',\n65:     notes: 'Mirrors existing family-level estimateCost() prompt/output rates with cache multipliers applied.',\n66:   },\n67:   {\n68:     pricing_key: 'claude-haiku-family-default',\n69:     model_family: 'haiku',\n70:     match_pattern: 'haiku',\n71:     effective_from: '2026-04-08T00:00:00.000Z',\n72:     effective_to: null,\n73:     prompt_price_per_million_usd: 0.25,\n74:     completion_price_per_million_usd: 1.25,\n75:     cache_write_price_per_million_usd: 0.25 * CACHE_WRITE_MULTIPLIER,\n76:     cache_read_price_per_million_usd: 0.25 * CACHE_READ_MULTIPLIER,\n77:     source: 'hooks/claude/claude-transcript.ts',\n78:     notes: 'Mirrors existing family-level estimateCost() prompt/output rates with cache multipliers applied.',\n79:   },\n80: ];\n81: \n82: const SEEDED_CACHE_TIER_ROWS = [\n83:   {\n84:     cache_tier: 'cache_write',\n85:     source_field: 'cache_creation_input_tokens',\n86:     description: 'Normalized cache-write tier sourced from Claude transcript cache creation tokens.',\n87:   },\n88:   {\n89:     cache_tier: 'cache_read',\n90:     source_field: 'cache_read_input_tokens',\n91:     description: 'Normalized cache-read tier sourced from Claude transcript cache read tokens.',\n92:   },\n93: ] as const;\n94: \n95: const SESSION_ANALYTICS_SCHEMA_SQL = `\n96:   CREATE TABLE IF NOT EXISTS analytics_sessions (\n97:     claude_session_id TEXT PRIMARY KEY,\n98:     speckit_session_id TEXT,\n99:     transcript_path TEXT,\n100:     transcript_fingerprint TEXT,\n101:     transcript_size_bytes INTEGER NOT NULL DEFAULT 0,\n102:     transcript_modified_at TEXT,\n103:     last_claude_turn_at TEXT,\n104:     last_replay_offset INTEGER NOT NULL DEFAULT 0,\n105:     prompt_tokens INTEGER NOT NULL DEFAULT 0,\n106:     completion_tokens INTEGER NOT NULL DEFAULT 0,\n107:     cache_creation_input_tokens INTEGER NOT NULL DEFAULT 0,\n108:     cache_read_input_tokens INTEGER NOT NULL DEFAULT 0,\n109:     total_tokens INTEGER NOT NULL DEFAULT 0,\n110:     prompt_cost_usd REAL NOT NULL DEFAULT 0,\n111:     completion_cost_usd REAL NOT NULL DEFAULT 0,\n112:     cache_creation_cost_usd REAL NOT NULL DEFAULT 0,\n113:     cache_read_cost_usd REAL NOT NULL DEFAULT 0,\n114:     estimated_total_cost_usd REAL NOT NULL DEFAULT 0,\n115:     turn_count INTEGER NOT NULL DEFAULT 0,\n116:     last_spec_folder TEXT,\n117:     updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n118:   );\n119: \n120:   CREATE TABLE IF NOT EXISTS analytics_turns (\n\n(Showing lines 1-120 of 582. Use offset=121 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Session Analytics Db\n// ───────────────────────────────────────────────────────────────\n// Reader-owned normalized analytics store for replaying Stop-hook\n// producer metadata into queryable session and turn tables.\n\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { parseTranscriptTurns, type TranscriptTurn } from '../../hooks/claude/claude-transcript.js';\nimport type { HookState } from '../../hooks/claude/hook-state.js';\nimport { BetterSqliteContentionPolicy } from '../storage/ports/index.js';\n\nexport const SESSION_ANALYTICS_DB_FILENAME = 'speckit-session-analytics.db';\n\nconst CACHE_WRITE_MULTIPLIER = 1.25;\nconst CACHE_READ_MULTIPLIER = 0.1;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/analytics/session-analytics-db.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Session Analytics Db\n// ───────────────────────────────────────────────────────────────\n// Reader-owned normalized analytics store for replaying Stop-hook\n// producer metadata into queryable session and turn tables.\n\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { parseTranscriptTurns, type TranscriptTurn } from '../../hooks/claude/claude-transcript.js';\nimport type { HookState } from '../../hooks/claude/hook-state.js';\nimport { BetterSqliteContentionPolicy } from '../storage/ports/index.js';\n\nexport const SESSION_ANALYTICS_DB_FILENAME = 'speckit-session-analytics.db';\n\nconst CACHE_WRITE_MULTIPLIER = 1.25;\nconst CACHE_READ_MULTIPLIER = 0.1;\n\ninterface SeedModelPricingRow {\n  pricing_key: string;\n  model_family: string;\n  match_pattern: string;\n  effective_from: string;\n  effective_to: string | null;\n  prompt_price_per_million_usd: number;\n  completion_price_per_million_usd: number;\n  cache_write_price_per_million_usd: number;\n  cache_read_price_per_million_usd: number;\n  source: string;\n  notes: string;\n}\n\n// Single source of truth for family-level pricing used by all internal cost calculations.\n// Pricing is intentionally hardcoded here rather than read from a DB table because the\n// values are compile-time constants tied to the estimateCost() family rates — keeping\n// them in-process eliminates a redundant DB round-trip and a divergence surface.\nconst SEEDED_MODEL_PRICING_ROWS: SeedModelPricingRow[] = [\n  {\n    pricing_key: 'claude-opus-family-default',\n    model_family: 'opus',\n    match_pattern: 'opus',\n    effective_from: '2026-04-08T00:00:00.000Z',\n    effective_to: null,\n    prompt_price_per_million_usd: 15,\n    completion_price_per_million_usd: 75,\n    cache_write_price_per_million_usd: 15 * CACHE_WRITE_MULTIPLIER,\n    cache_read_price_per_million_usd: 15 * CACHE_READ_MULTIPLIER,\n    source: 'hooks/claude/claude-transcript.ts',\n    notes: 'Mirrors existing family-level estimateCost() prompt/output rates with cache multipliers applied.',\n  },\n  {\n    pricing_key: 'claude-sonnet-family-default',\n    model_family: 'sonnet',\n    match_pattern: 'sonnet',\n    effective_from: '2026-04-08T00:00:00.000Z',\n    effective_to: null,\n    prompt_price_per_million_usd: 3,\n    completion_price_per_million_usd: 15,\n    cache_write_price_per_million_usd: 3 * CACHE_WRITE_MULTIPLIER,\n    cache_read_price_per_million_usd: 3 * CACHE_READ_MULTIPLIER,\n    source: 'hooks/claude/claude-transcript.ts',\n    notes: 'Mirrors existing family-level estimateCost() prompt/output rates with cache multipliers applied.',\n  },\n  {\n    pricing_key: 'claude-haiku-family-default',\n    model_family: 'haiku',\n    match_pattern: 'haiku',\n    effective_from: '2026-04-08T00:00:00.000Z',\n    effective_to: null,\n    prompt_price_per_million_usd: 0.25,\n    completion_price_per_million_usd: 1.25,\n    cache_write_price_per_million_usd: 0.25 * CACHE_WRITE_MULTIPLIER,\n    cache_read_price_per_million_usd: 0.25 * CACHE_READ_MULTIPLIER,\n    source: 'hooks/claude/claude-transcript.ts',\n    notes: 'Mirrors existing family-level estimateCost() prompt/output rates with cache multipliers applied.',\n  },\n];\n\nconst SEEDED_CACHE_TIER_ROWS = [\n  {\n    cache_tier: 'cache_write',\n    source_field: 'cache_creation_input_tokens',\n    description: 'Normalized cache-write tier sourced from Claude transcript cache creation tokens.',\n  },\n  {\n    cache_tier: 'cache_read',\n    source_field: 'cache_read_input_tokens',\n    description: 'Normalized cache-read tier sourced from Claude transcript cache read tokens.',\n  },\n] as const;\n\nconst SESSION_ANALYTICS_SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS analytics_sessions (\n    claude_session_id TEXT PRIMARY KEY,\n    speckit_session_id TEXT,\n    transcript_path TEXT,\n    transcript_fingerprint TEXT,\n    transcript_size_bytes INTEGER NOT NULL DEFAULT 0,\n    transcript_modified_at TEXT,\n    last_claude_turn_at TEXT,\n    last_replay_offset INTEGER NOT NULL DEFAULT 0,\n    prompt_tokens INTEGER NOT NULL DEFAULT 0,\n    completion_tokens INTEGER NOT NULL DEFAULT 0,\n    cache_creation_input_tokens INTEGER NOT NULL DEFAULT 0,\n    cache_read_input_tokens INTEGER NOT NULL DEFAULT 0,\n    total_tokens INTEGER NOT NULL DEFAULT 0,\n    prompt_cost_usd REAL NOT NULL DEFAULT 0,\n    completion_cost_usd REAL NOT NULL DEFAULT 0,\n    cache_creation_cost_usd REAL NOT NULL DEFAULT 0,\n    cache_read_cost_usd REAL NOT NULL DEFAULT 0,\n    estimated_total_cost_usd REAL NOT NULL DEFAULT 0,\n    turn_count INTEGER NOT NULL DEFAULT 0,\n    last_spec_folder TEXT,\n    updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n  );\n\n  CREATE TABLE IF NOT EXISTS analytics_turns (","lineStart":1,"lineEnd":120,"totalLines":582,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/analytics/session-analytics-db.ts","time":{"start":1781144210895,"end":1781144210901}},"metadata":{"openai":{"itemId":"fc_00ef7a07dc6fe920016a2a1a92bc808191b0eebedd097274f3"}},"id":"prt_eb477cdca001Lx3KCOzxfWWumX","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477aa88001NMcYgqsMCxrANg"}}
{"type":"tool_use","timestamp":1781144210907,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_ZJ5QVHP9qQgyHipkfit4V5oK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/eval-db.ts","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/eval-db.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Eval Db\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Evaluation database and schema\n5: // Separate evaluation database with 5 tables for tracking\n6: // Retrieval quality metrics, ground truth, and eval results.\n7: // Node stdlib\n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: \n11: // External packages\n12: import Database from 'better-sqlite3';\n13: \n14: import { BetterSqliteContentionPolicy } from '../storage/ports/index.js';\n15: \n16: /* ───────────────────────────────────────────────────────────────\n17:    1. CONFIGURATION\n18: ──────────────────────────────────────────────────────────────── */\n19: \n20: // Follow same env-var precedence as main DB (vector-index-impl.ts)\n21: // SPEC_KIT_DB_DIR (canonical) > MEMORY_DB_DIR (legacy) > default\n22: const DEFAULT_DB_DIR: string =\n23:   process.env.SPEC_KIT_DB_DIR ||\n24:   process.env.MEMORY_DB_DIR ||\n25:   path.resolve(import.meta.dirname, '../../database');\n26: \n27: const EVAL_DB_FILENAME = 'speckit-eval.db';\n28: \n29: /* ───────────────────────────────────────────────────────────────\n30:    2. MODULE STATE (singleton pattern matching main DB)\n31: ──────────────────────────────────────────────────────────────── */\n32: \n33: let evalDb: Database.Database | null = null;\n34: let evalDbPath: string | null = null;\n35: \n36: /* ───────────────────────────────────────────────────────────────\n37:    3. SCHEMA DDL\n38: ──────────────────────────────────────────────────────────────── */\n39: \n40: const EVAL_SCHEMA_SQL = `\n41:   -- Evaluation queries with metadata\n42:   CREATE TABLE IF NOT EXISTS eval_queries (\n43:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n44:     query TEXT NOT NULL,\n45:     intent TEXT,\n46:     spec_folder TEXT,\n47:     expected_memory_ids TEXT,\n48:     difficulty TEXT DEFAULT 'medium',\n49:     category TEXT,\n50:     created_at TEXT DEFAULT (datetime('now')),\n51:     updated_at TEXT DEFAULT (datetime('now'))\n52:   );\n53: \n54:   -- Per-channel results for each query evaluation\n55:   CREATE TABLE IF NOT EXISTS eval_channel_results (\n56:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n57:     eval_run_id INTEGER NOT NULL,\n58:     query_id INTEGER NOT NULL,\n59:     channel TEXT NOT NULL,\n60:     result_memory_ids TEXT,\n61:     scores TEXT,\n62:     latency_ms REAL,\n63:     hit_count INTEGER DEFAULT 0,\n64:     created_at TEXT DEFAULT (datetime('now'))\n65:   );\n66: \n67:   -- Final fused results after RRF/fusion\n68:   CREATE TABLE IF NOT EXISTS eval_final_results (\n69:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n70:     eval_run_id INTEGER NOT NULL,\n71:     query_id INTEGER NOT NULL,\n72:     result_memory_ids TEXT,\n73:     scores TEXT,\n74:     fusion_method TEXT DEFAULT 'rrf',\n75:     latency_ms REAL,\n76:     created_at TEXT DEFAULT (datetime('now'))\n77:   );\n78: \n79:   -- Ground truth relevance judgments\n80:   CREATE TABLE IF NOT EXISTS eval_ground_truth (\n81:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n82:     query_id INTEGER NOT NULL,\n83:     memory_id INTEGER NOT NULL,\n84:     relevance INTEGER NOT NULL DEFAULT 0,\n85:     annotator TEXT DEFAULT 'auto',\n86:     notes TEXT,\n87:     created_at TEXT DEFAULT (datetime('now')),\n88:     UNIQUE(query_id, memory_id)\n89:   );\n90: \n91:   -- Metric snapshots for tracking over time\n92:   CREATE TABLE IF NOT EXISTS eval_metric_snapshots (\n93:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n94:     eval_run_id INTEGER NOT NULL,\n95:     metric_name TEXT NOT NULL,\n96:     metric_value REAL NOT NULL,\n97:     channel TEXT,\n98:     query_count INTEGER,\n99:     metadata TEXT,\n100:     created_at TEXT DEFAULT (datetime('now'))\n101:   );\n102: \n103:   CREATE INDEX IF NOT EXISTS idx_metric_snapshots_run\n104:     ON eval_metric_snapshots (eval_run_id, metric_name, created_at);\n105: \n106:   CREATE INDEX IF NOT EXISTS idx_channel_results_run\n107:     ON eval_channel_results (eval_run_id, channel, query_id);\n108: \n109:   CREATE INDEX IF NOT EXISTS idx_final_results_run\n110:     ON eval_final_results (eval_run_id, query_id);\n111: `;\n112: \n113: /* ───────────────────────────────────────────────────────────────\n114:    4. INITIALIZATION\n115: ──────────────────────────────────────────────────────────────── */\n116: \n117: /**\n118:  * Initialize the evaluation database.\n119:  * Creates the DB file in dataDir (same directory as main DB) and\n120:  * ensures all 5 eval tables exist. Safe to call multiple times (idempotent).\n\n(Showing lines 1-120 of 207. Use offset=121 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Eval Db\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Evaluation database and schema\n// Separate evaluation database with 5 tables for tracking\n// Retrieval quality metrics, ground truth, and eval results.\n// Node stdlib\nimport * as path from 'path';\nimport * as fs from 'fs';\n\n// External packages\nimport Database from 'better-sqlite3';\n\nimport { BetterSqliteContentionPolicy } from '../storage/ports/index.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Follow same env-var precedence as main DB (vector-index-impl.ts)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/eval/eval-db.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Eval Db\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Evaluation database and schema\n// Separate evaluation database with 5 tables for tracking\n// Retrieval quality metrics, ground truth, and eval results.\n// Node stdlib\nimport * as path from 'path';\nimport * as fs from 'fs';\n\n// External packages\nimport Database from 'better-sqlite3';\n\nimport { BetterSqliteContentionPolicy } from '../storage/ports/index.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Follow same env-var precedence as main DB (vector-index-impl.ts)\n// SPEC_KIT_DB_DIR (canonical) > MEMORY_DB_DIR (legacy) > default\nconst DEFAULT_DB_DIR: string =\n  process.env.SPEC_KIT_DB_DIR ||\n  process.env.MEMORY_DB_DIR ||\n  path.resolve(import.meta.dirname, '../../database');\n\nconst EVAL_DB_FILENAME = 'speckit-eval.db';\n\n/* ───────────────────────────────────────────────────────────────\n   2. MODULE STATE (singleton pattern matching main DB)\n──────────────────────────────────────────────────────────────── */\n\nlet evalDb: Database.Database | null = null;\nlet evalDbPath: string | null = null;\n\n/* ───────────────────────────────────────────────────────────────\n   3. SCHEMA DDL\n──────────────────────────────────────────────────────────────── */\n\nconst EVAL_SCHEMA_SQL = `\n  -- Evaluation queries with metadata\n  CREATE TABLE IF NOT EXISTS eval_queries (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    query TEXT NOT NULL,\n    intent TEXT,\n    spec_folder TEXT,\n    expected_memory_ids TEXT,\n    difficulty TEXT DEFAULT 'medium',\n    category TEXT,\n    created_at TEXT DEFAULT (datetime('now')),\n    updated_at TEXT DEFAULT (datetime('now'))\n  );\n\n  -- Per-channel results for each query evaluation\n  CREATE TABLE IF NOT EXISTS eval_channel_results (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    eval_run_id INTEGER NOT NULL,\n    query_id INTEGER NOT NULL,\n    channel TEXT NOT NULL,\n    result_memory_ids TEXT,\n    scores TEXT,\n    latency_ms REAL,\n    hit_count INTEGER DEFAULT 0,\n    created_at TEXT DEFAULT (datetime('now'))\n  );\n\n  -- Final fused results after RRF/fusion\n  CREATE TABLE IF NOT EXISTS eval_final_results (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    eval_run_id INTEGER NOT NULL,\n    query_id INTEGER NOT NULL,\n    result_memory_ids TEXT,\n    scores TEXT,\n    fusion_method TEXT DEFAULT 'rrf',\n    latency_ms REAL,\n    created_at TEXT DEFAULT (datetime('now'))\n  );\n\n  -- Ground truth relevance judgments\n  CREATE TABLE IF NOT EXISTS eval_ground_truth (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    query_id INTEGER NOT NULL,\n    memory_id INTEGER NOT NULL,\n    relevance INTEGER NOT NULL DEFAULT 0,\n    annotator TEXT DEFAULT 'auto',\n    notes TEXT,\n    created_at TEXT DEFAULT (datetime('now')),\n    UNIQUE(query_id, memory_id)\n  );\n\n  -- Metric snapshots for tracking over time\n  CREATE TABLE IF NOT EXISTS eval_metric_snapshots (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    eval_run_id INTEGER NOT NULL,\n    metric_name TEXT NOT NULL,\n    metric_value REAL NOT NULL,\n    channel TEXT,\n    query_count INTEGER,\n    metadata TEXT,\n    created_at TEXT DEFAULT (datetime('now'))\n  );\n\n  CREATE INDEX IF NOT EXISTS idx_metric_snapshots_run\n    ON eval_metric_snapshots (eval_run_id, metric_name, created_at);\n\n  CREATE INDEX IF NOT EXISTS idx_channel_results_run\n    ON eval_channel_results (eval_run_id, channel, query_id);\n\n  CREATE INDEX IF NOT EXISTS idx_final_results_run\n    ON eval_final_results (eval_run_id, query_id);\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   4. INITIALIZATION\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Initialize the evaluation database.\n * Creates the DB file in dataDir (same directory as main DB) and\n * ensures all 5 eval tables exist. Safe to call multiple times (idempotent).","lineStart":1,"lineEnd":120,"totalLines":207,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/eval/eval-db.ts","time":{"start":1781144210904,"end":1781144210906}},"metadata":{"openai":{"itemId":"fc_00ef7a07dc6fe920016a2a1a92bc8481919eb668af175b18fa"}},"id":"prt_eb477cdd0001H7d6J839HjCnBH","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb477aa88001NMcYgqsMCxrANg"}}
