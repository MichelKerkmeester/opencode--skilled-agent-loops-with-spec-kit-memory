  "color": {
    "gloss-black": {
      "$value": "#17150e",
      "$type": "color",
      "$description": "Gloss Black — Primary text, dark card surfaces, footer background, pill button fill — a warm near-black that reads softer than pure #000 and makes the large display type feel printed rather than digital; 1.5px borders and dividers — uses the same warm-black as text to keep all structural lines tonally unified"
    },
    "gloss-white": {
      "$value": "#f0f7f6",
      "$type": "color",
      "$description": "Gloss White — Page tint sections, card surfaces, badge fills, button text on dark — a barely-green-tinted off-white that warms the interface and creates gentle contrast bands against pure white"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Primary page canvas, card surface, dark-button text, nav link color — used wherever maximum contrast is needed without any color temperature"
