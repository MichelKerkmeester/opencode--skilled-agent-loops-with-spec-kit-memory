{"type":"tool_use","timestamp":1781763369472,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"grep","callID":"call_fobhraeCTL0fI6XiPdddzJmc","state":{"status":"completed","input":{"pattern":"idempot|nearDuplicate|appendOnly|retention|deleteAfter|governance|transaction|indexMemoryDeferred|indexMemory\\(","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","include":"memory-save.ts"},"output":"Found 83 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:\n  Line 33: import * as transactionManager from '../lib/storage/transaction-manager.js';\n\n  Line 72: } from '../lib/governance/scope-governance.js';\n\n  Line 184: } from '../lib/storage/idempotency-receipts.js';\n\n  Line 438:   // Resolve to the canonical path before applying memory-index governance.\n\n  Line 458:         '[memory-save] governance_audit insert failed for tier downgrade:',\n\n  Line 2323:     // NOTE: Content-hash dedup (C5-1) moved inside BEGIN IMMEDIATE transaction\n\n  Line 2474:           const finalizeChunkedPeTx = database.transaction(() => {\n\n  Line 2540:     // A4 FIX: Wrap dedup-check + insert in a single transaction for DB-level\n\n  Line 2541:     // atomicity. Uses database.transaction() so inner transaction() calls in\n\n  Line 2543:     // of failing with \"cannot start a transaction within a transaction\".\n\n  Line 2544:     // withSpecFolderLock handles in-process serialization; this transaction\n\n  Line 2548:     // C5-1: Content-hash dedup check BEFORE the write transaction — reads are\n\n  Line 2549:     // safe outside the transaction and this avoids an early-return inside the\n\n  Line 2550:     // transaction callback (which would COMMIT an empty tx unnecessarily).\n\n  Line 2565:     const writeTransaction = database.transaction((): number => {\n\n  Line 2578:           const transactionalAction = determineAction(topCandidate.similarity);\n\n  Line 2579:           if (transactionalAction !== 'complement') {\n\n  Line 2584:                 `Transactional reconsolidation blocked create after ${transactionalAction} candidate #${topCandidate.id} appeared before commit.`,\n\n  Line 2587:                 kind: transactionalAction,\n\n  Line 2663:       // the same transaction, so a creation failure rolls back both operations.\n\n  Line 2666:         // C5-3: Supersede failure should abort the transaction\n\n  Line 2748:     // transaction (markEnrichmentPending), so a crash before the background run completes is\n\n  Line 2816:   // Validated governance decision threaded from the bulk scan/ingest paths so\n\n  Line 2817:   // their indexed rows carry the same provenance/retention/scope metadata the\n\n  Line 2819:   governance?: GovernanceDecision;\n\n  Line 2844:     governance,\n\n  Line 2861:   // When a governance decision is threaded in (bulk scan/ingest), derive the\n\n  Line 2863:   // how the direct save path seeds saveScope from governanceDecision.normalized.\n\n  Line 2864:   const effectiveScope: MemoryScopeMatch = governance\n\n  Line 2866:         tenantId: governance.normalized.tenantId ?? null,\n\n  Line 2867:         userId: governance.normalized.userId ?? null,\n\n  Line 2868:         agentId: governance.normalized.agentId ?? null,\n\n  Line 2869:         sessionId: governance.normalized.sessionId ?? null,\n\n  Line 2872:   const effectiveProvenance: WriteProvenanceContext | undefined = provenance ?? (governance || indexingOrigin === 'scan'\n\n  Line 2874:         provenanceSource: governance?.normalized.provenanceSource || (indexingOrigin === 'scan' ? 'memory_index_scan' : undefined),\n\n  Line 2875:         provenanceActor: governance?.normalized.provenanceActor || (indexingOrigin === 'scan' ? 'system-scan' : undefined),\n\n  Line 2893:   // Apply provenance/retention/deleteAfter metadata post-insert, mirroring the\n\n  Line 2896:   if (governance && typeof result.id === 'number' && result.id > 0\n\n  Line 2898:     applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governance));\n\n  Line 2934:  * enrichment-pending in the commit transaction and are recovered by the backfill path on next boot.\n\n  Line 2944: // transaction, so the backfill path re-enriches it. The counters below make a backed-up or failing\n\n  Line 2982:  * - caps concurrency. The row was marked enrichment-pending inside the commit transaction, so a\n\n  Line 3052:     // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n\n  Line 3063:   // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n\n  Line 3162:     retentionPolicy,\n\n  Line 3163:     deleteAfter,\n\n  Line 3238:   const governanceDecision = validateGovernedIngest({\n\n  Line 3246:     retentionPolicy,\n\n  Line 3247:     deleteAfter,\n\n  Line 3250:   if (!governanceDecision.allowed) {\n\n  Line 3258:       reason: governanceDecision.reason ?? 'governance_rejected',\n\n  Line 3259:       metadata: { issues: governanceDecision.issues },\n\n  Line 3261:     // Surface the governance rejection with its own code + issue list instead of a bare\n\n  Line 3265:       error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n\n  Line 3267:       details: { requestId, issues: governanceDecision.issues },\n\n  Line 3384:     tenantId: governanceDecision.normalized.tenantId,\n\n  Line 3385:     userId: governanceDecision.normalized.userId ?? null,\n\n  Line 3386:     agentId: governanceDecision.normalized.agentId ?? null,\n\n  Line 3387:     sessionId: governanceDecision.normalized.sessionId,\n\n  Line 3389:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  Line 3551:       // below point at this same idempotencySemantics value, so payloadHash\n\n  Line 3561:       const idempotencySemantics = {\n\n  Line 3576:         requestFingerprint: idempotencySemantics,\n\n  Line 3577:         payload: idempotencySemantics,\n\n  Line 3579:       idempotencyKey = lookup.key;\n\n  Line 3640:           code: 'idempotency_key_conflict',\n\n  Line 3650:       console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n\n  Line 3651:       idempotencyKey = null;\n\n  Line 3731:     // Wrap governance metadata in a transaction with rollback on failure.\n\n  Line 3732:     // If governance application fails, delete the orphaned memory row to prevent\n\n  Line 3733:     // persisted rows without tenant/session/retention metadata.\n\n  Line 3734:     const applyGovernanceTx = database.transaction(() => {\n\n  Line 3735:       applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n\n  Line 3745:         metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n\n  Line 3775:   if (idempotencyKey && shouldStoreMemorySaveReceipt(result, response)) {\n\n  Line 3777:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n\n  Line 3780:         // first winner's response so this mutating loser returns the idempotent result\n\n  Line 3782:         const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n\n  Line 3791:           return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n\n  Line 3796:       console.warn(`[memory-save] idempotency receipt store failed; continuing without replay receipt: ${message}`);\n\n  Line 3955:     getPendingPath: (currentFilePath) => `${transactionManager.getPendingPath(currentFilePath)}.${randomUUID().slice(0, 8)}`,\n\n  Line 4050: /** Return transaction manager metrics for atomicity monitoring */\n\n  Line 4052:   return transactionManager.getMetrics();\n","metadata":{"matches":83,"truncated":false},"title":"idempot|nearDuplicate|appendOnly|retention|deleteAfter|governance|transaction|indexMemoryDeferred|indexMemory\\(","time":{"start":1781763369459,"end":1781763369470}},"metadata":{"openai":{"itemId":"fc_03552064e9631f38016a338d2955e48191970f5b53cb25904c"}},"id":"prt_ed95f69ef001iCROQNHNypeD62","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f4037001ddVMOi7HLOCXJz"}}
{"type":"tool_use","timestamp":1781763369581,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_9RvC0OvAS2k3JSWreuoKFdPA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n\n(Showing lines 1-260 of 344. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;","lineStart":1,"lineEnd":260,"totalLines":344,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781763369567,"end":1781763369579}},"metadata":{"openai":{"itemId":"fc_03552064e9631f38016a338d2955ec8191b9fb085028a14c2c"}},"id":"prt_ed95f69f6001qUYm2159D1B0ZO","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f4037001ddVMOi7HLOCXJz"}}
{"type":"tool_use","timestamp":1781763369589,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_ZpzraDJwPCDjGPrCprcfBtSg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Update Handler\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { randomUUID } from 'node:crypto';\n10: import { checkDatabaseUpdated } from '../core/index.js';\n11: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n12: import * as vectorIndex from '../lib/search/vector-index.js';\n13: import type { UpdateMemoryParams } from '../lib/search/vector-index.js';\n14: import * as embeddings from '../lib/providers/embeddings.js';\n15: import * as bm25Index from '../lib/search/bm25-index.js';\n16: import { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\n17: import { MemoryError, ErrorCodes } from '../lib/errors.js';\n18: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n19: import { runInTransaction } from '../lib/storage/transaction-manager.js';\n20: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n21: import {\n22:   buildGovernanceLogicalKey,\n23:   recordTierDowngradeAudit,\n24: } from '../lib/governance/scope-governance.js';\n25: import { isConstitutionalPath } from '../lib/utils/index-scope.js';\n26: import { scrubSecrets, SecretScrubberError } from '../lib/parsing/secret-scrubber.js';\n27: import { toErrorMessage } from '../utils/index.js';\n28: import {\n29:   deleteIdempotencyReceiptByKey,\n30:   extractMemoryIdFromResponse,\n31:   isMemoryIdempotencyEnabled,\n32:   lookupIdempotencyReceipt,\n33:   lookupIdempotencyReceiptByKey,\n34:   markResponseWithReceiptStoreConflict,\n35:   storeIdempotencyReceipt,\n36:   type IdempotencyReceiptKey,\n37: } from '../lib/storage/idempotency-receipts.js';\n38: \n39: import { recordHistory } from '../lib/storage/history.js';\n40: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n41: import { runPostMutationHooks } from './mutation-hooks.js';\n42: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n43: import {\n44:   deriveSourceKindFromContext,\n45:   normalizeSourceKind,\n46:   persistProvenanceMetadata,\n47:   persistSourceKind,\n48:   type SourceKind,\n49: } from '../lib/storage/write-provenance.js';\n50: \n51: import type { MCPResponse } from './types.js';\n52: import type { UpdateArgs } from './memory-crud-types.js';\n53: \n54: // Feature catalog: Memory metadata update (memory_update)\n55: // Feature catalog: Validation feedback (memory_validate)\n56: // Feature catalog: Transaction wrappers on mutation handlers\n57: // Feature catalog: Per-memory history log\n58: \n59: \n60: /* ───────────────────────────────────────────────────────────────\n61:    CORE LOGIC\n62: ──────────────────────────────────────────────────────────────── */\n63: \n64: const PROTECTED_AUTOMATED_UPDATE_FIELDS = new Set(['title', 'triggerPhrases', 'importanceTier']);\n65: const SKIPPED_MANUAL_PROTECTION_HINT = 'skipped to protect manual data';\n66: \n67: interface ProvenanceGuardResult {\n68:   updateParams: UpdateMemoryParams;\n69:   requestedFields: string[];\n70:   persistedFields: string[];\n71:   skippedFields: string[];\n72:   sourceKind: SourceKind;\n73:   storedSourceKind: SourceKind;\n74:   hint: string | null;\n75: }\n76: \n77: function getInternalProvenanceContext(args: UpdateArgs): Record<string, unknown> {\n78:   const rawArgs = args as unknown as Record<string, unknown>;\n79:   const context = rawArgs.__provenanceContext;\n80:   return context && typeof context === 'object' && !Array.isArray(context)\n81:     ? context as Record<string, unknown>\n82:     : {};\n83: }\n84: \n85: function isProtectedExistingRow(existing: Record<string, unknown>): boolean {\n86:   const existingSourceKind = normalizeSourceKind(existing.source_kind);\n87:   const importanceTier = typeof existing.importance_tier === 'string' ? existing.importance_tier : null;\n88:   const isPinned = existing.is_pinned === true || existing.is_pinned === 1;\n89:   const pathCandidate = [existing.canonical_file_path, existing.file_path]\n90:     .find((value) => typeof value === 'string' && value.length > 0);\n91:   const rowPath = typeof pathCandidate === 'string' ? pathCandidate : null;\n92:   return existingSourceKind === null\n93:     || existingSourceKind === 'human'\n94:     || importanceTier === 'constitutional'\n95:     || importanceTier === 'critical'\n96:     || isPinned\n97:     || (rowPath !== null && isConstitutionalPath(rowPath));\n98: }\n99: \n100: function buildGuardedUpdateParams(\n101:   args: UpdateArgs,\n102:   existing: Record<string, unknown>,\n103: ): ProvenanceGuardResult {\n104:   const internalContext = getInternalProvenanceContext(args);\n105:   const sourceKind = deriveSourceKindFromContext({\n106:     provenanceSource: internalContext.provenanceSource ?? internalContext.provenance_source,\n107:     provenanceActor: internalContext.provenanceActor ?? internalContext.provenance_actor,\n108:     tool: internalContext.tool,\n109:   });\n110:   const existingSourceKind = normalizeSourceKind(existing.source_kind);\n111:   const automated = sourceKind !== 'human';\n112:   const protectExisting = automated && isProtectedExistingRow(existing);\n113:   const updateParams: UpdateMemoryParams = { id: args.id };\n114:   const requestedFields: string[] = [];\n115:   const persistedFields: string[] = [];\n116:   const skippedFields: string[] = [];\n117: \n118:   const maybeAssign = <K extends keyof UpdateMemoryParams>(field: K, value: UpdateMemoryParams[K]): void => {\n119:     if (value === undefined) {\n120:       return;\n121:     }\n122:     requestedFields.push(field);\n123:     if (protectExisting && PROTECTED_AUTOMATED_UPDATE_FIELDS.has(field)) {\n124:       skippedFields.push(field);\n125:       return;\n126:     }\n127:     updateParams[field] = value;\n128:     persistedFields.push(field);\n129:   };\n130: \n131:   maybeAssign('title', args.title);\n132:   maybeAssign('triggerPhrases', args.triggerPhrases);\n133:   maybeAssign('importanceWeight', args.importanceWeight);\n134:   maybeAssign('importanceTier', args.importanceTier);\n135: \n136:   const storedSourceKind = sourceKind === 'human'\n137:     ? 'human'\n138:     : (protectExisting ? (existingSourceKind ?? 'human') : sourceKind);\n139: \n140:   return {\n141:     updateParams,\n142:     requestedFields,\n143:     persistedFields,\n144:     skippedFields,\n145:     sourceKind,\n146:     storedSourceKind,\n147:     hint: skippedFields.length > 0 ? SKIPPED_MANUAL_PROTECTION_HINT : null,\n148:   };\n149: }\n150: \n151: /** Handle memory_update tool -- updates metadata fields and optionally regenerates embeddings. */\n152: async function handleMemoryUpdate(args: UpdateArgs): Promise<MCPResponse> {\n153:   await ensureMemoryRuntimeInitialized('handler:memory_update');\n154:   // Generate requestId for incident correlation in error responses\n155:   const requestId = randomUUID();\n156:   await checkDatabaseUpdated();\n157: \n158:   const {\n159:     id,\n160:     title: rawTitle,\n161:     triggerPhrases: rawTriggerPhrases,\n162:     importanceWeight,\n163:     importanceTier,\n164:     allowPartialUpdate = false,\n165:   } = args;\n166: \n167:   if (typeof id !== 'number') {\n168:     throw new MemoryError(ErrorCodes.MISSING_REQUIRED_PARAM, 'id is required', { param: 'id' });\n169:   }\n170: \n171:   // Title and trigger phrases are persisted/indexed fields written outside\n172:   // the parse path, so they get the same pre-index secret redaction. A\n173:   // scrubber failure refuses this write (fail-closed) rather than persisting\n174:   // potentially unscrubbed text.\n175:   let title = rawTitle;\n176:   let triggerPhrases = rawTriggerPhrases;\n177:   try {\n178:     if (typeof title === 'string') {\n179:       title = scrubSecrets(title);\n180:     }\n181:     if (Array.isArray(triggerPhrases)) {\n182:       triggerPhrases = triggerPhrases.map((phrase) => (\n183:         typeof phrase === 'string' ? scrubSecrets(phrase) : phrase\n184:       ));\n185:     }\n186:   } catch (error: unknown) {\n187:     if (error instanceof SecretScrubberError) {\n188:       throw new MemoryError(\n189:         ErrorCodes.INVALID_PARAMETER,\n190:         `Update refused: ${error.message}`,\n191:         { param: 'title/triggerPhrases', memoryId: id },\n192:       );\n193:     }\n194:     throw error;\n195:   }\n196: \n197:   if (importanceWeight !== undefined && (typeof importanceWeight !== 'number' || importanceWeight < 0 || importanceWeight > 1)) {\n198:     throw new MemoryError(\n199:       ErrorCodes.INVALID_PARAMETER,\n200:       'importanceWeight must be a number between 0 and 1',\n201:       { param: 'importanceWeight', value: importanceWeight }\n202:     );\n203:   }\n204: \n205:   if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n206:     throw new MemoryError(\n207:       ErrorCodes.INVALID_PARAMETER,\n208:       `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n209:       { param: 'importanceTier', value: importanceTier }\n210:     );\n211:   }\n212: \n213:   const existing = vectorIndex.getMemory(id);\n214:   if (!existing) {\n215:     throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n216:   }\n217: \n218:   const database = vectorIndex.getDb();\n219:   const priorSnapshot = getMemoryHashSnapshot(database, id);\n220: \n221:   const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n222:   const updateParams = guard.updateParams;\n223:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n224: \n225:   if (database && isMemoryIdempotencyEnabled()) {\n226:     try {\n227:       const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n228:       const logicalMutation = {\n229:         id,\n230:         title: updateParams.title ?? null,\n231:         triggerPhrases: updateParams.triggerPhrases ?? null,\n232:         importanceWeight: updateParams.importanceWeight ?? null,\n233:         importanceTier: updateParams.importanceTier ?? null,\n234:         contentHash,\n235:       };\n236:       const lookup = lookupIdempotencyReceipt(database, {\n237:         operation: 'memory_update',\n238:         contentHash,\n239:         requestFingerprint: {\n240:           id,\n241:           contentHash,\n242:           logicalMutation,\n243:         },\n244:         // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n245:         // payloadHash always equals requestFingerprintHash and the receiptKey is\n246:         // derived from it. Consequence: distinct logical updates always produce\n247:         // distinct keys, so the same-key/different-payload 'conflict' status can\n248:         // never fire from this caller; the conflict branch below is fail-safe\n249:         // defense-in-depth, not active protection. To make conflicts detectable\n250:         // the payload would have to carry MORE than the key material (e.g.\n251:         // execution-mode flags like allowPartialUpdate); it deliberately does\n252:         // not, so a benign flag flip cannot become a false hard conflict.\n253:         payload: {\n254:           id,\n255:           contentHash,\n256:           logicalMutation,\n257:         },\n258:       });\n259:       idempotencyKey = lookup.key;\n260:       if (lookup.status === 'replay') {\n261:         // A receipt is a replay cache, not proof the cached response still\n262:         // describes the live row. Re-read this id's current content_hash and\n263:         // honor the replay ONLY when it still matches the receipt's content_hash\n264:         // AND the cached response still reports this same id; an A->B->A content\n265:         // revert leaves the receipt for A intact while the row moved on, and a\n266:         // delete-then-recreate can leave the cached response naming a stale id,\n267:         // so replaying it would diverge from the row.\n268:         const liveRow = database\n269:           .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n270:           .get(id) as { content_hash: string | null } | undefined;\n271:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n272:         if (\n273:           liveRow\n274:           && liveRow.content_hash === lookup.key.contentHash\n275:           && (replayMemoryId == null || replayMemoryId === id)\n276:         ) {\n277:           return lookup.response;\n278:         }\n279:         // Stale receipt for this attempt: drop the cache entry so the live\n280:         // update stores its current response (the post-write store uses\n281:         // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n282:         // stale receipt), then fall through to the normal update path.\n283:         deleteIdempotencyReceiptByKey(database, lookup.key);\n284:       } else if (lookup.status === 'conflict') {\n285:         // Unreachable from this caller: payload is a structural copy of\n286:         // requestFingerprint (above), so a key match implies a payload match and\n287:         // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n288:         // case the key material and payload ever diverge.\n289:         return createMCPErrorResponse({\n290:           tool: 'memory_update',\n291:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n292:           code: 'idempotency_key_conflict',\n293:           details: { requestId, receiptKey: lookup.key.receiptKey, id },\n294:           recovery: {\n295:             hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n296:             severity: 'warning',\n297:           },\n298:         });\n299:       }\n300:     } catch (error: unknown) {\n301:       console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n302:       idempotencyKey = null;\n303:     }\n304:   }\n305: \n306:   let embeddingRegenerated = false;\n307:   let embeddingMarkedForReindex = false;\n308:   let embeddingStatusNeedsPendingWrite = false;\n309:   let mutationLedgerWarning: string | null = null;\n310: \n311:   if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n312:     console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n313:     let newEmbedding: Float32Array | null = null;\n314: \n315:     try {\n316:       // Embed title + content_text, not title alone.\n317:       // This produces better semantic embeddings that capture the full memory context.\n318:       const contentText = existing.content_text || '';\n319:       const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n320:       newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n\n(Showing lines 1-320 of 614. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Update Handler\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { UpdateMemoryParams } from '../lib/search/vector-index.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\nimport { MemoryError, ErrorCodes } from '../lib/errors.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport { runInTransaction } from '../lib/storage/transaction-manager.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Update Handler\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { UpdateMemoryParams } from '../lib/search/vector-index.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport { VALID_TIERS, isValidTier } from '../lib/scoring/importance-tiers.js';\nimport { MemoryError, ErrorCodes } from '../lib/errors.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport { runInTransaction } from '../lib/storage/transaction-manager.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport {\n  buildGovernanceLogicalKey,\n  recordTierDowngradeAudit,\n} from '../lib/governance/scope-governance.js';\nimport { isConstitutionalPath } from '../lib/utils/index-scope.js';\nimport { scrubSecrets, SecretScrubberError } from '../lib/parsing/secret-scrubber.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport {\n  deleteIdempotencyReceiptByKey,\n  extractMemoryIdFromResponse,\n  isMemoryIdempotencyEnabled,\n  lookupIdempotencyReceipt,\n  lookupIdempotencyReceiptByKey,\n  markResponseWithReceiptStoreConflict,\n  storeIdempotencyReceipt,\n  type IdempotencyReceiptKey,\n} from '../lib/storage/idempotency-receipts.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport {\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  persistProvenanceMetadata,\n  persistSourceKind,\n  type SourceKind,\n} from '../lib/storage/write-provenance.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { UpdateArgs } from './memory-crud-types.js';\n\n// Feature catalog: Memory metadata update (memory_update)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nconst PROTECTED_AUTOMATED_UPDATE_FIELDS = new Set(['title', 'triggerPhrases', 'importanceTier']);\nconst SKIPPED_MANUAL_PROTECTION_HINT = 'skipped to protect manual data';\n\ninterface ProvenanceGuardResult {\n  updateParams: UpdateMemoryParams;\n  requestedFields: string[];\n  persistedFields: string[];\n  skippedFields: string[];\n  sourceKind: SourceKind;\n  storedSourceKind: SourceKind;\n  hint: string | null;\n}\n\nfunction getInternalProvenanceContext(args: UpdateArgs): Record<string, unknown> {\n  const rawArgs = args as unknown as Record<string, unknown>;\n  const context = rawArgs.__provenanceContext;\n  return context && typeof context === 'object' && !Array.isArray(context)\n    ? context as Record<string, unknown>\n    : {};\n}\n\nfunction isProtectedExistingRow(existing: Record<string, unknown>): boolean {\n  const existingSourceKind = normalizeSourceKind(existing.source_kind);\n  const importanceTier = typeof existing.importance_tier === 'string' ? existing.importance_tier : null;\n  const isPinned = existing.is_pinned === true || existing.is_pinned === 1;\n  const pathCandidate = [existing.canonical_file_path, existing.file_path]\n    .find((value) => typeof value === 'string' && value.length > 0);\n  const rowPath = typeof pathCandidate === 'string' ? pathCandidate : null;\n  return existingSourceKind === null\n    || existingSourceKind === 'human'\n    || importanceTier === 'constitutional'\n    || importanceTier === 'critical'\n    || isPinned\n    || (rowPath !== null && isConstitutionalPath(rowPath));\n}\n\nfunction buildGuardedUpdateParams(\n  args: UpdateArgs,\n  existing: Record<string, unknown>,\n): ProvenanceGuardResult {\n  const internalContext = getInternalProvenanceContext(args);\n  const sourceKind = deriveSourceKindFromContext({\n    provenanceSource: internalContext.provenanceSource ?? internalContext.provenance_source,\n    provenanceActor: internalContext.provenanceActor ?? internalContext.provenance_actor,\n    tool: internalContext.tool,\n  });\n  const existingSourceKind = normalizeSourceKind(existing.source_kind);\n  const automated = sourceKind !== 'human';\n  const protectExisting = automated && isProtectedExistingRow(existing);\n  const updateParams: UpdateMemoryParams = { id: args.id };\n  const requestedFields: string[] = [];\n  const persistedFields: string[] = [];\n  const skippedFields: string[] = [];\n\n  const maybeAssign = <K extends keyof UpdateMemoryParams>(field: K, value: UpdateMemoryParams[K]): void => {\n    if (value === undefined) {\n      return;\n    }\n    requestedFields.push(field);\n    if (protectExisting && PROTECTED_AUTOMATED_UPDATE_FIELDS.has(field)) {\n      skippedFields.push(field);\n      return;\n    }\n    updateParams[field] = value;\n    persistedFields.push(field);\n  };\n\n  maybeAssign('title', args.title);\n  maybeAssign('triggerPhrases', args.triggerPhrases);\n  maybeAssign('importanceWeight', args.importanceWeight);\n  maybeAssign('importanceTier', args.importanceTier);\n\n  const storedSourceKind = sourceKind === 'human'\n    ? 'human'\n    : (protectExisting ? (existingSourceKind ?? 'human') : sourceKind);\n\n  return {\n    updateParams,\n    requestedFields,\n    persistedFields,\n    skippedFields,\n    sourceKind,\n    storedSourceKind,\n    hint: skippedFields.length > 0 ? SKIPPED_MANUAL_PROTECTION_HINT : null,\n  };\n}\n\n/** Handle memory_update tool -- updates metadata fields and optionally regenerates embeddings. */\nasync function handleMemoryUpdate(args: UpdateArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_update');\n  // Generate requestId for incident correlation in error responses\n  const requestId = randomUUID();\n  await checkDatabaseUpdated();\n\n  const {\n    id,\n    title: rawTitle,\n    triggerPhrases: rawTriggerPhrases,\n    importanceWeight,\n    importanceTier,\n    allowPartialUpdate = false,\n  } = args;\n\n  if (typeof id !== 'number') {\n    throw new MemoryError(ErrorCodes.MISSING_REQUIRED_PARAM, 'id is required', { param: 'id' });\n  }\n\n  // Title and trigger phrases are persisted/indexed fields written outside\n  // the parse path, so they get the same pre-index secret redaction. A\n  // scrubber failure refuses this write (fail-closed) rather than persisting\n  // potentially unscrubbed text.\n  let title = rawTitle;\n  let triggerPhrases = rawTriggerPhrases;\n  try {\n    if (typeof title === 'string') {\n      title = scrubSecrets(title);\n    }\n    if (Array.isArray(triggerPhrases)) {\n      triggerPhrases = triggerPhrases.map((phrase) => (\n        typeof phrase === 'string' ? scrubSecrets(phrase) : phrase\n      ));\n    }\n  } catch (error: unknown) {\n    if (error instanceof SecretScrubberError) {\n      throw new MemoryError(\n        ErrorCodes.INVALID_PARAMETER,\n        `Update refused: ${error.message}`,\n        { param: 'title/triggerPhrases', memoryId: id },\n      );\n    }\n    throw error;\n  }\n\n  if (importanceWeight !== undefined && (typeof importanceWeight !== 'number' || importanceWeight < 0 || importanceWeight > 1)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      'importanceWeight must be a number between 0 and 1',\n      { param: 'importanceWeight', value: importanceWeight }\n    );\n  }\n\n  if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n      { param: 'importanceTier', value: importanceTier }\n    );\n  }\n\n  const existing = vectorIndex.getMemory(id);\n  if (!existing) {\n    throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n  }\n\n  const database = vectorIndex.getDb();\n  const priorSnapshot = getMemoryHashSnapshot(database, id);\n\n  const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n  const updateParams = guard.updateParams;\n  let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  if (database && isMemoryIdempotencyEnabled()) {\n    try {\n      const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n      const logicalMutation = {\n        id,\n        title: updateParams.title ?? null,\n        triggerPhrases: updateParams.triggerPhrases ?? null,\n        importanceWeight: updateParams.importanceWeight ?? null,\n        importanceTier: updateParams.importanceTier ?? null,\n        contentHash,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_update',\n        contentHash,\n        requestFingerprint: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n        // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n        // payloadHash always equals requestFingerprintHash and the receiptKey is\n        // derived from it. Consequence: distinct logical updates always produce\n        // distinct keys, so the same-key/different-payload 'conflict' status can\n        // never fire from this caller; the conflict branch below is fail-safe\n        // defense-in-depth, not active protection. To make conflicts detectable\n        // the payload would have to carry MORE than the key material (e.g.\n        // execution-mode flags like allowPartialUpdate); it deliberately does\n        // not, so a benign flag flip cannot become a false hard conflict.\n        payload: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live row. Re-read this id's current content_hash and\n        // honor the replay ONLY when it still matches the receipt's content_hash\n        // AND the cached response still reports this same id; an A->B->A content\n        // revert leaves the receipt for A intact while the row moved on, and a\n        // delete-then-recreate can leave the cached response naming a stale id,\n        // so replaying it would diverge from the row.\n        const liveRow = database\n          .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n          .get(id) as { content_hash: string | null } | undefined;\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          liveRow\n          && liveRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || replayMemoryId === id)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the live\n        // update stores its current response (the post-write store uses\n        // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n        // stale receipt), then fall through to the normal update path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload is a structural copy of\n        // requestFingerprint (above), so a key match implies a payload match and\n        // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n        // case the key material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_update',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey, id },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n      idempotencyKey = null;\n    }\n  }\n\n  let embeddingRegenerated = false;\n  let embeddingMarkedForReindex = false;\n  let embeddingStatusNeedsPendingWrite = false;\n  let mutationLedgerWarning: string | null = null;\n\n  if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n    console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n    let newEmbedding: Float32Array | null = null;\n\n    try {\n      // Embed title + content_text, not title alone.\n      // This produces better semantic embeddings that capture the full memory context.\n      const contentText = existing.content_text || '';\n      const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n      newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);","lineStart":1,"lineEnd":320,"totalLines":614,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","time":{"start":1781763369574,"end":1781763369588}},"metadata":{"openai":{"itemId":"fc_03552064e9631f38016a338d2955f88191b832b9dea1b0255f"}},"id":"prt_ed95f6a62001C1gbY09Ixavdn5","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95f4037001ddVMOi7HLOCXJz"}}
