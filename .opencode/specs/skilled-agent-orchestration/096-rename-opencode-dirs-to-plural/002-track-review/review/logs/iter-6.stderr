+- `.opencode/skills/system-spec-kit/shared/review-research-paths.cjs:200`
+- `.opencode/skills/deep-review/scripts/reduce-state.cjs:1172`
+- `.opencode/skills/deep-review/scripts/reduce-state.cjs:1244`
