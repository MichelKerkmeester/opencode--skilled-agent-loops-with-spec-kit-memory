    77	function main() {
    78	  const args = parseArgs(process.argv.slice(2));
    79	  if (!args.profile || !args['outputs-dir']) {
    80	    process.stderr.write('Usage: node materialize-benchmark-fixtures.cjs --profile <path> --outputs-dir <path>\n');
    81	    process.exit(2);
    82	  }
    83	
    84	  // F-P1-4b: resolve --profile as a direct path OR a profile id under --profiles-dir,
    85	  // matching run-benchmark.cjs loadProfile so a profile-by-id does not fail here before run-benchmark.
    86	  const profilesDir = args['profiles-dir'] || DEFAULT_PROFILES_DIR;
    87	  const directPath = path.resolve(process.cwd(), args.profile);
    88	  const profilePath = fs.existsSync(directPath) ? directPath : path.join(profilesDir, `${args.profile}.json`);
    89	  if (!fs.existsSync(profilePath)) {
    90	    process.stderr.write(`Benchmark profile not found (tried direct path and id under ${profilesDir}): ${args.profile}\n`);
    91	    process.exit(1);
    92	  }
    93	
    94	  const profile = readJson(profilePath);
    95	  const fixtureDir = resolveInput(profile.fixtureDir || profile.benchmark?.fixtureDir, path.dirname(profilePath));
    96	  const fixtureRefs = profile.fixtures || profile.benchmark?.fixtures || [];
    97	  const outputsDir = path.resolve(process.cwd(), args['outputs-dir']);
    98	
    99	  // F017-P1-01: load + validate every fixture (existence AND id safety) BEFORE
   100	  // creating outputsDir or writing any file, so a single hostile id aborts with
   101	  // a non-zero exit and writes nothing inside OR outside outputsDir.
   102	  const materialized = [];
   103	  for (const fixtureRef of fixtureRefs) {
   104	    const filePath = fixturePathFor(fixtureRef, fixtureDir);
   105	    if (!fs.existsSync(filePath)) {
   106	      process.stderr.write(`Benchmark fixture not found: ${filePath}\n`);
   107	      process.exit(1);
   108	    }
   109	    const fixture = readJson(filePath);
   110	    try {
   111	      assertSafeFixtureId(fixture.id);
   112	    } catch (error) {
   113	      process.stderr.write(`${error.message}\n`);
   114	      process.exit(1);
   115	    }
   116	    materialized.push(fixture);
   117	  }
   118	
   119	  fs.mkdirSync(outputsDir, { recursive: true });
   120	  for (const fixture of materialized) {
   121	    fs.writeFileSync(path.join(outputsDir, `${fixture.id}.md`), renderFixture(fixture), 'utf8');
   122	  }
   123	
   124	  process.stdout.write(JSON.stringify({
   125	    status: 'fixtures-materialized',
   126	    profileId: profile.profileId || profile.id,
   127	    outputsDir,
   128	    fixtures: fixtureRefs.length,
   129	  }) + '\n');
   130	}
