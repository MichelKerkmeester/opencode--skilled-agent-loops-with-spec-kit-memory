 rg -l \"tool\\.execute\\.after\" .opencode/plugins/ 2>/dev/null; echo \"=== EXPERIMENTAL USAGE ===\" && rg -l \"experimental\\.\" .opencode/plugins/*.js 2>/dev/null; echo \"=== EVENT TYPES ===\" && rg \"input\\?\\.(event|type)\" .opencode/plugins/*.js 2>/dev/null | head -10","time":{"start":1783744394971,"end":1783744394973}},"id":"prt_f4f7376b3001edpOE3BfGa2tth","sessionID":"ses_0b0929e35ffeiPmK0rQRK8nw1B","messageID":"msg_f4f73506c001IIvtR7NKl7ch3a"}}
