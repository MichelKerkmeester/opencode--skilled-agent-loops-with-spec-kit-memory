ave already exited.\n546:   }\n547: }\n548: \n549: function expectedLineageArtifactPaths(loopType, lineageDir) {\n550:   assertActiveFanoutLoopType(loopType);\n551:   if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n552:   return [path.join(lineageDir, 'research.md')];\n553: }\n554: \n555: function hasNonEmptyFile(filePath) {\n556:   try {\n557:     return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n558:   } catch {\n559:     return false;\n560:   }\n561: }\n562: \n563: function findMissingLineageArtifacts(loopType, lineageDir) {\n564:   return expectedLineageArtifactPaths(loopType, lineageDir)\n565:     .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n566: }\n567: \n568: function parseJsonlRecords(filePath) {\n569:   const text = fs.readFileSync(filePath, 'utf8');\n570:   return text\n571:     .split(/\\r?\\n/)\n572:     .filter((line) => line.trim() !== '')\n573:     .map((line) => JSON.parse(line));\n574: }\n575: \n576: function lineageStateLogName(loopType) {\n577:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n578: }\n579: \n580: function readLineageStateRecords(loopType, lineageDir) {\n581:   const stateLogName = lineageStateLogName(loopType);\n582:   if (!stateLogName) {\n583:     return { statePath: null, records: [], missing: true, parseError: null };\n584:   }\n585:   const statePath = path.join(lineageDir, stateLogName);\n586:   if (!hasNonEmptyFile(statePath)) {\n587:     return { statePath, records: [], missing: true, parseError: null };\n588:   }\n589:   try {\n590:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n591:   } catch (error) {\n592:     return {\n593:       statePath,\n594:       records: [],\n595:       missing: false,\n596:       parseError: error instanceof Error ? error.message : String(error),\n597:     };\n598:   }\n599: }\n600: \n601: // A lineage's synthesis stopReason is written by its model and cannot be held to