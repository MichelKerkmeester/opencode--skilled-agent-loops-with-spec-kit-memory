{"type":"tool_use","timestamp":1783486770428,"sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","part":{"type":"tool","tool":"read","callID":"call_X7NEE970yKmZQnO9eotEPz5e","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: # ───────────────────────────────────────────────────────────────\n3: # COMPONENT: SKILL ADVISOR\n4: # ───────────────────────────────────────────────────────────────\n5: \n6: \"\"\"\n7: Skill Advisor - Analyzes user requests and recommends appropriate skills.\n8: Used by Gate 2 in AGENTS.md for skill routing.\n9: \n10: Usage: python skill_advisor.py \"user request\" [--threshold 0.8]\n11: Output: JSON array of skill recommendations with confidence scores\n12: \n13: Options:\n14:     --stdin      Read the single prompt from stdin instead of argv\n15:     --stdin-preferred  Prefer stdin for the single-prompt mode, falling back to argv when stdin is empty\n16:     --deep-skill-routing-json  Score deep-loop-workflows mode routing (research|review|ai-council) from JSON stdin\n17:     --health      Run health check diagnostics\n18:     --validate-only  Run strict skill-graph validation\n19:     --threshold   Confidence threshold used by default dual-threshold filtering (default: 0.8)\n20:     --confidence-only  Explicitly bypass uncertainty filtering\n21: \"\"\"\n22: \n23: import argparse\n24: import hashlib\n25: import importlib.util\n26: import json\n27: import os\n28: import re\n29: import sqlite3\n30: import subprocess\n31: import sys\n32: from functools import lru_cache\n33: from pathlib import Path\n34: from typing import Any, Dict, List, Optional, Set\n35: \n36: \n37: # ───────────────────────────────────────────────────────────────\n38: # 1. CONFIGURATION\n39: # ───────────────────────────────────────────────────────────────\n40: \n41: # Path to skill directory.\n42: # This script lives in .opencode/skills/system-skill-advisor/mcp_server/scripts/.\n43: SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))\n44: SKILLS_DIR = os.path.abspath(os.path.join(SCRIPT_DIR, \"..\", \"..\", \"..\"))\n45: REPO_ROOT = os.path.dirname(os.path.dirname(SKILLS_DIR))\n46: DISABLE_ADVISOR_ENV = \"SPECKIT_SKILL_ADVISOR_HOOK_DISABLED\"\n47: FORCE_LOCAL_ENV = \"SPECKIT_SKILL_ADVISOR_FORCE_LOCAL\"\n48: NATIVE_TIMEOUT_SECONDS = 2.5\n49: NATIVE_ADVISOR_STATUS = os.path.join(\n50:     REPO_ROOT,\n51:     \".opencode\",\n52:     \"skills\",\n53:     \"system-skill-advisor\",\n54:     \"mcp_server\",\n55:     \"dist\",\n56:     \"mcp_server\",\n57:     \"handlers\",\n58:     \"advisor-status.js\",\n59: )\n60: NATIVE_ADVISOR_COMPAT = os.path.join(\n61:     REPO_ROOT,\n62:     \".opencode\",\n63:     \"skills\",\n64:     \"system-skill-advisor\",\n65:     \"mcp_server\",\n66:     \"dist\",\n67:     \"mcp_server\",\n68:     \"compat\",\n69:     \"index.js\",\n70: )\n71: NATIVE_GENERATION_MODULE = os.path.join(\n72:     REPO_ROOT,\n73:     \".opencode\",\n74:     \"skills\",\n75:     \"system-skill-advisor\",\n76:     \"mcp_server\",\n77:     \"dist\",\n78:     \"mcp_server\",\n79:     \"lib\",\n80:     \"freshness\",\n81:     \"generation.js\",\n82: )\n83: MODE_REGISTRY_PATH = os.path.join(SKILLS_DIR, \"deep-loop-workflows\", \"mode-registry.json\")\n84: ALIASES_TS_PATH = os.path.join(\n85:     SKILLS_DIR,\n86:     \"system-skill-advisor\",\n87:     \"mcp_server\",\n88:     \"lib\",\n89:     \"scorer\",\n90:     \"aliases.ts\",\n91: )\n92: TS_PROJECTION_START = \"// BEGIN GENERATED DEEP ROUTING PROJECTION\"\n93: TS_PROJECTION_END = \"// END GENERATED DEEP ROUTING PROJECTION\"\n94: PY_HASH_START = \"# BEGIN GENERATED DEEP ROUTING \" + \"PROJECTION HASH\"\n95: PY_HASH_END = \"# END GENERATED DEEP ROUTING \" + \"PROJECTION HASH\"\n96: PY_LEXICAL_START = \"# BEGIN GENERATED DEEP ROUTING \" + \"LEXICAL PROJECTION\"\n97: PY_LEXICAL_END = \"# END GENERATED DEEP ROUTING \" + \"LEXICAL PROJECTION\"\n98: PY_LEXICAL_ORDER = (\"deep-review\", \"deep-research\", \"deep-ai-council\")\n99: \n100: NATIVE_ADVISOR_BRIDGE = r\"\"\"\n101: import { readFileSync } from 'node:fs';\n102: import { readAdvisorStatus, handleAdvisorRecommend } from 'ADVISOR_COMPAT_MODULE';\n103: import { readSkillGraphGeneration } from 'GENERATION_MODULE';\n104: \n105: const input = JSON.parse(readFileSync(0, 'utf8') || '{}');\n106: const workspaceRoot = input.workspaceRoot || process.cwd();\n107: \n108: function unavailable(reason) {\n109:   return {\n110:     available: false,\n111:     freshness: 'unavailable',\n112:     generation: 0,\n113:     trustState: {\n114:       state: 'unavailable',\n115:       reason,\n116:       generation: 0,\n117:       checkedAt: new Date().toISOString(),\n118:       lastLiveAt: null,\n119:     },\n120:     reason,\n121:   };\n122: }\n123: \n124: function probe() {\n125:   if (process.env.SPECKIT_SKILL_ADVISOR_HOOK_DISABLED === '1') {\n126:     return unavailable('ADVISOR_DISABLED');\n127:   }\n128:   try {\n129:     const status = readAdvisorStatus({ workspaceRoot });\n130:     // Compat-shim eligibility: native MCP callers gate on daemon liveness via\n131:     // status.freshness, but the Python shim is itself a one-shot reader that\n132:     // has no daemon to probe. Fall back to the underlying generation state so\n133:     // a fresh skill-graph artifact is still considered usable when invoked\n134:     // through skill_advisor.py (--force-native and the default routing path).\n135:     let shimEligible = status.freshness === 'live' || status.freshness === 'stale';\n136:     let effectiveFreshness = status.freshness;\n137:     if (!shimEligible) {\n138:       try {\n139:         const generation = readSkillGraphGeneration(workspaceRoot);\n140:         if (generation.state === 'live' || generation.state === 'stale') {\n141:           shimEligible = true;\n142:           effectiveFreshness = generation.state;\n143:         }\n144:       } catch {\n145:         // Keep shimEligible=false; surface the original status reason below.\n146:       }\n147:     }\n148:     return {\n149:       available: shimEligible,\n150:       freshness: effectiveFreshness,\n151:       generation: status.generation,\n152:       trustState: status.trustState,\n153:       daemonPid: status.daemonPid || null,\n154:       reason: (status.errors && status.errors[0]) || status.trustState.reason || null,\n155:     };\n156:   } catch (error) {\n157:     return unavailable((error && error.name ? error.name : 'PROBE_FAILED').toUpperCase().replace(/[^A-Z0-9_]/g, '_'));\n158:   }\n159: }\n160: \n161: const probeResult = probe();\n162: if (input.mode === 'status') {\n163:   process.stdout.write(JSON.stringify({ status: 'ok', data: probeResult }));\n164: } else if (!probeResult.available) {\n165:   process.stdout.write(JSON.stringify({ status: 'unavailable', data: probeResult }));\n166: } else {\n167:   const response = await handleAdvisorRecommend({\n168:     prompt: String(input.prompt || ''),\n169:     options: {\n170:       topK: Number.isFinite(input.topK) ? input.topK : 10,\n171:       includeAbstainReasons: true,\n172:       includeAttribution: false,\n173:       confidenceThreshold: Number.isFinite(input.confidenceThreshold) ? input.confidenceThreshold : undefined,\n174:       uncertaintyThreshold: Number.isFinite(input.uncertaintyThreshold) ? input.uncertaintyThreshold : undefined,\n175:     },\n176:   });\n177:   const parsed = JSON.parse(response.content[0].text);\n178:   process.stdout.write(JSON.stringify({\n179:     status: parsed.status || 'ok',\n180:     data: parsed.data,\n181:     probe: probeResult,\n182:   }));\n183: }\n184: \"\"\"\n185: \n186: RUNTIME_PATH = os.path.join(SCRIPT_DIR, \"skill_advisor_runtime.py\")\n187: COMPAT_CONTRACT_PATH = os.path.abspath(os.path.join(SCRIPT_DIR, \"..\", \"schemas\", \"compat-contract.json\"))\n188: with open(COMPAT_CONTRACT_PATH, \"r\", encoding=\"utf-8\") as _compat_contract_file:\n189:     COMPAT_CONTRACT = json.load(_compat_contract_file)\n190: DISABLE_ADVISOR_ENV = COMPAT_CONTRACT[\"disabledEnv\"]\n191: FORCE_LOCAL_ENV = COMPAT_CONTRACT[\"forceLocalEnv\"]\n192: NATIVE_DEFAULT_CONFIDENCE_THRESHOLD = COMPAT_CONTRACT[\"defaults\"][\"confidenceThreshold\"]\n193: NATIVE_DEFAULT_UNCERTAINTY_THRESHOLD = COMPAT_CONTRACT[\"defaults\"][\"uncertaintyThreshold\"]\n194: NATIVE_BRIDGE_ENV_ALLOWLIST = {\n195:     \"PATH\",\n196:     \"HOME\",\n197:     \"USER\",\n198:     \"LOGNAME\",\n199:     \"SHELL\",\n200:     \"TMPDIR\",\n201:     \"TEMP\",\n202:     \"TMP\",\n203:     \"LANG\",\n204:     \"LC_ALL\",\n205:     \"CI\",\n206:     \"VITEST\",\n207:     \"MK_SKILL_ADVISOR_DB_DIR\",\n208:     \"SYSTEM_SKILL_ADVISOR_DB_DIR\",\n209:     \"SPECKIT_RUNTIME\",\n210:     \"SPECKIT_ADVISOR_FRESHNESS\",\n211:     \"SPECKIT_SKILL_ADVISOR_FORCE_LOCAL\",\n212:     \"SPECKIT_OPENCODE_HOOK_TIMEOUT_MS\",\n213:     \"SPECKIT_ADVISOR_WORKSPACE_ALLOWLIST\",\n214:     \"SPECKIT_ADVISOR_SHADOW_DELTA_PATH\",\n215:     \"SPECKIT_METRICS_ENABLED\",\n216:     \"SPECKIT_ADVISOR_HOOK_CACHE_HIT_P95_WARN_MS\",\n217: }\n218: _RUNTIME_SPEC = None\n219: _runtime_module = None\n220: _runtime_load_error: Optional[Exception] = None\n221: try:\n222:     _RUNTIME_SPEC = importlib.util.spec_from_file_location(\"skill_advisor_runtime\", RUNTIME_PATH)\n223:     if _RUNTIME_SPEC and _RUNTIME_SPEC.loader:\n224:         _runtime_module = importlib.util.module_from_spec(_RUNTIME_SPEC)\n225:         _RUNTIME_SPEC.loader.exec_module(_runtime_module)\n226: except Exception as exc:  # pragma: no cover - startup safety\n227:     _runtime_load_error = exc\n228:     _runtime_module = None\n229: \n230: if _runtime_module is None:\n231:     raise RuntimeError(f\"Failed to load runtime helpers from {RUNTIME_PATH}\") from _runtime_load_error\n232: \n233: # Compiled skill graph for relationship-aware routing\n234: SKILL_GRAPH_PATH = os.path.join(SCRIPT_DIR, \"skill-graph.json\")\n235: SKILL_GRAPH_COMPILER_PATH = os.path.join(SCRIPT_DIR, \"skill_graph_compiler.py\")\n236: SKILL_GRAPH_SQLITE_PATH = os.path.normpath(os.path.join(\n237:     os.path.dirname(__file__),\n238:     '..',\n239:     'database',\n240:     'skill-graph.sqlite',\n241: ))\n242: GRAPH_ADJACENCY_EDGE_TYPES = (\"depends_on\", \"enhances\", \"siblings\", \"prerequisite_for\")\n243: GRAPH_ONLY_SKILL_IDS = {\"system-skill-advisor\"}\n244: GRAPHLESS_INLINE_SKILL_IDS = {\n245:     \"create:agent\",\n246:     \"create:manual-testing-playbook\",\n247:     \"memory:save\",\n248: }\n249: \n250: SKILL_ALIAS_GROUPS = {\n251:     \"create:agent\": {\"command-create-agent\", \"/create:agent\", \"create:agent\"},\n252:     \"create:manual-testing-playbook\": {\n253:         \"command-create-manual-testing-playbook\",\n254:         \"/create:manual-testing-playbook\",\n255:         \"create:manual-testing-playbook\",\n256:     },\n257:     \"memory:save\": {\"command-memory-save\", \"/memory:save\", \"memory:save\"},\n258:     \"deep-research\": {\n259:         \"command-spec-kit-deep-research\",\n260:         \"/deep:start-research-loop\",\n\n(Showing lines 1-260 of 4443. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n# ───────────────────────────────────────────────────────────────\n# COMPONENT: SKILL ADVISOR\n# ───────────────────────────────────────────────────────────────\n\n\"\"\"\nSkill Advisor - Analyzes user requests and recommends appropriate skills.\nUsed by Gate 2 in AGENTS.md for skill routing.\n\nUsage: python skill_advisor.py \"user request\" [--threshold 0.8]\nOutput: JSON array of skill recommendations with confidence scores\n\nOptions:\n    --stdin      Read the single prompt from stdin instead of argv\n    --stdin-preferred  Prefer stdin for the single-prompt mode, falling back to argv when stdin is empty\n    --deep-skill-routing-json  Score deep-loop-workflows mode routing (research|review|ai-council) from JSON stdin\n    --health      Run health check diagnostics\n    --validate-only  Run strict skill-graph validation\n    --threshold   Confidence threshold used by default dual-threshold filtering (default: 0.8)\n    --confidence-only  Explicitly bypass uncertainty filtering","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py","text":"#!/usr/bin/env python3\n# ───────────────────────────────────────────────────────────────\n# COMPONENT: SKILL ADVISOR\n# ───────────────────────────────────────────────────────────────\n\n\"\"\"\nSkill Advisor - Analyzes user requests and recommends appropriate skills.\nUsed by Gate 2 in AGENTS.md for skill routing.\n\nUsage: python skill_advisor.py \"user request\" [--threshold 0.8]\nOutput: JSON array of skill recommendations with confidence scores\n\nOptions:\n    --stdin      Read the single prompt from stdin instead of argv\n    --stdin-preferred  Prefer stdin for the single-prompt mode, falling back to argv when stdin is empty\n    --deep-skill-routing-json  Score deep-loop-workflows mode routing (research|review|ai-council) from JSON stdin\n    --health      Run health check diagnostics\n    --validate-only  Run strict skill-graph validation\n    --threshold   Confidence threshold used by default dual-threshold filtering (default: 0.8)\n    --confidence-only  Explicitly bypass uncertainty filtering\n\"\"\"\n\nimport argparse\nimport hashlib\nimport importlib.util\nimport json\nimport os\nimport re\nimport sqlite3\nimport subprocess\nimport sys\nfrom functools import lru_cache\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Set\n\n\n# ───────────────────────────────────────────────────────────────\n# 1. CONFIGURATION\n# ───────────────────────────────────────────────────────────────\n\n# Path to skill directory.\n# This script lives in .opencode/skills/system-skill-advisor/mcp_server/scripts/.\nSCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))\nSKILLS_DIR = os.path.abspath(os.path.join(SCRIPT_DIR, \"..\", \"..\", \"..\"))\nREPO_ROOT = os.path.dirname(os.path.dirname(SKILLS_DIR))\nDISABLE_ADVISOR_ENV = \"SPECKIT_SKILL_ADVISOR_HOOK_DISABLED\"\nFORCE_LOCAL_ENV = \"SPECKIT_SKILL_ADVISOR_FORCE_LOCAL\"\nNATIVE_TIMEOUT_SECONDS = 2.5\nNATIVE_ADVISOR_STATUS = os.path.join(\n    REPO_ROOT,\n    \".opencode\",\n    \"skills\",\n    \"system-skill-advisor\",\n    \"mcp_server\",\n    \"dist\",\n    \"mcp_server\",\n    \"handlers\",\n    \"advisor-status.js\",\n)\nNATIVE_ADVISOR_COMPAT = os.path.join(\n    REPO_ROOT,\n    \".opencode\",\n    \"skills\",\n    \"system-skill-advisor\",\n    \"mcp_server\",\n    \"dist\",\n    \"mcp_server\",\n    \"compat\",\n    \"index.js\",\n)\nNATIVE_GENERATION_MODULE = os.path.join(\n    REPO_ROOT,\n    \".opencode\",\n    \"skills\",\n    \"system-skill-advisor\",\n    \"mcp_server\",\n    \"dist\",\n    \"mcp_server\",\n    \"lib\",\n    \"freshness\",\n    \"generation.js\",\n)\nMODE_REGISTRY_PATH = os.path.join(SKILLS_DIR, \"deep-loop-workflows\", \"mode-registry.json\")\nALIASES_TS_PATH = os.path.join(\n    SKILLS_DIR,\n    \"system-skill-advisor\",\n    \"mcp_server\",\n    \"lib\",\n    \"scorer\",\n    \"aliases.ts\",\n)\nTS_PROJECTION_START = \"// BEGIN GENERATED DEEP ROUTING PROJECTION\"\nTS_PROJECTION_END = \"// END GENERATED DEEP ROUTING PROJECTION\"\nPY_HASH_START = \"# BEGIN GENERATED DEEP ROUTING \" + \"PROJECTION HASH\"\nPY_HASH_END = \"# END GENERATED DEEP ROUTING \" + \"PROJECTION HASH\"\nPY_LEXICAL_START = \"# BEGIN GENERATED DEEP ROUTING \" + \"LEXICAL PROJECTION\"\nPY_LEXICAL_END = \"# END GENERATED DEEP ROUTING \" + \"LEXICAL PROJECTION\"\nPY_LEXICAL_ORDER = (\"deep-review\", \"deep-research\", \"deep-ai-council\")\n\nNATIVE_ADVISOR_BRIDGE = r\"\"\"\nimport { readFileSync } from 'node:fs';\nimport { readAdvisorStatus, handleAdvisorRecommend } from 'ADVISOR_COMPAT_MODULE';\nimport { readSkillGraphGeneration } from 'GENERATION_MODULE';\n\nconst input = JSON.parse(readFileSync(0, 'utf8') || '{}');\nconst workspaceRoot = input.workspaceRoot || process.cwd();\n\nfunction unavailable(reason) {\n  return {\n    available: false,\n    freshness: 'unavailable',\n    generation: 0,\n    trustState: {\n      state: 'unavailable',\n      reason,\n      generation: 0,\n      checkedAt: new Date().toISOString(),\n      lastLiveAt: null,\n    },\n    reason,\n  };\n}\n\nfunction probe() {\n  if (process.env.SPECKIT_SKILL_ADVISOR_HOOK_DISABLED === '1') {\n    return unavailable('ADVISOR_DISABLED');\n  }\n  try {\n    const status = readAdvisorStatus({ workspaceRoot });\n    // Compat-shim eligibility: native MCP callers gate on daemon liveness via\n    // status.freshness, but the Python shim is itself a one-shot reader that\n    // has no daemon to probe. Fall back to the underlying generation state so\n    // a fresh skill-graph artifact is still considered usable when invoked\n    // through skill_advisor.py (--force-native and the default routing path).\n    let shimEligible = status.freshness === 'live' || status.freshness === 'stale';\n    let effectiveFreshness = status.freshness;\n    if (!shimEligible) {\n      try {\n        const generation = readSkillGraphGeneration(workspaceRoot);\n        if (generation.state === 'live' || generation.state === 'stale') {\n          shimEligible = true;\n          effectiveFreshness = generation.state;\n        }\n      } catch {\n        // Keep shimEligible=false; surface the original status reason below.\n      }\n    }\n    return {\n      available: shimEligible,\n      freshness: effectiveFreshness,\n      generation: status.generation,\n      trustState: status.trustState,\n      daemonPid: status.daemonPid || null,\n      reason: (status.errors && status.errors[0]) || status.trustState.reason || null,\n    };\n  } catch (error) {\n    return unavailable((error && error.name ? error.name : 'PROBE_FAILED').toUpperCase().replace(/[^A-Z0-9_]/g, '_'));\n  }\n}\n\nconst probeResult = probe();\nif (input.mode === 'status') {\n  process.stdout.write(JSON.stringify({ status: 'ok', data: probeResult }));\n} else if (!probeResult.available) {\n  process.stdout.write(JSON.stringify({ status: 'unavailable', data: probeResult }));\n} else {\n  const response = await handleAdvisorRecommend({\n    prompt: String(input.prompt || ''),\n    options: {\n      topK: Number.isFinite(input.topK) ? input.topK : 10,\n      includeAbstainReasons: true,\n      includeAttribution: false,\n      confidenceThreshold: Number.isFinite(input.confidenceThreshold) ? input.confidenceThreshold : undefined,\n      uncertaintyThreshold: Number.isFinite(input.uncertaintyThreshold) ? input.uncertaintyThreshold : undefined,\n    },\n  });\n  const parsed = JSON.parse(response.content[0].text);\n  process.stdout.write(JSON.stringify({\n    status: parsed.status || 'ok',\n    data: parsed.data,\n    probe: probeResult,\n  }));\n}\n\"\"\"\n\nRUNTIME_PATH = os.path.join(SCRIPT_DIR, \"skill_advisor_runtime.py\")\nCOMPAT_CONTRACT_PATH = os.path.abspath(os.path.join(SCRIPT_DIR, \"..\", \"schemas\", \"compat-contract.json\"))\nwith open(COMPAT_CONTRACT_PATH, \"r\", encoding=\"utf-8\") as _compat_contract_file:\n    COMPAT_CONTRACT = json.load(_compat_contract_file)\nDISABLE_ADVISOR_ENV = COMPAT_CONTRACT[\"disabledEnv\"]\nFORCE_LOCAL_ENV = COMPAT_CONTRACT[\"forceLocalEnv\"]\nNATIVE_DEFAULT_CONFIDENCE_THRESHOLD = COMPAT_CONTRACT[\"defaults\"][\"confidenceThreshold\"]\nNATIVE_DEFAULT_UNCERTAINTY_THRESHOLD = COMPAT_CONTRACT[\"defaults\"][\"uncertaintyThreshold\"]\nNATIVE_BRIDGE_ENV_ALLOWLIST = {\n    \"PATH\",\n    \"HOME\",\n    \"USER\",\n    \"LOGNAME\",\n    \"SHELL\",\n    \"TMPDIR\",\n    \"TEMP\",\n    \"TMP\",\n    \"LANG\",\n    \"LC_ALL\",\n    \"CI\",\n    \"VITEST\",\n    \"MK_SKILL_ADVISOR_DB_DIR\",\n    \"SYSTEM_SKILL_ADVISOR_DB_DIR\",\n    \"SPECKIT_RUNTIME\",\n    \"SPECKIT_ADVISOR_FRESHNESS\",\n    \"SPECKIT_SKILL_ADVISOR_FORCE_LOCAL\",\n    \"SPECKIT_OPENCODE_HOOK_TIMEOUT_MS\",\n    \"SPECKIT_ADVISOR_WORKSPACE_ALLOWLIST\",\n    \"SPECKIT_ADVISOR_SHADOW_DELTA_PATH\",\n    \"SPECKIT_METRICS_ENABLED\",\n    \"SPECKIT_ADVISOR_HOOK_CACHE_HIT_P95_WARN_MS\",\n}\n_RUNTIME_SPEC = None\n_runtime_module = None\n_runtime_load_error: Optional[Exception] = None\ntry:\n    _RUNTIME_SPEC = importlib.util.spec_from_file_location(\"skill_advisor_runtime\", RUNTIME_PATH)\n    if _RUNTIME_SPEC and _RUNTIME_SPEC.loader:\n        _runtime_module = importlib.util.module_from_spec(_RUNTIME_SPEC)\n        _RUNTIME_SPEC.loader.exec_module(_runtime_module)\nexcept Exception as exc:  # pragma: no cover - startup safety\n    _runtime_load_error = exc\n    _runtime_module = None\n\nif _runtime_module is None:\n    raise RuntimeError(f\"Failed to load runtime helpers from {RUNTIME_PATH}\") from _runtime_load_error\n\n# Compiled skill graph for relationship-aware routing\nSKILL_GRAPH_PATH = os.path.join(SCRIPT_DIR, \"skill-graph.json\")\nSKILL_GRAPH_COMPILER_PATH = os.path.join(SCRIPT_DIR, \"skill_graph_compiler.py\")\nSKILL_GRAPH_SQLITE_PATH = os.path.normpath(os.path.join(\n    os.path.dirname(__file__),\n    '..',\n    'database',\n    'skill-graph.sqlite',\n))\nGRAPH_ADJACENCY_EDGE_TYPES = (\"depends_on\", \"enhances\", \"siblings\", \"prerequisite_for\")\nGRAPH_ONLY_SKILL_IDS = {\"system-skill-advisor\"}\nGRAPHLESS_INLINE_SKILL_IDS = {\n    \"create:agent\",\n    \"create:manual-testing-playbook\",\n    \"memory:save\",\n}\n\nSKILL_ALIAS_GROUPS = {\n    \"create:agent\": {\"command-create-agent\", \"/create:agent\", \"create:agent\"},\n    \"create:manual-testing-playbook\": {\n        \"command-create-manual-testing-playbook\",\n        \"/create:manual-testing-playbook\",\n        \"create:manual-testing-playbook\",\n    },\n    \"memory:save\": {\"command-memory-save\", \"/memory:save\", \"memory:save\"},\n    \"deep-research\": {\n        \"command-spec-kit-deep-research\",\n        \"/deep:start-research-loop\",","lineStart":1,"lineEnd":260,"totalLines":4443,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py","time":{"start":1783486770366,"end":1783486770427}},"metadata":{"openai":{"itemId":"fc_08628de8328a168b016a4dd93247848191a7bbe82040b30c33"}},"id":"prt_f40186cbc001GvSMW3gnp4bfk6","sessionID":"ses_0bfeb66ceffeH0lBIVcE9YycJ4","messageID":"msg_f40183a64001FBnEF8pk5Iu8FF"}}
