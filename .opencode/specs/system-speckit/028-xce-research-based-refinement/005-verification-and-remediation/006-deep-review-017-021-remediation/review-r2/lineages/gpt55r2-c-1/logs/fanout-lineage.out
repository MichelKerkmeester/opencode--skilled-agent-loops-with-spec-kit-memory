{"type":"tool_use","timestamp":1781761641844,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_QjOGhHeZOoZO8aYtFFzed7Ab","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Checkpoints\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Checkpoint creation (checkpoint_create)\n5: // Feature catalog: Checkpoint restore (checkpoint_restore)\n6: // Gzip-compressed database checkpoints with embedding preservation\n7: // Node stdlib\n8: import * as fs from 'fs';\n9: import * as path from 'path';\n10: import * as zlib from 'zlib';\n11: \n12: // External packages\n13: import type Database from 'better-sqlite3';\n14: import { z } from 'zod';\n15: \n16: // Internal utils\n17: import { toErrorMessage } from '../../utils/db-helpers.js';\n18: import { rebuildAutoEntities } from '../extraction/entity-extractor.js';\n19: import {\n20:   buildGovernanceLogicalKey,\n21:   createScopeFilterPredicate,\n22:   GOVERNANCE_AUDIT_ACTIONS,\n23:   hasScopeConstraints,\n24:   normalizeScopeContext,\n25:   recordGovernanceAudit,\n26:   recordTierDowngradeAudit,\n27:   type ScopeContext,\n28:   type GovernanceAuditEntry,\n29:   type TierDowngradeAuditParams,\n30: } from '../governance/scope-governance.js';\n31: import { detectCommunities, storeCommunityAssignments } from '../graph/community-detection.js';\n32: import { generateCommunitySummaries } from '../graph/community-summaries.js';\n33: import { storeCommunities } from '../graph/community-storage.js';\n34: import { snapshotDegrees } from '../graph/graph-signals.js';\n35: import { runLineageBackfill } from './lineage-state.js';\n36: import { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../utils/index-scope.js';\n37: import { reopenActiveDatabase } from '../search/vector-index-store.js';\n38: import { SCHEMA_VERSION } from '../search/vector-index-schema.js';\n39: import { sweepCausalEdges } from '../causal/sweep.js';\n40: import { BetterSqliteContentionPolicy } from './ports/contention-policy.js';\n41: \n42: function batchedInQuery<T>(db: Database.Database, sql: string, ids: (number | string)[], batchSize = 500): T[] {\n43:   const results: T[] = [];\n44:   for (let i = 0; i < ids.length; i += batchSize) {\n45:     const batch = ids.slice(i, i + batchSize);\n46:     const placeholders = batch.map(() => '?').join(', ');\n47:     const batchSql = sql.replace('__PLACEHOLDERS__', placeholders);\n48:     results.push(...(db.prepare(batchSql).all(...batch) as T[]));\n49:   }\n50:   return results;\n51: }\n52: \n53: function dedupeRowsById<T extends Record<string, unknown>>(rows: T[]): T[] {\n54:   const results: T[] = [];\n55:   const seenIds = new Set<number | string>();\n56: \n57:   for (const row of rows) {\n58:     const id = row.id;\n59:     if (typeof id === 'number' || typeof id === 'string') {\n60:       if (seenIds.has(id)) {\n61:         continue;\n62:       }\n63:       seenIds.add(id);\n64:     }\n65:     results.push(row);\n66:   }\n67: \n68:   return results;\n69: }\n70: \n71: function getSnapshotColumnsFromRows(rows: Array<Record<string, unknown>>): string[] {\n72:   const columns = new Set<string>();\n73: \n74:   for (const row of rows) {\n75:     for (const key of Object.keys(row ?? {})) {\n76:       if (typeof key === 'string' && key.length > 0) {\n77:         columns.add(key);\n78:       }\n79:     }\n80:   }\n81: \n82:   return Array.from(columns);\n83: }\n84: \n85: function flushGovernanceAudits(\n86:   database: Database.Database,\n87:   entries: GovernanceAuditEntry[],\n88: ): void {\n89:   for (const entry of entries) {\n90:     try {\n91:       recordGovernanceAudit(database, entry);\n92:     } catch (error: unknown) {\n93:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n94:     }\n95:   }\n96: }\n97: \n98: function flushTierDowngradeAudits(\n99:   database: Database.Database,\n100:   entries: TierDowngradeAuditParams[],\n101: ): void {\n102:   for (const entry of entries) {\n103:     try {\n104:       recordTierDowngradeAudit(database, entry);\n105:     } catch (error: unknown) {\n106:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n107:     }\n108:   }\n109: }\n110: \n111: /* ───────────────────────────────────────────────────────────────\n112:    1. CONSTANTS\n113: ----------------------------------------------------------------*/\n114: \n115: const MAX_CHECKPOINTS = 10;\n116: const CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\n117: const CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\n118: const CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\n119: const RESTORE_JOURNAL_NAME = '.restore-journal.json';\n120: const NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n121: const checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n122: \n123: const CHECKPOINT_MANIFEST = Object.freeze({\n124:   snapshot: [\n125:     'memory_index',\n126:     'vec_memories',\n127:     'vec_metadata',\n128:     'working_memory',\n129:     'causal_edges',\n130:     'weight_history',\n131:     'memory_history',\n132:     'mutation_ledger',\n133:     'memory_conflicts',\n134:     'memory_corrections',\n135:     'adaptive_signal_events',\n136:     'negative_feedback_events',\n137:     'learned_feedback_audit',\n138:     'session_learning',\n139:     'governance_audit',\n140:     'session_state',\n141:     'session_sent_memories',\n142:     'memory_summaries',\n143:   ],\n144:   rebuild: [\n145:     'memory_lineage',\n146:     'active_memory_projection',\n147:     'memory_entities',\n148:     'entity_catalog',\n149:     'degree_snapshots',\n150:     'community_assignments',\n151:     'graph_communities',\n152:     'community_summaries',\n153:     'memory_fts',\n154:   ],\n155:   skip: [\n156:     'checkpoints',\n157:     'schema_version',\n158:     'embedding_cache',\n159:     'adaptive_shadow_runs',\n160:   ],\n161: });\n162: \n163: const CHECKPOINT_RESTORE_ORDER = [\n164:   'memory_index',\n165:   'vec_memories',\n166:   'vec_metadata',\n167:   'working_memory',\n168:   'causal_edges',\n169:   'weight_history',\n170:   'memory_history',\n171:   'mutation_ledger',\n172:   'memory_conflicts',\n173:   'memory_corrections',\n174:   'adaptive_signal_events',\n175:   'negative_feedback_events',\n176:   'learned_feedback_audit',\n177:   'session_learning',\n178:   'governance_audit',\n179:   'session_state',\n180:   'session_sent_memories',\n181:   'memory_summaries',\n182: ] as const;\n183: \n184: const CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n185: \n186: const MUTATION_LEDGER_TRIGGER_SQL = `\n187:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n188:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n189:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n190:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n191: `;\n192: \n193: /* ───────────────────────────────────────────────────────────────\n194:    2. INTERFACES\n195: ----------------------------------------------------------------*/\n196: \n197: interface CheckpointEntry {\n198:   id: number;\n199:   name: string;\n200:   created_at: string;\n201:   spec_folder: string | null;\n202:   git_branch: string | null;\n203:   memory_snapshot: Buffer | null;\n204:   file_snapshot: Buffer | null;\n205:   snapshot_format?: string | null;\n206:   snapshot_path?: string | null;\n207:   metadata: string | null;\n208: }\n209: \n210: interface CheckpointInfo {\n211:   id: number;\n212:   name: string;\n213:   createdAt: string;\n214:   specFolder: string | null;\n215:   gitBranch: string | null;\n216:   snapshotSize: number;\n217:   metadata: Record<string, unknown>;\n218:   [key: string]: unknown;\n219: }\n220: \n221: interface CreateCheckpointOptions {\n222:   name?: string;\n223:   specFolder?: string | null;\n224:   includeEmbeddings?: boolean;\n225:   metadata?: Record<string, unknown>;\n226:   scope?: ScopeContext;\n227: }\n228: \n229: type CheckpointCreateErrorCode =\n230:   | 'CHECKPOINT_CREATE_SQLITE_BUSY'\n231:   | 'CHECKPOINT_CREATE_SQLITE_LOCKED'\n232:   | 'CHECKPOINT_CREATE_DUPLICATE_NAME'\n233:   | 'CHECKPOINT_CREATE_INVALID_NAME'\n234:   | 'CHECKPOINT_CREATE_PERMISSION_DENIED'\n235:   | 'CHECKPOINT_CREATE_FAILED';\n236: \n237: type CheckpointRestoreErrorCode =\n238:   | 'CHECKPOINT_RESTORE_MANIFEST_INVALID'\n239:   | 'CHECKPOINT_RESTORE_DOWNGRADE_UNSAFE'\n240:   | 'CHECKPOINT_RESTORE_EMBEDDER_MISMATCH'\n241:   | 'CHECKPOINT_RESTORE_FILE_MISSING'\n242:   | 'CHECKPOINT_RESTORE_PATH_UNRESOLVED'\n243:   | 'CHECKPOINT_RESTORE_JOURNAL_FAILED'\n244:   | 'CHECKPOINT_RESTORE_SWAP_FAILED';\n245: \n246: class CheckpointCreateError extends Error {\n247:   public readonly code: CheckpointCreateErrorCode;\n248:   public readonly originalCode: string | null;\n249:   public readonly details: Record<string, unknown>;\n250: \n251:   constructor(\n252:     code: CheckpointCreateErrorCode,\n253:     message: string,\n254:     details: Record<string, unknown> = {},\n255:     cause?: unknown,\n256:   ) {\n257:     super(message, { cause });\n258:     Object.setPrototypeOf(this, CheckpointCreateError.prototype);\n259:     this.name = 'CheckpointCreateError';\n260:     this.code = code;\n\n(Showing lines 1-260 of 3364. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Gzip-compressed database checkpoints with embedding preservation\n// Node stdlib\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as zlib from 'zlib';\n\n// External packages\nimport type Database from 'better-sqlite3';\nimport { z } from 'zod';\n\n// Internal utils\nimport { toErrorMessage } from '../../utils/db-helpers.js';\nimport { rebuildAutoEntities } from '../extraction/entity-extractor.js';\nimport {\n  buildGovernanceLogicalKey,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Gzip-compressed database checkpoints with embedding preservation\n// Node stdlib\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as zlib from 'zlib';\n\n// External packages\nimport type Database from 'better-sqlite3';\nimport { z } from 'zod';\n\n// Internal utils\nimport { toErrorMessage } from '../../utils/db-helpers.js';\nimport { rebuildAutoEntities } from '../extraction/entity-extractor.js';\nimport {\n  buildGovernanceLogicalKey,\n  createScopeFilterPredicate,\n  GOVERNANCE_AUDIT_ACTIONS,\n  hasScopeConstraints,\n  normalizeScopeContext,\n  recordGovernanceAudit,\n  recordTierDowngradeAudit,\n  type ScopeContext,\n  type GovernanceAuditEntry,\n  type TierDowngradeAuditParams,\n} from '../governance/scope-governance.js';\nimport { detectCommunities, storeCommunityAssignments } from '../graph/community-detection.js';\nimport { generateCommunitySummaries } from '../graph/community-summaries.js';\nimport { storeCommunities } from '../graph/community-storage.js';\nimport { snapshotDegrees } from '../graph/graph-signals.js';\nimport { runLineageBackfill } from './lineage-state.js';\nimport { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../utils/index-scope.js';\nimport { reopenActiveDatabase } from '../search/vector-index-store.js';\nimport { SCHEMA_VERSION } from '../search/vector-index-schema.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { BetterSqliteContentionPolicy } from './ports/contention-policy.js';\n\nfunction batchedInQuery<T>(db: Database.Database, sql: string, ids: (number | string)[], batchSize = 500): T[] {\n  const results: T[] = [];\n  for (let i = 0; i < ids.length; i += batchSize) {\n    const batch = ids.slice(i, i + batchSize);\n    const placeholders = batch.map(() => '?').join(', ');\n    const batchSql = sql.replace('__PLACEHOLDERS__', placeholders);\n    results.push(...(db.prepare(batchSql).all(...batch) as T[]));\n  }\n  return results;\n}\n\nfunction dedupeRowsById<T extends Record<string, unknown>>(rows: T[]): T[] {\n  const results: T[] = [];\n  const seenIds = new Set<number | string>();\n\n  for (const row of rows) {\n    const id = row.id;\n    if (typeof id === 'number' || typeof id === 'string') {\n      if (seenIds.has(id)) {\n        continue;\n      }\n      seenIds.add(id);\n    }\n    results.push(row);\n  }\n\n  return results;\n}\n\nfunction getSnapshotColumnsFromRows(rows: Array<Record<string, unknown>>): string[] {\n  const columns = new Set<string>();\n\n  for (const row of rows) {\n    for (const key of Object.keys(row ?? {})) {\n      if (typeof key === 'string' && key.length > 0) {\n        columns.add(key);\n      }\n    }\n  }\n\n  return Array.from(columns);\n}\n\nfunction flushGovernanceAudits(\n  database: Database.Database,\n  entries: GovernanceAuditEntry[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordGovernanceAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\nfunction flushTierDowngradeAudits(\n  database: Database.Database,\n  entries: TierDowngradeAuditParams[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordTierDowngradeAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MAX_CHECKPOINTS = 10;\nconst CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\nconst CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\nconst CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';\nconst NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\nconst checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n\nconst CHECKPOINT_MANIFEST = Object.freeze({\n  snapshot: [\n    'memory_index',\n    'vec_memories',\n    'vec_metadata',\n    'working_memory',\n    'causal_edges',\n    'weight_history',\n    'memory_history',\n    'mutation_ledger',\n    'memory_conflicts',\n    'memory_corrections',\n    'adaptive_signal_events',\n    'negative_feedback_events',\n    'learned_feedback_audit',\n    'session_learning',\n    'governance_audit',\n    'session_state',\n    'session_sent_memories',\n    'memory_summaries',\n  ],\n  rebuild: [\n    'memory_lineage',\n    'active_memory_projection',\n    'memory_entities',\n    'entity_catalog',\n    'degree_snapshots',\n    'community_assignments',\n    'graph_communities',\n    'community_summaries',\n    'memory_fts',\n  ],\n  skip: [\n    'checkpoints',\n    'schema_version',\n    'embedding_cache',\n    'adaptive_shadow_runs',\n  ],\n});\n\nconst CHECKPOINT_RESTORE_ORDER = [\n  'memory_index',\n  'vec_memories',\n  'vec_metadata',\n  'working_memory',\n  'causal_edges',\n  'weight_history',\n  'memory_history',\n  'mutation_ledger',\n  'memory_conflicts',\n  'memory_corrections',\n  'adaptive_signal_events',\n  'negative_feedback_events',\n  'learned_feedback_audit',\n  'session_learning',\n  'governance_audit',\n  'session_state',\n  'session_sent_memories',\n  'memory_summaries',\n] as const;\n\nconst CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n\nconst MUTATION_LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CheckpointEntry {\n  id: number;\n  name: string;\n  created_at: string;\n  spec_folder: string | null;\n  git_branch: string | null;\n  memory_snapshot: Buffer | null;\n  file_snapshot: Buffer | null;\n  snapshot_format?: string | null;\n  snapshot_path?: string | null;\n  metadata: string | null;\n}\n\ninterface CheckpointInfo {\n  id: number;\n  name: string;\n  createdAt: string;\n  specFolder: string | null;\n  gitBranch: string | null;\n  snapshotSize: number;\n  metadata: Record<string, unknown>;\n  [key: string]: unknown;\n}\n\ninterface CreateCheckpointOptions {\n  name?: string;\n  specFolder?: string | null;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n  scope?: ScopeContext;\n}\n\ntype CheckpointCreateErrorCode =\n  | 'CHECKPOINT_CREATE_SQLITE_BUSY'\n  | 'CHECKPOINT_CREATE_SQLITE_LOCKED'\n  | 'CHECKPOINT_CREATE_DUPLICATE_NAME'\n  | 'CHECKPOINT_CREATE_INVALID_NAME'\n  | 'CHECKPOINT_CREATE_PERMISSION_DENIED'\n  | 'CHECKPOINT_CREATE_FAILED';\n\ntype CheckpointRestoreErrorCode =\n  | 'CHECKPOINT_RESTORE_MANIFEST_INVALID'\n  | 'CHECKPOINT_RESTORE_DOWNGRADE_UNSAFE'\n  | 'CHECKPOINT_RESTORE_EMBEDDER_MISMATCH'\n  | 'CHECKPOINT_RESTORE_FILE_MISSING'\n  | 'CHECKPOINT_RESTORE_PATH_UNRESOLVED'\n  | 'CHECKPOINT_RESTORE_JOURNAL_FAILED'\n  | 'CHECKPOINT_RESTORE_SWAP_FAILED';\n\nclass CheckpointCreateError extends Error {\n  public readonly code: CheckpointCreateErrorCode;\n  public readonly originalCode: string | null;\n  public readonly details: Record<string, unknown>;\n\n  constructor(\n    code: CheckpointCreateErrorCode,\n    message: string,\n    details: Record<string, unknown> = {},\n    cause?: unknown,\n  ) {\n    super(message, { cause });\n    Object.setPrototypeOf(this, CheckpointCreateError.prototype);\n    this.name = 'CheckpointCreateError';\n    this.code = code;","lineStart":1,"lineEnd":260,"totalLines":3364,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781761641836,"end":1781761641842}},"metadata":{"openai":{"itemId":"fc_06c8be0c896a84df016a3386699d58819180a2beac6955d99a"}},"id":"prt_ed9450d47001b7J5WkW18jBzPb","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed944dca1001Zh7E4l7FT65Dk6"}}
{"type":"tool_use","timestamp":1781761641863,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_KU61WZYfidJ32Fw7nQCWZrhD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":260,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n260:     this.code = code;\n261:     this.originalCode = typeof details.originalCode === 'string' ? details.originalCode : null;\n262:     this.details = details;\n263:   }\n264: }\n265: \n266: class CheckpointRestoreError extends Error {\n267:   public readonly code: CheckpointRestoreErrorCode;\n268: \n269:   constructor(code: CheckpointRestoreErrorCode, message: string, cause?: unknown) {\n270:     super(message, { cause });\n271:     Object.setPrototypeOf(this, CheckpointRestoreError.prototype);\n272:     this.name = 'CheckpointRestoreError';\n273:     this.code = code;\n274:   }\n275: }\n276: \n277: interface RestoreCheckpointV2Options {\n278:   reopen?: (targetMainPath: string, swapFn: () => void) => Database.Database;\n279: }\n280: \n281: interface RestoreResult {\n282:   restored: number;\n283:   skipped: number;\n284:   errors: string[];\n285:   workingMemoryRestored: number;\n286:   partialFailure?: boolean;\n287:   rolledBackTables?: string[];\n288: }\n289: \n290: interface DerivedRebuildFailure {\n291:   name: string;\n292:   error: string;\n293: }\n294: \n295: interface DerivedRebuildSkipped {\n296:   name: string;\n297:   reason: string;\n298: }\n299: \n300: interface DerivedRebuildSummary {\n301:   completed: string[];\n302:   failed: DerivedRebuildFailure[];\n303:   skipped: DerivedRebuildSkipped[];\n304: }\n305: \n306: interface RunDerivedArtifactRebuildOptions {\n307:   specFolder?: string | null;\n308:   actor?: string;\n309:   logContext?: string;\n310: }\n311: \n312: interface NeedsRebuildSentinelFile {\n313:   formatVersion: 1;\n314:   createdAt: string;\n315:   source: string;\n316:   reason: string;\n317:   rebuildSummary?: DerivedRebuildSummary;\n318: }\n319: \n320: interface NeedsRebuildSentinelWriteOptions {\n321:   source: string;\n322:   reason: string;\n323:   summary?: DerivedRebuildSummary;\n324: }\n325: \n326: interface NeedsRebuildRepairOptions {\n327:   source: string;\n328:   specFolder?: string | null;\n329:   actor?: string;\n330: }\n331: \n332: interface NeedsRebuildRepairResult {\n333:   sentinelPresent: boolean;\n334:   attempted: boolean;\n335:   cleared: boolean;\n336:   summary: DerivedRebuildSummary | null;\n337:   error: string | null;\n338: }\n339: \n340: interface SnapshotVectorRow {\n341:   rowid: number;\n342:   embedding: Buffer | null;\n343: }\n344: \n345: interface TableSnapshot {\n346:   columns: string[];\n347:   rows: Array<Record<string, unknown>>;\n348: }\n349: \n350: interface CheckpointManifest {\n351:   snapshot: string[];\n352:   rebuild: string[];\n353:   skip: string[];\n354: }\n355: \n356: interface CheckpointSnapshot {\n357:   manifest?: CheckpointManifest;\n358:   tables?: Record<string, TableSnapshot>;\n359:   memories: Array<Record<string, unknown>>;\n360:   workingMemory: Array<Record<string, unknown>>;\n361:   vectors?: SnapshotVectorRow[];\n362:   causalEdges?: Array<Record<string, unknown>>;\n363:   timestamp: string;\n364: }\n365: \n366: interface DatabaseListRow {\n367:   seq?: number;\n368:   name?: string;\n369:   file?: string;\n370: }\n371: \n372: interface CheckpointV2Manifest {\n373:   formatVersion: 2;\n374:   createdAt: string;\n375:   specFolder: null;\n376:   gitBranch: string | null;\n377:   embedderSlug: string | null;\n378:   includeEmbeddings: boolean;\n379:   mainTables: string[];\n380:   vecTables: string[];\n381:   schemaVersion: number;\n382:   memoryCount: number;\n383:   vectorCount: number;\n384:   mainBytes: number;\n385:   vecBytes: number;\n386: }\n387: \n388: type RestoreJournalPhase = 'swap-pending' | 'swap-done';\n389: \n390: interface RestoreJournalFile {\n391:   formatVersion: 1;\n392:   phase: RestoreJournalPhase;\n393:   createdAt: string;\n394:   checkpointName: string;\n395:   liveMainPath: string;\n396:   backupMainPath: string;\n397:   snapshotMainPath: string;\n398:   liveShardPath: string | null;\n399:   backupShardPath: string | null;\n400:   snapshotVecPath: string | null;\n401:   shouldRestoreVec: boolean;\n402:   liveShardPreexisted: boolean;\n403: }\n404: \n405: // Validate the decompressed checkpoint snapshot before\n406: // restore. Previously the gzipped blob was JSON.parsed and cast directly\n407: // to CheckpointSnapshot — malformed memory_index rows propagated through\n408: // `getMemoryIds()` and the INSERT loops. This schema validates the\n409: // outer envelope and the array shapes; individual row shapes are still\n410: // permissive (sqlite columns evolve over time) but each row must be a\n411: // non-null object so downstream column extraction doesn't NPE.\n412: const CheckpointTableSnapshotSchema = z.object({\n413:   columns: z.array(z.string()),\n414:   rows: z.array(z.record(z.string(), z.unknown())),\n415: });\n416: \n417: const CheckpointVectorRowSchema = z.object({\n418:   rowid: z.number(),\n419:   embedding: z.unknown(), // Buffer or null — preserved as-is\n420: });\n421: \n422: const CheckpointSnapshotSchema = z.object({\n423:   manifest: z.object({\n424:     snapshot: z.array(z.string()),\n425:     rebuild: z.array(z.string()),\n426:     skip: z.array(z.string()),\n427:   }).optional(),\n428:   tables: z.record(z.string(), CheckpointTableSnapshotSchema).optional(),\n429:   memories: z.array(z.record(z.string(), z.unknown())),\n430:   workingMemory: z.array(z.record(z.string(), z.unknown())),\n431:   vectors: z.array(CheckpointVectorRowSchema).optional(),\n432:   causalEdges: z.array(z.record(z.string(), z.unknown())).optional(),\n433:   timestamp: z.string(),\n434: }).passthrough();\n435: \n436: interface RestoreBarrierStatus {\n437:   code: string;\n438:   message: string;\n439: }\n440: \n441: interface RestoreBarrierHooks {\n442:   afterAcquire?: (() => void) | null;\n443:   beforeRelease?: (() => void) | null;\n444: }\n445: \n446: /* ───────────────────────────────────────────────────────────────\n447:    3. MODULE STATE\n448: ----------------------------------------------------------------*/\n449: \n450: let db: Database.Database | null = null;\n451: let restoreInProgress = false;\n452: let restoreBarrierHooks: RestoreBarrierHooks = {};\n453: \n454: const RESTORE_IN_PROGRESS_ERROR_CODE = 'E_RESTORE_IN_PROGRESS';\n455: const RESTORE_IN_PROGRESS_ERROR_MESSAGE = 'Checkpoint restore maintenance is in progress. Retry after the restore lifecycle completes.';\n456: \n457: /* ───────────────────────────────────────────────────────────────\n458:    4. INITIALIZATION\n459: ----------------------------------------------------------------*/\n460: \n461: function init(database: Database.Database): void {\n462:   db = database;\n463: }\n464: \n465: function getDatabase(): Database.Database {\n466:   if (!db) throw new Error('Database not initialized. The checkpoints module requires the MCP server to be running. Restart the MCP server and retry.');\n467:   return db;\n468: }\n469: \n470: function getErrorCode(error: unknown): string | null {\n471:   if (typeof error === 'object' && error !== null && 'code' in error) {\n472:     const code = (error as { code?: unknown }).code;\n473:     return typeof code === 'string' ? code : null;\n474:   }\n475:   return null;\n476: }\n477: \n478: function isCheckpointBusyError(error: unknown): boolean {\n479:   const code = getErrorCode(error);\n480:   const message = toErrorMessage(error);\n481:   return code === 'SQLITE_BUSY'\n482:     || code === 'SQLITE_LOCKED'\n483:     || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n484: }\n485: \n486: function classifyCheckpointCreateError(\n487:   error: unknown,\n488:   context: Record<string, unknown> = {},\n489: ): CheckpointCreateError {\n490:   if (error instanceof CheckpointCreateError) {\n491:     return error;\n492:   }\n493: \n494:   const originalCode = getErrorCode(error);\n495:   const message = toErrorMessage(error);\n496:   const details = {\n497:     ...context,\n498:     ...(originalCode ? { originalCode } : {}),\n499:     originalMessage: message,\n500:   };\n501: \n502:   if (originalCode === 'SQLITE_BUSY' || /\\bSQLITE_BUSY\\b|database is locked/i.test(message)) {\n503:     return new CheckpointCreateError(\n504:       'CHECKPOINT_CREATE_SQLITE_BUSY',\n505:       'Checkpoint creation failed because the SQLite database was busy. Retry after current writes finish.',\n506:       details,\n507:       error,\n508:     );\n509:   }\n510: \n511:   if (originalCode === 'SQLITE_LOCKED' || /\\bSQLITE_LOCKED\\b/i.test(message)) {\n512:     return new CheckpointCreateError(\n513:       'CHECKPOINT_CREATE_SQLITE_LOCKED',\n514:       'Checkpoint creation failed because the SQLite database was locked by another operation.',\n515:       details,\n516:       error,\n517:     );\n518:   }\n519: \n520:   if (/UNIQUE constraint failed: checkpoints\\.name|constraint failed/i.test(message)) {\n521:     return new CheckpointCreateError(\n522:       'CHECKPOINT_CREATE_DUPLICATE_NAME',\n523:       'Checkpoint creation failed because a checkpoint with this name already exists.',\n524:       details,\n525:       error,\n526:     );\n527:   }\n528: \n529:   if (\n530:     originalCode === 'EACCES'\n531:     || originalCode === 'EPERM'\n532:     || originalCode === 'SQLITE_READONLY'\n533:     || /permission denied|readonly|read-only/i.test(message)\n534:   ) {\n535:     return new CheckpointCreateError(\n536:       'CHECKPOINT_CREATE_PERMISSION_DENIED',\n537:       'Checkpoint creation failed because the database path is not writable.',\n538:       details,\n539:       error,\n540:     );\n541:   }\n542: \n543:   return new CheckpointCreateError(\n544:     'CHECKPOINT_CREATE_FAILED',\n545:     `Checkpoint creation failed: ${message}`,\n546:     details,\n547:     error,\n548:   );\n549: }\n550: \n551: function checkpointRetryDelayMs(): number {\n552:   return CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS\n553:     + Math.floor(Math.random() * (CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS - CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS + 1));\n554: }\n555: \n556: function isRestoreInProgress(): boolean {\n557:   return restoreInProgress;\n558: }\n559: \n560: function getRestoreBarrierStatus(): RestoreBarrierStatus | null {\n561:   if (!restoreInProgress) {\n562:     return null;\n563:   }\n564: \n565:   return {\n566:     code: RESTORE_IN_PROGRESS_ERROR_CODE,\n567:     message: RESTORE_IN_PROGRESS_ERROR_MESSAGE,\n568:   };\n569: }\n570: \n571: function setRestoreBarrierHooks(hooks: RestoreBarrierHooks | null): void {\n572:   restoreBarrierHooks = hooks ?? {};\n573: }\n574: \n575: function acquireRestoreBarrier(): void {\n576:   restoreInProgress = true;\n577:   restoreBarrierHooks.afterAcquire?.();\n578: }\n579: \n580: function releaseRestoreBarrier(): void {\n581:   try {\n582:     restoreBarrierHooks.beforeRelease?.();\n583:   } finally {\n584:     restoreInProgress = false;\n585:   }\n586: }\n587: \n588: /* ───────────────────────────────────────────────────────────────\n589:    5. HELPERS\n590: ----------------------------------------------------------------*/\n591: \n592: function getGitBranch(): string | null {\n593:   const candidates = [\n594:     process.env.GIT_BRANCH,\n595:     process.env.BRANCH_NAME,\n596:     process.env.CI_COMMIT_REF_NAME,\n597:     process.env.VERCEL_GIT_COMMIT_REF,\n598:   ];\n599: \n600:   for (const candidate of candidates) {\n601:     if (typeof candidate === 'string' && candidate.trim().length > 0) {\n602:       return candidate.trim();\n603:     }\n604:   }\n605: \n606:   return null;\n607: }\n608: \n609: function quoteSqlString(value: string): string {\n610:   return `'${value.replace(/'/g, \"''\")}'`;\n611: }\n612: \n613: function getDatabaseList(database: Database.Database): DatabaseListRow[] {\n614:   return database.prepare('PRAGMA database_list').all() as DatabaseListRow[];\n615: }\n616: \n617: function sanitizeCheckpointName(name: string): string {\n618:   const sanitized = name.trim();\n619:   if (\n\n(Showing lines 260-619 of 3364. Use offset=620 to continue.)\n</content>","metadata":{"preview":"    this.code = code;\n    this.originalCode = typeof details.originalCode === 'string' ? details.originalCode : null;\n    this.details = details;\n  }\n}\n\nclass CheckpointRestoreError extends Error {\n  public readonly code: CheckpointRestoreErrorCode;\n\n  constructor(code: CheckpointRestoreErrorCode, message: string, cause?: unknown) {\n    super(message, { cause });\n    Object.setPrototypeOf(this, CheckpointRestoreError.prototype);\n    this.name = 'CheckpointRestoreError';\n    this.code = code;\n  }\n}\n\ninterface RestoreCheckpointV2Options {\n  reopen?: (targetMainPath: string, swapFn: () => void) => Database.Database;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"    this.code = code;\n    this.originalCode = typeof details.originalCode === 'string' ? details.originalCode : null;\n    this.details = details;\n  }\n}\n\nclass CheckpointRestoreError extends Error {\n  public readonly code: CheckpointRestoreErrorCode;\n\n  constructor(code: CheckpointRestoreErrorCode, message: string, cause?: unknown) {\n    super(message, { cause });\n    Object.setPrototypeOf(this, CheckpointRestoreError.prototype);\n    this.name = 'CheckpointRestoreError';\n    this.code = code;\n  }\n}\n\ninterface RestoreCheckpointV2Options {\n  reopen?: (targetMainPath: string, swapFn: () => void) => Database.Database;\n}\n\ninterface RestoreResult {\n  restored: number;\n  skipped: number;\n  errors: string[];\n  workingMemoryRestored: number;\n  partialFailure?: boolean;\n  rolledBackTables?: string[];\n}\n\ninterface DerivedRebuildFailure {\n  name: string;\n  error: string;\n}\n\ninterface DerivedRebuildSkipped {\n  name: string;\n  reason: string;\n}\n\ninterface DerivedRebuildSummary {\n  completed: string[];\n  failed: DerivedRebuildFailure[];\n  skipped: DerivedRebuildSkipped[];\n}\n\ninterface RunDerivedArtifactRebuildOptions {\n  specFolder?: string | null;\n  actor?: string;\n  logContext?: string;\n}\n\ninterface NeedsRebuildSentinelFile {\n  formatVersion: 1;\n  createdAt: string;\n  source: string;\n  reason: string;\n  rebuildSummary?: DerivedRebuildSummary;\n}\n\ninterface NeedsRebuildSentinelWriteOptions {\n  source: string;\n  reason: string;\n  summary?: DerivedRebuildSummary;\n}\n\ninterface NeedsRebuildRepairOptions {\n  source: string;\n  specFolder?: string | null;\n  actor?: string;\n}\n\ninterface NeedsRebuildRepairResult {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  cleared: boolean;\n  summary: DerivedRebuildSummary | null;\n  error: string | null;\n}\n\ninterface SnapshotVectorRow {\n  rowid: number;\n  embedding: Buffer | null;\n}\n\ninterface TableSnapshot {\n  columns: string[];\n  rows: Array<Record<string, unknown>>;\n}\n\ninterface CheckpointManifest {\n  snapshot: string[];\n  rebuild: string[];\n  skip: string[];\n}\n\ninterface CheckpointSnapshot {\n  manifest?: CheckpointManifest;\n  tables?: Record<string, TableSnapshot>;\n  memories: Array<Record<string, unknown>>;\n  workingMemory: Array<Record<string, unknown>>;\n  vectors?: SnapshotVectorRow[];\n  causalEdges?: Array<Record<string, unknown>>;\n  timestamp: string;\n}\n\ninterface DatabaseListRow {\n  seq?: number;\n  name?: string;\n  file?: string;\n}\n\ninterface CheckpointV2Manifest {\n  formatVersion: 2;\n  createdAt: string;\n  specFolder: null;\n  gitBranch: string | null;\n  embedderSlug: string | null;\n  includeEmbeddings: boolean;\n  mainTables: string[];\n  vecTables: string[];\n  schemaVersion: number;\n  memoryCount: number;\n  vectorCount: number;\n  mainBytes: number;\n  vecBytes: number;\n}\n\ntype RestoreJournalPhase = 'swap-pending' | 'swap-done';\n\ninterface RestoreJournalFile {\n  formatVersion: 1;\n  phase: RestoreJournalPhase;\n  createdAt: string;\n  checkpointName: string;\n  liveMainPath: string;\n  backupMainPath: string;\n  snapshotMainPath: string;\n  liveShardPath: string | null;\n  backupShardPath: string | null;\n  snapshotVecPath: string | null;\n  shouldRestoreVec: boolean;\n  liveShardPreexisted: boolean;\n}\n\n// Validate the decompressed checkpoint snapshot before\n// restore. Previously the gzipped blob was JSON.parsed and cast directly\n// to CheckpointSnapshot — malformed memory_index rows propagated through\n// `getMemoryIds()` and the INSERT loops. This schema validates the\n// outer envelope and the array shapes; individual row shapes are still\n// permissive (sqlite columns evolve over time) but each row must be a\n// non-null object so downstream column extraction doesn't NPE.\nconst CheckpointTableSnapshotSchema = z.object({\n  columns: z.array(z.string()),\n  rows: z.array(z.record(z.string(), z.unknown())),\n});\n\nconst CheckpointVectorRowSchema = z.object({\n  rowid: z.number(),\n  embedding: z.unknown(), // Buffer or null — preserved as-is\n});\n\nconst CheckpointSnapshotSchema = z.object({\n  manifest: z.object({\n    snapshot: z.array(z.string()),\n    rebuild: z.array(z.string()),\n    skip: z.array(z.string()),\n  }).optional(),\n  tables: z.record(z.string(), CheckpointTableSnapshotSchema).optional(),\n  memories: z.array(z.record(z.string(), z.unknown())),\n  workingMemory: z.array(z.record(z.string(), z.unknown())),\n  vectors: z.array(CheckpointVectorRowSchema).optional(),\n  causalEdges: z.array(z.record(z.string(), z.unknown())).optional(),\n  timestamp: z.string(),\n}).passthrough();\n\ninterface RestoreBarrierStatus {\n  code: string;\n  message: string;\n}\n\ninterface RestoreBarrierHooks {\n  afterAcquire?: (() => void) | null;\n  beforeRelease?: (() => void) | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet restoreInProgress = false;\nlet restoreBarrierHooks: RestoreBarrierHooks = {};\n\nconst RESTORE_IN_PROGRESS_ERROR_CODE = 'E_RESTORE_IN_PROGRESS';\nconst RESTORE_IN_PROGRESS_ERROR_MESSAGE = 'Checkpoint restore maintenance is in progress. Retry after the restore lifecycle completes.';\n\n/* ───────────────────────────────────────────────────────────────\n   4. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction init(database: Database.Database): void {\n  db = database;\n}\n\nfunction getDatabase(): Database.Database {\n  if (!db) throw new Error('Database not initialized. The checkpoints module requires the MCP server to be running. Restart the MCP server and retry.');\n  return db;\n}\n\nfunction getErrorCode(error: unknown): string | null {\n  if (typeof error === 'object' && error !== null && 'code' in error) {\n    const code = (error as { code?: unknown }).code;\n    return typeof code === 'string' ? code : null;\n  }\n  return null;\n}\n\nfunction isCheckpointBusyError(error: unknown): boolean {\n  const code = getErrorCode(error);\n  const message = toErrorMessage(error);\n  return code === 'SQLITE_BUSY'\n    || code === 'SQLITE_LOCKED'\n    || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n}\n\nfunction classifyCheckpointCreateError(\n  error: unknown,\n  context: Record<string, unknown> = {},\n): CheckpointCreateError {\n  if (error instanceof CheckpointCreateError) {\n    return error;\n  }\n\n  const originalCode = getErrorCode(error);\n  const message = toErrorMessage(error);\n  const details = {\n    ...context,\n    ...(originalCode ? { originalCode } : {}),\n    originalMessage: message,\n  };\n\n  if (originalCode === 'SQLITE_BUSY' || /\\bSQLITE_BUSY\\b|database is locked/i.test(message)) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_SQLITE_BUSY',\n      'Checkpoint creation failed because the SQLite database was busy. Retry after current writes finish.',\n      details,\n      error,\n    );\n  }\n\n  if (originalCode === 'SQLITE_LOCKED' || /\\bSQLITE_LOCKED\\b/i.test(message)) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_SQLITE_LOCKED',\n      'Checkpoint creation failed because the SQLite database was locked by another operation.',\n      details,\n      error,\n    );\n  }\n\n  if (/UNIQUE constraint failed: checkpoints\\.name|constraint failed/i.test(message)) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_DUPLICATE_NAME',\n      'Checkpoint creation failed because a checkpoint with this name already exists.',\n      details,\n      error,\n    );\n  }\n\n  if (\n    originalCode === 'EACCES'\n    || originalCode === 'EPERM'\n    || originalCode === 'SQLITE_READONLY'\n    || /permission denied|readonly|read-only/i.test(message)\n  ) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_PERMISSION_DENIED',\n      'Checkpoint creation failed because the database path is not writable.',\n      details,\n      error,\n    );\n  }\n\n  return new CheckpointCreateError(\n    'CHECKPOINT_CREATE_FAILED',\n    `Checkpoint creation failed: ${message}`,\n    details,\n    error,\n  );\n}\n\nfunction checkpointRetryDelayMs(): number {\n  return CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS\n    + Math.floor(Math.random() * (CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS - CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS + 1));\n}\n\nfunction isRestoreInProgress(): boolean {\n  return restoreInProgress;\n}\n\nfunction getRestoreBarrierStatus(): RestoreBarrierStatus | null {\n  if (!restoreInProgress) {\n    return null;\n  }\n\n  return {\n    code: RESTORE_IN_PROGRESS_ERROR_CODE,\n    message: RESTORE_IN_PROGRESS_ERROR_MESSAGE,\n  };\n}\n\nfunction setRestoreBarrierHooks(hooks: RestoreBarrierHooks | null): void {\n  restoreBarrierHooks = hooks ?? {};\n}\n\nfunction acquireRestoreBarrier(): void {\n  restoreInProgress = true;\n  restoreBarrierHooks.afterAcquire?.();\n}\n\nfunction releaseRestoreBarrier(): void {\n  try {\n    restoreBarrierHooks.beforeRelease?.();\n  } finally {\n    restoreInProgress = false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. HELPERS\n----------------------------------------------------------------*/\n\nfunction getGitBranch(): string | null {\n  const candidates = [\n    process.env.GIT_BRANCH,\n    process.env.BRANCH_NAME,\n    process.env.CI_COMMIT_REF_NAME,\n    process.env.VERCEL_GIT_COMMIT_REF,\n  ];\n\n  for (const candidate of candidates) {\n    if (typeof candidate === 'string' && candidate.trim().length > 0) {\n      return candidate.trim();\n    }\n  }\n\n  return null;\n}\n\nfunction quoteSqlString(value: string): string {\n  return `'${value.replace(/'/g, \"''\")}'`;\n}\n\nfunction getDatabaseList(database: Database.Database): DatabaseListRow[] {\n  return database.prepare('PRAGMA database_list').all() as DatabaseListRow[];\n}\n\nfunction sanitizeCheckpointName(name: string): string {\n  const sanitized = name.trim();\n  if (","lineStart":260,"lineEnd":619,"totalLines":3364,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781761641852,"end":1781761641860}},"metadata":{"openai":{"itemId":"fc_06c8be0c896a84df016a3386699d688191b9b5dab8898bbcd5"}},"id":"prt_ed9450d6d001TYXxB8p2PRfsbD","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed944dca1001Zh7E4l7FT65Dk6"}}
{"type":"tool_use","timestamp":1781761641863,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_TQpwHr3AJcL1mASQjovNG1Hk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":620,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n620:     sanitized.length === 0\n621:     || sanitized.length > 128\n622:     || sanitized.includes('/')\n623:     || sanitized.includes('\\\\')\n624:     || sanitized.includes('..')\n625:     || sanitized.includes('\\0')\n626:   ) {\n627:     throw new CheckpointCreateError(\n628:       'CHECKPOINT_CREATE_INVALID_NAME',\n629:       'Checkpoint creation failed because the checkpoint name is invalid.',\n630:       { name },\n631:     );\n632:   }\n633:   return sanitized;\n634: }\n635: \n636: function resolveCheckpointDir(database: Database.Database, name: string): string {\n637:   const sanitizedName = sanitizeCheckpointName(name);\n638:   const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n639:   const mainFile = mainRow?.file;\n640:   if (!mainFile || mainFile === ':memory:') {\n641:     throw new CheckpointCreateError(\n642:       'CHECKPOINT_CREATE_FAILED',\n643:       'Checkpoint creation failed because the main database file path could not be resolved.',\n644:       { name: sanitizedName },\n645:     );\n646:   }\n647:   return path.join(path.dirname(mainFile), 'checkpoints', sanitizedName);\n648: }\n649: \n650: function getActiveVectorShardPath(database: Database.Database): string | null {\n651:   const activeVec = getDatabaseList(database).find((row) => row.name === 'active_vec');\n652:   return activeVec?.file && activeVec.file.length > 0 ? activeVec.file : null;\n653: }\n654: \n655: function deriveEmbedderSlug(shardPath: string | null): string | null {\n656:   if (!shardPath) {\n657:     return null;\n658:   }\n659:   const match = /^context-vectors__(.+)\\.sqlite$/.exec(path.basename(shardPath));\n660:   return match?.[1] ?? null;\n661: }\n662: \n663: function sweepStaleCheckpointTmpDirs(checkpointsDir: string): void {\n664:   if (!fs.existsSync(checkpointsDir)) {\n665:     return;\n666:   }\n667:   for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n668:     if (entry.isDirectory() && entry.name.includes('.tmp-')) {\n669:       fs.rmSync(path.join(checkpointsDir, entry.name), { recursive: true, force: true });\n670:     }\n671:   }\n672: }\n673: \n674: function resolvePathSafe(targetPath: string): string {\n675:   try {\n676:     return fs.realpathSync(targetPath);\n677:   } catch (_error: unknown) {\n678:     return path.resolve(targetPath);\n679:   }\n680: }\n681: \n682: function sweepOrphanCheckpointSnapshotDirs(database: Database.Database, checkpointsDir: string): void {\n683:   // Checkpoint pruning removes the catalog row inside the create transaction but deletes\n684:   // the snapshot dir AFTER commit. A crash in that gap leaves a snapshot dir with no\n685:   // catalog row — never swept by the .tmp-* sweep (it has a published name) and never\n686:   // restorable. Reconcile on-disk v2 snapshot dirs against the live catalog and remove\n687:   // any that no catalog row references. Best-effort: never throw out of the create path.\n688:   try {\n689:     if (!fs.existsSync(checkpointsDir) || !tableExists(database, 'checkpoints')) {\n690:       return;\n691:     }\n692: \n693:     const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n694:     if (!checkpointColumns.has('snapshot_path')) {\n695:       return;\n696:     }\n697:     const referenced = new Set<string>();\n698:     const rows = database.prepare(\n699:       \"SELECT snapshot_path FROM checkpoints WHERE snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n700:     ).all() as Array<{ snapshot_path?: string | null }>;\n701:     for (const row of rows) {\n702:       if (typeof row.snapshot_path === 'string' && row.snapshot_path.length > 0) {\n703:         referenced.add(resolvePathSafe(row.snapshot_path));\n704:       }\n705:     }\n706: \n707:     for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n708:       if (!entry.isDirectory() || entry.name.includes('.tmp-')) {\n709:         continue;\n710:       }\n711:       const entryPath = path.join(checkpointsDir, entry.name);\n712:       if (referenced.has(resolvePathSafe(entryPath))) {\n713:         continue;\n714:       }\n715:       try {\n716:         fs.rmSync(entryPath, { recursive: true, force: true });\n717:         console.warn(`[checkpoints] Swept orphan checkpoint snapshot dir with no catalog row: ${entry.name}`);\n718:       } catch (_removeError: unknown) {\n719:         // Best-effort: a single un-removable dir must not block checkpoint creation.\n720:       }\n721:     }\n722:   } catch (error: unknown) {\n723:     console.warn(`[checkpoints] Orphan checkpoint snapshot sweep skipped (non-fatal): ${toErrorMessage(error)}`);\n724:   }\n725: }\n726: \n727: function readSchemaVersion(database: Database.Database): number | null {\n728:   try {\n729:     const row = database.prepare('SELECT version FROM schema_version WHERE id = 1').get() as { version?: number } | undefined;\n730:     return typeof row?.version === 'number' ? row.version : null;\n731:   } catch (_error: unknown) {\n732:     return null;\n733:   }\n734: }\n735: \n736: function countTableRows(database: Database.Database, tableName: string): number {\n737:   if (!tableExists(database, tableName)) {\n738:     return 0;\n739:   }\n740:   const row = database.prepare(`SELECT COUNT(*) AS count FROM ${tableName}`).get() as { count?: number } | undefined;\n741:   return typeof row?.count === 'number' ? row.count : 0;\n742: }\n743: \n744: function countActiveVectorRows(database: Database.Database): number {\n745:   try {\n746:     const row = database.prepare(`\n747:       SELECT 1 AS found\n748:       FROM active_vec.sqlite_master\n749:       WHERE type IN ('table', 'view') AND name = 'vec_memories'\n750:       LIMIT 1\n751:     `).get() as { found?: number } | undefined;\n752:     if (row?.found !== 1) {\n753:       return 0;\n754:     }\n755:     const countRow = database.prepare('SELECT COUNT(*) AS count FROM active_vec.vec_memories').get() as { count?: number } | undefined;\n756:     return typeof countRow?.count === 'number' ? countRow.count : 0;\n757:   } catch (_error: unknown) {\n758:     return 0;\n759:   }\n760: }\n761: \n762: function readCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest | null {\n763:   if (!snapshotPath) {\n764:     return null;\n765:   }\n766:   try {\n767:     const raw = fs.readFileSync(path.join(snapshotPath, 'manifest.json'), 'utf-8');\n768:     const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n769:     return parsed.formatVersion === 2 ? parsed as CheckpointV2Manifest : null;\n770:   } catch (_error: unknown) {\n771:     return null;\n772:   }\n773: }\n774: \n775: function loadCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest {\n776:   if (!snapshotPath) {\n777:     throw new CheckpointRestoreError(\n778:       'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n779:       'Checkpoint v2 restore failed because snapshot_path is missing.',\n780:     );\n781:   }\n782: \n783:   const manifestPath = path.join(snapshotPath, 'manifest.json');\n784:   try {\n785:     const raw = fs.readFileSync(manifestPath, 'utf-8');\n786:     const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n787:     if (\n788:       parsed.formatVersion !== 2\n789:       || typeof parsed.includeEmbeddings !== 'boolean'\n790:       || !Array.isArray(parsed.mainTables)\n791:       || !Array.isArray(parsed.vecTables)\n792:       || typeof parsed.schemaVersion !== 'number'\n793:       || typeof parsed.memoryCount !== 'number'\n794:       || typeof parsed.vectorCount !== 'number'\n795:     ) {\n796:       throw new Error('manifest shape is invalid');\n797:     }\n798:     return parsed as CheckpointV2Manifest;\n799:   } catch (error: unknown) {\n800:     throw new CheckpointRestoreError(\n801:       'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n802:       `Checkpoint v2 restore failed because manifest.json could not be read: ${toErrorMessage(error)}`,\n803:       error,\n804:     );\n805:   }\n806: }\n807: \n808: function resolveMainDatabasePath(database: Database.Database): string {\n809:   const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n810:   const mainFile = mainRow?.file;\n811:   if (!mainFile || mainFile === ':memory:') {\n812:     throw new CheckpointRestoreError(\n813:       'CHECKPOINT_RESTORE_PATH_UNRESOLVED',\n814:       'Checkpoint v2 restore failed because the live main database path could not be resolved.',\n815:     );\n816:   }\n817:   return mainFile;\n818: }\n819: \n820: function removeSqliteSidecars(databasePath: string): void {\n821:   for (const sidecarPath of [`${databasePath}-wal`, `${databasePath}-shm`]) {\n822:     fs.rmSync(sidecarPath, { force: true });\n823:   }\n824: }\n825: \n826: function getRestoreJournalPath(liveMainPath: string): string {\n827:   return path.join(path.dirname(liveMainPath), 'checkpoints', RESTORE_JOURNAL_NAME);\n828: }\n829: \n830: function getNeedsRebuildSentinelPath(liveMainPath: string): string {\n831:   return path.join(path.dirname(liveMainPath), 'checkpoints', NEEDS_REBUILD_SENTINEL_NAME);\n832: }\n833: \n834: function fsyncFileIfPossible(filePath: string): void {\n835:   let fd: number | null = null;\n836:   try {\n837:     fd = fs.openSync(filePath, 'r');\n838:     fs.fsyncSync(fd);\n839:   } catch (_error: unknown) {\n840:     // Best-effort durability; the next boot still treats any visible journal as authoritative.\n841:   } finally {\n842:     if (fd !== null) {\n843:       try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n844:     }\n845:   }\n846: }\n847: \n848: function fsyncDirectoryIfPossible(dirPath: string): void {\n849:   let fd: number | null = null;\n850:   try {\n851:     fd = fs.openSync(dirPath, 'r');\n852:     fs.fsyncSync(fd);\n853:   } catch (_error: unknown) {\n854:     // Directory fsync is unavailable on some platforms/filesystems.\n855:   } finally {\n856:     if (fd !== null) {\n857:       try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n858:     }\n859:   }\n860: }\n861: \n862: function writeRestoreJournal(journalPath: string, journal: RestoreJournalFile): void {\n863:   const journalDir = path.dirname(journalPath);\n864:   const tempJournalPath = `${journalPath}.tmp`;\n865:   fs.mkdirSync(journalDir, { recursive: true, mode: 0o700 });\n866:   fs.writeFileSync(tempJournalPath, `${JSON.stringify(journal, null, 2)}\\n`, { mode: 0o600 });\n867:   fsyncFileIfPossible(tempJournalPath);\n868:   fs.renameSync(tempJournalPath, journalPath);\n869:   fsyncDirectoryIfPossible(journalDir);\n870: }\n871: \n872: function clearRestoreJournal(journalPath: string): void {\n873:   fs.rmSync(journalPath, { force: true });\n874:   fsyncDirectoryIfPossible(path.dirname(journalPath));\n875: }\n876: \n877: function writeNeedsRebuildSentinelAtPath(\n878:   sentinelPath: string,\n879:   options: NeedsRebuildSentinelWriteOptions,\n880: ): void {\n881:   const sentinelDir = path.dirname(sentinelPath);\n882:   const tempSentinelPath = `${sentinelPath}.tmp`;\n883:   const sentinel: NeedsRebuildSentinelFile = {\n884:     formatVersion: 1,\n885:     createdAt: new Date().toISOString(),\n886:     source: options.source,\n887:     reason: options.reason,\n888:     ...(options.summary ? { rebuildSummary: options.summary } : {}),\n889:   };\n890: \n891:   fs.mkdirSync(sentinelDir, { recursive: true, mode: 0o700 });\n892:   fs.writeFileSync(tempSentinelPath, `${JSON.stringify(sentinel, null, 2)}\\n`, { mode: 0o600 });\n893:   fsyncFileIfPossible(tempSentinelPath);\n894:   fs.renameSync(tempSentinelPath, sentinelPath);\n895:   fsyncDirectoryIfPossible(sentinelDir);\n896: }\n897: \n898: function clearNeedsRebuildSentinelAtPath(sentinelPath: string): boolean {\n899:   const existed = fs.existsSync(sentinelPath);\n900:   fs.rmSync(sentinelPath, { force: true });\n901:   if (existed) {\n902:     fsyncDirectoryIfPossible(path.dirname(sentinelPath));\n903:   }\n904:   return existed;\n905: }\n906: \n907: function getNeedsRebuildSentinelPathForDatabase(database: Database.Database): string | null {\n908:   try {\n909:     return getNeedsRebuildSentinelPath(resolveMainDatabasePath(database));\n910:   } catch (_error: unknown) {\n911:     return null;\n912:   }\n913: }\n914: \n915: function hasNeedsRebuildSentinel(database: Database.Database): boolean {\n916:   const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n917:   return sentinelPath !== null && fs.existsSync(sentinelPath);\n918: }\n919: \n920: function writeNeedsRebuildSentinelForDatabase(\n921:   database: Database.Database,\n922:   options: NeedsRebuildSentinelWriteOptions,\n923: ): string | null {\n924:   const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n925:   if (sentinelPath === null) {\n926:     return null;\n927:   }\n928:   writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n929:   return sentinelPath;\n930: }\n931: \n932: function writeNeedsRebuildSentinelForMainPath(\n933:   liveMainPath: string,\n934:   options: NeedsRebuildSentinelWriteOptions,\n935: ): string {\n936:   const sentinelPath = getNeedsRebuildSentinelPath(liveMainPath);\n937:   writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n938:   return sentinelPath;\n939: }\n940: \n941: function clearNeedsRebuildSentinelForDatabase(database: Database.Database): boolean {\n942:   const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n943:   if (sentinelPath === null) {\n944:     return false;\n945:   }\n946:   return clearNeedsRebuildSentinelAtPath(sentinelPath);\n947: }\n948: \n949: function removeRestoreBackupIfPossible(backupPath: string): void {\n950:   try {\n951:     fs.rmSync(backupPath, { force: true });\n952:   } catch (error: unknown) {\n953:     console.warn(`[checkpoints] restore backup cleanup skipped for ${backupPath}: ${toErrorMessage(error)}`);\n954:   }\n955: }\n956: \n957: function readCheckpointCatalogRows(database: Database.Database): Array<Record<string, unknown>> {\n958:   if (!tableExists(database, 'checkpoints')) {\n959:     return [];\n960:   }\n961:   return database.prepare('SELECT * FROM checkpoints ORDER BY id ASC').all() as Array<Record<string, unknown>>;\n962: }\n963: \n964: function mergeCheckpointCatalogRows(database: Database.Database, rows: Array<Record<string, unknown>>): void {\n965:   if (rows.length === 0 || !tableExists(database, 'checkpoints')) {\n966:     return;\n967:   }\n968: \n969:   const targetColumns = new Set(getTableColumns(database, 'checkpoints'));\n970:   for (const row of rows) {\n971:     const name = row.name;\n972:     if (typeof name !== 'string' || name.length === 0) {\n973:       continue;\n974:     }\n975:     const existingByName = database.prepare('SELECT id FROM checkpoints WHERE name = ?').get(name) as { id?: number } | undefined;\n976:     if (existingByName?.id) {\n977:       continue;\n978:     }\n979: \n980:     let columns = Object.keys(row).filter((column) => targetColumns.has(column));\n981:     const id = row.id;\n982:     if (typeof id === 'number') {\n983:       const existingById = database.prepare('SELECT name FROM checkpoints WHERE id = ?').get(id) as { name?: string } | undefined;\n984:       if (existingById?.name && existingById.name !== name) {\n985:         columns = columns.filter((column) => column !== 'id');\n986:       }\n987:     }\n988:     if (columns.length === 0) {\n989:       continue;\n990:     }\n991: \n992:     const placeholders = columns.map(() => '?').join(', ');\n993:     database.prepare(`\n994:       INSERT OR IGNORE INTO checkpoints (${columns.join(', ')})\n995:       VALUES (${placeholders})\n996:     `).run(...columns.map((column) => row[column]));\n997:   }\n998: }\n999: \n1000: function pruneCheckpointCatalogRowsMissingSnapshots(database: Database.Database): void {\n1001:   // The restored snapshot-main DB carries the full checkpoints table as of the\n1002:   // snapshot, including v2 rows whose snapshot dir was deleted after the snapshot\n1003:   // was taken. Those rows would resurface in listCheckpoints with no restorable\n1004:   // dir, so drop any v2 row whose snapshot_path no longer exists on disk.\n1005:   // Best-effort: never throw out of the restore path.\n1006:   try {\n1007:     if (!tableExists(database, 'checkpoints')) {\n1008:       return;\n1009:     }\n1010:     const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n1011:     if (!checkpointColumns.has('snapshot_path') || !checkpointColumns.has('snapshot_format')) {\n1012:       return;\n1013:     }\n1014:     const rows = database.prepare(\n1015:       \"SELECT id, snapshot_path FROM checkpoints WHERE snapshot_format = 'v2' AND snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n1016:     ).all() as Array<{ id: number; snapshot_path: string }>;\n1017:     for (const row of rows) {\n1018:       if (!fs.existsSync(row.snapshot_path)) {\n1019:         database.prepare('DELETE FROM checkpoints WHERE id = ?').run(row.id);\n1020:         console.warn(`[checkpoints] Dropped restored catalog row with missing snapshot dir: ${row.snapshot_path}`);\n1021:       }\n1022:     }\n1023:   } catch (error: unknown) {\n1024:     console.warn(`[checkpoints] Post-restore catalog reconciliation skipped (non-fatal): ${toErrorMessage(error)}`);\n1025:   }\n1026: }\n1027: \n1028: function statPathBytes(targetPath: string): number {\n1029:   try {\n1030:     const stats = fs.statSync(targetPath);\n1031:     if (stats.isFile()) {\n1032:       return stats.size;\n1033:     }\n1034:     if (!stats.isDirectory()) {\n1035:       return 0;\n1036:     }\n1037:     return fs.readdirSync(targetPath).reduce((total, entry) => total + statPathBytes(path.join(targetPath, entry)), 0);\n1038:   } catch (_error: unknown) {\n1039:     return 0;\n\n(Showing lines 620-1039 of 3364. Use offset=1040 to continue.)\n</content>","metadata":{"preview":"    sanitized.length === 0\n    || sanitized.length > 128\n    || sanitized.includes('/')\n    || sanitized.includes('\\\\')\n    || sanitized.includes('..')\n    || sanitized.includes('\\0')\n  ) {\n    throw new CheckpointCreateError(\n      'CHECKPOINT_CREATE_INVALID_NAME',\n      'Checkpoint creation failed because the checkpoint name is invalid.',\n      { name },\n    );\n  }\n  return sanitized;\n}\n\nfunction resolveCheckpointDir(database: Database.Database, name: string): string {\n  const sanitizedName = sanitizeCheckpointName(name);\n  const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n  const mainFile = mainRow?.file;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"    sanitized.length === 0\n    || sanitized.length > 128\n    || sanitized.includes('/')\n    || sanitized.includes('\\\\')\n    || sanitized.includes('..')\n    || sanitized.includes('\\0')\n  ) {\n    throw new CheckpointCreateError(\n      'CHECKPOINT_CREATE_INVALID_NAME',\n      'Checkpoint creation failed because the checkpoint name is invalid.',\n      { name },\n    );\n  }\n  return sanitized;\n}\n\nfunction resolveCheckpointDir(database: Database.Database, name: string): string {\n  const sanitizedName = sanitizeCheckpointName(name);\n  const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n  const mainFile = mainRow?.file;\n  if (!mainFile || mainFile === ':memory:') {\n    throw new CheckpointCreateError(\n      'CHECKPOINT_CREATE_FAILED',\n      'Checkpoint creation failed because the main database file path could not be resolved.',\n      { name: sanitizedName },\n    );\n  }\n  return path.join(path.dirname(mainFile), 'checkpoints', sanitizedName);\n}\n\nfunction getActiveVectorShardPath(database: Database.Database): string | null {\n  const activeVec = getDatabaseList(database).find((row) => row.name === 'active_vec');\n  return activeVec?.file && activeVec.file.length > 0 ? activeVec.file : null;\n}\n\nfunction deriveEmbedderSlug(shardPath: string | null): string | null {\n  if (!shardPath) {\n    return null;\n  }\n  const match = /^context-vectors__(.+)\\.sqlite$/.exec(path.basename(shardPath));\n  return match?.[1] ?? null;\n}\n\nfunction sweepStaleCheckpointTmpDirs(checkpointsDir: string): void {\n  if (!fs.existsSync(checkpointsDir)) {\n    return;\n  }\n  for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n    if (entry.isDirectory() && entry.name.includes('.tmp-')) {\n      fs.rmSync(path.join(checkpointsDir, entry.name), { recursive: true, force: true });\n    }\n  }\n}\n\nfunction resolvePathSafe(targetPath: string): string {\n  try {\n    return fs.realpathSync(targetPath);\n  } catch (_error: unknown) {\n    return path.resolve(targetPath);\n  }\n}\n\nfunction sweepOrphanCheckpointSnapshotDirs(database: Database.Database, checkpointsDir: string): void {\n  // Checkpoint pruning removes the catalog row inside the create transaction but deletes\n  // the snapshot dir AFTER commit. A crash in that gap leaves a snapshot dir with no\n  // catalog row — never swept by the .tmp-* sweep (it has a published name) and never\n  // restorable. Reconcile on-disk v2 snapshot dirs against the live catalog and remove\n  // any that no catalog row references. Best-effort: never throw out of the create path.\n  try {\n    if (!fs.existsSync(checkpointsDir) || !tableExists(database, 'checkpoints')) {\n      return;\n    }\n\n    const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n    if (!checkpointColumns.has('snapshot_path')) {\n      return;\n    }\n    const referenced = new Set<string>();\n    const rows = database.prepare(\n      \"SELECT snapshot_path FROM checkpoints WHERE snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n    ).all() as Array<{ snapshot_path?: string | null }>;\n    for (const row of rows) {\n      if (typeof row.snapshot_path === 'string' && row.snapshot_path.length > 0) {\n        referenced.add(resolvePathSafe(row.snapshot_path));\n      }\n    }\n\n    for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n      if (!entry.isDirectory() || entry.name.includes('.tmp-')) {\n        continue;\n      }\n      const entryPath = path.join(checkpointsDir, entry.name);\n      if (referenced.has(resolvePathSafe(entryPath))) {\n        continue;\n      }\n      try {\n        fs.rmSync(entryPath, { recursive: true, force: true });\n        console.warn(`[checkpoints] Swept orphan checkpoint snapshot dir with no catalog row: ${entry.name}`);\n      } catch (_removeError: unknown) {\n        // Best-effort: a single un-removable dir must not block checkpoint creation.\n      }\n    }\n  } catch (error: unknown) {\n    console.warn(`[checkpoints] Orphan checkpoint snapshot sweep skipped (non-fatal): ${toErrorMessage(error)}`);\n  }\n}\n\nfunction readSchemaVersion(database: Database.Database): number | null {\n  try {\n    const row = database.prepare('SELECT version FROM schema_version WHERE id = 1').get() as { version?: number } | undefined;\n    return typeof row?.version === 'number' ? row.version : null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction countTableRows(database: Database.Database, tableName: string): number {\n  if (!tableExists(database, tableName)) {\n    return 0;\n  }\n  const row = database.prepare(`SELECT COUNT(*) AS count FROM ${tableName}`).get() as { count?: number } | undefined;\n  return typeof row?.count === 'number' ? row.count : 0;\n}\n\nfunction countActiveVectorRows(database: Database.Database): number {\n  try {\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM active_vec.sqlite_master\n      WHERE type IN ('table', 'view') AND name = 'vec_memories'\n      LIMIT 1\n    `).get() as { found?: number } | undefined;\n    if (row?.found !== 1) {\n      return 0;\n    }\n    const countRow = database.prepare('SELECT COUNT(*) AS count FROM active_vec.vec_memories').get() as { count?: number } | undefined;\n    return typeof countRow?.count === 'number' ? countRow.count : 0;\n  } catch (_error: unknown) {\n    return 0;\n  }\n}\n\nfunction readCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest | null {\n  if (!snapshotPath) {\n    return null;\n  }\n  try {\n    const raw = fs.readFileSync(path.join(snapshotPath, 'manifest.json'), 'utf-8');\n    const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n    return parsed.formatVersion === 2 ? parsed as CheckpointV2Manifest : null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction loadCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest {\n  if (!snapshotPath) {\n    throw new CheckpointRestoreError(\n      'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n      'Checkpoint v2 restore failed because snapshot_path is missing.',\n    );\n  }\n\n  const manifestPath = path.join(snapshotPath, 'manifest.json');\n  try {\n    const raw = fs.readFileSync(manifestPath, 'utf-8');\n    const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n    if (\n      parsed.formatVersion !== 2\n      || typeof parsed.includeEmbeddings !== 'boolean'\n      || !Array.isArray(parsed.mainTables)\n      || !Array.isArray(parsed.vecTables)\n      || typeof parsed.schemaVersion !== 'number'\n      || typeof parsed.memoryCount !== 'number'\n      || typeof parsed.vectorCount !== 'number'\n    ) {\n      throw new Error('manifest shape is invalid');\n    }\n    return parsed as CheckpointV2Manifest;\n  } catch (error: unknown) {\n    throw new CheckpointRestoreError(\n      'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n      `Checkpoint v2 restore failed because manifest.json could not be read: ${toErrorMessage(error)}`,\n      error,\n    );\n  }\n}\n\nfunction resolveMainDatabasePath(database: Database.Database): string {\n  const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n  const mainFile = mainRow?.file;\n  if (!mainFile || mainFile === ':memory:') {\n    throw new CheckpointRestoreError(\n      'CHECKPOINT_RESTORE_PATH_UNRESOLVED',\n      'Checkpoint v2 restore failed because the live main database path could not be resolved.',\n    );\n  }\n  return mainFile;\n}\n\nfunction removeSqliteSidecars(databasePath: string): void {\n  for (const sidecarPath of [`${databasePath}-wal`, `${databasePath}-shm`]) {\n    fs.rmSync(sidecarPath, { force: true });\n  }\n}\n\nfunction getRestoreJournalPath(liveMainPath: string): string {\n  return path.join(path.dirname(liveMainPath), 'checkpoints', RESTORE_JOURNAL_NAME);\n}\n\nfunction getNeedsRebuildSentinelPath(liveMainPath: string): string {\n  return path.join(path.dirname(liveMainPath), 'checkpoints', NEEDS_REBUILD_SENTINEL_NAME);\n}\n\nfunction fsyncFileIfPossible(filePath: string): void {\n  let fd: number | null = null;\n  try {\n    fd = fs.openSync(filePath, 'r');\n    fs.fsyncSync(fd);\n  } catch (_error: unknown) {\n    // Best-effort durability; the next boot still treats any visible journal as authoritative.\n  } finally {\n    if (fd !== null) {\n      try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction fsyncDirectoryIfPossible(dirPath: string): void {\n  let fd: number | null = null;\n  try {\n    fd = fs.openSync(dirPath, 'r');\n    fs.fsyncSync(fd);\n  } catch (_error: unknown) {\n    // Directory fsync is unavailable on some platforms/filesystems.\n  } finally {\n    if (fd !== null) {\n      try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction writeRestoreJournal(journalPath: string, journal: RestoreJournalFile): void {\n  const journalDir = path.dirname(journalPath);\n  const tempJournalPath = `${journalPath}.tmp`;\n  fs.mkdirSync(journalDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(tempJournalPath, `${JSON.stringify(journal, null, 2)}\\n`, { mode: 0o600 });\n  fsyncFileIfPossible(tempJournalPath);\n  fs.renameSync(tempJournalPath, journalPath);\n  fsyncDirectoryIfPossible(journalDir);\n}\n\nfunction clearRestoreJournal(journalPath: string): void {\n  fs.rmSync(journalPath, { force: true });\n  fsyncDirectoryIfPossible(path.dirname(journalPath));\n}\n\nfunction writeNeedsRebuildSentinelAtPath(\n  sentinelPath: string,\n  options: NeedsRebuildSentinelWriteOptions,\n): void {\n  const sentinelDir = path.dirname(sentinelPath);\n  const tempSentinelPath = `${sentinelPath}.tmp`;\n  const sentinel: NeedsRebuildSentinelFile = {\n    formatVersion: 1,\n    createdAt: new Date().toISOString(),\n    source: options.source,\n    reason: options.reason,\n    ...(options.summary ? { rebuildSummary: options.summary } : {}),\n  };\n\n  fs.mkdirSync(sentinelDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(tempSentinelPath, `${JSON.stringify(sentinel, null, 2)}\\n`, { mode: 0o600 });\n  fsyncFileIfPossible(tempSentinelPath);\n  fs.renameSync(tempSentinelPath, sentinelPath);\n  fsyncDirectoryIfPossible(sentinelDir);\n}\n\nfunction clearNeedsRebuildSentinelAtPath(sentinelPath: string): boolean {\n  const existed = fs.existsSync(sentinelPath);\n  fs.rmSync(sentinelPath, { force: true });\n  if (existed) {\n    fsyncDirectoryIfPossible(path.dirname(sentinelPath));\n  }\n  return existed;\n}\n\nfunction getNeedsRebuildSentinelPathForDatabase(database: Database.Database): string | null {\n  try {\n    return getNeedsRebuildSentinelPath(resolveMainDatabasePath(database));\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction hasNeedsRebuildSentinel(database: Database.Database): boolean {\n  const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n  return sentinelPath !== null && fs.existsSync(sentinelPath);\n}\n\nfunction writeNeedsRebuildSentinelForDatabase(\n  database: Database.Database,\n  options: NeedsRebuildSentinelWriteOptions,\n): string | null {\n  const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n  if (sentinelPath === null) {\n    return null;\n  }\n  writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n  return sentinelPath;\n}\n\nfunction writeNeedsRebuildSentinelForMainPath(\n  liveMainPath: string,\n  options: NeedsRebuildSentinelWriteOptions,\n): string {\n  const sentinelPath = getNeedsRebuildSentinelPath(liveMainPath);\n  writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n  return sentinelPath;\n}\n\nfunction clearNeedsRebuildSentinelForDatabase(database: Database.Database): boolean {\n  const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n  if (sentinelPath === null) {\n    return false;\n  }\n  return clearNeedsRebuildSentinelAtPath(sentinelPath);\n}\n\nfunction removeRestoreBackupIfPossible(backupPath: string): void {\n  try {\n    fs.rmSync(backupPath, { force: true });\n  } catch (error: unknown) {\n    console.warn(`[checkpoints] restore backup cleanup skipped for ${backupPath}: ${toErrorMessage(error)}`);\n  }\n}\n\nfunction readCheckpointCatalogRows(database: Database.Database): Array<Record<string, unknown>> {\n  if (!tableExists(database, 'checkpoints')) {\n    return [];\n  }\n  return database.prepare('SELECT * FROM checkpoints ORDER BY id ASC').all() as Array<Record<string, unknown>>;\n}\n\nfunction mergeCheckpointCatalogRows(database: Database.Database, rows: Array<Record<string, unknown>>): void {\n  if (rows.length === 0 || !tableExists(database, 'checkpoints')) {\n    return;\n  }\n\n  const targetColumns = new Set(getTableColumns(database, 'checkpoints'));\n  for (const row of rows) {\n    const name = row.name;\n    if (typeof name !== 'string' || name.length === 0) {\n      continue;\n    }\n    const existingByName = database.prepare('SELECT id FROM checkpoints WHERE name = ?').get(name) as { id?: number } | undefined;\n    if (existingByName?.id) {\n      continue;\n    }\n\n    let columns = Object.keys(row).filter((column) => targetColumns.has(column));\n    const id = row.id;\n    if (typeof id === 'number') {\n      const existingById = database.prepare('SELECT name FROM checkpoints WHERE id = ?').get(id) as { name?: string } | undefined;\n      if (existingById?.name && existingById.name !== name) {\n        columns = columns.filter((column) => column !== 'id');\n      }\n    }\n    if (columns.length === 0) {\n      continue;\n    }\n\n    const placeholders = columns.map(() => '?').join(', ');\n    database.prepare(`\n      INSERT OR IGNORE INTO checkpoints (${columns.join(', ')})\n      VALUES (${placeholders})\n    `).run(...columns.map((column) => row[column]));\n  }\n}\n\nfunction pruneCheckpointCatalogRowsMissingSnapshots(database: Database.Database): void {\n  // The restored snapshot-main DB carries the full checkpoints table as of the\n  // snapshot, including v2 rows whose snapshot dir was deleted after the snapshot\n  // was taken. Those rows would resurface in listCheckpoints with no restorable\n  // dir, so drop any v2 row whose snapshot_path no longer exists on disk.\n  // Best-effort: never throw out of the restore path.\n  try {\n    if (!tableExists(database, 'checkpoints')) {\n      return;\n    }\n    const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n    if (!checkpointColumns.has('snapshot_path') || !checkpointColumns.has('snapshot_format')) {\n      return;\n    }\n    const rows = database.prepare(\n      \"SELECT id, snapshot_path FROM checkpoints WHERE snapshot_format = 'v2' AND snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n    ).all() as Array<{ id: number; snapshot_path: string }>;\n    for (const row of rows) {\n      if (!fs.existsSync(row.snapshot_path)) {\n        database.prepare('DELETE FROM checkpoints WHERE id = ?').run(row.id);\n        console.warn(`[checkpoints] Dropped restored catalog row with missing snapshot dir: ${row.snapshot_path}`);\n      }\n    }\n  } catch (error: unknown) {\n    console.warn(`[checkpoints] Post-restore catalog reconciliation skipped (non-fatal): ${toErrorMessage(error)}`);\n  }\n}\n\nfunction statPathBytes(targetPath: string): number {\n  try {\n    const stats = fs.statSync(targetPath);\n    if (stats.isFile()) {\n      return stats.size;\n    }\n    if (!stats.isDirectory()) {\n      return 0;\n    }\n    return fs.readdirSync(targetPath).reduce((total, entry) => total + statPathBytes(path.join(targetPath, entry)), 0);\n  } catch (_error: unknown) {\n    return 0;","lineStart":620,"lineEnd":1039,"totalLines":3364,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781761641854,"end":1781761641862}},"metadata":{"openai":{"itemId":"fc_06c8be0c896a84df016a3386699d708191b6f326c8205386ff"}},"id":"prt_ed9450d7d0015hdDTYgz4fzUU1","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed944dca1001Zh7E4l7FT65Dk6"}}
