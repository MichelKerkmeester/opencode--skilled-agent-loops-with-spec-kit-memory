    93	    promoter: .opencode/skills/deep-agent-improvement/scripts/shared/promote-candidate.cjs
    94	    journal: .opencode/skills/deep-agent-improvement/scripts/shared/improvement-journal.cjs
    95	    reducer: .opencode/skills/deep-agent-improvement/scripts/shared/reduce-state.cjs
    96	
    97	# ─────────────────────────────────────────────────────────────────
    98	# STATE PATHS
    99	# ─────────────────────────────────────────────────────────────────
   100	state_paths:
   101	  runtime_root: "{spec_folder}/improvement"
   102	  config: "{spec_folder}/improvement/model-benchmark-config.json"
