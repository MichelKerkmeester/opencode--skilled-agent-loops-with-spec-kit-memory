ummary = record && typeof record === 'object'\n594:     ? getNestedField(record, 'findingsSummary')\n595:     : null;\n596:   if (!summary || typeof summary !== 'object' || Array.isArray(summary)) {\n597:     return null;\n598:   }\n599:   const counts = zeroSeverityMap();\n600:   let total = 0;\n601:   for (const severity of SEVERITY_KEYS) {\n602:     const rawCount = summary[severity];\n603:     const count = Number.isFinite(rawCount) && rawCount > 0\n604:       ? Math.floor(rawCount)\n605:       : 0;\n606:     counts[severity] = count;\n607:     total += count;\n608:   }\n609:   return total > 0 ? counts : null;\n610: }\n611: \n612: function parseFindingLocation(fileValue) {\n613:   const file = typeof fileValue === 'string' ? fileValue : null;\n614:   let fileBase = null;\n615:   let lineNumber = null;\n616:   if (file) {\n617:     const m = file.match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n618:     if (m) {\n619:       fileBase = m[1];\n620:       lineNumber = Number(m[2]);\n621:     } else {\n622:       fileBase = file;\n623:     }\n624:   }\n625:   return { fileBase, lineNumber };\n626: }\n627: \n628: function findingDetailToFinding(detail, record, index) {\n629:   if (!detail || typeof detail !== 'object') {\n630:     return null;\n631:   }\n632:   const severity = normalizeSeverity(detail.finalSeverity || detail.severity);\n633:   if (!severity) {\n634:     return null;\n635:   }\n636:   const run = getIterationRun(record) || 0;\n637:   const findingId = normalizeText(detail.id || detail.findingId || '')\n638:     || `SUMMARY-${run}-${severity}-${String(index + 1).padStart(3, '0')}`;\n639:   const { fileBase, lineNumber } = parseFindingLocation(detail.file);\n640:   return {\n641:     findingId,\n642:     severity,\n643:     title: normalizeText(detail.title || `Summary ${severity} finding`),\n644:     file: fileBase,\n645:     line: lineNumber,\n646:     description: normalizeText(\n647:       detail.claim || detail.detail || detail.evidence || detail.recommendation || detail.description || '',\n648:     ),\n649:     findingClass: detail.findingClass || null,\n650:     deltaStatus: detail.disposition || detail.status || null,\n651:     scopeProof: typeof detail.scopeProof === 'string' ? detail.scopeProof : null,\n652:     affectedSurfaceHints: asStringList(detail.affectedSurfaceHints),\n653:     contentHash: typeof detail.content_hash === 'string' && detail.content_hash\n654:       ? detail.content_hash\n655:       : (typeof detail.contentHash === 'string' && detail.contentHash ? detail.contentHash : null),\n656:   };\n657: }\n658: \n659: function collectSummaryFallbackRecords(iterationRecords, deltaRecords) {\n660:   const byRun = new Map();\n661:   const candidates = []\n662:     .concat(Array.isArray(iterationRecords) ? iterationRecords : [])\n663:     .concat(Array.isArray(deltaRecords) ? deltaRecords : [])\n664:     .filter((record) => record?.type === 'iteration');\n665: \n666:   for (const record of candidates) {\n667:     const run = getIterationRun(record);\n668:     if (!isFiniteNumber(run)) {\n669:       continue;\n670:     }\n671:     const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n672:     const summary = normalizeSummaryCounts(record);\n673:     if (!summary && details.length === 0) {\n674:       continue;\n675:     }\n676:     const score = details.length * 10 + (summary ? SEVERITY_KEYS.reduce((sum, key) => sum + summary[key], 0) : 0);\n677:     const existing = byRun.get(run);\n678:     if (!existing || score >= existing.score) {\n679:       byRun.set(run, { record, score });\n680:     }\n681:   }\n682: \n683:   return [...byRun.entries()]\n684:     .sort(([leftRun], [rightRun]) => leftRun - rightRun)\n685:     .map(([run, value]) => ({ run, record: value.record }));\n686: }\n687: \n688: function countFindingsSeenInRun(findingById, run) {\n689:   const counts = zeroSeverityMap();\n690:   for (const finding of findingById.values()) {\n691:     if (!SEVERITY_KEYS.includes(finding.severity)) {\n692:       continue;\n693:     }\n694:     if (finding.firstSeen <= run && finding.lastSeen >= run) {\n695:       counts[finding.severity] += 1;\n696:     }\n697:   }\n698:   return counts;\n699: }\n700: \n701: function summarySlotFinding(run, severity, slotIndex, record) {\n702:   return {\n703:     findingId: `SUMMARY-${severity}-${String(slotIndex + 1).padStart(3, '0')}`,\n704:     severity,\n705:     title: `Summary ${severity} finding ${slotIndex + 1}`,\n706:     file: null,\n707:     line: null,\n708:     description: normalizeText(record.focus || 'Finding carried by iteration summary counts'),\n709:     findingClass: 'summary-only',\n710:     deltaStatus: 'active',\n711:     scopeProof: null,\n712:     affectedSurfaceHints: [],\n713:     contentHash: null,\n714:   };\n715: }\n716: \n717: function fallbackFindingsFromIterationRecord(record, run, representedCounts) {\n718:   const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n719:   const detailFindings = details\n720:     .map((detail, index) => findingDetailToFinding(detail, record, index))\n721:     .filter(Boolean);\n722:   const detailCounts = zeroSeverityMap();\n723:   for (const finding of detailFindings) {\n724:     detailCounts[finding.severity] += 1;\n725:   }\n726: \n727:   const summary = normalizeSummaryCounts(record);\n728:   if (!summary) {\n729:     return detailFindings;\n730:   }\n731: \n732:   const findings = [...detailFindings];\n733:   for (const severity of SEVERITY_KEYS) {\n734:     const alreadyRepresented = (representedCounts[severity] || 0) + detailCounts[severity];\n735:     const missingCount = Math.max(0, summary[severity] - alreadyRepresented);\n736:     for (let index = 0; index < missingCount; index += 1) {\n737:       findings.push(summarySlotFinding(run, severity, alreadyRepresented + index, record));\n738:     }\n739:   }\n\n(Showing lines 560-739 of 2235. Use offset=740 to continue.)\n</content>","metadata":{"preview":"    file: fileBase,\n    line: lineNumber,\n    description,\n    findingClass: record.findingClass || null,\n    deltaStatus: record.status || null,\n    // Preserve structured evidence fields so registry consumers do not need to\n    // re-open raw delta files for scope and surface hints.\n    scopeProof: typeof record.scopeProof === 'string' ? record.scopeProof : null,\n    affectedSurfaceHints: asStringList(record.affectedSurfaceHints),\n    // Content hashes let the registry collapse repeated findings across review\n    // dimensions; legacy records remain valid without one.\n    contentHash: typeof record.content_hash === 'string' && record.content_hash\n      ? record.content_hash\n      : (typeof record.contentHash === 'string' && record.contentHash ? record.contentHash : null),\n  };\n}\n\nfunction getIterationRun(record) {\n  if (!record || typeof record !== 'object') {\n    return null;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","text":"    file: fileBase,\n    line: lineNumber,\n    description,\n    findingClass: record.findingClass || null,\n    deltaStatus: record.status || null,\n    // Preserve structured evidence fields so registry consumers do not need to\n    // re-open raw delta files for scope and surface hints.\n    scopeProof: typeof record.scopeProof === 'string' ? record.scopeProof : null,\n    affectedSurfaceHints: asStringList(record.affectedSurfaceHints),\n    // Content hashes let the registry collapse repeated findings across review\n    // dimensions; legacy records remain valid without one.\n    contentHash: typeof record.content_hash === 'string' && record.content_hash\n      ? record.content_hash\n      : (typeof record.contentHash === 'string' && record.contentHash ? record.contentHash : null),\n  };\n}\n\nfunction getIterationRun(record) {\n  if (!record || typeof record !== 'object') {\n    return null;\n  }\n  if (isFiniteNumber(record.iteration)) {\n    return record.iteration;\n  }\n  if (isFiniteNumber(record.run)) {\n    return record.run;\n  }\n  const runText = normalizeText(record.run || '');\n  const runMatch = runText.match(/(\\d+)$/);\n  return runMatch ? Number(runMatch[1]) : null;\n}\n\nfunction normalizeSummaryCounts(record) {\n  const summary = record && typeof record === 'object'\n    ? getNestedField(record, 'findingsSummary')\n    : null;\n  if (!summary || typeof summary !== 'object' || Array.isArray(summary)) {\n    return null;\n  }\n  const counts = zeroSeverityMap();\n  let total = 0;\n  for (const severity of SEVERITY_KEYS) {\n    const rawCount = summary[severity];\n    const count = Number.isFinite(rawCount) && rawCount > 0\n      ? Math.floor(rawCount)\n      : 0;\n    counts[severity] = count;\n    total += count;\n  }\n  return total > 0 ? counts : null;\n}\n\nfunction parseFindingLocation(fileValue) {\n  const file = typeof fileValue === 'string' ? fileValue : null;\n  let fileBase = null;\n  let lineNumber = null;\n  if (file) {\n    const m = file.match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n    if (m) {\n      fileBase = m[1];\n      lineNumber = Number(m[2]);\n    } else {\n      fileBase = file;\n    }\n  }\n  return { fileBase, lineNumber };\n}\n\nfunction findingDetailToFinding(detail, record, index) {\n  if (!detail || typeof detail !== 'object') {\n    return null;\n  }\n  const severity = normalizeSeverity(detail.finalSeverity || detail.severity);\n  if (!severity) {\n    return null;\n  }\n  const run = getIterationRun(record) || 0;\n  const findingId = normalizeText(detail.id || detail.findingId || '')\n    || `SUMMARY-${run}-${severity}-${String(index + 1).padStart(3, '0')}`;\n  const { fileBase, lineNumber } = parseFindingLocation(detail.file);\n  return {\n    findingId,\n    severity,\n    title: normalizeText(detail.title || `Summary ${severity} finding`),\n    file: fileBase,\n    line: lineNumber,\n    description: normalizeText(\n      detail.claim || detail.detail || detail.evidence || detail.recommendation || detail.description || '',\n    ),\n    findingClass: detail.findingClass || null,\n    deltaStatus: detail.disposition || detail.status || null,\n    scopeProof: typeof detail.scopeProof === 'string' ? detail.scopeProof : null,\n    affectedSurfaceHints: asStringList(detail.affectedSurfaceHints),\n    contentHash: typeof detail.content_hash === 'string' && detail.content_hash\n      ? detail.content_hash\n      : (typeof detail.contentHash === 'string' && detail.contentHash ? detail.contentHash : null),\n  };\n}\n\nfunction collectSummaryFallbackRecords(iterationRecords, deltaRecords) {\n  const byRun = new Map();\n  const candidates = []\n    .concat(Array.isArray(iterationRecords) ? iterationRecords : [])\n    .concat(Array.isArray(deltaRecords) ? deltaRecords : [])\n    .filter((record) => record?.type === 'iteration');\n\n  for (const record of candidates) {\n    const run = getIterationRun(record);\n    if (!isFiniteNumber(run)) {\n      continue;\n    }\n    const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n    const summary = normalizeSummaryCounts(record);\n    if (!summary && details.length === 0) {\n      continue;\n    }\n    const score = details.length * 10 + (summary ? SEVERITY_KEYS.reduce((sum, key) => sum + summary[key], 0) : 0);\n    const existing = byRun.get(run);\n    if (!existing || score >= existing.score) {\n      byRun.set(run, { record, score });\n    }\n  }\n\n  return [...byRun.entries()]\n    .sort(([leftRun], [rightRun]) => leftRun - rightRun)\n    .map(([run, value]) => ({ run, record: value.record }));\n}\n\nfunction countFindingsSeenInRun(findingById, run) {\n  const counts = zeroSeverityMap();\n  for (const finding of findingById.values()) {\n    if (!SEVERITY_KEYS.includes(finding.severity)) {\n      continue;\n    }\n    if (finding.firstSeen <= run && finding.lastSeen >= run) {\n      counts[finding.severity] += 1;\n    }\n  }\n  return counts;\n}\n\nfunction summarySlotFinding(run, severity, slotIndex, record) {\n  return {\n    findingId: `SUMMARY-${severity}-${String(slotIndex + 1).padStart(3, '0')}`,\n    severity,\n    title: `Summary ${severity} finding ${slotIndex + 1}`,\n    file: null,\n    line: null,\n    description: normalizeText(record.focus || 'Finding carried by iteration summary counts'),\n    findingClass: 'summary-only',\n    deltaStatus: 'active',\n    scopeProof: null,\n    affectedSurfaceHints: [],\n    contentHash: null,\n  };\n}\n\nfunction fallbackFindingsFromIterationRecord(record, run, representedCounts) {\n  const details = Array.isArray(record.findingDetails) ? record.findingDetails : [];\n  const detailFindings = details\n    .map((detail, index) => findingDetailToFinding(detail, record, index))\n    .filter(Boolean);\n  const detailCounts = zeroSeverityMap();\n  for (const finding of detailFindings) {\n    detailCounts[finding.severity] += 1;\n  }\n\n  const summary = normalizeSummaryCounts(record);\n  if (!summary) {\n    return detailFindings;\n  }\n\n  const findings = [...detailFindings];\n  for (const severity of SEVERITY_KEYS) {\n    const alreadyRepresented = (representedCounts[severity] || 0) + detailCounts[severity];\n    const missingCount = Math.max(0, summary[severity] - alreadyRepresented);\n    for (let index = 0; index < missingCount; index += 1) {\n      findings.push(summarySlotFinding(run, severity, alreadyRepresented + index, record));\n    }\n  }","lineStart":560,"lineEnd":739,"totalLines":2235,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","time":{"start":1784388005177,"end":1784388005190}},"metadata":{"openai":{"itemId":"fc_089cd0a54d9e99bc016a5b99a43abc8191810384d7587f6e7d"}},"id":"prt_f75d0299d001FwuWl9OzlqTJ47","sessionID":"ses_08a55b97affezjS590Sxu4oUZ9","messageID":"msg_f75d0196e001Lru7aujDhw5uA4"}}
