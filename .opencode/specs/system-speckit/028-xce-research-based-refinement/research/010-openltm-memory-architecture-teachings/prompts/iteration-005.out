es ce\n\n  Line 333:  * Invalidated via clearDegreeCache() on causal edge mutations.\n\n  Line 338:  * causal-edges.ts.  Community detection in community-detection.ts uses a\n\n  Line 348:  *   - Invalidation: clearDegreeCache() wipes all entries on causal edge\n\n  Line 382:     SELECT relation, strength FROM causal_edges WHERE source_id = ?\n\n  Line 384:     SELECT relation, strength FROM causal_edges WHERE target_id = ?\n\n  Line 440:                 WHEN 'contradicts' THEN 0.7\n\n  Line 441:                 WHEN 'supersedes' THEN 0.6\n\n  Line 447:             SELECT source_id AS node_id, relation, strength FROM causal_edges\n\n  Line 450:             SELECT target_id AS node_id, relation, strength FROM causal_edges\n\n  Line 512:       FROM causal_edges ce\n\n  Line 517:       FROM causal_edges ce\n\n  Line 528:           WHEN 'contradicts' THEN 0.7\n\n  Line 529:           WHEN 'supersedes' THEN 0.6\n\n  Line 628:  * Call this on causal edge mutations (insert, update, delete)\n\n  Line 655:  * Creates a graph search function backed by causal_edges only.\n\n  Line 658:  * @returns A GraphSearchFn over causal edges\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts:\n  Line 27: // 2c. Graph signals           — N2a momentum + N2b causal depth\n\n  Line 55: import * as causalBoost from '../causal-boost.js';\n\n  Line 326: type GraphContributionKey = 'causalDelta' | 'coActivationDelta' | 'communityDelta' | 'graphSignalDelta';\n\n  Line 343:   const totalDelta = ['causalDelta', 'coActivationDelta', 'communityDelta', 'graphSignalDelta']\n\n  Line 391:       causalDelta: Math.max(0, resolveGraphContributionValue(graphContribution, 'causalDelta')),\n\n  Line 404:       calibrated.causalDelta +\n\n  Line 419:         causalDelta: calibrated.causalDelta,\n\n  Line 431:  * a graph-based boost. Extracts contributing causal edges, co-activation edges,\n\n  Line 460:   // Ba