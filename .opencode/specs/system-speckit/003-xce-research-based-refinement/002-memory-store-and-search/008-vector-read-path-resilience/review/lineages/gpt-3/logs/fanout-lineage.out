{"type":"text","timestamp":1781151292332,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"id":"prt_eb4e3ce3d001xQRmejOPtEEpe8","messageID":"msg_eb4e3ba82001ebIrUU1GfimBXY","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","type":"text","text":"phase_main_loop is starting. The target docs identify the changed code and tests; I will review one dimension per iteration and write only lineage-local state/output files.","time":{"start":1781151288893,"end":1781151292328},"metadata":{"openai":{"itemId":"msg_04e44631d543a090016a2a3638e3388191a98b5f4f6d853b28","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781151292376,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_HU0uWcFMW3omsk9FeIDdueqV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // SEARCH: VECTOR INDEX\n6: // TypeScript port of the vector index implementation.\n7: // DECAY STRATEGY: Search-time temporal decay uses an\n8: // FSRS-preferred strategy. Memories with FSRS review data (last_review\n9: // IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n10: // R(t) = (1 + 0.2346 * t / S)^(-0.5)\n11: // Memories without review data fall back to half-life exponential:\n12: // Weight * 0.5^(days / half_life_days)\n13: // This ensures backward compatibility while aligning reviewed\n14: // Memories with the canonical FSRS algorithm.\n15: \n16: import * as fs from 'fs';\n17: import * as os from 'os';\n18: import * as path from 'path';\n19: \n20: import Database from 'better-sqlite3';\n21: import * as sqliteVec from 'sqlite-vec';\n22: \n23: import { getEmbeddingDimension } from '@spec-kit/shared/embeddings';\n24: import {\n25:   EmbeddingProfile,\n26: } from '@spec-kit/shared/embeddings/profile';\n27: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings/factory';\n28: \n29: import { resolveDatabasePaths, SERVER_DIR } from '../../core/config.js';\n30: import { computeInterferenceScoresBatch } from '../scoring/interference-scoring.js';\n31: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n32: import {\n33:   recordVectorShardProbeFailure,\n34:   recordVectorShardQuarantined,\n35:   recordVectorShardRebuildFailed,\n36: } from '../observability/retrieval-observability.js';\n37: import { validateFilePath } from '../utils/path-security.js';\n38: import {\n39:   get_error_code,\n40:   get_error_message,\n41:   parse_trigger_phrases,\n42:   VectorIndexError,\n43:   VectorIndexErrorCode,\n44: } from './vector-index-types.js';\n45: import {\n46:   create_schema,\n47:   ensure_schema_version,\n48: } from './vector-index-schema.js';\n49: import { migrateLegacySingleDbToShardSync } from './db-shard-migration.js';\n50: import type { MemoryRow } from './vector-index-types.js';\n51: \n52: type SearchWeightsConfig = {\n53:   maxTriggersPerMemory?: number;\n54:   smartRanking?: {\n55:     recencyWeight?: number;\n56:     accessWeight?: number;\n57:     relevanceWeight?: number;\n58:   };\n59: };\n60: \n61: type RestoreJournalPhase = 'swap-pending' | 'swap-done';\n62: \n63: type RestoreJournalFile = {\n64:   formatVersion: 1;\n65:   phase: RestoreJournalPhase;\n66:   createdAt: string;\n67:   checkpointName: string;\n68:   liveMainPath: string;\n69:   backupMainPath: string;\n70:   snapshotMainPath: string;\n71:   liveShardPath: string | null;\n72:   backupShardPath: string | null;\n73:   snapshotVecPath: string | null;\n74:   shouldRestoreVec: boolean;\n75:   liveShardPreexisted: boolean;\n76: };\n77: \n78: type InitializeDbOptions = {\n79:   skipRestoreRecovery?: boolean;\n80: };\n81: \n82: const RESTORE_JOURNAL_NAME = '.restore-journal.json';\n83: const NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n84: \n85: function loadSearchWeights(): SearchWeightsConfig {\n86:   // SERVER_DIR points to dist/ at runtime; configs/ lives at the package root (dist/..)\n87:   const candidates = [\n88:     path.join(SERVER_DIR, 'configs', 'search-weights.json'),\n89:     path.join(SERVER_DIR, '..', 'configs', 'search-weights.json'),\n90:   ];\n91:   for (const candidate of candidates) {\n92:     try {\n93:       return JSON.parse(fs.readFileSync(candidate, 'utf-8')) as SearchWeightsConfig;\n94:     } catch {\n95:       // Try next candidate\n96:     }\n97:   }\n98:   return {};\n99: }\n100: \n101: let _search_weights: SearchWeightsConfig | null = null;\n102: \n103: function getSearchWeights(): SearchWeightsConfig {\n104:   if (_search_weights === null) {\n105:     _search_weights = loadSearchWeights();\n106:   }\n107:   return _search_weights;\n108: }\n109: \n110: /** Loaded search weight configuration for vector-index ranking (lazy-loaded). */\n111: export const search_weights: SearchWeightsConfig = {\n112:   get maxTriggersPerMemory() {\n113:     return getSearchWeights().maxTriggersPerMemory;\n114:   },\n115:   get smartRanking() {\n116:     return getSearchWeights().smartRanking;\n117:   },\n118: };\n119: \n120: /* ───────────────────────────────────────────────────────────────\n121:    1. CONFIGURATION — Embedding Dimension\n122: ----------------------------------------------------------------*/\n123: \n124: /** Default embedding dimension used by the vector index. */\n125: export const EMBEDDING_DIM = getEmbeddingDimension();\n126: \n127: /**\n128:  * Gets the active embedding dimension for the current provider.\n129:  * @returns The embedding dimension.\n130:  */\n131: export function get_embedding_dim(): number {\n132:   return getEmbeddingDimension();\n133: }\n134: \n135: /**\n136:  * Waits for the embedding provider to report a stable dimension.\n137:  * @param timeout_ms - The maximum time to wait in milliseconds.\n138:  * @returns A promise that resolves to the confirmed embedding dimension.\n139:  */\n140: export async function get_confirmed_embedding_dimension(timeout_ms = 5000): Promise<number> {\n141:   const start = Date.now();\n142:   while (Date.now() - start < timeout_ms) {\n143:     const dim = get_embedding_dim();\n144:     if (Number.isFinite(dim) && dim > 0) {\n145:       return dim;\n146:     }\n147:     await new Promise(resolve => setTimeout(resolve, 100));\n148:   }\n149:   const fallbackDim = get_embedding_dim();\n150:   console.warn(`[vector-index] Using embedding dimension ${fallbackDim} after timeout`);\n151:   return fallbackDim;\n152: }\n153: \n154: type EmbeddingDimensionValidation = {\n155:   valid: boolean;\n156:   stored: number | null;\n157:   current: number | null;\n158:   reason?: string;\n159:   warning?: string;\n160: };\n161: \n162: type StoredEmbeddingDimension = {\n163:   existing_db: boolean;\n164:   stored_dim: number | null;\n165:   source: 'vec_metadata' | 'active_embedder_profile' | 'startup_profile' | 'vec_memories' | null;\n166:   reason?: string;\n167: };\n168: \n169: function get_existing_embedding_dimension(\n170:   database: Database.Database,\n171:   options: { allowProfileFallback?: boolean } = {},\n172: ): StoredEmbeddingDimension {\n173:   const allowProfileFallback = options.allowProfileFallback !== false;\n174:   const schema_row = database.prepare(`\n175:     SELECT name FROM sqlite_master WHERE type='table' AND name='memory_index'\n176:   `).get();\n177: \n178:   if (!schema_row) {\n179:     return {\n180:       existing_db: false,\n181:       stored_dim: null,\n182:       source: null,\n183:       reason: 'No existing schema',\n184:     };\n185:   }\n186: \n187:   const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string }>;\n188:   if (attached.some((entry) => entry.name === ACTIVE_VECTOR_SCHEMA)) {\n189:     const shard_metadata_table = database.prepare(`\n190:       SELECT name FROM ${ACTIVE_VECTOR_SCHEMA}.sqlite_master WHERE type='table' AND name='vec_metadata'\n191:     `).get();\n192: \n193:     if (shard_metadata_table) {\n194:       const stored_row = database.prepare(`\n195:         SELECT value FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata WHERE key IN ('embedding_dim', 'dim')\n196:         ORDER BY CASE key WHEN 'embedding_dim' THEN 0 ELSE 1 END\n197:         LIMIT 1\n198:       `).get() as { value: string } | undefined;\n199: \n200:       if (stored_row) {\n201:         const stored_dim = parseInt(stored_row.value, 10);\n202:         if (Number.isFinite(stored_dim) && stored_dim > 0) {\n203:           return {\n204:             existing_db: true,\n205:             stored_dim,\n206:             source: 'vec_metadata',\n207:           };\n208:         }\n209:       }\n210:     }\n211:   }\n212: \n213:   const metadata_table = database.prepare(`\n214:     SELECT name FROM sqlite_master WHERE type='table' AND name='vec_metadata'\n215:   `).get();\n216: \n217:   if (metadata_table) {\n218:     const stored_row = database.prepare(`\n219:       SELECT key, value FROM vec_metadata WHERE key IN ('embedding_dim', 'dim', 'active_embedder_dim')\n220:       ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n221:       LIMIT 1\n222:     `).get() as { key: string; value: string } | undefined;\n223: \n224:     if (stored_row) {\n225:       const stored_dim = parseInt(stored_row.value, 10);\n226:       if (Number.isFinite(stored_dim) && stored_dim > 0) {\n227:         return {\n228:           existing_db: true,\n229:           stored_dim,\n230:           source: stored_row.key === 'active_embedder_dim' ? 'active_embedder_profile' : 'vec_metadata',\n231:         };\n232:       }\n233:     }\n234:   }\n235: \n236:   if (allowProfileFallback) {\n237:     const active = getActiveEmbedder(database);\n238:     if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n239:       return {\n240:         existing_db: true,\n241:         stored_dim: active.dim,\n242:         source: 'active_embedder_profile',\n243:       };\n244:     }\n245: \n246:     const startupProfile = getStartupEmbeddingProfile();\n247:     if (Number.isInteger(startupProfile.dim) && startupProfile.dim > 0) {\n248:       return {\n249:         existing_db: true,\n250:         stored_dim: startupProfile.dim,\n251:         source: 'startup_profile',\n252:       };\n253:     }\n254:   }\n255: \n256:   const vec_table = database.prepare(`\n257:     SELECT sql FROM sqlite_master WHERE name='vec_memories'\n258:   `).get() as { sql: string | null } | undefined;\n259:   const vec_sql = typeof vec_table?.sql === 'string' ? vec_table.sql : null;\n260:   const match = vec_sql?.match(/FLOAT\\[(\\d+)\\]/i);\n261: \n262:   if (match) {\n263:     const stored_dim = parseInt(match[1], 10);\n264:     if (Number.isFinite(stored_dim) && stored_dim > 0) {\n265:       console.warn('[vector-index] Falling back to vec_memories schema text for embedding dimension; configure an active embedder profile to make dimension discovery authoritative.');\n266:       return {\n267:         existing_db: true,\n268:         stored_dim,\n269:         source: 'vec_memories',\n270:       };\n271:     }\n272:   }\n273: \n274:   return {\n275:     existing_db: true,\n276:     stored_dim: null,\n277:     source: null,\n278:     reason: 'No stored vector dimension found for existing schema',\n279:   };\n280: }\n281: \n282: function validate_embedding_dimension_for_connection(\n283:   database: Database.Database | null,\n284:   _sqlite_vec_available: boolean,\n285: ): EmbeddingDimensionValidation {\n286:   if (!database) {\n287:     return { valid: true, stored: null, current: null, reason: 'No database' };\n288:   }\n289: \n290:   try {\n291:     const active = getActiveEmbedder(database);\n292:     const current_dim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0\n293:       ? active.dim\n294:       : get_embedding_dim();\n295:     const existing = get_existing_embedding_dimension(database);\n296: \n297:     if (!existing.existing_db) {\n298:       return { valid: true, stored: null, current: current_dim, reason: existing.reason };\n299:     }\n300: \n301:     if (existing.stored_dim == null) {\n302:       return { valid: true, stored: null, current: current_dim, reason: existing.reason || 'No stored dimension' };\n303:     }\n304: \n305:     if (existing.stored_dim !== current_dim) {\n306:       const source_label = existing.source === 'vec_metadata' ? 'vec_metadata' : 'vec_memories schema';\n307:       const warning = `EMBEDDING DIMENSION MISMATCH: Existing database stores ${existing.stored_dim}-dim vectors (${source_label}), ` +\n308:         `but the active embedding configuration resolves to ${current_dim}. Refusing to bootstrap because vector search would fail. ` +\n309:         `Solutions: 1) Delete database and re-index, 2) Set EMBEDDINGS_PROVIDER to match original, ` +\n310:         `3) Let SPEC_KIT_DB_DIR auto-derive a profile-specific database, or set MEMORY_DB_PATH only for an intentional file override.`;\n311:       console.error(`[vector-index] WARNING: ${warning}`);\n312:       return { valid: false, stored: existing.stored_dim, current: current_dim, warning };\n313:     }\n314: \n315:     return { valid: true, stored: existing.stored_dim, current: current_dim };\n316:   } catch (e: unknown) {\n317:     console.warn('[vector-index] Dimension validation error:', get_error_message(e));\n318:     return { valid: true, stored: null, current: get_embedding_dim(), reason: get_error_message(e) };\n319:   }\n320: }\n321: \n322: /**\n323:  * Validates that stored vector dimensions match the provider.\n324:  * @returns The validation result.\n325:  */\n326: export function validate_embedding_dimension(): { valid: boolean; stored: number | null; current: number | null; reason?: string; warning?: string } {\n327:   return validate_embedding_dimension_for_connection(db, sqlite_vec_available_flag);\n328: }\n329: \n330: /* ───────────────────────────────────────────────────────────────\n331:    2. DATABASE PATH AND SECURITY\n332: ----------------------------------------------------------------*/\n333: \n334: function get_default_db_path(): string {\n335:   return process.env.MEMORY_DB_PATH || resolveDatabasePaths().databasePath;\n336: }\n337: \n338: /** Default path for the vector-index database file. */\n339: export const DEFAULT_DB_PATH = process.env.MEMORY_DB_PATH\n340:   || get_default_db_path();\n341: const DB_PERMISSIONS = 0o600;\n342: \n343: function resolve_database_path() {\n344:   return process.env.MEMORY_DB_PATH || get_default_db_path();\n345: }\n346: \n347: export const ACTIVE_VECTOR_SCHEMA = 'active_vec';\n348: \n349: type ActiveVectorSourceTelemetry = {\n350:   canonical_path: string;\n351:   shard_path: string;\n352:   attached: boolean;\n353:   profile: {\n354:     provider: string;\n355:     model: string;\n356:     dim: number;\n357:     dtype: string | null;\n358:   };\n359: };\n360: \n361: function quote_sql_string(value: string): string {\n362:   return `'${value.replace(/'/g, \"''\")}'`;\n363: }\n364: \n365: function quote_identifier(value: string): string {\n366:   return `\"${value.replace(/\"/g, '\"\"')}\"`;\n367: }\n368: \n369: function get_database_file_path(database: Database.Database): string {\n370:   const row = database.prepare('PRAGMA database_list').all()\n371:     .find((entry: unknown) => (entry as { name?: string }).name === 'main') as { file?: string } | undefined;\n372:   return row?.file && row.file.length > 0 ? row.file : db_path;\n373: }\n374: \n375: function resolve_database_base_dir(database: Database.Database): string {\n376:   const filePath = get_database_file_path(database);\n377:   if (!filePath || filePath === ':memory:') {\n378:     return resolveDatabasePaths().databaseDir;\n379:   }\n380:   return path.dirname(filePath);\n381: }\n382: \n383: function legacy_profile_database_path(profile: EmbeddingProfile, baseDir: string): string {\n384:   return path.join(baseDir, `context-index__${profile.slug}.sqlite`);\n385: }\n386: \n387: function get_vector_shard_path(profile: EmbeddingProfile, baseDir: string): string {\n388:   const vectorDir = path.join(baseDir, 'vectors');\n389:   if (!fs.existsSync(vectorDir)) {\n390:     fs.mkdirSync(vectorDir, { recursive: true, mode: 0o700 });\n391:   }\n392:   return path.join(vectorDir, `context-vectors__${profile.slug}.sqlite`);\n393: }\n394: \n395: function resolve_profile_for_active_embedder(database: Database.Database): EmbeddingProfile {\n396:   const active = getActiveEmbedder(database);\n397:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n398:     const startup = getStartupEmbeddingProfile();\n399:     return new EmbeddingProfile({\n400:       provider: active.provider ?? startup.provider,\n401:       model: active.name,\n402:       dim: active.dim,\n403:       dtype: null,\n404:       baseUrl: startup.baseUrl,\n405:     });\n406:   }\n407:   return getStartupEmbeddingProfile();\n408: }\n409: \n410: function vector_table_name_for_profile(profile: EmbeddingProfile): string {\n411:   return `vec_${profile.dim}`;\n412: }\n413: \n414: function active_schema_table(tableName: string): string {\n415:   return `${ACTIVE_VECTOR_SCHEMA}.${tableName}`;\n416: }\n417: \n418: export function activeVectorSource(tableName?: string): string {\n419:   return tableName ? active_schema_table(tableName) : ACTIVE_VECTOR_SCHEMA;\n420: }\n421: \n422: function get_attached_vector_path(database: Database.Database): string | null {\n423:   const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>;\n424:   const row = attached.find((entry) => entry.name === ACTIVE_VECTOR_SCHEMA);\n425:   return row?.file ? path.resolve(row.file) : null;\n426: }\n427: \n428: function table_exists_in_schema(database: Database.Database, schema: string, tableName: string): boolean {\n429:   const row = database.prepare(`\n430:     SELECT 1 AS found\n431:     FROM ${quote_identifier(schema)}.sqlite_master\n432:     WHERE type IN ('table', 'view') AND name = ?\n433:     LIMIT 1\n434:   `).get(tableName) as { found?: number } | undefined;\n435:   return row?.found === 1;\n436: }\n437: \n438: type VectorShardIntegrityProbeResult =\n439:   | { ok: true }\n440:   | { ok: false; reason: string };\n441: \n442: function quick_check_verdict(database: Database.Database, schema?: string): string {\n443:   const rows = schema\n444:     ? database.pragma(`${schema}.quick_check(1)`) as Array<Record<string, unknown>>\n445:     : database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n446:   const first = rows?.[0] ? Object.values(rows[0])[0] : undefined;\n447:   return typeof first === 'string' ? first : 'quick_check returned no verdict';\n448: }\n449: \n450: function required_vector_shard_tables(profile: EmbeddingProfile, vecAvailable: boolean): string[] {\n451:   return [\n452:     'vec_metadata',\n453:     'embedding_cache',\n454:     vector_table_name_for_profile(profile),\n455:     ...(vecAvailable ? ['vec_memories'] : []),\n456:   ];\n457: }\n458: \n459: function run_attached_vector_shard_integrity_probe(\n460:   database: Database.Database,\n461:   profile: EmbeddingProfile,\n462:   vecAvailable: boolean,\n463: ): VectorShardIntegrityProbeResult {\n464:   try {\n465:     const verdict = quick_check_verdict(database, ACTIVE_VECTOR_SCHEMA);\n466:     if (verdict !== 'ok') {\n467:       return { ok: false, reason: `quick_check failed: ${verdict}` };\n468:     }\n469:     for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n470:       if (!table_exists_in_schema(database, ACTIVE_VECTOR_SCHEMA, tableName)) {\n471:         return { ok: false, reason: `required table missing: ${tableName}` };\n472:       }\n473:     }\n474:     return { ok: true };\n475:   } catch (error: unknown) {\n476:     return { ok: false, reason: get_error_message(error) };\n477:   }\n478: }\n479: \n480: function run_vector_shard_integrity_probe_at_path(\n481:   shardPath: string,\n482:   profile: EmbeddingProfile,\n483:   vecAvailable: boolean,\n484: ): VectorShardIntegrityProbeResult {\n485:   if (!fs.existsSync(shardPath)) {\n486:     return { ok: true };\n487:   }\n488: \n489:   let shard: Database.Database | null = null;\n490:   try {\n491:     shard = new Database(shardPath, { readonly: true, fileMustExist: true });\n492:     if (vecAvailable) {\n493:       sqliteVec.load(shard);\n494:     }\n495:     const verdict = quick_check_verdict(shard);\n496:     if (verdict !== 'ok') {\n497:       return { ok: false, reason: `quick_check failed: ${verdict}` };\n498:     }\n499:     for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n500:       const row = shard.prepare(`\n501:         SELECT 1 AS found\n502:         FROM sqlite_master\n503:         WHERE type IN ('table', 'view') AND name = ?\n504:         LIMIT 1\n505:       `).get(tableName) as { found?: number } | undefined;\n506:       if (row?.found !== 1) {\n507:         return { ok: false, reason: `required table missing: ${tableName}` };\n508:       }\n509:     }\n510:     return { ok: true };\n511:   } catch (error: unknown) {\n512:     return { ok: false, reason: get_error_message(error) };\n513:   } finally {\n514:     if (shard) {\n515:       try { shard.close(); } catch (_error: unknown) { /* best-effort */ }\n516:     }\n517:   }\n518: }\n519: \n520: function quarantine_vector_shard(shardPath: string, reason: string): string {\n521:   const stamp = new Date().toISOString().replace(/[^0-9A-Za-z]/g, '');\n522:   const quarantinePath = `${shardPath}.quarantined-${stamp}-${process.pid}`;\n523:   for (const suffix of ['', '-wal', '-shm']) {\n524:     const source = `${shardPath}${suffix}`;\n525:     if (!fs.existsSync(source)) {\n526:       continue;\n527:     }\n528:     fs.renameSync(source, `${quarantinePath}${suffix}`);\n529:   }\n530:   fsync_file_if_possible(quarantinePath);\n531:   fsync_directory_if_possible(path.dirname(shardPath));\n532:   recordVectorShardQuarantined({ shardPath, quarantinePath, reason });\n533:   return quarantinePath;\n534: }\n535: \n536: function schedule_vector_shard_rebuild(\n537:   database: Database.Database,\n538:   profile: EmbeddingProfile,\n539:   shardPath: string,\n540:   reason: string,\n541: ): void {\n542:   setImmediate(() => {\n543:     void import('../embedders/reindex.js')\n544:       .then(({ startVectorShardRepairReindex }) => {\n545:         startVectorShardRepairReindex(profile, { db: database, reason, shardPath });\n546:       })\n547:       .catch((error: unknown) => {\n548:         recordVectorShardRebuildFailed({\n549:           jobId: 'not-started',\n550:           shardPath,\n551:           reason: get_error_message(error),\n552:         });\n553:       });\n554:   });\n555: }\n556: \n557: function quarantine_and_rebuild_vector_shard(\n558:   database: Database.Database,\n559:   profile: EmbeddingProfile,\n560:   shardPath: string,\n561:   reason: string,\n562: ): void {\n563:   recordVectorShardProbeFailure({ shardPath, reason });\n564:   const quarantinePath = quarantine_vector_shard(shardPath, reason);\n565:   schedule_vector_shard_rebuild(database, profile, shardPath, `${reason}; quarantined as ${path.basename(quarantinePath)}`);\n566: }\n567: \n568: function write_shard_metadata(database: Database.Database, profile: EmbeddingProfile): void {\n569:   database.exec(`\n570:     CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.vec_metadata (\n571:       key TEXT PRIMARY KEY,\n572:       value TEXT NOT NULL,\n573:       created_at TEXT DEFAULT (datetime('now'))\n574:     )\n575:   `);\n576: \n577:   const rows = database.prepare(`\n578:     SELECT key, value\n579:     FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata\n580:     WHERE key IN ('provider', 'model', 'dim', 'embedding_dim')\n581:   `).all() as Array<{ key: string; value: string }>;\n582:   const metadata = new Map(rows.map((row) => [row.key, row.value]));\n583:   const mismatches = [\n584:     ['provider', profile.provider],\n585:     ['model', profile.model],\n586:     ['dim', String(profile.dim)],\n587:     ['embedding_dim', String(profile.dim)],\n588:   ].filter(([key, expected]) => {\n589:     const actual = metadata.get(key);\n590:     return actual != null && actual.length > 0 && actual !== expected;\n591:   });\n592: \n593:   if (mismatches.length > 0) {\n594:     const detail = mismatches.map(([key, expected]) => `${key}: expected ${expected}, got ${metadata.get(key)}`).join('; ');\n595:     throw new VectorIndexError(\n596:       `Attached vector shard metadata mismatch (${detail})`,\n597:       VectorIndexErrorCode.INTEGRITY_ERROR,\n598:     );\n599:   }\n600: \n601:   const upsert = database.prepare(`\n602:     INSERT OR REPLACE INTO ${ACTIVE_VECTOR_SCHEMA}.vec_metadata (key, value)\n603:     VALUES (?, ?)\n604:   `);\n605:   upsert.run('provider', profile.provider);\n606:   upsert.run('model', profile.model);\n607:   upsert.run('dim', String(profile.dim));\n608:   upsert.run('embedding_dim', String(profile.dim));\n609: }\n610: \n611: function ensure_embedding_cache_table(database: Database.Database): void {\n612:   database.exec(`\n613:     CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.embedding_cache (\n614:       content_hash TEXT NOT NULL,\n615:       profile_key TEXT NOT NULL DEFAULT '',\n616:       input_kind TEXT NOT NULL DEFAULT 'document' CHECK (input_kind IN ('document', 'query')),\n617:       model_id TEXT NOT NULL,\n618:       embedding BLOB NOT NULL,\n619:       dimensions INTEGER NOT NULL,\n620:       created_at TEXT NOT NULL DEFAULT (datetime('now')),\n621:       last_used_at TEXT NOT NULL DEFAULT (datetime('now')),\n622:       PRIMARY KEY (content_hash, profile_key, input_kind, model_id, dimensions)\n623:     )\n624:   `);\n625: }\n626: \n627: function ensure_vector_shard_schema(database: Database.Database, profile: EmbeddingProfile): void {\n628:   database.pragma(`${ACTIVE_VECTOR_SCHEMA}.journal_mode = WAL`);\n629:   database.pragma(`${ACTIVE_VECTOR_SCHEMA}.cache_size = -8192`);\n630:   database.pragma(`${ACTIVE_VECTOR_SCHEMA}.mmap_size = 33554432`);\n631:   database.pragma(`${ACTIVE_VECTOR_SCHEMA}.temp_store = DEFAULT`);\n632:   database.pragma(`${ACTIVE_VECTOR_SCHEMA}.wal_autocheckpoint = 256`);\n633: \n634:   write_shard_metadata(database, profile);\n635:   ensure_embedding_cache_table(database);\n636: \n637:   const dimTableName = vector_table_name_for_profile(profile);\n638:   database.exec(`\n639:     CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)} (\n640:       id INTEGER PRIMARY KEY,\n641:       vec BLOB NOT NULL\n642:     )\n643:   `);\n644: \n645:   if (sqlite_vec_available_flag && !table_exists_in_schema(database, ACTIVE_VECTOR_SCHEMA, 'vec_memories')) {\n646:     database.exec(`\n647:       CREATE VIRTUAL TABLE ${ACTIVE_VECTOR_SCHEMA}.vec_memories USING vec0(\n648:         embedding FLOAT[${profile.dim}]\n649:       )\n650:     `);\n651:   }\n652: }\n653: \n654: function drop_canonical_vector_payload_tables(database: Database.Database): void {\n655:   for (const tableName of ['embedding_cache', 'vec_memories']) {\n656:     try {\n657:       database.exec(`DROP TABLE IF EXISTS main.${quote_identifier(tableName)}`);\n658:     } catch (_error: unknown) {\n659:       // Existing legacy virtual/shadow tables are migrated before this cleanup; failures are non-fatal.\n660:     }\n661:   }\n662:   const rows = database.prepare(`\n663:     SELECT name\n664:     FROM main.sqlite_master\n665:     WHERE type='table'\n666:       AND (name LIKE 'vec\\\\_%' ESCAPE '\\\\' OR name LIKE 'vec_memories\\\\_%' ESCAPE '\\\\')\n667:   `).all() as Array<{ name: string }>;\n668:   for (const row of rows) {\n669:     if (row.name === 'vec_metadata') {\n670:       continue;\n671:     }\n672:     try {\n673:       database.exec(`DROP TABLE IF EXISTS main.${quote_identifier(row.name)}`);\n674:     } catch (_error: unknown) {\n675:       // Best-effort canonical slimming. Query paths use active_vec after attach.\n676:     }\n677:   }\n678: }\n679: \n680: function create_legacy_temp_aliases(database: Database.Database, profile: EmbeddingProfile): void {\n681:   const dimTableName = vector_table_name_for_profile(profile);\n682:   try {\n683:     database.exec(`\n684:       DROP VIEW IF EXISTS temp.vec_memories;\n685:       DROP TRIGGER IF EXISTS temp.vec_memories_insert;\n686:       DROP TRIGGER IF EXISTS temp.vec_memories_delete;\n687:       CREATE TEMP VIEW vec_memories AS\n688:         SELECT rowid, embedding FROM ${ACTIVE_VECTOR_SCHEMA}.vec_memories;\n689:       CREATE TEMP TRIGGER vec_memories_insert\n690:       INSTEAD OF INSERT ON vec_memories\n691:       BEGIN\n692:         INSERT INTO ${ACTIVE_VECTOR_SCHEMA}.vec_memories(rowid, embedding)\n693:         VALUES (CAST(new.rowid AS INTEGER), new.embedding);\n694:       END;\n695:       CREATE TEMP TRIGGER vec_memories_delete\n696:       INSTEAD OF DELETE ON vec_memories\n697:       BEGIN\n698:         DELETE FROM ${ACTIVE_VECTOR_SCHEMA}.vec_memories WHERE rowid = old.rowid;\n699:       END;\n700:       DROP VIEW IF EXISTS temp.${quote_identifier(dimTableName)};\n701:       DROP TRIGGER IF EXISTS temp.${quote_identifier(`${dimTableName}_insert`)};\n702:       DROP TRIGGER IF EXISTS temp.${quote_identifier(`${dimTableName}_delete`)};\n703:       CREATE TEMP VIEW ${quote_identifier(dimTableName)} AS\n704:         SELECT id, vec FROM ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)};\n705:       CREATE TEMP TRIGGER ${quote_identifier(`${dimTableName}_insert`)}\n706:       INSTEAD OF INSERT ON ${quote_identifier(dimTableName)}\n707:       BEGIN\n708:         INSERT OR REPLACE INTO ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)}(id, vec)\n709:         VALUES (new.id, new.vec);\n710:       END;\n711:       CREATE TEMP TRIGGER ${quote_identifier(`${dimTableName}_delete`)}\n712:       INSTEAD OF DELETE ON ${quote_identifier(dimTableName)}\n713:       BEGIN\n714:         DELETE FROM ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)} WHERE id = old.id;\n715:       END;\n716:     `);\n717:   } catch (error: unknown) {\n718:     console.warn(`[vector-index] Could not create legacy vector temp aliases: ${get_error_message(error)}`);\n719:   }\n720: }\n721: \n722: function drop_legacy_temp_aliases(database: Database.Database): void {\n723:   try {\n724:     const rows = database.prepare(`\n725:       SELECT type, name\n726:       FROM temp.sqlite_master\n727:       WHERE name = 'vec_memories'\n728:          OR name LIKE 'vec_memories\\\\_%' ESCAPE '\\\\'\n729:          OR name LIKE 'vec\\\\_%' ESCAPE '\\\\'\n730:     `).all() as Array<{ type: string; name: string }>;\n731: \n732:     for (const row of rows) {\n733:       if (row.type !== 'view' && row.type !== 'trigger') {\n734:         continue;\n735:       }\n736:       database.exec(`DROP ${row.type.toUpperCase()} IF EXISTS temp.${quote_identifier(row.name)}`);\n737:     }\n738:   } catch (_error: unknown) {\n739:     // Best-effort cleanup only.\n740:   }\n741: }\n742: \n743: // Unified allowed paths\n744: const ALLOWED_BASE_PATHS = [\n745:   path.join(process.cwd(), 'specs'),\n746:   path.join(process.cwd(), '.opencode'),\n747:   path.join(os.homedir(), '.claude'),\n748:   process.cwd(),\n749:   ...(process.env.MEMORY_ALLOWED_PATHS ? process.env.MEMORY_ALLOWED_PATHS.split(path.delimiter) : [])\n750: ].filter(Boolean).map(p => path.resolve(p));\n751: \n752: /**\n753:  * Validates a file path against allowed local base paths.\n754:  * @param file_path - The file path to validate.\n755:  * @returns The validated file path, if allowed.\n756:  */\n757: export function validate_file_path_local(file_path: unknown): string | null {\n758:   if (typeof file_path !== 'string') {\n759:     return null;\n760:   }\n761: \n762:   return validateFilePath(file_path, ALLOWED_BASE_PATHS);\n763: }\n764: \n765: // HIGH-004 FIX: Async version for non-blocking concurrent file reads\n766: /**\n767:  * Reads a file asynchronously after validating the path.\n768:  * @param file_path - The file path to read.\n769:  * @returns A promise that resolves to the file contents or an empty string.\n770:  */\n771: export async function safe_read_file_async(file_path: unknown): Promise<string> {\n772:   const valid_path = validate_file_path_local(file_path);\n773:   if (!valid_path) {\n774:     return '';\n775:   }\n776: \n777:   try {\n778:     return await fs.promises.readFile(valid_path, 'utf-8');\n779:   } catch (err: unknown) {\n780:     if (!(err instanceof Error && 'code' in err && get_error_code(err) === 'ENOENT')) {\n781:       console.warn(`[vector-index] Could not read file ${valid_path}: ${get_error_message(err)}`);\n782:     }\n783:     return '';\n784:   }\n785: }\n786: \n787: // Safely parse JSON with validation (CWE-502: Deserialization mitigation)\n788: /**\n789:  * Parses JSON with prototype-pollution safeguards.\n790:  * @param json_string - The JSON string to parse.\n791:  * @param default_value - The fallback value to return on failure.\n792:  * @returns The parsed JSON value or the fallback.\n793:  */\n794: export function safe_parse_json(json_string: unknown, default_value = []): unknown {\n795:   if (!json_string || typeof json_string !== 'string') {\n796:     return default_value;\n797:   }\n798: \n799:   try {\n800:     const parsed = JSON.parse(json_string);\n801: \n802:     if (Array.isArray(parsed)) {\n803:       return parsed.filter(item =>\n804:         item && typeof item === 'object' &&\n805:         !Array.isArray(item) &&\n806:         !('__proto__' in item) &&\n807:         !('constructor' in item) &&\n808:         !('prototype' in item)\n809:       );\n810:     }\n811: \n812:     if (typeof parsed === 'object' && parsed !== null) {\n813:       if ('__proto__' in parsed || 'constructor' in parsed || 'prototype' in parsed) {\n814:         console.warn('[vector-index] Blocked potential prototype pollution in JSON');\n815:         return default_value;\n816:       }\n817:     }\n818: \n819:     return parsed;\n820:   } catch (err: unknown) {\n821:     console.warn(`[vector-index] JSON parse error: ${get_error_message(err)}`);\n822:     return default_value;\n823:   }\n824: }\n825: \n826: /* ───────────────────────────────────────────────────────────────\n827:    3. DATABASE SINGLETON\n828: ----------------------------------------------------------------*/\n829: \n830: let db: Database.Database | null = null;\n831: let db_path = resolve_database_path();\n832: let sqlite_vec_available_flag = true;\n833: let active_vector_source: ActiveVectorSourceTelemetry | null = null;\n834: // C1 FIX: Key connections by resolved DB path to prevent cross-store data corruption\n835: const db_connections = new Map<string, Database.Database>();\n836: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n837: type DatabaseConnectionListener = (\n838:   database: Database.Database,\n839:   change: {\n840:     previousDb: Database.Database | null;\n841:     previousPath: string;\n842:     nextPath: string;\n843:   },\n844: ) => boolean | void;\n845: const database_connection_listeners = new Set<DatabaseConnectionListener>();\n846: \n847: function set_active_database_connection(\n848:   connection: Database.Database,\n849:   target_path: string,\n850:   vec_available: boolean,\n851: ): void {\n852:   const previousDb = db;\n853:   const previousPath = db_path;\n854:   db = connection;\n855:   db_path = target_path;\n856:   sqlite_vec_available_flag = vec_available;\n857: \n858:   if (previousDb !== connection || previousPath !== target_path) {\n859:     clear_constitutional_cache();\n860: \n861:     const listenerErrors: string[] = [];\n862:     for (const listener of database_connection_listeners) {\n863:       try {\n864:         const listenerResult = listener(connection, {\n865:           previousDb,\n866:           previousPath,\n867:           nextPath: target_path,\n868:         });\n869:         if (listenerResult === false) {\n870:           listenerErrors.push('listener returned false');\n871:         }\n872:       } catch (error: unknown) {\n873:         const message = get_error_message(error);\n874:         listenerErrors.push(message);\n875:         console.warn(`[vector-index] Database connection listener failed: ${message}`);\n876:       }\n877:     }\n878:     if (listenerErrors.length > 0) {\n879:       throw new Error(`Database connection listener rebind failed: ${listenerErrors.join('; ')}`);\n880:     }\n881:   }\n882: \n883:   if (target_path === ':memory:') {\n884:     return;\n885:   }\n886: \n887:   try {\n888:     fs.chmodSync(target_path, DB_PERMISSIONS);\n889:   } catch (err: unknown) {\n890:     console.warn(`[vector-index] Could not set permissions on ${target_path}: ${get_error_message(err)}`);\n891:   }\n892: }\n893: \n894: function get_unclean_shutdown_marker_path(target_path: string): string | null {\n895:   if (target_path === ':memory:') {\n896:     return null;\n897:   }\n898:   return path.join(path.dirname(target_path), UNCLEAN_SHUTDOWN_MARKER);\n899: }\n900: \n901: function write_unclean_shutdown_marker(target_path: string): void {\n902:   const marker_path = get_unclean_shutdown_marker_path(target_path);\n903:   if (!marker_path) {\n904:     return;\n905:   }\n906: \n907:   try {\n908:     fs.writeFileSync(marker_path, `${JSON.stringify({\n909:       pid: process.pid,\n910:       databasePath: target_path,\n911:       startedAt: new Date().toISOString(),\n912:     })}\\n`, { mode: 0o600 });\n913:   } catch (_error: unknown) {\n914:     // Best-effort: marker failure must not block DB startup.\n915:   }\n916: }\n917: \n918: function remove_unclean_shutdown_marker(target_path: string): void {\n919:   const marker_path = get_unclean_shutdown_marker_path(target_path);\n920:   if (!marker_path) {\n921:     return;\n922:   }\n923: \n924:   try {\n925:     fs.rmSync(marker_path, { force: true });\n926:   } catch (_error: unknown) {\n927:     // Best-effort: marker cleanup must not block DB close.\n928:   }\n929: }\n930: \n931: function remove_sqlite_sidecars(database_path: string): void {\n932:   for (const sidecar_path of [`${database_path}-wal`, `${database_path}-shm`]) {\n933:     fs.rmSync(sidecar_path, { force: true });\n934:   }\n935: }\n936: \n937: function fsync_file_if_possible(file_path: string): void {\n938:   let fd: number | null = null;\n939:   try {\n940:     fd = fs.openSync(file_path, 'r');\n941:     fs.fsyncSync(fd);\n942:   } catch (_error: unknown) {\n943:     // Recovery remains journal-driven when the platform cannot flush explicitly.\n944:   } finally {\n945:     if (fd !== null) {\n946:       try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n947:     }\n948:   }\n949: }\n950: \n951: function fsync_directory_if_possible(dir_path: string): void {\n952:   let fd: number | null = null;\n953:   try {\n954:     fd = fs.openSync(dir_path, 'r');\n955:     fs.fsyncSync(fd);\n956:   } catch (_error: unknown) {\n957:     // Directory fsync is unavailable on some platforms/filesystems.\n958:   } finally {\n959:     if (fd !== null) {\n960:       try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n961:     }\n962:   }\n963: }\n964: \n965: function get_restore_journal_path(target_path: string): string | null {\n966:   if (target_path === ':memory:') {\n967:     return null;\n968:   }\n969:   return path.join(path.dirname(target_path), 'checkpoints', RESTORE_JOURNAL_NAME);\n970: }\n971: \n972: function get_needs_rebuild_sentinel_path(target_path: string): string | null {\n973:   if (target_path === ':memory:') {\n974:     return null;\n975:   }\n976:   return path.join(path.dirname(target_path), 'checkpoints', NEEDS_REBUILD_SENTINEL_NAME);\n977: }\n978: \n979: function write_needs_rebuild_sentinel_for_recovered_restore(target_path: string, checkpoint_name: string): void {\n980:   const sentinel_path = get_needs_rebuild_sentinel_path(target_path);\n981:   if (!sentinel_path || fs.existsSync(sentinel_path)) {\n982:     return;\n983:   }\n984: \n985:   try {\n986:     const sentinel_dir = path.dirname(sentinel_path);\n987:     const temp_sentinel_path = `${sentinel_path}.tmp`;\n988:     fs.mkdirSync(sentinel_dir, { recursive: true, mode: 0o700 });\n989:     fs.writeFileSync(temp_sentinel_path, `${JSON.stringify({\n990:       formatVersion: 1,\n991:       createdAt: new Date().toISOString(),\n992:       source: 'swap_done_recovery',\n993:       reason: 'completed restore journal recovered without derived rebuild evidence',\n994:       checkpointName: checkpoint_name,\n995:     }, null, 2)}\\n`, { mode: 0o600 });\n996:     fsync_file_if_possible(temp_sentinel_path);\n997:     fs.renameSync(temp_sentinel_path, sentinel_path);\n998:     fsync_directory_if_possible(sentinel_dir);\n999:   } catch (error: unknown) {\n1000:     console.warn(`[vector-index] Failed to write checkpoint needs-rebuild sentinel during recovery: ${get_error_message(error)}`);\n1001:   }\n1002: }\n1003: \n1004: function write_needs_rebuild_sentinel_for_corruption(target_path: string, detail: string): void {\n1005:   // Same atomic temp+rename discipline as the restore-recovery writer: a crash\n1006:   // mid-write must never leave a torn sentinel that half-triggers a rebuild.\n1007:   const sentinel_path = get_needs_rebuild_sentinel_path(target_path);\n1008:   if (!sentinel_path) {\n1009:     return;\n1010:   }\n1011:   try {\n1012:     const sentinel_dir = path.dirname(sentinel_path);\n1013:     fs.mkdirSync(sentinel_dir, { recursive: true });\n1014:     const temp_sentinel_path = `${sentinel_path}.tmp.${process.pid}`;\n1015:     fs.writeFileSync(temp_sentinel_path, `${JSON.stringify({\n1016:       formatVersion: 1,\n1017:       createdAt: new Date().toISOString(),\n1018:       source: 'post_crash_integrity_probe',\n1019:       reason: detail,\n1020:     }, null, 2)}\\n`, { mode: 0o600 });\n1021:     fsync_file_if_possible(temp_sentinel_path);\n1022:     fs.renameSync(temp_sentinel_path, sentinel_path);\n1023:     fsync_directory_if_possible(sentinel_dir);\n1024:   } catch (error: unknown) {\n1025:     console.warn(`[vector-index] Failed to write needs-rebuild sentinel after integrity probe: ${get_error_message(error)}`);\n1026:   }\n1027: }\n1028: \n1029: function read_restore_journal(journal_path: string): RestoreJournalFile | null {\n1030:   try {\n1031:     const parsed = JSON.parse(fs.readFileSync(journal_path, 'utf-8')) as Partial<RestoreJournalFile>;\n1032:     const phase = parsed.phase === 'swap-done' ? 'swap-done' : 'swap-pending';\n1033:     if (\n1034:       parsed.formatVersion !== 1\n1035:       || typeof parsed.createdAt !== 'string'\n1036:       || typeof parsed.checkpointName !== 'string'\n1037:       || typeof parsed.liveMainPath !== 'string'\n1038:       || typeof parsed.backupMainPath !== 'string'\n1039:       || typeof parsed.snapshotMainPath !== 'string'\n1040:       || (parsed.liveShardPath !== null && typeof parsed.liveShardPath !== 'string')\n1041:       || (parsed.backupShardPath !== null && typeof parsed.backupShardPath !== 'string')\n1042:       || (parsed.snapshotVecPath !== null && typeof parsed.snapshotVecPath !== 'string')\n1043:       || typeof parsed.shouldRestoreVec !== 'boolean'\n1044:       || (\n1045:         parsed.liveShardPreexisted !== undefined\n1046:         && typeof parsed.liveShardPreexisted !== 'boolean'\n1047:       )\n1048:     ) {\n1049:       throw new Error('restore journal shape is invalid');\n1050:     }\n1051:     return {\n1052:       ...parsed,\n1053:       phase,\n1054:       liveShardPreexisted: parsed.liveShardPreexisted\n1055:         ?? (parsed.shouldRestoreVec && typeof parsed.backupShardPath === 'string' && fs.existsSync(parsed.backupShardPath)),\n1056:     } as RestoreJournalFile;\n1057:   } catch (error: unknown) {\n1058:     console.warn(`[vector-index] Ignoring unreadable checkpoint restore journal: ${get_error_message(error)}`);\n1059:     return null;\n1060:   }\n1061: }\n1062: \n1063: function merge_checkpoint_catalog_from_backup(live_main_path: string, backup_main_path: string): void {\n1064:   // A swap-done crash happens after the snapshot DB is in place but before the live\n1065:   // catalog rows (captured from the pre-swap DB) are re-merged in-process. The snapshot's\n1066:   // checkpoints table only reflects state at snapshot time, so post-snapshot catalog rows\n1067:   // would be lost when boot recovery deletes the .bak. Re-merge them here, reading the BLOB\n1068:   // payloads directly from the .bak so v1 inline snapshots keep full fidelity. Best-effort:\n1069:   // recovery must finalize even if the merge cannot run.\n1070:   if (!fs.existsSync(backup_main_path)) {\n1071:     return;\n1072:   }\n1073:   let live_db: Database.Database | null = null;\n1074:   let backup_db: Database.Database | null = null;\n1075:   try {\n1076:     backup_db = new Database(backup_main_path, { readonly: true });\n1077:     const catalog_exists = backup_db.prepare(\n1078:       \"SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = 'checkpoints'\",\n1079:     ).get() as { 1?: number } | undefined;\n1080:     if (!catalog_exists) {\n1081:       return;\n1082:     }\n1083:     const backup_rows = backup_db.prepare('SELECT * FROM checkpoints ORDER BY id ASC').all() as Array<Record<string, unknown>>;\n1084:     if (backup_rows.length === 0) {\n1085:       return;\n1086:     }\n1087: \n1088:     live_db = new Database(live_main_path);\n1089:     const live_catalog_exists = live_db.prepare(\n1090:       \"SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = 'checkpoints'\",\n1091:     ).get() as { 1?: number } | undefined;\n1092:     if (!live_catalog_exists) {\n1093:       return;\n1094:     }\n1095:     const target_columns = new Set(\n1096:       (live_db.prepare('PRAGMA table_info(\"checkpoints\")').all() as Array<{ name?: unknown }>)\n1097:         .map((column) => column.name)\n1098:         .filter((name): name is string => typeof name === 'string' && name.length > 0),\n1099:     );\n1100: \n1101:     const merge = live_db.transaction((rows: Array<Record<string, unknown>>) => {\n1102:       for (const row of rows) {\n1103:         const name = row.name;\n1104:         if (typeof name !== 'string' || name.length === 0) {\n1105:           continue;\n1106:         }\n1107:         const existing_by_name = (live_db as Database.Database).prepare('SELECT id FROM checkpoints WHERE name = ?').get(name) as { id?: number } | undefined;\n1108:         if (existing_by_name?.id) {\n1109:           continue;\n1110:         }\n1111: \n1112:         let columns = Object.keys(row).filter((column) => target_columns.has(column));\n1113:         const id = row.id;\n1114:         if (typeof id === 'number') {\n1115:           const existing_by_id = (live_db as Database.Database).prepare('SELECT name FROM checkpoints WHERE id = ?').get(id) as { name?: string } | undefined;\n1116:           if (existing_by_id?.name && existing_by_id.name !== name) {\n1117:             columns = columns.filter((column) => column !== 'id');\n1118:           }\n1119:         }\n1120:         if (columns.length === 0) {\n1121:           continue;\n1122:         }\n1123: \n1124:         const placeholders = columns.map(() => '?').join(', ');\n1125:         (live_db as Database.Database).prepare(`\n1126:           INSERT OR IGNORE INTO checkpoints (${columns.join(', ')})\n1127:           VALUES (${placeholders})\n1128:         `).run(...columns.map((column) => row[column]));\n1129:       }\n1130:     });\n1131:     merge(backup_rows);\n1132:   } catch (error: unknown) {\n1133:     console.warn(`[vector-index] Failed to re-merge checkpoint catalog during swap-done recovery (non-fatal): ${get_error_message(error)}`);\n1134:   } finally {\n1135:     if (backup_db) {\n1136:       try { backup_db.close(); } catch (_error: unknown) { /* best-effort */ }\n1137:     }\n1138:     if (live_db) {\n1139:       try { live_db.close(); } catch (_error: unknown) { /* best-effort */ }\n1140:     }\n1141:   }\n1142: }\n1143: \n1144: export function recover_interrupted_checkpoint_restore(target_path: string): boolean {\n1145:   const journal_path = get_restore_journal_path(target_path);\n1146:   if (!journal_path || !fs.existsSync(journal_path)) {\n1147:     return false;\n1148:   }\n1149: \n1150:   const journal = read_restore_journal(journal_path);\n1151:   if (!journal) {\n1152:     return false;\n1153:   }\n1154: \n1155:   if (journal.phase === 'swap-done') {\n1156:     // Re-merge any post-snapshot catalog rows from the .bak before deleting it; the\n1157:     // crashed in-process restore would have done this merge had it not been interrupted.\n1158:     merge_checkpoint_catalog_from_backup(journal.liveMainPath, journal.backupMainPath);\n1159:     fs.rmSync(journal.backupMainPath, { force: true });\n1160:     fsync_directory_if_possible(path.dirname(journal.backupMainPath));\n1161:     if (journal.shouldRestoreVec && journal.backupShardPath) {\n1162:       fs.rmSync(journal.backupShardPath, { force: true });\n1163:       fsync_directory_if_possible(path.dirname(journal.backupShardPath));\n1164:     }\n1165:     write_needs_rebuild_sentinel_for_recovered_restore(journal.liveMainPath, journal.checkpointName);\n1166:     fs.rmSync(journal_path, { force: true });\n1167:     fsync_directory_if_possible(path.dirname(journal_path));\n1168:     console.warn('[vector-index] Finalized completed checkpoint restore from rollback journal');\n1169:     return true;\n1170:   }\n1171: \n1172:   remove_sqlite_sidecars(journal.liveMainPath);\n1173:   if (fs.existsSync(journal.backupMainPath)) {\n1174:     fs.rmSync(journal.liveMainPath, { force: true });\n1175:     fs.renameSync(journal.backupMainPath, journal.liveMainPath);\n1176:     fsync_file_if_possible(journal.liveMainPath);\n1177:     fsync_directory_if_possible(path.dirname(journal.liveMainPath));\n1178:   }\n1179: \n1180:   if (journal.shouldRestoreVec && journal.liveShardPath) {\n1181:     remove_sqlite_sidecars(journal.liveShardPath);\n1182:     if (journal.liveShardPreexisted && journal.backupShardPath && fs.existsSync(journal.backupShardPath)) {\n1183:       fs.rmSync(journal.liveShardPath, { force: true });\n1184:       fs.renameSync(journal.backupShardPath, journal.liveShardPath);\n1185:       fsync_file_if_possible(journal.liveShardPath);\n1186:       fsync_directory_if_possible(path.dirname(journal.liveShardPath));\n1187:     } else if (!journal.liveShardPreexisted) {\n1188:       fs.rmSync(journal.liveShardPath, { force: true });\n1189:       fsync_directory_if_possible(path.dirname(journal.liveShardPath));\n1190:     }\n1191:   }\n1192: \n1193:   fs.rmSync(journal_path, { force: true });\n1194:   fsync_directory_if_possible(path.dirname(journal_path));\n1195:   console.warn('[vector-index] Recovered interrupted checkpoint restore from rollback journal');\n1196:   return true;\n1197: }\n1198: \n1199: export function migrate_active_legacy_profile_database(\n1200:   canonicalPath: string,\n1201:   profile: EmbeddingProfile,\n1202: ): void {\n1203:   if (canonicalPath === ':memory:') {\n1204:     return;\n1205:   }\n1206: \n1207:   const baseDir = path.dirname(canonicalPath);\n1208:   const shardPath = get_vector_shard_path(profile, baseDir);\n1209:   const legacyPath = legacy_profile_database_path(profile, baseDir);\n1210:   if (path.resolve(legacyPath) === path.resolve(canonicalPath)) {\n1211:     return;\n1212:   }\n1213: \n1214:   migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n1215: }\n1216: \n1217: export function attachActiveVectorShard(database: Database.Database, profile: EmbeddingProfile): void {\n1218:   try {\n1219:     sqliteVec.load(database);\n1220:     sqlite_vec_available_flag = true;\n1221:   } catch (_error: unknown) {\n1222:     sqlite_vec_available_flag = false;\n1223:   }\n1224:   database.pragma('journal_mode = WAL');\n1225:   const canonicalPath = get_database_file_path(database);\n1226:   const baseDir = resolve_database_base_dir(database);\n1227:   const shardPath = get_vector_shard_path(profile, baseDir);\n1228:   const attachedPath = get_attached_vector_path(database);\n1229: \n1230:   if (attachedPath && attachedPath !== path.resolve(shardPath)) {\n1231:     drop_legacy_temp_aliases(database);\n1232:     database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1233:   } else if (attachedPath === path.resolve(shardPath)) {\n1234:     const probe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n1235:     if (!probe.ok) {\n1236:       drop_legacy_temp_aliases(database);\n1237:       database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1238:       quarantine_and_rebuild_vector_shard(database, profile, shardPath, probe.reason);\n1239:       database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1240:       ensure_vector_shard_schema(database, profile);\n1241:       drop_canonical_vector_payload_tables(database);\n1242:       create_legacy_temp_aliases(database, profile);\n1243:       active_vector_source = {\n1244:         canonical_path: canonicalPath,\n1245:         shard_path: shardPath,\n1246:         attached: true,\n1247:         profile: {\n1248:           provider: profile.provider,\n1249:           model: profile.model,\n1250:           dim: profile.dim,\n1251:           dtype: profile.dtype,\n1252:         },\n1253:       };\n1254:       return;\n1255:     }\n1256:     ensure_vector_shard_schema(database, profile);\n1257:     drop_canonical_vector_payload_tables(database);\n1258:     create_legacy_temp_aliases(database, profile);\n1259:     active_vector_source = {\n1260:       canonical_path: canonicalPath,\n1261:       shard_path: shardPath,\n1262:       attached: true,\n1263:       profile: {\n1264:         provider: profile.provider,\n1265:         model: profile.model,\n1266:         dim: profile.dim,\n1267:         dtype: profile.dtype,\n1268:       },\n1269:     };\n1270:     return;\n1271:   }\n1272: \n1273:   const shardExistedBeforeAttach = fs.existsSync(shardPath);\n1274:   const preAttachProbe = run_vector_shard_integrity_probe_at_path(shardPath, profile, sqlite_vec_available_flag);\n1275:   let needsPostAttachProbe = shardExistedBeforeAttach && preAttachProbe.ok;\n1276:   if (!preAttachProbe.ok) {\n1277:     quarantine_and_rebuild_vector_shard(database, profile, shardPath, preAttachProbe.reason);\n1278:     needsPostAttachProbe = false;\n1279:   }\n1280: \n1281:   try {\n1282:     database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1283:   } catch (attachError: unknown) {\n1284:     const reason = get_error_message(attachError);\n1285:     if (!fs.existsSync(shardPath)) {\n1286:       throw attachError;\n1287:     }\n1288:     quarantine_and_rebuild_vector_shard(database, profile, shardPath, reason);\n1289:     needsPostAttachProbe = false;\n1290:     database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1291:   }\n1292: \n1293:   if (needsPostAttachProbe) {\n1294:     const attachedProbe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n1295:     if (!attachedProbe.ok) {\n1296:       drop_legacy_temp_aliases(database);\n1297:       database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1298:       quarantine_and_rebuild_vector_shard(database, profile, shardPath, attachedProbe.reason);\n1299:       database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n1300:     }\n1301:   }\n1302:   ensure_vector_shard_schema(database, profile);\n1303:   drop_canonical_vector_payload_tables(database);\n1304:   create_legacy_temp_aliases(database, profile);\n1305:   active_vector_source = {\n1306:     canonical_path: canonicalPath,\n1307:     shard_path: shardPath,\n1308:     attached: true,\n1309:     profile: {\n1310:       provider: profile.provider,\n1311:       model: profile.model,\n1312:       dim: profile.dim,\n1313:       dtype: profile.dtype,\n1314:     },\n1315:   };\n1316: }\n1317: \n1318: export function attachActiveVectorShardForActiveProfile(database: Database.Database): void {\n1319:   attachActiveVectorShard(database, resolve_profile_for_active_embedder(database));\n1320: }\n1321: \n1322: export function detachActiveVectorShard(database: Database.Database): void {\n1323:   drop_legacy_temp_aliases(database);\n1324: \n1325:   if (get_attached_vector_path(database)) {\n1326:     database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n1327:   }\n1328: \n1329:   if (active_vector_source) {\n1330:     active_vector_source = { ...active_vector_source, attached: false };\n1331:   }\n1332: }\n1333: \n1334: export function getActiveVectorSource(): ActiveVectorSourceTelemetry {\n1335:   if (db) {\n1336:     const profile = resolve_profile_for_active_embedder(db);\n1337:     const canonicalPath = get_database_file_path(db);\n1338:     const baseDir = resolve_database_base_dir(db);\n1339:     const shardPath = get_vector_shard_path(profile, baseDir);\n1340:     const attached = get_attached_vector_path(db) === path.resolve(shardPath);\n1341:     active_vector_source = {\n1342:       canonical_path: canonicalPath,\n1343:       shard_path: shardPath,\n1344:       attached,\n1345:       profile: {\n1346:         provider: profile.provider,\n1347:         model: profile.model,\n1348:         dim: profile.dim,\n1349:         dtype: profile.dtype,\n1350:       },\n1351:     };\n1352:   }\n1353: \n1354:   return active_vector_source ?? {\n1355:     canonical_path: db_path,\n1356:     shard_path: '',\n1357:     attached: false,\n1358:     profile: {\n1359:       provider: '',\n1360:       model: '',\n1361:       dim: get_embedding_dim(),\n1362:       dtype: null,\n1363:     },\n1364:   };\n1365: }\n1366: \n1367: /** Accessor for sqlite_vec_available (used by other modules) */\n1368: export function sqlite_vec_available(): boolean {\n1369:   return sqlite_vec_available_flag;\n1370: }\n1371: \n1372: export function on_database_connection_change(listener: DatabaseConnectionListener): () => void {\n1373:   database_connection_listeners.add(listener);\n1374:   return () => {\n1375:     database_connection_listeners.delete(listener);\n1376:   };\n1377: }\n1378: \n1379: const constitutional_cache = new Map<string, { data: MemoryRow[]; timestamp: number }>();\n1380: const CONSTITUTIONAL_CACHE_TTL = 300000;\n1381: const CONSTITUTIONAL_CACHE_MAX_KEYS = 50;\n1382: \n1383: // BUG-012 FIX: Track which cache keys are currently being loaded\n1384: const constitutional_cache_loading = new Map<string, boolean>();\n1385: \n1386: let last_db_mod_time = 0;\n1387: let last_constitutional_cache_db_path: string | null = null;\n1388: \n1389: function get_constitutional_cache_db_scope(): string {\n1390:   if (db_path === ':memory:') {\n1391:     return db_path;\n1392:   }\n1393: \n1394:   return path.resolve(db_path);\n1395: }\n1396: \n1397: function build_constitutional_cache_key(\n1398:   spec_folder: string | null,\n1399:   includeArchived: boolean,\n1400: ): string {\n1401:   const db_scope = get_constitutional_cache_db_scope();\n1402:   return `${db_scope}::${spec_folder || 'global'}:${includeArchived ? 'arch' : 'noarch'}`;\n1403: }\n1404: \n1405: function refresh_constitutional_cache_db_state(): void {\n1406:   const current_db_path = get_constitutional_cache_db_scope();\n1407:   last_constitutional_cache_db_path = current_db_path;\n1408: \n1409:   if (current_db_path === ':memory:' || !fs.existsSync(current_db_path)) {\n1410:     last_db_mod_time = 0;\n1411:     return;\n1412:   }\n1413: \n1414:   last_db_mod_time = fs.statSync(current_db_path).mtimeMs;\n1415: }\n1416: \n1417: function is_constitutional_cache_valid() {\n1418:   if (constitutional_cache.size === 0) return false;\n1419: \n1420:   try {\n1421:     const current_db_path = get_constitutional_cache_db_scope();\n1422:     if (\n1423:       last_constitutional_cache_db_path &&\n1424:       last_constitutional_cache_db_path !== current_db_path\n1425:     ) {\n1426:       return false;\n1427:     }\n1428: \n\n(Output capped at 50 KB. Showing lines 1-1428. Use offset=1429 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Store\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// SEARCH: VECTOR INDEX\n// TypeScript port of the vector index implementation.\n// DECAY STRATEGY: Search-time temporal decay uses an\n// FSRS-preferred strategy. Memories with FSRS review data (last_review\n// IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n// R(t) = (1 + 0.2346 * t / S)^(-0.5)\n// Memories without review data fall back to half-life exponential:\n// Weight * 0.5^(days / half_life_days)\n// This ensures backward compatibility while aligning reviewed\n// Memories with the canonical FSRS algorithm.\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Store\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// SEARCH: VECTOR INDEX\n// TypeScript port of the vector index implementation.\n// DECAY STRATEGY: Search-time temporal decay uses an\n// FSRS-preferred strategy. Memories with FSRS review data (last_review\n// IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n// R(t) = (1 + 0.2346 * t / S)^(-0.5)\n// Memories without review data fall back to half-life exponential:\n// Weight * 0.5^(days / half_life_days)\n// This ensures backward compatibility while aligning reviewed\n// Memories with the canonical FSRS algorithm.\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { getEmbeddingDimension } from '@spec-kit/shared/embeddings';\nimport {\n  EmbeddingProfile,\n} from '@spec-kit/shared/embeddings/profile';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings/factory';\n\nimport { resolveDatabasePaths, SERVER_DIR } from '../../core/config.js';\nimport { computeInterferenceScoresBatch } from '../scoring/interference-scoring.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport {\n  recordVectorShardProbeFailure,\n  recordVectorShardQuarantined,\n  recordVectorShardRebuildFailed,\n} from '../observability/retrieval-observability.js';\nimport { validateFilePath } from '../utils/path-security.js';\nimport {\n  get_error_code,\n  get_error_message,\n  parse_trigger_phrases,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  create_schema,\n  ensure_schema_version,\n} from './vector-index-schema.js';\nimport { migrateLegacySingleDbToShardSync } from './db-shard-migration.js';\nimport type { MemoryRow } from './vector-index-types.js';\n\ntype SearchWeightsConfig = {\n  maxTriggersPerMemory?: number;\n  smartRanking?: {\n    recencyWeight?: number;\n    accessWeight?: number;\n    relevanceWeight?: number;\n  };\n};\n\ntype RestoreJournalPhase = 'swap-pending' | 'swap-done';\n\ntype RestoreJournalFile = {\n  formatVersion: 1;\n  phase: RestoreJournalPhase;\n  createdAt: string;\n  checkpointName: string;\n  liveMainPath: string;\n  backupMainPath: string;\n  snapshotMainPath: string;\n  liveShardPath: string | null;\n  backupShardPath: string | null;\n  snapshotVecPath: string | null;\n  shouldRestoreVec: boolean;\n  liveShardPreexisted: boolean;\n};\n\ntype InitializeDbOptions = {\n  skipRestoreRecovery?: boolean;\n};\n\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';\nconst NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n\nfunction loadSearchWeights(): SearchWeightsConfig {\n  // SERVER_DIR points to dist/ at runtime; configs/ lives at the package root (dist/..)\n  const candidates = [\n    path.join(SERVER_DIR, 'configs', 'search-weights.json'),\n    path.join(SERVER_DIR, '..', 'configs', 'search-weights.json'),\n  ];\n  for (const candidate of candidates) {\n    try {\n      return JSON.parse(fs.readFileSync(candidate, 'utf-8')) as SearchWeightsConfig;\n    } catch {\n      // Try next candidate\n    }\n  }\n  return {};\n}\n\nlet _search_weights: SearchWeightsConfig | null = null;\n\nfunction getSearchWeights(): SearchWeightsConfig {\n  if (_search_weights === null) {\n    _search_weights = loadSearchWeights();\n  }\n  return _search_weights;\n}\n\n/** Loaded search weight configuration for vector-index ranking (lazy-loaded). */\nexport const search_weights: SearchWeightsConfig = {\n  get maxTriggersPerMemory() {\n    return getSearchWeights().maxTriggersPerMemory;\n  },\n  get smartRanking() {\n    return getSearchWeights().smartRanking;\n  },\n};\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONFIGURATION — Embedding Dimension\n----------------------------------------------------------------*/\n\n/** Default embedding dimension used by the vector index. */\nexport const EMBEDDING_DIM = getEmbeddingDimension();\n\n/**\n * Gets the active embedding dimension for the current provider.\n * @returns The embedding dimension.\n */\nexport function get_embedding_dim(): number {\n  return getEmbeddingDimension();\n}\n\n/**\n * Waits for the embedding provider to report a stable dimension.\n * @param timeout_ms - The maximum time to wait in milliseconds.\n * @returns A promise that resolves to the confirmed embedding dimension.\n */\nexport async function get_confirmed_embedding_dimension(timeout_ms = 5000): Promise<number> {\n  const start = Date.now();\n  while (Date.now() - start < timeout_ms) {\n    const dim = get_embedding_dim();\n    if (Number.isFinite(dim) && dim > 0) {\n      return dim;\n    }\n    await new Promise(resolve => setTimeout(resolve, 100));\n  }\n  const fallbackDim = get_embedding_dim();\n  console.warn(`[vector-index] Using embedding dimension ${fallbackDim} after timeout`);\n  return fallbackDim;\n}\n\ntype EmbeddingDimensionValidation = {\n  valid: boolean;\n  stored: number | null;\n  current: number | null;\n  reason?: string;\n  warning?: string;\n};\n\ntype StoredEmbeddingDimension = {\n  existing_db: boolean;\n  stored_dim: number | null;\n  source: 'vec_metadata' | 'active_embedder_profile' | 'startup_profile' | 'vec_memories' | null;\n  reason?: string;\n};\n\nfunction get_existing_embedding_dimension(\n  database: Database.Database,\n  options: { allowProfileFallback?: boolean } = {},\n): StoredEmbeddingDimension {\n  const allowProfileFallback = options.allowProfileFallback !== false;\n  const schema_row = database.prepare(`\n    SELECT name FROM sqlite_master WHERE type='table' AND name='memory_index'\n  `).get();\n\n  if (!schema_row) {\n    return {\n      existing_db: false,\n      stored_dim: null,\n      source: null,\n      reason: 'No existing schema',\n    };\n  }\n\n  const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string }>;\n  if (attached.some((entry) => entry.name === ACTIVE_VECTOR_SCHEMA)) {\n    const shard_metadata_table = database.prepare(`\n      SELECT name FROM ${ACTIVE_VECTOR_SCHEMA}.sqlite_master WHERE type='table' AND name='vec_metadata'\n    `).get();\n\n    if (shard_metadata_table) {\n      const stored_row = database.prepare(`\n        SELECT value FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata WHERE key IN ('embedding_dim', 'dim')\n        ORDER BY CASE key WHEN 'embedding_dim' THEN 0 ELSE 1 END\n        LIMIT 1\n      `).get() as { value: string } | undefined;\n\n      if (stored_row) {\n        const stored_dim = parseInt(stored_row.value, 10);\n        if (Number.isFinite(stored_dim) && stored_dim > 0) {\n          return {\n            existing_db: true,\n            stored_dim,\n            source: 'vec_metadata',\n          };\n        }\n      }\n    }\n  }\n\n  const metadata_table = database.prepare(`\n    SELECT name FROM sqlite_master WHERE type='table' AND name='vec_metadata'\n  `).get();\n\n  if (metadata_table) {\n    const stored_row = database.prepare(`\n      SELECT key, value FROM vec_metadata WHERE key IN ('embedding_dim', 'dim', 'active_embedder_dim')\n      ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n      LIMIT 1\n    `).get() as { key: string; value: string } | undefined;\n\n    if (stored_row) {\n      const stored_dim = parseInt(stored_row.value, 10);\n      if (Number.isFinite(stored_dim) && stored_dim > 0) {\n        return {\n          existing_db: true,\n          stored_dim,\n          source: stored_row.key === 'active_embedder_dim' ? 'active_embedder_profile' : 'vec_metadata',\n        };\n      }\n    }\n  }\n\n  if (allowProfileFallback) {\n    const active = getActiveEmbedder(database);\n    if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n      return {\n        existing_db: true,\n        stored_dim: active.dim,\n        source: 'active_embedder_profile',\n      };\n    }\n\n    const startupProfile = getStartupEmbeddingProfile();\n    if (Number.isInteger(startupProfile.dim) && startupProfile.dim > 0) {\n      return {\n        existing_db: true,\n        stored_dim: startupProfile.dim,\n        source: 'startup_profile',\n      };\n    }\n  }\n\n  const vec_table = database.prepare(`\n    SELECT sql FROM sqlite_master WHERE name='vec_memories'\n  `).get() as { sql: string | null } | undefined;\n  const vec_sql = typeof vec_table?.sql === 'string' ? vec_table.sql : null;\n  const match = vec_sql?.match(/FLOAT\\[(\\d+)\\]/i);\n\n  if (match) {\n    const stored_dim = parseInt(match[1], 10);\n    if (Number.isFinite(stored_dim) && stored_dim > 0) {\n      console.warn('[vector-index] Falling back to vec_memories schema text for embedding dimension; configure an active embedder profile to make dimension discovery authoritative.');\n      return {\n        existing_db: true,\n        stored_dim,\n        source: 'vec_memories',\n      };\n    }\n  }\n\n  return {\n    existing_db: true,\n    stored_dim: null,\n    source: null,\n    reason: 'No stored vector dimension found for existing schema',\n  };\n}\n\nfunction validate_embedding_dimension_for_connection(\n  database: Database.Database | null,\n  _sqlite_vec_available: boolean,\n): EmbeddingDimensionValidation {\n  if (!database) {\n    return { valid: true, stored: null, current: null, reason: 'No database' };\n  }\n\n  try {\n    const active = getActiveEmbedder(database);\n    const current_dim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0\n      ? active.dim\n      : get_embedding_dim();\n    const existing = get_existing_embedding_dimension(database);\n\n    if (!existing.existing_db) {\n      return { valid: true, stored: null, current: current_dim, reason: existing.reason };\n    }\n\n    if (existing.stored_dim == null) {\n      return { valid: true, stored: null, current: current_dim, reason: existing.reason || 'No stored dimension' };\n    }\n\n    if (existing.stored_dim !== current_dim) {\n      const source_label = existing.source === 'vec_metadata' ? 'vec_metadata' : 'vec_memories schema';\n      const warning = `EMBEDDING DIMENSION MISMATCH: Existing database stores ${existing.stored_dim}-dim vectors (${source_label}), ` +\n        `but the active embedding configuration resolves to ${current_dim}. Refusing to bootstrap because vector search would fail. ` +\n        `Solutions: 1) Delete database and re-index, 2) Set EMBEDDINGS_PROVIDER to match original, ` +\n        `3) Let SPEC_KIT_DB_DIR auto-derive a profile-specific database, or set MEMORY_DB_PATH only for an intentional file override.`;\n      console.error(`[vector-index] WARNING: ${warning}`);\n      return { valid: false, stored: existing.stored_dim, current: current_dim, warning };\n    }\n\n    return { valid: true, stored: existing.stored_dim, current: current_dim };\n  } catch (e: unknown) {\n    console.warn('[vector-index] Dimension validation error:', get_error_message(e));\n    return { valid: true, stored: null, current: get_embedding_dim(), reason: get_error_message(e) };\n  }\n}\n\n/**\n * Validates that stored vector dimensions match the provider.\n * @returns The validation result.\n */\nexport function validate_embedding_dimension(): { valid: boolean; stored: number | null; current: number | null; reason?: string; warning?: string } {\n  return validate_embedding_dimension_for_connection(db, sqlite_vec_available_flag);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. DATABASE PATH AND SECURITY\n----------------------------------------------------------------*/\n\nfunction get_default_db_path(): string {\n  return process.env.MEMORY_DB_PATH || resolveDatabasePaths().databasePath;\n}\n\n/** Default path for the vector-index database file. */\nexport const DEFAULT_DB_PATH = process.env.MEMORY_DB_PATH\n  || get_default_db_path();\nconst DB_PERMISSIONS = 0o600;\n\nfunction resolve_database_path() {\n  return process.env.MEMORY_DB_PATH || get_default_db_path();\n}\n\nexport const ACTIVE_VECTOR_SCHEMA = 'active_vec';\n\ntype ActiveVectorSourceTelemetry = {\n  canonical_path: string;\n  shard_path: string;\n  attached: boolean;\n  profile: {\n    provider: string;\n    model: string;\n    dim: number;\n    dtype: string | null;\n  };\n};\n\nfunction quote_sql_string(value: string): string {\n  return `'${value.replace(/'/g, \"''\")}'`;\n}\n\nfunction quote_identifier(value: string): string {\n  return `\"${value.replace(/\"/g, '\"\"')}\"`;\n}\n\nfunction get_database_file_path(database: Database.Database): string {\n  const row = database.prepare('PRAGMA database_list').all()\n    .find((entry: unknown) => (entry as { name?: string }).name === 'main') as { file?: string } | undefined;\n  return row?.file && row.file.length > 0 ? row.file : db_path;\n}\n\nfunction resolve_database_base_dir(database: Database.Database): string {\n  const filePath = get_database_file_path(database);\n  if (!filePath || filePath === ':memory:') {\n    return resolveDatabasePaths().databaseDir;\n  }\n  return path.dirname(filePath);\n}\n\nfunction legacy_profile_database_path(profile: EmbeddingProfile, baseDir: string): string {\n  return path.join(baseDir, `context-index__${profile.slug}.sqlite`);\n}\n\nfunction get_vector_shard_path(profile: EmbeddingProfile, baseDir: string): string {\n  const vectorDir = path.join(baseDir, 'vectors');\n  if (!fs.existsSync(vectorDir)) {\n    fs.mkdirSync(vectorDir, { recursive: true, mode: 0o700 });\n  }\n  return path.join(vectorDir, `context-vectors__${profile.slug}.sqlite`);\n}\n\nfunction resolve_profile_for_active_embedder(database: Database.Database): EmbeddingProfile {\n  const active = getActiveEmbedder(database);\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && active.dim > 0) {\n    const startup = getStartupEmbeddingProfile();\n    return new EmbeddingProfile({\n      provider: active.provider ?? startup.provider,\n      model: active.name,\n      dim: active.dim,\n      dtype: null,\n      baseUrl: startup.baseUrl,\n    });\n  }\n  return getStartupEmbeddingProfile();\n}\n\nfunction vector_table_name_for_profile(profile: EmbeddingProfile): string {\n  return `vec_${profile.dim}`;\n}\n\nfunction active_schema_table(tableName: string): string {\n  return `${ACTIVE_VECTOR_SCHEMA}.${tableName}`;\n}\n\nexport function activeVectorSource(tableName?: string): string {\n  return tableName ? active_schema_table(tableName) : ACTIVE_VECTOR_SCHEMA;\n}\n\nfunction get_attached_vector_path(database: Database.Database): string | null {\n  const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>;\n  const row = attached.find((entry) => entry.name === ACTIVE_VECTOR_SCHEMA);\n  return row?.file ? path.resolve(row.file) : null;\n}\n\nfunction table_exists_in_schema(database: Database.Database, schema: string, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM ${quote_identifier(schema)}.sqlite_master\n    WHERE type IN ('table', 'view') AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\ntype VectorShardIntegrityProbeResult =\n  | { ok: true }\n  | { ok: false; reason: string };\n\nfunction quick_check_verdict(database: Database.Database, schema?: string): string {\n  const rows = schema\n    ? database.pragma(`${schema}.quick_check(1)`) as Array<Record<string, unknown>>\n    : database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n  const first = rows?.[0] ? Object.values(rows[0])[0] : undefined;\n  return typeof first === 'string' ? first : 'quick_check returned no verdict';\n}\n\nfunction required_vector_shard_tables(profile: EmbeddingProfile, vecAvailable: boolean): string[] {\n  return [\n    'vec_metadata',\n    'embedding_cache',\n    vector_table_name_for_profile(profile),\n    ...(vecAvailable ? ['vec_memories'] : []),\n  ];\n}\n\nfunction run_attached_vector_shard_integrity_probe(\n  database: Database.Database,\n  profile: EmbeddingProfile,\n  vecAvailable: boolean,\n): VectorShardIntegrityProbeResult {\n  try {\n    const verdict = quick_check_verdict(database, ACTIVE_VECTOR_SCHEMA);\n    if (verdict !== 'ok') {\n      return { ok: false, reason: `quick_check failed: ${verdict}` };\n    }\n    for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n      if (!table_exists_in_schema(database, ACTIVE_VECTOR_SCHEMA, tableName)) {\n        return { ok: false, reason: `required table missing: ${tableName}` };\n      }\n    }\n    return { ok: true };\n  } catch (error: unknown) {\n    return { ok: false, reason: get_error_message(error) };\n  }\n}\n\nfunction run_vector_shard_integrity_probe_at_path(\n  shardPath: string,\n  profile: EmbeddingProfile,\n  vecAvailable: boolean,\n): VectorShardIntegrityProbeResult {\n  if (!fs.existsSync(shardPath)) {\n    return { ok: true };\n  }\n\n  let shard: Database.Database | null = null;\n  try {\n    shard = new Database(shardPath, { readonly: true, fileMustExist: true });\n    if (vecAvailable) {\n      sqliteVec.load(shard);\n    }\n    const verdict = quick_check_verdict(shard);\n    if (verdict !== 'ok') {\n      return { ok: false, reason: `quick_check failed: ${verdict}` };\n    }\n    for (const tableName of required_vector_shard_tables(profile, vecAvailable)) {\n      const row = shard.prepare(`\n        SELECT 1 AS found\n        FROM sqlite_master\n        WHERE type IN ('table', 'view') AND name = ?\n        LIMIT 1\n      `).get(tableName) as { found?: number } | undefined;\n      if (row?.found !== 1) {\n        return { ok: false, reason: `required table missing: ${tableName}` };\n      }\n    }\n    return { ok: true };\n  } catch (error: unknown) {\n    return { ok: false, reason: get_error_message(error) };\n  } finally {\n    if (shard) {\n      try { shard.close(); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction quarantine_vector_shard(shardPath: string, reason: string): string {\n  const stamp = new Date().toISOString().replace(/[^0-9A-Za-z]/g, '');\n  const quarantinePath = `${shardPath}.quarantined-${stamp}-${process.pid}`;\n  for (const suffix of ['', '-wal', '-shm']) {\n    const source = `${shardPath}${suffix}`;\n    if (!fs.existsSync(source)) {\n      continue;\n    }\n    fs.renameSync(source, `${quarantinePath}${suffix}`);\n  }\n  fsync_file_if_possible(quarantinePath);\n  fsync_directory_if_possible(path.dirname(shardPath));\n  recordVectorShardQuarantined({ shardPath, quarantinePath, reason });\n  return quarantinePath;\n}\n\nfunction schedule_vector_shard_rebuild(\n  database: Database.Database,\n  profile: EmbeddingProfile,\n  shardPath: string,\n  reason: string,\n): void {\n  setImmediate(() => {\n    void import('../embedders/reindex.js')\n      .then(({ startVectorShardRepairReindex }) => {\n        startVectorShardRepairReindex(profile, { db: database, reason, shardPath });\n      })\n      .catch((error: unknown) => {\n        recordVectorShardRebuildFailed({\n          jobId: 'not-started',\n          shardPath,\n          reason: get_error_message(error),\n        });\n      });\n  });\n}\n\nfunction quarantine_and_rebuild_vector_shard(\n  database: Database.Database,\n  profile: EmbeddingProfile,\n  shardPath: string,\n  reason: string,\n): void {\n  recordVectorShardProbeFailure({ shardPath, reason });\n  const quarantinePath = quarantine_vector_shard(shardPath, reason);\n  schedule_vector_shard_rebuild(database, profile, shardPath, `${reason}; quarantined as ${path.basename(quarantinePath)}`);\n}\n\nfunction write_shard_metadata(database: Database.Database, profile: EmbeddingProfile): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.vec_metadata (\n      key TEXT PRIMARY KEY,\n      value TEXT NOT NULL,\n      created_at TEXT DEFAULT (datetime('now'))\n    )\n  `);\n\n  const rows = database.prepare(`\n    SELECT key, value\n    FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata\n    WHERE key IN ('provider', 'model', 'dim', 'embedding_dim')\n  `).all() as Array<{ key: string; value: string }>;\n  const metadata = new Map(rows.map((row) => [row.key, row.value]));\n  const mismatches = [\n    ['provider', profile.provider],\n    ['model', profile.model],\n    ['dim', String(profile.dim)],\n    ['embedding_dim', String(profile.dim)],\n  ].filter(([key, expected]) => {\n    const actual = metadata.get(key);\n    return actual != null && actual.length > 0 && actual !== expected;\n  });\n\n  if (mismatches.length > 0) {\n    const detail = mismatches.map(([key, expected]) => `${key}: expected ${expected}, got ${metadata.get(key)}`).join('; ');\n    throw new VectorIndexError(\n      `Attached vector shard metadata mismatch (${detail})`,\n      VectorIndexErrorCode.INTEGRITY_ERROR,\n    );\n  }\n\n  const upsert = database.prepare(`\n    INSERT OR REPLACE INTO ${ACTIVE_VECTOR_SCHEMA}.vec_metadata (key, value)\n    VALUES (?, ?)\n  `);\n  upsert.run('provider', profile.provider);\n  upsert.run('model', profile.model);\n  upsert.run('dim', String(profile.dim));\n  upsert.run('embedding_dim', String(profile.dim));\n}\n\nfunction ensure_embedding_cache_table(database: Database.Database): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.embedding_cache (\n      content_hash TEXT NOT NULL,\n      profile_key TEXT NOT NULL DEFAULT '',\n      input_kind TEXT NOT NULL DEFAULT 'document' CHECK (input_kind IN ('document', 'query')),\n      model_id TEXT NOT NULL,\n      embedding BLOB NOT NULL,\n      dimensions INTEGER NOT NULL,\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      last_used_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (content_hash, profile_key, input_kind, model_id, dimensions)\n    )\n  `);\n}\n\nfunction ensure_vector_shard_schema(database: Database.Database, profile: EmbeddingProfile): void {\n  database.pragma(`${ACTIVE_VECTOR_SCHEMA}.journal_mode = WAL`);\n  database.pragma(`${ACTIVE_VECTOR_SCHEMA}.cache_size = -8192`);\n  database.pragma(`${ACTIVE_VECTOR_SCHEMA}.mmap_size = 33554432`);\n  database.pragma(`${ACTIVE_VECTOR_SCHEMA}.temp_store = DEFAULT`);\n  database.pragma(`${ACTIVE_VECTOR_SCHEMA}.wal_autocheckpoint = 256`);\n\n  write_shard_metadata(database, profile);\n  ensure_embedding_cache_table(database);\n\n  const dimTableName = vector_table_name_for_profile(profile);\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)} (\n      id INTEGER PRIMARY KEY,\n      vec BLOB NOT NULL\n    )\n  `);\n\n  if (sqlite_vec_available_flag && !table_exists_in_schema(database, ACTIVE_VECTOR_SCHEMA, 'vec_memories')) {\n    database.exec(`\n      CREATE VIRTUAL TABLE ${ACTIVE_VECTOR_SCHEMA}.vec_memories USING vec0(\n        embedding FLOAT[${profile.dim}]\n      )\n    `);\n  }\n}\n\nfunction drop_canonical_vector_payload_tables(database: Database.Database): void {\n  for (const tableName of ['embedding_cache', 'vec_memories']) {\n    try {\n      database.exec(`DROP TABLE IF EXISTS main.${quote_identifier(tableName)}`);\n    } catch (_error: unknown) {\n      // Existing legacy virtual/shadow tables are migrated before this cleanup; failures are non-fatal.\n    }\n  }\n  const rows = database.prepare(`\n    SELECT name\n    FROM main.sqlite_master\n    WHERE type='table'\n      AND (name LIKE 'vec\\\\_%' ESCAPE '\\\\' OR name LIKE 'vec_memories\\\\_%' ESCAPE '\\\\')\n  `).all() as Array<{ name: string }>;\n  for (const row of rows) {\n    if (row.name === 'vec_metadata') {\n      continue;\n    }\n    try {\n      database.exec(`DROP TABLE IF EXISTS main.${quote_identifier(row.name)}`);\n    } catch (_error: unknown) {\n      // Best-effort canonical slimming. Query paths use active_vec after attach.\n    }\n  }\n}\n\nfunction create_legacy_temp_aliases(database: Database.Database, profile: EmbeddingProfile): void {\n  const dimTableName = vector_table_name_for_profile(profile);\n  try {\n    database.exec(`\n      DROP VIEW IF EXISTS temp.vec_memories;\n      DROP TRIGGER IF EXISTS temp.vec_memories_insert;\n      DROP TRIGGER IF EXISTS temp.vec_memories_delete;\n      CREATE TEMP VIEW vec_memories AS\n        SELECT rowid, embedding FROM ${ACTIVE_VECTOR_SCHEMA}.vec_memories;\n      CREATE TEMP TRIGGER vec_memories_insert\n      INSTEAD OF INSERT ON vec_memories\n      BEGIN\n        INSERT INTO ${ACTIVE_VECTOR_SCHEMA}.vec_memories(rowid, embedding)\n        VALUES (CAST(new.rowid AS INTEGER), new.embedding);\n      END;\n      CREATE TEMP TRIGGER vec_memories_delete\n      INSTEAD OF DELETE ON vec_memories\n      BEGIN\n        DELETE FROM ${ACTIVE_VECTOR_SCHEMA}.vec_memories WHERE rowid = old.rowid;\n      END;\n      DROP VIEW IF EXISTS temp.${quote_identifier(dimTableName)};\n      DROP TRIGGER IF EXISTS temp.${quote_identifier(`${dimTableName}_insert`)};\n      DROP TRIGGER IF EXISTS temp.${quote_identifier(`${dimTableName}_delete`)};\n      CREATE TEMP VIEW ${quote_identifier(dimTableName)} AS\n        SELECT id, vec FROM ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)};\n      CREATE TEMP TRIGGER ${quote_identifier(`${dimTableName}_insert`)}\n      INSTEAD OF INSERT ON ${quote_identifier(dimTableName)}\n      BEGIN\n        INSERT OR REPLACE INTO ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)}(id, vec)\n        VALUES (new.id, new.vec);\n      END;\n      CREATE TEMP TRIGGER ${quote_identifier(`${dimTableName}_delete`)}\n      INSTEAD OF DELETE ON ${quote_identifier(dimTableName)}\n      BEGIN\n        DELETE FROM ${ACTIVE_VECTOR_SCHEMA}.${quote_identifier(dimTableName)} WHERE id = old.id;\n      END;\n    `);\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Could not create legacy vector temp aliases: ${get_error_message(error)}`);\n  }\n}\n\nfunction drop_legacy_temp_aliases(database: Database.Database): void {\n  try {\n    const rows = database.prepare(`\n      SELECT type, name\n      FROM temp.sqlite_master\n      WHERE name = 'vec_memories'\n         OR name LIKE 'vec_memories\\\\_%' ESCAPE '\\\\'\n         OR name LIKE 'vec\\\\_%' ESCAPE '\\\\'\n    `).all() as Array<{ type: string; name: string }>;\n\n    for (const row of rows) {\n      if (row.type !== 'view' && row.type !== 'trigger') {\n        continue;\n      }\n      database.exec(`DROP ${row.type.toUpperCase()} IF EXISTS temp.${quote_identifier(row.name)}`);\n    }\n  } catch (_error: unknown) {\n    // Best-effort cleanup only.\n  }\n}\n\n// Unified allowed paths\nconst ALLOWED_BASE_PATHS = [\n  path.join(process.cwd(), 'specs'),\n  path.join(process.cwd(), '.opencode'),\n  path.join(os.homedir(), '.claude'),\n  process.cwd(),\n  ...(process.env.MEMORY_ALLOWED_PATHS ? process.env.MEMORY_ALLOWED_PATHS.split(path.delimiter) : [])\n].filter(Boolean).map(p => path.resolve(p));\n\n/**\n * Validates a file path against allowed local base paths.\n * @param file_path - The file path to validate.\n * @returns The validated file path, if allowed.\n */\nexport function validate_file_path_local(file_path: unknown): string | null {\n  if (typeof file_path !== 'string') {\n    return null;\n  }\n\n  return validateFilePath(file_path, ALLOWED_BASE_PATHS);\n}\n\n// HIGH-004 FIX: Async version for non-blocking concurrent file reads\n/**\n * Reads a file asynchronously after validating the path.\n * @param file_path - The file path to read.\n * @returns A promise that resolves to the file contents or an empty string.\n */\nexport async function safe_read_file_async(file_path: unknown): Promise<string> {\n  const valid_path = validate_file_path_local(file_path);\n  if (!valid_path) {\n    return '';\n  }\n\n  try {\n    return await fs.promises.readFile(valid_path, 'utf-8');\n  } catch (err: unknown) {\n    if (!(err instanceof Error && 'code' in err && get_error_code(err) === 'ENOENT')) {\n      console.warn(`[vector-index] Could not read file ${valid_path}: ${get_error_message(err)}`);\n    }\n    return '';\n  }\n}\n\n// Safely parse JSON with validation (CWE-502: Deserialization mitigation)\n/**\n * Parses JSON with prototype-pollution safeguards.\n * @param json_string - The JSON string to parse.\n * @param default_value - The fallback value to return on failure.\n * @returns The parsed JSON value or the fallback.\n */\nexport function safe_parse_json(json_string: unknown, default_value = []): unknown {\n  if (!json_string || typeof json_string !== 'string') {\n    return default_value;\n  }\n\n  try {\n    const parsed = JSON.parse(json_string);\n\n    if (Array.isArray(parsed)) {\n      return parsed.filter(item =>\n        item && typeof item === 'object' &&\n        !Array.isArray(item) &&\n        !('__proto__' in item) &&\n        !('constructor' in item) &&\n        !('prototype' in item)\n      );\n    }\n\n    if (typeof parsed === 'object' && parsed !== null) {\n      if ('__proto__' in parsed || 'constructor' in parsed || 'prototype' in parsed) {\n        console.warn('[vector-index] Blocked potential prototype pollution in JSON');\n        return default_value;\n      }\n    }\n\n    return parsed;\n  } catch (err: unknown) {\n    console.warn(`[vector-index] JSON parse error: ${get_error_message(err)}`);\n    return default_value;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. DATABASE SINGLETON\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet db_path = resolve_database_path();\nlet sqlite_vec_available_flag = true;\nlet active_vector_source: ActiveVectorSourceTelemetry | null = null;\n// C1 FIX: Key connections by resolved DB path to prevent cross-store data corruption\nconst db_connections = new Map<string, Database.Database>();\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\ntype DatabaseConnectionListener = (\n  database: Database.Database,\n  change: {\n    previousDb: Database.Database | null;\n    previousPath: string;\n    nextPath: string;\n  },\n) => boolean | void;\nconst database_connection_listeners = new Set<DatabaseConnectionListener>();\n\nfunction set_active_database_connection(\n  connection: Database.Database,\n  target_path: string,\n  vec_available: boolean,\n): void {\n  const previousDb = db;\n  const previousPath = db_path;\n  db = connection;\n  db_path = target_path;\n  sqlite_vec_available_flag = vec_available;\n\n  if (previousDb !== connection || previousPath !== target_path) {\n    clear_constitutional_cache();\n\n    const listenerErrors: string[] = [];\n    for (const listener of database_connection_listeners) {\n      try {\n        const listenerResult = listener(connection, {\n          previousDb,\n          previousPath,\n          nextPath: target_path,\n        });\n        if (listenerResult === false) {\n          listenerErrors.push('listener returned false');\n        }\n      } catch (error: unknown) {\n        const message = get_error_message(error);\n        listenerErrors.push(message);\n        console.warn(`[vector-index] Database connection listener failed: ${message}`);\n      }\n    }\n    if (listenerErrors.length > 0) {\n      throw new Error(`Database connection listener rebind failed: ${listenerErrors.join('; ')}`);\n    }\n  }\n\n  if (target_path === ':memory:') {\n    return;\n  }\n\n  try {\n    fs.chmodSync(target_path, DB_PERMISSIONS);\n  } catch (err: unknown) {\n    console.warn(`[vector-index] Could not set permissions on ${target_path}: ${get_error_message(err)}`);\n  }\n}\n\nfunction get_unclean_shutdown_marker_path(target_path: string): string | null {\n  if (target_path === ':memory:') {\n    return null;\n  }\n  return path.join(path.dirname(target_path), UNCLEAN_SHUTDOWN_MARKER);\n}\n\nfunction write_unclean_shutdown_marker(target_path: string): void {\n  const marker_path = get_unclean_shutdown_marker_path(target_path);\n  if (!marker_path) {\n    return;\n  }\n\n  try {\n    fs.writeFileSync(marker_path, `${JSON.stringify({\n      pid: process.pid,\n      databasePath: target_path,\n      startedAt: new Date().toISOString(),\n    })}\\n`, { mode: 0o600 });\n  } catch (_error: unknown) {\n    // Best-effort: marker failure must not block DB startup.\n  }\n}\n\nfunction remove_unclean_shutdown_marker(target_path: string): void {\n  const marker_path = get_unclean_shutdown_marker_path(target_path);\n  if (!marker_path) {\n    return;\n  }\n\n  try {\n    fs.rmSync(marker_path, { force: true });\n  } catch (_error: unknown) {\n    // Best-effort: marker cleanup must not block DB close.\n  }\n}\n\nfunction remove_sqlite_sidecars(database_path: string): void {\n  for (const sidecar_path of [`${database_path}-wal`, `${database_path}-shm`]) {\n    fs.rmSync(sidecar_path, { force: true });\n  }\n}\n\nfunction fsync_file_if_possible(file_path: string): void {\n  let fd: number | null = null;\n  try {\n    fd = fs.openSync(file_path, 'r');\n    fs.fsyncSync(fd);\n  } catch (_error: unknown) {\n    // Recovery remains journal-driven when the platform cannot flush explicitly.\n  } finally {\n    if (fd !== null) {\n      try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction fsync_directory_if_possible(dir_path: string): void {\n  let fd: number | null = null;\n  try {\n    fd = fs.openSync(dir_path, 'r');\n    fs.fsyncSync(fd);\n  } catch (_error: unknown) {\n    // Directory fsync is unavailable on some platforms/filesystems.\n  } finally {\n    if (fd !== null) {\n      try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction get_restore_journal_path(target_path: string): string | null {\n  if (target_path === ':memory:') {\n    return null;\n  }\n  return path.join(path.dirname(target_path), 'checkpoints', RESTORE_JOURNAL_NAME);\n}\n\nfunction get_needs_rebuild_sentinel_path(target_path: string): string | null {\n  if (target_path === ':memory:') {\n    return null;\n  }\n  return path.join(path.dirname(target_path), 'checkpoints', NEEDS_REBUILD_SENTINEL_NAME);\n}\n\nfunction write_needs_rebuild_sentinel_for_recovered_restore(target_path: string, checkpoint_name: string): void {\n  const sentinel_path = get_needs_rebuild_sentinel_path(target_path);\n  if (!sentinel_path || fs.existsSync(sentinel_path)) {\n    return;\n  }\n\n  try {\n    const sentinel_dir = path.dirname(sentinel_path);\n    const temp_sentinel_path = `${sentinel_path}.tmp`;\n    fs.mkdirSync(sentinel_dir, { recursive: true, mode: 0o700 });\n    fs.writeFileSync(temp_sentinel_path, `${JSON.stringify({\n      formatVersion: 1,\n      createdAt: new Date().toISOString(),\n      source: 'swap_done_recovery',\n      reason: 'completed restore journal recovered without derived rebuild evidence',\n      checkpointName: checkpoint_name,\n    }, null, 2)}\\n`, { mode: 0o600 });\n    fsync_file_if_possible(temp_sentinel_path);\n    fs.renameSync(temp_sentinel_path, sentinel_path);\n    fsync_directory_if_possible(sentinel_dir);\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to write checkpoint needs-rebuild sentinel during recovery: ${get_error_message(error)}`);\n  }\n}\n\nfunction write_needs_rebuild_sentinel_for_corruption(target_path: string, detail: string): void {\n  // Same atomic temp+rename discipline as the restore-recovery writer: a crash\n  // mid-write must never leave a torn sentinel that half-triggers a rebuild.\n  const sentinel_path = get_needs_rebuild_sentinel_path(target_path);\n  if (!sentinel_path) {\n    return;\n  }\n  try {\n    const sentinel_dir = path.dirname(sentinel_path);\n    fs.mkdirSync(sentinel_dir, { recursive: true });\n    const temp_sentinel_path = `${sentinel_path}.tmp.${process.pid}`;\n    fs.writeFileSync(temp_sentinel_path, `${JSON.stringify({\n      formatVersion: 1,\n      createdAt: new Date().toISOString(),\n      source: 'post_crash_integrity_probe',\n      reason: detail,\n    }, null, 2)}\\n`, { mode: 0o600 });\n    fsync_file_if_possible(temp_sentinel_path);\n    fs.renameSync(temp_sentinel_path, sentinel_path);\n    fsync_directory_if_possible(sentinel_dir);\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to write needs-rebuild sentinel after integrity probe: ${get_error_message(error)}`);\n  }\n}\n\nfunction read_restore_journal(journal_path: string): RestoreJournalFile | null {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(journal_path, 'utf-8')) as Partial<RestoreJournalFile>;\n    const phase = parsed.phase === 'swap-done' ? 'swap-done' : 'swap-pending';\n    if (\n      parsed.formatVersion !== 1\n      || typeof parsed.createdAt !== 'string'\n      || typeof parsed.checkpointName !== 'string'\n      || typeof parsed.liveMainPath !== 'string'\n      || typeof parsed.backupMainPath !== 'string'\n      || typeof parsed.snapshotMainPath !== 'string'\n      || (parsed.liveShardPath !== null && typeof parsed.liveShardPath !== 'string')\n      || (parsed.backupShardPath !== null && typeof parsed.backupShardPath !== 'string')\n      || (parsed.snapshotVecPath !== null && typeof parsed.snapshotVecPath !== 'string')\n      || typeof parsed.shouldRestoreVec !== 'boolean'\n      || (\n        parsed.liveShardPreexisted !== undefined\n        && typeof parsed.liveShardPreexisted !== 'boolean'\n      )\n    ) {\n      throw new Error('restore journal shape is invalid');\n    }\n    return {\n      ...parsed,\n      phase,\n      liveShardPreexisted: parsed.liveShardPreexisted\n        ?? (parsed.shouldRestoreVec && typeof parsed.backupShardPath === 'string' && fs.existsSync(parsed.backupShardPath)),\n    } as RestoreJournalFile;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Ignoring unreadable checkpoint restore journal: ${get_error_message(error)}`);\n    return null;\n  }\n}\n\nfunction merge_checkpoint_catalog_from_backup(live_main_path: string, backup_main_path: string): void {\n  // A swap-done crash happens after the snapshot DB is in place but before the live\n  // catalog rows (captured from the pre-swap DB) are re-merged in-process. The snapshot's\n  // checkpoints table only reflects state at snapshot time, so post-snapshot catalog rows\n  // would be lost when boot recovery deletes the .bak. Re-merge them here, reading the BLOB\n  // payloads directly from the .bak so v1 inline snapshots keep full fidelity. Best-effort:\n  // recovery must finalize even if the merge cannot run.\n  if (!fs.existsSync(backup_main_path)) {\n    return;\n  }\n  let live_db: Database.Database | null = null;\n  let backup_db: Database.Database | null = null;\n  try {\n    backup_db = new Database(backup_main_path, { readonly: true });\n    const catalog_exists = backup_db.prepare(\n      \"SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = 'checkpoints'\",\n    ).get() as { 1?: number } | undefined;\n    if (!catalog_exists) {\n      return;\n    }\n    const backup_rows = backup_db.prepare('SELECT * FROM checkpoints ORDER BY id ASC').all() as Array<Record<string, unknown>>;\n    if (backup_rows.length === 0) {\n      return;\n    }\n\n    live_db = new Database(live_main_path);\n    const live_catalog_exists = live_db.prepare(\n      \"SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = 'checkpoints'\",\n    ).get() as { 1?: number } | undefined;\n    if (!live_catalog_exists) {\n      return;\n    }\n    const target_columns = new Set(\n      (live_db.prepare('PRAGMA table_info(\"checkpoints\")').all() as Array<{ name?: unknown }>)\n        .map((column) => column.name)\n        .filter((name): name is string => typeof name === 'string' && name.length > 0),\n    );\n\n    const merge = live_db.transaction((rows: Array<Record<string, unknown>>) => {\n      for (const row of rows) {\n        const name = row.name;\n        if (typeof name !== 'string' || name.length === 0) {\n          continue;\n        }\n        const existing_by_name = (live_db as Database.Database).prepare('SELECT id FROM checkpoints WHERE name = ?').get(name) as { id?: number } | undefined;\n        if (existing_by_name?.id) {\n          continue;\n        }\n\n        let columns = Object.keys(row).filter((column) => target_columns.has(column));\n        const id = row.id;\n        if (typeof id === 'number') {\n          const existing_by_id = (live_db as Database.Database).prepare('SELECT name FROM checkpoints WHERE id = ?').get(id) as { name?: string } | undefined;\n          if (existing_by_id?.name && existing_by_id.name !== name) {\n            columns = columns.filter((column) => column !== 'id');\n          }\n        }\n        if (columns.length === 0) {\n          continue;\n        }\n\n        const placeholders = columns.map(() => '?').join(', ');\n        (live_db as Database.Database).prepare(`\n          INSERT OR IGNORE INTO checkpoints (${columns.join(', ')})\n          VALUES (${placeholders})\n        `).run(...columns.map((column) => row[column]));\n      }\n    });\n    merge(backup_rows);\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to re-merge checkpoint catalog during swap-done recovery (non-fatal): ${get_error_message(error)}`);\n  } finally {\n    if (backup_db) {\n      try { backup_db.close(); } catch (_error: unknown) { /* best-effort */ }\n    }\n    if (live_db) {\n      try { live_db.close(); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nexport function recover_interrupted_checkpoint_restore(target_path: string): boolean {\n  const journal_path = get_restore_journal_path(target_path);\n  if (!journal_path || !fs.existsSync(journal_path)) {\n    return false;\n  }\n\n  const journal = read_restore_journal(journal_path);\n  if (!journal) {\n    return false;\n  }\n\n  if (journal.phase === 'swap-done') {\n    // Re-merge any post-snapshot catalog rows from the .bak before deleting it; the\n    // crashed in-process restore would have done this merge had it not been interrupted.\n    merge_checkpoint_catalog_from_backup(journal.liveMainPath, journal.backupMainPath);\n    fs.rmSync(journal.backupMainPath, { force: true });\n    fsync_directory_if_possible(path.dirname(journal.backupMainPath));\n    if (journal.shouldRestoreVec && journal.backupShardPath) {\n      fs.rmSync(journal.backupShardPath, { force: true });\n      fsync_directory_if_possible(path.dirname(journal.backupShardPath));\n    }\n    write_needs_rebuild_sentinel_for_recovered_restore(journal.liveMainPath, journal.checkpointName);\n    fs.rmSync(journal_path, { force: true });\n    fsync_directory_if_possible(path.dirname(journal_path));\n    console.warn('[vector-index] Finalized completed checkpoint restore from rollback journal');\n    return true;\n  }\n\n  remove_sqlite_sidecars(journal.liveMainPath);\n  if (fs.existsSync(journal.backupMainPath)) {\n    fs.rmSync(journal.liveMainPath, { force: true });\n    fs.renameSync(journal.backupMainPath, journal.liveMainPath);\n    fsync_file_if_possible(journal.liveMainPath);\n    fsync_directory_if_possible(path.dirname(journal.liveMainPath));\n  }\n\n  if (journal.shouldRestoreVec && journal.liveShardPath) {\n    remove_sqlite_sidecars(journal.liveShardPath);\n    if (journal.liveShardPreexisted && journal.backupShardPath && fs.existsSync(journal.backupShardPath)) {\n      fs.rmSync(journal.liveShardPath, { force: true });\n      fs.renameSync(journal.backupShardPath, journal.liveShardPath);\n      fsync_file_if_possible(journal.liveShardPath);\n      fsync_directory_if_possible(path.dirname(journal.liveShardPath));\n    } else if (!journal.liveShardPreexisted) {\n      fs.rmSync(journal.liveShardPath, { force: true });\n      fsync_directory_if_possible(path.dirname(journal.liveShardPath));\n    }\n  }\n\n  fs.rmSync(journal_path, { force: true });\n  fsync_directory_if_possible(path.dirname(journal_path));\n  console.warn('[vector-index] Recovered interrupted checkpoint restore from rollback journal');\n  return true;\n}\n\nexport function migrate_active_legacy_profile_database(\n  canonicalPath: string,\n  profile: EmbeddingProfile,\n): void {\n  if (canonicalPath === ':memory:') {\n    return;\n  }\n\n  const baseDir = path.dirname(canonicalPath);\n  const shardPath = get_vector_shard_path(profile, baseDir);\n  const legacyPath = legacy_profile_database_path(profile, baseDir);\n  if (path.resolve(legacyPath) === path.resolve(canonicalPath)) {\n    return;\n  }\n\n  migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n}\n\nexport function attachActiveVectorShard(database: Database.Database, profile: EmbeddingProfile): void {\n  try {\n    sqliteVec.load(database);\n    sqlite_vec_available_flag = true;\n  } catch (_error: unknown) {\n    sqlite_vec_available_flag = false;\n  }\n  database.pragma('journal_mode = WAL');\n  const canonicalPath = get_database_file_path(database);\n  const baseDir = resolve_database_base_dir(database);\n  const shardPath = get_vector_shard_path(profile, baseDir);\n  const attachedPath = get_attached_vector_path(database);\n\n  if (attachedPath && attachedPath !== path.resolve(shardPath)) {\n    drop_legacy_temp_aliases(database);\n    database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n  } else if (attachedPath === path.resolve(shardPath)) {\n    const probe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n    if (!probe.ok) {\n      drop_legacy_temp_aliases(database);\n      database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n      quarantine_and_rebuild_vector_shard(database, profile, shardPath, probe.reason);\n      database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n      ensure_vector_shard_schema(database, profile);\n      drop_canonical_vector_payload_tables(database);\n      create_legacy_temp_aliases(database, profile);\n      active_vector_source = {\n        canonical_path: canonicalPath,\n        shard_path: shardPath,\n        attached: true,\n        profile: {\n          provider: profile.provider,\n          model: profile.model,\n          dim: profile.dim,\n          dtype: profile.dtype,\n        },\n      };\n      return;\n    }\n    ensure_vector_shard_schema(database, profile);\n    drop_canonical_vector_payload_tables(database);\n    create_legacy_temp_aliases(database, profile);\n    active_vector_source = {\n      canonical_path: canonicalPath,\n      shard_path: shardPath,\n      attached: true,\n      profile: {\n        provider: profile.provider,\n        model: profile.model,\n        dim: profile.dim,\n        dtype: profile.dtype,\n      },\n    };\n    return;\n  }\n\n  const shardExistedBeforeAttach = fs.existsSync(shardPath);\n  const preAttachProbe = run_vector_shard_integrity_probe_at_path(shardPath, profile, sqlite_vec_available_flag);\n  let needsPostAttachProbe = shardExistedBeforeAttach && preAttachProbe.ok;\n  if (!preAttachProbe.ok) {\n    quarantine_and_rebuild_vector_shard(database, profile, shardPath, preAttachProbe.reason);\n    needsPostAttachProbe = false;\n  }\n\n  try {\n    database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n  } catch (attachError: unknown) {\n    const reason = get_error_message(attachError);\n    if (!fs.existsSync(shardPath)) {\n      throw attachError;\n    }\n    quarantine_and_rebuild_vector_shard(database, profile, shardPath, reason);\n    needsPostAttachProbe = false;\n    database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n  }\n\n  if (needsPostAttachProbe) {\n    const attachedProbe = run_attached_vector_shard_integrity_probe(database, profile, sqlite_vec_available_flag);\n    if (!attachedProbe.ok) {\n      drop_legacy_temp_aliases(database);\n      database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n      quarantine_and_rebuild_vector_shard(database, profile, shardPath, attachedProbe.reason);\n      database.exec(`ATTACH DATABASE ${quote_sql_string(shardPath)} AS ${ACTIVE_VECTOR_SCHEMA}`);\n    }\n  }\n  ensure_vector_shard_schema(database, profile);\n  drop_canonical_vector_payload_tables(database);\n  create_legacy_temp_aliases(database, profile);\n  active_vector_source = {\n    canonical_path: canonicalPath,\n    shard_path: shardPath,\n    attached: true,\n    profile: {\n      provider: profile.provider,\n      model: profile.model,\n      dim: profile.dim,\n      dtype: profile.dtype,\n    },\n  };\n}\n\nexport function attachActiveVectorShardForActiveProfile(database: Database.Database): void {\n  attachActiveVectorShard(database, resolve_profile_for_active_embedder(database));\n}\n\nexport function detachActiveVectorShard(database: Database.Database): void {\n  drop_legacy_temp_aliases(database);\n\n  if (get_attached_vector_path(database)) {\n    database.exec(`DETACH DATABASE ${ACTIVE_VECTOR_SCHEMA}`);\n  }\n\n  if (active_vector_source) {\n    active_vector_source = { ...active_vector_source, attached: false };\n  }\n}\n\nexport function getActiveVectorSource(): ActiveVectorSourceTelemetry {\n  if (db) {\n    const profile = resolve_profile_for_active_embedder(db);\n    const canonicalPath = get_database_file_path(db);\n    const baseDir = resolve_database_base_dir(db);\n    const shardPath = get_vector_shard_path(profile, baseDir);\n    const attached = get_attached_vector_path(db) === path.resolve(shardPath);\n    active_vector_source = {\n      canonical_path: canonicalPath,\n      shard_path: shardPath,\n      attached,\n      profile: {\n        provider: profile.provider,\n        model: profile.model,\n        dim: profile.dim,\n        dtype: profile.dtype,\n      },\n    };\n  }\n\n  return active_vector_source ?? {\n    canonical_path: db_path,\n    shard_path: '',\n    attached: false,\n    profile: {\n      provider: '',\n      model: '',\n      dim: get_embedding_dim(),\n      dtype: null,\n    },\n  };\n}\n\n/** Accessor for sqlite_vec_available (used by other modules) */\nexport function sqlite_vec_available(): boolean {\n  return sqlite_vec_available_flag;\n}\n\nexport function on_database_connection_change(listener: DatabaseConnectionListener): () => void {\n  database_connection_listeners.add(listener);\n  return () => {\n    database_connection_listeners.delete(listener);\n  };\n}\n\nconst constitutional_cache = new Map<string, { data: MemoryRow[]; timestamp: number }>();\nconst CONSTITUTIONAL_CACHE_TTL = 300000;\nconst CONSTITUTIONAL_CACHE_MAX_KEYS = 50;\n\n// BUG-012 FIX: Track which cache keys are currently being loaded\nconst constitutional_cache_loading = new Map<string, boolean>();\n\nlet last_db_mod_time = 0;\nlet last_constitutional_cache_db_path: string | null = null;\n\nfunction get_constitutional_cache_db_scope(): string {\n  if (db_path === ':memory:') {\n    return db_path;\n  }\n\n  return path.resolve(db_path);\n}\n\nfunction build_constitutional_cache_key(\n  spec_folder: string | null,\n  includeArchived: boolean,\n): string {\n  const db_scope = get_constitutional_cache_db_scope();\n  return `${db_scope}::${spec_folder || 'global'}:${includeArchived ? 'arch' : 'noarch'}`;\n}\n\nfunction refresh_constitutional_cache_db_state(): void {\n  const current_db_path = get_constitutional_cache_db_scope();\n  last_constitutional_cache_db_path = current_db_path;\n\n  if (current_db_path === ':memory:' || !fs.existsSync(current_db_path)) {\n    last_db_mod_time = 0;\n    return;\n  }\n\n  last_db_mod_time = fs.statSync(current_db_path).mtimeMs;\n}\n\nfunction is_constitutional_cache_valid() {\n  if (constitutional_cache.size === 0) return false;\n\n  try {\n    const current_db_path = get_constitutional_cache_db_scope();\n    if (\n      last_constitutional_cache_db_path &&\n      last_constitutional_cache_db_path !== current_db_path\n    ) {\n      return false;\n    }\n","lineStart":1,"lineEnd":1428,"totalLines":1429,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1781151292366,"end":1781151292373}},"metadata":{"openai":{"itemId":"fc_04e44631d543a090016a2a363c50848191a9abddd38659673f"}},"id":"prt_eb4e3dbaa001Kgka42TnImiLa2","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ba82001ebIrUU1GfimBXY"}}
{"type":"tool_use","timestamp":1781151292390,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_KH8BqJtgR1Fu5QHQYzE4e6jt","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Embedder Reindex Orchestrator\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { randomUUID } from 'node:crypto';\n6: import * as fs from 'node:fs';\n7: import * as path from 'node:path';\n8: \n9: import Database from 'better-sqlite3';\n10: import * as sqliteVec from 'sqlite-vec';\n11: \n12: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n13: import { invalidateProviderSingleton } from '@spec-kit/shared/embeddings';\n14: \n15: import { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\n16: import { to_embedding_buffer } from '../search/vector-index-types.js';\n17: import {\n18:   ensureVecTableForDim,\n19:   getActiveEmbedder,\n20:   setActiveEmbedder,\n21:   vecTableNameForDim,\n22: } from './schema.js';\n23: import { getEmbedderAdapter, teardownEmbedderAfterSwap } from './execution-router.js';\n24: import { getManifest } from './registry.js';\n25: import { parseBoundedEnv } from '../util/env.js';\n26: import { createLogger } from '../utils/logger.js';\n27: import { getRestoreBarrierStatus } from '../storage/checkpoints.js';\n28: import { BetterSqliteMaintenance } from '../storage/ports/maintenance.js';\n29: import {\n30:   recordVectorShardRebuildCompleted,\n31:   recordVectorShardRebuildFailed,\n32:   recordVectorShardRebuildStarted,\n33: } from '../observability/retrieval-observability.js';\n34: \n35: // ───────────────────────────────────────────────────────────────\n36: // 1. TYPE DEFINITIONS\n37: // ───────────────────────────────────────────────────────────────\n38: \n39: export type ReindexJobStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n40: \n41: export interface ReindexJob {\n42:   readonly id: string;\n43:   readonly fromName: string;\n44:   readonly toName: string;\n45:   readonly toDim: number;\n46:   readonly total: number;\n47:   readonly processed: number;\n48:   readonly status: ReindexJobStatus;\n49:   readonly startedAt: string;\n50:   readonly updatedAt: string;\n51:   readonly error?: string;\n52: }\n53: \n54: export interface StartReindexOptions {\n55:   readonly toName: string;\n56: }\n57: \n58: export interface ReindexRuntimeOptions {\n59:   readonly db?: Database.Database;\n60: }\n61: \n62: interface ReindexInternalRuntimeOptions extends ReindexRuntimeOptions {\n63:   readonly autoStart?: boolean;\n64:   readonly vectorShardRepair?: {\n65:     readonly reason: string;\n66:     readonly shardPath: string;\n67:   };\n68: }\n69: \n70: type JobRow = Omit<ReindexJob, 'error'> & {\n71:   readonly error: string | null;\n72: };\n73: \n74: interface MemoryRow {\n75:   readonly id: number;\n76:   readonly content_text: string | null;\n77:   readonly title: string | null;\n78:   readonly file_path: string | null;\n79: }\n80: \n81: // ───────────────────────────────────────────────────────────────\n82: // 2. CONSTANTS\n83: // ───────────────────────────────────────────────────────────────\n84: \n85: const DEFAULT_BATCH_SIZE = 50;\n86: const MIN_BATCH_SIZE = 1;\n87: const MAX_BATCH_SIZE = 1_000;\n88: const RESTORE_REQUEUE_DELAY_MS = 100;\n89: const logger = createLogger('embedder-reindex');\n90: const JOB_TABLE_SQL = `\n91:   CREATE TABLE IF NOT EXISTS embedder_jobs (\n92:     id TEXT PRIMARY KEY,\n93:     from_name TEXT NOT NULL,\n94:     to_name TEXT NOT NULL,\n95:     to_dim INTEGER NOT NULL,\n96:     total INTEGER NOT NULL,\n97:     processed INTEGER NOT NULL DEFAULT 0,\n98:     status TEXT NOT NULL CHECK(status IN ('queued', 'running', 'completed', 'failed', 'cancelled')),\n99:     started_at TEXT NOT NULL,\n100:     updated_at TEXT NOT NULL,\n101:     error TEXT\n102:   )\n103: `;\n104: \n105: const JOB_SELECT_COLUMNS = `\n106:   id,\n107:   from_name AS fromName,\n108:   to_name AS toName,\n109:   to_dim AS toDim,\n110:   total,\n111:   processed,\n112:   status,\n113:   started_at AS startedAt,\n114:   updated_at AS updatedAt,\n115:   error\n116: `;\n117: \n118: const runningJobs = new Set<string>();\n119: const vectorShardRepairJobs = new Map<string, { readonly reason: string; readonly shardPath: string }>();\n120: \n121: // ───────────────────────────────────────────────────────────────\n122: // 3. HELPERS\n123: // ───────────────────────────────────────────────────────────────\n124: \n125: export class InvalidDatabaseDirError extends Error {\n126:   constructor(message: string) {\n127:     super(message);\n128:     this.name = 'InvalidDatabaseDirError';\n129:   }\n130: }\n131: \n132: function resolveDb(db?: Database.Database): Database.Database {\n133:   return db ?? initializeDb();\n134: }\n135: \n136: function nowIso(): string {\n137:   return new Date().toISOString();\n138: }\n139: \n140: function readJobStatus(db: Database.Database, jobId: string): ReindexJobStatus | null {\n141:   ensureJobTable(db);\n142:   const row = db.prepare('SELECT status FROM embedder_jobs WHERE id = ?').get(jobId) as\n143:     | { status?: ReindexJobStatus }\n144:     | undefined;\n145:   return row?.status ?? null;\n146: }\n147: \n148: function getBatchSize(): number {\n149:   return parseBoundedEnv('EMBEDDER_REINDEX_BATCH_SIZE', DEFAULT_BATCH_SIZE, MIN_BATCH_SIZE, MAX_BATCH_SIZE);\n150: }\n151: \n152: function jobFromRow(row: JobRow): ReindexJob {\n153:   const { error, ...job } = row;\n154:   return error ? { ...job, error } : job;\n155: }\n156: \n157: function ensureJobTable(db: Database.Database): void {\n158:   db.exec(JOB_TABLE_SQL);\n159: }\n160: \n161: function selectJob(db: Database.Database, jobId: string): ReindexJob | null {\n162:   ensureJobTable(db);\n163:   const row = db.prepare(`\n164:     SELECT ${JOB_SELECT_COLUMNS}\n165:     FROM embedder_jobs\n166:     WHERE id = ?\n167:   `).get(jobId) as JobRow | undefined;\n168: \n169:   return row ? jobFromRow(row) : null;\n170: }\n171: \n172: function selectActiveJob(db: Database.Database): ReindexJob | null {\n173:   ensureJobTable(db);\n174:   const row = db.prepare(`\n175:     SELECT ${JOB_SELECT_COLUMNS}\n176:     FROM embedder_jobs\n177:     WHERE status IN ('queued', 'running')\n178:     ORDER BY started_at DESC, id DESC\n179:     LIMIT 1\n180:   `).get() as JobRow | undefined;\n181: \n182:   return row ? jobFromRow(row) : null;\n183: }\n184: \n185: function setJobStatus(\n186:   db: Database.Database,\n187:   jobId: string,\n188:   status: ReindexJobStatus,\n189:   processed?: number,\n190:   error?: string,\n191: ): void {\n192:   const params = {\n193:     jobId,\n194:     status,\n195:     updatedAt: nowIso(),\n196:     processed,\n197:     error,\n198:   };\n199: \n200:   if (typeof processed === 'number' && typeof error === 'string') {\n201:     db.prepare(`\n202:       UPDATE embedder_jobs\n203:       SET status = @status,\n204:           updated_at = @updatedAt,\n205:           processed = @processed,\n206:           error = @error\n207:       WHERE id = @jobId\n208:     `).run(params);\n209:     return;\n210:   }\n211: \n212:   if (typeof processed === 'number') {\n213:     // A per-batch progress write must NOT clobber a terminal status set\n214:     // by a concurrent cancelJob(). The only caller that passes processed without an error\n215:     // is the in-loop 'running' progress update, which must only apply while the job is\n216:     // still 'running' (or being re-affirmed as 'running'); never resurrect a 'cancelled'\n217:     // (or 'completed'/'failed') row back to 'running'. Terminal transitions (completed /\n218:     // failed) always carry the other branches and stay unconditional.\n219:     if (status === 'running') {\n220:       db.prepare(`\n221:         UPDATE embedder_jobs\n222:         SET status = @status,\n223:             updated_at = @updatedAt,\n224:             processed = @processed\n225:         WHERE id = @jobId\n226:           AND status = 'running'\n227:       `).run(params);\n228:       return;\n229:     }\n230:     db.prepare(`\n231:       UPDATE embedder_jobs\n232:       SET status = @status,\n233:           updated_at = @updatedAt,\n234:           processed = @processed\n235:       WHERE id = @jobId\n236:     `).run(params);\n237:     return;\n238:   }\n239: \n240:   if (typeof error === 'string') {\n241:     db.prepare(`\n242:       UPDATE embedder_jobs\n243:       SET status = @status,\n244:           updated_at = @updatedAt,\n245:           error = @error\n246:       WHERE id = @jobId\n247:     `).run(params);\n248:     return;\n249:   }\n250: \n251:   db.prepare(`\n252:     UPDATE embedder_jobs\n253:     SET status = @status,\n254:         updated_at = @updatedAt\n255:     WHERE id = @jobId\n256:   `).run(params);\n257: }\n258: \n259: function selectMemoryBatch(db: Database.Database, offset: number, limit: number): MemoryRow[] {\n260:   return db.prepare(`\n261:     SELECT id, content_text, title, file_path\n262:     FROM memory_index\n263:     ORDER BY id ASC\n264:     LIMIT ? OFFSET ?\n265:   `).all(limit, offset) as MemoryRow[];\n266: }\n267: \n268: function memoryText(row: MemoryRow): string {\n269:   if (typeof row.content_text === 'string' && row.content_text.length > 0) {\n270:     return row.content_text;\n271:   }\n272:   if (typeof row.title === 'string' && row.title.length > 0) {\n273:     return row.title;\n274:   }\n275:   return row.file_path ?? '';\n276: }\n277: \n278: function getBatchPair(\n279:   rows: MemoryRow[],\n280:   embeddings: Float32Array[],\n281:   index: number,\n282: ): { readonly row: MemoryRow; readonly embedding: Float32Array } {\n283:   const row = rows[index];\n284:   const embedding = embeddings[index];\n285:   if (!row || !embedding) {\n286:     const missing: string[] = [];\n287:     if (!row) missing.push('row=undefined');\n288:     if (!embedding) missing.push('embedding=undefined');\n289:     throw new Error(\n290:       `Embedding batch entry missing at index ${index}: ${missing.join(', ')} ` +\n291:         `(rows.length=${rows.length}, embeddings.length=${embeddings.length})`,\n292:     );\n293:   }\n294:   return { row, embedding };\n295: }\n296: \n297: function writeVectors(\n298:   db: Database.Database,\n299:   tableName: string,\n300:   rows: MemoryRow[],\n301:   embeddings: Float32Array[],\n302: ): void {\n303:   const writeBatch = db.transaction(() => {\n304:     const stmt = db.prepare(`\n305:       INSERT OR REPLACE INTO ${tableName} (id, vec)\n306:       VALUES (?, ?)\n307:     `);\n308: \n309:     for (let i = 0; i < rows.length; i += 1) {\n310:       const { row, embedding } = getBatchPair(rows, embeddings, i);\n311:       stmt.run(row.id, to_embedding_buffer(embedding));\n312:     }\n313:   });\n314: \n315:   writeBatch();\n316: }\n317: \n318: function getDatabaseDir(db: Database.Database): string | null {\n319:   const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n320:     .find((entry) => entry.name === 'main');\n321:   if (!row?.file || row.file === ':memory:') {\n322:     return null;\n323:   }\n324:   return path.dirname(row.file);\n325: }\n326: \n327: function getDatabasePath(db: Database.Database): string | null {\n328:   try {\n329:     const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n330:       .find((entry) => entry.name === 'main');\n331:     if (!row?.file || row.file === ':memory:') {\n332:       return null;\n333:     }\n334:     return row.file;\n335:   } catch (_error: unknown) {\n336:     return null;\n337:   }\n338: }\n339: \n340: function isClosedDatabaseHandleError(error: unknown): boolean {\n341:   const message = error instanceof Error ? error.message : String(error);\n342:   return /database connection is not open|closed database|database handle is closed/i.test(message);\n343: }\n344: \n345: function scheduleJobAfterRestore(jobId: string, dbPath: string | null): void {\n346:   setTimeout(() => {\n347:     // Do not re-open the database while a checkpoint restore is still in\n348:     // progress: initialize_db runs interrupted-restore recovery, which would\n349:     // roll back the in-flight restore. Wait for the barrier to clear.\n350:     if (getRestoreBarrierStatus()) {\n351:       scheduleJobAfterRestore(jobId, dbPath);\n352:       return;\n353:     }\n354:     try {\n355:       enqueueJob(dbPath ? initializeDb(dbPath) : initializeDb(), jobId);\n356:     } catch (error: unknown) {\n357:       logger.warn('embedder reindex restore retry skipped', {\n358:         event: 'embedder_reindex_restore_retry_skipped',\n359:         jobId,\n360:         error: error instanceof Error ? error.message : String(error),\n361:       });\n362:     }\n363:   }, RESTORE_REQUEUE_DELAY_MS).unref?.();\n364: }\n365: \n366: function requireDatabaseDir(db: Database.Database, operation: string): string {\n367:   const databaseDir = getDatabaseDir(db);\n368:   if (!databaseDir) {\n369:     throw new InvalidDatabaseDirError(\n370:       `Embedder reindex ${operation} requires a file-backed database; received an in-memory or anonymous database without a database directory`,\n371:     );\n372:   }\n373:   return databaseDir;\n374: }\n375: \n376: function writeVectorsToKnn(\n377:   db: Database.Database,\n378:   rows: MemoryRow[],\n379:   embeddings: Float32Array[],\n380: ): void {\n381:   const writeBatch = db.transaction(() => {\n382:     const del = db.prepare('DELETE FROM vec_memories WHERE rowid = ?');\n383:     const ins = db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)');\n384:     for (let i = 0; i < rows.length; i += 1) {\n385:       const { row, embedding } = getBatchPair(rows, embeddings, i);\n386:       del.run(BigInt(row.id));\n387:       ins.run(BigInt(row.id), to_embedding_buffer(embedding));\n388:     }\n389:   });\n390: \n391:   writeBatch();\n392: }\n393: \n394: function ensureShardSchema(shard: Database.Database, profile: EmbeddingProfile, tableName: string): void {\n395:   shard.exec(`\n396:     CREATE TABLE IF NOT EXISTS vec_metadata (\n397:       key TEXT PRIMARY KEY,\n398:       value TEXT NOT NULL,\n399:       created_at TEXT DEFAULT (datetime('now'))\n400:     );\n401:     CREATE TABLE IF NOT EXISTS ${tableName} (\n402:       id INTEGER PRIMARY KEY,\n403:       vec BLOB NOT NULL\n404:     );\n405:   `);\n406: \n407:   const writeMetadata = shard.transaction(() => {\n408:     const stmt = shard.prepare('INSERT OR REPLACE INTO vec_metadata (key, value) VALUES (?, ?)');\n409:     stmt.run('provider', profile.provider);\n410:     stmt.run('model', profile.model);\n411:     stmt.run('dim', String(profile.dim));\n412:     stmt.run('embedding_dim', String(profile.dim));\n413:   });\n414:   writeMetadata();\n415: }\n416: \n417: function writeVectorsToShard(\n418:   db: Database.Database,\n419:   profile: EmbeddingProfile,\n420:   tableName: string,\n421:   rows: MemoryRow[],\n422:   embeddings: Float32Array[],\n423:   shardPath?: string,\n424: ): void {\n425:   const databaseDir = requireDatabaseDir(db, 'vector shard write');\n426: \n427:   // Writes target a caller-supplied STAGING shard path (default: the live\n428:   // active shard for backward compatibility). runJob writes every batch to the staging\n429:   // path and atomically renames staging -> active on success, so a mid-loop failure can\n430:   // never leave the live (active) shard half-written.\n431:   const shard = new Database(shardPath ?? profile.getVectorShardPath(databaseDir));\n432:   try {\n433:     shard.pragma('journal_mode = WAL');\n434: \n435:     // Load sqlite-vec so the runtime KNN virtual table can be created\n436:     // and populated alongside the canonical vec_<dim> blob table. When the extension\n437:     // is unavailable the runtime falls back to vec_<dim> only and search degrades to\n438:     // lexical signals; we surface that through the existing console.warn in vector-index-store.\n439:     let vecAvailable = true;\n440:     try {\n441:       sqliteVec.load(shard);\n442:     } catch (_err) {\n443:       vecAvailable = false;\n444:     }\n445: \n446:     ensureShardSchema(shard, profile, tableName);\n447: \n448:     if (vecAvailable) {\n449:       shard.exec(`\n450:         CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n451:           embedding FLOAT[${profile.dim}]\n452:         )\n453:       `);\n454:     }\n455: \n456:     writeVectors(shard, tableName, rows, embeddings);\n457:     if (vecAvailable) {\n458:       writeVectorsToKnn(shard, rows, embeddings);\n459:     }\n460:   } finally {\n461:     // WAL-durability: flush + TRUNCATE the shard WAL before close so the shard file is\n462:     // consistent at rest with an empty WAL — mirrors close_db's corruption-prevention.\n463:     // better-sqlite3 .close() only does a passive checkpoint; an abrupt later kill could otherwise\n464:     // corrupt un-checkpointed shard frames (vec0 / FTS segment writes). Best-effort; never block close.\n465:     new BetterSqliteMaintenance(shard).checkpoint({ mode: 'truncate' });\n466:     shard.close();\n467:   }\n468: }\n469: \n470: function enqueueJob(db: Database.Database, jobId: string): void {\n471:   if (runningJobs.has(jobId)) {\n472:     return;\n473:   }\n474: \n475:   runningJobs.add(jobId);\n476:   void runJob(db, jobId).finally(() => {\n477:     runningJobs.delete(jobId);\n478:   });\n479: }\n480: \n481: async function runJob(db: Database.Database, jobId: string): Promise<void> {\n482:   const dbPath = getDatabasePath(db);\n483:   let jobDb = db;\n484:   if (getRestoreBarrierStatus()) {\n485:     scheduleJobAfterRestore(jobId, dbPath);\n486:     return;\n487:   }\n488:   const resolveJobDb = (): Database.Database => {\n489:     const barrierStatus = getRestoreBarrierStatus();\n490:     if (barrierStatus) {\n491:       const error = new Error(barrierStatus.message);\n492:       error.name = barrierStatus.code;\n493:       throw error;\n494:     }\n495:     return jobDb;\n496:   };\n497:   jobDb = resolveJobDb();\n498:   const initialJob = selectJob(jobDb, jobId);\n499:   if (!initialJob || initialJob.status === 'completed' || initialJob.status === 'failed' || initialJob.status === 'cancelled') {\n500:     return;\n501:   }\n502: \n503:   const manifest = getManifest(initialJob.toName);\n504:   if (!manifest) {\n505:     setJobStatus(jobDb, jobId, 'failed', undefined, `UNKNOWN_EMBEDDER: ${initialJob.toName}`);\n506:     return;\n507:   }\n508:   const adapter = getEmbedderAdapter(manifest.backend, initialJob.toName, initialJob.toDim);\n509:   const targetProfile = new EmbeddingProfile({\n510:     provider: manifest.backend,\n511:     model: manifest.name,\n512:     dim: manifest.dim,\n513:     dtype: null,\n514:     baseUrl: null,\n515:   });\n516: \n517:   ensureVecTableForDim(jobDb, initialJob.toDim);\n518:   const tableName = vecTableNameForDim(initialJob.toDim);\n519:   const batchSize = getBatchSize();\n520:   let processed = initialJob.processed;\n521: \n522:   // Stage every shard write into a per-job staging file, then atomically\n523:   // rename it over the live active shard ONLY after the completion transaction commits.\n524:   // A mid-loop throw (or cancel) leaves the live (active) shard untouched; the partial\n525:   // staging artifact is unlinked in the catch/cancel paths. databaseDir is guaranteed\n526:   // file-backed here (startReindexInternal already called requireDatabaseDir).\n527:   const databaseDir = requireDatabaseDir(jobDb, 'reindex staging');\n528:   const activeShardPath = targetProfile.getVectorShardPath(databaseDir);\n529:   const stagingShardPath = `${activeShardPath}.reindex-${jobId}.staging`;\n530: \n531:   const cleanupStaging = (): void => {\n532:     for (const suffix of ['', '-wal', '-shm']) {\n533:       try {\n534:         fs.unlinkSync(`${stagingShardPath}${suffix}`);\n535:       } catch (_err: unknown) {\n536:         /* best-effort: staging may not exist */\n537:       }\n538:     }\n539:   };\n540: \n541:   try {\n542:     setJobStatus(jobDb, jobId, 'running');\n543:     const repairContext = vectorShardRepairJobs.get(jobId);\n544:     if (repairContext) {\n545:       recordVectorShardRebuildStarted({\n546:         jobId,\n547:         shardPath: repairContext.shardPath,\n548:         reason: repairContext.reason,\n549:       });\n550:     }\n551:     // Start each run from a clean staging slate (a prior crashed run may have left one).\n552:     cleanupStaging();\n553: \n554:     while (processed < initialJob.total) {\n555:       jobDb = resolveJobDb();\n556:       // Re-read the live cancel/status before each batch so cancelJob()\n557:       // during a run stops the worker before the next write. Abort cleanly: drop the\n558:       // staging artifact and leave the live shard + active pointer untouched.\n559:       if (readJobStatus(jobDb, jobId) === 'cancelled') {\n560:         cleanupStaging();\n561:         return;\n562:       }\n563: \n564:       const rows = selectMemoryBatch(jobDb, processed, batchSize);\n565:       if (rows.length === 0) {\n566:         break;\n567:       }\n568: \n569:       const embeddings = await adapter.embed(rows.map(memoryText));\n570:       jobDb = resolveJobDb();\n571:       if (embeddings.length !== rows.length) {\n572:         throw new Error(`Embedder returned ${embeddings.length} embeddings for ${rows.length} memories`);\n573:       }\n574: \n575:       writeVectors(jobDb, tableName, rows, embeddings);\n576:       writeVectorsToShard(jobDb, targetProfile, tableName, rows, embeddings, stagingShardPath);\n577:       processed += rows.length;\n578:       // Clobber-safe: only advances while status is still 'running' (never resurrects\n579:       // a concurrently-set 'cancelled').\n580:       setJobStatus(jobDb, jobId, 'running', processed);\n581:       await new Promise<void>((resolve) => {\n582:         setImmediate(resolve);\n583:       });\n584:     }\n585: \n586:     // Final cancel checkpoint before the irreversible swap/commit.\n587:     jobDb = resolveJobDb();\n588:     if (readJobStatus(jobDb, jobId) === 'cancelled') {\n589:       cleanupStaging();\n590:       return;\n591:     }\n592: \n593:     // Atomically swap the staged shard over the live active shard BEFORE the\n594:     // completion transaction flips the active-embedder pointer. rename(2) is atomic on\n595:     // the same filesystem; the staging file always lives beside the active shard, so the\n596:     // active shard either is the old file (failure) or the fully-staged new file (success),\n597:     // never a half-written mix. If no batch produced a staging file (e.g. zero rows), skip.\n598:     if (fs.existsSync(stagingShardPath)) {\n599:       // Drop any stale sidecars next to the active shard so the renamed WAL/SHM (already\n600:       // TRUNCATE-checkpointed at staging close) is the authoritative pair.\n601:       for (const suffix of ['-wal', '-shm']) {\n602:         try {\n603:           fs.unlinkSync(`${activeShardPath}${suffix}`);\n604:         } catch (_err: unknown) {\n605:           /* best-effort */\n606:         }\n607:       }\n608:       fs.renameSync(stagingShardPath, activeShardPath);\n609:     }\n610: \n611:     const complete = jobDb.transaction(() => {\n612:       // Persist the active-embedder provider pointer too; omitting it leaves the pointer empty,\n613:       // which readActiveEmbedderIfValid coerces to undefined and the next boot loses provider\n614:       // identity. 'api' backends are ambiguous (openai vs voyage) from the manifest alone, so\n615:       // leave the provider unset for those rather than guess.\n616:       const activeProvider = manifest.backend === 'ollama'\n617:         ? 'ollama'\n618:         : manifest.backend === 'sentence-transformers'\n619:           ? 'hf-local'\n620:           : undefined;\n621:       setActiveEmbedder(jobDb, initialJob.toName, initialJob.toDim, activeProvider);\n622:       // Commit embedding_status for rows now backed by an active-profile vector.\n623:       // A vector-only reindex previously wrote vectors but left memory_index.embedding_status\n624:       // stale, so a \"completed\" bulk re-embed never raised the success count. Reconcile the\n625:       // status for every row present in the just-written vec_<dim> table, inside the same\n626:       // atomic completion transaction so vectors and status flip together.\n627:       const completedAt = nowIso();\n628:       jobDb.prepare(`\n629:         UPDATE memory_index\n630:         SET embedding_status = 'success',\n631:             embedding_generated_at = COALESCE(embedding_generated_at, @ts),\n632:             updated_at = @ts,\n633:             failure_reason = NULL\n634:         WHERE embedding_status != 'success'\n635:           AND id IN (SELECT id FROM ${tableName})\n636:       `).run({ ts: completedAt });\n637:       setJobStatus(jobDb, jobId, 'completed', initialJob.total);\n638:     });\n639:     complete();\n640:     if (repairContext) {\n641:       recordVectorShardRebuildCompleted({ jobId, shardPath: repairContext.shardPath });\n642:       vectorShardRepairJobs.delete(jobId);\n643:     }\n644:     // The active-embedder pointer just flipped; drop the cached provider singleton so the\n645:     // next embedding re-resolves against the new pointer instead of the stale model/dim.\n646:     invalidateProviderSingleton();\n647:     void teardownEmbedderAfterSwap(manifest.backend, initialJob.toName).catch((error: unknown) => {\n648:       console.warn(`[embedder-reindex] embedder teardown after swap failed: ${error instanceof Error ? error.message : String(error)}`);\n649:     });\n650:     if (getDatabaseDir(jobDb)) {\n651:       attachActiveVectorShard(jobDb, targetProfile);\n652:     }\n653:   } catch (error: unknown) {\n654:     if (getRestoreBarrierStatus() || isClosedDatabaseHandleError(error)) {\n655:       cleanupStaging();\n656:       scheduleJobAfterRestore(jobId, dbPath);\n657:       logger.warn('embedder reindex paused for checkpoint restore', {\n658:         event: 'embedder_reindex_restore_paused',\n659:         jobId,\n660:         processed,\n661:       });\n662:       return;\n663:     }\n664:     // A failed run must not leave a half-written shard anywhere. The live active\n665:     // shard was never mutated (all writes went to staging); discard the partial staging\n666:     // artifact so the next attempt starts clean and the active shard stays the last-good one.\n667:     cleanupStaging();\n668:     const message = error instanceof Error ? error.message : String(error);\n669:     setJobStatus(jobDb, jobId, 'failed', processed, message);\n670:     const repairContext = vectorShardRepairJobs.get(jobId);\n671:     if (repairContext) {\n672:       recordVectorShardRebuildFailed({ jobId, shardPath: repairContext.shardPath, reason: message });\n673:       vectorShardRepairJobs.delete(jobId);\n674:     }\n675:     logger.error('embedder reindex job failed', {\n676:       event: 'embedder_reindex_failed',\n677:       jobId,\n678:       toName: initialJob.toName,\n679:       processed,\n680:       total: initialJob.total,\n681:       error: message,\n682:     });\n683:   }\n684: }\n685: \n686: // ───────────────────────────────────────────────────────────────\n687: // 4. CORE LOGIC\n688: // ───────────────────────────────────────────────────────────────\n689: \n690: export function startReindex(\n691:   options: StartReindexOptions,\n692:   runtimeOptions: ReindexRuntimeOptions = {},\n693: ): string {\n694:   return startReindexInternal(options, runtimeOptions);\n695: }\n696: \n697: function startReindexInternal(\n698:   options: StartReindexOptions,\n699:   runtimeOptions: ReindexInternalRuntimeOptions = {},\n700: ): string {\n701:   const db = resolveDb(runtimeOptions.db);\n702:   requireDatabaseDir(db, 'startup');\n703:   ensureJobTable(db);\n704: \n705:   const manifest = getManifest(options.toName);\n706:   if (!manifest) {\n707:     const error = new Error(`UNKNOWN_EMBEDDER: ${options.toName}`);\n708:     error.name = 'UNKNOWN_EMBEDDER';\n709:     throw error;\n710:   }\n711: \n712:   ensureVecTableForDim(db, manifest.dim);\n713:   const active = getActiveEmbedder(db);\n714:   const totalRow = db.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count?: number } | undefined;\n715:   const total = Number(totalRow?.count ?? 0);\n716:   const timestamp = nowIso();\n717:   const id = `emb-swap-${timestamp.replace(/[:.]/g, '-')}-${randomUUID().slice(0, 8)}`;\n718: \n719:   db.prepare(`\n720:     INSERT INTO embedder_jobs (\n721:       id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n722:     ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n723:   `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n724: \n725:   if (runtimeOptions.vectorShardRepair) {\n726:     vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n727:   }\n728: \n729:   if (runtimeOptions.autoStart !== false) {\n730:     enqueueJob(db, id);\n731:   }\n732: \n733:   return id;\n734: }\n735: \n736: export function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n737:   return selectJob(resolveDb(db), jobId);\n738: }\n739: \n740: export function getActiveJob(db?: Database.Database): ReindexJob | null {\n741:   return selectActiveJob(resolveDb(db));\n742: }\n743: \n744: export function cancelJob(jobId: string, db?: Database.Database): ReindexJob | null {\n745:   const resolvedDb = resolveDb(db);\n746:   ensureJobTable(resolvedDb);\n747:   const job = selectJob(resolvedDb, jobId);\n748:   if (!job) {\n749:     return null;\n750:   }\n751: \n752:   if (job.status === 'completed' || job.status === 'failed' || job.status === 'cancelled') {\n753:     return job;\n754:   }\n755: \n756:   setJobStatus(resolvedDb, jobId, 'cancelled');\n757:   return selectJob(resolvedDb, jobId);\n758: }\n759: \n760: export function resumeReindexJobs(db?: Database.Database): ReindexJob[] {\n761:   const resolvedDb = resolveDb(db);\n762:   requireDatabaseDir(resolvedDb, 'resume');\n763:   ensureJobTable(resolvedDb);\n764:   const rows = resolvedDb.prepare(`\n765:     SELECT ${JOB_SELECT_COLUMNS}\n766:     FROM embedder_jobs\n767:     WHERE status IN ('queued', 'running')\n768:     ORDER BY started_at ASC, id ASC\n769:   `).all() as JobRow[];\n770: \n771:   const jobs = rows.map(jobFromRow);\n772:   for (const job of jobs) {\n773:     enqueueJob(resolvedDb, job.id);\n774:   }\n775:   return jobs;\n776: }\n777: \n778: export function startReindexForTest(\n779:   options: StartReindexOptions,\n780:   runtimeOptions: ReindexInternalRuntimeOptions = {},\n781: ): string {\n782:   return startReindexInternal(options, runtimeOptions);\n783: }\n784: \n785: export function startVectorShardRepairReindex(\n786:   profile: EmbeddingProfile,\n787:   runtimeOptions: ReindexRuntimeOptions & { readonly reason: string; readonly shardPath: string; readonly autoStart?: boolean },\n788: ): string {\n789:   return startReindexInternal(\n790:     { toName: profile.model },\n791:     {\n792:       db: runtimeOptions.db,\n793:       autoStart: runtimeOptions.autoStart,\n794:       vectorShardRepair: {\n795:         reason: runtimeOptions.reason,\n796:         shardPath: runtimeOptions.shardPath,\n797:       },\n798:     },\n799:   );\n800: }\n801: \n802: export function estimateEta(job: ReindexJob | null): number | null {\n803:   if (!job || job.status === 'completed') {\n804:     return 0;\n805:   }\n806:   if (job.processed <= 0 || job.total <= 0) {\n807:     return null;\n808:   }\n809: \n810:   const elapsedMs = Date.now() - Date.parse(job.startedAt);\n811:   if (!Number.isFinite(elapsedMs) || elapsedMs <= 0) {\n812:     return null;\n813:   }\n814: \n815:   const ratePerMs = job.processed / elapsedMs;\n816:   if (ratePerMs <= 0) {\n817:     return null;\n818:   }\n819: \n820:   return Math.ceil((job.total - job.processed) / ratePerMs / 1000);\n821: }\n\n(End of file - total 821 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embedder Reindex Orchestrator\n// ───────────────────────────────────────────────────────────────\n\nimport { randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { invalidateProviderSingleton } from '@spec-kit/shared/embeddings';\n\nimport { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\nimport { to_embedding_buffer } from '../search/vector-index-types.js';\nimport {\n  ensureVecTableForDim,\n  getActiveEmbedder,\n  setActiveEmbedder,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embedder Reindex Orchestrator\n// ───────────────────────────────────────────────────────────────\n\nimport { randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { invalidateProviderSingleton } from '@spec-kit/shared/embeddings';\n\nimport { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\nimport { to_embedding_buffer } from '../search/vector-index-types.js';\nimport {\n  ensureVecTableForDim,\n  getActiveEmbedder,\n  setActiveEmbedder,\n  vecTableNameForDim,\n} from './schema.js';\nimport { getEmbedderAdapter, teardownEmbedderAfterSwap } from './execution-router.js';\nimport { getManifest } from './registry.js';\nimport { parseBoundedEnv } from '../util/env.js';\nimport { createLogger } from '../utils/logger.js';\nimport { getRestoreBarrierStatus } from '../storage/checkpoints.js';\nimport { BetterSqliteMaintenance } from '../storage/ports/maintenance.js';\nimport {\n  recordVectorShardRebuildCompleted,\n  recordVectorShardRebuildFailed,\n  recordVectorShardRebuildStarted,\n} from '../observability/retrieval-observability.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────\n\nexport type ReindexJobStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n\nexport interface ReindexJob {\n  readonly id: string;\n  readonly fromName: string;\n  readonly toName: string;\n  readonly toDim: number;\n  readonly total: number;\n  readonly processed: number;\n  readonly status: ReindexJobStatus;\n  readonly startedAt: string;\n  readonly updatedAt: string;\n  readonly error?: string;\n}\n\nexport interface StartReindexOptions {\n  readonly toName: string;\n}\n\nexport interface ReindexRuntimeOptions {\n  readonly db?: Database.Database;\n}\n\ninterface ReindexInternalRuntimeOptions extends ReindexRuntimeOptions {\n  readonly autoStart?: boolean;\n  readonly vectorShardRepair?: {\n    readonly reason: string;\n    readonly shardPath: string;\n  };\n}\n\ntype JobRow = Omit<ReindexJob, 'error'> & {\n  readonly error: string | null;\n};\n\ninterface MemoryRow {\n  readonly id: number;\n  readonly content_text: string | null;\n  readonly title: string | null;\n  readonly file_path: string | null;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────\n\nconst DEFAULT_BATCH_SIZE = 50;\nconst MIN_BATCH_SIZE = 1;\nconst MAX_BATCH_SIZE = 1_000;\nconst RESTORE_REQUEUE_DELAY_MS = 100;\nconst logger = createLogger('embedder-reindex');\nconst JOB_TABLE_SQL = `\n  CREATE TABLE IF NOT EXISTS embedder_jobs (\n    id TEXT PRIMARY KEY,\n    from_name TEXT NOT NULL,\n    to_name TEXT NOT NULL,\n    to_dim INTEGER NOT NULL,\n    total INTEGER NOT NULL,\n    processed INTEGER NOT NULL DEFAULT 0,\n    status TEXT NOT NULL CHECK(status IN ('queued', 'running', 'completed', 'failed', 'cancelled')),\n    started_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL,\n    error TEXT\n  )\n`;\n\nconst JOB_SELECT_COLUMNS = `\n  id,\n  from_name AS fromName,\n  to_name AS toName,\n  to_dim AS toDim,\n  total,\n  processed,\n  status,\n  started_at AS startedAt,\n  updated_at AS updatedAt,\n  error\n`;\n\nconst runningJobs = new Set<string>();\nconst vectorShardRepairJobs = new Map<string, { readonly reason: string; readonly shardPath: string }>();\n\n// ───────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ───────────────────────────────────────────────────────────────\n\nexport class InvalidDatabaseDirError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'InvalidDatabaseDirError';\n  }\n}\n\nfunction resolveDb(db?: Database.Database): Database.Database {\n  return db ?? initializeDb();\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction readJobStatus(db: Database.Database, jobId: string): ReindexJobStatus | null {\n  ensureJobTable(db);\n  const row = db.prepare('SELECT status FROM embedder_jobs WHERE id = ?').get(jobId) as\n    | { status?: ReindexJobStatus }\n    | undefined;\n  return row?.status ?? null;\n}\n\nfunction getBatchSize(): number {\n  return parseBoundedEnv('EMBEDDER_REINDEX_BATCH_SIZE', DEFAULT_BATCH_SIZE, MIN_BATCH_SIZE, MAX_BATCH_SIZE);\n}\n\nfunction jobFromRow(row: JobRow): ReindexJob {\n  const { error, ...job } = row;\n  return error ? { ...job, error } : job;\n}\n\nfunction ensureJobTable(db: Database.Database): void {\n  db.exec(JOB_TABLE_SQL);\n}\n\nfunction selectJob(db: Database.Database, jobId: string): ReindexJob | null {\n  ensureJobTable(db);\n  const row = db.prepare(`\n    SELECT ${JOB_SELECT_COLUMNS}\n    FROM embedder_jobs\n    WHERE id = ?\n  `).get(jobId) as JobRow | undefined;\n\n  return row ? jobFromRow(row) : null;\n}\n\nfunction selectActiveJob(db: Database.Database): ReindexJob | null {\n  ensureJobTable(db);\n  const row = db.prepare(`\n    SELECT ${JOB_SELECT_COLUMNS}\n    FROM embedder_jobs\n    WHERE status IN ('queued', 'running')\n    ORDER BY started_at DESC, id DESC\n    LIMIT 1\n  `).get() as JobRow | undefined;\n\n  return row ? jobFromRow(row) : null;\n}\n\nfunction setJobStatus(\n  db: Database.Database,\n  jobId: string,\n  status: ReindexJobStatus,\n  processed?: number,\n  error?: string,\n): void {\n  const params = {\n    jobId,\n    status,\n    updatedAt: nowIso(),\n    processed,\n    error,\n  };\n\n  if (typeof processed === 'number' && typeof error === 'string') {\n    db.prepare(`\n      UPDATE embedder_jobs\n      SET status = @status,\n          updated_at = @updatedAt,\n          processed = @processed,\n          error = @error\n      WHERE id = @jobId\n    `).run(params);\n    return;\n  }\n\n  if (typeof processed === 'number') {\n    // A per-batch progress write must NOT clobber a terminal status set\n    // by a concurrent cancelJob(). The only caller that passes processed without an error\n    // is the in-loop 'running' progress update, which must only apply while the job is\n    // still 'running' (or being re-affirmed as 'running'); never resurrect a 'cancelled'\n    // (or 'completed'/'failed') row back to 'running'. Terminal transitions (completed /\n    // failed) always carry the other branches and stay unconditional.\n    if (status === 'running') {\n      db.prepare(`\n        UPDATE embedder_jobs\n        SET status = @status,\n            updated_at = @updatedAt,\n            processed = @processed\n        WHERE id = @jobId\n          AND status = 'running'\n      `).run(params);\n      return;\n    }\n    db.prepare(`\n      UPDATE embedder_jobs\n      SET status = @status,\n          updated_at = @updatedAt,\n          processed = @processed\n      WHERE id = @jobId\n    `).run(params);\n    return;\n  }\n\n  if (typeof error === 'string') {\n    db.prepare(`\n      UPDATE embedder_jobs\n      SET status = @status,\n          updated_at = @updatedAt,\n          error = @error\n      WHERE id = @jobId\n    `).run(params);\n    return;\n  }\n\n  db.prepare(`\n    UPDATE embedder_jobs\n    SET status = @status,\n        updated_at = @updatedAt\n    WHERE id = @jobId\n  `).run(params);\n}\n\nfunction selectMemoryBatch(db: Database.Database, offset: number, limit: number): MemoryRow[] {\n  return db.prepare(`\n    SELECT id, content_text, title, file_path\n    FROM memory_index\n    ORDER BY id ASC\n    LIMIT ? OFFSET ?\n  `).all(limit, offset) as MemoryRow[];\n}\n\nfunction memoryText(row: MemoryRow): string {\n  if (typeof row.content_text === 'string' && row.content_text.length > 0) {\n    return row.content_text;\n  }\n  if (typeof row.title === 'string' && row.title.length > 0) {\n    return row.title;\n  }\n  return row.file_path ?? '';\n}\n\nfunction getBatchPair(\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n  index: number,\n): { readonly row: MemoryRow; readonly embedding: Float32Array } {\n  const row = rows[index];\n  const embedding = embeddings[index];\n  if (!row || !embedding) {\n    const missing: string[] = [];\n    if (!row) missing.push('row=undefined');\n    if (!embedding) missing.push('embedding=undefined');\n    throw new Error(\n      `Embedding batch entry missing at index ${index}: ${missing.join(', ')} ` +\n        `(rows.length=${rows.length}, embeddings.length=${embeddings.length})`,\n    );\n  }\n  return { row, embedding };\n}\n\nfunction writeVectors(\n  db: Database.Database,\n  tableName: string,\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n): void {\n  const writeBatch = db.transaction(() => {\n    const stmt = db.prepare(`\n      INSERT OR REPLACE INTO ${tableName} (id, vec)\n      VALUES (?, ?)\n    `);\n\n    for (let i = 0; i < rows.length; i += 1) {\n      const { row, embedding } = getBatchPair(rows, embeddings, i);\n      stmt.run(row.id, to_embedding_buffer(embedding));\n    }\n  });\n\n  writeBatch();\n}\n\nfunction getDatabaseDir(db: Database.Database): string | null {\n  const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n    .find((entry) => entry.name === 'main');\n  if (!row?.file || row.file === ':memory:') {\n    return null;\n  }\n  return path.dirname(row.file);\n}\n\nfunction getDatabasePath(db: Database.Database): string | null {\n  try {\n    const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n      .find((entry) => entry.name === 'main');\n    if (!row?.file || row.file === ':memory:') {\n      return null;\n    }\n    return row.file;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction isClosedDatabaseHandleError(error: unknown): boolean {\n  const message = error instanceof Error ? error.message : String(error);\n  return /database connection is not open|closed database|database handle is closed/i.test(message);\n}\n\nfunction scheduleJobAfterRestore(jobId: string, dbPath: string | null): void {\n  setTimeout(() => {\n    // Do not re-open the database while a checkpoint restore is still in\n    // progress: initialize_db runs interrupted-restore recovery, which would\n    // roll back the in-flight restore. Wait for the barrier to clear.\n    if (getRestoreBarrierStatus()) {\n      scheduleJobAfterRestore(jobId, dbPath);\n      return;\n    }\n    try {\n      enqueueJob(dbPath ? initializeDb(dbPath) : initializeDb(), jobId);\n    } catch (error: unknown) {\n      logger.warn('embedder reindex restore retry skipped', {\n        event: 'embedder_reindex_restore_retry_skipped',\n        jobId,\n        error: error instanceof Error ? error.message : String(error),\n      });\n    }\n  }, RESTORE_REQUEUE_DELAY_MS).unref?.();\n}\n\nfunction requireDatabaseDir(db: Database.Database, operation: string): string {\n  const databaseDir = getDatabaseDir(db);\n  if (!databaseDir) {\n    throw new InvalidDatabaseDirError(\n      `Embedder reindex ${operation} requires a file-backed database; received an in-memory or anonymous database without a database directory`,\n    );\n  }\n  return databaseDir;\n}\n\nfunction writeVectorsToKnn(\n  db: Database.Database,\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n): void {\n  const writeBatch = db.transaction(() => {\n    const del = db.prepare('DELETE FROM vec_memories WHERE rowid = ?');\n    const ins = db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)');\n    for (let i = 0; i < rows.length; i += 1) {\n      const { row, embedding } = getBatchPair(rows, embeddings, i);\n      del.run(BigInt(row.id));\n      ins.run(BigInt(row.id), to_embedding_buffer(embedding));\n    }\n  });\n\n  writeBatch();\n}\n\nfunction ensureShardSchema(shard: Database.Database, profile: EmbeddingProfile, tableName: string): void {\n  shard.exec(`\n    CREATE TABLE IF NOT EXISTS vec_metadata (\n      key TEXT PRIMARY KEY,\n      value TEXT NOT NULL,\n      created_at TEXT DEFAULT (datetime('now'))\n    );\n    CREATE TABLE IF NOT EXISTS ${tableName} (\n      id INTEGER PRIMARY KEY,\n      vec BLOB NOT NULL\n    );\n  `);\n\n  const writeMetadata = shard.transaction(() => {\n    const stmt = shard.prepare('INSERT OR REPLACE INTO vec_metadata (key, value) VALUES (?, ?)');\n    stmt.run('provider', profile.provider);\n    stmt.run('model', profile.model);\n    stmt.run('dim', String(profile.dim));\n    stmt.run('embedding_dim', String(profile.dim));\n  });\n  writeMetadata();\n}\n\nfunction writeVectorsToShard(\n  db: Database.Database,\n  profile: EmbeddingProfile,\n  tableName: string,\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n  shardPath?: string,\n): void {\n  const databaseDir = requireDatabaseDir(db, 'vector shard write');\n\n  // Writes target a caller-supplied STAGING shard path (default: the live\n  // active shard for backward compatibility). runJob writes every batch to the staging\n  // path and atomically renames staging -> active on success, so a mid-loop failure can\n  // never leave the live (active) shard half-written.\n  const shard = new Database(shardPath ?? profile.getVectorShardPath(databaseDir));\n  try {\n    shard.pragma('journal_mode = WAL');\n\n    // Load sqlite-vec so the runtime KNN virtual table can be created\n    // and populated alongside the canonical vec_<dim> blob table. When the extension\n    // is unavailable the runtime falls back to vec_<dim> only and search degrades to\n    // lexical signals; we surface that through the existing console.warn in vector-index-store.\n    let vecAvailable = true;\n    try {\n      sqliteVec.load(shard);\n    } catch (_err) {\n      vecAvailable = false;\n    }\n\n    ensureShardSchema(shard, profile, tableName);\n\n    if (vecAvailable) {\n      shard.exec(`\n        CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n          embedding FLOAT[${profile.dim}]\n        )\n      `);\n    }\n\n    writeVectors(shard, tableName, rows, embeddings);\n    if (vecAvailable) {\n      writeVectorsToKnn(shard, rows, embeddings);\n    }\n  } finally {\n    // WAL-durability: flush + TRUNCATE the shard WAL before close so the shard file is\n    // consistent at rest with an empty WAL — mirrors close_db's corruption-prevention.\n    // better-sqlite3 .close() only does a passive checkpoint; an abrupt later kill could otherwise\n    // corrupt un-checkpointed shard frames (vec0 / FTS segment writes). Best-effort; never block close.\n    new BetterSqliteMaintenance(shard).checkpoint({ mode: 'truncate' });\n    shard.close();\n  }\n}\n\nfunction enqueueJob(db: Database.Database, jobId: string): void {\n  if (runningJobs.has(jobId)) {\n    return;\n  }\n\n  runningJobs.add(jobId);\n  void runJob(db, jobId).finally(() => {\n    runningJobs.delete(jobId);\n  });\n}\n\nasync function runJob(db: Database.Database, jobId: string): Promise<void> {\n  const dbPath = getDatabasePath(db);\n  let jobDb = db;\n  if (getRestoreBarrierStatus()) {\n    scheduleJobAfterRestore(jobId, dbPath);\n    return;\n  }\n  const resolveJobDb = (): Database.Database => {\n    const barrierStatus = getRestoreBarrierStatus();\n    if (barrierStatus) {\n      const error = new Error(barrierStatus.message);\n      error.name = barrierStatus.code;\n      throw error;\n    }\n    return jobDb;\n  };\n  jobDb = resolveJobDb();\n  const initialJob = selectJob(jobDb, jobId);\n  if (!initialJob || initialJob.status === 'completed' || initialJob.status === 'failed' || initialJob.status === 'cancelled') {\n    return;\n  }\n\n  const manifest = getManifest(initialJob.toName);\n  if (!manifest) {\n    setJobStatus(jobDb, jobId, 'failed', undefined, `UNKNOWN_EMBEDDER: ${initialJob.toName}`);\n    return;\n  }\n  const adapter = getEmbedderAdapter(manifest.backend, initialJob.toName, initialJob.toDim);\n  const targetProfile = new EmbeddingProfile({\n    provider: manifest.backend,\n    model: manifest.name,\n    dim: manifest.dim,\n    dtype: null,\n    baseUrl: null,\n  });\n\n  ensureVecTableForDim(jobDb, initialJob.toDim);\n  const tableName = vecTableNameForDim(initialJob.toDim);\n  const batchSize = getBatchSize();\n  let processed = initialJob.processed;\n\n  // Stage every shard write into a per-job staging file, then atomically\n  // rename it over the live active shard ONLY after the completion transaction commits.\n  // A mid-loop throw (or cancel) leaves the live (active) shard untouched; the partial\n  // staging artifact is unlinked in the catch/cancel paths. databaseDir is guaranteed\n  // file-backed here (startReindexInternal already called requireDatabaseDir).\n  const databaseDir = requireDatabaseDir(jobDb, 'reindex staging');\n  const activeShardPath = targetProfile.getVectorShardPath(databaseDir);\n  const stagingShardPath = `${activeShardPath}.reindex-${jobId}.staging`;\n\n  const cleanupStaging = (): void => {\n    for (const suffix of ['', '-wal', '-shm']) {\n      try {\n        fs.unlinkSync(`${stagingShardPath}${suffix}`);\n      } catch (_err: unknown) {\n        /* best-effort: staging may not exist */\n      }\n    }\n  };\n\n  try {\n    setJobStatus(jobDb, jobId, 'running');\n    const repairContext = vectorShardRepairJobs.get(jobId);\n    if (repairContext) {\n      recordVectorShardRebuildStarted({\n        jobId,\n        shardPath: repairContext.shardPath,\n        reason: repairContext.reason,\n      });\n    }\n    // Start each run from a clean staging slate (a prior crashed run may have left one).\n    cleanupStaging();\n\n    while (processed < initialJob.total) {\n      jobDb = resolveJobDb();\n      // Re-read the live cancel/status before each batch so cancelJob()\n      // during a run stops the worker before the next write. Abort cleanly: drop the\n      // staging artifact and leave the live shard + active pointer untouched.\n      if (readJobStatus(jobDb, jobId) === 'cancelled') {\n        cleanupStaging();\n        return;\n      }\n\n      const rows = selectMemoryBatch(jobDb, processed, batchSize);\n      if (rows.length === 0) {\n        break;\n      }\n\n      const embeddings = await adapter.embed(rows.map(memoryText));\n      jobDb = resolveJobDb();\n      if (embeddings.length !== rows.length) {\n        throw new Error(`Embedder returned ${embeddings.length} embeddings for ${rows.length} memories`);\n      }\n\n      writeVectors(jobDb, tableName, rows, embeddings);\n      writeVectorsToShard(jobDb, targetProfile, tableName, rows, embeddings, stagingShardPath);\n      processed += rows.length;\n      // Clobber-safe: only advances while status is still 'running' (never resurrects\n      // a concurrently-set 'cancelled').\n      setJobStatus(jobDb, jobId, 'running', processed);\n      await new Promise<void>((resolve) => {\n        setImmediate(resolve);\n      });\n    }\n\n    // Final cancel checkpoint before the irreversible swap/commit.\n    jobDb = resolveJobDb();\n    if (readJobStatus(jobDb, jobId) === 'cancelled') {\n      cleanupStaging();\n      return;\n    }\n\n    // Atomically swap the staged shard over the live active shard BEFORE the\n    // completion transaction flips the active-embedder pointer. rename(2) is atomic on\n    // the same filesystem; the staging file always lives beside the active shard, so the\n    // active shard either is the old file (failure) or the fully-staged new file (success),\n    // never a half-written mix. If no batch produced a staging file (e.g. zero rows), skip.\n    if (fs.existsSync(stagingShardPath)) {\n      // Drop any stale sidecars next to the active shard so the renamed WAL/SHM (already\n      // TRUNCATE-checkpointed at staging close) is the authoritative pair.\n      for (const suffix of ['-wal', '-shm']) {\n        try {\n          fs.unlinkSync(`${activeShardPath}${suffix}`);\n        } catch (_err: unknown) {\n          /* best-effort */\n        }\n      }\n      fs.renameSync(stagingShardPath, activeShardPath);\n    }\n\n    const complete = jobDb.transaction(() => {\n      // Persist the active-embedder provider pointer too; omitting it leaves the pointer empty,\n      // which readActiveEmbedderIfValid coerces to undefined and the next boot loses provider\n      // identity. 'api' backends are ambiguous (openai vs voyage) from the manifest alone, so\n      // leave the provider unset for those rather than guess.\n      const activeProvider = manifest.backend === 'ollama'\n        ? 'ollama'\n        : manifest.backend === 'sentence-transformers'\n          ? 'hf-local'\n          : undefined;\n      setActiveEmbedder(jobDb, initialJob.toName, initialJob.toDim, activeProvider);\n      // Commit embedding_status for rows now backed by an active-profile vector.\n      // A vector-only reindex previously wrote vectors but left memory_index.embedding_status\n      // stale, so a \"completed\" bulk re-embed never raised the success count. Reconcile the\n      // status for every row present in the just-written vec_<dim> table, inside the same\n      // atomic completion transaction so vectors and status flip together.\n      const completedAt = nowIso();\n      jobDb.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'success',\n            embedding_generated_at = COALESCE(embedding_generated_at, @ts),\n            updated_at = @ts,\n            failure_reason = NULL\n        WHERE embedding_status != 'success'\n          AND id IN (SELECT id FROM ${tableName})\n      `).run({ ts: completedAt });\n      setJobStatus(jobDb, jobId, 'completed', initialJob.total);\n    });\n    complete();\n    if (repairContext) {\n      recordVectorShardRebuildCompleted({ jobId, shardPath: repairContext.shardPath });\n      vectorShardRepairJobs.delete(jobId);\n    }\n    // The active-embedder pointer just flipped; drop the cached provider singleton so the\n    // next embedding re-resolves against the new pointer instead of the stale model/dim.\n    invalidateProviderSingleton();\n    void teardownEmbedderAfterSwap(manifest.backend, initialJob.toName).catch((error: unknown) => {\n      console.warn(`[embedder-reindex] embedder teardown after swap failed: ${error instanceof Error ? error.message : String(error)}`);\n    });\n    if (getDatabaseDir(jobDb)) {\n      attachActiveVectorShard(jobDb, targetProfile);\n    }\n  } catch (error: unknown) {\n    if (getRestoreBarrierStatus() || isClosedDatabaseHandleError(error)) {\n      cleanupStaging();\n      scheduleJobAfterRestore(jobId, dbPath);\n      logger.warn('embedder reindex paused for checkpoint restore', {\n        event: 'embedder_reindex_restore_paused',\n        jobId,\n        processed,\n      });\n      return;\n    }\n    // A failed run must not leave a half-written shard anywhere. The live active\n    // shard was never mutated (all writes went to staging); discard the partial staging\n    // artifact so the next attempt starts clean and the active shard stays the last-good one.\n    cleanupStaging();\n    const message = error instanceof Error ? error.message : String(error);\n    setJobStatus(jobDb, jobId, 'failed', processed, message);\n    const repairContext = vectorShardRepairJobs.get(jobId);\n    if (repairContext) {\n      recordVectorShardRebuildFailed({ jobId, shardPath: repairContext.shardPath, reason: message });\n      vectorShardRepairJobs.delete(jobId);\n    }\n    logger.error('embedder reindex job failed', {\n      event: 'embedder_reindex_failed',\n      jobId,\n      toName: initialJob.toName,\n      processed,\n      total: initialJob.total,\n      error: message,\n    });\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ───────────────────────────────────────────────────────────────\n\nexport function startReindex(\n  options: StartReindexOptions,\n  runtimeOptions: ReindexRuntimeOptions = {},\n): string {\n  return startReindexInternal(options, runtimeOptions);\n}\n\nfunction startReindexInternal(\n  options: StartReindexOptions,\n  runtimeOptions: ReindexInternalRuntimeOptions = {},\n): string {\n  const db = resolveDb(runtimeOptions.db);\n  requireDatabaseDir(db, 'startup');\n  ensureJobTable(db);\n\n  const manifest = getManifest(options.toName);\n  if (!manifest) {\n    const error = new Error(`UNKNOWN_EMBEDDER: ${options.toName}`);\n    error.name = 'UNKNOWN_EMBEDDER';\n    throw error;\n  }\n\n  ensureVecTableForDim(db, manifest.dim);\n  const active = getActiveEmbedder(db);\n  const totalRow = db.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count?: number } | undefined;\n  const total = Number(totalRow?.count ?? 0);\n  const timestamp = nowIso();\n  const id = `emb-swap-${timestamp.replace(/[:.]/g, '-')}-${randomUUID().slice(0, 8)}`;\n\n  db.prepare(`\n    INSERT INTO embedder_jobs (\n      id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n    ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n  `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n\n  if (runtimeOptions.vectorShardRepair) {\n    vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n  }\n\n  if (runtimeOptions.autoStart !== false) {\n    enqueueJob(db, id);\n  }\n\n  return id;\n}\n\nexport function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n  return selectJob(resolveDb(db), jobId);\n}\n\nexport function getActiveJob(db?: Database.Database): ReindexJob | null {\n  return selectActiveJob(resolveDb(db));\n}\n\nexport function cancelJob(jobId: string, db?: Database.Database): ReindexJob | null {\n  const resolvedDb = resolveDb(db);\n  ensureJobTable(resolvedDb);\n  const job = selectJob(resolvedDb, jobId);\n  if (!job) {\n    return null;\n  }\n\n  if (job.status === 'completed' || job.status === 'failed' || job.status === 'cancelled') {\n    return job;\n  }\n\n  setJobStatus(resolvedDb, jobId, 'cancelled');\n  return selectJob(resolvedDb, jobId);\n}\n\nexport function resumeReindexJobs(db?: Database.Database): ReindexJob[] {\n  const resolvedDb = resolveDb(db);\n  requireDatabaseDir(resolvedDb, 'resume');\n  ensureJobTable(resolvedDb);\n  const rows = resolvedDb.prepare(`\n    SELECT ${JOB_SELECT_COLUMNS}\n    FROM embedder_jobs\n    WHERE status IN ('queued', 'running')\n    ORDER BY started_at ASC, id ASC\n  `).all() as JobRow[];\n\n  const jobs = rows.map(jobFromRow);\n  for (const job of jobs) {\n    enqueueJob(resolvedDb, job.id);\n  }\n  return jobs;\n}\n\nexport function startReindexForTest(\n  options: StartReindexOptions,\n  runtimeOptions: ReindexInternalRuntimeOptions = {},\n): string {\n  return startReindexInternal(options, runtimeOptions);\n}\n\nexport function startVectorShardRepairReindex(\n  profile: EmbeddingProfile,\n  runtimeOptions: ReindexRuntimeOptions & { readonly reason: string; readonly shardPath: string; readonly autoStart?: boolean },\n): string {\n  return startReindexInternal(\n    { toName: profile.model },\n    {\n      db: runtimeOptions.db,\n      autoStart: runtimeOptions.autoStart,\n      vectorShardRepair: {\n        reason: runtimeOptions.reason,\n        shardPath: runtimeOptions.shardPath,\n      },\n    },\n  );\n}\n\nexport function estimateEta(job: ReindexJob | null): number | null {\n  if (!job || job.status === 'completed') {\n    return 0;\n  }\n  if (job.processed <= 0 || job.total <= 0) {\n    return null;\n  }\n\n  const elapsedMs = Date.now() - Date.parse(job.startedAt);\n  if (!Number.isFinite(elapsedMs) || elapsedMs <= 0) {\n    return null;\n  }\n\n  const ratePerMs = job.processed / elapsedMs;\n  if (ratePerMs <= 0) {\n    return null;\n  }\n\n  return Math.ceil((job.total - job.processed) / ratePerMs / 1000);\n}","lineStart":1,"lineEnd":821,"totalLines":821,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","time":{"start":1781151292384,"end":1781151292389}},"metadata":{"openai":{"itemId":"fc_04e44631d543a090016a2a363c50988191babd3f3d25d2262d"}},"id":"prt_eb4e3dbd00012cDPiR5HWYg4gL","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ba82001ebIrUU1GfimBXY"}}
{"type":"tool_use","timestamp":1781151292402,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_Y8q5pnnaXufAKQsPuLkU480c","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Queries\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL query/search functions,\n6: // Content extraction, ranking, stats, cleanup, and integrity checks.\n7: \n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: import type Database from 'better-sqlite3';\n11: import { formatAgeString as format_age_string } from '../utils/format-helpers.js';\n12: import { createLogger } from '../utils/logger.js';\n13: import { recordHistory } from '../storage/history.js';\n14: import * as embeddingsProvider from '../providers/embeddings.js';\n15: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\n16: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n17: import { getEmbedderAdapter } from '../embedders/execution-router.js';\n18: import { getManifest } from '../embedders/registry.js';\n19: import {\n20:   computeContentHash,\n21:   getActiveEmbeddingProfileKey,\n22:   lookupEmbedding,\n23:   storeEmbedding,\n24: } from '../cache/embedding-cache.js';\n25: import {\n26:   get_error_message,\n27:   parse_trigger_phrases,\n28:   to_embedding_buffer,\n29:   VectorIndexError,\n30:   VectorIndexErrorCode,\n31: } from './vector-index-types.js';\n32: import {\n33:   initialize_db,\n34:   get_embedding_dim,\n35:   get_constitutional_memories,\n36:   init_prepared_statements,\n37:   validate_file_path_local,\n38:   safe_read_file_async,\n39:   safe_parse_json,\n40:   search_weights,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource as activeVectorSchema,\n43: } from './vector-index-store.js';\n44: import { delete_memory_from_database } from './vector-index-mutations.js';\n45: import type {\n46:   EmbeddingInput,\n47:   EnrichedSearchResult,\n48:   MemoryRow,\n49:   VectorSearchOptions,\n50: } from './vector-index-types.js';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: type RelatedMemoryLink = { id: number; similarity: number };\n55: type UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\n56: type CleanupOptions = {\n57:   maxAgeDays?: number;\n58:   maxAccessCount?: number;\n59:   maxConfidence?: number;\n60:   limit?: number;\n61: };\n62: type VectorSource = {\n63:   dim: number;\n64:   tableName: string;\n65:   idColumn: string;\n66:   embeddingColumn: string;\n67: };\n68: \n69: export interface KnnQueryShapeBenchmarkResult {\n70:   readonly corpusSize: number;\n71:   readonly iterations: number;\n72:   readonly scalarJoinAverageMs: number;\n73:   readonly matchAverageMs: number | null;\n74:   readonly matchSupported: boolean;\n75:   readonly matchImprovementPct: number | null;\n76:   readonly decision: 'adopt_match' | 'keep_scalar_join';\n77:   readonly reason: string;\n78: }\n79: \n80: const KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n81: \n82: function appendSpecFolderScope(\n83:   clauses: string[],\n84:   params: unknown[],\n85:   specFolder: string | null | undefined,\n86:   column = 'm.spec_folder',\n87: ): void {\n88:   if (!specFolder) return;\n89:   clauses.push(`(${column} = ? OR ${column} LIKE ?)`);\n90:   params.push(specFolder, `${specFolder}/%`);\n91: }\n92: \n93: function tableExists(database: Database.Database, tableName: string): boolean {\n94:   const row = database.prepare(`\n95:     SELECT 1 AS found\n96:     FROM active_vec.sqlite_master\n97:     WHERE type = 'table' AND name = ?\n98:     LIMIT 1\n99:   `).get(tableName) as { found?: number } | undefined;\n100:   return row?.found === 1;\n101: }\n102: \n103: function getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n104:   const active = getActiveEmbedder(database);\n105:   const dimTableName = `vec_${active.dim}`;\n106:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n107:     return {\n108:       dim: active.dim,\n109:       tableName: activeVectorSchema(dimTableName),\n110:       idColumn: 'id',\n111:       embeddingColumn: 'vec',\n112:     };\n113:   }\n114: \n115:   return {\n116:     dim: get_embedding_dim(),\n117:     tableName: activeVectorSchema('vec_memories'),\n118:     idColumn: 'rowid',\n119:     embeddingColumn: 'embedding',\n120:   };\n121: }\n122: \n123: function elapsedMs(start: bigint): number {\n124:   return Number(process.hrtime.bigint() - start) / 1_000_000;\n125: }\n126: \n127: function average(values: number[]): number {\n128:   if (values.length === 0) return 0;\n129:   return values.reduce((sum, value) => sum + value, 0) / values.length;\n130: }\n131: \n132: export function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n133:   return result.matchSupported === true\n134:     && typeof result.matchImprovementPct === 'number'\n135:     && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n136: }\n137: \n138: export function benchmarkKnnQueryShapes(\n139:   query_embedding: EmbeddingInput,\n140:   options: { iterations?: number; limit?: number } = {},\n141:   database: Database.Database = initialize_db(),\n142: ): KnnQueryShapeBenchmarkResult {\n143:   const vectorSource = getActiveVectorSourceForQuery(database);\n144:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n145:     throw new VectorIndexError(\n146:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n147:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n148:     );\n149:   }\n150: \n151:   const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n152:   const limit = Math.max(1, Math.floor(options.limit ?? 20));\n153:   const queryBuffer = to_embedding_buffer(query_embedding);\n154:   const corpusSize = (database.prepare(`\n155:     SELECT COUNT(*) AS count\n156:     FROM memory_index m\n157:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n158:     WHERE m.embedding_status = 'success'\n159:   `).get() as { count: number }).count;\n160: \n161:   const scalarSql = `\n162:     SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n163:     FROM memory_index m\n164:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n165:     JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n166:     WHERE m.embedding_status = 'success'\n167:     ORDER BY distance ASC\n168:     LIMIT ?\n169:   `;\n170:   const scalarStmt = database.prepare(scalarSql);\n171:   scalarStmt.all(queryBuffer, limit);\n172:   const scalarRuns: number[] = [];\n173:   for (let i = 0; i < iterations; i += 1) {\n174:     const start = process.hrtime.bigint();\n175:     scalarStmt.all(queryBuffer, limit);\n176:     scalarRuns.push(elapsedMs(start));\n177:   }\n178: \n179:   const matchTable = activeVectorSchema('vec_memories');\n180:   const matchAvailable = tableExists(database, 'vec_memories');\n181:   let matchAverageMs: number | null = null;\n182:   let matchError: string | null = null;\n183: \n184:   if (matchAvailable) {\n185:     try {\n186:       const matchSql = `\n187:         WITH knn AS (\n188:           SELECT rowid, distance\n189:           FROM ${matchTable}\n190:           WHERE embedding MATCH ? AND k = ?\n191:         )\n192:         SELECT m.id, knn.distance\n193:         FROM knn\n194:         JOIN memory_index m ON m.id = knn.rowid\n195:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n196:         WHERE m.embedding_status = 'success'\n197:         ORDER BY knn.distance ASC\n198:         LIMIT ?\n199:       `;\n200:       const matchStmt = database.prepare(matchSql);\n201:       matchStmt.all(queryBuffer, limit, limit);\n202:       const matchRuns: number[] = [];\n203:       for (let i = 0; i < iterations; i += 1) {\n204:         const start = process.hrtime.bigint();\n205:         matchStmt.all(queryBuffer, limit, limit);\n206:         matchRuns.push(elapsedMs(start));\n207:       }\n208:       matchAverageMs = average(matchRuns);\n209:     } catch (error: unknown) {\n210:       matchError = get_error_message(error);\n211:     }\n212:   }\n213: \n214:   const scalarJoinAverageMs = average(scalarRuns);\n215:   const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n216:     ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n217:     : null;\n218:   const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n219:     matchSupported: matchAverageMs !== null,\n220:     matchImprovementPct,\n221:   };\n222:   const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n223: \n224:   return {\n225:     corpusSize,\n226:     iterations,\n227:     scalarJoinAverageMs,\n228:     matchAverageMs,\n229:     matchSupported: matchAverageMs !== null,\n230:     matchImprovementPct,\n231:     decision,\n232:     reason: decision === 'adopt_match'\n233:       ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n234:       : matchError\n235:         ? `MATCH unavailable: ${matchError}`\n236:         : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n237:   };\n238: }\n239: \n240: /* ───────────────────────────────────────────────────────────────\n241:    SIMPLE QUERIES\n242: ----------------------------------------------------------------*/\n243: \n244: /**\n245:  * Gets one indexed memory by identifier.\n246:  * @param id - The memory identifier.\n247:  * @returns The matching memory row, if found.\n248:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n249:  * @example\n250:  * ```ts\n251:  * const memory = get_memory(42);\n252:  * ```\n253:  */\n254: export function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n255:   const stmts = init_prepared_statements(database);\n256:   const row = stmts.get_by_id.get(id);\n257: \n258:   if (row) {\n259:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n260:     row.isConstitutional = row.importance_tier === 'constitutional';\n261:   }\n262: \n263:   return row || null;\n264: }\n265: \n266: /**\n267:  * Gets indexed memories for a spec folder.\n268:  * @param spec_folder - The spec folder to query.\n269:  * @returns The memory rows for the folder.\n270:  */\n271: export function get_memories_by_folder(\n272:   spec_folder: string,\n273:   database: Database.Database = initialize_db(),\n274: ): MemoryRow[] {\n275:   const rows = database.prepare(`\n276:     SELECT m.*\n277:     FROM memory_index m\n278:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n279:     WHERE (m.spec_folder = ? OR m.spec_folder LIKE ?)\n280:     ORDER BY m.created_at DESC\n281:   `).all(spec_folder, `${spec_folder}/%`) as MemoryRow[];\n282: \n283:   return rows.map((row: MemoryRow) => {\n284:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n285:     row.isConstitutional = row.importance_tier === 'constitutional';\n286:     return row;\n287:   });\n288: }\n289: \n290: /**\n291:  * Gets the total number of indexed memories.\n292:  * @returns The total memory count.\n293:  */\n294: export function get_memory_count(database: Database.Database = initialize_db()): number {\n295:   const stmts = init_prepared_statements(database);\n296:   const result = stmts.count_all.get();\n297:   return result?.count ?? 0;\n298: }\n299: \n300: /**\n301:  * Gets memory counts grouped by embedding status.\n302:  * @returns The counts for each embedding status.\n303:  */\n304: export function get_status_counts(\n305:   database: Database.Database = initialize_db(),\n306: ): { pending: number; success: number; failed: number; retry: number; partial: number } {\n307:   const rows = database.prepare(`\n308:     SELECT m.embedding_status, COUNT(*) as count\n309:     FROM memory_index m\n310:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n311:     GROUP BY m.embedding_status\n312:   `).all();\n313: \n314:   // Include 'partial' status in counts.\n315:   const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n316:   for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n317:     if (row.embedding_status in counts) {\n318:       counts[row.embedding_status] = row.count;\n319:     }\n320:   }\n321: \n322:   return counts;\n323: }\n324: \n325: /**\n326:  * Gets summary counts for indexed memories.\n327:  * @returns The aggregate memory statistics.\n328:  */\n329: export function get_stats(\n330:   database: Database.Database = initialize_db(),\n331: ): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n332:   const counts = get_status_counts(database);\n333:   const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n334: \n335:   return {\n336:     total,\n337:     ...counts\n338:   };\n339: }\n340: \n341: /* ───────────────────────────────────────────────────────────────\n342:    VECTOR SEARCH\n343: ----------------------------------------------------------------*/\n344: \n345: /**\n346:  * Searches indexed memories by vector similarity.\n347:  * @param query_embedding - The query embedding to search with.\n348:  * @param options - Search options.\n349:  * @returns The matching memory rows.\n350:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n351:  * @example\n352:  * ```ts\n353:  * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n354:  * ```\n355:  */\n356: export function vector_search(\n357:   query_embedding: EmbeddingInput,\n358:   options: VectorSearchOptions = {},\n359:   database: Database.Database = initialize_db(),\n360: ): MemoryRow[] {\n361:   const sqlite_vec = get_sqlite_vec_available();\n362:   if (!sqlite_vec) {\n363:     console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n364:     return [];\n365:   }\n366: \n367:   const {\n368:     limit = 10,\n369:     specFolder = null,\n370:     minSimilarity = 0,\n371:     useDecay = true,\n372:     tier = null,\n373:     contextType = null,\n374:     includeConstitutional = true,\n375:     includeArchived = false\n376:   } = options;\n377: \n378:   const vectorSource = getActiveVectorSourceForQuery(database);\n379:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n380:     throw new VectorIndexError(\n381:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n382:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n383:     );\n384:   }\n385: \n386:   const query_buffer = to_embedding_buffer(query_embedding);\n387:   const max_distance = 2 * (1 - minSimilarity / 100);\n388: \n389:   // FSRS-preferred decay with half-life fallback\n390:   const decay_expr = useDecay\n391:     ? `CASE\n392:          WHEN m.is_pinned = 1 THEN m.importance_weight\n393:          WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n394:            m.importance_weight * POWER(\n395:              1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n396:              -0.5\n397:            )\n398:          ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n399:        END`\n400:     : 'm.importance_weight';\n401: \n402:   let constitutional_results: MemoryRow[] = [];\n403: \n404:   if (includeConstitutional && tier !== 'constitutional') {\n405:     constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n406:   }\n407: \n408:   const where_clauses = ['m.embedding_status = \\'success\\''];\n409:   const params: unknown[] = [query_buffer];\n410: \n411:   where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n412: \n413:   if (tier === 'deprecated') {\n414:     where_clauses.push('m.importance_tier = ?');\n415:     params.push('deprecated');\n416:   } else if (tier === 'constitutional') {\n417:     where_clauses.push('m.importance_tier = ?');\n418:     params.push('constitutional');\n419:   } else if (tier) {\n420:     where_clauses.push('m.importance_tier = ?');\n421:     params.push(tier);\n422:   } else {\n423:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n424:   }\n425: \n426:   appendSpecFolderScope(where_clauses, params, specFolder);\n427: \n428:   if (contextType) {\n429:     where_clauses.push('m.context_type = ?');\n430:     params.push(contextType);\n431:   }\n432: \n433:   // If constitutional results already satisfy limit, return them directly.\n434:   if (constitutional_results.length >= limit) {\n435:     return constitutional_results.slice(0, limit);\n436:   }\n437:   const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n438:   params.push(max_distance, adjusted_limit);\n439: \n440:   const sql = `\n441:     SELECT sub.*,\n442:            ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n443:     FROM (\n444:       SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n445:              ${decay_expr} as effective_importance\n446:       FROM memory_index m\n447:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n448:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n449:       WHERE ${where_clauses.join(' AND ')}\n450:     ) sub\n451:     WHERE sub.distance <= ?\n452:     ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n453:     LIMIT ?\n454:   `;\n455: \n456:   const rows = database.prepare(sql).all(...params);\n457: \n458:   const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n459:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n460:     row.isConstitutional = row.importance_tier === 'constitutional';\n461:     return row;\n462:   });\n463: \n464:   return [...constitutional_results, ...regular_results];\n465: }\n466: \n467: /**\n468:  * Gets constitutional memories for prompt assembly.\n469:  * @param options - Retrieval options.\n470:  * @returns The constitutional memory rows.\n471:  */\n472: export function get_constitutional_memories_public(\n473:   options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n474:   database: Database.Database = initialize_db(),\n475: ): MemoryRow[] {\n476:   const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n477: \n478:   let results = get_constitutional_memories(database, specFolder, includeArchived);\n479: \n480:   const TOKENS_PER_MEMORY = 100;\n481:   const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n482:   if (results.length > max_count) {\n483:     results = results.slice(0, max_count);\n484:   }\n485: \n486:   return results;\n487: }\n488: \n489: /**\n490:  * Searches indexed memories with multiple concept embeddings.\n491:  * @param concept_embeddings - The concept embeddings to search with.\n492:  * @param options - Search options.\n493:  * @returns The matching memory rows.\n494:  * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n495:  * @example\n496:  * ```ts\n497:  * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n498:  * ```\n499:  */\n500: export function multi_concept_search(\n501:   concept_embeddings: EmbeddingInput[],\n502:   options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n503: ): MemoryRow[] {\n504:   const sqlite_vec = get_sqlite_vec_available();\n505:   if (!sqlite_vec) {\n506:     console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n507:     return [];\n508:   }\n509: \n510:   const database = initialize_db();\n511: \n512:   const concepts = concept_embeddings;\n513:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n514:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n515:   }\n516: \n517:   const vectorSource = getActiveVectorSourceForQuery(database);\n518:   for (const emb of concepts) {\n519:     if (!emb || emb.length !== vectorSource.dim) {\n520:       throw new VectorIndexError(\n521:         `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n522:         VectorIndexErrorCode.QUERY_FAILED,\n523:       );\n524:     }\n525:   }\n526: \n527:   const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n528: \n529:   const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n530:   const max_distance = 2 * (1 - minSimilarity / 100);\n531: \n532:   const distance_expressions = concept_buffers.map((_, i) =>\n533:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n534:   ).join(', ');\n535: \n536:   const distance_filters = concept_buffers.map((_, _i) =>\n537:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n538:   ).join(' AND ');\n539: \n540:   const folder_filter = specFolder ? 'AND (m.spec_folder = ? OR m.spec_folder LIKE ?)' : '';\n541:   const similarity_select = concept_buffers.map((_, i) =>\n542:     `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n543:   ).join(', ');\n544: \n545:   const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n546: \n547:   const sql = `\n548:     SELECT\n549:       sub.*,\n550:       ${similarity_select},\n551:       (${avg_distance_expr}) / ${concepts.length} as avg_distance\n552:     FROM (\n553:       SELECT\n554:         m.*,\n555:         ${distance_expressions}\n556:       FROM memory_index m\n557:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n558:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n559:       WHERE m.embedding_status = 'success'\n560:         AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n561:         ${folder_filter}\n562:         AND ${distance_filters}\n563:     ) sub\n564:     ORDER BY avg_distance ASC\n565:     LIMIT ?\n566:   `;\n567: \n568:   const params = [\n569:     ...concept_buffers,\n570:     ...(specFolder ? [specFolder, `${specFolder}/%`] : []),\n571:     ...concept_buffers.flatMap(b => [b, max_distance]),\n572:     limit\n573:   ];\n574: \n575:   const rows = database.prepare(sql).all(...params);\n576: \n577:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n578:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n579:     row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n580:     row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n581:     row.isConstitutional = row.importance_tier === 'constitutional';\n582:     return row;\n583:   });\n584: }\n585: \n586: /* ───────────────────────────────────────────────────────────────\n587:    CONTENT EXTRACTION HELPERS\n588: ----------------------------------------------------------------*/\n589: \n590: /**\n591:  * Extracts a display title from indexed content.\n592:  * @param content - The content to inspect.\n593:  * @param filename - The optional source filename.\n594:  * @returns The extracted title.\n595:  */\n596: export function extract_title(content: unknown, filename?: string): string {\n597:   if (!content || typeof content !== 'string') {\n598:     return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n599:   }\n600: \n601:   const h1_match = content.match(/^#\\s+(.+)$/m);\n602:   if (h1_match && h1_match[1]) {\n603:     return h1_match[1].trim();\n604:   }\n605: \n606:   const h2_match = content.match(/^##\\s+(.+)$/m);\n607:   if (h2_match && h2_match[1]) {\n608:     return h2_match[1].trim();\n609:   }\n610: \n611:   const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n612:   if (yaml_match && yaml_match[1]) {\n613:     return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n614:   }\n615: \n616:   const lines = content.split('\\n').filter(l => l.trim().length > 0);\n617:   if (lines.length > 0) {\n618:     const first_line = lines[0].trim();\n619:     return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n620:   }\n621: \n622:   return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n623: }\n624: \n625: /**\n626:  * Extracts a preview snippet from indexed content.\n627:  * @param content - The content to inspect.\n628:  * @param max_length - The maximum snippet length.\n629:  * @returns The extracted snippet.\n630:  */\n631: export function extract_snippet(content: unknown, max_length = 200): string {\n632:   if (!content || typeof content !== 'string') {\n633:     return '';\n634:   }\n635: \n636:   const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n637:   const lines = text.split('\\n');\n638:   const snippet_lines: string[] = [];\n639: \n640:   for (const line of lines) {\n641:     const trimmed = line.trim();\n642: \n643:     if (!trimmed || /^#+\\s/.test(trimmed)) {\n644:       if (snippet_lines.length > 0) {\n645:         break;\n646:       }\n647:       continue;\n648:     }\n649: \n650:     if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n651:       continue;\n652:     }\n653: \n654:     snippet_lines.push(trimmed);\n655: \n656:     const current_length = snippet_lines.join(' ').length;\n657:     if (current_length >= max_length) {\n658:       break;\n659:     }\n660:   }\n661: \n662:   let snippet = snippet_lines.join(' ');\n663: \n664:   if (snippet.length > max_length) {\n665:     snippet = snippet.substring(0, max_length);\n666:     const last_space = snippet.lastIndexOf(' ');\n667:     if (last_space > max_length * 0.7) {\n668:       snippet = snippet.substring(0, last_space);\n669:     }\n670:     snippet += '...';\n671:   }\n672: \n673:   return snippet;\n674: }\n675: \n676: /**\n677:  * Extracts tags from indexed content.\n678:  * @param content - The content to inspect.\n679:  * @returns The extracted tags.\n680:  */\n681: export function extract_tags(content: unknown): string[] {\n682:   if (!content || typeof content !== 'string') {\n683:     console.warn('[vector-index] extract_tags: invalid content type, expected string');\n684:     return [];\n685:   }\n686: \n687:   const tags = new Set<string>();\n688: \n689:   const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n690:   if (yaml_tags_match && yaml_tags_match[1]) {\n691:     yaml_tags_match[1].split(',').forEach(tag => {\n692:       const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n693:       if (cleaned) tags.add(cleaned.toLowerCase());\n694:     });\n695:   }\n696: \n697:   const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n698:   if (yaml_list_match && yaml_list_match[1]) {\n699:     yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n700:       const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n701:       if (tag) tags.add(tag.toLowerCase());\n702:     });\n703:   }\n704: \n705:   const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n706:   if (hashtag_matches) {\n707:     hashtag_matches.forEach(match => {\n708:       const tag = match.trim().replace(/^#/, '');\n709:       if (tag && !tag.match(/^[0-9]+$/)) {\n710:         tags.add(tag.toLowerCase());\n711:       }\n712:     });\n713:   }\n714: \n715:   return Array.from(tags);\n716: }\n717: \n718: /**\n719:  * Extracts a relevant date from indexed content or path.\n720:  * @param content - The content to inspect.\n721:  * @param file_path - The optional source file path.\n722:  * @returns The extracted date, if available.\n723:  */\n724: export function extract_date(content: unknown, file_path?: string): string | null {\n725:   if (content && typeof content === 'string') {\n726:     const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n727:     if (date_match && date_match[1]) {\n728:       const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n729:       try {\n730:         const parsed = new Date(date_str);\n731:         if (!isNaN(parsed.getTime())) {\n732:           return parsed.toISOString().split('T')[0];\n733:         }\n734:       } catch (_e: unknown) {\n735:         console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n736:       }\n737:     }\n738:   }\n739: \n740:   if (file_path) {\n741:     const filename = path.basename(file_path);\n742: \n743:     const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n744:     if (iso_match) {\n745:       return iso_match[1];\n746:     }\n747: \n748:     const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n749:     if (ddmmyy_match) {\n750:       const [, day, month, year] = ddmmyy_match;\n751:       const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n752:       return `${full_year}-${month}-${day}`;\n753:     }\n754:   }\n755: \n756:   return null;\n757: }\n758: \n759: /* ───────────────────────────────────────────────────────────────\n760:    EMBEDDING GENERATION WRAPPER\n761: ----------------------------------------------------------------*/\n762: \n763: /**\n764:  * Generates an embedding for a search query.\n765:  * @param query - The search query.\n766:  * @returns A promise that resolves to the embedding, if generated.\n767:  */\n768: export async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n769:   if (!query || typeof query !== 'string' || query.trim().length === 0) {\n770:     console.warn('[vector-index] Empty query provided for embedding');\n771:     return null;\n772:   }\n773: \n774:   try {\n775:     const database = initialize_db();\n776:     const active = getActiveEmbedder(database);\n777:     const trimmedQuery = query.trim();\n778:     const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n779:       ? active.name\n780:       : embeddingsProvider.getModelName();\n781:     const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n782:       ? active.dim\n783:       : embeddingsProvider.getEmbeddingDimension();\n784:     const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n785:     const contentHash = computeContentHash(trimmedQuery);\n786:     const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n787:       profileKey,\n788:       inputKind: 'query',\n789:     });\n790:     if (cached) {\n791:       return new Float32Array(\n792:         cached.buffer,\n793:         cached.byteOffset,\n794:         Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n795:       );\n796:     }\n797: \n798:     const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n799:       ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n800:       : getStartupEmbeddingProfile().provider;\n801:     const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n802:     const activeAdapter = adapter as typeof adapter & {\n803:       embed: (\n804:         texts: ReadonlyArray<string>,\n805:         options?: { inputType?: 'query' | 'document' },\n806:       ) => Promise<Float32Array[]>;\n807:     };\n808:     const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n809:     const embedding: Float32Array | null = activeEmbedding ?? null;\n810: \n811:     if (embedding) {\n812:       storeEmbedding(\n813:         database,\n814:         contentHash,\n815:         modelId,\n816:         Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n817:         embedding.length,\n818:         { profileKey, inputKind: 'query' },\n819:       );\n820:     }\n821: \n822:     return embedding;\n823:   } catch (error: unknown) {\n824:     console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n825:     return null;\n826:   }\n827: }\n828: \n829: /* ───────────────────────────────────────────────────────────────\n830:    KEYWORD SEARCH FALLBACK\n831: ----------------------------------------------------------------*/\n832: \n833: /**\n834:  * Searches indexed memories using keyword matching.\n835:  * @param query - The search query.\n836:  * @param options - Search options.\n837:  * @returns The matching memory rows.\n838:  */\n839: export function keyword_search(\n840:   query: string,\n841:   options: { limit?: number; specFolder?: string | null } = {},\n842:   database: Database.Database = initialize_db(),\n843: ): MemoryRow[] {\n844:   const { limit = 20, specFolder = null } = options;\n845: \n846:   if (!query || typeof query !== 'string') {\n847:     console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n848:     return [];\n849:   }\n850: \n851:   const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n852:   if (search_terms.length === 0) {\n853:     console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n854:     return [];\n855:   }\n856: \n857:   let where_clause = '1=1';\n858:   const params: unknown[] = [];\n859: \n860:   if (specFolder) {\n861:     where_clause += ' AND (spec_folder = ? OR spec_folder LIKE ?)';\n862:     params.push(specFolder, `${specFolder}/%`);\n863:   }\n864: \n865:   const sql = `\n866:     SELECT m.* FROM memory_index m\n867:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n868:     WHERE ${where_clause}\n869:     ORDER BY m.importance_weight DESC, m.created_at DESC\n870:   `;\n871: \n872:   const rows = database.prepare(sql).all(...params);\n873: \n874:   const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n875:     let score = 0;\n876:     const searchable_text = [\n877:       row.title || '',\n878:       parse_trigger_phrases(row.trigger_phrases).join(' '),\n879:       row.spec_folder || '',\n880:       row.file_path || ''\n881:     ].join(' ').toLowerCase();\n882: \n883:     for (const term of search_terms) {\n884:       if (searchable_text.includes(term)) {\n885:         score += 1;\n886:         if ((row.title || '').toLowerCase().includes(term)) {\n887:           score += 2;\n888:         }\n889:         if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n890:           score += 1.5;\n891:         }\n892:       }\n893:     }\n894: \n895:     score *= (0.5 + (row.importance_weight ?? 0));\n896:     return { ...row, keyword_score: score };\n897:   });\n898: \n899:   const filtered = scored\n900:     .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n901:     .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n902:     .slice(0, limit);\n903: \n904:   return filtered.map((row: MemoryRow) => {\n905:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n906:     row.isConstitutional = row.importance_tier === 'constitutional';\n907:     return row;\n908:   });\n909: }\n910: \n911: /* ───────────────────────────────────────────────────────────────\n912:    ENRICHED VECTOR SEARCH\n913: ----------------------------------------------------------------*/\n914: \n915: /**\n916:  * Runs enriched vector search for a text query.\n917:  * @param query - The search query.\n918:  * @param limit - The maximum number of results to return.\n919:  * @param options - Search options.\n920:  * @returns A promise that resolves to enriched search results.\n921:  * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n922:  * @example\n923:  * ```ts\n924:  * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n925:  * ```\n926:  */\n927: export async function vector_search_enriched(\n928:   query: string,\n929:   limit = 20,\n930:   options: { specFolder?: string | null; minSimilarity?: number } = {},\n931:   database: Database.Database = initialize_db(),\n932: ): Promise<EnrichedSearchResult[]> {\n933:   const start_time = Date.now();\n934:   const { specFolder = null, minSimilarity = 30 } = options;\n935: \n936:   const query_embedding = await generate_query_embedding(query);\n937: \n938:   let raw_results;\n939:   let search_method = 'vector';\n940: \n941:   const sqlite_vec = get_sqlite_vec_available();\n942:   if (query_embedding && sqlite_vec) {\n943:     raw_results = vector_search(query_embedding, {\n944:       limit,\n945:       specFolder,\n946:       minSimilarity\n947:     }, database);\n948:   } else {\n949:     console.warn('[vector-index] Falling back to keyword search');\n950:     search_method = 'keyword';\n951:     raw_results = keyword_search(query, { limit, specFolder }, database);\n952:   }\n953: \n954:   // HIGH-004 FIX: Read all files concurrently\n955:   const file_contents = await Promise.all(\n956:     raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n957:   );\n958: \n959:   const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n960:     const content = file_contents[i];\n961:     const title = row.title || extract_title(content, row.file_path);\n962:     const snippet = extract_snippet(content);\n963:     const tags = extract_tags(content);\n964:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n965: \n966:     const similarity = search_method === 'vector'\n967:       ? (row.similarity || 0)\n968:       : Math.min(100, (row.keyword_score || 0) * 20);\n969: \n970:     return {\n971:       rank: i + 1,\n972:       similarity: Math.round(similarity * 100) / 100,\n973:       title,\n974:       specFolder: row.spec_folder,\n975:       filePath: row.file_path,\n976:       date,\n977:       tags,\n978:       snippet,\n979:       id: row.id,\n980:       importanceWeight: row.importance_weight ?? 0.5,\n981:       searchMethod: search_method,\n982:       isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n983:     };\n984:   });\n985: \n986:   const elapsed = Date.now() - start_time;\n987:   if (elapsed > 500) {\n988:     console.warn(`[vector-index] Enriched search took ${elapsed}ms (target <500ms)`);\n989:   }\n990: \n991:   return enriched_results;\n992: }\n993: \n994: /* ───────────────────────────────────────────────────────────────\n995:    MULTI-CONCEPT ENRICHED SEARCH\n996: ----------------------------------------------------------------*/\n997: \n998: /**\n999:  * Runs enriched search across multiple concepts.\n1000:  * @param concepts - The concept queries or embeddings.\n1001:  * @param limit - The maximum number of results to return.\n1002:  * @param options - Search options.\n1003:  * @returns A promise that resolves to enriched search results.\n1004:  * @throws {VectorIndexError} When concept validation fails or the vector search pipeline cannot execute.\n1005:  * @example\n1006:  * ```ts\n1007:  * const results = await multi_concept_search_enriched(['sqlite', 'vector'], 10, { specFolder: 'specs/001-demo' });\n1008:  * ```\n1009:  */\n1010: export async function multi_concept_search_enriched(\n1011:   concepts: Array<string | EmbeddingInput>,\n1012:   limit = 20,\n1013:   options: { specFolder?: string | null; minSimilarity?: number } = {}\n1014: ): Promise<EnrichedSearchResult[]> {\n1015:   const start_time = Date.now();\n1016: \n1017:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n1018:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n1019:   }\n1020: \n1021:   const { specFolder = null, minSimilarity = 50 } = options;\n1022: \n1023:   const concept_embeddings: EmbeddingInput[] = [];\n1024:   for (const concept of concepts) {\n1025:     if (typeof concept === 'string') {\n1026:       const embedding = await generate_query_embedding(concept);\n1027:       if (!embedding) {\n1028:         console.warn(`[vector-index] Failed to embed concept: \"${concept}\"`);\n1029:         return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n1030:       }\n1031:       concept_embeddings.push(embedding);\n1032:     } else {\n1033:       concept_embeddings.push(concept);\n1034:     }\n1035:   }\n1036: \n1037:   const sqlite_vec = get_sqlite_vec_available();\n1038:   if (!sqlite_vec) {\n1039:     console.warn('[vector-index] Falling back to keyword multi-concept search');\n1040:     return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n1041:   }\n1042: \n1043:   const raw_results = multi_concept_search(concept_embeddings, { limit, specFolder, minSimilarity });\n1044: \n1045:   const file_contents = await Promise.all(\n1046:     raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n1047:   );\n1048: \n1049:   const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n1050:     const content = file_contents[i];\n1051:     const title = row.title || extract_title(content, row.file_path);\n1052:     const snippet = extract_snippet(content);\n1053:     const tags = extract_tags(content);\n1054:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n1055: \n1056:     return {\n1057:       rank: i + 1,\n1058:       avgSimilarity: Math.round((row.avg_similarity || 0) * 100) / 100,\n1059:       conceptSimilarities: (row.concept_similarities as number[] | undefined) || [],\n1060:       title,\n1061:       specFolder: row.spec_folder,\n1062:       filePath: row.file_path,\n1063:       date,\n1064:       tags,\n1065:       snippet,\n1066:       id: row.id,\n1067:       importanceWeight: row.importance_weight ?? 0.5,\n1068:       isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n1069:     };\n1070:   });\n1071: \n1072:   const elapsed = Date.now() - start_time;\n1073:   if (elapsed > 500) {\n1074:     console.warn(`[vector-index] Multi-concept search took ${elapsed}ms (target <500ms)`);\n1075:   }\n1076: \n1077:   return enriched_results;\n1078: }\n1079: \n1080: /**\n1081:  * Runs keyword search for multiple concepts.\n1082:  * @param concepts - The concept terms to search for.\n1083:  * @param limit - The maximum number of results to return.\n1084:  * @param options - Search options.\n1085:  * @returns A promise that resolves to enriched search results.\n1086:  */\n1087: export async function multi_concept_keyword_search(\n1088:   concepts: string[],\n1089:   limit = 20,\n1090:   options: { specFolder?: string | null } = {}\n1091: ): Promise<EnrichedSearchResult[]> {\n1092:   const { specFolder = null } = options;\n1093: \n1094:   if (!concepts.length) {\n1095:     console.warn('[vector-index] multi_concept_keyword_search: empty concepts array');\n1096:     return [];\n1097:   }\n1098: \n1099:   const concept_results = concepts.map((concept: string) =>\n1100:     keyword_search(concept, { limit: 100, specFolder })\n1101:   );\n1102: \n1103:   const id_counts = new Map<number, number>();\n1104:   const id_to_row = new Map<number, MemoryRow>();\n1105: \n1106:   for (const results of concept_results) {\n1107:     for (const row of results) {\n1108:       const count = id_counts.get(row.id) || 0;\n1109:       id_counts.set(row.id, count + 1);\n1110:       if (!id_to_row.has(row.id)) {\n1111:         id_to_row.set(row.id, row);\n1112:       }\n1113:     }\n1114:   }\n1115: \n1116:   const matching_ids: number[] = [];\n1117:   for (const [id, count] of id_counts) {\n1118:     if (count === concepts.length) {\n1119:       matching_ids.push(id);\n1120:     }\n1121:   }\n1122: \n1123:   const limited_ids = matching_ids.slice(0, limit);\n1124:   const rows = limited_ids.map(id => id_to_row.get(id)).filter((row): row is MemoryRow => Boolean(row));\n1125: \n1126:   const file_contents = await Promise.all(\n1127:     rows.map(row => safe_read_file_async(row.file_path))\n1128:   );\n1129: \n1130:   const enriched_results = rows.map((row, i) => {\n1131:     const content = file_contents[i];\n1132:     const title = row.title || extract_title(content, row.file_path);\n1133:     const snippet = extract_snippet(content);\n1134:     const tags = extract_tags(content);\n1135:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n1136: \n1137:     return {\n1138:       rank: i + 1,\n1139:       avgSimilarity: Math.min(100, (row.keyword_score || 1) * 15),\n1140:       conceptSimilarities: concepts.map(() => row.keyword_score || 1),\n1141:       title,\n1142:       specFolder: row.spec_folder,\n1143:       filePath: row.file_path,\n1144:       date,\n1145:       tags,\n1146:       snippet,\n1147:       id: row.id,\n1148:       importanceWeight: row.importance_weight ?? 0.5,\n1149:       searchMethod: 'keyword',\n1150:       isConstitutional: row.importance_tier === 'constitutional'\n1151:     };\n1152:   });\n1153: \n1154:   return enriched_results;\n1155: }\n1156: \n1157: /**\n1158:  * Parses quoted phrases from a search query.\n1159:  * @param query - The search query.\n1160:  * @returns The quoted search terms.\n1161:  */\n1162: export function parse_quoted_terms(query: string): string[] {\n1163:   if (!query || typeof query !== 'string') {\n1164:     console.warn('[vector-index] parse_quoted_terms: invalid query, expected non-empty string');\n1165:     return [];\n1166:   }\n1167: \n1168:   const quoted: string[] = [];\n1169:   const regex = /\"([^\"]+)\"/g;\n1170:   let match;\n1171: \n1172:   while ((match = regex.exec(query)) !== null) {\n1173:     if (match[1] && match[1].trim()) {\n1174:       quoted.push(match[1].trim());\n1175:     }\n1176:   }\n1177: \n1178:   return quoted;\n1179: }\n1180: \n1181: /* ───────────────────────────────────────────────────────────────\n1182:    SMART RANKING AND DIVERSITY\n1183: ----------------------------------------------------------------*/\n1184: \n1185: // BUG-012 FIX: Weights read from config instead of hardcoded\n1186: /**\n1187:  * Applies smart ranking weights to enriched results.\n1188:  * @param results - The results to rank.\n1189:  * @returns The ranked results.\n1190:  */\n1191: export function apply_smart_ranking(results: EnrichedSearchResult[]): EnrichedSearchResult[] {\n1192:   if (!results || results.length === 0) return results;\n1193: \n1194:   const recency_weight = search_weights.smartRanking?.recencyWeight || 0.3;\n1195:   const access_weight = search_weights.smartRanking?.accessWeight || 0.2;\n1196:   const relevance_weight = search_weights.smartRanking?.relevanceWeight || 0.5;\n1197: \n1198:   const now = Date.now();\n1199:   const week_ms = 7 * 24 * 60 * 60 * 1000;\n1200:   const month_ms = 30 * 24 * 60 * 60 * 1000;\n1201: \n1202:   return results.map((r: EnrichedSearchResult) => {\n1203:     const created_at = r.created_at ? new Date(r.created_at).getTime() : now;\n1204:     const age = now - created_at;\n1205:     let recency_factor;\n1206:     if (age < week_ms) {\n1207:       recency_factor = 1.0;\n1208:     } else if (age < month_ms) {\n1209:       recency_factor = 0.8;\n1210:     } else {\n1211:       recency_factor = 0.5;\n1212:     }\n1213: \n1214:     const usage_factor = Math.min(1.0, (r.access_count || 0) / 10);\n1215:     const similarity_factor = (r.similarity || 0) / 100;\n1216: \n1217:     r.smartScore = (similarity_factor * relevance_weight) + (recency_factor * recency_weight) + (usage_factor * access_weight);\n1218:     r.smartScore = Math.round(r.smartScore * 100) / 100;\n1219: \n1220:     return r;\n1221:   }).sort((a, b) => Number(b.smartScore ?? 0) - Number(a.smartScore ?? 0));\n1222: }\n1223: \n1224: // Apply diversity filtering using MMR (Maximal Marginal Relevance)\n1225: /**\n1226:  * Applies diversity reordering to enriched results.\n1227:  * @param results - The results to diversify.\n1228:  * @param diversity_factor - The diversity weight to apply.\n1229:  * @returns The diversified results.\n1230:  */\n1231: export function apply_diversity(results: EnrichedSearchResult[], diversity_factor = 0.3): EnrichedSearchResult[] {\n1232:   if (!results || results.length <= 3) return results;\n1233: \n1234:   const selected = [results[0]];\n1235:   const remaining = [...results.slice(1)];\n1236: \n1237:   while (selected.length < results.length && remaining.length > 0) {\n1238:     let best_idx = 0;\n1239:     let best_score = -Infinity;\n1240: \n1241:     for (let i = 0; i < remaining.length; i++) {\n1242:       const candidate = remaining[i];\n1243:       const relevance = candidate.smartScore || ((candidate.similarity ?? 0) / 100) || 0;\n1244: \n1245:       let max_similarity_to_selected = 0;\n1246:       for (const sel of selected) {\n1247:         if (sel.specFolder === candidate.specFolder || sel.spec_folder === candidate.spec_folder) {\n1248:           max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.8);\n1249:         }\n1250:         if (sel.date === candidate.date) {\n1251:           max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.5);\n1252:         }\n1253:       }\n1254: \n1255:       const mmr_score = relevance - (diversity_factor * max_similarity_to_selected);\n1256: \n1257:       if (mmr_score > best_score) {\n1258:         best_score = mmr_score;\n1259:         best_idx = i;\n1260:       }\n1261:     }\n1262: \n1263:     selected.push(remaining.splice(best_idx, 1)[0]);\n1264:   }\n1265: \n1266:   return selected;\n1267: }\n1268: \n1269: /* ───────────────────────────────────────────────────────────────\n1270:    RELATED MEMORIES AND USAGE TRACKING\n1271: ----------------------------------------------------------------*/\n1272: \n1273: /**\n1274:  * Gets memories related to a stored memory.\n1275:  * @param memory_id - The memory identifier.\n1276:  * @returns The related memory rows.\n1277:  */\n1278: export function get_related_memories(memory_id: number): MemoryRow[] {\n1279:   try {\n1280:     const database = initialize_db();\n1281: \n1282:     const memory = database.prepare(`\n1283:       SELECT related_memories FROM memory_index WHERE id = ?\n1284:     `).get(memory_id) as { related_memories?: string | null } | undefined;\n1285: \n1286:     if (!memory || !memory.related_memories) {\n1287:       return [];\n1288:     }\n1289: \n1290:     const related = safe_parse_json(memory.related_memories, []);\n1291: \n1292:     return (related as RelatedMemoryLink[]).map((rel: RelatedMemoryLink): MemoryRow | null => {\n1293:       const full_memory = get_memory(rel.id);\n1294:       if (full_memory) {\n1295:         return {\n1296:           ...full_memory,\n1297:           relationSimilarity: rel.similarity\n1298:         };\n1299:       }\n1300:       return null;\n1301:     }).filter((relatedMemory): relatedMemory is MemoryRow => Boolean(relatedMemory));\n1302:   } catch (error: unknown) {\n1303:     console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n1304:     return [];\n1305:   }\n1306: }\n1307: \n1308: /**\n1309:  * Gets usage statistics for indexed memories.\n1310:  * @param options - Sorting and limit options.\n1311:  * @returns The usage statistics rows.\n1312:  */\n1313: export function get_usage_stats(options: UsageStatsOptions = {}): Array<{ id: number; title: string | null; spec_folder: string; file_path: string; access_count: number; last_accessed: number | null; confidence: number | null; created_at: string }> {\n1314:   const {\n1315:     sortBy = 'access_count',\n1316:     order = 'DESC',\n1317:     limit = 20\n1318:   } = options;\n1319: \n1320:   const valid_sort_fields = ['access_count', 'last_accessed', 'confidence'];\n1321:   const sort_field = valid_sort_fields.includes(sortBy) ? sortBy : 'access_count';\n1322:   const sort_order = order.toUpperCase() === 'ASC' ? 'ASC' : 'DESC';\n1323: \n1324:   const database = initialize_db();\n1325: \n1326:   const rows = database.prepare(`\n1327:     SELECT id, title, spec_folder, file_path, access_count,\n1328:            last_accessed, confidence, created_at\n1329:     FROM memory_index\n1330:     WHERE access_count > 0\n1331:     ORDER BY ${sort_field} ${sort_order}\n1332:     LIMIT ?\n1333:   `).all(limit) as Array<{\n1334:     id: number;\n1335:     title: string | null;\n1336:     spec_folder: string;\n1337:     file_path: string;\n1338:     access_count: number;\n1339:     last_accessed: number | null;\n1340:     confidence: number | null;\n1341:     created_at: string;\n1342:   }>;\n1343: \n1344:   return rows;\n1345: }\n1346: \n1347: /* ───────────────────────────────────────────────────────────────\n1348:    CLEANUP FUNCTIONS\n1349: ----------------------------------------------------------------*/\n1350: \n1351: /**\n1352:  * Finds memory records that are candidates for cleanup.\n1353:  * @param options - Cleanup thresholds and limits.\n1354:  * @returns The cleanup candidate details.\n1355:  */\n1356: export function find_cleanup_candidates(options: CleanupOptions = {}): Array<{ id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; reasons: string[] }> {\n1357:   const database = initialize_db();\n1358: \n1359:   const {\n1360:     maxAgeDays = 90,\n1361:     maxAccessCount = 2,\n1362:     maxConfidence = 0.4,\n1363:     limit = 50\n1364:   } = options;\n1365: \n1366:   const cutoff_date = new Date();\n1367:   cutoff_date.setDate(cutoff_date.getDate() - maxAgeDays);\n1368:   const cutoff_iso = cutoff_date.toISOString();\n1369: \n1370:   const sql = `\n1371:     SELECT\n1372:       id,\n1373:       spec_folder,\n1374:       file_path,\n1375:       title,\n1376:       created_at,\n1377:       last_accessed,\n1378:       access_count,\n1379:       confidence,\n1380:       importance_weight\n1381:     FROM memory_index\n1382:     WHERE\n1383:       created_at < ?\n1384:       OR access_count <= ?\n1385:       OR confidence <= ?\n1386:       OR (last_accessed IS NULL AND created_at < ?)\n1387:     ORDER BY\n1388:       last_accessed ASC NULLS FIRST,\n1389:       access_count ASC,\n1390:       confidence ASC\n1391:     LIMIT ?\n1392:   `;\n1393: \n1394:   let rows;\n1395:   try {\n1396:     rows = database.prepare(sql).all(\n1397:       cutoff_iso,\n1398:       maxAccessCount,\n1399:       maxConfidence,\n1400:       cutoff_iso,\n1401:       limit\n1402:     );\n1403:   } catch (e: unknown) {\n1404:     console.warn(`[vector-index] find_cleanup_candidates error: ${get_error_message(e)}`);\n1405:     return [];\n1406:   }\n1407: \n1408:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n1409:     const age_string = format_age_string(row.created_at ?? null);\n1410:     const last_access_string = format_age_string(\n1411:       typeof row.last_accessed === 'number' ? new Date(row.last_accessed).toISOString() : null\n1412:     );\n1413: \n1414:     const reasons: string[] = [];\n1415:     if (row.created_at && new Date(row.created_at) < cutoff_date) {\n1416:       reasons.push(`created ${age_string}`);\n1417:     }\n1418:     if ((row.access_count || 0) <= maxAccessCount) {\n1419:       const count = row.access_count || 0;\n1420:       reasons.push(`accessed ${count} time${count !== 1 ? 's' : ''}`);\n1421:     }\n1422:     if ((row.confidence || 0.5) <= maxConfidence) {\n1423:       reasons.push(`low importance (${Math.round((row.confidence || 0.5) * 100)}%)`);\n1424:     }\n1425: \n1426:     return {\n1427:       id: row.id,\n1428:       specFolder: row.spec_folder,\n1429:       filePath: row.file_path,\n1430:       title: row.title || 'Untitled',\n1431:       createdAt: row.created_at,\n1432:       lastAccessedAt: row.last_accessed,\n1433:       accessCount: row.access_count || 0,\n1434:       confidence: row.confidence || 0.5,\n1435:       ageString: age_string,\n1436:       lastAccessString: last_access_string,\n1437:       reasons\n1438:     };\n1439:   });\n1440: }\n1441: \n1442: /**\n1443:  * Builds a preview payload for a stored memory.\n1444:  * @param memory_id - The memory identifier.\n1445:  * @param max_lines - The maximum number of file lines to include.\n1446:  * @returns The memory preview, if found.\n1447:  */\n1448: export function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n1449:   const database = initialize_db();\n1450: \n1451:   let memory: MemoryRow | undefined;\n1452:   try {\n1453:     memory = database.prepare(`\n1454:       SELECT * FROM memory_index WHERE id = ?\n1455:     `).get(memory_id) as MemoryRow | undefined;\n1456:   } catch (e: unknown) {\n1457:     console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n1458:     return null;\n1459:   }\n1460: \n1461:   if (!memory) return null;\n1462: \n1463:   let content = '';\n1464:   try {\n1465:     // Validate DB-stored file paths before reading\n1466:     if (memory.file_path) {\n1467:       const valid_path = validate_file_path_local(memory.file_path);\n1468:       if (valid_path && fs.existsSync(valid_path)) {\n1469:         const full_content = fs.readFileSync(valid_path, 'utf-8');\n1470:         const lines = full_content.split('\\n');\n1471:         content = lines.slice(0, max_lines).join('\\n');\n1472:         if (lines.length > max_lines) {\n1473:           content += `\\n... (${lines.length - max_lines} more lines)`;\n1474:         }\n1475:       }\n1476:     }\n1477:   } catch (e: unknown) {\n1478:     console.warn('[vector-index] get_memory_preview file read warning', {\n1479:       operation: 'get_memory_preview',\n1480:       memoryId: memory_id,\n1481:       filePath: memory.file_path ?? null,\n1482:       error: get_error_message(e),\n1483:     });\n1484:     content = '(Unable to read file content)';\n1485:   }\n1486: \n1487:   return {\n1488:     id: memory.id,\n1489:     specFolder: memory.spec_folder,\n1490:     filePath: memory.file_path,\n1491:     title: memory.title || 'Untitled',\n1492:     createdAt: memory.created_at,\n1493:     lastAccessedAt: memory.last_accessed,\n1494:     accessCount: memory.access_count || 0,\n1495:     confidence: memory.confidence || 0.5,\n\n(Output capped at 50 KB. Showing lines 1-1495. Use offset=1496 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport {\n  get_error_message,\n  parse_trigger_phrases,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  initialize_db,\n  get_embedding_dim,\n  get_constitutional_memories,\n  init_prepared_statements,\n  validate_file_path_local,\n  safe_read_file_async,\n  safe_parse_json,\n  search_weights,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource as activeVectorSchema,\n} from './vector-index-store.js';\nimport { delete_memory_from_database } from './vector-index-mutations.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\nconst logger = createLogger('VectorIndex');\n\ntype RelatedMemoryLink = { id: number; similarity: number };\ntype UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\ntype CleanupOptions = {\n  maxAgeDays?: number;\n  maxAccessCount?: number;\n  maxConfidence?: number;\n  limit?: number;\n};\ntype VectorSource = {\n  dim: number;\n  tableName: string;\n  idColumn: string;\n  embeddingColumn: string;\n};\n\nexport interface KnnQueryShapeBenchmarkResult {\n  readonly corpusSize: number;\n  readonly iterations: number;\n  readonly scalarJoinAverageMs: number;\n  readonly matchAverageMs: number | null;\n  readonly matchSupported: boolean;\n  readonly matchImprovementPct: number | null;\n  readonly decision: 'adopt_match' | 'keep_scalar_join';\n  readonly reason: string;\n}\n\nconst KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n\nfunction appendSpecFolderScope(\n  clauses: string[],\n  params: unknown[],\n  specFolder: string | null | undefined,\n  column = 'm.spec_folder',\n): void {\n  if (!specFolder) return;\n  clauses.push(`(${column} = ? OR ${column} LIKE ?)`);\n  params.push(specFolder, `${specFolder}/%`);\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM active_vec.sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\nfunction getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n  const active = getActiveEmbedder(database);\n  const dimTableName = `vec_${active.dim}`;\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n    return {\n      dim: active.dim,\n      tableName: activeVectorSchema(dimTableName),\n      idColumn: 'id',\n      embeddingColumn: 'vec',\n    };\n  }\n\n  return {\n    dim: get_embedding_dim(),\n    tableName: activeVectorSchema('vec_memories'),\n    idColumn: 'rowid',\n    embeddingColumn: 'embedding',\n  };\n}\n\nfunction elapsedMs(start: bigint): number {\n  return Number(process.hrtime.bigint() - start) / 1_000_000;\n}\n\nfunction average(values: number[]): number {\n  if (values.length === 0) return 0;\n  return values.reduce((sum, value) => sum + value, 0) / values.length;\n}\n\nexport function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n  return result.matchSupported === true\n    && typeof result.matchImprovementPct === 'number'\n    && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n}\n\nexport function benchmarkKnnQueryShapes(\n  query_embedding: EmbeddingInput,\n  options: { iterations?: number; limit?: number } = {},\n  database: Database.Database = initialize_db(),\n): KnnQueryShapeBenchmarkResult {\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n  const limit = Math.max(1, Math.floor(options.limit ?? 20));\n  const queryBuffer = to_embedding_buffer(query_embedding);\n  const corpusSize = (database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE m.embedding_status = 'success'\n  `).get() as { count: number }).count;\n\n  const scalarSql = `\n    SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n    WHERE m.embedding_status = 'success'\n    ORDER BY distance ASC\n    LIMIT ?\n  `;\n  const scalarStmt = database.prepare(scalarSql);\n  scalarStmt.all(queryBuffer, limit);\n  const scalarRuns: number[] = [];\n  for (let i = 0; i < iterations; i += 1) {\n    const start = process.hrtime.bigint();\n    scalarStmt.all(queryBuffer, limit);\n    scalarRuns.push(elapsedMs(start));\n  }\n\n  const matchTable = activeVectorSchema('vec_memories');\n  const matchAvailable = tableExists(database, 'vec_memories');\n  let matchAverageMs: number | null = null;\n  let matchError: string | null = null;\n\n  if (matchAvailable) {\n    try {\n      const matchSql = `\n        WITH knn AS (\n          SELECT rowid, distance\n          FROM ${matchTable}\n          WHERE embedding MATCH ? AND k = ?\n        )\n        SELECT m.id, knn.distance\n        FROM knn\n        JOIN memory_index m ON m.id = knn.rowid\n        JOIN active_memory_projection p ON p.active_memory_id = m.id\n        WHERE m.embedding_status = 'success'\n        ORDER BY knn.distance ASC\n        LIMIT ?\n      `;\n      const matchStmt = database.prepare(matchSql);\n      matchStmt.all(queryBuffer, limit, limit);\n      const matchRuns: number[] = [];\n      for (let i = 0; i < iterations; i += 1) {\n        const start = process.hrtime.bigint();\n        matchStmt.all(queryBuffer, limit, limit);\n        matchRuns.push(elapsedMs(start));\n      }\n      matchAverageMs = average(matchRuns);\n    } catch (error: unknown) {\n      matchError = get_error_message(error);\n    }\n  }\n\n  const scalarJoinAverageMs = average(scalarRuns);\n  const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n    ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n    : null;\n  const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n  };\n  const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n\n  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n\n/**\n * Gets one indexed memory by identifier.\n * @param id - The memory identifier.\n * @returns The matching memory row, if found.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const memory = get_memory(42);\n * ```\n */\nexport function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n  const stmts = init_prepared_statements(database);\n  const row = stmts.get_by_id.get(id);\n\n  if (row) {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n  }\n\n  return row || null;\n}\n\n/**\n * Gets indexed memories for a spec folder.\n * @param spec_folder - The spec folder to query.\n * @returns The memory rows for the folder.\n */\nexport function get_memories_by_folder(\n  spec_folder: string,\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const rows = database.prepare(`\n    SELECT m.*\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE (m.spec_folder = ? OR m.spec_folder LIKE ?)\n    ORDER BY m.created_at DESC\n  `).all(spec_folder, `${spec_folder}/%`) as MemoryRow[];\n\n  return rows.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/**\n * Gets the total number of indexed memories.\n * @returns The total memory count.\n */\nexport function get_memory_count(database: Database.Database = initialize_db()): number {\n  const stmts = init_prepared_statements(database);\n  const result = stmts.count_all.get();\n  return result?.count ?? 0;\n}\n\n/**\n * Gets memory counts grouped by embedding status.\n * @returns The counts for each embedding status.\n */\nexport function get_status_counts(\n  database: Database.Database = initialize_db(),\n): { pending: number; success: number; failed: number; retry: number; partial: number } {\n  const rows = database.prepare(`\n    SELECT m.embedding_status, COUNT(*) as count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    GROUP BY m.embedding_status\n  `).all();\n\n  // Include 'partial' status in counts.\n  const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n  for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n    if (row.embedding_status in counts) {\n      counts[row.embedding_status] = row.count;\n    }\n  }\n\n  return counts;\n}\n\n/**\n * Gets summary counts for indexed memories.\n * @returns The aggregate memory statistics.\n */\nexport function get_stats(\n  database: Database.Database = initialize_db(),\n): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n  const counts = get_status_counts(database);\n  const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n\n  return {\n    total,\n    ...counts\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories by vector similarity.\n * @param query_embedding - The query embedding to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const {\n    limit = 10,\n    specFolder = null,\n    minSimilarity = 0,\n    useDecay = true,\n    tier = null,\n    contextType = null,\n    includeConstitutional = true,\n    includeArchived = false\n  } = options;\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const query_buffer = to_embedding_buffer(query_embedding);\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  // FSRS-preferred decay with half-life fallback\n  const decay_expr = useDecay\n    ? `CASE\n         WHEN m.is_pinned = 1 THEN m.importance_weight\n         WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n           m.importance_weight * POWER(\n             1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n             -0.5\n           )\n         ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n       END`\n    : 'm.importance_weight';\n\n  let constitutional_results: MemoryRow[] = [];\n\n  if (includeConstitutional && tier !== 'constitutional') {\n    constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n  }\n\n  const where_clauses = ['m.embedding_status = \\'success\\''];\n  const params: unknown[] = [query_buffer];\n\n  where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n\n  if (tier === 'deprecated') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('deprecated');\n  } else if (tier === 'constitutional') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('constitutional');\n  } else if (tier) {\n    where_clauses.push('m.importance_tier = ?');\n    params.push(tier);\n  } else {\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n  }\n\n  appendSpecFolderScope(where_clauses, params, specFolder);\n\n  if (contextType) {\n    where_clauses.push('m.context_type = ?');\n    params.push(contextType);\n  }\n\n  // If constitutional results already satisfy limit, return them directly.\n  if (constitutional_results.length >= limit) {\n    return constitutional_results.slice(0, limit);\n  }\n  const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n  params.push(max_distance, adjusted_limit);\n\n  const sql = `\n    SELECT sub.*,\n           ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n    FROM (\n      SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n             ${decay_expr} as effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n\n  return [...constitutional_results, ...regular_results];\n}\n\n/**\n * Gets constitutional memories for prompt assembly.\n * @param options - Retrieval options.\n * @returns The constitutional memory rows.\n */\nexport function get_constitutional_memories_public(\n  options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n\n  let results = get_constitutional_memories(database, specFolder, includeArchived);\n\n  const TOKENS_PER_MEMORY = 100;\n  const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n  if (results.length > max_count) {\n    results = results.slice(0, max_count);\n  }\n\n  return results;\n}\n\n/**\n * Searches indexed memories with multiple concept embeddings.\n * @param concept_embeddings - The concept embeddings to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n * @example\n * ```ts\n * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function multi_concept_search(\n  concept_embeddings: EmbeddingInput[],\n  options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const database = initialize_db();\n\n  const concepts = concept_embeddings;\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  for (const emb of concepts) {\n    if (!emb || emb.length !== vectorSource.dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n        VectorIndexErrorCode.QUERY_FAILED,\n      );\n    }\n  }\n\n  const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  const distance_expressions = concept_buffers.map((_, i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n  ).join(', ');\n\n  const distance_filters = concept_buffers.map((_, _i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n  ).join(' AND ');\n\n  const folder_filter = specFolder ? 'AND (m.spec_folder = ? OR m.spec_folder LIKE ?)' : '';\n  const similarity_select = concept_buffers.map((_, i) =>\n    `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n  ).join(', ');\n\n  const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n\n  const sql = `\n    SELECT\n      sub.*,\n      ${similarity_select},\n      (${avg_distance_expr}) / ${concepts.length} as avg_distance\n    FROM (\n      SELECT\n        m.*,\n        ${distance_expressions}\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE m.embedding_status = 'success'\n        AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n        ${folder_filter}\n        AND ${distance_filters}\n    ) sub\n    ORDER BY avg_distance ASC\n    LIMIT ?\n  `;\n\n  const params = [\n    ...concept_buffers,\n    ...(specFolder ? [specFolder, `${specFolder}/%`] : []),\n    ...concept_buffers.flatMap(b => [b, max_distance]),\n    limit\n  ];\n\n  const rows = database.prepare(sql).all(...params);\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n    row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CONTENT EXTRACTION HELPERS\n----------------------------------------------------------------*/\n\n/**\n * Extracts a display title from indexed content.\n * @param content - The content to inspect.\n * @param filename - The optional source filename.\n * @returns The extracted title.\n */\nexport function extract_title(content: unknown, filename?: string): string {\n  if (!content || typeof content !== 'string') {\n    return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n  }\n\n  const h1_match = content.match(/^#\\s+(.+)$/m);\n  if (h1_match && h1_match[1]) {\n    return h1_match[1].trim();\n  }\n\n  const h2_match = content.match(/^##\\s+(.+)$/m);\n  if (h2_match && h2_match[1]) {\n    return h2_match[1].trim();\n  }\n\n  const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n  if (yaml_match && yaml_match[1]) {\n    return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n  }\n\n  const lines = content.split('\\n').filter(l => l.trim().length > 0);\n  if (lines.length > 0) {\n    const first_line = lines[0].trim();\n    return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n  }\n\n  return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n}\n\n/**\n * Extracts a preview snippet from indexed content.\n * @param content - The content to inspect.\n * @param max_length - The maximum snippet length.\n * @returns The extracted snippet.\n */\nexport function extract_snippet(content: unknown, max_length = 200): string {\n  if (!content || typeof content !== 'string') {\n    return '';\n  }\n\n  const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n  const lines = text.split('\\n');\n  const snippet_lines: string[] = [];\n\n  for (const line of lines) {\n    const trimmed = line.trim();\n\n    if (!trimmed || /^#+\\s/.test(trimmed)) {\n      if (snippet_lines.length > 0) {\n        break;\n      }\n      continue;\n    }\n\n    if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n      continue;\n    }\n\n    snippet_lines.push(trimmed);\n\n    const current_length = snippet_lines.join(' ').length;\n    if (current_length >= max_length) {\n      break;\n    }\n  }\n\n  let snippet = snippet_lines.join(' ');\n\n  if (snippet.length > max_length) {\n    snippet = snippet.substring(0, max_length);\n    const last_space = snippet.lastIndexOf(' ');\n    if (last_space > max_length * 0.7) {\n      snippet = snippet.substring(0, last_space);\n    }\n    snippet += '...';\n  }\n\n  return snippet;\n}\n\n/**\n * Extracts tags from indexed content.\n * @param content - The content to inspect.\n * @returns The extracted tags.\n */\nexport function extract_tags(content: unknown): string[] {\n  if (!content || typeof content !== 'string') {\n    console.warn('[vector-index] extract_tags: invalid content type, expected string');\n    return [];\n  }\n\n  const tags = new Set<string>();\n\n  const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n  if (yaml_tags_match && yaml_tags_match[1]) {\n    yaml_tags_match[1].split(',').forEach(tag => {\n      const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n      if (cleaned) tags.add(cleaned.toLowerCase());\n    });\n  }\n\n  const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n  if (yaml_list_match && yaml_list_match[1]) {\n    yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n      const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n      if (tag) tags.add(tag.toLowerCase());\n    });\n  }\n\n  const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n  if (hashtag_matches) {\n    hashtag_matches.forEach(match => {\n      const tag = match.trim().replace(/^#/, '');\n      if (tag && !tag.match(/^[0-9]+$/)) {\n        tags.add(tag.toLowerCase());\n      }\n    });\n  }\n\n  return Array.from(tags);\n}\n\n/**\n * Extracts a relevant date from indexed content or path.\n * @param content - The content to inspect.\n * @param file_path - The optional source file path.\n * @returns The extracted date, if available.\n */\nexport function extract_date(content: unknown, file_path?: string): string | null {\n  if (content && typeof content === 'string') {\n    const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n    if (date_match && date_match[1]) {\n      const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n      try {\n        const parsed = new Date(date_str);\n        if (!isNaN(parsed.getTime())) {\n          return parsed.toISOString().split('T')[0];\n        }\n      } catch (_e: unknown) {\n        console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n      }\n    }\n  }\n\n  if (file_path) {\n    const filename = path.basename(file_path);\n\n    const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n    if (iso_match) {\n      return iso_match[1];\n    }\n\n    const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n    if (ddmmyy_match) {\n      const [, day, month, year] = ddmmyy_match;\n      const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n      return `${full_year}-${month}-${day}`;\n    }\n  }\n\n  return null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EMBEDDING GENERATION WRAPPER\n----------------------------------------------------------------*/\n\n/**\n * Generates an embedding for a search query.\n * @param query - The search query.\n * @returns A promise that resolves to the embedding, if generated.\n */\nexport async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n  if (!query || typeof query !== 'string' || query.trim().length === 0) {\n    console.warn('[vector-index] Empty query provided for embedding');\n    return null;\n  }\n\n  try {\n    const database = initialize_db();\n    const active = getActiveEmbedder(database);\n    const trimmedQuery = query.trim();\n    const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.name\n      : embeddingsProvider.getModelName();\n    const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.dim\n      : embeddingsProvider.getEmbeddingDimension();\n    const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n    const contentHash = computeContentHash(trimmedQuery);\n    const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n      profileKey,\n      inputKind: 'query',\n    });\n    if (cached) {\n      return new Float32Array(\n        cached.buffer,\n        cached.byteOffset,\n        Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n      );\n    }\n\n    const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n      : getStartupEmbeddingProfile().provider;\n    const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n    const activeAdapter = adapter as typeof adapter & {\n      embed: (\n        texts: ReadonlyArray<string>,\n        options?: { inputType?: 'query' | 'document' },\n      ) => Promise<Float32Array[]>;\n    };\n    const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n    const embedding: Float32Array | null = activeEmbedding ?? null;\n\n    if (embedding) {\n      storeEmbedding(\n        database,\n        contentHash,\n        modelId,\n        Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n        embedding.length,\n        { profileKey, inputKind: 'query' },\n      );\n    }\n\n    return embedding;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n    return null;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   KEYWORD SEARCH FALLBACK\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories using keyword matching.\n * @param query - The search query.\n * @param options - Search options.\n * @returns The matching memory rows.\n */\nexport function keyword_search(\n  query: string,\n  options: { limit?: number; specFolder?: string | null } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { limit = 20, specFolder = null } = options;\n\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n  if (search_terms.length === 0) {\n    console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n    return [];\n  }\n\n  let where_clause = '1=1';\n  const params: unknown[] = [];\n\n  if (specFolder) {\n    where_clause += ' AND (spec_folder = ? OR spec_folder LIKE ?)';\n    params.push(specFolder, `${specFolder}/%`);\n  }\n\n  const sql = `\n    SELECT m.* FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE ${where_clause}\n    ORDER BY m.importance_weight DESC, m.created_at DESC\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    let score = 0;\n    const searchable_text = [\n      row.title || '',\n      parse_trigger_phrases(row.trigger_phrases).join(' '),\n      row.spec_folder || '',\n      row.file_path || ''\n    ].join(' ').toLowerCase();\n\n    for (const term of search_terms) {\n      if (searchable_text.includes(term)) {\n        score += 1;\n        if ((row.title || '').toLowerCase().includes(term)) {\n          score += 2;\n        }\n        if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n          score += 1.5;\n        }\n      }\n    }\n\n    score *= (0.5 + (row.importance_weight ?? 0));\n    return { ...row, keyword_score: score };\n  });\n\n  const filtered = scored\n    .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n    .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n    .slice(0, limit);\n\n  return filtered.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   ENRICHED VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched vector search for a text query.\n * @param query - The search query.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n * @example\n * ```ts\n * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function vector_search_enriched(\n  query: string,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {},\n  database: Database.Database = initialize_db(),\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();\n  const { specFolder = null, minSimilarity = 30 } = options;\n\n  const query_embedding = await generate_query_embedding(query);\n\n  let raw_results;\n  let search_method = 'vector';\n\n  const sqlite_vec = get_sqlite_vec_available();\n  if (query_embedding && sqlite_vec) {\n    raw_results = vector_search(query_embedding, {\n      limit,\n      specFolder,\n      minSimilarity\n    }, database);\n  } else {\n    console.warn('[vector-index] Falling back to keyword search');\n    search_method = 'keyword';\n    raw_results = keyword_search(query, { limit, specFolder }, database);\n  }\n\n  // HIGH-004 FIX: Read all files concurrently\n  const file_contents = await Promise.all(\n    raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    const similarity = search_method === 'vector'\n      ? (row.similarity || 0)\n      : Math.min(100, (row.keyword_score || 0) * 20);\n\n    return {\n      rank: i + 1,\n      similarity: Math.round(similarity * 100) / 100,\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      searchMethod: search_method,\n      isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n    };\n  });\n\n  const elapsed = Date.now() - start_time;\n  if (elapsed > 500) {\n    console.warn(`[vector-index] Enriched search took ${elapsed}ms (target <500ms)`);\n  }\n\n  return enriched_results;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   MULTI-CONCEPT ENRICHED SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched search across multiple concepts.\n * @param concepts - The concept queries or embeddings.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} When concept validation fails or the vector search pipeline cannot execute.\n * @example\n * ```ts\n * const results = await multi_concept_search_enriched(['sqlite', 'vector'], 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function multi_concept_search_enriched(\n  concepts: Array<string | EmbeddingInput>,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {}\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();\n\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const { specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_embeddings: EmbeddingInput[] = [];\n  for (const concept of concepts) {\n    if (typeof concept === 'string') {\n      const embedding = await generate_query_embedding(concept);\n      if (!embedding) {\n        console.warn(`[vector-index] Failed to embed concept: \"${concept}\"`);\n        return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n      }\n      concept_embeddings.push(embedding);\n    } else {\n      concept_embeddings.push(concept);\n    }\n  }\n\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Falling back to keyword multi-concept search');\n    return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n  }\n\n  const raw_results = multi_concept_search(concept_embeddings, { limit, specFolder, minSimilarity });\n\n  const file_contents = await Promise.all(\n    raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    return {\n      rank: i + 1,\n      avgSimilarity: Math.round((row.avg_similarity || 0) * 100) / 100,\n      conceptSimilarities: (row.concept_similarities as number[] | undefined) || [],\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n    };\n  });\n\n  const elapsed = Date.now() - start_time;\n  if (elapsed > 500) {\n    console.warn(`[vector-index] Multi-concept search took ${elapsed}ms (target <500ms)`);\n  }\n\n  return enriched_results;\n}\n\n/**\n * Runs keyword search for multiple concepts.\n * @param concepts - The concept terms to search for.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n */\nexport async function multi_concept_keyword_search(\n  concepts: string[],\n  limit = 20,\n  options: { specFolder?: string | null } = {}\n): Promise<EnrichedSearchResult[]> {\n  const { specFolder = null } = options;\n\n  if (!concepts.length) {\n    console.warn('[vector-index] multi_concept_keyword_search: empty concepts array');\n    return [];\n  }\n\n  const concept_results = concepts.map((concept: string) =>\n    keyword_search(concept, { limit: 100, specFolder })\n  );\n\n  const id_counts = new Map<number, number>();\n  const id_to_row = new Map<number, MemoryRow>();\n\n  for (const results of concept_results) {\n    for (const row of results) {\n      const count = id_counts.get(row.id) || 0;\n      id_counts.set(row.id, count + 1);\n      if (!id_to_row.has(row.id)) {\n        id_to_row.set(row.id, row);\n      }\n    }\n  }\n\n  const matching_ids: number[] = [];\n  for (const [id, count] of id_counts) {\n    if (count === concepts.length) {\n      matching_ids.push(id);\n    }\n  }\n\n  const limited_ids = matching_ids.slice(0, limit);\n  const rows = limited_ids.map(id => id_to_row.get(id)).filter((row): row is MemoryRow => Boolean(row));\n\n  const file_contents = await Promise.all(\n    rows.map(row => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = rows.map((row, i) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    return {\n      rank: i + 1,\n      avgSimilarity: Math.min(100, (row.keyword_score || 1) * 15),\n      conceptSimilarities: concepts.map(() => row.keyword_score || 1),\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      searchMethod: 'keyword',\n      isConstitutional: row.importance_tier === 'constitutional'\n    };\n  });\n\n  return enriched_results;\n}\n\n/**\n * Parses quoted phrases from a search query.\n * @param query - The search query.\n * @returns The quoted search terms.\n */\nexport function parse_quoted_terms(query: string): string[] {\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] parse_quoted_terms: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const quoted: string[] = [];\n  const regex = /\"([^\"]+)\"/g;\n  let match;\n\n  while ((match = regex.exec(query)) !== null) {\n    if (match[1] && match[1].trim()) {\n      quoted.push(match[1].trim());\n    }\n  }\n\n  return quoted;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SMART RANKING AND DIVERSITY\n----------------------------------------------------------------*/\n\n// BUG-012 FIX: Weights read from config instead of hardcoded\n/**\n * Applies smart ranking weights to enriched results.\n * @param results - The results to rank.\n * @returns The ranked results.\n */\nexport function apply_smart_ranking(results: EnrichedSearchResult[]): EnrichedSearchResult[] {\n  if (!results || results.length === 0) return results;\n\n  const recency_weight = search_weights.smartRanking?.recencyWeight || 0.3;\n  const access_weight = search_weights.smartRanking?.accessWeight || 0.2;\n  const relevance_weight = search_weights.smartRanking?.relevanceWeight || 0.5;\n\n  const now = Date.now();\n  const week_ms = 7 * 24 * 60 * 60 * 1000;\n  const month_ms = 30 * 24 * 60 * 60 * 1000;\n\n  return results.map((r: EnrichedSearchResult) => {\n    const created_at = r.created_at ? new Date(r.created_at).getTime() : now;\n    const age = now - created_at;\n    let recency_factor;\n    if (age < week_ms) {\n      recency_factor = 1.0;\n    } else if (age < month_ms) {\n      recency_factor = 0.8;\n    } else {\n      recency_factor = 0.5;\n    }\n\n    const usage_factor = Math.min(1.0, (r.access_count || 0) / 10);\n    const similarity_factor = (r.similarity || 0) / 100;\n\n    r.smartScore = (similarity_factor * relevance_weight) + (recency_factor * recency_weight) + (usage_factor * access_weight);\n    r.smartScore = Math.round(r.smartScore * 100) / 100;\n\n    return r;\n  }).sort((a, b) => Number(b.smartScore ?? 0) - Number(a.smartScore ?? 0));\n}\n\n// Apply diversity filtering using MMR (Maximal Marginal Relevance)\n/**\n * Applies diversity reordering to enriched results.\n * @param results - The results to diversify.\n * @param diversity_factor - The diversity weight to apply.\n * @returns The diversified results.\n */\nexport function apply_diversity(results: EnrichedSearchResult[], diversity_factor = 0.3): EnrichedSearchResult[] {\n  if (!results || results.length <= 3) return results;\n\n  const selected = [results[0]];\n  const remaining = [...results.slice(1)];\n\n  while (selected.length < results.length && remaining.length > 0) {\n    let best_idx = 0;\n    let best_score = -Infinity;\n\n    for (let i = 0; i < remaining.length; i++) {\n      const candidate = remaining[i];\n      const relevance = candidate.smartScore || ((candidate.similarity ?? 0) / 100) || 0;\n\n      let max_similarity_to_selected = 0;\n      for (const sel of selected) {\n        if (sel.specFolder === candidate.specFolder || sel.spec_folder === candidate.spec_folder) {\n          max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.8);\n        }\n        if (sel.date === candidate.date) {\n          max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.5);\n        }\n      }\n\n      const mmr_score = relevance - (diversity_factor * max_similarity_to_selected);\n\n      if (mmr_score > best_score) {\n        best_score = mmr_score;\n        best_idx = i;\n      }\n    }\n\n    selected.push(remaining.splice(best_idx, 1)[0]);\n  }\n\n  return selected;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   RELATED MEMORIES AND USAGE TRACKING\n----------------------------------------------------------------*/\n\n/**\n * Gets memories related to a stored memory.\n * @param memory_id - The memory identifier.\n * @returns The related memory rows.\n */\nexport function get_related_memories(memory_id: number): MemoryRow[] {\n  try {\n    const database = initialize_db();\n\n    const memory = database.prepare(`\n      SELECT related_memories FROM memory_index WHERE id = ?\n    `).get(memory_id) as { related_memories?: string | null } | undefined;\n\n    if (!memory || !memory.related_memories) {\n      return [];\n    }\n\n    const related = safe_parse_json(memory.related_memories, []);\n\n    return (related as RelatedMemoryLink[]).map((rel: RelatedMemoryLink): MemoryRow | null => {\n      const full_memory = get_memory(rel.id);\n      if (full_memory) {\n        return {\n          ...full_memory,\n          relationSimilarity: rel.similarity\n        };\n      }\n      return null;\n    }).filter((relatedMemory): relatedMemory is MemoryRow => Boolean(relatedMemory));\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n    return [];\n  }\n}\n\n/**\n * Gets usage statistics for indexed memories.\n * @param options - Sorting and limit options.\n * @returns The usage statistics rows.\n */\nexport function get_usage_stats(options: UsageStatsOptions = {}): Array<{ id: number; title: string | null; spec_folder: string; file_path: string; access_count: number; last_accessed: number | null; confidence: number | null; created_at: string }> {\n  const {\n    sortBy = 'access_count',\n    order = 'DESC',\n    limit = 20\n  } = options;\n\n  const valid_sort_fields = ['access_count', 'last_accessed', 'confidence'];\n  const sort_field = valid_sort_fields.includes(sortBy) ? sortBy : 'access_count';\n  const sort_order = order.toUpperCase() === 'ASC' ? 'ASC' : 'DESC';\n\n  const database = initialize_db();\n\n  const rows = database.prepare(`\n    SELECT id, title, spec_folder, file_path, access_count,\n           last_accessed, confidence, created_at\n    FROM memory_index\n    WHERE access_count > 0\n    ORDER BY ${sort_field} ${sort_order}\n    LIMIT ?\n  `).all(limit) as Array<{\n    id: number;\n    title: string | null;\n    spec_folder: string;\n    file_path: string;\n    access_count: number;\n    last_accessed: number | null;\n    confidence: number | null;\n    created_at: string;\n  }>;\n\n  return rows;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CLEANUP FUNCTIONS\n----------------------------------------------------------------*/\n\n/**\n * Finds memory records that are candidates for cleanup.\n * @param options - Cleanup thresholds and limits.\n * @returns The cleanup candidate details.\n */\nexport function find_cleanup_candidates(options: CleanupOptions = {}): Array<{ id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; reasons: string[] }> {\n  const database = initialize_db();\n\n  const {\n    maxAgeDays = 90,\n    maxAccessCount = 2,\n    maxConfidence = 0.4,\n    limit = 50\n  } = options;\n\n  const cutoff_date = new Date();\n  cutoff_date.setDate(cutoff_date.getDate() - maxAgeDays);\n  const cutoff_iso = cutoff_date.toISOString();\n\n  const sql = `\n    SELECT\n      id,\n      spec_folder,\n      file_path,\n      title,\n      created_at,\n      last_accessed,\n      access_count,\n      confidence,\n      importance_weight\n    FROM memory_index\n    WHERE\n      created_at < ?\n      OR access_count <= ?\n      OR confidence <= ?\n      OR (last_accessed IS NULL AND created_at < ?)\n    ORDER BY\n      last_accessed ASC NULLS FIRST,\n      access_count ASC,\n      confidence ASC\n    LIMIT ?\n  `;\n\n  let rows;\n  try {\n    rows = database.prepare(sql).all(\n      cutoff_iso,\n      maxAccessCount,\n      maxConfidence,\n      cutoff_iso,\n      limit\n    );\n  } catch (e: unknown) {\n    console.warn(`[vector-index] find_cleanup_candidates error: ${get_error_message(e)}`);\n    return [];\n  }\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    const age_string = format_age_string(row.created_at ?? null);\n    const last_access_string = format_age_string(\n      typeof row.last_accessed === 'number' ? new Date(row.last_accessed).toISOString() : null\n    );\n\n    const reasons: string[] = [];\n    if (row.created_at && new Date(row.created_at) < cutoff_date) {\n      reasons.push(`created ${age_string}`);\n    }\n    if ((row.access_count || 0) <= maxAccessCount) {\n      const count = row.access_count || 0;\n      reasons.push(`accessed ${count} time${count !== 1 ? 's' : ''}`);\n    }\n    if ((row.confidence || 0.5) <= maxConfidence) {\n      reasons.push(`low importance (${Math.round((row.confidence || 0.5) * 100)}%)`);\n    }\n\n    return {\n      id: row.id,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      title: row.title || 'Untitled',\n      createdAt: row.created_at,\n      lastAccessedAt: row.last_accessed,\n      accessCount: row.access_count || 0,\n      confidence: row.confidence || 0.5,\n      ageString: age_string,\n      lastAccessString: last_access_string,\n      reasons\n    };\n  });\n}\n\n/**\n * Builds a preview payload for a stored memory.\n * @param memory_id - The memory identifier.\n * @param max_lines - The maximum number of file lines to include.\n * @returns The memory preview, if found.\n */\nexport function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n  const database = initialize_db();\n\n  let memory: MemoryRow | undefined;\n  try {\n    memory = database.prepare(`\n      SELECT * FROM memory_index WHERE id = ?\n    `).get(memory_id) as MemoryRow | undefined;\n  } catch (e: unknown) {\n    console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n    return null;\n  }\n\n  if (!memory) return null;\n\n  let content = '';\n  try {\n    // Validate DB-stored file paths before reading\n    if (memory.file_path) {\n      const valid_path = validate_file_path_local(memory.file_path);\n      if (valid_path && fs.existsSync(valid_path)) {\n        const full_content = fs.readFileSync(valid_path, 'utf-8');\n        const lines = full_content.split('\\n');\n        content = lines.slice(0, max_lines).join('\\n');\n        if (lines.length > max_lines) {\n          content += `\\n... (${lines.length - max_lines} more lines)`;\n        }\n      }\n    }\n  } catch (e: unknown) {\n    console.warn('[vector-index] get_memory_preview file read warning', {\n      operation: 'get_memory_preview',\n      memoryId: memory_id,\n      filePath: memory.file_path ?? null,\n      error: get_error_message(e),\n    });\n    content = '(Unable to read file content)';\n  }\n\n  return {\n    id: memory.id,\n    specFolder: memory.spec_folder,\n    filePath: memory.file_path,\n    title: memory.title || 'Untitled',\n    createdAt: memory.created_at,\n    lastAccessedAt: memory.last_accessed,\n    accessCount: memory.access_count || 0,\n    confidence: memory.confidence || 0.5,","lineStart":1,"lineEnd":1495,"totalLines":1496,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781151292394,"end":1781151292401}},"metadata":{"openai":{"itemId":"fc_04e44631d543a090016a2a363c50a08191ac89d13dc64f96df"}},"id":"prt_eb4e3dbe2001sd4PgAh4y7pEE5","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ba82001ebIrUU1GfimBXY"}}
{"type":"tool_use","timestamp":1781151292430,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_blEfoTCqCl13YrYBU5IGYZTx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retrieval Observability\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type Database from 'better-sqlite3';\n6: \n7: type MaintenanceTool = 'memory_index_scan' | 'memory_embedding_reconcile' | 'memory_retention_sweep';\n8: \n9: export interface DocumentAnchorKey {\n10:   path: string;\n11:   anchor: string | null;\n12: }\n13: \n14: export interface WhyRankedTrace {\n15:   document: DocumentAnchorKey;\n16:   rank: number;\n17:   effectiveScore: number | null;\n18:   scoreSource: string;\n19:   channels: Record<'vector' | 'bm25' | 'fts' | 'graph' | 'trigger', number | null>;\n20:   signals: Record<'fsrs' | 'importance' | 'recency', number | null>;\n21:   source: 'ranker_intermediates';\n22: }\n23: \n24: export interface RetrievalConflictWarning {\n25:   type: 'verify_before_applying';\n26:   relation: 'contradicts' | 'supersedes';\n27:   documents: [DocumentAnchorKey, DocumentAnchorKey];\n28:   message: string;\n29: }\n30: \n31: export interface VectorDegradationSignal {\n32:   degraded: boolean;\n33:   vectorSearchAvailable: boolean;\n34:   mode: 'hybrid' | 'lexical_only';\n35:   reason: string | null;\n36:   degradedVector?: DegradedVectorHealthSnapshot;\n37: }\n38: \n39: export type DegradedVectorRepairState = 'healthy' | 'detected' | 'quarantined' | 'rebuilding' | 'rebuild_failed';\n40: \n41: export interface DegradedVectorHealthSnapshot {\n42:   state: DegradedVectorRepairState;\n43:   degraded: boolean;\n44:   detections: number;\n45:   quarantines: number;\n46:   rebuildsStarted: number;\n47:   rebuildsCompleted: number;\n48:   rebuildsFailed: number;\n49:   lastEventAt: string | null;\n50:   lastReason: string | null;\n51:   lastShard: string | null;\n52:   lastQuarantine: string | null;\n53:   activeJobId: string | null;\n54: }\n55: \n56: export interface MaintenanceRunCounters {\n57:   tool: MaintenanceTool;\n58:   lastRunAt: string | null;\n59:   lastStatus: 'success' | 'error' | 'coalesced' | null;\n60:   counts: Record<string, number>;\n61:   staleCandidates: number;\n62: }\n63: \n64: const CHANNEL_KEYS = ['vector', 'bm25', 'fts', 'graph', 'trigger'] as const;\n65: \n66: const maintenanceRuns: Record<MaintenanceTool, MaintenanceRunCounters> = {\n67:   memory_index_scan: emptyMaintenanceRun('memory_index_scan'),\n68:   memory_embedding_reconcile: emptyMaintenanceRun('memory_embedding_reconcile'),\n69:   memory_retention_sweep: emptyMaintenanceRun('memory_retention_sweep'),\n70: };\n71: \n72: const degradedVectorHealth: DegradedVectorHealthSnapshot = {\n73:   state: 'healthy',\n74:   degraded: false,\n75:   detections: 0,\n76:   quarantines: 0,\n77:   rebuildsStarted: 0,\n78:   rebuildsCompleted: 0,\n79:   rebuildsFailed: 0,\n80:   lastEventAt: null,\n81:   lastReason: null,\n82:   lastShard: null,\n83:   lastQuarantine: null,\n84:   activeJobId: null,\n85: };\n86: \n87: function emptyMaintenanceRun(tool: MaintenanceTool): MaintenanceRunCounters {\n88:   return {\n89:     tool,\n90:     lastRunAt: null,\n91:     lastStatus: null,\n92:     counts: {},\n93:     staleCandidates: 0,\n94:   };\n95: }\n96: \n97: function finiteNumber(value: unknown): number | null {\n98:   if (typeof value === 'number' && Number.isFinite(value)) return value;\n99:   if (typeof value === 'string' && value.trim().length > 0) {\n100:     const parsed = Number(value);\n101:     if (Number.isFinite(parsed)) return parsed;\n102:   }\n103:   return null;\n104: }\n105: \n106: function scoreMap(value: unknown): Record<string, number> {\n107:   if (!value || typeof value !== 'object' || Array.isArray(value)) return {};\n108:   const output: Record<string, number> = {};\n109:   for (const [key, raw] of Object.entries(value as Record<string, unknown>)) {\n110:     const score = finiteNumber(raw);\n111:     if (score !== null) output[key] = score;\n112:   }\n113:   return output;\n114: }\n115: \n116: function basenameOrNull(value: string | null | undefined): string | null {\n117:   if (!value) return null;\n118:   const normalized = value.replace(/\\\\/g, '/');\n119:   return normalized.slice(normalized.lastIndexOf('/') + 1);\n120: }\n121: \n122: function updateDegradedVectorHealth(update: Partial<DegradedVectorHealthSnapshot>): void {\n123:   Object.assign(degradedVectorHealth, update, {\n124:     degraded: update.state ? update.state !== 'healthy' : degradedVectorHealth.state !== 'healthy',\n125:     lastEventAt: new Date().toISOString(),\n126:   });\n127: }\n128: \n129: function channelScore(rawResult: Record<string, unknown>, channel: typeof CHANNEL_KEYS[number]): number | null {\n130:   const scores = scoreMap(rawResult.sourceScores);\n131:   if (scores[channel] !== undefined) return scores[channel];\n132:   if (channel === 'fts') return finiteNumber(rawResult.fts_score);\n133:   if (channel === 'bm25') return finiteNumber(rawResult.bm25_score);\n134:   if (channel === 'trigger') return finiteNumber(rawResult.triggerScore);\n135:   if (channel === 'graph') {\n136:     const contribution = rawResult.graphContribution;\n137:     if (contribution && typeof contribution === 'object' && !Array.isArray(contribution)) {\n138:       const total = finiteNumber((contribution as Record<string, unknown>).totalDelta);\n139:       if (total !== null) return total;\n140:     }\n141:   }\n142:   if (channel === 'vector') {\n143:     const similarity = finiteNumber(rawResult.similarity ?? rawResult.averageSimilarity);\n144:     return similarity !== null ? similarity / 100 : null;\n145:   }\n146:   return null;\n147: }\n148: \n149: function resolveEffectiveScore(rawResult: Record<string, unknown>): { score: number | null; source: string } {\n150:   for (const [field, source] of [\n151:     ['intentAdjustedScore', 'intentAdjusted'],\n152:     ['rrfScore', 'fusion'],\n153:     ['stage2Score', 'stage2'],\n154:     ['score', 'score'],\n155:     ['similarity', 'semantic'],\n156:     ['averageSimilarity', 'semantic'],\n157:   ] as const) {\n158:     const score = finiteNumber(rawResult[field]);\n159:     if (score !== null) {\n160:       return { score: field === 'similarity' || field === 'averageSimilarity' ? score / 100 : score, source };\n161:     }\n162:   }\n163:   return { score: null, source: 'none' };\n164: }\n165: \n166: export function resolveDocumentAnchor(rawResult: Record<string, unknown>): DocumentAnchorKey {\n167:   const filePath = rawResult.file_path ?? rawResult.filePath;\n168:   const anchor = rawResult.anchor_id ?? rawResult.anchorId;\n169:   return {\n170:     path: typeof filePath === 'string' ? filePath : '',\n171:     anchor: typeof anchor === 'string' && anchor.trim().length > 0 ? anchor.trim() : null,\n172:   };\n173: }\n174: \n175: export function buildWhyRankedTrace(rawResult: Record<string, unknown>, rank: number): WhyRankedTrace {\n176:   const effective = resolveEffectiveScore(rawResult);\n177:   return {\n178:     document: resolveDocumentAnchor(rawResult),\n179:     rank,\n180:     effectiveScore: effective.score,\n181:     scoreSource: effective.source,\n182:     channels: {\n183:       vector: channelScore(rawResult, 'vector'),\n184:       bm25: channelScore(rawResult, 'bm25'),\n185:       fts: channelScore(rawResult, 'fts'),\n186:       graph: channelScore(rawResult, 'graph'),\n187:       trigger: channelScore(rawResult, 'trigger'),\n188:     },\n189:     signals: {\n190:       fsrs: finiteNumber(rawResult.attentionScore ?? rawResult.retrievability ?? rawResult.stability),\n191:       importance: finiteNumber(rawResult.importance_weight),\n192:       recency: finiteNumber(rawResult.recencyScore ?? rawResult.recency_score),\n193:     },\n194:     source: 'ranker_intermediates',\n195:   };\n196: }\n197: \n198: export function buildVectorDegradationSignal(\n199:   vectorSearchAvailable: boolean,\n200:   degradedVector = getDegradedVectorObservabilitySnapshot(),\n201: ): VectorDegradationSignal {\n202:   const degraded = !vectorSearchAvailable || degradedVector.degraded;\n203:   return {\n204:     degraded,\n205:     vectorSearchAvailable,\n206:     mode: vectorSearchAvailable ? 'hybrid' : 'lexical_only',\n207:     reason: !vectorSearchAvailable\n208:       ? 'vector_search_unavailable'\n209:       : degradedVector.degraded\n210:         ? `vector_shard_${degradedVector.state}`\n211:         : null,\n212:     degradedVector,\n213:   };\n214: }\n215: \n216: export function recordVectorShardProbeFailure(input: { shardPath: string; reason: string }): void {\n217:   degradedVectorHealth.detections += 1;\n218:   updateDegradedVectorHealth({\n219:     state: 'detected',\n220:     lastReason: input.reason,\n221:     lastShard: basenameOrNull(input.shardPath),\n222:   });\n223: }\n224: \n225: export function recordVectorShardQuarantined(input: { shardPath: string; quarantinePath: string; reason: string }): void {\n226:   degradedVectorHealth.quarantines += 1;\n227:   updateDegradedVectorHealth({\n228:     state: 'quarantined',\n229:     lastReason: input.reason,\n230:     lastShard: basenameOrNull(input.shardPath),\n231:     lastQuarantine: basenameOrNull(input.quarantinePath),\n232:   });\n233: }\n234: \n235: export function recordVectorShardRebuildStarted(input: { jobId: string; shardPath: string; reason: string }): void {\n236:   degradedVectorHealth.rebuildsStarted += 1;\n237:   updateDegradedVectorHealth({\n238:     state: 'rebuilding',\n239:     activeJobId: input.jobId,\n240:     lastReason: input.reason,\n241:     lastShard: basenameOrNull(input.shardPath),\n242:   });\n243: }\n244: \n245: export function recordVectorShardRebuildCompleted(input: { jobId: string; shardPath: string }): void {\n246:   degradedVectorHealth.rebuildsCompleted += 1;\n247:   updateDegradedVectorHealth({\n248:     state: 'healthy',\n249:     activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n250:     lastReason: null,\n251:     lastShard: basenameOrNull(input.shardPath),\n252:   });\n253: }\n254: \n255: export function recordVectorShardRebuildFailed(input: { jobId: string; shardPath: string; reason: string }): void {\n256:   degradedVectorHealth.rebuildsFailed += 1;\n257:   updateDegradedVectorHealth({\n258:     state: 'rebuild_failed',\n259:     activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n260:     lastReason: input.reason,\n261:     lastShard: basenameOrNull(input.shardPath),\n262:   });\n263: }\n264: \n265: export function getDegradedVectorObservabilitySnapshot(): DegradedVectorHealthSnapshot {\n266:   return { ...degradedVectorHealth };\n267: }\n268: \n269: export function resetDegradedVectorObservabilityForTest(): void {\n270:   Object.assign(degradedVectorHealth, {\n271:     state: 'healthy',\n272:     degraded: false,\n273:     detections: 0,\n274:     quarantines: 0,\n275:     rebuildsStarted: 0,\n276:     rebuildsCompleted: 0,\n277:     rebuildsFailed: 0,\n278:     lastEventAt: null,\n279:     lastReason: null,\n280:     lastShard: null,\n281:     lastQuarantine: null,\n282:     activeJobId: null,\n283:   });\n284: }\n285: \n286: export function recordMaintenanceRun(\n287:   tool: MaintenanceTool,\n288:   input: { status: MaintenanceRunCounters['lastStatus']; counts?: Record<string, unknown>; staleCandidates?: number },\n289: ): void {\n290:   const counts: Record<string, number> = {};\n291:   for (const [key, value] of Object.entries(input.counts ?? {})) {\n292:     const count = finiteNumber(value);\n293:     if (count !== null) counts[key] = count;\n294:   }\n295:   maintenanceRuns[tool] = {\n296:     tool,\n297:     lastRunAt: new Date().toISOString(),\n298:     lastStatus: input.status,\n299:     counts,\n300:     staleCandidates: Math.max(0, Math.floor(input.staleCandidates ?? 0)),\n301:   };\n302: }\n303: \n304: export function getMaintenanceObservabilitySnapshot(): Record<MaintenanceTool, MaintenanceRunCounters> {\n305:   return {\n306:     memory_index_scan: { ...maintenanceRuns.memory_index_scan, counts: { ...maintenanceRuns.memory_index_scan.counts } },\n307:     memory_embedding_reconcile: { ...maintenanceRuns.memory_embedding_reconcile, counts: { ...maintenanceRuns.memory_embedding_reconcile.counts } },\n308:     memory_retention_sweep: { ...maintenanceRuns.memory_retention_sweep, counts: { ...maintenanceRuns.memory_retention_sweep.counts } },\n309:   };\n310: }\n311: \n312: export function findInlineConflictWarnings(\n313:   results: Array<Record<string, unknown>>,\n314:   dbGetter: () => Database.Database,\n315: ): RetrievalConflictWarning[] {\n316:   const byId = new Map<string, Record<string, unknown>>();\n317:   for (const result of results) {\n318:     const id = result.id;\n319:     if (typeof id === 'number' || typeof id === 'string') byId.set(String(id), result);\n320:   }\n321:   if (byId.size < 2) return [];\n322: \n323:   let database: Database.Database;\n324:   try {\n325:     database = dbGetter();\n326:   } catch {\n327:     return [];\n328:   }\n329: \n330:   try {\n331:     const ids = Array.from(byId.keys());\n332:     const placeholders = ids.map(() => '?').join(',');\n333:     const rows = database.prepare(`\n334:       SELECT source_id, target_id, relation\n335:       FROM causal_edges\n336:       WHERE relation IN ('contradicts', 'supersedes')\n337:         AND source_id IN (${placeholders})\n338:         AND target_id IN (${placeholders})\n339:     `).all(...ids, ...ids) as Array<{ source_id: string; target_id: string; relation: 'contradicts' | 'supersedes' }>;\n340: \n341:     const warnings: RetrievalConflictWarning[] = [];\n342:     const seen = new Set<string>();\n343:     for (const row of rows) {\n344:       const source = byId.get(String(row.source_id));\n345:       const target = byId.get(String(row.target_id));\n346:       if (!source || !target) continue;\n347:       const key = [row.relation, row.source_id, row.target_id].join(':');\n348:       if (seen.has(key)) continue;\n349:       seen.add(key);\n350:       const documents: [DocumentAnchorKey, DocumentAnchorKey] = [\n351:         resolveDocumentAnchor(source),\n352:         resolveDocumentAnchor(target),\n353:       ];\n354:       warnings.push({\n355:         type: 'verify_before_applying',\n356:         relation: row.relation,\n357:         documents,\n358:         message: `Returned memories are linked by ${row.relation}; verify before applying either document.`,\n359:       });\n360:     }\n361:     return warnings;\n362:   } catch {\n363:     return [];\n364:   }\n365: }\n366: \n367: export const __testables = {\n368:   buildWhyRankedTrace,\n369:   buildVectorDegradationSignal,\n370:   findInlineConflictWarnings,\n371:   getDegradedVectorObservabilitySnapshot,\n372:   getMaintenanceObservabilitySnapshot,\n373:   recordMaintenanceRun,\n374:   resetDegradedVectorObservabilityForTest,\n375: };\n\n(End of file - total 375 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retrieval Observability\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype MaintenanceTool = 'memory_index_scan' | 'memory_embedding_reconcile' | 'memory_retention_sweep';\n\nexport interface DocumentAnchorKey {\n  path: string;\n  anchor: string | null;\n}\n\nexport interface WhyRankedTrace {\n  document: DocumentAnchorKey;\n  rank: number;\n  effectiveScore: number | null;\n  scoreSource: string;\n  channels: Record<'vector' | 'bm25' | 'fts' | 'graph' | 'trigger', number | null>;\n  signals: Record<'fsrs' | 'importance' | 'recency', number | null>;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retrieval Observability\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\n\ntype MaintenanceTool = 'memory_index_scan' | 'memory_embedding_reconcile' | 'memory_retention_sweep';\n\nexport interface DocumentAnchorKey {\n  path: string;\n  anchor: string | null;\n}\n\nexport interface WhyRankedTrace {\n  document: DocumentAnchorKey;\n  rank: number;\n  effectiveScore: number | null;\n  scoreSource: string;\n  channels: Record<'vector' | 'bm25' | 'fts' | 'graph' | 'trigger', number | null>;\n  signals: Record<'fsrs' | 'importance' | 'recency', number | null>;\n  source: 'ranker_intermediates';\n}\n\nexport interface RetrievalConflictWarning {\n  type: 'verify_before_applying';\n  relation: 'contradicts' | 'supersedes';\n  documents: [DocumentAnchorKey, DocumentAnchorKey];\n  message: string;\n}\n\nexport interface VectorDegradationSignal {\n  degraded: boolean;\n  vectorSearchAvailable: boolean;\n  mode: 'hybrid' | 'lexical_only';\n  reason: string | null;\n  degradedVector?: DegradedVectorHealthSnapshot;\n}\n\nexport type DegradedVectorRepairState = 'healthy' | 'detected' | 'quarantined' | 'rebuilding' | 'rebuild_failed';\n\nexport interface DegradedVectorHealthSnapshot {\n  state: DegradedVectorRepairState;\n  degraded: boolean;\n  detections: number;\n  quarantines: number;\n  rebuildsStarted: number;\n  rebuildsCompleted: number;\n  rebuildsFailed: number;\n  lastEventAt: string | null;\n  lastReason: string | null;\n  lastShard: string | null;\n  lastQuarantine: string | null;\n  activeJobId: string | null;\n}\n\nexport interface MaintenanceRunCounters {\n  tool: MaintenanceTool;\n  lastRunAt: string | null;\n  lastStatus: 'success' | 'error' | 'coalesced' | null;\n  counts: Record<string, number>;\n  staleCandidates: number;\n}\n\nconst CHANNEL_KEYS = ['vector', 'bm25', 'fts', 'graph', 'trigger'] as const;\n\nconst maintenanceRuns: Record<MaintenanceTool, MaintenanceRunCounters> = {\n  memory_index_scan: emptyMaintenanceRun('memory_index_scan'),\n  memory_embedding_reconcile: emptyMaintenanceRun('memory_embedding_reconcile'),\n  memory_retention_sweep: emptyMaintenanceRun('memory_retention_sweep'),\n};\n\nconst degradedVectorHealth: DegradedVectorHealthSnapshot = {\n  state: 'healthy',\n  degraded: false,\n  detections: 0,\n  quarantines: 0,\n  rebuildsStarted: 0,\n  rebuildsCompleted: 0,\n  rebuildsFailed: 0,\n  lastEventAt: null,\n  lastReason: null,\n  lastShard: null,\n  lastQuarantine: null,\n  activeJobId: null,\n};\n\nfunction emptyMaintenanceRun(tool: MaintenanceTool): MaintenanceRunCounters {\n  return {\n    tool,\n    lastRunAt: null,\n    lastStatus: null,\n    counts: {},\n    staleCandidates: 0,\n  };\n}\n\nfunction finiteNumber(value: unknown): number | null {\n  if (typeof value === 'number' && Number.isFinite(value)) return value;\n  if (typeof value === 'string' && value.trim().length > 0) {\n    const parsed = Number(value);\n    if (Number.isFinite(parsed)) return parsed;\n  }\n  return null;\n}\n\nfunction scoreMap(value: unknown): Record<string, number> {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};\n  const output: Record<string, number> = {};\n  for (const [key, raw] of Object.entries(value as Record<string, unknown>)) {\n    const score = finiteNumber(raw);\n    if (score !== null) output[key] = score;\n  }\n  return output;\n}\n\nfunction basenameOrNull(value: string | null | undefined): string | null {\n  if (!value) return null;\n  const normalized = value.replace(/\\\\/g, '/');\n  return normalized.slice(normalized.lastIndexOf('/') + 1);\n}\n\nfunction updateDegradedVectorHealth(update: Partial<DegradedVectorHealthSnapshot>): void {\n  Object.assign(degradedVectorHealth, update, {\n    degraded: update.state ? update.state !== 'healthy' : degradedVectorHealth.state !== 'healthy',\n    lastEventAt: new Date().toISOString(),\n  });\n}\n\nfunction channelScore(rawResult: Record<string, unknown>, channel: typeof CHANNEL_KEYS[number]): number | null {\n  const scores = scoreMap(rawResult.sourceScores);\n  if (scores[channel] !== undefined) return scores[channel];\n  if (channel === 'fts') return finiteNumber(rawResult.fts_score);\n  if (channel === 'bm25') return finiteNumber(rawResult.bm25_score);\n  if (channel === 'trigger') return finiteNumber(rawResult.triggerScore);\n  if (channel === 'graph') {\n    const contribution = rawResult.graphContribution;\n    if (contribution && typeof contribution === 'object' && !Array.isArray(contribution)) {\n      const total = finiteNumber((contribution as Record<string, unknown>).totalDelta);\n      if (total !== null) return total;\n    }\n  }\n  if (channel === 'vector') {\n    const similarity = finiteNumber(rawResult.similarity ?? rawResult.averageSimilarity);\n    return similarity !== null ? similarity / 100 : null;\n  }\n  return null;\n}\n\nfunction resolveEffectiveScore(rawResult: Record<string, unknown>): { score: number | null; source: string } {\n  for (const [field, source] of [\n    ['intentAdjustedScore', 'intentAdjusted'],\n    ['rrfScore', 'fusion'],\n    ['stage2Score', 'stage2'],\n    ['score', 'score'],\n    ['similarity', 'semantic'],\n    ['averageSimilarity', 'semantic'],\n  ] as const) {\n    const score = finiteNumber(rawResult[field]);\n    if (score !== null) {\n      return { score: field === 'similarity' || field === 'averageSimilarity' ? score / 100 : score, source };\n    }\n  }\n  return { score: null, source: 'none' };\n}\n\nexport function resolveDocumentAnchor(rawResult: Record<string, unknown>): DocumentAnchorKey {\n  const filePath = rawResult.file_path ?? rawResult.filePath;\n  const anchor = rawResult.anchor_id ?? rawResult.anchorId;\n  return {\n    path: typeof filePath === 'string' ? filePath : '',\n    anchor: typeof anchor === 'string' && anchor.trim().length > 0 ? anchor.trim() : null,\n  };\n}\n\nexport function buildWhyRankedTrace(rawResult: Record<string, unknown>, rank: number): WhyRankedTrace {\n  const effective = resolveEffectiveScore(rawResult);\n  return {\n    document: resolveDocumentAnchor(rawResult),\n    rank,\n    effectiveScore: effective.score,\n    scoreSource: effective.source,\n    channels: {\n      vector: channelScore(rawResult, 'vector'),\n      bm25: channelScore(rawResult, 'bm25'),\n      fts: channelScore(rawResult, 'fts'),\n      graph: channelScore(rawResult, 'graph'),\n      trigger: channelScore(rawResult, 'trigger'),\n    },\n    signals: {\n      fsrs: finiteNumber(rawResult.attentionScore ?? rawResult.retrievability ?? rawResult.stability),\n      importance: finiteNumber(rawResult.importance_weight),\n      recency: finiteNumber(rawResult.recencyScore ?? rawResult.recency_score),\n    },\n    source: 'ranker_intermediates',\n  };\n}\n\nexport function buildVectorDegradationSignal(\n  vectorSearchAvailable: boolean,\n  degradedVector = getDegradedVectorObservabilitySnapshot(),\n): VectorDegradationSignal {\n  const degraded = !vectorSearchAvailable || degradedVector.degraded;\n  return {\n    degraded,\n    vectorSearchAvailable,\n    mode: vectorSearchAvailable ? 'hybrid' : 'lexical_only',\n    reason: !vectorSearchAvailable\n      ? 'vector_search_unavailable'\n      : degradedVector.degraded\n        ? `vector_shard_${degradedVector.state}`\n        : null,\n    degradedVector,\n  };\n}\n\nexport function recordVectorShardProbeFailure(input: { shardPath: string; reason: string }): void {\n  degradedVectorHealth.detections += 1;\n  updateDegradedVectorHealth({\n    state: 'detected',\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function recordVectorShardQuarantined(input: { shardPath: string; quarantinePath: string; reason: string }): void {\n  degradedVectorHealth.quarantines += 1;\n  updateDegradedVectorHealth({\n    state: 'quarantined',\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n    lastQuarantine: basenameOrNull(input.quarantinePath),\n  });\n}\n\nexport function recordVectorShardRebuildStarted(input: { jobId: string; shardPath: string; reason: string }): void {\n  degradedVectorHealth.rebuildsStarted += 1;\n  updateDegradedVectorHealth({\n    state: 'rebuilding',\n    activeJobId: input.jobId,\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function recordVectorShardRebuildCompleted(input: { jobId: string; shardPath: string }): void {\n  degradedVectorHealth.rebuildsCompleted += 1;\n  updateDegradedVectorHealth({\n    state: 'healthy',\n    activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n    lastReason: null,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function recordVectorShardRebuildFailed(input: { jobId: string; shardPath: string; reason: string }): void {\n  degradedVectorHealth.rebuildsFailed += 1;\n  updateDegradedVectorHealth({\n    state: 'rebuild_failed',\n    activeJobId: degradedVectorHealth.activeJobId === input.jobId ? null : degradedVectorHealth.activeJobId,\n    lastReason: input.reason,\n    lastShard: basenameOrNull(input.shardPath),\n  });\n}\n\nexport function getDegradedVectorObservabilitySnapshot(): DegradedVectorHealthSnapshot {\n  return { ...degradedVectorHealth };\n}\n\nexport function resetDegradedVectorObservabilityForTest(): void {\n  Object.assign(degradedVectorHealth, {\n    state: 'healthy',\n    degraded: false,\n    detections: 0,\n    quarantines: 0,\n    rebuildsStarted: 0,\n    rebuildsCompleted: 0,\n    rebuildsFailed: 0,\n    lastEventAt: null,\n    lastReason: null,\n    lastShard: null,\n    lastQuarantine: null,\n    activeJobId: null,\n  });\n}\n\nexport function recordMaintenanceRun(\n  tool: MaintenanceTool,\n  input: { status: MaintenanceRunCounters['lastStatus']; counts?: Record<string, unknown>; staleCandidates?: number },\n): void {\n  const counts: Record<string, number> = {};\n  for (const [key, value] of Object.entries(input.counts ?? {})) {\n    const count = finiteNumber(value);\n    if (count !== null) counts[key] = count;\n  }\n  maintenanceRuns[tool] = {\n    tool,\n    lastRunAt: new Date().toISOString(),\n    lastStatus: input.status,\n    counts,\n    staleCandidates: Math.max(0, Math.floor(input.staleCandidates ?? 0)),\n  };\n}\n\nexport function getMaintenanceObservabilitySnapshot(): Record<MaintenanceTool, MaintenanceRunCounters> {\n  return {\n    memory_index_scan: { ...maintenanceRuns.memory_index_scan, counts: { ...maintenanceRuns.memory_index_scan.counts } },\n    memory_embedding_reconcile: { ...maintenanceRuns.memory_embedding_reconcile, counts: { ...maintenanceRuns.memory_embedding_reconcile.counts } },\n    memory_retention_sweep: { ...maintenanceRuns.memory_retention_sweep, counts: { ...maintenanceRuns.memory_retention_sweep.counts } },\n  };\n}\n\nexport function findInlineConflictWarnings(\n  results: Array<Record<string, unknown>>,\n  dbGetter: () => Database.Database,\n): RetrievalConflictWarning[] {\n  const byId = new Map<string, Record<string, unknown>>();\n  for (const result of results) {\n    const id = result.id;\n    if (typeof id === 'number' || typeof id === 'string') byId.set(String(id), result);\n  }\n  if (byId.size < 2) return [];\n\n  let database: Database.Database;\n  try {\n    database = dbGetter();\n  } catch {\n    return [];\n  }\n\n  try {\n    const ids = Array.from(byId.keys());\n    const placeholders = ids.map(() => '?').join(',');\n    const rows = database.prepare(`\n      SELECT source_id, target_id, relation\n      FROM causal_edges\n      WHERE relation IN ('contradicts', 'supersedes')\n        AND source_id IN (${placeholders})\n        AND target_id IN (${placeholders})\n    `).all(...ids, ...ids) as Array<{ source_id: string; target_id: string; relation: 'contradicts' | 'supersedes' }>;\n\n    const warnings: RetrievalConflictWarning[] = [];\n    const seen = new Set<string>();\n    for (const row of rows) {\n      const source = byId.get(String(row.source_id));\n      const target = byId.get(String(row.target_id));\n      if (!source || !target) continue;\n      const key = [row.relation, row.source_id, row.target_id].join(':');\n      if (seen.has(key)) continue;\n      seen.add(key);\n      const documents: [DocumentAnchorKey, DocumentAnchorKey] = [\n        resolveDocumentAnchor(source),\n        resolveDocumentAnchor(target),\n      ];\n      warnings.push({\n        type: 'verify_before_applying',\n        relation: row.relation,\n        documents,\n        message: `Returned memories are linked by ${row.relation}; verify before applying either document.`,\n      });\n    }\n    return warnings;\n  } catch {\n    return [];\n  }\n}\n\nexport const __testables = {\n  buildWhyRankedTrace,\n  buildVectorDegradationSignal,\n  findInlineConflictWarnings,\n  getDegradedVectorObservabilitySnapshot,\n  getMaintenanceObservabilitySnapshot,\n  recordMaintenanceRun,\n  resetDegradedVectorObservabilityForTest,\n};","lineStart":1,"lineEnd":375,"totalLines":375,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/observability/retrieval-observability.ts","time":{"start":1781151292426,"end":1781151292429}},"metadata":{"openai":{"itemId":"fc_04e44631d543a090016a2a363c50a48191b3d84dfb31c47744"}},"id":"prt_eb4e3dc020010CKhKLRyC7eqLl","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ba82001ebIrUU1GfimBXY"}}
