"file\": \".opencode/specs/sk-design/012-style-database-and-interface-commands/006-retire-design-alias-namespace/graph-metadata.json\",\n      \"line\": 42,\n      \"summary\": \"graph-metadata.json status='planned' and key_files lists the deleted commands/design/ tree.\"\n    },\n    {\n      \"id\": \"F6\",\n      \"severity\": \"P1\",\n      \"category\": \"traceability/doc-consistency\",\n      \"file\": \".opencode/skills/sk-design/feature-catalog/creation-command-surface/interface-creation-commands.md\",\n      \"line\": 3,\n      \"summary\": \"Four files still claim /design:* aliases 'remain' and reference the deleted commands/design/ tree.\"\n    }\n  ],\n  \"resolvedFindings\": [],\n  \"repeatedFindings\": [],\n  \"dimensionCoverage\": {\n    \"correctness\": true,\n    \"security\": false,\n    \"traceability\": true,\n    \"maintainability\": false\n  },\n  \"findingsBySeverity\": {\n    \"P0\": 0,\n    \"P1\": 4,\n    \"P2\": 2\n  },\n  \"openFindingsCount\": 6,\n  \"resolvedFindingsCount\": 0,\n  \"convergenceScore\": 0.55\n}","filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/specs/sk-design/016-session-shipped-work-review/review/lineages/minimax-m3-high/deep-review-findings-registry.json"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/specs/sk-design/016-session-shipped-work-review/review/lineages/minimax-m3-high/deep-review-findings-registry.json","exists":true,"truncated":false},"title":".opencode/specs/sk-design/016-session-shipped-work-review/review/lineages/minimax-m3-high/deep-review-findings-registry.json","time":{"start":1784606896649,"end":1784606896663}},"id":"prt_f82dc32030012tml7dnPiRXMF2","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82db1dd0001S3CAE74jw2ymW4"}}
