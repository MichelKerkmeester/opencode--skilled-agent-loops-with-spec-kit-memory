{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "es2022",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@spec-kit/mcp-server/api": ["../mcp_server/api/index.ts"],
      "@spec-kit/shared/*": ["../shared/*"],
      "@spec-kit/mcp-server/*": ["../mcp_server/*"]
    }
  },
  "references": [
    { "path": "../shared" },
    { "path": "../mcp_server" }
  ],
  "include": [
    "*.ts",
    "config/**/*.ts",
    "core/**/*.ts",
    "evals/**/*.ts",
    "extractors/**/*.ts",
    "git-hooks/**/*.ts",
    "graph/**/*.ts",
    "lib/**/*.ts",
    "loaders/**/*.ts",
    "memory/**/*.ts",
    "observability/**/*.ts",
    "ops/**/*.ts",
    "renderers/**/*.ts",
    "spec/**/*.ts",
    "spec-folder/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "validation/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "tests/**/*.vitest.ts"]
}
