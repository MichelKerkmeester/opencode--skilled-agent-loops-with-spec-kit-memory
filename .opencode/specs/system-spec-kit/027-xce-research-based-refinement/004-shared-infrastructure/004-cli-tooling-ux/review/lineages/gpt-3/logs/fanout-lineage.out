oolResult?.isError ? 'error' : 'ok',\n728:           tool: toolName,\n729:           text: firstText,\n730:         },\n731:         isError: toolResult?.isError === true,\n732:       };\n733:     }\n734:   }\n735:   return {\n736:     payload: {\n737:       status: toolResult?.isError ? 'error' : 'ok',\n738:       tool: toolName,\n739:       result,\n740:     },\n741:     isError: toolResult?.isError === true,\n742:   };\n743: }\n744: \n745: function isRecord(value: unknown): value is Record<string, unknown> {\n746:   return typeof value === 'object' && value !== null && !Array.isArray(value);\n747: }\n748: \n749: function stringField(record: Record<string, unknown>, key: string): string | undefined {\n750:   const value = record[key];\n751:   return typeof value === 'string' && value.length > 0 ? value : undefined;\n752: }\n753: \n754: function inferRequiredAction(payload: Record<string, unknown>): string | undefined {\n755:   const data = isRecord(payload.data) ? payload.data : null;\n756:   const payloadFallback = isRecord(payload.fallbackDecision) ? payload.fallbackDecision : null;\n757:   const dataFallback = data && isRecord(data.fallbackDecision) ? data.fallbackDecision : null;\n758:   const readiness = data && isRecord(data.readiness) ? data.readiness : null;\n759:   const text = [\n760:     stringField(payload, 'message'),\n761:     stringField(payload, 'blockedReason'),\n762:     data ? stringField(data, 'blockReason') : undefined,\n763:     data ? stringField(data, 'reason') : undefined,\n764:     readiness ? stringField(readiness, 'action') : undefined,\n765:   ].filter((value): value is string => Boolean(value)).join(' ').toLowerCase();\n766: \n767:   return stringField(payload, 'requiredAction')\n768:     ?? (data ? stringField(data, 'requiredAction') : undefined)\n769:     ?? (payloadFallback ? stringField(payloadFallback, 'nextTool') : undefined)\n770:     ?? (dataFallback ? stringField(dataFallback, 'nextTool') : undefined)\n771:     ?? (text.includes('readiness_check_crashed') || text.includes('scan_failed') ? 'rg' : undefined)\n772:     ?? (text.includes('code_graph_scan') || text.includes('full_scan') || text.includes('selective_reindex') || text.includes('stale') || text.includes('empty') ? 'code_graph_scan' : undefined);\n773: }\n774: \n775: function normalizeBlockedPayload(toolName: string, payload: unknown): unknown {\n776:   if (!BLOCKABLE_READ_TOOLS.has(toolName) || !isRecord(payload) || payload.status !== 'blocked') {\n777:     return payload;\n778:   }\n779: \n780:   const requiredAction = inferRequiredAction(payload);\n781:   if (!requiredAction) return payload;\n782:   const data = isRecord(payload.data) ? payload.data : null;\n783: \n784:   return {\n785:     ...payload,\n786:     requiredAction,\n787:     data: data ? { ...data, requiredAction } : { requiredAction },\n788:   };\n789: }\n790: \n791: function renderBlockedText(payload: Record<string, unknown>): string {\n792:   const data = isRecord(payload.data) ? payload.data : null;\n793:   const reason = stringField(payload, 'message')\n794:     ?? stringField(payload, 'blockedReason')\n795:     ?? (data ? stringField(data, 'blockReason') : undefined)\n796:     ?? (data ? stringField(data, 'reason') : undefined)\n797:     ?? 'code graph read is blocked';\n798:   const requiredAction = inferRequiredAction(payload) ?? 'UNKNOWN';\n799:   return `blocked: ${reason}\\nrequiredAction: ${requiredAction}`;\n800: }\n801: \n802: function renderPayload(toolName: string, payload: unknown, format: OutputFormat): string {\n803:   const normalized = normalizeBlockedPayload(toolName, payload);\n804:   if (format === 'json' || format === 'jsonl') return renderJson(normalized, format);\n805:   if (isRecord(normalized) && normalized.status === 'blocked') {\n806:     return renderBlockedText(normalized);\n807:   }\n808:   if (isRecord(normalized)) {\n809:     if (typeof normalized.summary === 'string') return normalized.summary;\n810:     if (typeof normalized.error === 'string') return normalized.error;\n811:     if (typeof normalized.message === 'string') return normalized.message;\n812:   }\n813:   return typeof normalized === 'string' ? normalized : JSON.stringify(normalized, null, 2);\n814: }\n815: \n816: function isErrorPayload(payload: unknown): boolean {\n817:   return isRecord(payload) && payload.status === 'error';\n818: }\n819: \n820: function isParseErrorPayload(payload: unknown): boolean {\n821:   return isRecord(payload) && payload.status === 'parse_error';\n822: }\n823: \n824: function isProtocolMismatch(error: unknown): boolean {\n825:   if (error instanceof JsonRpcError && error.code === -32002) return true;\n826:   const message = error instanceof Error ? error.message : String(error);\n827:   return /protocol.*(mismatch|changed|version)/i.test(message);\n828: }\n829: \n830: function isRetryableError(error: unknown): boolean {\n831:   if (error instanceof CliRetryableError) return true;\n832:   if (error instanceof JsonRpcError && error.code === -32001) return true;\n833:   const message = error instanceof Error ? error.message : String(error);\n834:   return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry|cold start/i.test(message);\n835: }\n836: \n837: function exitCodeForError(error: unknown): number {\n838:   if (error instanceof CliUsageError) return EXIT_USAGE;\n839:   if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n840:   if (isRetryableError(error)) return EXIT_RETRYABLE;\n841:   if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n842:   return EXIT_RUNTIME;\n843: }\n844: \n845: function levenshteinDistance(left: string, right: string): number {\n846:   const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n847:   const current = new Array<number>(right.length + 1);\n848: \n849:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n850:     current[0] = leftIndex;\n851:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n852:       const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n853:       current[rightIndex] = Math.min(\n854:         current[rightIndex - 1] + 1,\n855:         previous[rightIndex] + 1,\n856:         previous[rightIndex - 1] + cost,\n857:       );\n858:     }\n859:     previous.splice(0, previous.length, ...current);\n860:   }\n861: \n862:   return previous[right.length];\n863: }\n864: \n865: function closestCommand(command: string): string | undefined {\n866:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n867:   targets.set('completion', 'completion');\n868:   for (const tool of toolDefinitions()) {\n869:     for (const alias of commandAliases(tool.name)) {\n870:       targets.set(alias, tool.name);\n871:     }\n872:   }\n873: \n874:   let best: { readonly command: string; readonly distance: number } | null = null;\n875:   for (const [alias, canonical] of targets) {\n876:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n877:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n878:       best = { command: canonical, distance };\n879:     }\n880:   }\n881: \n882:   if (!best) return undefined;\n883:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n884:   return best.distance <= threshold ? best.command : undefined;\n885: }\n886: \n887: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n888:   const match = message.match(/^Unknown command: (.+)$/);\n889:   if (!match) return null;\n890:   return {\n891:     hint: 'Try `list-tools` to see available commands.',\n892:     suggestion: closestCommand(match[1]),\n893:   };\n894: }\n895: \n896: function socketPathTooLong(socketPath: string): boolean {\n897:   if (socketPath.startsWith('tcp://')) return false;\n898:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n899: }\n900: \n901: function ensureSocketEnvironment(): void {\n902:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n903:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n904:   }\n905:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n906:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n907:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n908:   const stat = statSync(socketDir);\n909:   if ((stat.mode & 0o022) !== 0) {\n910:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n911:   }\n912: }\n913: \n914: function sleep(ms: number): Promise<void> {\n915:   return new Promise((resolve) => setTimeout(resolve, ms));\n916: }\n917: \n918: function spawnLauncher(paths: RepoPaths): void {\n919:   const child = spawn(process.execPath, [paths.launcherPath], {\n920:     cwd: paths.repoRoot,\n921:     env: process.env,\n922:     detached: true,\n923:     stdio: 'ignore',\n924:   });\n925:   child.unref();\n926: }\n927: \n928: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n929:   const deadline = Date.now() + timeoutMs;\n930:   let lastReason = 'not probed';\n931: \n932:   while (Date.now() <= deadline) {\n933:     const remaining = Math.max(1, deadline - Date.now());\n934:     const probe = await bridge.probeDaemon(socketPath, {\n935:       timeoutMs: Math.min(remaining, 5000),\n936:       deepProbe: true,\n937:     });\n938:     if (probe.status === 'alive') return;\n939:     lastReason = probe.reason ?? probe.status;\n940:     await sleep(100);\n941:   }\n942: \n943:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n944: }\n945: \n946: class JsonRpcSocketClient {\n947:   private nextId = 1;\n948:   private readonly decoder = new StringDecoder('utf8');\n949: \n950:   private constructor(\n951:     private readonly socket: net.Socket,\n952:   ) {}\n953: \n954:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n955:     return new Promise((resolve, reject) => {\n956:       let socket: net.Socket;\n957:       let settled = false;\n958:       const finish = (error?: Error): void => {\n959:         if (settled) return;\n960:         settled = true;\n961:         clearTimeout(timer);\n962:         socket.off?.('connect', onConnect);\n963:         socket.off?.('error', onError);\n964:         if (error) {\n965:           socket.destroy?.();\n966:           reject(error);\n967:           return;\n968:         }\n969:         resolve(new JsonRpcSocketClient(socket));\n970:       };\n971:       const onConnect = (): void => finish();\n972:       const onError = (error: Error): void => finish(error);\n973:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n974:       timer.unref?.();\n975: \n976:       try {\n977:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n978:         socket = typeof connectionOptions === 'string'\n979:           ? net.createConnection(connectionOptions)\n980:           : net.createConnection(connectionOptions);\n981:       } catch (error: unknown) {\n982:         clearTimeout(timer);\n983:         reject(error instanceof Error ? error : new Error(String(error)));\n984:         return;\n985:       }\n986:       socket.once('connect', onConnect);\n987:       socket.once('error', onError);\n988:     });\n989:   }\n990: \n991:   notify(method: string, params?: unknown): void {\n992:     const frame = params === undefined\n993:       ? { jsonrpc: '2.0', method }\n994:       : { jsonrpc: '2.0', method, params };\n995:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n996:   }\n997: \n998:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n999:     const id = this.nextId++;\n1000:   