{"type":"tool_use","timestamp":1781145164212,"sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","part":{"type":"tool","tool":"read","callID":"call_n7SotNo2D9MGYVS8TjE8JCU8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Finalize Dist                                                           ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import crypto from 'node:crypto';\n8: import { fileURLToPath } from 'node:url';\n9: \n10: const serverDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');\n11: const distDir = path.join(serverDir, 'dist');\n12: const staleDistRoots = [\n13:   'system-spec-kit',\n14:   'system-skill-advisor',\n15:   'system-code-graph',\n16:   'tests',\n17:   'database',\n18: ];\n19: const requiredArtifacts = [\n20:   'context-server.js',\n21:   'api/index.js',\n22:   'hooks/codex/session-start.js',\n23: ];\n24: const cliSourceFiles = [\n25:   'spec-memory-cli.ts',\n26:   'tool-schemas.ts',\n27:   'schemas/tool-input-schemas.ts',\n28: ];\n29: const cliSourceHashState = path.join(distDir, '.spec-memory-cli-source-hash.json');\n30: \n31: function copyJsonFiles(sourceDir, targetDir) {\n32:   if (!fs.existsSync(sourceDir)) {\n33:     return;\n34:   }\n35: \n36:   fs.mkdirSync(targetDir, { recursive: true });\n37:   for (const entry of fs.readdirSync(sourceDir, { withFileTypes: true })) {\n38:     const sourcePath = path.join(sourceDir, entry.name);\n39:     const targetPath = path.join(targetDir, entry.name);\n40:     if (entry.isDirectory()) {\n41:       copyJsonFiles(sourcePath, targetPath);\n42:     } else if (entry.isFile() && entry.name.endsWith('.json')) {\n43:       fs.copyFileSync(sourcePath, targetPath);\n44:     }\n45:   }\n46: }\n47: \n48: function removeStaleDistRoots() {\n49:   for (const root of staleDistRoots) {\n50:     fs.rmSync(path.join(distDir, root), { recursive: true, force: true });\n51:   }\n52: }\n53: \n54: function assertRequiredArtifacts() {\n55:   const missing = requiredArtifacts.filter((artifact) => !fs.existsSync(path.join(distDir, artifact)));\n56:   if (missing.length > 0) {\n57:     throw new Error(`Missing expected dist artifact(s): ${missing.join(', ')}`);\n58:   }\n59: }\n60: \n61: function assertNoStaleDistRoots() {\n62:   const stale = staleDistRoots.filter((root) => fs.existsSync(path.join(distDir, root)));\n63:   if (stale.length > 0) {\n64:     throw new Error(`Stale dist root(s) still present: ${stale.join(', ')}`);\n65:   }\n66: }\n67: \n68: function writeCliSourceHash() {\n69:   const existingSources = cliSourceFiles\n70:     .map((filePath) => path.join(serverDir, filePath))\n71:     .filter((filePath) => fs.existsSync(filePath));\n72:   if (existingSources.length === 0) return;\n73: \n74:   const hash = crypto.createHash('sha256');\n75:   for (const filePath of existingSources.sort()) {\n76:     hash.update(path.relative(serverDir, filePath));\n77:     hash.update('\\0');\n78:     hash.update(fs.readFileSync(filePath));\n79:     hash.update('\\0');\n80:   }\n81:   fs.writeFileSync(cliSourceHashState, `${JSON.stringify({ version: 1, sourceHash: hash.digest('hex') })}\\n`);\n82: }\n83: \n84: copyJsonFiles(path.join(serverDir, 'lib', 'eval', 'data'), path.join(distDir, 'lib', 'eval', 'data'));\n85: copyJsonFiles(path.join(serverDir, 'lib', 'routing'), path.join(distDir, 'lib', 'routing'));\n86: \n87: removeStaleDistRoots();\n88: assertRequiredArtifacts();\n89: assertNoStaleDistRoots();\n90: writeCliSourceHash();\n\n(End of file - total 90 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Finalize Dist                                                           ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport crypto from 'node:crypto';\nimport { fileURLToPath } from 'node:url';\n\nconst serverDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');\nconst distDir = path.join(serverDir, 'dist');\nconst staleDistRoots = [\n  'system-spec-kit',\n  'system-skill-advisor',\n  'system-code-graph',\n  'tests',\n  'database',\n];\nconst requiredArtifacts = [\n  'context-server.js',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Finalize Dist                                                           ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport crypto from 'node:crypto';\nimport { fileURLToPath } from 'node:url';\n\nconst serverDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');\nconst distDir = path.join(serverDir, 'dist');\nconst staleDistRoots = [\n  'system-spec-kit',\n  'system-skill-advisor',\n  'system-code-graph',\n  'tests',\n  'database',\n];\nconst requiredArtifacts = [\n  'context-server.js',\n  'api/index.js',\n  'hooks/codex/session-start.js',\n];\nconst cliSourceFiles = [\n  'spec-memory-cli.ts',\n  'tool-schemas.ts',\n  'schemas/tool-input-schemas.ts',\n];\nconst cliSourceHashState = path.join(distDir, '.spec-memory-cli-source-hash.json');\n\nfunction copyJsonFiles(sourceDir, targetDir) {\n  if (!fs.existsSync(sourceDir)) {\n    return;\n  }\n\n  fs.mkdirSync(targetDir, { recursive: true });\n  for (const entry of fs.readdirSync(sourceDir, { withFileTypes: true })) {\n    const sourcePath = path.join(sourceDir, entry.name);\n    const targetPath = path.join(targetDir, entry.name);\n    if (entry.isDirectory()) {\n      copyJsonFiles(sourcePath, targetPath);\n    } else if (entry.isFile() && entry.name.endsWith('.json')) {\n      fs.copyFileSync(sourcePath, targetPath);\n    }\n  }\n}\n\nfunction removeStaleDistRoots() {\n  for (const root of staleDistRoots) {\n    fs.rmSync(path.join(distDir, root), { recursive: true, force: true });\n  }\n}\n\nfunction assertRequiredArtifacts() {\n  const missing = requiredArtifacts.filter((artifact) => !fs.existsSync(path.join(distDir, artifact)));\n  if (missing.length > 0) {\n    throw new Error(`Missing expected dist artifact(s): ${missing.join(', ')}`);\n  }\n}\n\nfunction assertNoStaleDistRoots() {\n  const stale = staleDistRoots.filter((root) => fs.existsSync(path.join(distDir, root)));\n  if (stale.length > 0) {\n    throw new Error(`Stale dist root(s) still present: ${stale.join(', ')}`);\n  }\n}\n\nfunction writeCliSourceHash() {\n  const existingSources = cliSourceFiles\n    .map((filePath) => path.join(serverDir, filePath))\n    .filter((filePath) => fs.existsSync(filePath));\n  if (existingSources.length === 0) return;\n\n  const hash = crypto.createHash('sha256');\n  for (const filePath of existingSources.sort()) {\n    hash.update(path.relative(serverDir, filePath));\n    hash.update('\\0');\n    hash.update(fs.readFileSync(filePath));\n    hash.update('\\0');\n  }\n  fs.writeFileSync(cliSourceHashState, `${JSON.stringify({ version: 1, sourceHash: hash.digest('hex') })}\\n`);\n}\n\ncopyJsonFiles(path.join(serverDir, 'lib', 'eval', 'data'), path.join(distDir, 'lib', 'eval', 'data'));\ncopyJsonFiles(path.join(serverDir, 'lib', 'routing'), path.join(distDir, 'lib', 'routing'));\n\nremoveStaleDistRoots();\nassertRequiredArtifacts();\nassertNoStaleDistRoots();\nwriteCliSourceHash();","lineStart":1,"lineEnd":90,"totalLines":90,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/scripts/finalize-dist.mjs","time":{"start":1781145164206,"end":1781145164211}},"metadata":{"openai":{"itemId":"fc_0334b83fb47366d1016a2a1e4c21e881918785fb5fc8ae524f"}},"id":"prt_eb48659860018fh4oy5T16Pd0w","sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","messageID":"msg_eb486105d001qWkPtT4fimD1Oe"}}
{"type":"tool_use","timestamp":1781145164218,"sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","part":{"type":"tool","tool":"read","callID":"call_4lQcxA5TEgNdxghNG1BfdrDm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/plugin_bridges/mk-spec-memory-bridge.mjs","offset":190,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/plugin_bridges/mk-spec-memory-bridge.mjs</path>\n<type>file</type>\n<content>\n190: \n191: function classifyCliFailure(exitCode, stderr, timedOut) {\n192:   const staleDist = exitCode === 69 && /dist entrypoint is (stale|missing)/i.test(stderr);\n193:   if (staleDist) {\n194:     return {\n195:       status: 'fail_open',\n196:       brief: 'dist stale, rebuild required',\n197:       error: 'dist_stale_rebuild_required',\n198:       retryable: false,\n199:       metadata: {\n200:         state: 'dist_stale_rebuild_required',\n201:         staleDist: true,\n202:         rebuildRequired: true,\n203:         action: 'run npm run build --workspace=@spec-kit/mcp-server',\n204:       },\n205:     };\n206:   }\n207:   const retryable = exitCode === 75 || timedOut;\n208:   return {\n209:     status: retryable ? 'skipped' : 'fail_open',\n210:     brief: null,\n211:     error: timedOut ? 'timeout' : `exit_${exitCode ?? 'unknown'}`,\n212:     retryable,\n213:     metadata: {},\n214:   };\n215: }\n216: \n217: async function runCli(input) {\n218:   const startedAt = Date.now();\n219:   const timeoutMs = positiveInt(Number(input.timeoutMs), DEFAULT_TIMEOUT_MS);\n220:   const probeTimeoutMs = Math.min(positiveInt(Number(input.probeTimeoutMs), DEFAULT_PROBE_TIMEOUT_MS), timeoutMs);\n221:   const request = typeof input.request === 'string' && input.request.trim()\n222:     ? input.request.trim()\n223:     : 'brief';\n224:   const toolName = typeof input.toolName === 'string' && input.toolName.trim()\n225:     ? input.toolName.trim()\n226:     : (request === 'status' ? 'memory_health' : 'session_resume');\n227:   const promptSafePolicy = promptSafeSpecMemoryBridgePolicy({ request, toolName });\n228:   if (!promptSafePolicy.allowed) {\n229:     return skipped(promptSafePolicy.reason, {\n230:       route: 'prompt_safe_policy',\n231:       request,\n232:       toolName,\n233:       retryable: false,\n234:       durationMs: Date.now() - startedAt,\n235:     });\n236:   }\n237: \n238:   const probe = await warmProbe(probeTimeoutMs);\n239:   const afterProbeMs = Date.now() - startedAt;\n240:   if (!probe.warm) {\n241:     return skipped(probe.reason, {\n242:       route: 'warm_probe',\n243:       retryable: true,\n244:       durationMs: afterProbeMs,\n245:       socketPath: probe.socketPath ? '[spec-memory-socket]' : null,\n246:       exitCode: 75,\n247:     });\n248:   }\n249: \n250:   const remainingMs = Math.max(1, timeoutMs - afterProbeMs);\n251:   const args = isRecord(input.args) ? { ...input.args } : {};\n252:   if (toolName === 'session_resume') {\n253:     args.minimal = args.minimal !== false;\n254:     if (typeof input.specFolder === 'string' && input.specFolder.trim()) {\n255:       args.specFolder = input.specFolder.trim();\n256:     }\n257:     if (typeof input.sessionId === 'string' && input.sessionId.trim()) {\n258:       args.sessionId = input.sessionId.trim();\n259:     }\n260:   }\n261: \n262:   return new Promise((resolveResult) => {\n263:     const child = spawn(process.execPath, [\n264:       CLI_SHIM,\n265:       toolName,\n266:       '--json',\n267:       JSON.stringify(args),\n268:       '--format',\n269:       'json',\n270:       '--timeout-ms',\n271:       String(remainingMs),\n272:       '--warm-only',\n273:     ], {\n274:       cwd: typeof input.workspaceRoot === 'string' && input.workspaceRoot.trim() ? input.workspaceRoot.trim() : REPO_ROOT,\n275:       env: {\n276:         ...process.env,\n277:         SPECKIT_IPC_SOCKET_DIR: process.env.SPECKIT_IPC_SOCKET_DIR ?? DEFAULT_SOCKET_DIR,\n278:         SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME: '1',\n279:       },\n280:       stdio: ['ignore', 'pipe', 'pipe'],\n281:     });\n282:     let stdout = '';\n283:     let stderr = '';\n284:     let settled = false;\n285:     let timedOut = false;\n286:     const finish = (exitCode, error) => {\n287:       if (settled) return;\n288:       settled = true;\n289:       clearTimeout(timer);\n290:       const payload = parseStdout(stdout);\n291:       const durationMs = Date.now() - startedAt;\n292:       if (exitCode === 0 && payload) {\n293:         resolveResult(response({\n294:           status: 'ok',\n295:           brief: input.request === 'status' ? null : renderContinuityBrief(payload, positiveInt(Number(input.maxBriefChars), 2400)),\n296:           data: payload,\n297:           metadata: {\n298:             route: 'cli',\n299:             toolName,\n300:             warm: true,\n301:             durationMs,\n302:             exitCode,\n303:             socketPath: '[spec-memory-socket]',\n304:           },\n305:         }));\n306:         return;\n307:       }\n308:       const failure = classifyCliFailure(exitCode, stderr, timedOut);\n309:       resolveResult(response({\n310:         status: failure.status,\n311:         brief: failure.brief,\n312:         data: payload,\n313:         error: error ?? failure.error,\n314:         metadata: {\n315:           route: 'cli',\n316:           toolName,\n317:           warm: true,\n318:           durationMs,\n319:           exitCode,\n\n(Showing lines 190-319 of 374. Use offset=320 to continue.)\n</content>","metadata":{"preview":"\nfunction classifyCliFailure(exitCode, stderr, timedOut) {\n  const staleDist = exitCode === 69 && /dist entrypoint is (stale|missing)/i.test(stderr);\n  if (staleDist) {\n    return {\n      status: 'fail_open',\n      brief: 'dist stale, rebuild required',\n      error: 'dist_stale_rebuild_required',\n      retryable: false,\n      metadata: {\n        state: 'dist_stale_rebuild_required',\n        staleDist: true,\n        rebuildRequired: true,\n        action: 'run npm run build --workspace=@spec-kit/mcp-server',\n      },\n    };\n  }\n  const retryable = exitCode === 75 || timedOut;\n  return {\n    status: retryable ? 'skipped' : 'fail_open',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/plugin_bridges/mk-spec-memory-bridge.mjs","text":"\nfunction classifyCliFailure(exitCode, stderr, timedOut) {\n  const staleDist = exitCode === 69 && /dist entrypoint is (stale|missing)/i.test(stderr);\n  if (staleDist) {\n    return {\n      status: 'fail_open',\n      brief: 'dist stale, rebuild required',\n      error: 'dist_stale_rebuild_required',\n      retryable: false,\n      metadata: {\n        state: 'dist_stale_rebuild_required',\n        staleDist: true,\n        rebuildRequired: true,\n        action: 'run npm run build --workspace=@spec-kit/mcp-server',\n      },\n    };\n  }\n  const retryable = exitCode === 75 || timedOut;\n  return {\n    status: retryable ? 'skipped' : 'fail_open',\n    brief: null,\n    error: timedOut ? 'timeout' : `exit_${exitCode ?? 'unknown'}`,\n    retryable,\n    metadata: {},\n  };\n}\n\nasync function runCli(input) {\n  const startedAt = Date.now();\n  const timeoutMs = positiveInt(Number(input.timeoutMs), DEFAULT_TIMEOUT_MS);\n  const probeTimeoutMs = Math.min(positiveInt(Number(input.probeTimeoutMs), DEFAULT_PROBE_TIMEOUT_MS), timeoutMs);\n  const request = typeof input.request === 'string' && input.request.trim()\n    ? input.request.trim()\n    : 'brief';\n  const toolName = typeof input.toolName === 'string' && input.toolName.trim()\n    ? input.toolName.trim()\n    : (request === 'status' ? 'memory_health' : 'session_resume');\n  const promptSafePolicy = promptSafeSpecMemoryBridgePolicy({ request, toolName });\n  if (!promptSafePolicy.allowed) {\n    return skipped(promptSafePolicy.reason, {\n      route: 'prompt_safe_policy',\n      request,\n      toolName,\n      retryable: false,\n      durationMs: Date.now() - startedAt,\n    });\n  }\n\n  const probe = await warmProbe(probeTimeoutMs);\n  const afterProbeMs = Date.now() - startedAt;\n  if (!probe.warm) {\n    return skipped(probe.reason, {\n      route: 'warm_probe',\n      retryable: true,\n      durationMs: afterProbeMs,\n      socketPath: probe.socketPath ? '[spec-memory-socket]' : null,\n      exitCode: 75,\n    });\n  }\n\n  const remainingMs = Math.max(1, timeoutMs - afterProbeMs);\n  const args = isRecord(input.args) ? { ...input.args } : {};\n  if (toolName === 'session_resume') {\n    args.minimal = args.minimal !== false;\n    if (typeof input.specFolder === 'string' && input.specFolder.trim()) {\n      args.specFolder = input.specFolder.trim();\n    }\n    if (typeof input.sessionId === 'string' && input.sessionId.trim()) {\n      args.sessionId = input.sessionId.trim();\n    }\n  }\n\n  return new Promise((resolveResult) => {\n    const child = spawn(process.execPath, [\n      CLI_SHIM,\n      toolName,\n      '--json',\n      JSON.stringify(args),\n      '--format',\n      'json',\n      '--timeout-ms',\n      String(remainingMs),\n      '--warm-only',\n    ], {\n      cwd: typeof input.workspaceRoot === 'string' && input.workspaceRoot.trim() ? input.workspaceRoot.trim() : REPO_ROOT,\n      env: {\n        ...process.env,\n        SPECKIT_IPC_SOCKET_DIR: process.env.SPECKIT_IPC_SOCKET_DIR ?? DEFAULT_SOCKET_DIR,\n        SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME: '1',\n      },\n      stdio: ['ignore', 'pipe', 'pipe'],\n    });\n    let stdout = '';\n    let stderr = '';\n    let settled = false;\n    let timedOut = false;\n    const finish = (exitCode, error) => {\n      if (settled) return;\n      settled = true;\n      clearTimeout(timer);\n      const payload = parseStdout(stdout);\n      const durationMs = Date.now() - startedAt;\n      if (exitCode === 0 && payload) {\n        resolveResult(response({\n          status: 'ok',\n          brief: input.request === 'status' ? null : renderContinuityBrief(payload, positiveInt(Number(input.maxBriefChars), 2400)),\n          data: payload,\n          metadata: {\n            route: 'cli',\n            toolName,\n            warm: true,\n            durationMs,\n            exitCode,\n            socketPath: '[spec-memory-socket]',\n          },\n        }));\n        return;\n      }\n      const failure = classifyCliFailure(exitCode, stderr, timedOut);\n      resolveResult(response({\n        status: failure.status,\n        brief: failure.brief,\n        data: payload,\n        error: error ?? failure.error,\n        metadata: {\n          route: 'cli',\n          toolName,\n          warm: true,\n          durationMs,\n          exitCode,","lineStart":190,"lineEnd":319,"totalLines":374,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/plugin_bridges/mk-spec-memory-bridge.mjs","time":{"start":1781145164215,"end":1781145164218}},"metadata":{"openai":{"itemId":"fc_0334b83fb47366d1016a2a1e4c220081919c428d24b326a739"}},"id":"prt_eb48659b0001Zmt5OADt179ran","sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","messageID":"msg_eb486105d001qWkPtT4fimD1Oe"}}
{"type":"tool_use","timestamp":1781145164227,"sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","part":{"type":"tool","tool":"read","callID":"call_LHugDxoBdoD4Mk1tHdARSznC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/warm-cli-fallback-envelope.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/warm-cli-fallback-envelope.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Warm CLI Fallback Envelope\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: export type WarmCliFallbackStatus = 'ok' | 'skipped' | 'fail_open';\n6: \n7: export interface WarmCliFallbackEnvelope {\n8:   readonly status: WarmCliFallbackStatus;\n9:   readonly reason: string;\n10:   readonly exitCode: number | null;\n11:   readonly retryable: boolean;\n12: }\n13: \n14: export interface WarmCliFallbackEnvelopeInput {\n15:   readonly status: WarmCliFallbackStatus;\n16:   readonly reason?: string | null;\n17:   readonly exitCode?: number | null;\n18:   readonly timedOut?: boolean;\n19: }\n20: \n21: const RETRYABLE_REASONS = new Set([\n22:   'budget_exhausted_before_cli',\n23:   'socket_absent',\n24:   'timeout',\n25: ]);\n26: \n27: function normalizeReason(reason: string | null | undefined, exitCode: number | null, status: WarmCliFallbackStatus): string {\n28:   const trimmed = typeof reason === 'string' ? reason.trim() : '';\n29:   if (trimmed) {\n30:     return trimmed\n31:       .replace(/^CLI_RETRYABLE_UNAVAILABLE\\s+exit\\s+75:\\s*/i, '')\n32:       .replace(/^CLI_/i, '')\n33:       .toLowerCase()\n34:       .replace(/[^a-z0-9]+/g, '_')\n35:       .replace(/^_+|_+$/g, '') || 'unknown';\n36:   }\n37:   if (status === 'ok') {\n38:     return 'ok';\n39:   }\n40:   return exitCode === null ? 'exit_unknown' : `exit_${exitCode}`;\n41: }\n42: \n43: export function warmCliFallbackEnvelope(input: WarmCliFallbackEnvelopeInput): WarmCliFallbackEnvelope {\n44:   const exitCode = input.exitCode ?? null;\n45:   const reason = normalizeReason(input.reason, exitCode, input.status);\n46:   return {\n47:     status: input.status,\n48:     reason,\n49:     exitCode,\n50:     retryable: input.status !== 'ok' && (input.timedOut === true || exitCode === 75 || RETRYABLE_REASONS.has(reason)),\n51:   };\n52: }\n\n(End of file - total 52 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Warm CLI Fallback Envelope\n// ───────────────────────────────────────────────────────────────\n\nexport type WarmCliFallbackStatus = 'ok' | 'skipped' | 'fail_open';\n\nexport interface WarmCliFallbackEnvelope {\n  readonly status: WarmCliFallbackStatus;\n  readonly reason: string;\n  readonly exitCode: number | null;\n  readonly retryable: boolean;\n}\n\nexport interface WarmCliFallbackEnvelopeInput {\n  readonly status: WarmCliFallbackStatus;\n  readonly reason?: string | null;\n  readonly exitCode?: number | null;\n  readonly timedOut?: boolean;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/warm-cli-fallback-envelope.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Warm CLI Fallback Envelope\n// ───────────────────────────────────────────────────────────────\n\nexport type WarmCliFallbackStatus = 'ok' | 'skipped' | 'fail_open';\n\nexport interface WarmCliFallbackEnvelope {\n  readonly status: WarmCliFallbackStatus;\n  readonly reason: string;\n  readonly exitCode: number | null;\n  readonly retryable: boolean;\n}\n\nexport interface WarmCliFallbackEnvelopeInput {\n  readonly status: WarmCliFallbackStatus;\n  readonly reason?: string | null;\n  readonly exitCode?: number | null;\n  readonly timedOut?: boolean;\n}\n\nconst RETRYABLE_REASONS = new Set([\n  'budget_exhausted_before_cli',\n  'socket_absent',\n  'timeout',\n]);\n\nfunction normalizeReason(reason: string | null | undefined, exitCode: number | null, status: WarmCliFallbackStatus): string {\n  const trimmed = typeof reason === 'string' ? reason.trim() : '';\n  if (trimmed) {\n    return trimmed\n      .replace(/^CLI_RETRYABLE_UNAVAILABLE\\s+exit\\s+75:\\s*/i, '')\n      .replace(/^CLI_/i, '')\n      .toLowerCase()\n      .replace(/[^a-z0-9]+/g, '_')\n      .replace(/^_+|_+$/g, '') || 'unknown';\n  }\n  if (status === 'ok') {\n    return 'ok';\n  }\n  return exitCode === null ? 'exit_unknown' : `exit_${exitCode}`;\n}\n\nexport function warmCliFallbackEnvelope(input: WarmCliFallbackEnvelopeInput): WarmCliFallbackEnvelope {\n  const exitCode = input.exitCode ?? null;\n  const reason = normalizeReason(input.reason, exitCode, input.status);\n  return {\n    status: input.status,\n    reason,\n    exitCode,\n    retryable: input.status !== 'ok' && (input.timedOut === true || exitCode === 75 || RETRYABLE_REASONS.has(reason)),\n  };\n}","lineStart":1,"lineEnd":52,"totalLines":52,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/hooks/warm-cli-fallback-envelope.ts","time":{"start":1781145164224,"end":1781145164226}},"metadata":{"openai":{"itemId":"fc_0334b83fb47366d1016a2a1e4c22088191a668cce11cbff6df"}},"id":"prt_eb48659b8001hEJJavpmQSO3Mw","sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","messageID":"msg_eb486105d001qWkPtT4fimD1Oe"}}
{"type":"tool_use","timestamp":1781145164257,"sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","part":{"type":"tool","tool":"read","callID":"call_ggqcbCGC3Mo9JWDk6zxWU94E","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/references/cli/daemon_cli_reference.md","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/references/cli/daemon_cli_reference.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Daemon CLI Reference\n3: description: Canonical reference for the three daemon-backed CLI shims over mk-spec-memory, mk-code-index, and mk-skill-advisor.\n4: ---\n5: \n6: # Daemon CLI Reference\n7: \n8: The daemon CLI shims are additive IPC clients over the existing MCP daemons. They are not replacement servers, and MCP remains the primary in-session transport.\n9: \n10: Use these CLIs when a runtime MCP transport is missing, failed, or not reconnecting while the daemon is expected to be warm, or when an operator needs shell diagnostics, CI checks, or scripted maintenance.\n11: \n12: ## 1. CLI Surfaces\n13: \n14: | CLI shim | MCP daemon | Tool count | Primary use |\n15: | --- | --- | ---: | --- |\n16: | `node .opencode/bin/spec-memory.cjs` | `mk-spec-memory` | 37 | Memory context, search, health, indexing, checkpoint, and session recovery fallback. |\n17: | `node .opencode/bin/code-index.cjs` | `mk-code-index` | 8 | Code graph status, scan, verify, query, context, apply-mode recovery, and diff impact fallback. |\n18: | `node .opencode/bin/skill-advisor.cjs` | `mk_skill_advisor` | 9 | Advisor recommendations, advisor health, skill graph diagnostics, and trusted maintainer mutations. |\n19: \n20: Each shim first checks its built CLI entrypoint, sets a default socket directory when needed, then runs the compiled CLI with inherited stdio. `list-tools` and `--help` are served from local definitions and do not contact or spawn a daemon.\n21: \n22: ## 2. Invocation Forms\n23: \n24: Common form:\n25: \n26: ```bash\n27: node .opencode/bin/<cli>.cjs list-tools [--format json|text|jsonl]\n28: node .opencode/bin/<cli>.cjs <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--warm-only]\n29: node .opencode/bin/<cli>.cjs <tool_name> --param value [--another-param value]\n30: node .opencode/bin/<cli>.cjs <tool_name> --help\n31: ```\n32: \n33: Tool names accept the aliases exposed by the CLI. The memory and code-index CLIs expose snake_case, kebab-case, and camelCase aliases from the tool name; the advisor CLI exposes aliases from its manifest.\n34: \n35: Use `--json` for one complete JSON object argument when a tool has structured input:\n36: \n37: ```bash\n38: node .opencode/bin/spec-memory.cjs memory_context --json '{\"input\":\"resume previous work\",\"mode\":\"resume\"}' --format json --timeout-ms 3000\n39: node .opencode/bin/code-index.cjs code_graph_status --format json --timeout-ms 3000 --warm-only\n40: node .opencode/bin/skill-advisor.cjs advisor_recommend --json '{\"prompt\":\"implement cli core\"}' --format json --timeout-ms 3000 --warm-only\n41: ```\n42: \n43: ## 3. Output Formats\n44: \n45: All three CLIs accept `--format json|text|jsonl`.\n46: \n47: | Format | Behavior |\n48: | --- | --- |\n49: | `json` | Pretty-printed JSON payload. |\n50: | `text` | Human-readable summary when the payload has one; `list-tools --format text` prints tool names. |\n51: | `jsonl` | A single complete JSON payload rendered on one stdout line. |\n52: \n53: `jsonl` is not streaming JSON Lines. Do not assume one record per tool, one record per result, or incremental output. When passing input with `--json`, pass one complete JSON object as one shell argument; the CLIs do not parse a stream of JSONL records from stdin.\n54: \n55: ## 4. Exit-Code Taxonomy\n56: \n57: | Exit | Meaning | Notes |\n58: | ---: | --- | --- |\n59: | `0` | Success | Includes actionable code-index `status:\"blocked\"` readiness refusals; blocked reads are valid answers with `requiredAction`. |\n60: | `1` | Runtime error | Tool returned an error payload or an unclassified runtime failure occurred. |\n61: | `64` | Usage or schema error | Bad flags, invalid `--json`, schema validation failure, advisor trusted-mutation refusal, or code-index `detect_changes` `parse_error`. |\n62: | `69` | Protocol mismatch or stale/missing dist | The shim or CLI refused an unsafe build/protocol state. Rebuild the matching package before retrying. |\n63: | `75` | Retryable daemon/IPC error | Warm-only daemon unavailable, connection refused/reset, timeout, busy database, spawn failure, or retryable backend state. |\n64: \n65: Exit `75` is retryable. Treat it as daemon or IPC unavailability, not as user input failure.\n66: \n67: ## 5. Warm-Only Policy\n68: \n69: Prompt-time hooks and prompt-time runtime fallbacks must use warm-only behavior. Warm-only probes the daemon socket and exits `75` when the daemon is cold instead of cold-spawning it.\n70: \n71: Use either the explicit flag or the prompt-time env flags:\n72: \n73: ```bash\n74: node .opencode/bin/spec-memory.cjs memory_stats --warm-only --format json --timeout-ms 3000\n75: node .opencode/bin/code-index.cjs code_graph_status --warm-only --format json --timeout-ms 3000\n76: node .opencode/bin/skill-advisor.cjs advisor_status --workspace-root \"$PWD\" --warm-only --format json --timeout-ms 3000\n77: ```\n78: \n79: Warm-only defaults can also come from env flags documented in `../config/environment_variables.md` and `../../mcp_server/ENV_REFERENCE.md`: per-CLI `*_CLI_WARM_ONLY`, per-CLI `*_CLI_PROMPT_TIME`, cross-CLI `SPECKIT_CLI_PROMPT_TIME`, and runtime prompt-time markers such as `OPENCODE_PROMPT_TIME`, `CODEX_PROMPT_TIME`, and `CLAUDE_CODE_PROMPT_TIME`.\n80: \n81: Non-prompt contexts such as explicit operator maintenance, CI, cron, or session startup may omit `--warm-only`; then a cold daemon can auto-spawn through the matching `mk-*-launcher.cjs`.\n82: \n83: ## 6. Exit 69 Recovery\n84: \n85: The shims refuse stale or missing dist entrypoints with exit `69`. Rebuild before retrying.\n86: \n87: | CLI | Shim stale/missing message | Build recovery |\n88: | --- | --- | --- |\n89: | `spec-memory.cjs` | `Run npm run build --workspace=@spec-kit/mcp-server.` | `npm run build --workspace=@spec-kit/mcp-server` |\n90: | `code-index.cjs` | `Run tsc -p .opencode/skills/system-code-graph/tsconfig.json.` | `npm --prefix .opencode/skills/system-code-graph run build` or the exact `tsc -p ...` command from the shim. |\n91: | `skill-advisor.cjs` | `Run the skill-advisor TypeScript build.` | `npm --prefix .opencode/skills/system-skill-advisor/mcp_server run build` |\n92: \n93: Development-only stale overrides exist for local loops, but should not be used in normal recovery: `SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE=1`, `SPECKIT_CODE_INDEX_CLI_DEV_ALLOW_STALE=1`, and `MK_SKILL_ADVISOR_CLI_DEV_ALLOW_STALE=1` or `SPECKIT_SKILL_ADVISOR_CLI_DEV_ALLOW_STALE=1`.\n94: \n95: ## 7. Help And Discovery\n96: \n97: Use `list-tools` for offline surface discovery:\n98: \n99: ```bash\n100: node .opencode/bin/spec-memory.cjs list-tools --format json\n101: node .opencode/bin/code-index.cjs list-tools --format json\n102: node .opencode/bin/skill-advisor.cjs list-tools --format json\n103: ```\n104: \n105: Expected counts are `37`, `8`, and `9` respectively.\n106: \n107: Per-command help is available and prints the command description, aliases, and input schema:\n108: \n109: ```bash\n110: node .opencode/bin/spec-memory.cjs memory_stats --help\n111: node .opencode/bin/code-index.cjs code_graph_status --help\n112: node .opencode/bin/skill-advisor.cjs advisor_status --help\n113: ```\n114: \n115: Run the host-safe offline smoke check to verify all three shims without daemon contact:\n116: \n117: ```bash\n118: node .opencode/bin/cli-offline-smoke.cjs --format json\n119: ```\n120: \n121: The smoke check expects `spec-memory=37`, `code-index=8`, `skill-advisor=9`, and `daemonFree:true` for each result.\n122: \n123: ## 8. Safety Rules\n124: \n125: - Keep MCP as the primary in-session transport; use CLIs as additive fallbacks and operator surfaces.\n126: - Prefer read-only recovery commands when transport fails: memory context/status, code graph status/query reads, advisor recommend/status.\n127: - Prompt-time hooks must probe warm daemons only. They must not cold-spawn daemons from prompt-time paths.\n128: - Treat exit `75` as retryable daemon/IPC unavailability. Retry after MCP reconnect, daemon prewarm, or short backoff.\n129: - Treat exit `69` as a stale/missing dist or protocol mismatch. Rebuild the matching package before retrying.\n130: - Keep code-index maintenance commands such as `code_graph_scan`, `code_graph_apply`, and `code_graph_verify` out of prompt-time hooks.\n131: - Skill-advisor CLI calls are untrusted by default. Mutations (`advisor_rebuild`, `skill_graph_scan`, and apply-mode `skill_graph_propagate_enhances`) require `--trusted` or `MK_SKILL_ADVISOR_CLI_TRUSTED=1`.\n132: - Do not use `jsonl` as a streaming automation contract; it is one complete JSON payload on one line.\n133: \n134: ## 9. Source Anchors\n135: \n136: - CLI sources: `system-spec-kit/mcp_server/spec-memory-cli.ts`, `system-code-graph/mcp_server/code-index-cli.ts`, `system-skill-advisor/mcp_server/skill-advisor-cli.ts`.\n137: - Shim sources: `.opencode/bin/spec-memory.cjs`, `.opencode/bin/code-index.cjs`, `.opencode/bin/skill-advisor.cjs`.\n138: - Env flags: `mcp_server/ENV_REFERENCE.md` section `CLI FRONT DOOR (DUAL-STACK)`.\n139: - Offline smoke: `.opencode/bin/cli-offline-smoke.cjs`.\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"---\ntitle: Daemon CLI Reference\ndescription: Canonical reference for the three daemon-backed CLI shims over mk-spec-memory, mk-code-index, and mk-skill-advisor.\n---\n\n# Daemon CLI Reference\n\nThe daemon CLI shims are additive IPC clients over the existing MCP daemons. They are not replacement servers, and MCP remains the primary in-session transport.\n\nUse these CLIs when a runtime MCP transport is missing, failed, or not reconnecting while the daemon is expected to be warm, or when an operator needs shell diagnostics, CI checks, or scripted maintenance.\n\n## 1. CLI Surfaces\n\n| CLI shim | MCP daemon | Tool count | Primary use |\n| --- | --- | ---: | --- |\n| `node .opencode/bin/spec-memory.cjs` | `mk-spec-memory` | 37 | Memory context, search, health, indexing, checkpoint, and session recovery fallback. |\n| `node .opencode/bin/code-index.cjs` | `mk-code-index` | 8 | Code graph status, scan, verify, query, context, apply-mode recovery, and diff impact fallback. |\n| `node .opencode/bin/skill-advisor.cjs` | `mk_skill_advisor` | 9 | Advisor recommendations, advisor health, skill graph diagnostics, and trusted maintainer mutations. |\n\nEach shim first checks its built CLI entrypoint, sets a default socket directory when needed, then runs the compiled CLI with inherited stdio. `list-tools` and `--help` are served from local definitions and do not contact or spawn a daemon.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/references/cli/daemon_cli_reference.md","text":"---\ntitle: Daemon CLI Reference\ndescription: Canonical reference for the three daemon-backed CLI shims over mk-spec-memory, mk-code-index, and mk-skill-advisor.\n---\n\n# Daemon CLI Reference\n\nThe daemon CLI shims are additive IPC clients over the existing MCP daemons. They are not replacement servers, and MCP remains the primary in-session transport.\n\nUse these CLIs when a runtime MCP transport is missing, failed, or not reconnecting while the daemon is expected to be warm, or when an operator needs shell diagnostics, CI checks, or scripted maintenance.\n\n## 1. CLI Surfaces\n\n| CLI shim | MCP daemon | Tool count | Primary use |\n| --- | --- | ---: | --- |\n| `node .opencode/bin/spec-memory.cjs` | `mk-spec-memory` | 37 | Memory context, search, health, indexing, checkpoint, and session recovery fallback. |\n| `node .opencode/bin/code-index.cjs` | `mk-code-index` | 8 | Code graph status, scan, verify, query, context, apply-mode recovery, and diff impact fallback. |\n| `node .opencode/bin/skill-advisor.cjs` | `mk_skill_advisor` | 9 | Advisor recommendations, advisor health, skill graph diagnostics, and trusted maintainer mutations. |\n\nEach shim first checks its built CLI entrypoint, sets a default socket directory when needed, then runs the compiled CLI with inherited stdio. `list-tools` and `--help` are served from local definitions and do not contact or spawn a daemon.\n\n## 2. Invocation Forms\n\nCommon form:\n\n```bash\nnode .opencode/bin/<cli>.cjs list-tools [--format json|text|jsonl]\nnode .opencode/bin/<cli>.cjs <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--warm-only]\nnode .opencode/bin/<cli>.cjs <tool_name> --param value [--another-param value]\nnode .opencode/bin/<cli>.cjs <tool_name> --help\n```\n\nTool names accept the aliases exposed by the CLI. The memory and code-index CLIs expose snake_case, kebab-case, and camelCase aliases from the tool name; the advisor CLI exposes aliases from its manifest.\n\nUse `--json` for one complete JSON object argument when a tool has structured input:\n\n```bash\nnode .opencode/bin/spec-memory.cjs memory_context --json '{\"input\":\"resume previous work\",\"mode\":\"resume\"}' --format json --timeout-ms 3000\nnode .opencode/bin/code-index.cjs code_graph_status --format json --timeout-ms 3000 --warm-only\nnode .opencode/bin/skill-advisor.cjs advisor_recommend --json '{\"prompt\":\"implement cli core\"}' --format json --timeout-ms 3000 --warm-only\n```\n\n## 3. Output Formats\n\nAll three CLIs accept `--format json|text|jsonl`.\n\n| Format | Behavior |\n| --- | --- |\n| `json` | Pretty-printed JSON payload. |\n| `text` | Human-readable summary when the payload has one; `list-tools --format text` prints tool names. |\n| `jsonl` | A single complete JSON payload rendered on one stdout line. |\n\n`jsonl` is not streaming JSON Lines. Do not assume one record per tool, one record per result, or incremental output. When passing input with `--json`, pass one complete JSON object as one shell argument; the CLIs do not parse a stream of JSONL records from stdin.\n\n## 4. Exit-Code Taxonomy\n\n| Exit | Meaning | Notes |\n| ---: | --- | --- |\n| `0` | Success | Includes actionable code-index `status:\"blocked\"` readiness refusals; blocked reads are valid answers with `requiredAction`. |\n| `1` | Runtime error | Tool returned an error payload or an unclassified runtime failure occurred. |\n| `64` | Usage or schema error | Bad flags, invalid `--json`, schema validation failure, advisor trusted-mutation refusal, or code-index `detect_changes` `parse_error`. |\n| `69` | Protocol mismatch or stale/missing dist | The shim or CLI refused an unsafe build/protocol state. Rebuild the matching package before retrying. |\n| `75` | Retryable daemon/IPC error | Warm-only daemon unavailable, connection refused/reset, timeout, busy database, spawn failure, or retryable backend state. |\n\nExit `75` is retryable. Treat it as daemon or IPC unavailability, not as user input failure.\n\n## 5. Warm-Only Policy\n\nPrompt-time hooks and prompt-time runtime fallbacks must use warm-only behavior. Warm-only probes the daemon socket and exits `75` when the daemon is cold instead of cold-spawning it.\n\nUse either the explicit flag or the prompt-time env flags:\n\n```bash\nnode .opencode/bin/spec-memory.cjs memory_stats --warm-only --format json --timeout-ms 3000\nnode .opencode/bin/code-index.cjs code_graph_status --warm-only --format json --timeout-ms 3000\nnode .opencode/bin/skill-advisor.cjs advisor_status --workspace-root \"$PWD\" --warm-only --format json --timeout-ms 3000\n```\n\nWarm-only defaults can also come from env flags documented in `../config/environment_variables.md` and `../../mcp_server/ENV_REFERENCE.md`: per-CLI `*_CLI_WARM_ONLY`, per-CLI `*_CLI_PROMPT_TIME`, cross-CLI `SPECKIT_CLI_PROMPT_TIME`, and runtime prompt-time markers such as `OPENCODE_PROMPT_TIME`, `CODEX_PROMPT_TIME`, and `CLAUDE_CODE_PROMPT_TIME`.\n\nNon-prompt contexts such as explicit operator maintenance, CI, cron, or session startup may omit `--warm-only`; then a cold daemon can auto-spawn through the matching `mk-*-launcher.cjs`.\n\n## 6. Exit 69 Recovery\n\nThe shims refuse stale or missing dist entrypoints with exit `69`. Rebuild before retrying.\n\n| CLI | Shim stale/missing message | Build recovery |\n| --- | --- | --- |\n| `spec-memory.cjs` | `Run npm run build --workspace=@spec-kit/mcp-server.` | `npm run build --workspace=@spec-kit/mcp-server` |\n| `code-index.cjs` | `Run tsc -p .opencode/skills/system-code-graph/tsconfig.json.` | `npm --prefix .opencode/skills/system-code-graph run build` or the exact `tsc -p ...` command from the shim. |\n| `skill-advisor.cjs` | `Run the skill-advisor TypeScript build.` | `npm --prefix .opencode/skills/system-skill-advisor/mcp_server run build` |\n\nDevelopment-only stale overrides exist for local loops, but should not be used in normal recovery: `SPECKIT_SPEC_MEMORY_CLI_DEV_ALLOW_STALE=1`, `SPECKIT_CODE_INDEX_CLI_DEV_ALLOW_STALE=1`, and `MK_SKILL_ADVISOR_CLI_DEV_ALLOW_STALE=1` or `SPECKIT_SKILL_ADVISOR_CLI_DEV_ALLOW_STALE=1`.\n\n## 7. Help And Discovery\n\nUse `list-tools` for offline surface discovery:\n\n```bash\nnode .opencode/bin/spec-memory.cjs list-tools --format json\nnode .opencode/bin/code-index.cjs list-tools --format json\nnode .opencode/bin/skill-advisor.cjs list-tools --format json\n```\n\nExpected counts are `37`, `8`, and `9` respectively.\n\nPer-command help is available and prints the command description, aliases, and input schema:\n\n```bash\nnode .opencode/bin/spec-memory.cjs memory_stats --help\nnode .opencode/bin/code-index.cjs code_graph_status --help\nnode .opencode/bin/skill-advisor.cjs advisor_status --help\n```\n\nRun the host-safe offline smoke check to verify all three shims without daemon contact:\n\n```bash\nnode .opencode/bin/cli-offline-smoke.cjs --format json\n```\n\nThe smoke check expects `spec-memory=37`, `code-index=8`, `skill-advisor=9`, and `daemonFree:true` for each result.\n\n## 8. Safety Rules\n\n- Keep MCP as the primary in-session transport; use CLIs as additive fallbacks and operator surfaces.\n- Prefer read-only recovery commands when transport fails: memory context/status, code graph status/query reads, advisor recommend/status.\n- Prompt-time hooks must probe warm daemons only. They must not cold-spawn daemons from prompt-time paths.\n- Treat exit `75` as retryable daemon/IPC unavailability. Retry after MCP reconnect, daemon prewarm, or short backoff.\n- Treat exit `69` as a stale/missing dist or protocol mismatch. Rebuild the matching package before retrying.\n- Keep code-index maintenance commands such as `code_graph_scan`, `code_graph_apply`, and `code_graph_verify` out of prompt-time hooks.\n- Skill-advisor CLI calls are untrusted by default. Mutations (`advisor_rebuild`, `skill_graph_scan`, and apply-mode `skill_graph_propagate_enhances`) require `--trusted` or `MK_SKILL_ADVISOR_CLI_TRUSTED=1`.\n- Do not use `jsonl` as a streaming automation contract; it is one complete JSON payload on one line.\n\n## 9. Source Anchors\n\n- CLI sources: `system-spec-kit/mcp_server/spec-memory-cli.ts`, `system-code-graph/mcp_server/code-index-cli.ts`, `system-skill-advisor/mcp_server/skill-advisor-cli.ts`.\n- Shim sources: `.opencode/bin/spec-memory.cjs`, `.opencode/bin/code-index.cjs`, `.opencode/bin/skill-advisor.cjs`.\n- Env flags: `mcp_server/ENV_REFERENCE.md` section `CLI FRONT DOOR (DUAL-STACK)`.\n- Offline smoke: `.opencode/bin/cli-offline-smoke.cjs`.","lineStart":1,"lineEnd":139,"totalLines":139,"truncated":false}},"title":".opencode/skills/system-spec-kit/references/cli/daemon_cli_reference.md","time":{"start":1781145164253,"end":1781145164256}},"metadata":{"openai":{"itemId":"fc_0334b83fb47366d1016a2a1e4c220c8191a0506c27f37b0051"}},"id":"prt_eb48659cf001PzGeKomhjMDcOP","sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","messageID":"msg_eb486105d001qWkPtT4fimD1Oe"}}
{"type":"tool_use","timestamp":1781145164258,"sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","part":{"type":"tool","tool":"read","callID":"call_oLSLN7ikODWWG6yTWqnTwahq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: const fs = require('fs');\n5: const os = require('os');\n6: const path = require('path');\n7: const { spawnSync } = require('child_process');\n8: \n9: const repoRoot = path.resolve(__dirname, '..', '..');\n10: const socketFileName = 'daemon-ipc.sock';\n11: const checks = [\n12:   { name: 'spec-memory', shim: path.join(__dirname, 'spec-memory.cjs'), expectedCount: 37 },\n13:   { name: 'code-index', shim: path.join(__dirname, 'code-index.cjs'), expectedCount: 8 },\n14:   { name: 'skill-advisor', shim: path.join(__dirname, 'skill-advisor.cjs'), expectedCount: 9 },\n15: ];\n16: \n17: function parseArgs(argv) {\n18:   const options = { format: 'text', timeoutMs: 20_000 };\n19:   for (let index = 0; index < argv.length; index += 1) {\n20:     const value = argv[index];\n21:     if (value === '--format') {\n22:       options.format = argv[index + 1] === 'json' ? 'json' : 'text';\n23:       index += 1;\n24:     } else if (value === '--json') {\n25:       options.format = 'json';\n26:     } else if (value === '--timeout-ms') {\n27:       const parsed = Number.parseInt(argv[index + 1], 10);\n28:       if (Number.isFinite(parsed) && parsed > 0) options.timeoutMs = parsed;\n29:       index += 1;\n30:     }\n31:   }\n32:   return options;\n33: }\n34: \n35: function classifyFreshness(exitCode, stderr) {\n36:   if (exitCode === 69 && /dist entrypoint is (stale|missing)/i.test(stderr)) {\n37:     return 'dist_stale_rebuild_required';\n38:   }\n39:   if (exitCode === 0) return 'fresh';\n40:   return 'unknown';\n41: }\n42: \n43: function parseJson(stdout) {\n44:   try {\n45:     return JSON.parse(stdout || '{}');\n46:   } catch {\n47:     return null;\n48:   }\n49: }\n50: \n51: function runCheck(check, timeoutMs) {\n52:   const sandbox = fs.mkdtempSync(path.join(os.tmpdir(), 'cli-offline-smoke-'));\n53:   const socketDir = path.join(sandbox, 'sock');\n54:   try {\n55:     const result = spawnSync(process.execPath, [check.shim, 'list-tools', '--format', 'json'], {\n56:       cwd: repoRoot,\n57:       env: {\n58:         ...process.env,\n59:         SPECKIT_IPC_SOCKET_DIR: socketDir,\n60:         SPECKIT_DAEMON_REELECTION: '0',\n61:       },\n62:       encoding: 'utf8',\n63:       timeout: timeoutMs,\n64:       maxBuffer: 1024 * 1024 * 10,\n65:       stdio: ['ignore', 'pipe', 'pipe'],\n66:     });\n67: \n68:     const payload = parseJson(result.stdout);\n69:     const count = payload?.data?.count;\n70:     const daemonSocket = path.join(socketDir, socketFileName);\n71:     const freshness = classifyFreshness(result.status, result.stderr ?? '');\n72:     const ok = result.status === 0\n73:       && payload?.status === 'ok'\n74:       && count === check.expectedCount\n75:       && !fs.existsSync(daemonSocket);\n76: \n77:     return {\n78:       name: check.name,\n79:       ok,\n80:       status: payload?.status ?? null,\n81:       count: typeof count === 'number' ? count : null,\n82:       expectedCount: check.expectedCount,\n83:       freshness,\n84:       exitCode: result.status,\n85:       signal: result.signal,\n86:       daemonFree: !fs.existsSync(daemonSocket),\n87:       stderr: result.stderr ? '[stderr-present]' : null,\n88:     };\n89:   } finally {\n90:     fs.rmSync(sandbox, { recursive: true, force: true });\n91:   }\n92: }\n93: \n94: function renderText(payload) {\n95:   const lines = [\n96:     `CLI offline smoke: ${payload.status.toUpperCase()}`,\n97:     `scenario=${payload.scenario}`,\n98:   ];\n99:   for (const result of payload.results) {\n100:     lines.push(`${result.name}: ${result.ok ? 'ok' : 'fail'} count=${result.count ?? 'n/a'}/${result.expectedCount} freshness=${result.freshness} daemonFree=${result.daemonFree}`);\n101:   }\n102:   return `${lines.join('\\n')}\\n`;\n103: }\n104: \n105: function main() {\n106:   const options = parseArgs(process.argv.slice(2));\n107:   const results = checks.map((check) => runCheck(check, options.timeoutMs));\n108:   const ok = results.every((result) => result.ok);\n109:   const payload = {\n110:     status: ok ? 'ok' : 'fail',\n111:     scenario: 'cli-list-tools-parity',\n112:     daemonRequired: false,\n113:     buildRequired: false,\n114:     scanRequired: false,\n115:     results,\n116:   };\n117: \n118:   process.stdout.write(options.format === 'json' ? `${JSON.stringify(payload, null, 2)}\\n` : renderText(payload));\n119:   process.exit(ok ? 0 : 1);\n120: }\n121: \n122: main();\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\nconst fs = require('fs');\nconst os = require('os');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\nconst repoRoot = path.resolve(__dirname, '..', '..');\nconst socketFileName = 'daemon-ipc.sock';\nconst checks = [\n  { name: 'spec-memory', shim: path.join(__dirname, 'spec-memory.cjs'), expectedCount: 37 },\n  { name: 'code-index', shim: path.join(__dirname, 'code-index.cjs'), expectedCount: 8 },\n  { name: 'skill-advisor', shim: path.join(__dirname, 'skill-advisor.cjs'), expectedCount: 9 },\n];\n\nfunction parseArgs(argv) {\n  const options = { format: 'text', timeoutMs: 20_000 };\n  for (let index = 0; index < argv.length; index += 1) {\n    const value = argv[index];","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/cli-offline-smoke.cjs","text":"#!/usr/bin/env node\n'use strict';\n\nconst fs = require('fs');\nconst os = require('os');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\nconst repoRoot = path.resolve(__dirname, '..', '..');\nconst socketFileName = 'daemon-ipc.sock';\nconst checks = [\n  { name: 'spec-memory', shim: path.join(__dirname, 'spec-memory.cjs'), expectedCount: 37 },\n  { name: 'code-index', shim: path.join(__dirname, 'code-index.cjs'), expectedCount: 8 },\n  { name: 'skill-advisor', shim: path.join(__dirname, 'skill-advisor.cjs'), expectedCount: 9 },\n];\n\nfunction parseArgs(argv) {\n  const options = { format: 'text', timeoutMs: 20_000 };\n  for (let index = 0; index < argv.length; index += 1) {\n    const value = argv[index];\n    if (value === '--format') {\n      options.format = argv[index + 1] === 'json' ? 'json' : 'text';\n      index += 1;\n    } else if (value === '--json') {\n      options.format = 'json';\n    } else if (value === '--timeout-ms') {\n      const parsed = Number.parseInt(argv[index + 1], 10);\n      if (Number.isFinite(parsed) && parsed > 0) options.timeoutMs = parsed;\n      index += 1;\n    }\n  }\n  return options;\n}\n\nfunction classifyFreshness(exitCode, stderr) {\n  if (exitCode === 69 && /dist entrypoint is (stale|missing)/i.test(stderr)) {\n    return 'dist_stale_rebuild_required';\n  }\n  if (exitCode === 0) return 'fresh';\n  return 'unknown';\n}\n\nfunction parseJson(stdout) {\n  try {\n    return JSON.parse(stdout || '{}');\n  } catch {\n    return null;\n  }\n}\n\nfunction runCheck(check, timeoutMs) {\n  const sandbox = fs.mkdtempSync(path.join(os.tmpdir(), 'cli-offline-smoke-'));\n  const socketDir = path.join(sandbox, 'sock');\n  try {\n    const result = spawnSync(process.execPath, [check.shim, 'list-tools', '--format', 'json'], {\n      cwd: repoRoot,\n      env: {\n        ...process.env,\n        SPECKIT_IPC_SOCKET_DIR: socketDir,\n        SPECKIT_DAEMON_REELECTION: '0',\n      },\n      encoding: 'utf8',\n      timeout: timeoutMs,\n      maxBuffer: 1024 * 1024 * 10,\n      stdio: ['ignore', 'pipe', 'pipe'],\n    });\n\n    const payload = parseJson(result.stdout);\n    const count = payload?.data?.count;\n    const daemonSocket = path.join(socketDir, socketFileName);\n    const freshness = classifyFreshness(result.status, result.stderr ?? '');\n    const ok = result.status === 0\n      && payload?.status === 'ok'\n      && count === check.expectedCount\n      && !fs.existsSync(daemonSocket);\n\n    return {\n      name: check.name,\n      ok,\n      status: payload?.status ?? null,\n      count: typeof count === 'number' ? count : null,\n      expectedCount: check.expectedCount,\n      freshness,\n      exitCode: result.status,\n      signal: result.signal,\n      daemonFree: !fs.existsSync(daemonSocket),\n      stderr: result.stderr ? '[stderr-present]' : null,\n    };\n  } finally {\n    fs.rmSync(sandbox, { recursive: true, force: true });\n  }\n}\n\nfunction renderText(payload) {\n  const lines = [\n    `CLI offline smoke: ${payload.status.toUpperCase()}`,\n    `scenario=${payload.scenario}`,\n  ];\n  for (const result of payload.results) {\n    lines.push(`${result.name}: ${result.ok ? 'ok' : 'fail'} count=${result.count ?? 'n/a'}/${result.expectedCount} freshness=${result.freshness} daemonFree=${result.daemonFree}`);\n  }\n  return `${lines.join('\\n')}\\n`;\n}\n\nfunction main() {\n  const options = parseArgs(process.argv.slice(2));\n  const results = checks.map((check) => runCheck(check, options.timeoutMs));\n  const ok = results.every((result) => result.ok);\n  const payload = {\n    status: ok ? 'ok' : 'fail',\n    scenario: 'cli-list-tools-parity',\n    daemonRequired: false,\n    buildRequired: false,\n    scanRequired: false,\n    results,\n  };\n\n  process.stdout.write(options.format === 'json' ? `${JSON.stringify(payload, null, 2)}\\n` : renderText(payload));\n  process.exit(ok ? 0 : 1);\n}\n\nmain();","lineStart":1,"lineEnd":122,"totalLines":122,"truncated":false}},"title":".opencode/bin/cli-offline-smoke.cjs","time":{"start":1781145164255,"end":1781145164258}},"metadata":{"openai":{"itemId":"fc_0334b83fb47366d1016a2a1e4c22148191b6a797b47bc16eb4"}},"id":"prt_eb48659dd001Oqr0ICMWDXGvgo","sessionID":"ses_14b7dcdddffei484GOhlnbTHUq","messageID":"msg_eb486105d001qWkPtT4fimD1Oe"}}
