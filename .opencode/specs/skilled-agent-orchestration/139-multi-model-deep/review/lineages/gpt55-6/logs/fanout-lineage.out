of parsed.startedAtIso === 'string' &&\n347:       typeof parsed.lastHeartbeatIso === 'string' &&\n348:       Number.isInteger(parsed.ttlMs) &&\n349:       typeof parsed.canonicalDbDir === 'string'\n350:     ) {\n351:       return parsed;\n352:     }\n353:   } catch {\n354:     // Missing or corrupt owner leases are treated as no active owner.\n355:   }\n356:   return null;\n357: }\n358: \n359: function writeOwnerLeaseFile(lease) {\n360:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n361:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n362:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n363:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n364:   // after power loss and break ownership detection.\n365:   let fd;\n366:   try {\n367:     fd = fs.openSync(tmp, 'wx', 0o600);\n368:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n369:     fs.fsyncSync(fd);\n370:   } finally {\n371:     if (typeof fd === 'number') fs.closeSync(fd);\n372:   }\n373:   fs.renameSync(tmp, currentLeasePath);\n374: }\n375: \n376: function writeOwnerLeaseFileExclusive(lease) {\n377:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n378:   let fd;\n379:   try {\n380:     fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n381:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n382:     fs.fsyncSync(fd);\n383:     return true;\n384:   } catch (error) {\n385:     if (error.code === 'EEXIST') return false;\n386:     throw error;\n387:   } finally {\n388:     if (typeof fd === 'number') fs.closeSync(fd);\n389:   }\n\n(Showing lines 300-389 of 1612. Use offset=390 to continue.)\n</content>","metadata":{"preview":"\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n\nfunction readOwnerLeaseFile(filePath = ownerLeasePath()) {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    if (\n      Number.isInteger(parsed.ownerPid) &&\n      Number.isInteger(parsed.ppid) &&\n      typeof parsed.executablePath === 'string' &&\n      typeof parsed.startedAtIso === 'string' &&\n      typeof parsed.lastHeartbeatIso === 'string' &&\n      Number.isInteger(parsed.ttlMs) &&\n      typeof parsed.canonicalDbDir === 'string'\n    ) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt owner leases are treated as no active owner.\n  }\n  return null;\n}\n\nfunction writeOwnerLeaseFile(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n  // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n  // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n  // after power loss and break ownership detection.\n  let fd;\n  try {\n    fd = fs.openSync(tmp, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction writeOwnerLeaseFileExclusive(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  let fd;\n  try {\n    fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n    return true;\n  } catch (error) {\n    if (error.code === 'EEXIST') return false;\n    throw error;\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }","lineStart":300,"lineEnd":389,"totalLines":1612,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780907830675,"end":1780907830688}},"metadata":{"openai":{"itemId":"fc_0563f766a2cb9c0f016a267f3687d08196984beaef8d9aabe5"}},"id":"prt_ea660ed53001nJ6OwgCSuMOmk2","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea660babd00107H2vSwkJc7II3"}}
