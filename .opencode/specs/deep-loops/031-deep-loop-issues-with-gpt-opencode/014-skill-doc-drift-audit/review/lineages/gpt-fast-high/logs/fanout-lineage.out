spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/gate-tool-routing.md\",\n          \"title\": \"TOOL ROUTING - Search & Retrieval Decision Tree\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: TOOL ROUTING - Search & Retrieval Decision Tree | Prioritize when: task context aligns with \\\"TOOL ROUTING - Search & Retrieval Decision Tree\\\"\"\n        },\n        {\n          \"id\": 16263,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/finding-is-a-hypothesis.md\",\n          \"title\": \"A Finding Is a Hypothesis Until You Open the Cited Code\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: rule applies — never ground truth. | Prioritize when: only verdict discipline still holds: never soften an active blocker without new evidence.\"\n        },\n        {\n          \"id\": 15815,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/regression-baseline-and-delta.md\",\n          \"title\": \"Baseline Before No-Regressions; Report the Delta\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: rule applies — never a grep narrowed to your own files — and report the delta in the form `baseline N failing {…} → now M: {…}`. | Prioritize when: never re-renders, a screenshot of the wrong screen, a fixture older than your work making a green result suspect. \\\"No r…\"\n        }\n      ],\n      \"triggered\": [\n        {\n          \"memory_id\": 7282,\n          \"spec_folder\": \"system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/002-skill-speckit-alignment\",\n          \"title\": \"Task [system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/task-02-skill-speckit-alignment/spec]\",\n          \"matched_phrases\": [\n            \"skill\",\n            \"audit\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 8109,\n          \"spec_folder\": \"system-spec-kit/z_archive/022-hybrid-rag-fusion/013-agents-alignment\",\n          \"title\": \"013 — Agent Alignment: Runtime Lineage Truth [system-spec-kit/022-hybrid-rag-fusion/013-agents-alignment/spec]\",\n          \"matched_phrases\": [\n            \"lineage\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 7600,\n          \"spec_folder\": \"system-spec-kit/z_archive/022-hybrid-rag-fusion/006-feature-catalog\",\n          \"title\": \"Feature Catalog Comprehensive Audit & Remediation [system-spec-kit/022-hybrid-rag-fusion/006-feature-catalog/spec]\",\n          \"matched_phrases\": [\n            \"audit\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 7281,\n          \"spec_folder\": \"system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/004-agent-alignment\",\n          \"title\": \"Task 04 — [system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/task-04-agent-alignment/spec]\",\n          \"matched_phrases\": [\n            \"audit\",\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 7274,\n          \"spec_folder\": \"system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/003-command-alignment\",\n          \"title\": \"Task 03 — [system-spec-kit/z_archive/013-memory-overhaul-and-agent-upgrade-release/task-03-command-alignment/spec]\",\n          \"matched_phrases\": [\n            \"audit\",\n            \"spec\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-07-01T15:15:35.825Z\",\n      \"latencyMs\": 1333\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1782918934487,"end":1782918935863}},"metadata":{"openai":{"itemId":"fc_0fdf08d73142ba52016a452f13154881918e3e02bac013c3cb"}},"id":"prt_f1e3fe289001onhW568zhuYhLS","sessionID":"ses_0e1c12f14ffe56Cs01FOXHPL99","messageID":"msg_f1e3fba38001a1bnM6r49Ln7iu"}}
