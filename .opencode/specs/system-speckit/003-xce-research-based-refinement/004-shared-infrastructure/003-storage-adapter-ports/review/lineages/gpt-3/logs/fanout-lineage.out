{"type":"tool_use","timestamp":1781144268159,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_FhTVuODRX0jgnV2mu3nwWg0G","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Vector Store\n3: // -------------------------------------------------------------------\n4: \n5: import { IVectorStore } from '../../interfaces/vector-store.js';\n6: import {\n7:   activeVectorSource,\n8:   close_db,\n9:   get_embedding_dim,\n10:   initialize_db,\n11:   sqlite_vec_available,\n12: } from '../../search/vector-index-store.js';\n13: import {\n14:   VectorIndexError,\n15:   VectorIndexErrorCode,\n16:   type EmbeddingInput,\n17:   type EnrichedSearchResult,\n18:   type IndexMemoryParams,\n19:   type MemoryRow,\n20:   type VectorSearchOptions as LegacyVectorSearchOptions,\n21: } from '../../search/vector-index-types.js';\n22: \n23: import type { Awaitable, StorageId } from './common.js';\n24: import type Database from 'better-sqlite3';\n25: \n26: type JsonObject = Record<string, unknown>;\n27: \n28: interface BetterSqliteVectorStoreOptions {\n29:   readonly dbPath?: string;\n30: }\n31: \n32: type EnhancedSearchOptions = {\n33:   specFolder?: string | null;\n34:   minSimilarity?: number;\n35:   diversityFactor?: number;\n36:   noDiversity?: boolean;\n37: };\n38: \n39: let cachedQueries: Awaited<typeof import('../../search/vector-index-queries.js')> | null = null;\n40: let cachedMutations: Awaited<typeof import('../../search/vector-index-mutations.js')> | null = null;\n41: let cachedAliases: Awaited<typeof import('../../search/vector-index-aliases.js')> | null = null;\n42: \n43: async function getQueriesModule(): Promise<Awaited<typeof import('../../search/vector-index-queries.js')>> {\n44:   return cachedQueries ??= await import('../../search/vector-index-queries.js');\n45: }\n46: \n47: async function getMutationsModule(): Promise<Awaited<typeof import('../../search/vector-index-mutations.js')>> {\n48:   return cachedMutations ??= await import('../../search/vector-index-mutations.js');\n49: }\n50: \n51: async function getAliasesModule(): Promise<Awaited<typeof import('../../search/vector-index-aliases.js')>> {\n52:   return cachedAliases ??= await import('../../search/vector-index-aliases.js');\n53: }\n54: \n55: /** Metadata attached to a vector record. */\n56: export type VectorMetadata = Readonly<Record<string, unknown>>;\n57: \n58: /** Persisted vector entry. */\n59: export interface VectorRecord<TMetadata extends VectorMetadata = VectorMetadata> {\n60:   readonly id: StorageId;\n61:   readonly embedding: readonly number[] | Float32Array;\n62:   readonly metadata: TMetadata;\n63: }\n64: \n65: /** Ranked vector search hit. */\n66: export interface VectorSearchResult<TMetadata extends VectorMetadata = VectorMetadata> {\n67:   readonly id: StorageId;\n68:   readonly score: number;\n69:   readonly metadata: TMetadata;\n70: }\n71: \n72: /** Query options for vector nearest-neighbor retrieval. */\n73: export interface VectorSearchOptions {\n74:   readonly limit: number;\n75:   readonly minScore?: number;\n76: }\n77: \n78: /** Port for vector persistence and similarity retrieval. */\n79: export interface VectorStore<TMetadata extends VectorMetadata = VectorMetadata> {\n80:   /** Insert or replace one vector record. */\n81:   upsert(record: VectorRecord<TMetadata>): Awaitable<void>;\n82: \n83:   /** Remove one vector record. */\n84:   delete(id: StorageId): Awaitable<boolean>;\n85: \n86:   /** Fetch one vector record by ID. */\n87:   get(id: StorageId): Awaitable<VectorRecord<TMetadata> | null>;\n88: \n89:   /** Return ranked vector matches for a query embedding. */\n90:   search(\n91:     embedding: readonly number[] | Float32Array,\n92:     options: VectorSearchOptions,\n93:   ): Awaitable<VectorSearchResult<TMetadata>[]>;\n94: \n95:   /** Remove all vector records. */\n96:   clear(): Awaitable<void>;\n97: }\n98: \n99: /** better-sqlite3-backed vector-store adapter. */\n100: export class BetterSqliteVectorStore<TMetadata extends VectorMetadata = VectorMetadata>\n101:   extends IVectorStore\n102:   implements VectorStore<TMetadata> {\n103:   dbPath: string | null;\n104:   _initialized: boolean;\n105: \n106:   constructor(options: BetterSqliteVectorStoreOptions = {}) {\n107:     super();\n108:     this.dbPath = options.dbPath || null;\n109:     this._initialized = false;\n110:   }\n111: \n112:   _ensureInitialized(): void {\n113:     if (!this._initialized) {\n114:       this._getDatabase();\n115:       this._initialized = true;\n116:     }\n117:   }\n118: \n119:   _getDatabase(): Database.Database {\n120:     return initialize_db(this.dbPath);\n121:   }\n122: \n123:   search(\n124:     embedding: readonly number[] | Float32Array,\n125:     options: VectorSearchOptions,\n126:   ): Promise<VectorSearchResult<TMetadata>[]>;\n127:   search(\n128:     embedding: EmbeddingInput,\n129:     topK: number,\n130:     options?: LegacyVectorSearchOptions,\n131:   ): Promise<MemoryRow[]>;\n132:   async search(\n133:     embedding: EmbeddingInput,\n134:     optionsOrTopK: VectorSearchOptions | number,\n135:     options: LegacyVectorSearchOptions = {},\n136:   ): Promise<VectorSearchResult<TMetadata>[] | MemoryRow[]> {\n137:     if (typeof optionsOrTopK !== 'number') {\n138:       const rows = await this.search(embedding, optionsOrTopK.limit, {\n139:         minSimilarity: optionsOrTopK.minScore === undefined ? 0 : optionsOrTopK.minScore * 100,\n140:         includeConstitutional: false,\n141:       });\n142:       return rows.map((row) => ({\n143:         id: String(row.id),\n144:         score: typeof row.similarity === 'number' ? row.similarity / 100 : 0,\n145:         metadata: row as unknown as TMetadata,\n146:       }));\n147:     }\n148: \n149:     this._ensureInitialized();\n150:     const database = this._getDatabase();\n151: \n152:     const expected_dim = get_embedding_dim();\n153:     if (!embedding || embedding.length !== expected_dim) {\n154:       throw new VectorIndexError(\n155:         `Invalid embedding dimension: expected ${expected_dim}, got ${embedding?.length}`,\n156:         VectorIndexErrorCode.EMBEDDING_VALIDATION,\n157:       );\n158:     }\n159: \n160:     const search_options = {\n161:       limit: optionsOrTopK,\n162:       specFolder: options.specFolder,\n163:       minSimilarity: options.minSimilarity || 0,\n164:       useDecay: options.useDecay !== false,\n165:       tier: options.tier,\n166:       contextType: options.contextType,\n167:       includeConstitutional: options.includeConstitutional !== false,\n168:       includeArchived: options.includeArchived === true\n169:     };\n170: \n171:     const { vector_search } = await getQueriesModule();\n172:     return vector_search(embedding, search_options, database);\n173:   }\n174: \n175:   upsert(record: VectorRecord<TMetadata>): Promise<void>;\n176:   upsert(id: string, embedding: EmbeddingInput, metadata: JsonObject): Promise<number>;\n177:   async upsert(\n178:     recordOrId: VectorRecord<TMetadata> | string,\n179:     embedding?: EmbeddingInput,\n180:     metadata?: JsonObject,\n181:   ): Promise<void | number> {\n182:     if (typeof recordOrId !== 'string') {\n183:       const recordEmbedding = recordOrId.embedding instanceof Float32Array\n184:         ? recordOrId.embedding\n185:         : Array.from(recordOrId.embedding);\n186:       await this.upsert(String(recordOrId.id), recordEmbedding, recordOrId.metadata);\n187:       return;\n188:     }\n189: \n190:     this._ensureInitialized();\n191:     const database = this._getDatabase();\n192: \n193:     const expected_dim = get_embedding_dim();\n194:     if (!embedding || embedding.length !== expected_dim) {\n195:       throw new VectorIndexError(\n196:         `Embedding dimension mismatch: expected ${expected_dim}, got ${embedding?.length}`,\n197:         VectorIndexErrorCode.EMBEDDING_VALIDATION,\n198:       );\n199:     }\n200: \n201:     const metadata_alias = (metadata ?? {}) as JsonObject & {\n202:       spec_folder?: string;\n203:       specFolder?: string;\n204:       file_path?: string;\n205:       filePath?: string;\n206:       anchor_id?: string;\n207:       anchorId?: string;\n208:       title?: string;\n209:       trigger_phrases?: string[];\n210:       triggerPhrases?: string[];\n211:       importance_weight?: number;\n212:       importanceWeight?: number;\n213:     };\n214: \n215:     const params: IndexMemoryParams = {\n216:       specFolder: metadata_alias.spec_folder || metadata_alias.specFolder || '',\n217:       filePath: metadata_alias.file_path || metadata_alias.filePath || '',\n218:       anchorId: metadata_alias.anchor_id || metadata_alias.anchorId || null,\n219:       title: metadata_alias.title || null,\n220:       triggerPhrases: metadata_alias.trigger_phrases || metadata_alias.triggerPhrases || [],\n221:       importanceWeight: metadata_alias.importance_weight ?? metadata_alias.importanceWeight ?? 0.5,\n222:       embedding: embedding\n223:     };\n224: \n225:     if (!params.specFolder || !params.filePath) {\n226:       throw new VectorIndexError(\n227:         'metadata must include spec_folder and file_path',\n228:         VectorIndexErrorCode.STORE_ERROR,\n229:       );\n230:     }\n231: \n232:     const { index_memory } = await getMutationsModule();\n233:     return index_memory(params, database);\n234:   }\n235: \n236:   async delete(id: StorageId): Promise<boolean> {\n237:     this._ensureInitialized();\n238:     const database = this._getDatabase();\n239:     const { delete_memory } = await getMutationsModule();\n240:     return delete_memory(Number(id), database);\n241:   }\n242: \n243:   async get(id: StorageId): Promise<VectorRecord<TMetadata> | null>;\n244:   async get(id: number): Promise<MemoryRow | null>;\n245:   async get(id: StorageId): Promise<VectorRecord<TMetadata> | MemoryRow | null> {\n246:     this._ensureInitialized();\n247:     const database = this._getDatabase();\n248:     const { get_memory } = await getQueriesModule();\n249:     const row = get_memory(Number(id), database);\n250:     if (!row) {\n251:       return null;\n252:     }\n253:     if (typeof id === 'number') {\n254:       return row;\n255:     }\n256:     const embedding = this.getEmbeddingForId(database, Number(row.id));\n257:     return {\n258:       id: row.id,\n259:       embedding,\n260:       metadata: row as unknown as TMetadata,\n261:     };\n262:   }\n263: \n264:   async clear(): Promise<void> {\n265:     this._ensureInitialized();\n266:     const database = this._getDatabase();\n267:     database.transaction(() => {\n268:       database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')}`).run();\n269:       database.prepare('DELETE FROM active_memory_projection').run();\n270:       database.prepare('DELETE FROM memory_index').run();\n271:     })();\n272:   }\n273: \n274:   async getStats(): Promise<{ total: number; pending: number; success: number; failed: number; retry: number }> {\n275:     this._ensureInitialized();\n276:     const database = this._getDatabase();\n277:     const { get_stats } = await getQueriesModule();\n278:     return get_stats(database);\n279:   }\n280: \n281:   isAvailable(): boolean {\n282:     return sqlite_vec_available();\n283:   }\n284: \n285:   getEmbeddingDimension(): number {\n286:     return get_embedding_dim();\n287:   }\n288: \n289:   async close(): Promise<void> {\n290:     if (this._initialized) {\n291:       close_db();\n292:       this._initialized = false;\n293:     }\n294:   }\n295: \n296:   async deleteByPath(specFolder: string, filePath: string, anchorId: string | null = null): Promise<boolean> {\n297:     this._ensureInitialized();\n298:     const database = this._getDatabase();\n299:     const { delete_memory_by_path } = await getMutationsModule();\n300:     return delete_memory_by_path(specFolder, filePath, anchorId, database);\n301:   }\n302: \n303:   async getByFolder(specFolder: string): Promise<MemoryRow[]> {\n304:     this._ensureInitialized();\n305:     const database = this._getDatabase();\n306:     const { get_memories_by_folder } = await getQueriesModule();\n307:     return get_memories_by_folder(specFolder, database);\n308:   }\n309: \n310:   async searchEnriched(\n311:     embedding: string,\n312:     options: { specFolder?: string | null; minSimilarity?: number } = {},\n313:   ): Promise<EnrichedSearchResult[]> {\n314:     this._ensureInitialized();\n315:     const database = this._getDatabase();\n316:     const { vector_search_enriched } = await getQueriesModule();\n317:     return vector_search_enriched(embedding, undefined, options, database);\n318:   }\n319: \n320:   async enhancedSearch(embedding: string, options: EnhancedSearchOptions = {}): Promise<EnrichedSearchResult[]> {\n321:     this._ensureInitialized();\n322:     const database = this._getDatabase();\n323:     const { enhanced_search } = await getAliasesModule();\n324:     return enhanced_search(embedding, undefined, options, database);\n325:   }\n326: \n327:   async getConstitutionalMemories(\n328:     options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n329:   ): Promise<MemoryRow[]> {\n330:     this._ensureInitialized();\n331:     const database = this._getDatabase();\n332:     const { get_constitutional_memories_public } = await getQueriesModule();\n333:     return get_constitutional_memories_public(options, database);\n334:   }\n335: \n336:   async verifyIntegrity(\n337:     options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n338:   ): Promise<{\n339:     totalMemories: number;\n340:     totalVectors: number;\n341:     orphanedVectors: number;\n342:     missingVectors: number;\n343:     orphanedFiles: Array<{ id: number; file_path: string; reason: string }>;\n344:     orphanedChunks: number;\n345:     isConsistent: boolean;\n346:     cleaned?: { vectors: number; chunks: number; files: number };\n347:   }> {\n348:     this._ensureInitialized();\n349:     const database = this._getDatabase();\n350:     const { verify_integrity } = await getQueriesModule();\n351:     return verify_integrity(options, database);\n352:   }\n353: \n354:   private getEmbeddingForId(database: Database.Database, id: number): Float32Array {\n355:     const row = database.prepare(`\n356:       SELECT embedding\n357:       FROM ${activeVectorSource('vec_memories')}\n358:       WHERE rowid = ?\n359:       LIMIT 1\n360:     `).get(BigInt(id)) as { embedding?: Buffer | Uint8Array } | undefined;\n\n(Showing lines 1-360 of 367. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Vector Store\n// -------------------------------------------------------------------\n\nimport { IVectorStore } from '../../interfaces/vector-store.js';\nimport {\n  activeVectorSource,\n  close_db,\n  get_embedding_dim,\n  initialize_db,\n  sqlite_vec_available,\n} from '../../search/vector-index-store.js';\nimport {\n  VectorIndexError,\n  VectorIndexErrorCode,\n  type EmbeddingInput,\n  type EnrichedSearchResult,\n  type IndexMemoryParams,\n  type MemoryRow,\n  type VectorSearchOptions as LegacyVectorSearchOptions,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Vector Store\n// -------------------------------------------------------------------\n\nimport { IVectorStore } from '../../interfaces/vector-store.js';\nimport {\n  activeVectorSource,\n  close_db,\n  get_embedding_dim,\n  initialize_db,\n  sqlite_vec_available,\n} from '../../search/vector-index-store.js';\nimport {\n  VectorIndexError,\n  VectorIndexErrorCode,\n  type EmbeddingInput,\n  type EnrichedSearchResult,\n  type IndexMemoryParams,\n  type MemoryRow,\n  type VectorSearchOptions as LegacyVectorSearchOptions,\n} from '../../search/vector-index-types.js';\n\nimport type { Awaitable, StorageId } from './common.js';\nimport type Database from 'better-sqlite3';\n\ntype JsonObject = Record<string, unknown>;\n\ninterface BetterSqliteVectorStoreOptions {\n  readonly dbPath?: string;\n}\n\ntype EnhancedSearchOptions = {\n  specFolder?: string | null;\n  minSimilarity?: number;\n  diversityFactor?: number;\n  noDiversity?: boolean;\n};\n\nlet cachedQueries: Awaited<typeof import('../../search/vector-index-queries.js')> | null = null;\nlet cachedMutations: Awaited<typeof import('../../search/vector-index-mutations.js')> | null = null;\nlet cachedAliases: Awaited<typeof import('../../search/vector-index-aliases.js')> | null = null;\n\nasync function getQueriesModule(): Promise<Awaited<typeof import('../../search/vector-index-queries.js')>> {\n  return cachedQueries ??= await import('../../search/vector-index-queries.js');\n}\n\nasync function getMutationsModule(): Promise<Awaited<typeof import('../../search/vector-index-mutations.js')>> {\n  return cachedMutations ??= await import('../../search/vector-index-mutations.js');\n}\n\nasync function getAliasesModule(): Promise<Awaited<typeof import('../../search/vector-index-aliases.js')>> {\n  return cachedAliases ??= await import('../../search/vector-index-aliases.js');\n}\n\n/** Metadata attached to a vector record. */\nexport type VectorMetadata = Readonly<Record<string, unknown>>;\n\n/** Persisted vector entry. */\nexport interface VectorRecord<TMetadata extends VectorMetadata = VectorMetadata> {\n  readonly id: StorageId;\n  readonly embedding: readonly number[] | Float32Array;\n  readonly metadata: TMetadata;\n}\n\n/** Ranked vector search hit. */\nexport interface VectorSearchResult<TMetadata extends VectorMetadata = VectorMetadata> {\n  readonly id: StorageId;\n  readonly score: number;\n  readonly metadata: TMetadata;\n}\n\n/** Query options for vector nearest-neighbor retrieval. */\nexport interface VectorSearchOptions {\n  readonly limit: number;\n  readonly minScore?: number;\n}\n\n/** Port for vector persistence and similarity retrieval. */\nexport interface VectorStore<TMetadata extends VectorMetadata = VectorMetadata> {\n  /** Insert or replace one vector record. */\n  upsert(record: VectorRecord<TMetadata>): Awaitable<void>;\n\n  /** Remove one vector record. */\n  delete(id: StorageId): Awaitable<boolean>;\n\n  /** Fetch one vector record by ID. */\n  get(id: StorageId): Awaitable<VectorRecord<TMetadata> | null>;\n\n  /** Return ranked vector matches for a query embedding. */\n  search(\n    embedding: readonly number[] | Float32Array,\n    options: VectorSearchOptions,\n  ): Awaitable<VectorSearchResult<TMetadata>[]>;\n\n  /** Remove all vector records. */\n  clear(): Awaitable<void>;\n}\n\n/** better-sqlite3-backed vector-store adapter. */\nexport class BetterSqliteVectorStore<TMetadata extends VectorMetadata = VectorMetadata>\n  extends IVectorStore\n  implements VectorStore<TMetadata> {\n  dbPath: string | null;\n  _initialized: boolean;\n\n  constructor(options: BetterSqliteVectorStoreOptions = {}) {\n    super();\n    this.dbPath = options.dbPath || null;\n    this._initialized = false;\n  }\n\n  _ensureInitialized(): void {\n    if (!this._initialized) {\n      this._getDatabase();\n      this._initialized = true;\n    }\n  }\n\n  _getDatabase(): Database.Database {\n    return initialize_db(this.dbPath);\n  }\n\n  search(\n    embedding: readonly number[] | Float32Array,\n    options: VectorSearchOptions,\n  ): Promise<VectorSearchResult<TMetadata>[]>;\n  search(\n    embedding: EmbeddingInput,\n    topK: number,\n    options?: LegacyVectorSearchOptions,\n  ): Promise<MemoryRow[]>;\n  async search(\n    embedding: EmbeddingInput,\n    optionsOrTopK: VectorSearchOptions | number,\n    options: LegacyVectorSearchOptions = {},\n  ): Promise<VectorSearchResult<TMetadata>[] | MemoryRow[]> {\n    if (typeof optionsOrTopK !== 'number') {\n      const rows = await this.search(embedding, optionsOrTopK.limit, {\n        minSimilarity: optionsOrTopK.minScore === undefined ? 0 : optionsOrTopK.minScore * 100,\n        includeConstitutional: false,\n      });\n      return rows.map((row) => ({\n        id: String(row.id),\n        score: typeof row.similarity === 'number' ? row.similarity / 100 : 0,\n        metadata: row as unknown as TMetadata,\n      }));\n    }\n\n    this._ensureInitialized();\n    const database = this._getDatabase();\n\n    const expected_dim = get_embedding_dim();\n    if (!embedding || embedding.length !== expected_dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${expected_dim}, got ${embedding?.length}`,\n        VectorIndexErrorCode.EMBEDDING_VALIDATION,\n      );\n    }\n\n    const search_options = {\n      limit: optionsOrTopK,\n      specFolder: options.specFolder,\n      minSimilarity: options.minSimilarity || 0,\n      useDecay: options.useDecay !== false,\n      tier: options.tier,\n      contextType: options.contextType,\n      includeConstitutional: options.includeConstitutional !== false,\n      includeArchived: options.includeArchived === true\n    };\n\n    const { vector_search } = await getQueriesModule();\n    return vector_search(embedding, search_options, database);\n  }\n\n  upsert(record: VectorRecord<TMetadata>): Promise<void>;\n  upsert(id: string, embedding: EmbeddingInput, metadata: JsonObject): Promise<number>;\n  async upsert(\n    recordOrId: VectorRecord<TMetadata> | string,\n    embedding?: EmbeddingInput,\n    metadata?: JsonObject,\n  ): Promise<void | number> {\n    if (typeof recordOrId !== 'string') {\n      const recordEmbedding = recordOrId.embedding instanceof Float32Array\n        ? recordOrId.embedding\n        : Array.from(recordOrId.embedding);\n      await this.upsert(String(recordOrId.id), recordEmbedding, recordOrId.metadata);\n      return;\n    }\n\n    this._ensureInitialized();\n    const database = this._getDatabase();\n\n    const expected_dim = get_embedding_dim();\n    if (!embedding || embedding.length !== expected_dim) {\n      throw new VectorIndexError(\n        `Embedding dimension mismatch: expected ${expected_dim}, got ${embedding?.length}`,\n        VectorIndexErrorCode.EMBEDDING_VALIDATION,\n      );\n    }\n\n    const metadata_alias = (metadata ?? {}) as JsonObject & {\n      spec_folder?: string;\n      specFolder?: string;\n      file_path?: string;\n      filePath?: string;\n      anchor_id?: string;\n      anchorId?: string;\n      title?: string;\n      trigger_phrases?: string[];\n      triggerPhrases?: string[];\n      importance_weight?: number;\n      importanceWeight?: number;\n    };\n\n    const params: IndexMemoryParams = {\n      specFolder: metadata_alias.spec_folder || metadata_alias.specFolder || '',\n      filePath: metadata_alias.file_path || metadata_alias.filePath || '',\n      anchorId: metadata_alias.anchor_id || metadata_alias.anchorId || null,\n      title: metadata_alias.title || null,\n      triggerPhrases: metadata_alias.trigger_phrases || metadata_alias.triggerPhrases || [],\n      importanceWeight: metadata_alias.importance_weight ?? metadata_alias.importanceWeight ?? 0.5,\n      embedding: embedding\n    };\n\n    if (!params.specFolder || !params.filePath) {\n      throw new VectorIndexError(\n        'metadata must include spec_folder and file_path',\n        VectorIndexErrorCode.STORE_ERROR,\n      );\n    }\n\n    const { index_memory } = await getMutationsModule();\n    return index_memory(params, database);\n  }\n\n  async delete(id: StorageId): Promise<boolean> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { delete_memory } = await getMutationsModule();\n    return delete_memory(Number(id), database);\n  }\n\n  async get(id: StorageId): Promise<VectorRecord<TMetadata> | null>;\n  async get(id: number): Promise<MemoryRow | null>;\n  async get(id: StorageId): Promise<VectorRecord<TMetadata> | MemoryRow | null> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_memory } = await getQueriesModule();\n    const row = get_memory(Number(id), database);\n    if (!row) {\n      return null;\n    }\n    if (typeof id === 'number') {\n      return row;\n    }\n    const embedding = this.getEmbeddingForId(database, Number(row.id));\n    return {\n      id: row.id,\n      embedding,\n      metadata: row as unknown as TMetadata,\n    };\n  }\n\n  async clear(): Promise<void> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    database.transaction(() => {\n      database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')}`).run();\n      database.prepare('DELETE FROM active_memory_projection').run();\n      database.prepare('DELETE FROM memory_index').run();\n    })();\n  }\n\n  async getStats(): Promise<{ total: number; pending: number; success: number; failed: number; retry: number }> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_stats } = await getQueriesModule();\n    return get_stats(database);\n  }\n\n  isAvailable(): boolean {\n    return sqlite_vec_available();\n  }\n\n  getEmbeddingDimension(): number {\n    return get_embedding_dim();\n  }\n\n  async close(): Promise<void> {\n    if (this._initialized) {\n      close_db();\n      this._initialized = false;\n    }\n  }\n\n  async deleteByPath(specFolder: string, filePath: string, anchorId: string | null = null): Promise<boolean> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { delete_memory_by_path } = await getMutationsModule();\n    return delete_memory_by_path(specFolder, filePath, anchorId, database);\n  }\n\n  async getByFolder(specFolder: string): Promise<MemoryRow[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_memories_by_folder } = await getQueriesModule();\n    return get_memories_by_folder(specFolder, database);\n  }\n\n  async searchEnriched(\n    embedding: string,\n    options: { specFolder?: string | null; minSimilarity?: number } = {},\n  ): Promise<EnrichedSearchResult[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { vector_search_enriched } = await getQueriesModule();\n    return vector_search_enriched(embedding, undefined, options, database);\n  }\n\n  async enhancedSearch(embedding: string, options: EnhancedSearchOptions = {}): Promise<EnrichedSearchResult[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { enhanced_search } = await getAliasesModule();\n    return enhanced_search(embedding, undefined, options, database);\n  }\n\n  async getConstitutionalMemories(\n    options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n  ): Promise<MemoryRow[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_constitutional_memories_public } = await getQueriesModule();\n    return get_constitutional_memories_public(options, database);\n  }\n\n  async verifyIntegrity(\n    options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n  ): Promise<{\n    totalMemories: number;\n    totalVectors: number;\n    orphanedVectors: number;\n    missingVectors: number;\n    orphanedFiles: Array<{ id: number; file_path: string; reason: string }>;\n    orphanedChunks: number;\n    isConsistent: boolean;\n    cleaned?: { vectors: number; chunks: number; files: number };\n  }> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { verify_integrity } = await getQueriesModule();\n    return verify_integrity(options, database);\n  }\n\n  private getEmbeddingForId(database: Database.Database, id: number): Float32Array {\n    const row = database.prepare(`\n      SELECT embedding\n      FROM ${activeVectorSource('vec_memories')}\n      WHERE rowid = ?\n      LIMIT 1\n    `).get(BigInt(id)) as { embedding?: Buffer | Uint8Array } | undefined;","lineStart":1,"lineEnd":360,"totalLines":367,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts","time":{"start":1781144268153,"end":1781144268158}},"metadata":{"openai":{"itemId":"fc_0bcf1286b764a18f016a2a1acc21e48191961372a408dec87a"}},"id":"prt_eb478ad76001BG6vJzlZeNUWuZ","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb4786517001A2S4LeO3LbBSEC"}}
{"type":"tool_use","timestamp":1781144268337,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_unrVZIw3zUFSpXeMq6rBzfZ3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Backward-compatible export surface across split modules.\n6: \n7: export {\n8:   BetterSqliteVectorStore,\n9:   BetterSqliteVectorStore as SQLiteVectorStore,\n10: } from '../storage/ports/vector-store.js';\n11: export {\n12:   MAX_TRIGGERS_PER_MEMORY,\n13:   to_embedding_buffer,\n14:   parse_trigger_phrases,\n15:   get_error_message,\n16:   get_error_code,\n17: } from './vector-index-types.js';\n18: export type {\n19:   MemoryIndexRow,\n20:   MemoryScopeParams,\n21:   IndexMemoryParams,\n22:   UpdateMemoryParams,\n23:   VectorSearchOptions,\n24:   EnrichedSearchResult,\n25: } from './vector-index-types.js';\n26: export {\n27:   SCHEMA_VERSION,\n28:   run_migrations,\n29:   ensure_schema_version,\n30:   migrate_confidence_columns,\n31:   ensure_canonical_file_path_support,\n32:   migrate_constitutional_tier,\n33:   create_common_indexes,\n34:   ensureCompanionTables,\n35:   create_schema,\n36:   ensureSchemaVersion,\n37:   runMigrations,\n38:   createSchema,\n39:   createCommonIndexes,\n40:   migrateConfidenceColumns,\n41:   ensureCanonicalFilePathSupport,\n42:   migrateConstitutionalTier,\n43: } from './vector-index-schema.js';\n44: export {\n45:   index_memory,\n46:   index_memory_deferred,\n47:   update_memory,\n48:   delete_memory,\n49:   delete_memory_by_path,\n50:   delete_memories,\n51:   update_embedding_status,\n52:   update_confidence,\n53:   indexMemory,\n54:   indexMemoryDeferred,\n55:   updateMemory,\n56:   deleteMemory,\n57:   deleteMemoryByPath,\n58:   deleteMemories,\n59:   updateEmbeddingStatus,\n60:   updateConfidence,\n61: } from './vector-index-mutations.js';\n62: export {\n63:   get_memory,\n64:   get_memories_by_folder,\n65:   get_memory_count,\n66:   get_status_counts,\n67:   get_stats,\n68:   vector_search,\n69:   get_constitutional_memories_public,\n70:   multi_concept_search,\n71:   extract_title,\n72:   extract_snippet,\n73:   extract_tags,\n74:   extract_date,\n75:   generate_query_embedding,\n76:   keyword_search,\n77:   vector_search_enriched,\n78:   multi_concept_search_enriched,\n79:   multi_concept_keyword_search,\n80:   parse_quoted_terms,\n\n(Showing lines 1-80 of 178. Use offset=81 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature cata