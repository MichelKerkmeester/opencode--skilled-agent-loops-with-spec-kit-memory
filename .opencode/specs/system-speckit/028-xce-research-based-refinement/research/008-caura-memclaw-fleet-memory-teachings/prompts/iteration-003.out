{"type":"text","timestamp":1780727690719,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"id":"prt_e9ba407b3001oCVGTgH4QCJjNF","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","type":"text","text":"Initial evidence shows MemClaw’s governance is explicitly fleet-oriented: tenant isolation, stamped visibility scopes, four agent trust tiers, PII quarantine, suppression mirroring, and append-only audit models. I’m checking implementation details now for enforcement lines rather than relying on README claims.","time":{"start":1780727678899,"end":1780727690717},"metadata":{"openai":{"itemId":"msg_0b30a93f3b98d370016a23bf7edda08191bdcfbc404e3565a8","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780727690810,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_glzmVarsqeYcSBwnblZXB8zS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/standalone_tenant.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/standalone_tenant.py</path>\n<type>file</type>\n<content>\n1: \"\"\"ASGI middleware that injects tenant_id into requests when running in standalone mode.\"\"\"\n2: \n3: import json\n4: from urllib.parse import parse_qs, urlencode\n5: \n6: from core_api.standalone import get_standalone_tenant_id\n7: \n8: \n9: class StandaloneTenantMiddleware:\n10:     \"\"\"When IS_STANDALONE=true and tenant_id is missing, inject it into query string and JSON body.\"\"\"\n11: \n12:     def __init__(self, app):\n13:         self.app = app\n14: \n15:     async def __call__(self, scope, receive, send):\n16:         if scope[\"type\"] != \"http\":\n17:             await self.app(scope, receive, send)\n18:             return\n19: \n20:         tenant_id = get_standalone_tenant_id()\n21:         if not tenant_id:\n22:             await self.app(scope, receive, send)\n23:             return\n24: \n25:         # Don't inject into paths where tenant_id has a different semantic\n26:         path = scope.get(\"path\", \"\")\n27:         if path.startswith(\n28:             (\n29:                 \"/api/auth/\",\n30:                 \"/api/orgs/\",\n31:                 \"/api/admin/\",\n32:                 \"/api/register\",\n33:                 \"/api/superadmin/\",\n34:                 \"/api/billing/webhook\",\n35:             )\n36:         ):\n37:             await self.app(scope, receive, send)\n38:             return\n39: \n40:         # Don't inject for superadmin sessions (they may intentionally omit tenant_id)\n41:         headers_list = scope.get(\"headers\", [])\n42:         for name, value in headers_list:\n43:             if name.lower() == b\"authorization\":\n44:                 auth_val = value.decode(\"latin-1\", errors=\"ignore\")\n45:                 if auth_val.startswith(\"Bearer \"):\n46:                     try:\n47:                         from jose import jwt as jose_jwt\n48: \n49:                         from core_api.config import settings as _settings\n50: \n51:                         token = auth_val[7:]  # strip \"Bearer \"\n52:                         payload = jose_jwt.decode(\n53:                             token,\n54:                             _settings.jwt_secret,\n55:                             algorithms=[\"HS256\"],\n56:                             options={\"verify_exp\": False},\n57:                         )\n58:                         if payload.get(\"super_admin\"):\n59:                             await self.app(scope, receive, send)\n60:                             return\n61:                     except Exception:\n62:                         pass\n63:                 break\n64: \n65:         # Inject tenant_id into query string if missing\n66:         qs = scope.get(\"query_string\", b\"\")\n67:         if b\"tenant_id=\" not in qs:\n68:             params = parse_qs(qs.decode(), keep_blank_values=True)\n69:             params[\"tenant_id\"] = [tenant_id]\n70:             scope = dict(scope, query_string=urlencode(params, doseq=True).encode())\n71: \n72:         # Inject tenant_id into JSON body if missing (POST/PUT/PATCH with JSON content only)\n73:         method = scope.get(\"method\", \"\")\n74:         if method in (\"POST\", \"PUT\", \"PATCH\"):\n75:             headers = scope.get(\"headers\", [])\n76:             content_type = \"\"\n77:             content_length = None\n78:             for name, value in headers:\n79:                 lower = name.lower()\n80:                 if lower == b\"content-type\":\n81:                     content_type = value.decode(\"latin-1\").split(\";\")[0].strip()\n82:                 elif lower == b\"content-length\":\n83:                     try:\n84:                         content_length = int(value)\n85:                     except (ValueError, TypeError):\n86:                         pass\n87:             can_inject = (\n88:                 content_type == \"application/json\"\n89:                 and content_length is not None\n90:                 and content_length <= _MAX_BODY_INJECT\n91:             )\n92:             if can_inject:\n93:                 body = await _read_body(receive)\n94:                 if len(body) <= _MAX_BODY_INJECT:\n95:                     try:\n96:                         data = json.loads(body)\n97:                         if isinstance(data, dict) and \"tenant_id\" not in data:\n98:                             data[\"tenant_id\"] = tenant_id\n99:                             body = json.dumps(data).encode()\n100:                     except (json.JSONDecodeError, UnicodeDecodeError):\n101:                         pass\n102:                 new_headers = [\n103:                     (n, str(len(body)).encode() if n.lower() == b\"content-length\" else v) for n, v in headers\n104:                 ]\n105:                 scope = dict(scope, headers=new_headers)\n106:                 receive = _make_receive(body)\n107: \n108:         await self.app(scope, receive, send)\n109: \n110: \n111: _MAX_BODY_INJECT = 1_048_576  # 1 MiB — skip injection for larger payloads\n112: \n113: \n114: async def _read_body(receive) -> bytes:\n115:     \"\"\"Read the full request body from the ASGI receive callable.\"\"\"\n116:     chunks = []\n117:     while True:\n118:         message = await receive()\n119:         chunks.append(message.get(\"body\", b\"\"))\n120:         if not message.get(\"more_body\", False):\n121:             break\n122:     return b\"\".join(chunks)\n123: \n124: \n125: def _make_receive(body: bytes):\n126:     \"\"\"Create a receive callable that returns the given body.\"\"\"\n127:     sent = False\n128: \n129:     async def receive():\n130:         nonlocal sent\n131:         if not sent:\n132:             sent = True\n133:             return {\"type\": \"http.request\", \"body\": body, \"more_body\": False}\n134:         return {\"type\": \"http.disconnect\"}\n135: \n136:     return receive\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"\"\"\"ASGI middleware that injects tenant_id into requests when running in standalone mode.\"\"\"\n\nimport json\nfrom urllib.parse import parse_qs, urlencode\n\nfrom core_api.standalone import get_standalone_tenant_id\n\n\nclass StandaloneTenantMiddleware:\n    \"\"\"When IS_STANDALONE=true and tenant_id is missing, inject it into query string and JSON body.\"\"\"\n\n    def __init__(self, app):\n        self.app = app\n\n    async def __call__(self, scope, receive, send):\n        if scope[\"type\"] != \"http\":\n            await self.app(scope, receive, send)\n            return\n\n        tenant_id = get_standalone_tenant_id()","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/standalone_tenant.py","text":"\"\"\"ASGI middleware that injects tenant_id into requests when running in standalone mode.\"\"\"\n\nimport json\nfrom urllib.parse import parse_qs, urlencode\n\nfrom core_api.standalone import get_standalone_tenant_id\n\n\nclass StandaloneTenantMiddleware:\n    \"\"\"When IS_STANDALONE=true and tenant_id is missing, inject it into query string and JSON body.\"\"\"\n\n    def __init__(self, app):\n        self.app = app\n\n    async def __call__(self, scope, receive, send):\n        if scope[\"type\"] != \"http\":\n            await self.app(scope, receive, send)\n            return\n\n        tenant_id = get_standalone_tenant_id()\n        if not tenant_id:\n            await self.app(scope, receive, send)\n            return\n\n        # Don't inject into paths where tenant_id has a different semantic\n        path = scope.get(\"path\", \"\")\n        if path.startswith(\n            (\n                \"/api/auth/\",\n                \"/api/orgs/\",\n                \"/api/admin/\",\n                \"/api/register\",\n                \"/api/superadmin/\",\n                \"/api/billing/webhook\",\n            )\n        ):\n            await self.app(scope, receive, send)\n            return\n\n        # Don't inject for superadmin sessions (they may intentionally omit tenant_id)\n        headers_list = scope.get(\"headers\", [])\n        for name, value in headers_list:\n            if name.lower() == b\"authorization\":\n                auth_val = value.decode(\"latin-1\", errors=\"ignore\")\n                if auth_val.startswith(\"Bearer \"):\n                    try:\n                        from jose import jwt as jose_jwt\n\n                        from core_api.config import settings as _settings\n\n                        token = auth_val[7:]  # strip \"Bearer \"\n                        payload = jose_jwt.decode(\n                            token,\n                            _settings.jwt_secret,\n                            algorithms=[\"HS256\"],\n                            options={\"verify_exp\": False},\n                        )\n                        if payload.get(\"super_admin\"):\n                            await self.app(scope, receive, send)\n                            return\n                    except Exception:\n                        pass\n                break\n\n        # Inject tenant_id into query string if missing\n        qs = scope.get(\"query_string\", b\"\")\n        if b\"tenant_id=\" not in qs:\n            params = parse_qs(qs.decode(), keep_blank_values=True)\n            params[\"tenant_id\"] = [tenant_id]\n            scope = dict(scope, query_string=urlencode(params, doseq=True).encode())\n\n        # Inject tenant_id into JSON body if missing (POST/PUT/PATCH with JSON content only)\n        method = scope.get(\"method\", \"\")\n        if method in (\"POST\", \"PUT\", \"PATCH\"):\n            headers = scope.get(\"headers\", [])\n            content_type = \"\"\n            content_length = None\n            for name, value in headers:\n                lower = name.lower()\n                if lower == b\"content-type\":\n                    content_type = value.decode(\"latin-1\").split(\";\")[0].strip()\n                elif lower == b\"content-length\":\n                    try:\n                        content_length = int(value)\n                    except (ValueError, TypeError):\n                        pass\n            can_inject = (\n                content_type == \"application/json\"\n                and content_length is not None\n                and content_length <= _MAX_BODY_INJECT\n            )\n            if can_inject:\n                body = await _read_body(receive)\n                if len(body) <= _MAX_BODY_INJECT:\n                    try:\n                        data = json.loads(body)\n                        if isinstance(data, dict) and \"tenant_id\" not in data:\n                            data[\"tenant_id\"] = tenant_id\n                            body = json.dumps(data).encode()\n                    except (json.JSONDecodeError, UnicodeDecodeError):\n                        pass\n                new_headers = [\n                    (n, str(len(body)).encode() if n.lower() == b\"content-length\" else v) for n, v in headers\n                ]\n                scope = dict(scope, headers=new_headers)\n                receive = _make_receive(body)\n\n        await self.app(scope, receive, send)\n\n\n_MAX_BODY_INJECT = 1_048_576  # 1 MiB — skip injection for larger payloads\n\n\nasync def _read_body(receive) -> bytes:\n    \"\"\"Read the full request body from the ASGI receive callable.\"\"\"\n    chunks = []\n    while True:\n        message = await receive()\n        chunks.append(message.get(\"body\", b\"\"))\n        if not message.get(\"more_body\", False):\n            break\n    return b\"\".join(chunks)\n\n\ndef _make_receive(body: bytes):\n    \"\"\"Create a receive callable that returns the given body.\"\"\"\n    sent = False\n\n    async def receive():\n        nonlocal sent\n        if not sent:\n            sent = True\n            return {\"type\": \"http.request\", \"body\": body, \"more_body\": False}\n        return {\"type\": \"http.disconnect\"}\n\n    return receive","lineStart":1,"lineEnd":136,"totalLines":136,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/standalone_tenant.py","time":{"start":1780727690785,"end":1780727690806}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa7788191b13f80c3fe2cb580"}},"id":"prt_e9ba43620001lC171MzJzwcCJD","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727690811,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_GwKCNuhCS1gOQm1re7TEJhqO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/per_tenant_concurrency.py","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/per_tenant_concurrency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Per-tenant in-flight concurrency caps — two-layer bulkhead.\n2: \n3: The slowapi-based ``rate_limit`` middleware bounds request *rate*. A\n4: single tenant burst can still occupy every worker slot in a container\n5: and starve other tenants — exactly the noisy-neighbor pattern the\n6: loadtest harness flagged.\n7: \n8: Two caps compose:\n9: \n10: 1. **Route-entry slot** (``\"write\"`` / ``\"search\"``, PR #33). Held for\n11:    the whole request lifecycle — embed + enrich + storage. Acquire\n12:    timeout is short (``per_tenant_acquire_timeout_seconds`` ≈ 50ms);\n13:    fails fast with 429 so a saturated tenant can't queue forever.\n14:    Bounds end-to-end concurrency.\n15: \n16: 2. **Storage-call slot** (``\"storage_write\"`` / ``\"storage_search\"``,\n17:    CAURA-602 follow-up). Held only across the storage roundtrip itself.\n18:    Acquire is unbounded — the outer request budget already caps how\n19:    long the wait can run, and queueing here is the *intended* shape\n20:    (a tenant in the embed phase doesn't hold a storage connection).\n21:    Bounds storage-pool occupancy per tenant — keeps a hot tenant from\n22:    parking every storage-writer connection on a 20-item bulk while\n23:    tenant B waits to write a single row.\n24: \n25: State is per-process. With cap ``N`` and Cloud Run ``max_instances``\n26: ``M``, the fleet-wide cap is ``N * M`` — size in concert with\n27: ``containerConcurrency`` and the storage-writer pool size.\n28: \"\"\"\n29: \n30: from __future__ import annotations\n31: \n32: import asyncio\n33: import logging\n34: from collections.abc import AsyncIterator\n35: from contextlib import asynccontextmanager\n36: from typing import Literal\n37: \n38: from fastapi import HTTPException\n39: \n40: from core_api.config import settings\n41: \n42: logger = logging.getLogger(__name__)\n43: \n44: Scope = Literal[\"write\", \"search\", \"storage_write\", \"storage_search\"]\n45: \n46: # Per-(scope, tenant) state. Read-modify-write of ``_TENANT_SEMAPHORES``\n47: # in ``_get_semaphore`` is safe without a lock because asyncio runs one\n48: # coroutine at a time on a single event loop and neither ``dict.get``\n49: # nor ``dict.__setitem__`` await — no other task can interleave between\n50: # the miss and the install.\n51: _TENANT_SEMAPHORES: dict[tuple[Scope, str], asyncio.Semaphore] = {}\n52: \n53: \n54: def _cap_for(scope: Scope) -> int:\n55:     \"\"\"Resolve the configured cap for ``scope`` from ``Settings``.\n56: \n57:     Centralised so callers can't drift — the cap is baked into the\n58:     Semaphore at creation time, so a per-call ``cap`` argument would\n59:     silently bind to the first call's value and ignore subsequent\n60:     setting changes.\n61:     \"\"\"\n62:     if scope == \"write\":\n63:         return settings.per_tenant_write_concurrency\n64:     if scope == \"search\":\n65:         return settings.per_tenant_search_concurrency\n66:     if scope == \"storage_write\":\n67:         return settings.per_tenant_storage_write_concurrency\n68:     if scope == \"storage_search\":\n69:         return settings.per_tenant_storage_search_concurrency\n70:     # ``Scope`` already enumerates every valid literal; this is a\n71:     # belt-and-suspenders guard for a future scope added to the type\n72:     # without updating the cap resolver. Without it, ``_get_semaphore``\n73:     # would silently install a Semaphore at the wrong cap and the\n74:     # mistake would only surface as anomalous 429 / queue behaviour\n75:     # under load.\n76:     raise ValueError(f\"Unknown concurrency scope: {scope!r}\")\n77: \n78: \n79: def _get_semaphore(scope: Scope, tenant_id: str) -> asyncio.Semaphore:\n80:     \"\"\"Return (and lazily create) the semaphore for ``(scope, tenant_id)``.\n81: \n82:     The dict grows monotonically with the set of tenants the instance\n83:     has seen — bounded by the active tenant count, never reset within\n84:     a process lifetime.\n85:     \"\"\"\n86:     key = (scope, tenant_id)\n87:     sem = _TENANT_SEMAPHORES.get(key)\n88:     if sem is None:\n89:         sem = asyncio.Semaphore(_cap_for(scope))\n90:         _TENANT_SEMAPHORES[key] = sem\n91:     return sem\n92: \n93: \n94: @asynccontextmanager\n95: async def per_tenant_slot(\n96:     scope: Literal[\"write\", \"search\"],\n97:     tenant_id: str,\n98: ) -> AsyncIterator[None]:\n99:     \"\"\"Acquire one of the per-tenant slots for ``scope``, or raise 429\n100:     fast.\n101: \n102:     Cap is read from ``Settings`` (``per_tenant_write_concurrency`` /\n103:     ``per_tenant_search_concurrency``) at semaphore-creation time.\n104:     Use as a context manager around the request handler body. Releases\n105:     on exit (success or exception) so a handler raising 5xx still\n106:     frees the slot.\n107: \n108:     The ``scope`` parameter is narrowed to the route-entry literals\n109:     only — the deeper ``\"storage_*\"`` scopes have different semantics\n110:     (unbounded queue) and live behind :func:`per_tenant_storage_slot`.\n111:     Passing a storage scope here would create a fast-fail 429\n112:     semaphore against the same ``(scope, tenant_id)`` key that the\n113:     storage variant uses, with no warning; the type-checker rejects\n114:     that mistake instead.\n115:     \"\"\"\n116:     sem = _get_semaphore(scope, tenant_id)\n117:     try:\n118:         async with asyncio.timeout(settings.per_tenant_acquire_timeout_seconds):\n119:             await sem.acquire()\n120:     except TimeoutError:\n121:         logger.info(\n122:             \"per-tenant concurrency cap reached\",\n123:             extra={\"scope\": scope, \"tenant_id\": tenant_id, \"cap\": _cap_for(scope)},\n124:         )\n125:         raise HTTPException(\n126:             status_code=429,\n127:             detail=f\"Too many concurrent {scope} requests; retry shortly.\",\n128:         )\n129:     try:\n130:         yield\n131:     finally:\n132:         sem.release()\n133: \n134: \n135: @asynccontextmanager\n136: async def per_tenant_storage_slot(\n137:     scope: Literal[\"storage_write\", \"storage_search\"],\n138:     tenant_id: str,\n139: ) -> AsyncIterator[None]:\n140:     \"\"\"Acquire a per-tenant slot scoped to the storage roundtrip itself.\n141: \n142:     Caller wraps a single ``sc.<call>`` invocation; the slot is held\n143:     only while the storage call is in flight, freeing as soon as the\n144:     response (or its cancellation) returns. Acquisition queues\n145:     unboundedly — the outer request budget (``RequestTimeoutMiddleware``\n146:     or the bulk route's ``asyncio.wait_for``) already caps total wall\n147:     time, and the request slot was already approved at route entry, so\n148:     a second fast-fail here would surface as a confusing 429-after-200.\n149: \n150:     Tenant-A storm scenario: A's writes occupy ``cap`` storage slots;\n151:     A's request 5+ queues on ``sem.acquire()``. Tenant B's write enters\n152:     on a different ``(scope, tenant_id)`` key, gets its own semaphore\n153:     with full capacity, and proceeds at baseline latency. The\n154:     storage-writer connection pool stays multi-tenant.\n155:     \"\"\"\n156:     sem = _get_semaphore(scope, tenant_id)\n157:     # Pre-acquire saturation log: queueing is the *intended* shape (the\n158:     # outer request budget caps wait time), but with no signal here a\n159:     # tenant whose storage writes are backing up generates zero\n160:     # observable evidence — operators just see elevated end-to-end\n161:     # latency with no log to localise the source. DEBUG-level so it\n162:     # doesn't drown low-traffic environments under steady-state load\n163:     # but stays grep-able when investigating a latency spike. Pair with\n164:     # the route-entry slot's INFO-level \"cap reached\" log (which fires\n165:     # on the fast-fail 429 path) for full observability across both\n166:     # layers.\n167:     if sem.locked():\n168:         logger.debug(\n169:             \"per-tenant storage slot saturated; queuing\",\n170:             extra={\"scope\": scope, \"tenant_id\": tenant_id, \"cap\": _cap_for(scope)},\n171:         )\n172:     await sem.acquire()\n173:     try:\n174:         yield\n175:     finally:\n176:         sem.release()\n177: \n178: \n179: def _reset_for_tests() -> None:\n180:     \"\"\"Drop all tracked semaphores. Test-only — production never calls\n181:     this.\"\"\"\n182:     _TENANT_SEMAPHORES.clear()\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"\"\"\"Per-tenant in-flight concurrency caps — two-layer bulkhead.\n\nThe slowapi-based ``rate_limit`` middleware bounds request *rate*. A\nsingle tenant burst can still occupy every worker slot in a container\nand starve other tenants — exactly the noisy-neighbor pattern the\nloadtest harness flagged.\n\nTwo caps compose:\n\n1. **Route-entry slot** (``\"write\"`` / ``\"search\"``, PR #33). Held for\n   the whole request lifecycle — embed + enrich + storage. Acquire\n   timeout is short (``per_tenant_acquire_timeout_seconds`` ≈ 50ms);\n   fails fast with 429 so a saturated tenant can't queue forever.\n   Bounds end-to-end concurrency.\n\n2. **Storage-call slot** (``\"storage_write\"`` / ``\"storage_search\"``,\n   CAURA-602 follow-up). Held only across the storage roundtrip itself.\n   Acquire is unbounded — the outer request budget already caps how\n   long the wait can run, and queueing here is the *intended* shape\n   (a tenant in the embed phase doesn't hold a storage connection).","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/per_tenant_concurrency.py","text":"\"\"\"Per-tenant in-flight concurrency caps — two-layer bulkhead.\n\nThe slowapi-based ``rate_limit`` middleware bounds request *rate*. A\nsingle tenant burst can still occupy every worker slot in a container\nand starve other tenants — exactly the noisy-neighbor pattern the\nloadtest harness flagged.\n\nTwo caps compose:\n\n1. **Route-entry slot** (``\"write\"`` / ``\"search\"``, PR #33). Held for\n   the whole request lifecycle — embed + enrich + storage. Acquire\n   timeout is short (``per_tenant_acquire_timeout_seconds`` ≈ 50ms);\n   fails fast with 429 so a saturated tenant can't queue forever.\n   Bounds end-to-end concurrency.\n\n2. **Storage-call slot** (``\"storage_write\"`` / ``\"storage_search\"``,\n   CAURA-602 follow-up). Held only across the storage roundtrip itself.\n   Acquire is unbounded — the outer request budget already caps how\n   long the wait can run, and queueing here is the *intended* shape\n   (a tenant in the embed phase doesn't hold a storage connection).\n   Bounds storage-pool occupancy per tenant — keeps a hot tenant from\n   parking every storage-writer connection on a 20-item bulk while\n   tenant B waits to write a single row.\n\nState is per-process. With cap ``N`` and Cloud Run ``max_instances``\n``M``, the fleet-wide cap is ``N * M`` — size in concert with\n``containerConcurrency`` and the storage-writer pool size.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nfrom collections.abc import AsyncIterator\nfrom contextlib import asynccontextmanager\nfrom typing import Literal\n\nfrom fastapi import HTTPException\n\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\nScope = Literal[\"write\", \"search\", \"storage_write\", \"storage_search\"]\n\n# Per-(scope, tenant) state. Read-modify-write of ``_TENANT_SEMAPHORES``\n# in ``_get_semaphore`` is safe without a lock because asyncio runs one\n# coroutine at a time on a single event loop and neither ``dict.get``\n# nor ``dict.__setitem__`` await — no other task can interleave between\n# the miss and the install.\n_TENANT_SEMAPHORES: dict[tuple[Scope, str], asyncio.Semaphore] = {}\n\n\ndef _cap_for(scope: Scope) -> int:\n    \"\"\"Resolve the configured cap for ``scope`` from ``Settings``.\n\n    Centralised so callers can't drift — the cap is baked into the\n    Semaphore at creation time, so a per-call ``cap`` argument would\n    silently bind to the first call's value and ignore subsequent\n    setting changes.\n    \"\"\"\n    if scope == \"write\":\n        return settings.per_tenant_write_concurrency\n    if scope == \"search\":\n        return settings.per_tenant_search_concurrency\n    if scope == \"storage_write\":\n        return settings.per_tenant_storage_write_concurrency\n    if scope == \"storage_search\":\n        return settings.per_tenant_storage_search_concurrency\n    # ``Scope`` already enumerates every valid literal; this is a\n    # belt-and-suspenders guard for a future scope added to the type\n    # without updating the cap resolver. Without it, ``_get_semaphore``\n    # would silently install a Semaphore at the wrong cap and the\n    # mistake would only surface as anomalous 429 / queue behaviour\n    # under load.\n    raise ValueError(f\"Unknown concurrency scope: {scope!r}\")\n\n\ndef _get_semaphore(scope: Scope, tenant_id: str) -> asyncio.Semaphore:\n    \"\"\"Return (and lazily create) the semaphore for ``(scope, tenant_id)``.\n\n    The dict grows monotonically with the set of tenants the instance\n    has seen — bounded by the active tenant count, never reset within\n    a process lifetime.\n    \"\"\"\n    key = (scope, tenant_id)\n    sem = _TENANT_SEMAPHORES.get(key)\n    if sem is None:\n        sem = asyncio.Semaphore(_cap_for(scope))\n        _TENANT_SEMAPHORES[key] = sem\n    return sem\n\n\n@asynccontextmanager\nasync def per_tenant_slot(\n    scope: Literal[\"write\", \"search\"],\n    tenant_id: str,\n) -> AsyncIterator[None]:\n    \"\"\"Acquire one of the per-tenant slots for ``scope``, or raise 429\n    fast.\n\n    Cap is read from ``Settings`` (``per_tenant_write_concurrency`` /\n    ``per_tenant_search_concurrency``) at semaphore-creation time.\n    Use as a context manager around the request handler body. Releases\n    on exit (success or exception) so a handler raising 5xx still\n    frees the slot.\n\n    The ``scope`` parameter is narrowed to the route-entry literals\n    only — the deeper ``\"storage_*\"`` scopes have different semantics\n    (unbounded queue) and live behind :func:`per_tenant_storage_slot`.\n    Passing a storage scope here would create a fast-fail 429\n    semaphore against the same ``(scope, tenant_id)`` key that the\n    storage variant uses, with no warning; the type-checker rejects\n    that mistake instead.\n    \"\"\"\n    sem = _get_semaphore(scope, tenant_id)\n    try:\n        async with asyncio.timeout(settings.per_tenant_acquire_timeout_seconds):\n            await sem.acquire()\n    except TimeoutError:\n        logger.info(\n            \"per-tenant concurrency cap reached\",\n            extra={\"scope\": scope, \"tenant_id\": tenant_id, \"cap\": _cap_for(scope)},\n        )\n        raise HTTPException(\n            status_code=429,\n            detail=f\"Too many concurrent {scope} requests; retry shortly.\",\n        )\n    try:\n        yield\n    finally:\n        sem.release()\n\n\n@asynccontextmanager\nasync def per_tenant_storage_slot(\n    scope: Literal[\"storage_write\", \"storage_search\"],\n    tenant_id: str,\n) -> AsyncIterator[None]:\n    \"\"\"Acquire a per-tenant slot scoped to the storage roundtrip itself.\n\n    Caller wraps a single ``sc.<call>`` invocation; the slot is held\n    only while the storage call is in flight, freeing as soon as the\n    response (or its cancellation) returns. Acquisition queues\n    unboundedly — the outer request budget (``RequestTimeoutMiddleware``\n    or the bulk route's ``asyncio.wait_for``) already caps total wall\n    time, and the request slot was already approved at route entry, so\n    a second fast-fail here would surface as a confusing 429-after-200.\n\n    Tenant-A storm scenario: A's writes occupy ``cap`` storage slots;\n    A's request 5+ queues on ``sem.acquire()``. Tenant B's write enters\n    on a different ``(scope, tenant_id)`` key, gets its own semaphore\n    with full capacity, and proceeds at baseline latency. The\n    storage-writer connection pool stays multi-tenant.\n    \"\"\"\n    sem = _get_semaphore(scope, tenant_id)\n    # Pre-acquire saturation log: queueing is the *intended* shape (the\n    # outer request budget caps wait time), but with no signal here a\n    # tenant whose storage writes are backing up generates zero\n    # observable evidence — operators just see elevated end-to-end\n    # latency with no log to localise the source. DEBUG-level so it\n    # doesn't drown low-traffic environments under steady-state load\n    # but stays grep-able when investigating a latency spike. Pair with\n    # the route-entry slot's INFO-level \"cap reached\" log (which fires\n    # on the fast-fail 429 path) for full observability across both\n    # layers.\n    if sem.locked():\n        logger.debug(\n            \"per-tenant storage slot saturated; queuing\",\n            extra={\"scope\": scope, \"tenant_id\": tenant_id, \"cap\": _cap_for(scope)},\n        )\n    await sem.acquire()\n    try:\n        yield\n    finally:\n        sem.release()\n\n\ndef _reset_for_tests() -> None:\n    \"\"\"Drop all tracked semaphores. Test-only — production never calls\n    this.\"\"\"\n    _TENANT_SEMAPHORES.clear()","lineStart":1,"lineEnd":182,"totalLines":182,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/per_tenant_concurrency.py","time":{"start":1780727690794,"end":1780727690810}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa7808191a7784bfc94a64886"}},"id":"prt_e9ba43622001cwxthxNfcIlVCs","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727690824,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_d76ZF4YJgQJiIDSJWbbuioA8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/rate_limit.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/rate_limit.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Rate limiting — slowapi-backed, Redis-or-memory.\n2: \n3: Uses Redis (``settings.redis_url``) when configured — gives distributed\n4: enforcement across Cloud Run instances — and falls back to an\n5: in-process store otherwise so OSS standalone deployments work\n6: unchanged.\n7: \n8: Keying precedence: API key (preferred, stable across IPs) → remote IP.\n9: Per-tenant and per-agent-key keying is a follow-up (tracked separately);\n10: see the enterprise gateway nginx.conf per-IP limits for the current\n11: coarse fallback.\n12: \n13: Exported decorators are applied surgically to the hot-path routes that\n14: the loadtest showed as unprotected:\n15: \n16: - ``write_limit`` — POST /memories, POST /documents\n17: - ``write_bulk_limit`` — POST /memories/bulk (stricter — 100x fanout)\n18: - ``search_limit`` — POST /search, POST /recall\n19: \"\"\"\n20: \n21: from __future__ import annotations\n22: \n23: import hashlib\n24: \n25: from fastapi import Request\n26: from slowapi import Limiter\n27: from slowapi.util import get_remote_address\n28: \n29: from core_api.config import settings\n30: \n31: # `limits` library storage URIs: \"memory://\", \"redis://host:port/db\".\n32: # An empty redis_url (OSS default) → memory store, single-instance only.\n33: _STORAGE_URI = settings.redis_url or \"memory://\"\n34: \n35: \n36: def _key_func(request: Request) -> str:\n37:     \"\"\"Rate-limit key. Prefers API key over IP so NAT'd agents don't\n38:     cannibalise each other's budget.\n39: \n40:     The API key is hashed so the full secret never lands in the\n41:     storage backend or access logs, while keeping buckets unique for\n42:     keys that happen to share a prefix.\n43:     \"\"\"\n44:     api_key = request.headers.get(\"x-api-key\")\n45:     if not api_key:\n46:         auth = request.headers.get(\"authorization\", \"\")\n47:         if auth.startswith(\"Bearer \"):\n48:             api_key = auth[len(\"Bearer \") :]\n49:     if api_key:\n50:         return f\"key:{hashlib.sha256(api_key.encode()).hexdigest()[:32]}\"\n51:     return f\"ip:{get_remote_address(request)}\"\n52: \n53: \n54: limiter = Limiter(\n55:     key_func=_key_func,\n56:     storage_uri=_STORAGE_URI,\n57:     # Redis outages degrade gracefully — requests pass through rather\n58:     # than all rate-limited routes returning 500.\n59:     swallow_errors=True,\n60:     # No default_limits — decorators are applied explicitly per-route.\n61:     # Avoids accidentally limiting /health, /version, /mcp, etc.\n62: )\n63: \n64: \n65: write_limit = limiter.limit(settings.rate_limit_write)\n66: write_bulk_limit = limiter.limit(settings.rate_limit_write_bulk)\n67: search_limit = limiter.limit(settings.rate_limit_search)\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"\"\"\"Rate limiting — slowapi-backed, Redis-or-memory.\n\nUses Redis (``settings.redis_url``) when configured — gives distributed\nenforcement across Cloud Run instances — and falls back to an\nin-process store otherwise so OSS standalone deployments work\nunchanged.\n\nKeying precedence: API key (preferred, stable across IPs) → remote IP.\nPer-tenant and per-agent-key keying is a follow-up (tracked separately);\nsee the enterprise gateway nginx.conf per-IP limits for the current\ncoarse fallback.\n\nExported decorators are applied surgically to the hot-path routes that\nthe loadtest showed as unprotected:\n\n- ``write_limit`` — POST /memories, POST /documents\n- ``write_bulk_limit`` — POST /memories/bulk (stricter — 100x fanout)\n- ``search_limit`` — POST /search, POST /recall\n\"\"\"\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/rate_limit.py","text":"\"\"\"Rate limiting — slowapi-backed, Redis-or-memory.\n\nUses Redis (``settings.redis_url``) when configured — gives distributed\nenforcement across Cloud Run instances — and falls back to an\nin-process store otherwise so OSS standalone deployments work\nunchanged.\n\nKeying precedence: API key (preferred, stable across IPs) → remote IP.\nPer-tenant and per-agent-key keying is a follow-up (tracked separately);\nsee the enterprise gateway nginx.conf per-IP limits for the current\ncoarse fallback.\n\nExported decorators are applied surgically to the hot-path routes that\nthe loadtest showed as unprotected:\n\n- ``write_limit`` — POST /memories, POST /documents\n- ``write_bulk_limit`` — POST /memories/bulk (stricter — 100x fanout)\n- ``search_limit`` — POST /search, POST /recall\n\"\"\"\n\nfrom __future__ import annotations\n\nimport hashlib\n\nfrom fastapi import Request\nfrom slowapi import Limiter\nfrom slowapi.util import get_remote_address\n\nfrom core_api.config import settings\n\n# `limits` library storage URIs: \"memory://\", \"redis://host:port/db\".\n# An empty redis_url (OSS default) → memory store, single-instance only.\n_STORAGE_URI = settings.redis_url or \"memory://\"\n\n\ndef _key_func(request: Request) -> str:\n    \"\"\"Rate-limit key. Prefers API key over IP so NAT'd agents don't\n    cannibalise each other's budget.\n\n    The API key is hashed so the full secret never lands in the\n    storage backend or access logs, while keeping buckets unique for\n    keys that happen to share a prefix.\n    \"\"\"\n    api_key = request.headers.get(\"x-api-key\")\n    if not api_key:\n        auth = request.headers.get(\"authorization\", \"\")\n        if auth.startswith(\"Bearer \"):\n            api_key = auth[len(\"Bearer \") :]\n    if api_key:\n        return f\"key:{hashlib.sha256(api_key.encode()).hexdigest()[:32]}\"\n    return f\"ip:{get_remote_address(request)}\"\n\n\nlimiter = Limiter(\n    key_func=_key_func,\n    storage_uri=_STORAGE_URI,\n    # Redis outages degrade gracefully — requests pass through rather\n    # than all rate-limited routes returning 500.\n    swallow_errors=True,\n    # No default_limits — decorators are applied explicitly per-route.\n    # Avoids accidentally limiting /health, /version, /mcp, etc.\n)\n\n\nwrite_limit = limiter.limit(settings.rate_limit_write)\nwrite_bulk_limit = limiter.limit(settings.rate_limit_write_bulk)\nsearch_limit = limiter.limit(settings.rate_limit_search)","lineStart":1,"lineEnd":67,"totalLines":67,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/rate_limit.py","time":{"start":1780727690803,"end":1780727690821}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa7888191816728787efeffc7"}},"id":"prt_e9ba4362c00105FBtDespFswD8","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727690840,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"grep","callID":"call_tO6VPQv113pYImzQZmVh17zP","state":{"status":"completed","input":{"pattern":"scope|tier|trust|suppress|audit|tenant|fleet|quarantine|pii","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main","include":"*.md"},"output":"Found 367 matches (showing first 100)\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/api-surfaces.md:\n  Line 16: | REST    | Web UI, ops dashboards, programmatic admins, scripted clients | Explicit `tenant_id` in body/query; API key + role gating; full operational vocabulary. |\n\n  Line 18: | OpenClaw plugin | Local plugin runtime that hosts agents | Operational concerns of the local install — heartbeat, agent registration, fleet readiness. Delegates business operations to MCP. |\n\n  Line 34: | Skill sharing | REST (`/documents` + `/documents/search` on `collection=\"skills\"`) + MCP (`memclaw_doc op=write\\|read\\|query\\|delete\\|search collection=skills`) | Skill sharing rides the generic document surface. Slugs (`doc_id`) are constrained to `^[a-z0-9][a-z0-9._-]{0,99}$` (filesystem-safe), and skills writes require `data[\"summary\"]` (with back-compat fallback to `data[\"description\"]`) so the catalog is semantic-searchable without ceremony. The dedicated `memclaw_share_skill`/`memclaw_unshare_skill` tools and `/skills/*` REST routes were dropped 2026-05; fleet auto-install (push to every node) is restored by Phase A's plugin-side reconciler. Trust ≥ 1 (inherited from `memclaw_doc`). |\n\n  Line 35: | Keystones (mandatory rules) | REST (`/memclaw/keystones`) + MCP (`memclaw_keystones` read, `memclaw_keystones_set` set\\|delete) | Governance policies that agents MUST obey — fetched deterministically (no semantic search) and injected into every session by the OpenClaw plugin. Storage lives in the system-managed `_keystones` collection on `documents`; the dedicated surface exists so the read tool stays discoverable in MCP `instructions` and the write surface can be trust-gated separately. Reads are open. Writes are tiered: a freshly-registered (trust ≥ 1) agent can author its own `scope=agent` rule — self-authored autonomy — but `scope=fleet`, `scope=tenant`, and cross-agent `scope=agent` stay at trust ≥ 2 so a default-trust agent (or a prompt-injected one) can't plant a tenant-wide rule. |\n\n  Line 36: | Tenant settings | REST only | Settings are a tenant-administrator concern; not safe for arbitrary agents to flip global config. |\n\n  Line 37: | Redistribute (mass reassign) | REST only | Destructive bulk op requires `trust_level >= 3`. Admin operation, not agent-driven. |\n\n  Line 40: | Heartbeat / fleet readiness | REST receives, plugin produces | Plugin is the natural producer (it knows the local node state). REST is the receiver. MCP doesn't need this — agents don't report their own runtime state. |\n\n  Line 51:    any agent that wants to introspect the store. Add freely; trust gate at\n\n  Line 52:    the same level as `memclaw_list` (≥ 1 for own scope, ≥ 2 for cross-agent).\n\n  Line 59:    trust-level enforcement consistent with the REST counterpart, and a wet\n\n  Line 87: - **Tenant resolution**: REST takes `body.tenant_id`; MCP infers from auth\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/performance.md:\n  Line 24: - **Token efficiency** — recall returns the relevant slice, not the full transcript. Token savings vs sending the full context to the LLM: 96–98% on the two benchmarks. That ratio is the bill at fleet scale.\n\n  Line 25: - **Governance correctness** — write a memory at the wrong scope and you've leaked data across teams. The retrieval surface enforces scope filtering by default; the audit log records every cross-scope read.\n\n  Line 31: - **Search latency** — p50 / p95 of `POST /search` against a warm cache, single-tenant load. Cold-cache p50 is higher; we publish warm because that's the steady-state condition under real load.\n\n  Line 38: - Does a new agent joining the fleet inherit what the fleet already knows, or start from zero?\n\n  Line 39: - Is a memory written by the sales fleet visible — or correctly invisible — to an agent in support?\n\n  Line 40: - Does cross-tenant data ever leak when the recall query is ambiguous?\n\n  Line 42: These are the questions that decide whether a memory system is deployable inside a company. MemClaw was designed around them — scoped memory (agent / fleet / cross-fleet), per-agent trust tiers, PII quarantine before cross-fleet exposure, full audit log, the `memclaw_evolve` → `memclaw_insights` outcome-propagation loop. **None of this moves a recall@k number. All of it moves whether you can deploy.**\n\n  Line 44: The field needs a benchmark for the fleet-shaped problem. We're working toward one. If you're thinking about this too, the [Discord](https://discord.com/invite/aNfpgfpj) is open.\n\n  Line 52: | Dimension | Why it matters at fleet scale |\n\n  Line 54: | Scoped memory (agent / fleet / cross-fleet) | A write at the wrong scope is a data leak across teams |\n\n  Line 55: | Per-agent trust tiers | Lets you trust some agents more than others without rewriting the recall path |\n\n  Line 56: | Cross-agent outcome propagation (`memclaw_evolve` → `memclaw_insights`) | One agent's mistake becomes a preventive rule the rest of the fleet sees before repeating it |\n\n  Line 57: | Latency at fleet load | 23 ms p50 search × millions of calls/day stays affordable; 250 ms doesn't |\n\n  Line 62: The published numbers are warm-cache, single-tenant, on our reference hardware. Before relying on them in capacity planning:\n\n  Line 66: - Audit `tenant_id` and `fleet_id` filtering on every recall path you care about; the test suite covers scope correctness, but your tenancy model is yours to validate.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/SECURITY.md:\n  Line 47: In scope:\n\n  Line 54: Out of scope:\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/SUPPORT.md:\n  Line 19: Open a [Feature request](https://github.com/caura-ai/caura-memclaw/issues/new?template=feature_request.yml). The form asks you to declare which surface from the SemVer contract the feature touches — this scopes the conversation early.\n\n  Line 21: Out-of-scope contributions get a polite decline with a pointer to the relevant section of [CONTRIBUTING.md](CONTRIBUTING.md). We don't merge features out of guilt; the issue thread is where to make the case before writing code.\n\n  Line 29: We aim to acknowledge every issue and PR within five business days — not necessarily with a fix or merge, but with a triage decision (accepted / needs-info / out-of-scope) so you know what's happening. If a week goes by without any response, ping the thread or open a Discussion — we'd rather be reminded than ghost you.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/RELEASING.md:\n  Line 47: ## Commit scope conventions\n\n  Line 50: with a scope when it helps:\n\n  Line 53: - `fix(core-api): handle null tenant_id in heartbeat`\n\n  Line 56: The scope is cosmetic — package routing is purely path-based. A commit\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/local-embedder.md:\n  Line 44: > or `MEMCLAW_API_KEY` instead, and add `tenant_id` matching your setup.\n\n  Line 49:   -d '{\"tenant_id\":\"default\",\"content\":\"smoke check for local embedder\"}'\n\n  Line 53:   -d '{\"tenant_id\":\"default\",\"query\":\"smoke check\",\"top_k\":5}'\n\n  Line 108: enough for a laptop, a small VM, or a single-tenant client. Numbers below are\n\n  Line 290: multi-tenant production cutovers prefer the event-driven path.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/plugin-upgrade.md:\n  Line 29: The **pre-manifest-aware floor** is the critical one for currently-deployed fleets. Plugins below the floor fetch source from their own hardcoded list set at release time. Any file the backend later adds (e.g. `keystones.ts`, statically imported by `context-engine.ts`) is never pulled, the post-deploy build completes but `dist/` imports a module that isn't on disk, and the plugin is **terminal** on the next OpenClaw restart. The gate prevents this; the manual path recovers from it.\n\n  Line 43:     \"fleet_id\":  \"your-fleet\",\n\n  Line 44:     \"tenant_id\": \"your-tenant\",\n\n  Line 57: When upgrading an existing install, read its current `.env` first and pass the values back so per-node identity (`tenant_id`, `node_name`, `fleet_id`, `api_key`) is preserved verbatim:\n\n  Line 75:         '{api_url:$u, api_key:$k, fleet_id:$f, tenant_id:$t, node_name:$n}')\" | bash\n\n  Line 78: Use this form when re-installing across an existing fleet — it preserves node identity end-to-end, so audit logs, fleet stats, and any per-node trust elevation stay intact.\n\n  Line 93: For operators with many nodes (and SSH or OpenClaw-agent reach to all of them), wrap the identity-preserving form in a loop over an inventory file. The enterprise repo ships a reference script at `scripts/reinstall-fleet.sh` that does exactly this — see its `--help` for inventory format and dry-run options.\n\n  Line 98: curl -s \"https://your-memclaw-server/api/v1/fleet/stats?tenant_id=$TENANT_ID&fleet_id=$FLEET_ID\" \\\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/docs/integration-without-plugin.md:\n  Line 7: > **One credential model.** Every API credential — tenant-scoped, agent-scoped, install, cross-tenant — uses the `mc_` prefix on the wire and lives in one underlying credential table. Scope is bound to the credential row at mint time, not encoded in the prefix. Pre-existing `mca_…` / `mci_…` keys continue to authenticate via back-compat; new mints all return `mc_…`.\n\n  Line 13: - A tenant-scoped `mc_` credential — get one from `memclaw.dev/settings/api-keys` (or self-host).\n\n  Line 18: ## 1. Mint an agent-scoped credential\n\n  Line 20: Every long-lived integration should bind to a named agent identity rather than calling under a tenant-scoped credential. Two ways:\n\n  Line 22: - **Dashboard (recommended for humans):** `memclaw.dev/settings/organization/api-credentials` — single-card wizard, one-time raw-key reveal, manages cross-tenant + read-scope settings.\n\n  Line 23: - **API (for scripted provisioning, shown below):** `POST /api/v1/admin/agent-keys/provision` — atomic call that creates the Agent row eagerly so subsequent trust-elevation or fleet-assignment endpoints work immediately:\n\n  Line 32:     \"initial_trust\": 1,\n\n  Line 33:     \"initial_fleet\": \"na-sales\"\n\n  Line 42:   \"tenant_id\": \"…\",\n\n  Line 50: Save `raw_key` immediately — it's only returned once. The returned credential uses the `mc_` prefix regardless of kind; the gateway derives scope (`tenant` / `agent` / `cross-tenant`) from the credential row, not the prefix. `agent_row_created: true` confirms the Agent row exists and `PATCH /agents/quote-agent-na/trust` will work without a synthetic first write.\n\n  Line 54: - `initial_trust` — `0`, `1`, `2`, `3` (default `1`).\n\n  Line 55: - `initial_fleet` — fleet membership; absent = no fleet (writes default to tenant-wide scope).\n\n  Line 71:   \"tenant_id\": \"your-tenant-id\",\n\n  Line 78: If `agent_id` is `null` or doesn't match what you provisioned, your credential isn't recognized as agent-scoped. Common causes:\n\n  Line 79: - You're sending a tenant-scoped credential, not the agent-scoped one you provisioned.\n\n  Line 110:     headers = {\"X-API-Key\": \"mc_...\"}   # agent-scoped credential\n\n  Line 144:                 \"authorization_token\": \"mc_...\",   # agent-scoped credential\n\n  Line 152: The SDK forwards `authorization_token` as `Authorization: Bearer mc_…`. memclaw recognises that shape and resolves your tenant + agent identity from the credential row.\n\n  Line 156: ## 4. Elevate trust (when needed)\n\n  Line 158: The default `trust_level=1` lets the agent write to its home fleet. Elevate when you need cross-fleet writes, keystone authoring, or deletes:\n\n  Line 161: curl -X PATCH \"https://memclaw.dev/api/v1/agents/quote-agent-na/trust?tenant_id=$TENANT_ID\" \\\n\n  Line 164:   -d '{\"trust_level\": 2}'\n\n  Line 169: - `1` — write to home fleet.\n\n  Line 170: - `2` — cross-fleet read.\n\n  Line 171: - `3` — cross-fleet write + delete + update others' memories.\n\n  Line 173: If you provisioned with `initial_trust`, this step is already done — confirm with `/whoami`.\n\n  Line 180: TENANT_KEY=mc_...   # tenant-scoped credential\n\n  Line 184: # 1. Provision agent + Agent row + trust + fleet in one call.\n\n  Line 188:   -d \"{\\\"agent_id\\\":\\\"$AGENT_ID\\\",\\\"initial_trust\\\":1,\\\"initial_fleet\\\":\\\"$FLEET_ID\\\"}\")\n\n  Line 190: # AGENT_KEY is an mc_… agent-scoped credential.\n\n  Line 199:   -d \"{\\\"tenant_id\\\":\\\"$TENANT_ID\\\",\\\"agent_id\\\":\\\"$AGENT_ID\\\",\\\"fleet_id\\\":\\\"$FLEET_ID\\\",\\\"content\\\":\\\"Hello world\\\"}\"\n\n  Line 202: Four steps, one round-trip per agent. The bootstrap dance from earlier integration attempts (provision → fake-write → patch trust → seed) is no longer necessary.\n\n  Line 208: A write of identical content (same `agent_id`, same `fleet_id`) is retry-safe via MCP:\n\n  Line 219: - **`POST /provision` returns the raw key once.** Save it before the response goes out of scope.\n\n  Line 220: - **`PATCH /agents/{id}/trust` returns 404 immediately after provisioning.** This should not happen post-2026-05-13; if it does, the Agent row was not materialized atomically. Check `whoami` and `GET /api/v1/agents/{id}`.\n\n  Line 230: - `GET /api/v1/agents/{id}?tenant_id=...` — agent detail.\n\n  Line 231: - `PATCH /api/v1/agents/{id}/trust?tenant_id=...` — change trust level.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/static/skills/memclaw/SKILL.md:\n  Line 13: ## Your identity: `agent_id` and `fleet_id`\n\n  Line 17: - `agent_id` — who you are. Attributes memories, drives trust progression,\n\n  Line 18:   gates `scope_agent` privacy. Resolved by your runtime. Never fabricate,\n\n  Line 20: - `fleet_id` — your team / organization scope. Required for\n\n  Line 21:   `visibility=scope_team`, for fleet-scoped reads, and for cross-fleet\n\n  Line 22:   operations. Never substitute another team's `fleet_id`.\n\n  Line 24: Wrong `agent_id` poisons attribution and trust. Wrong `fleet_id` leaks\n\n  Line 27: or write privately (`visibility=scope_agent`) until resolved.\n\n  Line 44: Reserve deletes (soft-delete, requires trust 3) for correcting genuinely\n\n  Line 49: Auto-registered at trust 1 on your first write.\n\n  Line 54: | 1     | standard    | own fleet                 | own fleet              |\n\n  Line 55: | 2     | cross-fleet | all fleets in your tenant | own fleet              |\n\n  Line 59: - browsing or reflecting with `scope=\"fleet\"` / `\"all\"` → trust 2\n\n  Line 60: - reporting outcomes (`memclaw_evolve`) at `scope=\"fleet\"` / `\"all\"` → trust 2 (default `scope=\"agent\"` needs only trust 1)\n\n  Line 61: - authoring your OWN `scope=agent` keystone (`memclaw_keystones_set`) → trust 1\n\n\n(Results truncated: showing 100 of 367 matches (267 hidden). Consider using a more specific path or pattern.)","metadata":{"matches":367,"truncated":true},"title":"scope|tier|trust|suppress|audit|tenant|fleet|quarantine|pii","time":{"start":1780727690783,"end":1780727690837}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa7708191816ce5421f2afbce"}},"id":"prt_e9ba4361c001HJrrAUmxBSiP5D","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727690840,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_O1ZKpkzwReEdizivSsf0MVCz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Idempotency-Key helper (CAURA-601).\n2: \n3: Per-route opt-in: handlers call :func:`idempotency_for` after auth\n4: has enforced the tenant, get back a :class:`IdempotencyGuard`, check\n5: ``guard.cached_replay`` for a cached response, and call\n6: ``guard.record(...)`` after running the work.\n7: \n8: Not a middleware — slowapi + FastAPI already handle the request/response\n9: pipeline, and per-handler wiring keeps the replay contract explicit at\n10: the route level. The boilerplate is five lines per decorated handler.\n11: \"\"\"\n12: \n13: from __future__ import annotations\n14: \n15: import asyncio\n16: import hashlib\n17: import logging\n18: from datetime import UTC, datetime, timedelta\n19: from typing import Any, Literal\n20: \n21: from fastapi import HTTPException, Request\n22: \n23: from core_api.clients.storage_client import get_storage_client\n24: from core_api.config import settings\n25: \n26: logger = logging.getLogger(__name__)\n27: \n28: IDEMPOTENCY_HEADER = \"Idempotency-Key\"\n29: # Matches Stripe's limit. Guards the `Text` column against oversized\n30: # values from buggy or adversarial clients before it reaches storage.\n31: MAX_IDEMPOTENCY_KEY_LEN = 255\n32: \n33: # Poll cadence + budget while waiting for a concurrent holder of the\n34: # same key to finish. Total wait =\n35: # ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n36: # enough to absorb a typical write pipeline (~2-5s end-to-end) without\n37: # holding the second request indefinitely; on timeout the caller gets\n38: # 409 and can retry.\n39: _CLAIM_POLL_INTERVAL_SECONDS = 0.5\n40: _CLAIM_POLL_MAX_ATTEMPTS = 20\n41: \n42: # Sentinels ``_poll_until_complete`` may return alongside the\n43: # completed row dict and ``None`` (budget exhausted):\n44: #\n45: # - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n46: #   or pending TTL elapsed). Caller can tell the client to retry as\n47: #   a fresh request.\n48: # - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n49: #   timeout, network). Caller should respond 503 — retrying into a\n50: #   downed cluster wastes the client's retry budget.\n51: _POLL_VANISHED = \"vanished\"\n52: _POLL_STORAGE_ERROR = \"storage_error\"\n53: \n54: # Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n55: # header is absent. ``Idempotency-Key`` (header) remains the\n56: # canonical form per the IETF draft; the body fallback exists for\n57: # SDK / load-test clients that can't easily set headers per request.\n58: # ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n59: # alias the loadtest harness uses.\n60: _IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n61: \n62: \n63: def idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n64:     \"\"\"Extract the idempotency key from a request body's ``metadata``\n65:     dict, if present. Returns ``None`` if metadata is missing/empty\n66:     or no recognised key field is set.\n67: \n68:     The header takes precedence — call this only as a fallback when\n69:     the header is absent. Routes that wire idempotency wire it once\n70:     via:\n71: \n72:         key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n73:     \"\"\"\n74:     if not metadata:\n75:         return None\n76:     for field in _IDEMPOTENCY_BODY_FIELDS:\n77:         value = metadata.get(field)\n78:         # Return the un-stripped value: ``idempotency_for`` hashes the\n79:         # RAW request bytes for replay-conflict detection, so any\n80:         # normalisation here would let two byte-identical retries —\n81:         # one with surrounding whitespace, one without — hit the same\n82:         # cache bucket but mismatch on body hash, triggering a false\n83:         # 422. The blank guard still rejects pure-whitespace values.\n84:         if isinstance(value, str) and value.strip():\n85:             return value\n86:     return None\n87: \n88: \n89: class IdempotencyGuard:\n90:     \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n91: \n92:     def __init__(\n93:         self,\n94:         tenant_id: str,\n95:         key: str,\n96:         request_hash: str,\n97:         cached: dict | None,\n98:     ) -> None:\n99:         self.tenant_id = tenant_id\n100:         self.key = key\n101:         self.request_hash = request_hash\n102:         self._cached = cached\n103: \n104:     @property\n105:     def cached_replay(self) -> tuple[Any, int] | None:\n106:         \"\"\"``(response_body, status_code)`` if the same key + body was\n107:         served before and is still within TTL; else ``None``.\"\"\"\n108:         if self._cached is None:\n109:             return None\n110:         return self._cached[\"response_body\"], self._cached[\"status_code\"]\n111: \n112:     async def record(self, response_body: Any, status_code: int = 200) -> None:\n113:         \"\"\"Cache the response body under this key. Failures are logged,\n114:         not raised — the client already has the live response; losing the\n115:         cache only costs a chance at future dedup.\"\"\"\n116:         expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n117:         try:\n118:             await get_storage_client().upsert_idempotency(\n119:                 tenant_id=self.tenant_id,\n120:                 idempotency_key=self.key,\n121:                 request_hash=self.request_hash,\n122:                 response_body=response_body,\n123:                 status_code=status_code,\n124:                 expires_at=expires_at.isoformat(),\n125:             )\n126:         except Exception:\n127:             logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n128: \n129: \n130: async def idempotency_for(\n131:     request: Request,\n132:     tenant_id: str,\n133:     idempotency_key: str | None,\n134:     *,\n135:     source: Literal[\"header\", \"body\"] = \"header\",\n136: ) -> IdempotencyGuard | None:\n137:     \"\"\"Look up — and atomically claim — the inbox for (tenant, key).\n138: \n139:     Returns None if the key was absent. On a cache hit with a\n140:     *different* body hash, raises 422 — reusing the same key with\n141:     different content is explicitly a client error per the IETF\n142:     idempotency-key draft.\n143: \n144:     Call this inside a route handler *after* auth enforcement, so the\n145:     tenant_id passed here is already vetted.\n146: \n147:     ``source`` selects a transport-specific prefix (``\"header\"`` →\n148:     ``header:``, ``\"body\"`` → ``body:``) prepended before the lookup\n149:     so the same string value sent via different transports never\n150:     shares a cache bucket. Validation runs against the RAW key the\n151:     caller supplied; the prefix is added only for storage.\n152: \n153:     Body hashing note: uses raw request bytes. Clients retrying a write\n154:     MUST send byte-identical bodies (same JSON serializer, same key\n155:     ordering). Non-deterministic serialization will falsely flag a\n156:     retry as a conflict. Matches Stripe and the IETF draft.\n157: \n158:     Concurrency: closes the race where two requests with the same key\n159:     arrive within milliseconds. The flow is lookup → claim → poll:\n160: \n161:     1. ``get_idempotency`` reads any existing row.\n162:     2. If a completed row matches the request hash, replay it.\n163:     3. If no row, ``claim_idempotency`` atomically inserts a pending\n164:        sentinel via INSERT ... ON CONFLICT DO NOTHING. The winning\n165:        caller proceeds with the handler; ``record()`` flips\n166:        ``is_pending`` to False.\n167:     4. If the claim collided (a concurrent caller raced ahead between\n168:        step 1 and step 3, or the row was pending in step 1), poll the\n169:        existing row until ``is_pending`` is False, then replay.\n170: \n171:     Storage outages degrade to \"no cache\" — a lost dedup opportunity\n172:     beats a blocked write.\n173:     \"\"\"\n174:     if not idempotency_key:\n175:         return None\n176:     if not idempotency_key.strip():\n177:         raise HTTPException(status_code=400, detail=\"Idempotency-Key must not be blank\")\n178:     if len(idempotency_key) > MAX_IDEMPOTENCY_KEY_LEN:\n179:         raise HTTPException(\n180:             status_code=400,\n181:             detail=f\"Idempotency-Key must be at most {MAX_IDEMPOTENCY_KEY_LEN} characters\",\n182:         )\n183: \n184:     namespaced_key = f\"{source}:{idempotency_key}\"\n185: \n186:     body_bytes = await request.body()\n187:     request_hash = hashlib.sha256(body_bytes).hexdigest()\n188: \n189:     sc = get_storage_client()\n190: \n191:     cached: dict | None\n192:     try:\n193:         cached = await sc.get_idempotency(tenant_id, namespaced_key)\n194:     except Exception:\n195:         logger.warning(\"Idempotency lookup failed (degrading to no-cache)\", exc_info=True)\n196:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n197: \n198:     if cached and not cached.get(\"is_pending\", False):\n199:         if cached[\"request_hash\"] != request_hash:\n200:             raise HTTPException(\n201:                 status_code=422,\n202:                 detail=\"Idempotency-Key reused with a different request body\",\n203:             )\n204:         return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=cached)\n205: \n206:     if cached and cached.get(\"is_pending\", False):\n207:         # Hash-check before polling: a different body for the same key is\n208:         # always a 422 regardless of the in-flight handler's outcome,\n209:         # and the pending row already carries the original hash. Without\n210:         # this short-circuit the loser burns the full poll budget before\n211:         # getting the same 422.\n212:         if cached[\"request_hash\"] != request_hash:\n213:             raise HTTPException(\n214:                 status_code=422,\n215:                 detail=\"Idempotency-Key reused with a different request body\",\n216:             )\n217:         completed = await _poll_until_complete(sc, tenant_id, namespaced_key)\n218:         if completed is None:\n219:             raise HTTPException(\n220:                 status_code=409,\n\n(Showing lines 1-220 of 333. Use offset=221 to continue.)\n</content>","metadata":{"preview":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","text":"\"\"\"Idempotency-Key helper (CAURA-601).\n\nPer-route opt-in: handlers call :func:`idempotency_for` after auth\nhas enforced the tenant, get back a :class:`IdempotencyGuard`, check\n``guard.cached_replay`` for a cached response, and call\n``guard.record(...)`` after running the work.\n\nNot a middleware — slowapi + FastAPI already handle the request/response\npipeline, and per-handler wiring keeps the replay contract explicit at\nthe route level. The boilerplate is five lines per decorated handler.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport hashlib\nimport logging\nfrom datetime import UTC, datetime, timedelta\nfrom typing import Any, Literal\n\nfrom fastapi import HTTPException, Request\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\nIDEMPOTENCY_HEADER = \"Idempotency-Key\"\n# Matches Stripe's limit. Guards the `Text` column against oversized\n# values from buggy or adversarial clients before it reaches storage.\nMAX_IDEMPOTENCY_KEY_LEN = 255\n\n# Poll cadence + budget while waiting for a concurrent holder of the\n# same key to finish. Total wait =\n# ``_CLAIM_POLL_INTERVAL_SECONDS * _CLAIM_POLL_MAX_ATTEMPTS``. Long\n# enough to absorb a typical write pipeline (~2-5s end-to-end) without\n# holding the second request indefinitely; on timeout the caller gets\n# 409 and can retry.\n_CLAIM_POLL_INTERVAL_SECONDS = 0.5\n_CLAIM_POLL_MAX_ATTEMPTS = 20\n\n# Sentinels ``_poll_until_complete`` may return alongside the\n# completed row dict and ``None`` (budget exhausted):\n#\n# - ``_POLL_VANISHED``: the row no longer exists (cleanup-job pruned\n#   or pending TTL elapsed). Caller can tell the client to retry as\n#   a fresh request.\n# - ``_POLL_STORAGE_ERROR``: the storage call itself failed (down,\n#   timeout, network). Caller should respond 503 — retrying into a\n#   downed cluster wastes the client's retry budget.\n_POLL_VANISHED = \"vanished\"\n_POLL_STORAGE_ERROR = \"storage_error\"\n\n# Body-metadata keys checked when the ``Idempotency-Key`` HTTP\n# header is absent. ``Idempotency-Key`` (header) remains the\n# canonical form per the IETF draft; the body fallback exists for\n# SDK / load-test clients that can't easily set headers per request.\n# ``idempotency_key`` first, then the legacy ``client_idempotency_key``\n# alias the loadtest harness uses.\n_IDEMPOTENCY_BODY_FIELDS = (\"idempotency_key\", \"client_idempotency_key\")\n\n\ndef idempotency_key_from_metadata(metadata: dict | None) -> str | None:\n    \"\"\"Extract the idempotency key from a request body's ``metadata``\n    dict, if present. Returns ``None`` if metadata is missing/empty\n    or no recognised key field is set.\n\n    The header takes precedence — call this only as a fallback when\n    the header is absent. Routes that wire idempotency wire it once\n    via:\n\n        key = idempotency_header or idempotency_key_from_metadata(body.metadata)\n    \"\"\"\n    if not metadata:\n        return None\n    for field in _IDEMPOTENCY_BODY_FIELDS:\n        value = metadata.get(field)\n        # Return the un-stripped value: ``idempotency_for`` hashes the\n        # RAW request bytes for replay-conflict detection, so any\n        # normalisation here would let two byte-identical retries —\n        # one with surrounding whitespace, one without — hit the same\n        # cache bucket but mismatch on body hash, triggering a false\n        # 422. The blank guard still rejects pure-whitespace values.\n        if isinstance(value, str) and value.strip():\n            return value\n    return None\n\n\nclass IdempotencyGuard:\n    \"\"\"One per request-with-header. Replay or record, never both.\"\"\"\n\n    def __init__(\n        self,\n        tenant_id: str,\n        key: str,\n        request_hash: str,\n        cached: dict | None,\n    ) -> None:\n        self.tenant_id = tenant_id\n        self.key = key\n        self.request_hash = request_hash\n        self._cached = cached\n\n    @property\n    def cached_replay(self) -> tuple[Any, int] | None:\n        \"\"\"``(response_body, status_code)`` if the same key + body was\n        served before and is still within TTL; else ``None``.\"\"\"\n        if self._cached is None:\n            return None\n        return self._cached[\"response_body\"], self._cached[\"status_code\"]\n\n    async def record(self, response_body: Any, status_code: int = 200) -> None:\n        \"\"\"Cache the response body under this key. Failures are logged,\n        not raised — the client already has the live response; losing the\n        cache only costs a chance at future dedup.\"\"\"\n        expires_at = datetime.now(UTC) + timedelta(seconds=settings.idempotency_ttl_seconds)\n        try:\n            await get_storage_client().upsert_idempotency(\n                tenant_id=self.tenant_id,\n                idempotency_key=self.key,\n                request_hash=self.request_hash,\n                response_body=response_body,\n                status_code=status_code,\n                expires_at=expires_at.isoformat(),\n            )\n        except Exception:\n            logger.warning(\"Idempotency record failed (non-critical)\", exc_info=True)\n\n\nasync def idempotency_for(\n    request: Request,\n    tenant_id: str,\n    idempotency_key: str | None,\n    *,\n    source: Literal[\"header\", \"body\"] = \"header\",\n) -> IdempotencyGuard | None:\n    \"\"\"Look up — and atomically claim — the inbox for (tenant, key).\n\n    Returns None if the key was absent. On a cache hit with a\n    *different* body hash, raises 422 — reusing the same key with\n    different content is explicitly a client error per the IETF\n    idempotency-key draft.\n\n    Call this inside a route handler *after* auth enforcement, so the\n    tenant_id passed here is already vetted.\n\n    ``source`` selects a transport-specific prefix (``\"header\"`` →\n    ``header:``, ``\"body\"`` → ``body:``) prepended before the lookup\n    so the same string value sent via different transports never\n    shares a cache bucket. Validation runs against the RAW key the\n    caller supplied; the prefix is added only for storage.\n\n    Body hashing note: uses raw request bytes. Clients retrying a write\n    MUST send byte-identical bodies (same JSON serializer, same key\n    ordering). Non-deterministic serialization will falsely flag a\n    retry as a conflict. Matches Stripe and the IETF draft.\n\n    Concurrency: closes the race where two requests with the same key\n    arrive within milliseconds. The flow is lookup → claim → poll:\n\n    1. ``get_idempotency`` reads any existing row.\n    2. If a completed row matches the request hash, replay it.\n    3. If no row, ``claim_idempotency`` atomically inserts a pending\n       sentinel via INSERT ... ON CONFLICT DO NOTHING. The winning\n       caller proceeds with the handler; ``record()`` flips\n       ``is_pending`` to False.\n    4. If the claim collided (a concurrent caller raced ahead between\n       step 1 and step 3, or the row was pending in step 1), poll the\n       existing row until ``is_pending`` is False, then replay.\n\n    Storage outages degrade to \"no cache\" — a lost dedup opportunity\n    beats a blocked write.\n    \"\"\"\n    if not idempotency_key:\n        return None\n    if not idempotency_key.strip():\n        raise HTTPException(status_code=400, detail=\"Idempotency-Key must not be blank\")\n    if len(idempotency_key) > MAX_IDEMPOTENCY_KEY_LEN:\n        raise HTTPException(\n            status_code=400,\n            detail=f\"Idempotency-Key must be at most {MAX_IDEMPOTENCY_KEY_LEN} characters\",\n        )\n\n    namespaced_key = f\"{source}:{idempotency_key}\"\n\n    body_bytes = await request.body()\n    request_hash = hashlib.sha256(body_bytes).hexdigest()\n\n    sc = get_storage_client()\n\n    cached: dict | None\n    try:\n        cached = await sc.get_idempotency(tenant_id, namespaced_key)\n    except Exception:\n        logger.warning(\"Idempotency lookup failed (degrading to no-cache)\", exc_info=True)\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=None)\n\n    if cached and not cached.get(\"is_pending\", False):\n        if cached[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        return IdempotencyGuard(tenant_id, namespaced_key, request_hash, cached=cached)\n\n    if cached and cached.get(\"is_pending\", False):\n        # Hash-check before polling: a different body for the same key is\n        # always a 422 regardless of the in-flight handler's outcome,\n        # and the pending row already carries the original hash. Without\n        # this short-circuit the loser burns the full poll budget before\n        # getting the same 422.\n        if cached[\"request_hash\"] != request_hash:\n            raise HTTPException(\n                status_code=422,\n                detail=\"Idempotency-Key reused with a different request body\",\n            )\n        completed = await _poll_until_complete(sc, tenant_id, namespaced_key)\n        if completed is None:\n            raise HTTPException(\n                status_code=409,","lineStart":1,"lineEnd":220,"totalLines":333,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/idempotency.py","time":{"start":1780727690808,"end":1780727690838}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa7908191bcf1c311b3c0f59e"}},"id":"prt_e9ba43633001MNlLeQjld3Mzcj","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727690846,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_9fWYERQFAwGIlKazVGgxDpwl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/ingest_body_size.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/ingest_body_size.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Ingest body-size middleware (PR #9).\n2: \n3: Rejects oversized requests to ``/ingest/preview``, ``/ingest/commit``, and\n4: ``/ingest/file`` before FastAPI parses the body — same pattern as\n5: ``RequestTimeoutMiddleware``: pure ASGI rather than ``BaseHTTPMiddleware``,\n6: so it runs ahead of body parsing and pydantic validation.\n7: \n8: A path-level ``Depends(...)`` doesn't work for this because FastAPI evaluates\n9: body parameters and path dependencies together; an oversized payload returns\n10: a 422 from body validation before our 413 dep ever fires. Middleware fixes\n11: that ordering.\n12: \n13: The check is cheap: read ``Content-Length`` from scope headers, return 413\n14: if it exceeds the cap. If the header is missing (chunked transfer), fall\n15: through — the per-route handler still re-checks the actual payload size for\n16: defense in depth.\n17: \"\"\"\n18: \n19: from __future__ import annotations\n20: \n21: import json\n22: import logging\n23: \n24: from starlette.types import ASGIApp as ASGIApplication\n25: from starlette.types import Receive, Scope, Send\n26: \n27: from core_api.services.ingest_service import INGEST_MAX_INPUT_BYTES\n28: \n29: logger = logging.getLogger(__name__)\n30: \n31: # Paths this middleware gates. We match by suffix (after the ``/api/v1``\n32: # prefix is stripped, both styles can exist) so the same middleware works\n33: # for the OSS and enterprise mount points without coupling to the\n34: # include_router prefix used in app.py.\n35: _GATED_PATH_SUFFIXES: tuple[str, ...] = (\n36:     \"/ingest/preview\",\n37:     \"/ingest/commit\",\n38:     \"/ingest/file\",\n39: )\n40: \n41: \n42: def _is_gated(path: str) -> bool:\n43:     return any(path.endswith(s) for s in _GATED_PATH_SUFFIXES)\n44: \n45: \n46: class IngestBodySizeMiddleware:\n47:     \"\"\"ASGI middleware that 413s oversized ingest requests on Content-Length.\"\"\"\n48: \n49:     def __init__(self, app: ASGIApplication) -> None:\n50:         self.app = app\n51: \n52:     async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:\n53:         if scope[\"type\"] != \"http\" or not _is_gated(scope[\"path\"]):\n54:             await self.app(scope, receive, send)\n55:             return\n56: \n57:         # Scope headers are a list of (bytes, bytes) tuples — Starlette's\n58:         # canonical form. We don't construct a Request object to avoid\n59:         # consuming the receive stream.\n60:         cl_bytes: bytes | None = None\n61:         for k, v in scope.get(\"headers\", []):\n62:             if k == b\"content-length\":\n63:                 cl_bytes = v\n64:                 break\n65: \n66:         if cl_bytes is None:\n67:             # No Content-Length (e.g. chunked transfer encoding). The route\n68:             # handler still enforces the cap on the actual payload, so we\n69:             # let this through — middleware just makes the common case cheap.\n70:             await self.app(scope, receive, send)\n71:             return\n72: \n73:         try:\n74:             n = int(cl_bytes.decode(\"ascii\", errors=\"ignore\"))\n75:         except ValueError:\n76:             # Malformed Content-Length — fall through; route guards still apply.\n77:             await self.app(scope, receive, send)\n78:             return\n79: \n80:         if n > INGEST_MAX_INPUT_BYTES:\n81:             max_mb = INGEST_MAX_INPUT_BYTES // 1_000_000\n82:             payload = {\n83:                 \"detail\": (\n84:                     f\"File must be {max_mb} MB or under (got {n:,} bytes, max {INGEST_MAX_INPUT_BYTES:,}).\"\n85:                 )\n86:             }\n87:             body = json.dumps(payload).encode()\n88:             logger.info(\n89:                 \"ingest body-size cap fired: path=%s content_length=%d (max %d)\",\n90:                 scope[\"path\"],\n91:                 n,\n92:                 INGEST_MAX_INPUT_BYTES,\n93:             )\n94:             await send(\n95:                 {\n96:                     \"type\": \"http.response.start\",\n97:                     \"status\": 413,\n98:                     \"headers\": [\n99:                         (b\"content-type\", b\"application/json\"),\n100:                         (b\"content-length\", str(len(body)).encode()),\n101:                     ],\n102:                 }\n103:             )\n104:             await send(\n105:                 {\n106:                     \"type\": \"http.response.body\",\n107:                     \"body\": body,\n108:                     \"more_body\": False,\n109:                 }\n110:             )\n111:             return\n112: \n113:         await self.app(scope, receive, send)\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"\"\"\"Ingest body-size middleware (PR #9).\n\nRejects oversized requests to ``/ingest/preview``, ``/ingest/commit``, and\n``/ingest/file`` before FastAPI parses the body — same pattern as\n``RequestTimeoutMiddleware``: pure ASGI rather than ``BaseHTTPMiddleware``,\nso it runs ahead of body parsing and pydantic validation.\n\nA path-level ``Depends(...)`` doesn't work for this because FastAPI evaluates\nbody parameters and path dependencies together; an oversized payload returns\na 422 from body validation before our 413 dep ever fires. Middleware fixes\nthat ordering.\n\nThe check is cheap: read ``Content-Length`` from scope headers, return 413\nif it exceeds the cap. If the header is missing (chunked transfer), fall\nthrough — the per-route handler still re-checks the actual payload size for\ndefense in depth.\n\"\"\"\n\nfrom __future__ import annotations\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/ingest_body_size.py","text":"\"\"\"Ingest body-size middleware (PR #9).\n\nRejects oversized requests to ``/ingest/preview``, ``/ingest/commit``, and\n``/ingest/file`` before FastAPI parses the body — same pattern as\n``RequestTimeoutMiddleware``: pure ASGI rather than ``BaseHTTPMiddleware``,\nso it runs ahead of body parsing and pydantic validation.\n\nA path-level ``Depends(...)`` doesn't work for this because FastAPI evaluates\nbody parameters and path dependencies together; an oversized payload returns\na 422 from body validation before our 413 dep ever fires. Middleware fixes\nthat ordering.\n\nThe check is cheap: read ``Content-Length`` from scope headers, return 413\nif it exceeds the cap. If the header is missing (chunked transfer), fall\nthrough — the per-route handler still re-checks the actual payload size for\ndefense in depth.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\n\nfrom starlette.types import ASGIApp as ASGIApplication\nfrom starlette.types import Receive, Scope, Send\n\nfrom core_api.services.ingest_service import INGEST_MAX_INPUT_BYTES\n\nlogger = logging.getLogger(__name__)\n\n# Paths this middleware gates. We match by suffix (after the ``/api/v1``\n# prefix is stripped, both styles can exist) so the same middleware works\n# for the OSS and enterprise mount points without coupling to the\n# include_router prefix used in app.py.\n_GATED_PATH_SUFFIXES: tuple[str, ...] = (\n    \"/ingest/preview\",\n    \"/ingest/commit\",\n    \"/ingest/file\",\n)\n\n\ndef _is_gated(path: str) -> bool:\n    return any(path.endswith(s) for s in _GATED_PATH_SUFFIXES)\n\n\nclass IngestBodySizeMiddleware:\n    \"\"\"ASGI middleware that 413s oversized ingest requests on Content-Length.\"\"\"\n\n    def __init__(self, app: ASGIApplication) -> None:\n        self.app = app\n\n    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:\n        if scope[\"type\"] != \"http\" or not _is_gated(scope[\"path\"]):\n            await self.app(scope, receive, send)\n            return\n\n        # Scope headers are a list of (bytes, bytes) tuples — Starlette's\n        # canonical form. We don't construct a Request object to avoid\n        # consuming the receive stream.\n        cl_bytes: bytes | None = None\n        for k, v in scope.get(\"headers\", []):\n            if k == b\"content-length\":\n                cl_bytes = v\n                break\n\n        if cl_bytes is None:\n            # No Content-Length (e.g. chunked transfer encoding). The route\n            # handler still enforces the cap on the actual payload, so we\n            # let this through — middleware just makes the common case cheap.\n            await self.app(scope, receive, send)\n            return\n\n        try:\n            n = int(cl_bytes.decode(\"ascii\", errors=\"ignore\"))\n        except ValueError:\n            # Malformed Content-Length — fall through; route guards still apply.\n            await self.app(scope, receive, send)\n            return\n\n        if n > INGEST_MAX_INPUT_BYTES:\n            max_mb = INGEST_MAX_INPUT_BYTES // 1_000_000\n            payload = {\n                \"detail\": (\n                    f\"File must be {max_mb} MB or under (got {n:,} bytes, max {INGEST_MAX_INPUT_BYTES:,}).\"\n                )\n            }\n            body = json.dumps(payload).encode()\n            logger.info(\n                \"ingest body-size cap fired: path=%s content_length=%d (max %d)\",\n                scope[\"path\"],\n                n,\n                INGEST_MAX_INPUT_BYTES,\n            )\n            await send(\n                {\n                    \"type\": \"http.response.start\",\n                    \"status\": 413,\n                    \"headers\": [\n                        (b\"content-type\", b\"application/json\"),\n                        (b\"content-length\", str(len(body)).encode()),\n                    ],\n                }\n            )\n            await send(\n                {\n                    \"type\": \"http.response.body\",\n                    \"body\": body,\n                    \"more_body\": False,\n                }\n            )\n            return\n\n        await self.app(scope, receive, send)","lineStart":1,"lineEnd":113,"totalLines":113,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/ingest_body_size.py","time":{"start":1780727690819,"end":1780727690845}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa7948191a1d4df71108362c1"}},"id":"prt_e9ba43638001bLD1tR8DOAm8uI","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727690849,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_9EA6YhziNGzhbqYmCfV5iiXM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/request_timeout.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/request_timeout.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Request-wide timeout middleware (CAURA-600).\n2: \n3: Pure ASGI middleware — matches the ``SecurityHeadersMiddleware`` pattern\n4: rather than ``@app.middleware('http')`` (which wraps in\n5: ``BaseHTTPMiddleware`` and has known edge cases around cancellation\n6: through Starlette's anyio task groups).\n7: \n8: Caveat: ``asyncio.timeout`` cannot cancel synchronous threads started\n9: via ``asyncio.to_thread`` (used by the Vertex and Gemini provider\n10: SDKs). The deadline frees the request slot and returns 504 to the\n11: caller on time, but the background thread may outlive the budget up\n12: to the provider's own latency and hold a ThreadPoolExecutor slot.\n13: Moving those calls off the hot path (CAURA-594 / CAURA-595) is the\n14: real fix; this middleware is the outer safety net.\n15: \"\"\"\n16: \n17: import asyncio\n18: import logging\n19: from collections.abc import MutableMapping\n20: from typing import Any\n21: \n22: from starlette.types import ASGIApp as ASGIApplication\n23: from starlette.types import Receive, Scope, Send\n24: \n25: from core_api.constants import is_mcp_path\n26: \n27: logger = logging.getLogger(__name__)\n28: \n29: # Routes that opt out of the blanket middleware budget and enforce their\n30: # own deadline at the route layer. Bulk-write (CAURA-602) needs a longer\n31: # budget than the single-write hot path, and cancelling it from this\n32: # middleware *after* storage commits is exactly what produced the\n33: # silent-create regression in loadtest-1777301515 — the route now wraps\n34: # its own ``asyncio.wait_for`` and surfaces the 504 with the retry\n35: # contract intact.\n36: # ``/admin/org/purge-data`` (CAURA-689) hard-deletes every row of a\n37: # soft-deleted org across the OSS schema — a terminal admin batch op\n38: # driven by the daily sweep, not a user request. A large org can take\n39: # well past the hot-path budget; cancelling it mid-flight is pointless\n40: # (the purge is one transaction per tenant and idempotent on retry), so\n41: # it opts out and is bounded by the storage client's own timeout instead.\n42: _TIMEOUT_OPT_OUT_PATHS: frozenset[str] = frozenset({\"/api/v1/memories/bulk\", \"/api/v1/admin/org/purge-data\"})\n43: \n44: \n45: def _is_opted_out(path: str) -> bool:\n46:     # Exact match keeps neighbours like ``/memories/bulk-delete`` on the\n47:     # default budget. ASGI ``scope[\"path\"]`` excludes the querystring, so\n48:     # no startswith-with-``?`` fallback is needed.\n49:     return path in _TIMEOUT_OPT_OUT_PATHS\n50: \n51: \n52: class RequestTimeoutMiddleware:\n53:     def __init__(self, app: ASGIApplication, timeout_seconds: float) -> None:\n54:         self.app = app\n55:         self.timeout_seconds = timeout_seconds\n56: \n57:     async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:\n58:         if scope[\"type\"] != \"http\" or is_mcp_path(scope[\"path\"]) or _is_opted_out(scope[\"path\"]):\n59:             await self.app(scope, receive, send)\n60:             return\n61: \n62:         response_started = False\n63: \n64:         async def _send(message: MutableMapping[str, Any]) -> None:\n65:             nonlocal response_started\n66:             if message[\"type\"] == \"http.response.start\":\n67:                 response_started = True\n68:             await send(message)\n69: \n70:         try:\n71:             async with asyncio.timeout(self.timeout_seconds):\n72:                 await self.app(scope, receive, _send)\n73:         except TimeoutError:\n74:             logger.warning(\n75:                 \"request exceeded %ss budget: %s %s\",\n76:                 self.timeout_seconds,\n77:                 scope.get(\"method\", \"?\"),\n78:                 scope[\"path\"],\n79:             )\n80:             if response_started:\n81:                 # Headers already sent; synthesizing a 504 here would leave\n82:                 # the response body half-written. Let the ASGI server drop\n83:                 # the connection via normal cancellation propagation.\n84:                 raise\n85:             await send(\n86:                 {\n87:                     \"type\": \"http.response.start\",\n88:                     \"status\": 504,\n89:                     \"headers\": [(b\"content-type\", b\"application/json\")],\n90:                 }\n91:             )\n92:             await send(\n93:                 {\n94:                     \"type\": \"http.response.body\",\n95:                     \"body\": b'{\"detail\":\"request timeout\"}',\n96:                     \"more_body\": False,\n97:                 }\n98:             )\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"\"\"\"Request-wide timeout middleware (CAURA-600).\n\nPure ASGI middleware — matches the ``SecurityHeadersMiddleware`` pattern\nrather than ``@app.middleware('http')`` (which wraps in\n``BaseHTTPMiddleware`` and has known edge cases around cancellation\nthrough Starlette's anyio task groups).\n\nCaveat: ``asyncio.timeout`` cannot cancel synchronous threads started\nvia ``asyncio.to_thread`` (used by the Vertex and Gemini provider\nSDKs). The deadline frees the request slot and returns 504 to the\ncaller on time, but the background thread may outlive the budget up\nto the provider's own latency and hold a ThreadPoolExecutor slot.\nMoving those calls off the hot path (CAURA-594 / CAURA-595) is the\nreal fix; this middleware is the outer safety net.\n\"\"\"\n\nimport asyncio\nimport logging\nfrom collections.abc import MutableMapping\nfrom typing import Any","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/request_timeout.py","text":"\"\"\"Request-wide timeout middleware (CAURA-600).\n\nPure ASGI middleware — matches the ``SecurityHeadersMiddleware`` pattern\nrather than ``@app.middleware('http')`` (which wraps in\n``BaseHTTPMiddleware`` and has known edge cases around cancellation\nthrough Starlette's anyio task groups).\n\nCaveat: ``asyncio.timeout`` cannot cancel synchronous threads started\nvia ``asyncio.to_thread`` (used by the Vertex and Gemini provider\nSDKs). The deadline frees the request slot and returns 504 to the\ncaller on time, but the background thread may outlive the budget up\nto the provider's own latency and hold a ThreadPoolExecutor slot.\nMoving those calls off the hot path (CAURA-594 / CAURA-595) is the\nreal fix; this middleware is the outer safety net.\n\"\"\"\n\nimport asyncio\nimport logging\nfrom collections.abc import MutableMapping\nfrom typing import Any\n\nfrom starlette.types import ASGIApp as ASGIApplication\nfrom starlette.types import Receive, Scope, Send\n\nfrom core_api.constants import is_mcp_path\n\nlogger = logging.getLogger(__name__)\n\n# Routes that opt out of the blanket middleware budget and enforce their\n# own deadline at the route layer. Bulk-write (CAURA-602) needs a longer\n# budget than the single-write hot path, and cancelling it from this\n# middleware *after* storage commits is exactly what produced the\n# silent-create regression in loadtest-1777301515 — the route now wraps\n# its own ``asyncio.wait_for`` and surfaces the 504 with the retry\n# contract intact.\n# ``/admin/org/purge-data`` (CAURA-689) hard-deletes every row of a\n# soft-deleted org across the OSS schema — a terminal admin batch op\n# driven by the daily sweep, not a user request. A large org can take\n# well past the hot-path budget; cancelling it mid-flight is pointless\n# (the purge is one transaction per tenant and idempotent on retry), so\n# it opts out and is bounded by the storage client's own timeout instead.\n_TIMEOUT_OPT_OUT_PATHS: frozenset[str] = frozenset({\"/api/v1/memories/bulk\", \"/api/v1/admin/org/purge-data\"})\n\n\ndef _is_opted_out(path: str) -> bool:\n    # Exact match keeps neighbours like ``/memories/bulk-delete`` on the\n    # default budget. ASGI ``scope[\"path\"]`` excludes the querystring, so\n    # no startswith-with-``?`` fallback is needed.\n    return path in _TIMEOUT_OPT_OUT_PATHS\n\n\nclass RequestTimeoutMiddleware:\n    def __init__(self, app: ASGIApplication, timeout_seconds: float) -> None:\n        self.app = app\n        self.timeout_seconds = timeout_seconds\n\n    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:\n        if scope[\"type\"] != \"http\" or is_mcp_path(scope[\"path\"]) or _is_opted_out(scope[\"path\"]):\n            await self.app(scope, receive, send)\n            return\n\n        response_started = False\n\n        async def _send(message: MutableMapping[str, Any]) -> None:\n            nonlocal response_started\n            if message[\"type\"] == \"http.response.start\":\n                response_started = True\n            await send(message)\n\n        try:\n            async with asyncio.timeout(self.timeout_seconds):\n                await self.app(scope, receive, _send)\n        except TimeoutError:\n            logger.warning(\n                \"request exceeded %ss budget: %s %s\",\n                self.timeout_seconds,\n                scope.get(\"method\", \"?\"),\n                scope[\"path\"],\n            )\n            if response_started:\n                # Headers already sent; synthesizing a 504 here would leave\n                # the response body half-written. Let the ASGI server drop\n                # the connection via normal cancellation propagation.\n                raise\n            await send(\n                {\n                    \"type\": \"http.response.start\",\n                    \"status\": 504,\n                    \"headers\": [(b\"content-type\", b\"application/json\")],\n                }\n            )\n            await send(\n                {\n                    \"type\": \"http.response.body\",\n                    \"body\": b'{\"detail\":\"request timeout\"}',\n                    \"more_body\": False,\n                }\n            )","lineStart":1,"lineEnd":98,"totalLines":98,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/middleware/request_timeout.py","time":{"start":1780727690822,"end":1780727690847}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa79c8191b8aa090519728a2a"}},"id":"prt_e9ba43644001PoR9AdbOM4js8z","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"tool_use","timestamp":1780727691049,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"grep","callID":"call_brc3vIEtpg6rZuwEe7CpkdLB","state":{"status":"completed","input":{"pattern":"scope|tier|trust|suppress|audit|tenant|fleet|quarantine|pii","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main","include":"*.py"},"output":"Found 11604 matches (showing first 100)\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py:\n  Line 48:     enforce_fleet_read,\n\n  Line 49:     enforce_fleet_write,\n\n  Line 51: from core_api.services.audit_service import log_action, log_cross_tenant_read\n\n  Line 61: # Re-export so existing `monkeypatch.setattr(mcp_server, \"_require_trust\", ...)`\n\n  Line 62: # sites in tests keep working; production callers should import ``require_trust``\n\n  Line 63: # directly from ``core_api.services.trust_service``.\n\n  Line 64: from core_api.services.trust_service import parse_trust_error\n\n  Line 65: from core_api.services.trust_service import require_trust as _require_trust\n\n  Line 66: from core_api.services.usage_service import check_and_increment_by_tenant as check_and_increment\n\n  Line 67: from core_api.trust_utils import effective_keystone_min_trust, keystone_min_trust\n\n  Line 73: _tenant_id_var: contextvars.ContextVar[str] = contextvars.ContextVar(\"mcp_tenant_id\")\n\n  Line 78: # from a tenant-key holder to a single shared identity (friction §2.8 / Stage 6b).\n\n  Line 80: # Cross-tenant read set plumbed from X-Readable-Tenant-IDs (CSV). Empty list\n\n  Line 81: # means single-tenant key (reads pinned to ``_tenant_id_var``). When populated\n\n  Line 82: # the home tenant_id is the first element and writes still go there.\n\n  Line 83: _readable_tenant_ids_var: contextvars.ContextVar[list[str] | None] = contextvars.ContextVar(\n\n  Line 84:     \"mcp_readable_tenant_ids\", default=None\n\n  Line 86: _scopes_var: contextvars.ContextVar[set[str] | None] = contextvars.ContextVar(\"mcp_scopes\", default=None)\n\n  Line 134:         \"Missing or invalid X-API-Key header. Provide a tenant-scoped API key.\",\n\n  Line 140:         \"Admin/system keys cannot be used with MCP. Use a tenant-scoped API key.\",\n\n  Line 146:     \"\"\"ASGI middleware that resolves X-API-Key to tenant_id before MCP handlers run.\"\"\"\n\n  Line 151:     async def __call__(self, scope: Scope, receive: Receive, send: Send):\n\n  Line 152:         if scope[\"type\"] == \"http\":\n\n  Line 155:             headers = dict(scope.get(\"headers\", []))\n\n  Line 165:             tenant_header = headers.get(b\"x-tenant-id\", b\"\").decode()\n\n  Line 166:             if tenant_header:\n\n  Line 167:                 _tenant_id_var.set(tenant_header)\n\n  Line 179:                     _tenant_id_var.set(_ADMIN)\n\n  Line 181:                     from core_api.standalone import get_standalone_tenant_id\n\n  Line 183:                     _tenant_id_var.set(get_standalone_tenant_id())\n\n  Line 185:                     _tenant_id_var.set(_UNAUTH if admin_key else _NO_AUTH)\n\n  Line 187:                     _tenant_id_var.set(_UNAUTH)\n\n  Line 189:             # X-Agent-ID injected by enterprise gateway for agent-scoped\n\n  Line 196:             # for credentials authorized to read beyond their home tenant\n\n  Line 197:             # (cross-tenant agent keys). Absent / empty headers leave the\n\n  Line 198:             # context vars at their single-tenant defaults.\n\n  Line 203:             # token-based reset. An absent header means \"single-tenant /\n\n  Line 204:             # full-scope\" — make that explicit so a previous request's\n\n  Line 205:             # cross-tenant read-set or read-only scope cannot bleed through.\n\n  Line 206:             readable_header = headers.get(b\"x-readable-tenant-ids\", b\"\").decode()\n\n  Line 207:             _readable_tenant_ids_var.set(\n\n  Line 214:                 headers.get(b\"x-capabilities\", b\"\").decode() or headers.get(b\"x-key-scopes\", b\"\").decode()\n\n  Line 216:             _scopes_var.set({s.strip() for s in caps_header.split(\",\") if s.strip()} if caps_header else None)\n\n  Line 218:         await self.app(scope, receive, send)\n\n  Line 221: def _get_tenant() -> str:\n\n  Line 222:     return _tenant_id_var.get(_UNAUTH)\n\n  Line 230: def _get_readable_tenants() -> list[str]:\n\n  Line 231:     \"\"\"Return the cross-tenant read set; empty for single-tenant keys.\"\"\"\n\n  Line 232:     return _readable_tenant_ids_var.get(None) or []\n\n  Line 235: def _get_scopes() -> set[str] | None:\n\n  Line 236:     \"\"\"Return the credential's scope set, or None for full-scope (legacy) keys.\"\"\"\n\n  Line 237:     return _scopes_var.get(None)\n\n  Line 241:     \"\"\"Return False if the active credential is scope-limited to read-only.\"\"\"\n\n  Line 242:     scopes = _get_scopes()\n\n  Line 243:     if scopes is None:\n\n  Line 245:     return \"write\" in scopes\n\n  Line 250:     and the gateway didn't inject X-Agent-ID (mc_ tenant-key path), the caller\n\n  Line 252:     default would silently attribute every write from a tenant-key holder to\n\n  Line 257:     Standalone, admin, and gateway-routed agent-scoped paths are unaffected:\n\n  Line 258:     standalone uses a stable single-tenant identity, admin is a system caller,\n\n  Line 259:     and an agent-scoped credential resolves X-Agent-ID via auth_validate so\n\n  Line 270:         \"Writes via the gateway with a tenant-scoped credential must specify \"\n\n  Line 273:         \"agent_id=<your-agent-name> or provision an agent-scoped credential \"\n\n  Line 330:     tid = _get_tenant()\n\n  Line 341:         \"This credential is scope-limited to read operations. \"\n\n  Line 349: def _check_write_scope() -> CallToolResult | None:\n\n  Line 354:         if err := _check_write_scope(): return err\n\n  Line 356:     A ``None`` scope set means \"legacy / full-scope key\" and is allowed\n\n  Line 357:     (back-compat for credentials minted before scopes existed). Only an\n\n  Line 358:     explicitly-set scope set without 'write' triggers the block.\n\n  Line 367:     \"\"\"Session with RLS tenant context set from MCP auth.\"\"\"\n\n  Line 369:         tenant_id = _get_tenant()\n\n  Line 370:         if tenant_id and tenant_id not in (_UNAUTH, _ADMIN, _NO_AUTH):\n\n  Line 372:                 sa_text(\"SELECT set_config('app.tenant_id', :tid, true)\"),\n\n  Line 373:                 {\"tid\": tenant_id},\n\n  Line 376:             await session.execute(sa_text(\"SELECT set_config('app.tenant_id', '', true)\"))\n\n  Line 377:         # Plumb the cross-tenant read set as a second GUC alongside\n\n  Line 378:         # ``app.tenant_id``. Deployments may extend RLS policies to honor\n\n  Line 380:         readable = _get_readable_tenants()\n\n  Line 382:             sa_text(\"SELECT set_config('app.readable_tenant_ids', :csv, true)\"),\n\n  Line 403:         \"memclaw_keystones_set (set|delete) and requires elevated trust.\"\n\n  Line 458:     fleet_ids: Annotated[list[str] | None, Field(description=\"Restrict fleets.\")] = None,\n\n  Line 486:     tenant_id = _get_tenant()\n\n  Line 498:     # capturing the search results + config + readable-tenant set, then\n\n  Line 503:             await check_and_increment(db, tenant_id, \"search\")\n\n  Line 507:             config = await resolve_config(db, tenant_id)\n\n  Line 508:             _ag = await agent_repo.get_by_id(db, agent_id, tenant_id)\n\n  Line 512:             # Fleet scope enforcement (parity with REST /search): a constrained\n\n  Line 513:             # agent that omits fleet_ids is scoped to its own fleet, and a single\n\n  Line 514:             # explicit fleet goes through the cross-fleet trust ladder. Closes the\n\n  Line 515:             # recall side of the cross-fleet content leak.\n\n  Line 516:             if _ag is not None and not fleet_ids:\n\n  Line 517:                 ag_fleet = _ag.get(\"fleet_id\") if isinstance(_ag, dict) else getattr(_ag, \"fleet_id\", None)\n\n  Line 518:                 ag_trust = (\n\n  Line 519:                     _ag.get(\"trust_level\", 0) if isinstance(_ag, dict) else getattr(_ag, \"trust_level\", 0)\n\n  Line 521:                 if ag_fleet and ag_trust < 2:\n\n  Line 522:                     fleet_ids = [ag_fleet]\n\n  Line 523:             if fleet_ids and len(fleet_ids) == 1:\n\n  Line 524:                 await enforce_fleet_read(db, tenant_id, agent_id, fleet_ids[0])\n\n  Line 525:             # Cross-tenant recall widens via readable_tenant_ids when\n\n\n(Results truncated: showing 100 of 11604 matches (11504 hidden). Consider using a more specific path or pattern.)","metadata":{"matches":11604,"truncated":true},"title":"scope|tier|trust|suppress|audit|tenant|fleet|quarantine|pii","time":{"start":1780727690779,"end":1780727691048}},"metadata":{"openai":{"itemId":"fc_0b30a93f3b98d370016a23bf8aa75c8191b431896a6ac6783c"}},"id":"prt_e9ba435e90014XqvdBBDyzYPUs","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B"}}
{"type":"step_finish","timestamp":1780727691310,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"id":"prt_e9ba4382c001GblU5i7JgpvrRG","reason":"tool-calls","snapshot":"20843d9cdf48381b6728a7de50f65022e5664b82","messageID":"msg_e9ba3f2e30014ioeehrkqJqb2B","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","type":"step-finish","tokens":{"total":54351,"input":13147,"output":715,"reasoning":41,"cache":{"write":0,"read":40448}},"cost":0}}
{"type":"step_start","timestamp":1780727692980,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"id":"prt_e9ba43eb0001wlP1egyI9LCTJu","messageID":"msg_e9ba4392d001E9I9tmUrBHUGcq","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","snapshot":"8b445609a3463835f2c356c7fd708ebd746c61bc","type":"step-start"}}
{"type":"text","timestamp":1780727706170,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"id":"prt_e9ba44939001N2FonwKHbpljfV","messageID":"msg_e9ba4392d001E9I9tmUrBHUGcq","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","type":"text","text":"The middleware directory mostly contains tenant injection, per-tenant bulkheads, and request guards; scope/trust enforcement appears concentrated in MCP handlers plus services. I’m following those files next and will keep the total source set bounded.","time":{"start":1780727695673,"end":1780727706169},"metadata":{"openai":{"itemId":"msg_0cbf2f4b5d66edbe016a23bf8fa62481919e5a95f039192c4c","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780727706223,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_CU1rZl75TXL3rGAOH2VkTmlr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","offset":40,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py</path>\n<type>file</type>\n<content>\n40: )\n41: from core_api.db.session import async_session\n42: from core_api.errors import code_for_status\n43: from core_api.repositories import memory_repo\n44: from core_api.schemas import BulkMemoryCreate, BulkMemoryItem, MemoryCreate, MemoryUpdate\n45: from core_api.services.agent_service import (\n46:     authorize_memory_access,\n47:     enforce_delete,\n48:     enforce_fleet_read,\n49:     enforce_fleet_write,\n50: )\n51: from core_api.services.audit_service import log_action, log_cross_tenant_read\n52: from core_api.services.entity_service import get_entity\n53: from core_api.services.memory_service import (\n54:     create_memories_bulk,\n55:     create_memory,\n56:     search_memories,\n57:     soft_delete_memory,\n58:     update_memory,\n59: )\n60: \n61: # Re-export so existing `monkeypatch.setattr(mcp_server, \"_require_trust\", ...)`\n62: # sites in tests keep working; production callers should import ``require_trust``\n63: # directly from ``core_api.services.trust_service``.\n64: from core_api.services.trust_service import parse_trust_error\n65: from core_api.services.trust_service import require_trust as _require_trust\n66: from core_api.services.usage_service import check_and_increment_by_tenant as check_and_increment\n67: from core_api.trust_utils import effective_keystone_min_trust, keystone_min_trust\n68: \n69: logger = logging.getLogger(__name__)\n70: \n71: # ── Auth via context vars ──\n72: \n73: _tenant_id_var: contextvars.ContextVar[str] = contextvars.ContextVar(\"mcp_tenant_id\")\n74: _agent_id_var: contextvars.ContextVar[str | None] = contextvars.ContextVar(\"mcp_agent_id\", default=None)\n75: # True iff X-Tenant-ID arrived as a request header (gateway-routed). On that\n76: # path the gateway is the source of truth for identity; falling back to the\n77: # literal \"mcp-agent\" tool-param default would silently attribute every write\n78: # from a tenant-key holder to a single shared identity (friction §2.8 / Stage 6b).\n79: _via_gateway_var: contextvars.ContextVar[bool] = contextvars.ContextVar(\"mcp_via_gateway\", default=False)\n80: # Cross-tenant read set plumbed from X-Readable-Tenant-IDs (CSV). Empty list\n81: # means single-tenant key (reads pinned to ``_tenant_id_var``). When populated\n82: # the home tenant_id is the first element and writes still go there.\n83: _readable_tenant_ids_var: contextvars.ContextVar[list[str] | None] = contextvars.ContextVar(\n84:     \"mcp_readable_tenant_ids\", default=None\n85: )\n86: _scopes_var: contextvars.ContextVar[set[str] | None] = contextvars.ContextVar(\"mcp_scopes\", default=None)\n87: \n88: _UNAUTH = \"__unauthenticated__\"\n89: _ADMIN = \"__admin__\"\n90: _NO_AUTH = \"__no_auth__\"\n91: _DEFAULT_AGENT_ID = \"mcp-agent\"\n92: \n93: \n94: def _error_response(code: str, message: str, **details) -> str:\n95:     \"\"\"Return the canonical MCP error envelope as a JSON string.\n96: \n97:     Shape matches the REST surface (see ``core_api.errors.make_error_payload``):\n98:     ``{\"error\": {\"code\": \"...\", \"message\": \"...\", \"details\": {...}}}``.\n99: \n100:     The string is wrapped into a ``CallToolResult(isError=True)`` before\n101:     leaving the tool — either by ``_with_latency`` (which detects the\n102:     error shape) or by ``_as_error_result`` for pre-tool returns that\n103:     skip the latency stamp. Tool callsites keep returning plain strings;\n104:     the wrap happens at one of those two chokepoints (CAURA-000,\n105:     FRICTION-REPORT-V3 B2 — clients literal-reading the MCP spec were\n106:     seeing ``isError=False`` on every gateway-side refusal).\n107:     \"\"\"\n108:     from core_api.errors import make_error_payload\n109: \n110:     payload = make_error_payload(code, message, details=details if details else None)\n111:     return json.dumps(payload, default=str)\n112: \n113: \n114: def _as_error_result(envelope: str) -> CallToolResult:\n115:     \"\"\"Wrap a ``_error_response`` JSON envelope into a CallToolResult\n116:     with ``isError=True``. The envelope JSON is preserved verbatim in\n117:     a single TextContent so callers reading ``result.content[0].text``\n118:     still get the structured payload. Used for the pre-tool / auth\n119:     return paths that don't run through ``_with_latency``.\n120:     \"\"\"\n121:     return CallToolResult(\n122:         content=[TextContent(type=\"text\", text=envelope)],\n123:         isError=True,\n124:     )\n125: \n126: \n127: # Pre-tool auth errors (returned directly, NOT through _with_latency, because\n128: # they fire before any tool work has begun, so we wrap them as\n129: # CallToolResults at module load — every tool that returns one\n130: # propagates ``isError=True`` to the MCP client.\n131: _AUTH_ERROR = _as_error_result(\n132:     _error_response(\n133:         \"UNAUTHORIZED\",\n134:         \"Missing or invalid X-API-Key header. Provide a tenant-scoped API key.\",\n135:     )\n136: )\n137: _ADMIN_ERROR = _as_error_result(\n138:     _error_response(\n139:         \"FORBIDDEN\",\n140:         \"Admin/system keys cannot be used with MCP. Use a tenant-scoped API key.\",\n141:     )\n142: )\n143: \n144: \n145: class MCPAuthMiddleware:\n146:     \"\"\"ASGI middleware that resolves X-API-Key to tenant_id before MCP handlers run.\"\"\"\n147: \n148:     def __init__(self, app: ASGIApp):\n149:         self.app = app\n150: \n151:     async def __call__(self, scope: Scope, receive: Receive, send: Send):\n152:         if scope[\"type\"] == \"http\":\n153:             from core_api.config import settings\n154: \n155:             headers = dict(scope.get(\"headers\", []))\n156: \n157:             # Preferred path: enterprise nginx has already validated the\n158:             # session cookie / JWT / API key via auth_request and injected\n159:             # X-Tenant-ID. Trust that resolution verbatim — otherwise a\n160:             # browser dashboard call (which sends `Authorization: Bearer\n161:             # <session JWT>` alongside the gateway-injected X-Tenant-ID)\n162:             # falls into the Authorization→api_key fallback below, fails\n163:             # the admin-key comparison, and reports UNAUTH despite the\n164:             # gateway having already approved the caller.\n165:             tenant_header = headers.get(b\"x-tenant-id\", b\"\").decode()\n166:             if tenant_header:\n167:                 _tenant_id_var.set(tenant_header)\n168:                 _via_gateway_var.set(True)\n169:             else:\n170:                 _via_gateway_var.set(False)\n171:                 api_key = headers.get(b\"x-api-key\", b\"\").decode()\n172:                 if not api_key:\n173:                     auth_header = headers.get(b\"authorization\", b\"\").decode()\n174:                     if auth_header.lower().startswith(\"bearer \"):\n175:                         api_key = auth_header[7:]\n176:                 admin_key = get_admin_key()\n177: \n178:                 if admin_key and api_key and _hmac.compare_digest(api_key, admin_key):\n179:                     _tenant_id_var.set(_ADMIN)\n180:                 elif settings.is_standalone:\n181:                     from core_api.standalone import get_standalone_tenant_id\n182: \n183:                     _tenant_id_var.set(get_standalone_tenant_id())\n184:                 elif not api_key:\n185:                     _tenant_id_var.set(_UNAUTH if admin_key else _NO_AUTH)\n186:                 else:\n187:                     _tenant_id_var.set(_UNAUTH)\n188: \n189:             # X-Agent-ID injected by enterprise gateway for agent-scoped\n190:             # credentials (kind=agent_key). When present, this is the\n191:             # cryptographically verified agent identity.\n192:             agent_header = headers.get(b\"x-agent-id\", b\"\").decode()\n193:             _agent_id_var.set(agent_header or None)\n194: \n195:             # X-Readable-Tenant-IDs and X-Key-Scopes are plumbed by the gateway\n196:             # for credentials authorized to read beyond their home tenant\n197:             # (cross-tenant agent keys). Absent / empty headers leave the\n198:             # context vars at their single-tenant defaults.\n199:             # Always reset both context vars at the start of every request,\n200:             # not just when the header is present. ContextVars set inside a\n201:             # prior request can survive into the next request when the\n202:             # underlying ASGI task is reused or the var was never assigned a\n203:             # token-based reset. An absent header means \"single-tenant /\n204:             # full-scope\" — make that explicit so a previous request's\n205:             # cross-tenant read-set or read-only scope cannot bleed through.\n206:             readable_header = headers.get(b\"x-readable-tenant-ids\", b\"\").decode()\n207:             _readable_tenant_ids_var.set(\n208:                 [t.strip() for t in readable_header.split(\",\") if t.strip()] if readable_header else None\n209:             )\n210:             # X-Capabilities is canonical from the unified auth-api;\n211:             # X-Key-Scopes is accepted as a back-compat alias during\n212:             # the gateway rollout window.\n213:             caps_header = (\n214:                 headers.get(b\"x-capabilities\", b\"\").decode() or headers.get(b\"x-key-scopes\", b\"\").decode()\n215:             )\n216:             _scopes_var.set({s.strip() for s in caps_header.split(\",\") if s.strip()} if caps_header else None)\n217: \n218:         await self.app(scope, receive, send)\n219: \n220: \n221: def _get_tenant() -> str:\n222:     return _tenant_id_var.get(_UNAUTH)\n223: \n224: \n225: def _get_agent_id() -> str | None:\n226:     \"\"\"Return the verified agent_id from X-Agent-ID header, or None.\"\"\"\n227:     return _agent_id_var.get(None)\n228: \n229: \n230: def _get_readable_tenants() -> list[str]:\n231:     \"\"\"Return the cross-tenant read set; empty for single-tenant keys.\"\"\"\n232:     return _readable_tenant_ids_var.get(None) or []\n233: \n234: \n235: def _get_scopes() -> set[str] | None:\n236:     \"\"\"Return the credential's scope set, or None for full-scope (legacy) keys.\"\"\"\n237:     return _scopes_var.get(None)\n238: \n239: \n240: def _is_write_allowed() -> bool:\n241:     \"\"\"Return False if the active credential is scope-limited to read-only.\"\"\"\n242:     scopes = _get_scopes()\n243:     if scopes is None:\n244:         return True\n245:     return \"write\" in scopes\n246: \n247: \n248: def _refuse_default_agent_on_gateway(agent_id: str) -> str | None:\n249:     \"\"\"When the request came through the enterprise gateway (X-Tenant-ID set)\n250:     and the gateway didn't inject X-Agent-ID (mc_ tenant-key path), the caller\n251:     must supply a real agent_id. Falling back to the reserved ``\"mcp-agent\"``\n252:     default would silently attribute every write from a tenant-key holder to\n253:     one shared identity — the failure mode the friction report's bug repro\n254:     documented as ``agent row missing from list_agents``.\n255: \n256:     Returns an error envelope if the call should be refused; ``None`` to proceed.\n257:     Standalone, admin, and gateway-routed agent-scoped paths are unaffected:\n258:     standalone uses a stable single-tenant identity, admin is a system caller,\n259:     and an agent-scoped credential resolves X-Agent-ID via auth_validate so\n260:     this guard never fires for it.\n261:     \"\"\"\n262:     if not _via_gateway_var.get(False):\n263:         return None\n264:     if _get_agent_id() is not None:\n265:         return None\n266:     if agent_id != _DEFAULT_AGENT_ID:\n267:         return None\n268:     return _error_response(\n269:         \"MISSING_AGENT_ID\",\n270:         \"Writes via the gateway with a tenant-scoped credential must specify \"\n271:         \"an agent_id explicitly; the reserved default \"\n272:         f\"'{_DEFAULT_AGENT_ID}' is not accepted on this path. Either pass \"\n273:         \"agent_id=<your-agent-name> or provision an agent-scoped credential \"\n274:         \"(POST /api/v1/admin/agent-keys/provision, or via the dashboard at \"\n275:         \"Settings → Organization → API Credentials with kind=agent_key) — \"\n276:         \"those have agent identity bound at mint time and the gateway \"\n277:         \"injects X-Agent-ID for them.\",\n278:     )\n279: \n\n(Showing lines 40-279 of 2542. Use offset=280 to continue.)\n</content>","metadata":{"preview":")\nfrom core_api.db.session import async_session\nfrom core_api.errors import code_for_status\nfrom core_api.repositories import memory_repo\nfrom core_api.schemas import BulkMemoryCreate, BulkMemoryItem, MemoryCreate, MemoryUpdate\nfrom core_api.services.agent_service import (\n    authorize_memory_access,\n    enforce_delete,\n    enforce_fleet_read,\n    enforce_fleet_write,\n)\nfrom core_api.services.audit_service import log_action, log_cross_tenant_read\nfrom core_api.services.entity_service import get_entity\nfrom core_api.services.memory_service import (\n    create_memories_bulk,\n    create_memory,\n    search_memories,\n    soft_delete_memory,\n    update_memory,\n)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","text":")\nfrom core_api.db.session import async_session\nfrom core_api.errors import code_for_status\nfrom core_api.repositories import memory_repo\nfrom core_api.schemas import BulkMemoryCreate, BulkMemoryItem, MemoryCreate, MemoryUpdate\nfrom core_api.services.agent_service import (\n    authorize_memory_access,\n    enforce_delete,\n    enforce_fleet_read,\n    enforce_fleet_write,\n)\nfrom core_api.services.audit_service import log_action, log_cross_tenant_read\nfrom core_api.services.entity_service import get_entity\nfrom core_api.services.memory_service import (\n    create_memories_bulk,\n    create_memory,\n    search_memories,\n    soft_delete_memory,\n    update_memory,\n)\n\n# Re-export so existing `monkeypatch.setattr(mcp_server, \"_require_trust\", ...)`\n# sites in tests keep working; production callers should import ``require_trust``\n# directly from ``core_api.services.trust_service``.\nfrom core_api.services.trust_service import parse_trust_error\nfrom core_api.services.trust_service import require_trust as _require_trust\nfrom core_api.services.usage_service import check_and_increment_by_tenant as check_and_increment\nfrom core_api.trust_utils import effective_keystone_min_trust, keystone_min_trust\n\nlogger = logging.getLogger(__name__)\n\n# ── Auth via context vars ──\n\n_tenant_id_var: contextvars.ContextVar[str] = contextvars.ContextVar(\"mcp_tenant_id\")\n_agent_id_var: contextvars.ContextVar[str | None] = contextvars.ContextVar(\"mcp_agent_id\", default=None)\n# True iff X-Tenant-ID arrived as a request header (gateway-routed). On that\n# path the gateway is the source of truth for identity; falling back to the\n# literal \"mcp-agent\" tool-param default would silently attribute every write\n# from a tenant-key holder to a single shared identity (friction §2.8 / Stage 6b).\n_via_gateway_var: contextvars.ContextVar[bool] = contextvars.ContextVar(\"mcp_via_gateway\", default=False)\n# Cross-tenant read set plumbed from X-Readable-Tenant-IDs (CSV). Empty list\n# means single-tenant key (reads pinned to ``_tenant_id_var``). When populated\n# the home tenant_id is the first element and writes still go there.\n_readable_tenant_ids_var: contextvars.ContextVar[list[str] | None] = contextvars.ContextVar(\n    \"mcp_readable_tenant_ids\", default=None\n)\n_scopes_var: contextvars.ContextVar[set[str] | None] = contextvars.ContextVar(\"mcp_scopes\", default=None)\n\n_UNAUTH = \"__unauthenticated__\"\n_ADMIN = \"__admin__\"\n_NO_AUTH = \"__no_auth__\"\n_DEFAULT_AGENT_ID = \"mcp-agent\"\n\n\ndef _error_response(code: str, message: str, **details) -> str:\n    \"\"\"Return the canonical MCP error envelope as a JSON string.\n\n    Shape matches the REST surface (see ``core_api.errors.make_error_payload``):\n    ``{\"error\": {\"code\": \"...\", \"message\": \"...\", \"details\": {...}}}``.\n\n    The string is wrapped into a ``CallToolResult(isError=True)`` before\n    leaving the tool — either by ``_with_latency`` (which detects the\n    error shape) or by ``_as_error_result`` for pre-tool returns that\n    skip the latency stamp. Tool callsites keep returning plain strings;\n    the wrap happens at one of those two chokepoints (CAURA-000,\n    FRICTION-REPORT-V3 B2 — clients literal-reading the MCP spec were\n    seeing ``isError=False`` on every gateway-side refusal).\n    \"\"\"\n    from core_api.errors import make_error_payload\n\n    payload = make_error_payload(code, message, details=details if details else None)\n    return json.dumps(payload, default=str)\n\n\ndef _as_error_result(envelope: str) -> CallToolResult:\n    \"\"\"Wrap a ``_error_response`` JSON envelope into a CallToolResult\n    with ``isError=True``. The envelope JSON is preserved verbatim in\n    a single TextContent so callers reading ``result.content[0].text``\n    still get the structured payload. Used for the pre-tool / auth\n    return paths that don't run through ``_with_latency``.\n    \"\"\"\n    return CallToolResult(\n        content=[TextContent(type=\"text\", text=envelope)],\n        isError=True,\n    )\n\n\n# Pre-tool auth errors (returned directly, NOT through _with_latency, because\n# they fire before any tool work has begun, so we wrap them as\n# CallToolResults at module load — every tool that returns one\n# propagates ``isError=True`` to the MCP client.\n_AUTH_ERROR = _as_error_result(\n    _error_response(\n        \"UNAUTHORIZED\",\n        \"Missing or invalid X-API-Key header. Provide a tenant-scoped API key.\",\n    )\n)\n_ADMIN_ERROR = _as_error_result(\n    _error_response(\n        \"FORBIDDEN\",\n        \"Admin/system keys cannot be used with MCP. Use a tenant-scoped API key.\",\n    )\n)\n\n\nclass MCPAuthMiddleware:\n    \"\"\"ASGI middleware that resolves X-API-Key to tenant_id before MCP handlers run.\"\"\"\n\n    def __init__(self, app: ASGIApp):\n        self.app = app\n\n    async def __call__(self, scope: Scope, receive: Receive, send: Send):\n        if scope[\"type\"] == \"http\":\n            from core_api.config import settings\n\n            headers = dict(scope.get(\"headers\", []))\n\n            # Preferred path: enterprise nginx has already validated the\n            # session cookie / JWT / API key via auth_request and injected\n            # X-Tenant-ID. Trust that resolution verbatim — otherwise a\n            # browser dashboard call (which sends `Authorization: Bearer\n            # <session JWT>` alongside the gateway-injected X-Tenant-ID)\n            # falls into the Authorization→api_key fallback below, fails\n            # the admin-key comparison, and reports UNAUTH despite the\n            # gateway having already approved the caller.\n            tenant_header = headers.get(b\"x-tenant-id\", b\"\").decode()\n            if tenant_header:\n                _tenant_id_var.set(tenant_header)\n                _via_gateway_var.set(True)\n            else:\n                _via_gateway_var.set(False)\n                api_key = headers.get(b\"x-api-key\", b\"\").decode()\n                if not api_key:\n                    auth_header = headers.get(b\"authorization\", b\"\").decode()\n                    if auth_header.lower().startswith(\"bearer \"):\n                        api_key = auth_header[7:]\n                admin_key = get_admin_key()\n\n                if admin_key and api_key and _hmac.compare_digest(api_key, admin_key):\n                    _tenant_id_var.set(_ADMIN)\n                elif settings.is_standalone:\n                    from core_api.standalone import get_standalone_tenant_id\n\n                    _tenant_id_var.set(get_standalone_tenant_id())\n                elif not api_key:\n                    _tenant_id_var.set(_UNAUTH if admin_key else _NO_AUTH)\n                else:\n                    _tenant_id_var.set(_UNAUTH)\n\n            # X-Agent-ID injected by enterprise gateway for agent-scoped\n            # credentials (kind=agent_key). When present, this is the\n            # cryptographically verified agent identity.\n            agent_header = headers.get(b\"x-agent-id\", b\"\").decode()\n            _agent_id_var.set(agent_header or None)\n\n            # X-Readable-Tenant-IDs and X-Key-Scopes are plumbed by the gateway\n            # for credentials authorized to read beyond their home tenant\n            # (cross-tenant agent keys). Absent / empty headers leave the\n            # context vars at their single-tenant defaults.\n            # Always reset both context vars at the start of every request,\n            # not just when the header is present. ContextVars set inside a\n            # prior request can survive into the next request when the\n            # underlying ASGI task is reused or the var was never assigned a\n            # token-based reset. An absent header means \"single-tenant /\n            # full-scope\" — make that explicit so a previous request's\n            # cross-tenant read-set or read-only scope cannot bleed through.\n            readable_header = headers.get(b\"x-readable-tenant-ids\", b\"\").decode()\n            _readable_tenant_ids_var.set(\n                [t.strip() for t in readable_header.split(\",\") if t.strip()] if readable_header else None\n            )\n            # X-Capabilities is canonical from the unified auth-api;\n            # X-Key-Scopes is accepted as a back-compat alias during\n            # the gateway rollout window.\n            caps_header = (\n                headers.get(b\"x-capabilities\", b\"\").decode() or headers.get(b\"x-key-scopes\", b\"\").decode()\n            )\n            _scopes_var.set({s.strip() for s in caps_header.split(\",\") if s.strip()} if caps_header else None)\n\n        await self.app(scope, receive, send)\n\n\ndef _get_tenant() -> str:\n    return _tenant_id_var.get(_UNAUTH)\n\n\ndef _get_agent_id() -> str | None:\n    \"\"\"Return the verified agent_id from X-Agent-ID header, or None.\"\"\"\n    return _agent_id_var.get(None)\n\n\ndef _get_readable_tenants() -> list[str]:\n    \"\"\"Return the cross-tenant read set; empty for single-tenant keys.\"\"\"\n    return _readable_tenant_ids_var.get(None) or []\n\n\ndef _get_scopes() -> set[str] | None:\n    \"\"\"Return the credential's scope set, or None for full-scope (legacy) keys.\"\"\"\n    return _scopes_var.get(None)\n\n\ndef _is_write_allowed() -> bool:\n    \"\"\"Return False if the active credential is scope-limited to read-only.\"\"\"\n    scopes = _get_scopes()\n    if scopes is None:\n        return True\n    return \"write\" in scopes\n\n\ndef _refuse_default_agent_on_gateway(agent_id: str) -> str | None:\n    \"\"\"When the request came through the enterprise gateway (X-Tenant-ID set)\n    and the gateway didn't inject X-Agent-ID (mc_ tenant-key path), the caller\n    must supply a real agent_id. Falling back to the reserved ``\"mcp-agent\"``\n    default would silently attribute every write from a tenant-key holder to\n    one shared identity — the failure mode the friction report's bug repro\n    documented as ``agent row missing from list_agents``.\n\n    Returns an error envelope if the call should be refused; ``None`` to proceed.\n    Standalone, admin, and gateway-routed agent-scoped paths are unaffected:\n    standalone uses a stable single-tenant identity, admin is a system caller,\n    and an agent-scoped credential resolves X-Agent-ID via auth_validate so\n    this guard never fires for it.\n    \"\"\"\n    if not _via_gateway_var.get(False):\n        return None\n    if _get_agent_id() is not None:\n        return None\n    if agent_id != _DEFAULT_AGENT_ID:\n        return None\n    return _error_response(\n        \"MISSING_AGENT_ID\",\n        \"Writes via the gateway with a tenant-scoped credential must specify \"\n        \"an agent_id explicitly; the reserved default \"\n        f\"'{_DEFAULT_AGENT_ID}' is not accepted on this path. Either pass \"\n        \"agent_id=<your-agent-name> or provision an agent-scoped credential \"\n        \"(POST /api/v1/admin/agent-keys/provision, or via the dashboard at \"\n        \"Settings → Organization → API Credentials with kind=agent_key) — \"\n        \"those have agent identity bound at mint time and the gateway \"\n        \"injects X-Agent-ID for them.\",\n    )\n","lineStart":40,"lineEnd":279,"totalLines":2542,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","time":{"start":1780727706216,"end":1780727706222}},"metadata":{"openai":{"itemId":"fc_0cbf2f4b5d66edbe016a23bf9a20588191aaa55bf6688f1323"}},"id":"prt_e9ba4723a001lkVrBb5dd9JYbq","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba4392d001E9I9tmUrBHUGcq"}}
{"type":"tool_use","timestamp":1780727706259,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_cOmhYPY1LwXA3wpLv5uX2eZV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","offset":490,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py</path>\n<type>file</type>\n<content>\n490:     capped_top_k = min(top_k, MAX_SEARCH_TOP_K)\n491: \n492:     # Audit finding P3: prior implementation held ``_mcp_session()``\n493:     # open across the brief-generation LLM round-trip (~5-30s), pinning\n494:     # a pooled DB connection during work that is entirely network-bound\n495:     # to the LLM provider. The brief path also issued a duplicate\n496:     # ``search_memories`` call (once here, once inside ``recall()``).\n497:     # Both are fixed by doing all DB-bound work inside the session,\n498:     # capturing the search results + config + readable-tenant set, then\n499:     # closing the session before invoking ``summarize_memories`` for\n500:     # the LLM brief.\n501:     try:\n502:         async with _mcp_session() as db:\n503:             await check_and_increment(db, tenant_id, \"search\")\n504:             from core_api.repositories import agent_repo\n505:             from core_api.services.organization_settings import resolve_config\n506: \n507:             config = await resolve_config(db, tenant_id)\n508:             _ag = await agent_repo.get_by_id(db, agent_id, tenant_id)\n509:             agent_profile = None\n510:             if _ag:\n511:                 agent_profile = _ag.get(\"search_profile\") if isinstance(_ag, dict) else _ag.search_profile\n512:             # Fleet scope enforcement (parity with REST /search): a constrained\n513:             # agent that omits fleet_ids is scoped to its own fleet, and a single\n514:             # explicit fleet goes through the cross-fleet trust ladder. Closes the\n515:             # recall side of the cross-fleet content leak.\n516:             if _ag is not None and not fleet_ids:\n517:                 ag_fleet = _ag.get(\"fleet_id\") if isinstance(_ag, dict) else getattr(_ag, \"fleet_id\", None)\n518:                 ag_trust = (\n519:                     _ag.get(\"trust_level\", 0) if isinstance(_ag, dict) else getattr(_ag, \"trust_level\", 0)\n520:                 )\n521:                 if ag_fleet and ag_trust < 2:\n522:                     fleet_ids = [ag_fleet]\n523:             if fleet_ids and len(fleet_ids) == 1:\n524:                 await enforce_fleet_read(db, tenant_id, agent_id, fleet_ids[0])\n525:             # Cross-tenant recall widens via readable_tenant_ids when\n526:             # the caller authenticated with a cross-tenant credential\n527:             # (kind=cross_tenant) — the gateway plumbs\n528:             # ``X-Readable-Tenant-IDs`` and the MCP middleware parks\n529:             # it on ``_readable_tenant_ids_var``. Single-tenant\n530:             # credentials leave the var empty; ``search_memories`` falls\n531:             # back to ``WHERE tenant_id = $1`` in that case.\n532:             results = await search_memories(\n533:                 db,\n534:                 tenant_id=tenant_id,\n535:                 query=query,\n536:                 fleet_ids=fleet_ids,\n537:                 filter_agent_id=filter_agent_id,\n538:                 caller_agent_id=agent_id,\n539:                 memory_type_filter=memory_type,\n540:                 status_filter=status,\n541:                 top_k=capped_top_k,\n542:                 recall_boost=config.recall_boost,\n543:                 graph_expand=config.graph_expand,\n544:                 tenant_config=config,\n545:                 search_profile=agent_profile,\n546:                 readable_tenant_ids=_get_readable_tenants() or None,\n547:             )\n548:             # Cross-tenant read audit (F2): emit one event per source\n549:             # tenant when the credential widened beyond home. Async\n550:             # queue — does not block the response.\n551:             readable = _get_readable_tenants()\n552:             source_tenants = [t for t in readable if t and t != tenant_id]\n553:             if source_tenants:\n554:                 await log_cross_tenant_read(\n555:                     db,\n556:                     home_tenant_id=tenant_id,\n557:                     home_agent_id=agent_id,\n558:                     source_tenants=source_tenants,\n559:                     surface=\"memclaw_recall\",\n560:                     query_summary=(query or \"\")[:200],\n561:                 )\n562:         # ── Session closed; the LLM brief (when requested) runs without\n563:         # holding a DB connection.\n564:         payload: dict = {\n565:             \"results\": [r.model_dump(mode=\"json\") for r in results] if results else [],\n566:         }\n567:         if include_brief:\n568:             from core_api.services.recall_service import summarize_memories\n569: \n570:             payload[\"brief\"] = await summarize_memories(\n571:                 results,\n572:                 query,\n573:                 config,\n574:                 top_k=capped_top_k,\n575:             )\n576:         return _with_latency(json.dumps(payload, indent=2, default=str), t0)\n577:     except HTTPException as e:\n578:         logger.warning(\"MCP tool error (%s): %s\", e.status_code, e.detail)\n579:         return _with_latency(_error_response(code_for_status(e.status_code), str(e.detail)), t0)\n580: \n581: \n582: async def memclaw_write(\n583:     content: Annotated[str | None, Field(description=\"Single-write text.\")] = None,\n584:     items: Annotated[\n585:         list[dict] | None, Field(description=\"Batch of objects, ≤100; each needs 'content'.\")\n586:     ] = None,\n587:     agent_id: Annotated[str, Field(description=\"Caller agent.\")] = \"mcp-agent\",\n588:     fleet_id: Annotated[str | None, Field(description=\"Fleet scope.\")] = None,\n589:     visibility: Annotated[str | None, Field(description=\"scope_team|scope_org|scope_agent.\")] = None,\n590:     memory_type: Annotated[str | None, Field(description=\"Type (single only).\")] = None,\n591:     weight: Annotated[float | None, Field(description=\"0-1 (single only).\")] = None,\n592:     source_uri: Annotated[str | None, Field(description=\"Source URI (single only).\")] = None,\n593:     run_id: Annotated[str | None, Field(description=\"Run id (single only).\")] = None,\n594:     metadata: Annotated[dict | None, Field(description=\"Metadata (single only).\")] = None,\n595:     status: Annotated[str | None, Field(description=\"Status (single only).\")] = None,\n596:     write_mode: Annotated[str | None, Field(description=\"fast|strong|auto (single only).\")] = None,\n597: ) -> str:\n598:     \"\"\"Single OR batch write. Exactly one of {content, items} is required.\"\"\"\n599:     t0 = time.perf_counter()\n600:     if err := _check_auth():\n601:         return err\n602:     if err := _check_write_scope():\n603:         return err\n604:     if (content is None) == (items is None):\n605:         return _with_latency(\n606:             json.dumps(\n607:                 {\n608:                     \"error\": {\n609:                         \"code\": \"INVALID_ARGUMENTS\",\n610:                         \"message\": \"memclaw_write requires exactly one of {content, items}.\",\n611:                         \"details\": {\n612:                             \"received_content\": content is not None,\n613:                             \"received_items\": items is not None,\n614:                             \"resolution\": \"omit one\",\n615:                         },\n616:                     }\n617:                 }\n618:             ),\n619:             t0,\n620:         )\n621:     tenant_id = _get_tenant()\n622:     agent_id = _get_agent_id() or agent_id\n623:     if refuse := _refuse_default_agent_on_gateway(agent_id):\n624:         return _with_latency(refuse, t0)\n625:     # C3/C8 — reject reserved memory_types at the boundary before we\n626:     # touch the DB. Single-write checks the top-level kwarg; the batch\n627:     # path below loops over BulkMemoryItem after validation.\n628:     if content is not None and (refuse := _refuse_reserved_memory_type(memory_type)):\n629:         return _with_latency(refuse, t0)\n630: \n631:     async with _mcp_session() as db:\n632:         try:\n633:             # Register the calling agent (auto-create row on first write) and\n634:             # enforce trust gating for cross-fleet writes — same surface the\n635:             # REST write path uses. Without this, MCP writes succeed without\n636:             # ever creating an Agent row, so a follow-up\n637:             # PATCH /agents/{id}/trust 404s.\n638:             await enforce_fleet_write(db, tenant_id, agent_id, fleet_id)\n639:             if content is not None:\n640:                 await check_and_increment(db, tenant_id, \"write\")\n641:                 result = await create_memory(\n642:                     db,\n643:                     MemoryCreate(\n644:                         tenant_id=tenant_id,\n645:                         fleet_id=fleet_id,\n646:                         agent_id=agent_id,\n647:                         memory_type=memory_type,\n648:                         content=content,\n649:                         weight=weight,\n\n(Showing lines 490-649 of 2542. Use offset=650 to continue.)\n</content>","metadata":{"preview":"    capped_top_k = min(top_k, MAX_SEARCH_TOP_K)\n\n    # Audit finding P3: prior implementation held ``_mcp_session()``\n    # open across the brief-generation LLM round-trip (~5-30s), pinning\n    # a pooled DB connection during work that is entirely network-bound\n    # to the LLM provider. The brief path also issued a duplicate\n    # ``search_memories`` call (once here, once inside ``recall()``).\n    # Both are fixed by doing all DB-bound work inside the session,\n    # capturing the search results + config + readable-tenant set, then\n    # closing the session before invoking ``summarize_memories`` for\n    # the LLM brief.\n    try:\n        async with _mcp_session() as db:\n            await check_and_increment(db, tenant_id, \"search\")\n            from core_api.repositories import agent_repo\n            from core_api.services.organization_settings import resolve_config\n\n            config = await resolve_config(db, tenant_id)\n            _ag = await agent_repo.get_by_id(db, agent_id, tenant_id)\n            agent_profile = None","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","text":"    capped_top_k = min(top_k, MAX_SEARCH_TOP_K)\n\n    # Audit finding P3: prior implementation held ``_mcp_session()``\n    # open across the brief-generation LLM round-trip (~5-30s), pinning\n    # a pooled DB connection during work that is entirely network-bound\n    # to the LLM provider. The brief path also issued a duplicate\n    # ``search_memories`` call (once here, once inside ``recall()``).\n    # Both are fixed by doing all DB-bound work inside the session,\n    # capturing the search results + config + readable-tenant set, then\n    # closing the session before invoking ``summarize_memories`` for\n    # the LLM brief.\n    try:\n        async with _mcp_session() as db:\n            await check_and_increment(db, tenant_id, \"search\")\n            from core_api.repositories import agent_repo\n            from core_api.services.organization_settings import resolve_config\n\n            config = await resolve_config(db, tenant_id)\n            _ag = await agent_repo.get_by_id(db, agent_id, tenant_id)\n            agent_profile = None\n            if _ag:\n                agent_profile = _ag.get(\"search_profile\") if isinstance(_ag, dict) else _ag.search_profile\n            # Fleet scope enforcement (parity with REST /search): a constrained\n            # agent that omits fleet_ids is scoped to its own fleet, and a single\n            # explicit fleet goes through the cross-fleet trust ladder. Closes the\n            # recall side of the cross-fleet content leak.\n            if _ag is not None and not fleet_ids:\n                ag_fleet = _ag.get(\"fleet_id\") if isinstance(_ag, dict) else getattr(_ag, \"fleet_id\", None)\n                ag_trust = (\n                    _ag.get(\"trust_level\", 0) if isinstance(_ag, dict) else getattr(_ag, \"trust_level\", 0)\n                )\n                if ag_fleet and ag_trust < 2:\n                    fleet_ids = [ag_fleet]\n            if fleet_ids and len(fleet_ids) == 1:\n                await enforce_fleet_read(db, tenant_id, agent_id, fleet_ids[0])\n            # Cross-tenant recall widens via readable_tenant_ids when\n            # the caller authenticated with a cross-tenant credential\n            # (kind=cross_tenant) — the gateway plumbs\n            # ``X-Readable-Tenant-IDs`` and the MCP middleware parks\n            # it on ``_readable_tenant_ids_var``. Single-tenant\n            # credentials leave the var empty; ``search_memories`` falls\n            # back to ``WHERE tenant_id = $1`` in that case.\n            results = await search_memories(\n                db,\n                tenant_id=tenant_id,\n                query=query,\n                fleet_ids=fleet_ids,\n                filter_agent_id=filter_agent_id,\n                caller_agent_id=agent_id,\n                memory_type_filter=memory_type,\n                status_filter=status,\n                top_k=capped_top_k,\n                recall_boost=config.recall_boost,\n                graph_expand=config.graph_expand,\n                tenant_config=config,\n                search_profile=agent_profile,\n                readable_tenant_ids=_get_readable_tenants() or None,\n            )\n            # Cross-tenant read audit (F2): emit one event per source\n            # tenant when the credential widened beyond home. Async\n            # queue — does not block the response.\n            readable = _get_readable_tenants()\n            source_tenants = [t for t in readable if t and t != tenant_id]\n            if source_tenants:\n                await log_cross_tenant_read(\n                    db,\n                    home_tenant_id=tenant_id,\n                    home_agent_id=agent_id,\n                    source_tenants=source_tenants,\n                    surface=\"memclaw_recall\",\n                    query_summary=(query or \"\")[:200],\n                )\n        # ── Session closed; the LLM brief (when requested) runs without\n        # holding a DB connection.\n        payload: dict = {\n            \"results\": [r.model_dump(mode=\"json\") for r in results] if results else [],\n        }\n        if include_brief:\n            from core_api.services.recall_service import summarize_memories\n\n            payload[\"brief\"] = await summarize_memories(\n                results,\n                query,\n                config,\n                top_k=capped_top_k,\n            )\n        return _with_latency(json.dumps(payload, indent=2, default=str), t0)\n    except HTTPException as e:\n        logger.warning(\"MCP tool error (%s): %s\", e.status_code, e.detail)\n        return _with_latency(_error_response(code_for_status(e.status_code), str(e.detail)), t0)\n\n\nasync def memclaw_write(\n    content: Annotated[str | None, Field(description=\"Single-write text.\")] = None,\n    items: Annotated[\n        list[dict] | None, Field(description=\"Batch of objects, ≤100; each needs 'content'.\")\n    ] = None,\n    agent_id: Annotated[str, Field(description=\"Caller agent.\")] = \"mcp-agent\",\n    fleet_id: Annotated[str | None, Field(description=\"Fleet scope.\")] = None,\n    visibility: Annotated[str | None, Field(description=\"scope_team|scope_org|scope_agent.\")] = None,\n    memory_type: Annotated[str | None, Field(description=\"Type (single only).\")] = None,\n    weight: Annotated[float | None, Field(description=\"0-1 (single only).\")] = None,\n    source_uri: Annotated[str | None, Field(description=\"Source URI (single only).\")] = None,\n    run_id: Annotated[str | None, Field(description=\"Run id (single only).\")] = None,\n    metadata: Annotated[dict | None, Field(description=\"Metadata (single only).\")] = None,\n    status: Annotated[str | None, Field(description=\"Status (single only).\")] = None,\n    write_mode: Annotated[str | None, Field(description=\"fast|strong|auto (single only).\")] = None,\n) -> str:\n    \"\"\"Single OR batch write. Exactly one of {content, items} is required.\"\"\"\n    t0 = time.perf_counter()\n    if err := _check_auth():\n        return err\n    if err := _check_write_scope():\n        return err\n    if (content is None) == (items is None):\n        return _with_latency(\n            json.dumps(\n                {\n                    \"error\": {\n                        \"code\": \"INVALID_ARGUMENTS\",\n                        \"message\": \"memclaw_write requires exactly one of {content, items}.\",\n                        \"details\": {\n                            \"received_content\": content is not None,\n                            \"received_items\": items is not None,\n                            \"resolution\": \"omit one\",\n                        },\n                    }\n                }\n            ),\n            t0,\n        )\n    tenant_id = _get_tenant()\n    agent_id = _get_agent_id() or agent_id\n    if refuse := _refuse_default_agent_on_gateway(agent_id):\n        return _with_latency(refuse, t0)\n    # C3/C8 — reject reserved memory_types at the boundary before we\n    # touch the DB. Single-write checks the top-level kwarg; the batch\n    # path below loops over BulkMemoryItem after validation.\n    if content is not None and (refuse := _refuse_reserved_memory_type(memory_type)):\n        return _with_latency(refuse, t0)\n\n    async with _mcp_session() as db:\n        try:\n            # Register the calling agent (auto-create row on first write) and\n            # enforce trust gating for cross-fleet writes — same surface the\n            # REST write path uses. Without this, MCP writes succeed without\n            # ever creating an Agent row, so a follow-up\n            # PATCH /agents/{id}/trust 404s.\n            await enforce_fleet_write(db, tenant_id, agent_id, fleet_id)\n            if content is not None:\n                await check_and_increment(db, tenant_id, \"write\")\n                result = await create_memory(\n                    db,\n                    MemoryCreate(\n                        tenant_id=tenant_id,\n                        fleet_id=fleet_id,\n                        agent_id=agent_id,\n                        memory_type=memory_type,\n                        content=content,\n                        weight=weight,","lineStart":490,"lineEnd":649,"totalLines":2542,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/mcp_server.py","time":{"start":1780727706236,"end":1780727706258}},"metadata":{"openai":{"itemId":"fc_0cbf2f4b5d66edbe016a23bf9a20688191a89f8eaacf9f88c8"}},"id":"prt_e9ba4726b001QAE1ovxTtGliV4","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba4392d001E9I9tmUrBHUGcq"}}
