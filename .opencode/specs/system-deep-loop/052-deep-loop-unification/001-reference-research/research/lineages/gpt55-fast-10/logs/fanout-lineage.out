 validate lineage consistency","status":"pending","priority":"high"},{"content":"Return required FANOUT_LINEAGE_COMPLETE marker","status":"pending","priority":"high"}],"truncated":false},"title":"5 todos","time":{"start":1783489117365,"end":1783489117367}},"metadata":{"openai":{"itemId":"fc_080d7e264695dcb3016a4de25b22888191b8dc1e9755951b7d"}},"id":"prt_f403c340c001LloLOJz7Y7MtyO","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f403c0e1d001RY0HFhGtfjyZNG"}}
