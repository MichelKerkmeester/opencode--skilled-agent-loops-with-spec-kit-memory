{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "verbatimModuleSyntax": true,
    "rootDir": "./mcp-server",
    "outDir": "./mcp-server/dist",
    "tsBuildInfoFile": "./mcp-server/dist/tsconfig.tsbuildinfo",
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "mcp-server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "mcp-server/dist",
    "mcp-server/tests/**/*.ts",
    "mcp-server/stress-test/**/*.ts",
    "mcp-server/**/__tests__/**/*.ts",
    "**/*.test.ts",
    "**/*.vitest.ts",
    "**/*.test-d.ts"
  ]
}
