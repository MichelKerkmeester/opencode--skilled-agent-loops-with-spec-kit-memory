   105	    if (next !== undefined && !next.startsWith('--')) {
   106	      args[key] = next;
   107	      index += 1;
   108	    } else {
   109	      args[key] = true;
   110	    }
   111	  }
   112	  return args;
   113	}
   114	
   115	function resolveMode(rawMode) {
   116	  if (rawMode === undefined) return 'agent-improvement';
   117	  if (VALID_MODES.has(rawMode)) return rawMode;
   118	  process.stderr.write(`loop-host: unknown mode '${rawMode}', defaulting to 'agent-improvement'\n`);
   119	  return 'agent-improvement';
   120	}
   121	
   122	/**
   123	 * Pure planner: map (mode, args) -> the ordered script invocations to run.
   124	 * Planning is separated from execution so the backward-compat identity gate
   125	 * (TST-1) can assert byte-identical plans for the default and explicit
   126	 * agent-improvement routes without spawning anything.
   127	 *
   128	 * @returns {{ ok: true, steps: Array<{script: string, args: string[]}> } | { ok: false, error: string }}
   129	 */
   130	function planInvocation(mode, args) {
   131	  if (mode === 'model-benchmark') {
   132	    if (!args.profile || !args['outputs-dir']) {
   133	      return { ok: false, error: 'model-benchmark: missing required --profile=<path-or-id> and --outputs-dir=<path>' };
   134	    }
   135	    // EC-5: materialize MUST run (and succeed) before run-benchmark, else scoring
   136	    // silently produces all-zero "missing-output" results. These scripts use
   137	    // space-separated args.
   138	    //
   139	    // Both steps share one option schema (BENCHMARK_* lists) so forwarding stays
   140	    // in sync with run-benchmark.cjs and the materializer, instead of a hand-rolled
   141	    // per-flag chain that silently drifts (P2 "Benchmark option schema split").
   142	    // run-benchmark.cjs forwards scorer/grader/integration-report so the journal
   143	    // and report.json agree on the requested method; the materializer forwards
   144	    // --profiles-dir so a profile-by-ID resolves identically in both steps (F-P1-4b).
   145	    const materializeArgs = ['--profile', args.profile, '--outputs-dir', args['outputs-dir']];
   146	    for (const opt of BENCHMARK_MATERIALIZE_OPTIONS) {
   147	      if (args[opt] !== undefined) materializeArgs.push(`--${opt}`, String(args[opt]));
   148	    }
   149	    const benchArgs = ['--profile', args.profile, '--outputs-dir', args['outputs-dir']];
   150	    for (const opt of BENCHMARK_RUN_OPTIONS) {
   151	      if (args[opt] !== undefined) benchArgs.push(`--${opt}`, String(args[opt]));
   152	    }
   153	    return {
   154	      ok: true,
   155	      steps: [
   156	        { script: 'materialize-benchmark-fixtures.cjs', args: materializeArgs },
   157	        { script: 'run-benchmark.cjs', args: benchArgs },
   158	      ],
   159	    };
   160	  }
   161	  // agent-improvement (default). score-candidate.cjs uses key=value args.
   162	  if (!args.candidate) {
   163	    return { ok: false, error: 'agent-improvement: missing required --candidate=<path>' };
   164	  }
   165	  const scoreArgs = [`--candidate=${args.candidate}`];
   166	  if (args.baseline) scoreArgs.push(`--baseline=${args.baseline}`);
   167	  if (args.output) scoreArgs.push(`--output=${args.output}`);
   168	  return { ok: true, steps: [{ script: 'score-candidate.cjs', args: scoreArgs }] };
   169	}
   170	
   171	function runNode(scriptName, scriptArgs) {
   172	  const scriptPath = resolveScriptPath(scriptName);
   173	  const res = spawnSync('node', [scriptPath, ...scriptArgs], {
   174	    stdio: 'inherit',
   175	    encoding: 'utf8',
   176	  });
   177	  return res.status == null ? 1 : res.status;
   178	}
   179	
   180	function runPlan(plan) {
   181	  if (!plan.ok) {
   182	    process.stderr.write(`loop-host: ${plan.error}\n`);
   183	    return 2;
   184	  }
   185	  for (const step of plan.steps) {
   186	    const exit = runNode(step.script, step.args);
   187	    if (exit !== 0) {
   188	      process.stderr.write(`loop-host: ${step.script} failed (exit ${exit}); aborting remaining steps\n`);
   189	      return exit;
   190	    }
   191	  }
   192	  return 0;
   193	}
   194	
   195	function main() {
   196	  const args = parseArgs(process.argv.slice(2));
   197	  const mode = resolveMode(args.mode);
   198	  process.exit(runPlan(planInvocation(mode, args)));
   199	}
   200	
   201	if (require.main === module) main();
   202	
   203	module.exports = { parseArgs, resolveMode, planInvocation, resolveScriptPath, VALID_MODES };

