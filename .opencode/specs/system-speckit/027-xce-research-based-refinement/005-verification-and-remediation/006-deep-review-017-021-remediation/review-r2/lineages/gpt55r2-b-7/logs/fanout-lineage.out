{"type":"tool_use","timestamp":1781763323895,"sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","part":{"type":"tool","tool":"read","callID":"call_h71IiwhkVaa0a4HNNyEWJyDn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":190},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n\n(Showing lines 1-190 of 650. Use offset=191 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;","lineStart":1,"lineEnd":190,"totalLines":650,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781763323879,"end":1781763323893}},"metadata":{"openai":{"itemId":"fc_0f640e13738b2698016a338cf979088191a47bc7e4f375f113"}},"id":"prt_ed95eaea4001I2F1Oe7eCx7Z8Y","sessionID":"ses_126a3e098ffexlbbiPvr4M06CK","messageID":"msg_ed95e8eb5001zTQcFKn3UGWOCD"}}
