  1010	function waitForChildExit(child, timeoutMs) {
  1011	  if (!isChildRunning(child)) return Promise.resolve(true);
  1012	  return new Promise((resolve) => {
  1013	    let settled = false;
  1014	    const finish = (exited) => {
  1015	      if (settled) return;
  1016	      settled = true;
  1017	      clearTimeout(timer);
  1018	      child.off('exit', onExit);
  1019	      resolve(exited);
  1020	    };
  1021	    const onExit = () => finish(true);
  1022	    const timer = setTimeout(() => finish(false), timeoutMs);
  1023	    timer.unref?.();
  1024	    child.once('exit', onExit);
  1025	  });
  1026	}
