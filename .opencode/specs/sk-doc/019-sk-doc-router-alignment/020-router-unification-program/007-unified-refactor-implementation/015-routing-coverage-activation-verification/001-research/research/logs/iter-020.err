    38	
    39	// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over
    40	// .env, both are gitignored. Existing process.env wins over file values (do not override).
    41	// Minimal parser — no external dependency.
    42	function loadEnvFile(filePath) {
    43	  if (!fs.existsSync(filePath)) return 0;
    44	  let count = 0;
    45	  const raw = fs.readFileSync(filePath, 'utf8');
    46	  for (const line of raw.split('\n')) {
    47	    const trimmed = line.trim();
    48	    if (!trimmed || trimmed.startsWith('#')) continue;
    49	    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*)$/);
    50	    if (!m) continue;
    51	    const key = m[1];
    52	    let val = m[2];
    53	    // Strip matching outer quotes (single or double)
    54	    if ((val.startsWith('"') && val.endsWith('"')) || (val.startsWith("'") && val.endsWith("'"))) {
    55	      val = val.slice(1, -1);
    56	    }
    57	    if (!(key in process.env)) {
    58	      process.env[key] = val;
    59	      count++;
    60	    }
    61	  }
    62	  return count;
    63	}
    64	
    65	function isStrictModeDisabled(value) {
    66	  if (value === undefined || value === null) return false;
    67	  const v = String(value).trim().toLowerCase();
    68	  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';
    69	}
    70	for (const fname of ['.env.local', '.env']) {
    71	  const p = path.join(root, fname);
    72	  if (fs.existsSync(p)) {
    73	    const n = loadEnvFile(p);
    74	    if (n > 0) process.stderr.write(`[mk-skill-advisor-launcher] loaded ${n} env(s) from ${fname}\n`);
    75	  }
    76	}
