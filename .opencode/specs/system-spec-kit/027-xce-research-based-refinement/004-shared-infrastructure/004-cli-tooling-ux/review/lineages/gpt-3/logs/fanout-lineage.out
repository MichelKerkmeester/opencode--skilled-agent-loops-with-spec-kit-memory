timeoutMs);\n1047:       timer.unref?.();\n1048: \n1049:       this.socket.on('data', onData);\n1050:       this.socket.once('error', onError);\n1051:       this.socket.once('close', onClose);\n1052:       this.socket.write(`${JSON.stringify(request)}\\n`);\n1053:     });\n1054:   }\n1055: \n1056:   close(): void {\n1057:     this.socket.end();\n1058:     this.socket.destroy();\n1059:   }\n1060: }\n1061: \n1062: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n1063:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n1064:   if (initialProbe.status === 'alive') return;\n1065:   if (warmOnly) {\n1066:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n1067:   }\n1068:   spawnLauncher(paths);\n1069:   await waitForDaemon(socketPath, bridge, timeoutMs);\n1070: }\n1071: \n1072: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n1073:   ensureSocketEnvironment();\n1074:   const paths = findRepoPaths();\n1075:   const bridge = loadBridge(paths);\n1076:   const socketPath = bridge.getIpcSocketPath('mk-code-index', { dbDir: paths.dbDir });\n1077:   if (socketPathTooLong(socketPath)) {\n1078:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n1079:   }\n1080: \n1081:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n1082: \n1083:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n1084:   try {\n1085:     const initialize = await client.request('initialize', {\n1086:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n1087:       capabilities: {},\n1088:       clientInfo: { name: 'code-index-cli', version: readCliVersion(paths) },\n1089:     }, timeoutMs) as InitializeResult;\n1090:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n1091:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n1092:     }\n1093:     client.notify('notifications/initialized');\n1094:     return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n1095:   } finally {\n1096:     client.close();\n1097:   }\n1098: }\n1099: \n1100: export async function runCodeIndexCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n1101:   try {\n1102:     const parsed = parseCliArgs(argv);\n1103:     if (parsed.help) {\n1104:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n1105:       return EXIT_SUCCESS;\n1106:     }\n1107:     if (parsed.version) {\n1108:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n1109:       return EXIT_SUCCESS;\n1110:     }\n1111:     if (parsed.command === 'list-tools') {\n1112:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n1113:       return EXIT_SUCCESS;\n1114:     }\n1115:     if (parsed.command === 'completion') {\n1116:       if (!parsed.completionShell) {\n1117:         throw new CliUsageError('completion requires a shell: bash or zsh');\n1118:       }\n1119:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n1120:       return EXIT_SUCCESS;\n1121:     }\n1122: \n1123:     const validated = validateCommand(parsed);\n1124:     if (!validated) {\n1125:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n1126:     }\n1127:     const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n1128:     const { payload, isError } = extractToolPayload(validated.tool.name, result);\n1129:     const renderedPayload = normalizeBlockedPayload(validated.tool.name, payload);\n1130:     await writeLine(io.stdout, renderPayload(validated.tool.name, renderedPayload, parsed.format));\n1131:     if (validated.tool.name === 'detect_changes' && isParseErrorPayload(renderedPayload)) {\n1132:       return EXIT_USAGE;\n1133:     }\n1134:     return isError || isErrorPayload(renderedPayload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n1135:   } catch (error: unknown) {\n1136:     const exitCode = exitCodeForError(error);\n1137:     const message = error instanceof Error ? error.message : String(error);\n1138:     const unknownCommand = unknownCommandContext(message);\n1139:     const payload = {\n1140:       status: 'error',\n1141:       error: message,\n1142:       exitCode,\n1143:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n1144:       ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n1145:     };\n1146:     const format = (() => {\n1147:       try {\n1148:         return parseCliArgs(argv).format;\n1149:       } catch {\n1150:         return 'text' as OutputFormat;\n1151:       }\n1152:     })();\n1153:     if (format === 'json' || format === 'jsonl') {\n1154:       await writeLine(io.stderr, renderJson(payload, format));\n1155:     } else {\n1156:       await writeLine(io.stderr, [\n1157:         `ERROR: ${message}`,\n1158:         unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n1159:         unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n1160:       ].filter((line): line is string => Boolean(line)).join('\\n'));\n1161:     }\n1162:     return exitCode;\n1163:   }\n1164: }\n1165: \n1166: function isCliEntrypoint(): boolean {\n1167:   const invoked = process.argv[1];\n1168:   if (!invoked) return false;\n1169:   return path.resolve(invoked) === path.resolve(currentModulePath());\n1170: }\n1171: \n1172: export const __testing = {\n1173:   DEFAULT_SOCKET_DIR,\n1174:   EXIT_PROTOCOL,\n1175:   EXIT_RETRYABLE,\n1176:   EXIT_USAGE,\n1177:   commandMap,\n1178:   commandAliases,\n1179:   closes