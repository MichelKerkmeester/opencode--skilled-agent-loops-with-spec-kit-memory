   703	      cwd: input.workspaceRoot,
   704	      env: createCliChildEnv(env),
   705	      stdio: ['ignore', 'pipe', 'pipe'],
   706	    });
   707	    const timer = setTimeout(() => {
   708	      timedOut = true;
   709	      child.kill('SIGKILL');
   710	    }, timeoutMs);
   711	    timer.unref?.();
   712	    const finish = (result) => {
   713	      if (settled) return;
   714	      settled = true;
   715	      clearTimeout(timer);
   716	      resolvePromise(result);
   717	    };
   718	    child.stdout?.setEncoding('utf8');
   719	    child.stdout?.on('data', (chunk) => {
   720	      stdout += chunk;
