   196	    return {doc.relative_to(SKILL_ROOT).as_posix() for doc in docs}
   197	
   198	def keyword_present(keyword: str, text: str) -> bool:
   199	    """Boundary-aware match: bare substrings misroute ('pr' in 'improve prompt')."""
   200	    return re.search(rf"(?<![a-z0-9]){re.escape(keyword)}(?![a-z0-9])", text) is not None
   201	
   202	def score_intents(task) -> dict[str, float]:
   203	    text = _task_text(task)
   204	    scores = {intent: 0.0 for intent in INTENT_SIGNALS}
   205	    for intent, cfg in INTENT_SIGNALS.items():
   206	        for keyword in cfg["keywords"]:
   207	            if keyword_present(keyword, text):
   208	                scores[intent] += cfg["weight"]
   209	    return scores
   210	
   211	def select_intents(scores: dict[str, float], ambiguity_delta: float = 1.0, max_intents: int = 2) -> list[str]:
   212	    ranked = sorted(scores.items(), key=lambda item: item[1], reverse=True)
   213	    if not ranked or ranked[0][1] <= 0:
   214	        return ["QUALITY"]
   215	    selected = [ranked[0][0]]
   216	    if len(ranked) > 1 and ranked[1][1] > 0 and (ranked[0][1] - ranked[1][1]) <= ambiguity_delta:
   217	        selected.append(ranked[1][0])
   218	    return selected[:max_intents]
   219	
   220	def detect_surface_evidence(task, workspace_files=None, changed_files=None) -> str:
   221	    text = _task_text(task)
   222	    files = " ".join((workspace_files or []) + (changed_files or [])).lower()
   223	
   224	    if ".opencode/" in files or keyword_present("jsonc", text) or keyword_present("mcp", text):
   225	        return "sk-code:code-opencode"
   226	    if any(keyword_present(term, text) for term in ["frontend", "web", "css", "dom", "browser"]) or any(
   227	        marker in files for marker in ["next.config", "vite.config", "package.json", "src/"]
   228	    ):
   229	        return "sk-code:code-webflow"
   230	    return "sk-code:unknown"
   231	
   232	def route_review_resources(task, workspace_files=None, changed_files=None):
   233	    inventory = discover_markdown_resources()
   234	    text = _task_text(task)
   235	    scores = score_intents(task)
   236	    intents = select_intents(scores, ambiguity_delta=1.0)
   237	
   238	    loaded = []
   239	    seen = set()
   240	
   241	    def load_if_available(relative_path: str) -> None:
   242	        guarded = _guard_in_skill(relative_path)
   243	        if guarded in inventory and guarded not in seen:
   244	            load(guarded)
   245	            loaded.append(guarded)
   246	            seen.add(guarded)
   247	
   248	    for relative_path in DEFAULT_RESOURCES:
   249	        load_if_available(relative_path)
   250	
   251	    if sum(scores.values()) < 0.5:
   252	        return {
   253	            "intents": ["QUALITY"],
   254	            "needs_disambiguation": True,
   255	            "disambiguation_checklist": UNKNOWN_FALLBACK_CHECKLIST,
   256	            "surface_evidence": detect_surface_evidence(task, workspace_files, changed_files),
   257	            "resources": loaded,
   258	        }
   259	
   260	    for intent in intents:
   261	        for relative_path in RESOURCE_MAP.get(intent, []):
   262	            load_if_available(relative_path)
   263	
   264	    if any(keyword_present(keyword, text) for keyword in ON_DEMAND_KEYWORDS):
   265	        for paths in RESOURCE_MAP.values():
   266	            for relative_path in paths:
   267	                load_if_available(relative_path)
   268	
   269	    surface_evidence = detect_surface_evidence(task, workspace_files, changed_files)
   270	
   271	    precedence = {
   272	        "baseline_minimums": ["security", "correctness"],
   273	        "surface_overrides": ["style", "build", "test_commands", "surface_process"],
   274	        "on_conflict": "escalate",
   275	    }
   276	
   277	    return {
   278	        "intents": intents,
   279	        "scores": scores,
   280	        "surface_evidence": surface_evidence,
   281	        "precedence": precedence,
   282	        "resources": loaded,
   283	    }
   284	```
   285	
   286	---
   287	
   288	## 3. HOW IT WORKS
   289	
   290	### Phase 1: Scope and Baseline
   291	
   292	1. Inspect the review target (`git diff`, staged diff, file list, or commit range).
   293	2. For local diffs, optionally run `detect_changes` with the unified diff to identify affected symbols/files and readiness before narrowing evidence.
   294	3. If `detect_changes` returns blocked or unavailable, surface "structural-impact analysis unavailable" as a caveat and continue the plain git-diff review; never block the review on structural-impact availability.
   295	4. Load baseline standards from the `code-review` mode (of the sk-code family).
   296	5. Load `sk-code` surface standards evidence when a surface is detected.
   297	
   298	### Phase 2: Surface Alignment
   299	
   300	1. Load standards from `sk-code` for the detected surface only.
   301	2. Apply precedence matrix:
   302	   - Baseline security/correctness minimums always apply.
   303	   - Surface style/process/verification conventions win on conflicts.
   304	3. If precedence cannot be resolved deterministically, escalate before scoring.
   305	
   306	### Phase 3: Findings-First Analysis
   307	
   308	1. Analyze for security and correctness first.
   309	2. Analyze quality/performance, test adequacy, contract safety, and architecture concerns.
   310	3. Analyze KISS/DRY and SOLID violations (SRP/OCP/LSP/ISP/DIP) with evidence.
   311	4. Analyze removal opportunities with safe-now vs deferred classification.
   312	5. Produce findings ordered by severity (`P0`, `P1`, `P2`).
   313	6. For every actionable finding, classify fix scope as `instance-only`, `class-of-bug`, `cross-consumer`, `algorithmic`, `matrix/evidence`, or `test-isolation`. If unknown, default to class/cross-consumer until a producer/consumer inventory proves instance-only.
   314	
   315	#### Numeric Severity Calibration
   316	
   317	Use numeric calibration only as reviewer context, never as the gate. A finding may include an optional advisory `riskScore` to communicate relative risk, and reviewers may adjust that score by `+/-2` for local context such as exploitability, blast radius, user impact, confidence, or proven containment. The blocking decision still comes only from the `P0`/`P1`/`P2` severity contract. Do not introduce `score>=4` or any other numeric threshold as a blocker.
   318	
   319	#### Instance-Only Opt-Out
   320	
   321	A finding may use the narrow fix path only when all are true:
   322	
   323	- It is not P0/P1 security, path, auth/authz, sandboxing, env precedence, schema, persistence, or public-response behavior.
   324	- `rg` proves no same-class producer or consumer.
   325	- Verification is local and cheap: one focused test, one doc row, or one static audit command.
   326	- The fix response includes the exact command evidence for the opt-out.
   327	
   328	Otherwise, run the full fix completeness checklist.
   329	
   330	### Phase 4: Output and Next Action
   331	
   332	Required output contract:
   333	
   334	```markdown
   335	## Code Review Summary
   336	
   337	**Files reviewed**: X files, Y lines changed
   338	**Overall assessment**: [APPROVE / REQUEST_CHANGES / COMMENT]
   339	**Baseline used**: [sk-code (`code-review`)]
   340	**Surface evidence used**: [sk-code:code-webflow | sk-code:code-opencode | sk-code:unknown]
   341	
   342	## Findings
   343	
   344	### P0 - Critical
   345	1. [path:line] Title
   346	   - Risk
   347	   - User impact
   348	   - Finding class: [instance-only | class-of-bug | cross-consumer | algorithmic | matrix/evidence | test-isolation]
   349	   - Scope proof: [grep/test evidence proving class coverage or instance-only status]
   350	   - affectedSurfaceHints: [optional string array of short producer/consumer surface names; recommended for actionable findings, required for cross-consumer findings]
   351	   - riskScore: [optional advisory number only; never gating]
   352	   - Recommended fix
   353	
   354	### P1 - High
   355	...
   356	
   357	## Removal/Iteration Plan
   358	
   359	## Next Steps
   360	```
   361	
   362	After reporting findings, request explicit next action before any implementation follow-up.
   363	
   364	### Final-line exact-string contract (MANDATORY)
   365	
   366	Every review MUST end with exactly one of the following plain-text lines as the **absolute final line** of the output (no trailing whitespace, no variation):
   367	
   368	```
   369	Review status: APPROVED
   370	```
   371	
   372	```
   373	Review status: REQUESTED_CHANGES
   374	```
   375	
   376	```
   377	Review status: COMMENTED
   378	```
   379	
   380	**Example output bottom:**

