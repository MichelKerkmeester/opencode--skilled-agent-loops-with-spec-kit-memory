 Line 460:     top_k: Annotated[int, Field(description=\"1-20.\")] = DEFAULT_SEARCH_TOP_K,\n\n  Line 462:     \"\"\"Hybrid semantic+keyword recall, with optional LLM brief.\"\"\"\n\n  Line 467:         return _with_latency(\n\n  Line 477:         return _with_latency(\n\n  Line 489:         return _with_latency(refuse, t0)\n\n  Line 490:     capped_top_k = min(top_k, MAX_SEARCH_TOP_K)\n\n  Line 493:     # open across the brief-generation LLM round-trip (~5-30s), pinning\n\n  Line 495:     # to the LLM provider. The brief path also issued a duplicate\n\n  Line 500:     # the LLM brief.\n\n  Line 541:                 top_k=capped_top_k,\n\n  Line 560:                     query_summary=(query or \"\")[:200],\n\n  Line 562:         # ── Session closed; the LLM brief (when requested) runs without\n\n  Line 567:         if include_brief:\n\n  Line 570:             payload[\"brief\"] = await summarize_memories(\n\n  Line 574:                 top_k=capped_top_k,\n\n  Line 576:         return _with_latency(json.dumps(payload, indent=2, default=str), t0)\n\n  Line 579:         return _with_latency(_error_response(code_for_status(e.status_code), str(e.detail)), t0)\n\n  Line 582: async def memclaw_write(\n\n  Line 605:         return _with_latency(\n\n  Line 624:         return _with_latency(refuse, t0)\n\n  Line 629:         return _with_latency(refuse, t0)\n\n  Line 658:                 return _with_latency(_serialize(result), t0)\n\n  Line 661:                 return _with_latency(\n\n  Line 676:                 return _with_latency(\n\n  Line 692:                     return _with_latency(refuse, t0)\n\n  Line 708:             # client can pass an explicit token via metadata.\n\n  Line 710:             return _with_latency(_serialize(result), t0)\n\n  Line 730:                 return _with_latency(json.dumps(payload), t0)\n\n  Line 732:             return _with_latency(_error_response(code_for_status(e.status_code), str(e.detail)), t0)\n\n  Line 735: async def memclaw_manage(\n\n  Line 763:         return _with_latency(\n\n  Line 786:             return _with_latency(\n\n  Line 800:         return _with_latency(refuse, t0)\n\n  Line 806:                     return _with_latency(\n\n  Line 813:                     return _with_latency(\n\n  Line 822:                     return _with_latency(\n\n  Line 857:                 return _with_latency(json.dumps({\"deleted\": result.rowcount, \"requested\": len(uids)}), t0)\n\n  Line 865:                     return _with_latency(_error_response(\"NOT_FOUND\", \"Memory not found.\"), t0)\n\n  Line 876:                     return _with_latency(_error_response(\"NOT_FOUND\", \"Memory not found.\"), t0)\n\n  Line 912:                 return _with_latency(\n\n  Line 930:                     return _with_latency(_error_response(\"NOT_FOUND\", \"Memory not found.\"), t0)\n\n  Line 943:                     return _with_latency(_error_response(\"NOT_FOUND\", \"Memory not found.\"), t0)\n\n  Line 944:                 return _with_latency(\n\n  Line 974:                     return _with_latency(\n\n  Line 978:                     return _with_latency(\n\n  Line 987:                     return _with_latency(_error_response(\"NOT_FOUND\", \"Memory not found.\"), t0)\n\n  Line 998:                     return _with_latency(\n\n  Line 1017:                 return _with_latency(f\"Memory {memory_id} status updated: {old_status} -> {status}\", t0)\n\n  Line 1035:                     return _with_latency(\n\n  Line 1044:                 return _with_latency(_serialize(result), t0)\n\n  Line 1060:                     return _with_latency(\n\n  Line 1068:             return _with_latency(f\"Memory {memory_id} deleted.\", t0)\n\n  Line 1071:             return _with_latency(_error_response(code_for_status(e.status_code), str(e.detail)), t0)\n\n  Line 1074: async def memclaw_entity_get(\n\n  Line 1083:         return _with_latency(\n\n  Line 1091:         return _with_latency(text, t0)\n\n  Line 1094: async def memcl