    72	function ensurePhasePath(filePath) {
    73	  const relative = path.relative(PHASE_ROOT, filePath);
    74	  if (relative.startsWith('..') || path.isAbsolute(relative)) {
    75	    throw new Error(`artifact path escapes the phase root: ${filePath}`);
    76	  }
    77	}
    78	
    79	function writeBytes(filePath, bytes) {
