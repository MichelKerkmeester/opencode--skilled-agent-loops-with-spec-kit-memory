{"type":"tool_use","timestamp":1782750738900,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_80765f07da354e32adaa0bb3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-foundations/scripts/naming_doc_check.py"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-foundations/scripts/naming_doc_check.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: # ---------------------------------------------------------------\n3: # COMPONENT: DESIGN-SYSTEM NAMING AND DOC CHECKER\n4: # ---------------------------------------------------------------\n5: \"\"\"Deterministic naming and documentation checker for design-system artifacts.\n6: \n7: The gate applies only to token, component, and library artifacts. Ordinary\n8: skill, reference, example, and vocabulary markdown exits cleanly as not\n9: applicable.\n10: \n11: Usage:\n12:   naming_doc_check.py artifact.md\n13:   naming_doc_check.py --json artifact.md\n14: \n15: Exit: 0 = clean or not applicable; 1 = naming/doc violation; 2 = usage or read\n16: error.\n17: \"\"\"\n18: import json\n19: from pathlib import Path\n20: import re\n21: import sys\n22: from typing import Any, Optional\n23: \n24: ARTIFACT_KINDS = {\"token\", \"component\", \"library\"}\n25: TOKEN_PATTERN = re.compile(r\"(?<![A-Za-z0-9_-])--[A-Za-z0-9_][A-Za-z0-9_-]*(?![A-Za-z0-9_-])\")\n26: MARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+(.+?)\\s*(?:#+\\s*)?$\")\n27: FRONTMATTER_KIND = re.compile(r\"^artifact[-_]?kind\\s*:\\s*['\\\"]?([A-Za-z-]+)['\\\"]?\\s*$\", re.I)\n28: \n29: TOKEN_TIERS: list[tuple[str, re.Pattern[str]]] = [\n30:     (\"neutral ramp\", re.compile(r\"^--neutral-\\d{2,3}$\")),\n31:     (\"color role\", re.compile(r\"^--color-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n32:     (\"spacing baseline\", re.compile(r\"^--baseline$\")),\n33:     (\"spacing scale\", re.compile(r\"^--space-[a-z0-9]+(?:-[a-z0-9]+)*$\")),\n34:     (\"surface\", re.compile(r\"^--surface-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n35:     (\"text\", re.compile(r\"^--text-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n36:     (\"type\", re.compile(r\"^--type-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n37:     (\"elevation and shape\", re.compile(r\"^--(?:radius|shadow|layer|stroke|material)-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n38:     (\"motion and state\", re.compile(r\"^--(?:motion|state)-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n39: ]\n40: \n41: REQUIRED_HEADINGS: dict[str, list[dict[str, list[str]]]] = {\n42:     \"token\": [\n43:         {\"label\": \"COLOR RAMP\", \"aliases\": [\"color ramp\", \"color tokens\", \"color system\"]},\n44:         {\"label\": \"TYPE SCALE\", \"aliases\": [\"type scale\"]},\n45:         {\"label\": \"SPACING SCALE\", \"aliases\": [\"spacing scale\"]},\n46:         {\"label\": \"HAND OFF\", \"aliases\": [\"hand off\", \"handoff\", \"implementation handoff\"]},\n47:     ],\n48:     \"component\": [\n49:         {\"label\": \"COMPONENT CONTRACT\", \"aliases\": [\"component contract\"]},\n50:         {\"label\": \"VARIANTS\", \"aliases\": [\"variants\"]},\n51:         {\"label\": \"STATES\", \"aliases\": [\"states\"]},\n52:         {\"label\": \"TOKEN HOOKS\", \"aliases\": [\"token hooks\", \"tokens\"]},\n53:         {\"label\": \"USAGE\", \"aliases\": [\"usage\"]},\n54:     ],\n55:     \"library\": [\n56:         {\"label\": \"LIBRARY SCOPE\", \"aliases\": [\"library scope\"]},\n57:         {\"label\": \"FOUNDATIONS\", \"aliases\": [\"foundations\"]},\n58:         {\"label\": \"COMPONENTS\", \"aliases\": [\"components\"]},\n59:         {\"label\": \"HAND OFF\", \"aliases\": [\"hand off\", \"handoff\", \"implementation handoff\"]},\n60:     ],\n61: }\n62: \n63: KNOWN_PREFIXES = [\n64:     \"--baseline\",\n65:     \"--neutral-\",\n66:     \"--color-\",\n67:     \"--space-\",\n68:     \"--surface-\",\n69:     \"--text-\",\n70:     \"--type-\",\n71:     \"--radius-\",\n72:     \"--shadow-\",\n73:     \"--layer-\",\n74:     \"--stroke-\",\n75:     \"--material-\",\n76:     \"--motion-\",\n77:     \"--state-\",\n78: ]\n79: \n80: \n81: def _clean_cell(value: str) -> str:\n82:     value = value.strip()\n83:     if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n84:         value = value[1:-1].strip()\n85:     return value\n86: \n87: \n88: def _split_table_row(line: str) -> list[str]:\n89:     line = line.strip()\n90:     if not line.startswith(\"|\") or not line.endswith(\"|\"):\n91:         return []\n92:     return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n93: \n94: \n95: def _is_separator_row(cells: list[str]) -> bool:\n96:     return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n97: \n98: \n99: def _normalized_header(cells: list[str]) -> list[str]:\n100:     return [re.sub(r\"\\s+\", \" \", _clean_cell(cell).lower()) for cell in cells]\n101: \n102: \n103: def _normalize_heading(value: str) -> str:\n104:     value = re.sub(r\"^\\d+\\.\\s+\", \"\", value.strip())\n105:     value = value.strip(\"#\").strip()\n106:     value = re.sub(r\"[\\s_-]+\", \" \", value.lower())\n107:     return value\n108: \n109: \n110: def _frontmatter_artifact_kind(text: str) -> Optional[str]:\n111:     lines = text.splitlines()\n112:     if not lines or lines[0].strip() != \"---\":\n113:         return None\n114: \n115:     for line in lines[1:]:\n116:         if line.strip() == \"---\":\n117:             return None\n118:         match = FRONTMATTER_KIND.match(line.strip())\n119:         if match:\n120:             kind = match.group(1).strip().lower()\n121:             return kind if kind in ARTIFACT_KINDS else None\n122:     return None\n123: \n124: \n125: def _find_token_table_declarations(text: str) -> list[dict[str, Any]]:\n126:     lines = text.splitlines()\n127:     declarations: list[dict[str, Any]] = []\n128:     token_column: Optional[int] = None\n129:     in_table = False\n130:     awaiting_separator = False\n131:     seen: set[str] = set()\n132: \n133:     for line_number, line in enumerate(lines, 1):\n134:         cells = _split_table_row(line)\n135:         if not cells:\n136:             token_column = None\n137:             in_table = False\n138:             awaiting_separator = False\n139:             continue\n140: \n141:         normalized = _normalized_header(cells)\n142:         if \"token\" in normalized:\n143:             token_column = normalized.index(\"token\")\n144:             in_table = True\n145:             awaiting_separator = True\n146:             continue\n147: \n148:         if in_table and _is_separator_row(cells):\n149:             awaiting_separator = False\n150:             continue\n151: \n152:         if token_column is None or awaiting_separator:\n153:             continue\n154: \n155:         if len(cells) <= token_column:\n156:             continue\n157: \n158:         for match in TOKEN_PATTERN.finditer(_clean_cell(cells[token_column])):\n159:             name = match.group(0)\n160:             if name not in seen:\n161:                 declarations.append({\"name\": name, \"line\": line_number})\n162:                 seen.add(name)\n163: \n164:     return declarations\n165: \n166: \n167: def _find_all_token_declarations(text: str) -> list[dict[str, Any]]:\n168:     declarations: list[dict[str, Any]] = []\n169:     seen: set[str] = set()\n170:     for line_number, line in enumerate(text.splitlines(), 1):\n171:         for match in TOKEN_PATTERN.finditer(line):\n172:             name = match.group(0)\n173:             if name not in seen:\n174:                 declarations.append({\"name\": name, \"line\": line_number})\n175:                 seen.add(name)\n176:     return declarations\n177: \n178: \n179: def _headings(text: str) -> set[str]:\n180:     found = set()\n181:     for line in text.splitlines():\n182:         match = MARKDOWN_HEADING.match(line)\n183:         if match:\n184:             found.add(_normalize_heading(match.group(1)))\n185:     return found\n186: \n187: \n188: def _has_all_required_headings(text: str, artifact_kind: str) -> bool:\n189:     found = _headings(text)\n190:     required = REQUIRED_HEADINGS[artifact_kind]\n191:     return all(any(_normalize_heading(alias) in found for alias in item[\"aliases\"]) for item in required)\n192: \n193: \n194: def _detect_artifact(text: str) -> tuple[bool, Optional[str], str, list[dict[str, Any]]]:\n195:     frontmatter_kind = _frontmatter_artifact_kind(text)\n196:     table_declarations = _find_token_table_declarations(text)\n197: \n198:     if frontmatter_kind:\n199:         declarations = _find_all_token_declarations(text) if frontmatter_kind == \"token\" else table_declarations\n200:         return True, frontmatter_kind, \"frontmatter artifactKind\", declarations\n201: \n202:     if table_declarations and _has_all_required_headings(text, \"token\"):\n203:         return True, \"token\", \"token table with token-artifact headings\", table_declarations\n204: \n205:     return False, None, \"no design-system artifact marker\", []\n206: \n207: \n208: def _match_token_tier(name: str) -> Optional[str]:\n209:     for tier, pattern in TOKEN_TIERS:\n210:         if pattern.fullmatch(name):\n211:             return tier\n212:     return None\n213: \n214: \n215: def _token_reason(name: str) -> str:\n216:     if \"_\" in name:\n217:         return \"use hyphens, not underscores\"\n218:     if any(char.isupper() for char in name):\n219:         return \"use lowercase kebab-case, not camelCase or uppercase\"\n220:     if not any(name == prefix or name.startswith(prefix) for prefix in KNOWN_PREFIXES):\n221:         return \"category must be one of the design-system token tiers\"\n222:     return \"name does not match its tier regex\"\n223: \n224: \n225: def _check_tokens(declarations: list[dict[str, Any]], artifact_kind: str) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:\n226:     checked: list[dict[str, Any]] = []\n227:     invalid: list[dict[str, Any]] = []\n228: \n229:     for declaration in declarations:\n230:         name = declaration[\"name\"]\n231:         tier = _match_token_tier(name)\n232:         item = {**declaration, \"tier\": tier}\n233:         checked.append(item)\n234:         if tier is None:\n235:             invalid.append({**declaration, \"reason\": _token_reason(name)})\n236: \n237:     if artifact_kind == \"token\" and not declarations:\n238:         invalid.append({\"name\": None, \"line\": None, \"reason\": \"token artifact has no declared token names\"})\n239: \n240:     return checked, invalid\n241: \n242: \n243: def _check_headings(text: str, artifact_kind: str) -> tuple[list[str], list[str]]:\n244:     found = _headings(text)\n245:     required = REQUIRED_HEADINGS[artifact_kind]\n246:     missing = [\n247:         item[\"label\"]\n248:         for item in required\n249:         if not any(_normalize_heading(alias) in found for alias in item[\"aliases\"])\n250:     ]\n251:     return [item[\"label\"] for item in required], missing\n252: \n253: \n254: def check(text: str) -> dict[str, Any]:\n255:     applicable, artifact_kind, reason, declarations = _detect_artifact(text)\n256:     if not applicable or artifact_kind is None:\n257:         return {\n258:             \"applicable\": False,\n259:             \"artifact_kind\": None,\n260:             \"applicability_reason\": reason,\n261:             \"token_names\": [],\n262:             \"invalid_token_names\": [],\n263:             \"required_headings\": [],\n264:             \"missing_headings\": [],\n265:             \"ok\": True,\n266:         }\n267: \n268:     checked_tokens, invalid_tokens = _check_tokens(declarations, artifact_kind)\n269:     required_headings, missing_headings = _check_headings(text, artifact_kind)\n270:     ok = not invalid_tokens and not missing_headings\n271: \n272:     return {\n273:         \"applicable\": True,\n274:         \"artifact_kind\": artifact_kind,\n275:         \"applicability_reason\": reason,\n276:         \"token_names\": checked_tokens,\n277:         \"invalid_token_names\": invalid_tokens,\n278:         \"required_headings\": required_headings,\n279:         \"missing_headings\": missing_headings,\n280:         \"ok\": ok,\n281:     }\n282: \n283: \n284: def _print_text(path: Path, result: dict[str, Any]) -> None:\n285:     print(f\"Naming/doc gate - {path}\")\n286:     if not result[\"applicable\"]:\n287:         print(f\"NOT_APPLICABLE - {result['applicability_reason']}\")\n288:         return\n289: \n290:     print(f\"  artifact kind: {result['artifact_kind']} ({result['applicability_reason']})\")\n291:     print(f\"  token names: {len(result['token_names'])}\")\n292:     print(f\"  required headings: {', '.join(result['required_headings'])}\")\n293: \n294:     if result[\"ok\"]:\n295:         print(\"PASS - token names and required headings conform.\")\n296:         return\n297: \n298:     for item in result[\"invalid_token_names\"]:\n299:         name = item.get(\"name\") or \"<none>\"\n300:         line = item.get(\"line\")\n301:         prefix = f\"line {line}: \" if line else \"\"\n302:         print(f\"FAIL - {prefix}{name} - {item['reason']}\")\n303:     for heading in result[\"missing_headings\"]:\n304:         print(f\"FAIL - missing heading {heading}\")\n305: \n306: \n307: def main(argv: list[str]) -> int:\n308:     as_json = \"--json\" in argv\n309:     paths = [arg for arg in argv if arg != \"--json\"]\n310:     if len(paths) != 1:\n311:         sys.stderr.write(\"usage: naming_doc_check.py [--json] <artifact.md>\\n\")\n312:         return 2\n313: \n314:     path = Path(paths[0])\n315:     try:\n316:         text = path.read_text(encoding=\"utf-8\")\n317:     except OSError as exc:\n318:         sys.stderr.write(f\"cannot read {path}: {exc}\\n\")\n319:         return 2\n320: \n321:     result = check(text)\n322:     if as_json:\n323:         print(json.dumps({\"file\": str(path), **result}, indent=2))\n324:     else:\n325:         _print_text(path, result)\n326: \n327:     return 0 if result[\"ok\"] else 1\n328: \n329: \n330: if __name__ == \"__main__\":\n331:     raise SystemExit(main(sys.argv[1:]))\n\n(End of file - total 331 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n# ---------------------------------------------------------------\n# COMPONENT: DESIGN-SYSTEM NAMING AND DOC CHECKER\n# ---------------------------------------------------------------\n\"\"\"Deterministic naming and documentation checker for design-system artifacts.\n\nThe gate applies only to token, component, and library artifacts. Ordinary\nskill, reference, example, and vocabulary markdown exits cleanly as not\napplicable.\n\nUsage:\n  naming_doc_check.py artifact.md\n  naming_doc_check.py --json artifact.md\n\nExit: 0 = clean or not applicable; 1 = naming/doc violation; 2 = usage or read\nerror.\n\"\"\"\nimport json\nfrom pathlib import Path\nimport re","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/design-foundations/scripts/naming_doc_check.py","text":"#!/usr/bin/env python3\n# ---------------------------------------------------------------\n# COMPONENT: DESIGN-SYSTEM NAMING AND DOC CHECKER\n# ---------------------------------------------------------------\n\"\"\"Deterministic naming and documentation checker for design-system artifacts.\n\nThe gate applies only to token, component, and library artifacts. Ordinary\nskill, reference, example, and vocabulary markdown exits cleanly as not\napplicable.\n\nUsage:\n  naming_doc_check.py artifact.md\n  naming_doc_check.py --json artifact.md\n\nExit: 0 = clean or not applicable; 1 = naming/doc violation; 2 = usage or read\nerror.\n\"\"\"\nimport json\nfrom pathlib import Path\nimport re\nimport sys\nfrom typing import Any, Optional\n\nARTIFACT_KINDS = {\"token\", \"component\", \"library\"}\nTOKEN_PATTERN = re.compile(r\"(?<![A-Za-z0-9_-])--[A-Za-z0-9_][A-Za-z0-9_-]*(?![A-Za-z0-9_-])\")\nMARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+(.+?)\\s*(?:#+\\s*)?$\")\nFRONTMATTER_KIND = re.compile(r\"^artifact[-_]?kind\\s*:\\s*['\\\"]?([A-Za-z-]+)['\\\"]?\\s*$\", re.I)\n\nTOKEN_TIERS: list[tuple[str, re.Pattern[str]]] = [\n    (\"neutral ramp\", re.compile(r\"^--neutral-\\d{2,3}$\")),\n    (\"color role\", re.compile(r\"^--color-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n    (\"spacing baseline\", re.compile(r\"^--baseline$\")),\n    (\"spacing scale\", re.compile(r\"^--space-[a-z0-9]+(?:-[a-z0-9]+)*$\")),\n    (\"surface\", re.compile(r\"^--surface-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n    (\"text\", re.compile(r\"^--text-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n    (\"type\", re.compile(r\"^--type-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n    (\"elevation and shape\", re.compile(r\"^--(?:radius|shadow|layer|stroke|material)-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n    (\"motion and state\", re.compile(r\"^--(?:motion|state)-[a-z][a-z0-9]*(?:-[a-z0-9]+)*$\")),\n]\n\nREQUIRED_HEADINGS: dict[str, list[dict[str, list[str]]]] = {\n    \"token\": [\n        {\"label\": \"COLOR RAMP\", \"aliases\": [\"color ramp\", \"color tokens\", \"color system\"]},\n        {\"label\": \"TYPE SCALE\", \"aliases\": [\"type scale\"]},\n        {\"label\": \"SPACING SCALE\", \"aliases\": [\"spacing scale\"]},\n        {\"label\": \"HAND OFF\", \"aliases\": [\"hand off\", \"handoff\", \"implementation handoff\"]},\n    ],\n    \"component\": [\n        {\"label\": \"COMPONENT CONTRACT\", \"aliases\": [\"component contract\"]},\n        {\"label\": \"VARIANTS\", \"aliases\": [\"variants\"]},\n        {\"label\": \"STATES\", \"aliases\": [\"states\"]},\n        {\"label\": \"TOKEN HOOKS\", \"aliases\": [\"token hooks\", \"tokens\"]},\n        {\"label\": \"USAGE\", \"aliases\": [\"usage\"]},\n    ],\n    \"library\": [\n        {\"label\": \"LIBRARY SCOPE\", \"aliases\": [\"library scope\"]},\n        {\"label\": \"FOUNDATIONS\", \"aliases\": [\"foundations\"]},\n        {\"label\": \"COMPONENTS\", \"aliases\": [\"components\"]},\n        {\"label\": \"HAND OFF\", \"aliases\": [\"hand off\", \"handoff\", \"implementation handoff\"]},\n    ],\n}\n\nKNOWN_PREFIXES = [\n    \"--baseline\",\n    \"--neutral-\",\n    \"--color-\",\n    \"--space-\",\n    \"--surface-\",\n    \"--text-\",\n    \"--type-\",\n    \"--radius-\",\n    \"--shadow-\",\n    \"--layer-\",\n    \"--stroke-\",\n    \"--material-\",\n    \"--motion-\",\n    \"--state-\",\n]\n\n\ndef _clean_cell(value: str) -> str:\n    value = value.strip()\n    if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n        value = value[1:-1].strip()\n    return value\n\n\ndef _split_table_row(line: str) -> list[str]:\n    line = line.strip()\n    if not line.startswith(\"|\") or not line.endswith(\"|\"):\n        return []\n    return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n\n\ndef _is_separator_row(cells: list[str]) -> bool:\n    return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n\n\ndef _normalized_header(cells: list[str]) -> list[str]:\n    return [re.sub(r\"\\s+\", \" \", _clean_cell(cell).lower()) for cell in cells]\n\n\ndef _normalize_heading(value: str) -> str:\n    value = re.sub(r\"^\\d+\\.\\s+\", \"\", value.strip())\n    value = value.strip(\"#\").strip()\n    value = re.sub(r\"[\\s_-]+\", \" \", value.lower())\n    return value\n\n\ndef _frontmatter_artifact_kind(text: str) -> Optional[str]:\n    lines = text.splitlines()\n    if not lines or lines[0].strip() != \"---\":\n        return None\n\n    for line in lines[1:]:\n        if line.strip() == \"---\":\n            return None\n        match = FRONTMATTER_KIND.match(line.strip())\n        if match:\n            kind = match.group(1).strip().lower()\n            return kind if kind in ARTIFACT_KINDS else None\n    return None\n\n\ndef _find_token_table_declarations(text: str) -> list[dict[str, Any]]:\n    lines = text.splitlines()\n    declarations: list[dict[str, Any]] = []\n    token_column: Optional[int] = None\n    in_table = False\n    awaiting_separator = False\n    seen: set[str] = set()\n\n    for line_number, line in enumerate(lines, 1):\n        cells = _split_table_row(line)\n        if not cells:\n            token_column = None\n            in_table = False\n            awaiting_separator = False\n            continue\n\n        normalized = _normalized_header(cells)\n        if \"token\" in normalized:\n            token_column = normalized.index(\"token\")\n            in_table = True\n            awaiting_separator = True\n            continue\n\n        if in_table and _is_separator_row(cells):\n            awaiting_separator = False\n            continue\n\n        if token_column is None or awaiting_separator:\n            continue\n\n        if len(cells) <= token_column:\n            continue\n\n        for match in TOKEN_PATTERN.finditer(_clean_cell(cells[token_column])):\n            name = match.group(0)\n            if name not in seen:\n                declarations.append({\"name\": name, \"line\": line_number})\n                seen.add(name)\n\n    return declarations\n\n\ndef _find_all_token_declarations(text: str) -> list[dict[str, Any]]:\n    declarations: list[dict[str, Any]] = []\n    seen: set[str] = set()\n    for line_number, line in enumerate(text.splitlines(), 1):\n        for match in TOKEN_PATTERN.finditer(line):\n            name = match.group(0)\n            if name not in seen:\n                declarations.append({\"name\": name, \"line\": line_number})\n                seen.add(name)\n    return declarations\n\n\ndef _headings(text: str) -> set[str]:\n    found = set()\n    for line in text.splitlines():\n        match = MARKDOWN_HEADING.match(line)\n        if match:\n            found.add(_normalize_heading(match.group(1)))\n    return found\n\n\ndef _has_all_required_headings(text: str, artifact_kind: str) -> bool:\n    found = _headings(text)\n    required = REQUIRED_HEADINGS[artifact_kind]\n    return all(any(_normalize_heading(alias) in found for alias in item[\"aliases\"]) for item in required)\n\n\ndef _detect_artifact(text: str) -> tuple[bool, Optional[str], str, list[dict[str, Any]]]:\n    frontmatter_kind = _frontmatter_artifact_kind(text)\n    table_declarations = _find_token_table_declarations(text)\n\n    if frontmatter_kind:\n        declarations = _find_all_token_declarations(text) if frontmatter_kind == \"token\" else table_declarations\n        return True, frontmatter_kind, \"frontmatter artifactKind\", declarations\n\n    if table_declarations and _has_all_required_headings(text, \"token\"):\n        return True, \"token\", \"token table with token-artifact headings\", table_declarations\n\n    return False, None, \"no design-system artifact marker\", []\n\n\ndef _match_token_tier(name: str) -> Optional[str]:\n    for tier, pattern in TOKEN_TIERS:\n        if pattern.fullmatch(name):\n            return tier\n    return None\n\n\ndef _token_reason(name: str) -> str:\n    if \"_\" in name:\n        return \"use hyphens, not underscores\"\n    if any(char.isupper() for char in name):\n        return \"use lowercase kebab-case, not camelCase or uppercase\"\n    if not any(name == prefix or name.startswith(prefix) for prefix in KNOWN_PREFIXES):\n        return \"category must be one of the design-system token tiers\"\n    return \"name does not match its tier regex\"\n\n\ndef _check_tokens(declarations: list[dict[str, Any]], artifact_kind: str) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:\n    checked: list[dict[str, Any]] = []\n    invalid: list[dict[str, Any]] = []\n\n    for declaration in declarations:\n        name = declaration[\"name\"]\n        tier = _match_token_tier(name)\n        item = {**declaration, \"tier\": tier}\n        checked.append(item)\n        if tier is None:\n            invalid.append({**declaration, \"reason\": _token_reason(name)})\n\n    if artifact_kind == \"token\" and not declarations:\n        invalid.append({\"name\": None, \"line\": None, \"reason\": \"token artifact has no declared token names\"})\n\n    return checked, invalid\n\n\ndef _check_headings(text: str, artifact_kind: str) -> tuple[list[str], list[str]]:\n    found = _headings(text)\n    required = REQUIRED_HEADINGS[artifact_kind]\n    missing = [\n        item[\"label\"]\n        for item in required\n        if not any(_normalize_heading(alias) in found for alias in item[\"aliases\"])\n    ]\n    return [item[\"label\"] for item in required], missing\n\n\ndef check(text: str) -> dict[str, Any]:\n    applicable, artifact_kind, reason, declarations = _detect_artifact(text)\n    if not applicable or artifact_kind is None:\n        return {\n            \"applicable\": False,\n            \"artifact_kind\": None,\n            \"applicability_reason\": reason,\n            \"token_names\": [],\n            \"invalid_token_names\": [],\n            \"required_headings\": [],\n            \"missing_headings\": [],\n            \"ok\": True,\n        }\n\n    checked_tokens, invalid_tokens = _check_tokens(declarations, artifact_kind)\n    required_headings, missing_headings = _check_headings(text, artifact_kind)\n    ok = not invalid_tokens and not missing_headings\n\n    return {\n        \"applicable\": True,\n        \"artifact_kind\": artifact_kind,\n        \"applicability_reason\": reason,\n        \"token_names\": checked_tokens,\n        \"invalid_token_names\": invalid_tokens,\n        \"required_headings\": required_headings,\n        \"missing_headings\": missing_headings,\n        \"ok\": ok,\n    }\n\n\ndef _print_text(path: Path, result: dict[str, Any]) -> None:\n    print(f\"Naming/doc gate - {path}\")\n    if not result[\"applicable\"]:\n        print(f\"NOT_APPLICABLE - {result['applicability_reason']}\")\n        return\n\n    print(f\"  artifact kind: {result['artifact_kind']} ({result['applicability_reason']})\")\n    print(f\"  token names: {len(result['token_names'])}\")\n    print(f\"  required headings: {', '.join(result['required_headings'])}\")\n\n    if result[\"ok\"]:\n        print(\"PASS - token names and required headings conform.\")\n        return\n\n    for item in result[\"invalid_token_names\"]:\n        name = item.get(\"name\") or \"<none>\"\n        line = item.get(\"line\")\n        prefix = f\"line {line}: \" if line else \"\"\n        print(f\"FAIL - {prefix}{name} - {item['reason']}\")\n    for heading in result[\"missing_headings\"]:\n        print(f\"FAIL - missing heading {heading}\")\n\n\ndef main(argv: list[str]) -> int:\n    as_json = \"--json\" in argv\n    paths = [arg for arg in argv if arg != \"--json\"]\n    if len(paths) != 1:\n        sys.stderr.write(\"usage: naming_doc_check.py [--json] <artifact.md>\\n\")\n        return 2\n\n    path = Path(paths[0])\n    try:\n        text = path.read_text(encoding=\"utf-8\")\n    except OSError as exc:\n        sys.stderr.write(f\"cannot read {path}: {exc}\\n\")\n        return 2\n\n    result = check(text)\n    if as_json:\n        print(json.dumps({\"file\": str(path), **result}, indent=2))\n    else:\n        _print_text(path, result)\n\n    return 0 if result[\"ok\"] else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main(sys.argv[1:]))","lineStart":1,"lineEnd":331,"totalLines":331,"truncated":false}},"title":".opencode/skills/sk-design/design-foundations/scripts/naming_doc_check.py","time":{"start":1782750738894,"end":1782750738899}},"id":"prt_f143979cc001YxocW4nTQ7DQ3J","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f14394674001elbPzTZBjfvR5r"}}
