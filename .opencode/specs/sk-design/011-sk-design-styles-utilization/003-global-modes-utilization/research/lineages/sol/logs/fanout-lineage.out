iled: salvage.failed };\n1922:         failure.missingArtifacts = [];\n1923:         throw failure;\n1924:       }\n1925: \n1926:       const output = { label: lineage.label, exitCode, timedOut, salvage, ...slotAccounting };\n1927:       if (stateRead.statePath && !stateRead.missing && !stateRead.parseError) {\n1928:         const slotWindowEndIso = new Date().toISOString();\n1929:         try {\n1930:           const timestampCheck = checkLineageTimestampWindow(stateRead.records, {\n1931:             windowStart: slotWindowStartIso,\n1932:             windowEnd: slotWindowEndIso,\n1933:             toleranceMs: DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1934:           });\n1935:           if (timestampCheck.anomalous > 0) {\n1936:             const timestampAnomaly = buildTimestampAnomalyPayload({\n1937:               lineage,\n1938:               statePath: stateRead.statePath,\n1939:               check: timestampCheck,\n1940:             });\n1941:             appendFanoutStatusLedger(ledgerPath, {\n1942:               event: 'timestamp_anomaly',\n1943:               status: 'warning',\n1944:               severity: 'warning',\n1945:               label: lineage.label,\n1946:               at: new Date().toISOString(),\n1947:               ...timestampAnomaly,\n1948:             });\n1949:             output.timestamp_anomaly = timestampAnomaly;\n\n(Showing lines 1780-1949 of 2021. Use offset=1950 to continue.)\n</content>","metadata":{"preview":"      if (\n        isInsideFanoutLineage\n        && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n      ) {\n        throw new Error(\n          `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n        );\n      }\n\n      // Stamp the dispatch stack with this lineage's executor kind so a seat that\n      // tries to recursively launch the same kind is detectable by the runtime\n      // recursion guard (detec