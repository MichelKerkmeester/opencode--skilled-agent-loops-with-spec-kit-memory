    63	function computeDatabasePaths(): DatabasePaths {
    64	  // H8 FIX: Re-check SPEC_KIT_DB_DIR at call time to support runtime overrides
    65	  // (e.g. tests that set the env var after module import). Fall back to the
    66	  // import-time DB_PATH when no runtime override is present.
    67	  const runtimeDbDir = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();
    68	  const runtimeDbPath = process.env.MEMORY_DB_PATH?.trim();
