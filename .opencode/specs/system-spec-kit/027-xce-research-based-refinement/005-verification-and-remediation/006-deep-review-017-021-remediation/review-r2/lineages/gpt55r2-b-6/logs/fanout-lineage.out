d(ready.prepared)) {\n3900:         return ready;\n3901:       }\n3902: \n3903:       // Rebuild the canonical merge while the spec-folder lock is held so\n3904:       // concurrent routed saves always merge against the latest on-disk doc.\n3905:       const canonicalPrepared = await buildCanonicalAtomicPreparedSave(currentParams, database);\n3906:       if (canonicalPrepared.status !== 'ready') {\n3907:         return canonicalPrepared;\n3908:       }\n3909: \n3910:       return {\n3911:         status: 'ready',\n3912:         prepared: canonicalPrepared.prepared,\n3913:         specFolder: canonicalPrepared.prepared.preparedMemory.parsed.specFolder,\n3914:         persistedContent: canonicalPrepared.persistedContent,\n3915:         persistedFilePath: canonicalPrepared.persistedFilePath,\n3916:       } as const;\n3917:     },\n3918:     indexPrepared: ({ ready, params: currentParams, force }) => {\n3919:       const effectiveFilePath = ready.persistedFilePath ?? currentParams.file_path;\n3920:       const routedPrepared = isCanonicalAtomicPrepared(ready.prepared)\n3921:         ? ready.prepared\n3922:         : null;\n3923: \n3924:       if (routedPrepared) {\n3925:         const validationResult = validateCanonicalPreparedSave(routedPrepared);\n3926:         if (!validationResult.ok) {\n3927:           return validationResult.rejection;\n3928:         }\n3929: \n3930:         return processPreparedMemory(routedPrepared.preparedMemory, effectiveFilePath, {\n3931:           force,\n3932:           asyncEmbedding: true,\n3933:           plannerMode: currentParams.plannerMode,\n3934:           persistQualityLoopContent: false,\n3935:           specFolderLockAlreadyHeld: true,\n3936:           qualityGateMode: 'warn-only',\n3937:           routing: routedPrepared.routing,\n3938:         }).then((result) => {\n3939:           for (const warning of validationResult.warnings) {\n3940:             appendResultWarning(result, warning);\n3941:           }\n3942:           return result;\n3943:         });\n3944:       }\n3945: \n3946:       return processPreparedMemory(ready.prepared as PreparedParsedMemory, currentParams.file_path, {\n3947:         force,\n3948:         asyncEmbedding: true,\n3949:         plannerMode: currentParams.plannerMode,\n3950:         persistQualityLoopContent: false,\n3951:         specFolderLockAlreadyHeld: true,\n3952:         routing: buildRoutedSaveOptions(currentParams.file_path, currentParams.routeAs, currentParams.mergeModeHint, currentParams.targetAnchorId),\n3953:       });\n3954:     },\n3955:     getPendingPath: (currentFilePath) => `${transactionManager.getPendingPath(currentFilePath)}.${randomUUID().slice(0, 8)}`,\n3956:     withSpecFolderLock,\n3957:     captureOriginalState: captureAtomicSaveOriginalState,\n3958:     restoreOriginalState: restoreAtomicSaveOriginalState,\n3959:     cleanupPendingFile: cleanupAtomicSavePendingFile,\n3960:     writePendingFile: (pendingPath, persistedContent) => {\n3961:       fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n3962:       fs.writeFileSync(pendingPath, persistedContent, 'utf-8');\n3963:     },\n3964:     promotePendingFile: (pendingPath, currentFilePath) => {\n3965:       fs.mkdirSync(path.dirname(currentFilePath), { recursive: true });\n3966:       fs.renameSync(pendingPath, currentFilePath);\n3967:     },\n3968:     mapSuccessResult: (indexResult, context) => {\n3969:       const effectiveFilePath = context.ready.persistedFilePath ?? file_path;\n3970:       const routedRouteCategory = indexResult.routeCategory ?? routing?.routeAs;\n3971:       const routedMergeMode = indexResult.mergeMode ?? routing?.mergeModeHint;\n3972:       const routedTargetDocPath = indexResult.targetDocPath ?? effectiveFilePath;\n3973: \n3974:       if (indexResult.status !== 'unchanged' && indexResult.status !== 'duplicate' && indexResult.id > 0) {\n3975:         applyPostInsertMetadata(database, indexResult.id, {});\n3976:       }\n3977: \n3978:       const 