2098:   });\n2099:   const answeredSet = new Set(\n2100:     questionCoverageRecords.flatMap((record) => (Array.isArray(record.answeredQuestions) ? record.answeredQuestions : [])).map(normalizeText),\n2101:   );\n2102: \n2103:   const keyedQuestions = strategyQuestions.map((question, index) => {\n2104:     const normalized = normalizeText(question.text);\n2105:     const resolved = question.checked || answeredSet.has(normalized);\n2106:     const id = normalizeQuestionId(question.id);\n2107:     const promotedQuestionId = normalizeQuestionId(question.promotedQuestionId);\n2108:     const inboxId = normalizeQuestionId(question.inboxId);\n2109:     const injectedAtIteration = normalizeQuestionIteration(question.injectedAtIteration);\n2110:     const operatorDecision = normalizeQuestionDecision(question.operatorDecision);\n2111:     const conflictId = normalizeQuestionId(question.conflictId);\n2112:     return {\n2113:       id: id || promotedQuestionId || `question-${index + 1}-${slugify(normalized)}`,\n2114:       inboxId,\n2115:       text: normalized,\n2116:       origin: normalizeQuestionOrigin(question.origin),\n2117:       source: normalizeQuestionSource(question.source, LEGACY_IMPORT_SOURCE),\n2118:       injectedAtIteration,\n2119:       promotedQuestionId,\n2120:       ...(operatorDecision ? { operatorDecision } : {}),\n2121:       ...(conflictId ? { conflictId } : {}),\n2122:       addedAtIteration: injectedAtIteration,\n2123:       resolvedAtIteration: resolved\n2124:         ? questionCoverageRecords.find((record) =>\n2125:             Array.isArray(record.answeredQuestions)\n2126:               && record.answeredQuestions.map(normalizeText).includes(normalized),\n2127:           )?.run ?? 0\n2128:         : null,\n2129:       resolved,\n2130:     };\n2131:   });\n2132: \n2133:   const keyFindings = uniqueById(\n2134:     iterationFiles\n2135:       .flatMap((iteration) =>\n2136:         iteration.findings.map((finding, index) => ({\n2137:           id: `finding-${iteration.run}-${index + 1}-${slugify(finding)}`,\n2138:           text: finding,\n2139:           addedAtIteration: iteration.run,\n2140:           sources: iteration.sources,\n2141:         })),\n2142:       )\n2143:       .sort((left, right) => left.addedAtIteration - right.addedAtIteration || left.text.localeCompare(right.text)),\n2144:   );\n2145: \n2146:   const ruledOutDirectionCandidates = iterationFiles\n2147:     .flatMap((iteration) =>\n2148:       iteration.deadEnds.concat(iteration.ruledOut).map((entry) => {\n2149:         const hash = contentHash(entry);\n2150:         return {\n2151:           id: `ruled-out-${hash}`,\n2152:           text: entry,\n2153:           contentHash: hash,\n2154:           addedAtIteration: iteration.run,\n2155:         };\n2156:       }),\n2157:     )\n2158:     .sort((left, right) => left.addedAtIteration - right.addedAtIteration || left.text.localeCompare(right.text));\n2159:   const ruledOutDirections = uniqueRuledOutByContent(ruledOutDirectionCandidates);\n2160: \n2161:   const coverageBySources = buildCoverageBySources(iterationFiles, iterationRecords);\n2162:   const latestIteration = iterationRecords.filter((record) => record.type === 'iteration').at(-1);\n2163:   const convergenceScore =\n2164:     latestIteration?.convergenceSignals?.compositeStop\n2165:     ?? latestIteration?.newInfoRatio\n2166:     ?? 0;\n2167:   const blockedStopHistory = eventRecords\n2168:     .filter((record) => record.event === 'blocked_stop')\n2169:     .map((record) => ({\n2170:       run: typeof record.run === 'number' ? record.run : 0,\n2171:       blockedBy: Array.isArray(record.blockedBy) ? record.blockedBy : [],\n2172:       gateResults: record.gateResults && typeof record.gateResults === 'object' ? record.gateResults : {},\n2173:       recoveryStrategy: typeof record.recoveryStrategy === 'string' ? record.recoveryStrategy : '',\n2174:       timestamp: typeof record.timestamp === 'string' ? record.timestamp : '',\n2175:     