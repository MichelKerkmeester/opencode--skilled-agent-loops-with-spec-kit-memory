62:       `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n163:     );\n164:   }\n165:   paths = withinLength;\n166: \n167:   if (paths.length === 0) {\n168:     throw new Error('paths must be a non-empty array of file paths');\n169:   }\n170: \n171:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n172:   const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n173:     ? path.resolve(process.cwd(), configuredMemoryRoot)\n174:     : path.resolve(path.dirname(DATABASE_PATH));\n175:   const allowedBasePaths = Array.from(\n176:     new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n177:   );\n178: \n179:   const normalizedPaths: string[] = [];\n180:   const invalidPaths: Array<{ input: string; reason: string }> = [];\n181: \n182:   for (const inputPath of paths) {\n183:     const trimmedPath = inputPath.trim();\n184: \n185:     if (hasTraversalSegment(trimmedPath)) {\n186:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n187:       continue;\n188:     }\n189: \n190:     const resolvedPath = path.resolve(trimmedPath);\n191: \n192:     const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n193:     if (hasTraversalAfterResolve) {\n194:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n195:       continue;\n196:     }\n197: \n198:     // Resolve symlinks so traversal checks apply to canonical targets.\n199:     let realPath: string;\n200:     try {\n201:       realPath = fs.realpathSync(resolvedPath);\n202:     } catch {\n203:       // Fall back to resolvedPath during pre-validation when target does not yet exist.\n204:       realPath = resolvedPath;\n205:     }\n206: \n207:     const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n208:       realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n209:     ));\n210:     if (!isWithinAllowedBase) {\n211:       invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n212:       continue;\n213:     }\n214: \n215:     normalizedPaths.push(realPath);\n216:   }\n217: \n218:   if (invalidPaths.length > 0) {\n219:     return createMCPErrorResponse({\n220:       tool: 'memory_ingest_start',\n221:       error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n222:       code: 'E_VALIDATION',\n223:       details: {\n224:         allowedBasePathCount: allowedBasePaths.length,\n225:         allowedPathPolicy: 'configured-memory-roots',\n226:         rejectedCount: invalidPaths.length,\n227:       },\n228:       recovery: {\n229:         hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n230:         actions: ['Use absolute paths rooted in the configured memory base path'],\n231:         severity: 'warning',\n232:       },\n233:     });\n234:   }\n235: \n236:   const deduplicatedPaths: string[] = [];\n237:   const seenPaths = new Set<string>();\n238:   let duplicatePathCount = 0;\n239: \n240:   for (const normalizedPath of normalizedPaths) {\n241:     if (seenPaths.has(normalizedPath)) {\n242:       duplicatePathCount++;\n243:       continue;\n244:     }\n245: \n246:     seenPaths.add(normalizedPath);\n247:     deduplicatedPaths.push(normalizedPath);\n248:   }\n249: \n\n(Showing lines 130-249 of 375. Use offset=250 to continue.)\n</content>","metadata":{"preview":" * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  if (paths.length > MAX_INGEST_PATHS) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","text":" * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  if (paths.length > MAX_INGEST_PATHS) {\n    throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n  }\n\n  const overlengthPaths = paths\n    .filter((entry) => entry.length > MAX_PATH_LENGTH)\n    .map((entry) => ({\n      filePath: toPublicPathLabel(entry),\n      reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n    }));\n  const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n  if (withinLength.length !== paths.length) {\n    console.warn(\n      `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n    );\n  }\n  paths = withinLength;\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n  const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n    ? path.resolve(process.cwd(), configuredMemoryRoot)\n    : path.resolve(path.dirname(DATABASE_PATH));\n  const allowedBasePaths = Array.from(\n    new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n  );\n\n  const normalizedPaths: string[] = [];\n  const invalidPaths: Array<{ input: string; reason: string }> = [];\n\n  for (const inputPath of paths) {\n    const trimmedPath = inputPath.trim();\n\n    if (hasTraversalSegment(trimmedPath)) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    const resolvedPath = path.resolve(trimmedPath);\n\n    const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n    if (hasTraversalAfterResolve) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    // Resolve symlinks so traversal checks apply to canonical targets.\n    let realPath: string;\n    try {\n      realPath = fs.realpathSync(resolvedPath);\n    } catch {\n      // Fall back to resolvedPath during pre-validation when target does not yet exist.\n      realPath = resolvedPath;\n    }\n\n    const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n      realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n    ));\n    if (!isWithinAllowedBase) {\n      invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n      continue;\n    }\n\n    normalizedPaths.push(realPath);\n  }\n\n  if (invalidPaths.length > 0) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_start',\n      error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n      code: 'E_VALIDATION',\n      details: {\n        allowedBasePathCount: allowedBasePaths.length,\n        allowedPathPolicy: 'configured-memory-roots',\n        rejectedCount: invalidPaths.length,\n      },\n      recovery: {\n        hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n        actions: ['Use absolute paths rooted in the configured memory base path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const deduplicatedPaths: string[] = [];\n  const seenPaths = new Set<string>();\n  let duplicatePathCount = 0;\n\n  for (const normalizedPath of normalizedPaths) {\n    if (seenPaths.has(normalizedPath)) {\n      duplicatePathCount++;\n      continue;\n    }\n\n    seenPaths.add(normalizedPath);\n    deduplicatedPaths.push(normalizedPath);\n  }\n","lineStart":130,"lineEnd":249,"totalLines":375,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","time":{"start":1781761568478,"end":1781761568483}},"metadata":{"openai":{"itemId":"fc_0372ccb897927fde016a3386205e1c8191ba2cbf6b6856fa49"}},"id":"prt_ed943eebf001A5ZmL9LaWchZy9","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed943c28e001MAxRdWNh41jYp6"}}
{"type":"tool_use","timestamp":1781761568507,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_KeaAwsGdhHZSrfCQWHY74O9J","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":3000,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n3000:     // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n3001:     setImmediate(task);\n3002:   };\n3003:   const run = (): void => {\n3004:     void (async () => {\n3005:       try {\n3006:         if (enrichmentShuttingDown) return; // fenced before this run started — do not reopen the DB during shutdown\n3007:         let db: ReturnType<typeof requireDb>;\n3008:         try {\n3009:           db = requireDb();\n3010:         } catch {\n3011:           return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n3012:         }\n3013:         const row = db\n3014:           .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n3015:           .get(memoryId) as { importance_tier?: string } | undefined;\n3016:         if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n3017:           return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n3018:         }\n3019:         const result = await runPostInsertEnrichment(db, memoryId, parsed);\n3020:         if (enrichmentShuttingDown) return; // shutdown began during the embed await — do not write after the close checkpoint\n3021:         recordEnrichmentResult(db, memoryId, result);\n3022:         emitPostInsertEnrichmentSubscribers(memoryId, 'post-insert-enrichment-async');\n3023:       } catch (bgErr: unknown) {\n3024:         enrichmentFailureTotal++;\n3025:         enrichmentLastError = bgErr instanceof Error ? bgErr.message : String(bgErr);\n3026:         enrichmentLastErrorAt = new Date().toISOString();\n3027:         // Rate-limit the per-failure warning so a systemic failure burst cannot spam the log; the\n3028:         // running total + last error stay available via memory_health. Log the first few, then suppress\n3029:         // and fold a suppressed-count summary into the next emitted line.\n3030:         if (enrichmentFailureTotal <= 5 || enrichmentFailureTotal % 100 === 0) {\n3031:           const suppressed = enrichmentSuppressedWarnings;\n3032:           enrichmentSuppressedWarnings = 0;\n3033:           console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n3034:         } else {\n3035:           enrichmentSuppressedWarnings++;\n3036:         }\n3037:       } finally {\n3038:         activeBackgroundEnrichments--;\n3039:         if (!enrichmentShuttingDown) {\n3040:           const next = backgroundEnrichmentQueue.shift();\n3041:           if (next) start(next);\n3042:         }\n3043:       }\n3044:     })();\n3045:   };\n3046:   if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n3047:     start(run);\n3048:   } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n3049:     backgroundEnrichmentQueue.push(run);\n3050:   } else {\n3051:     // Overflow: drop rather than grow the queue (and its retained parsed payloads) without bound under\n3052:     // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n3053:     // path re-enriches it later. Surfaced via the dropped counter in memory_health.\n3054:     enrichmentDroppedTotal++;\n3055:   }\n3056: }\n3057: \n3058: /* --- 9. MEMORY SAVE HANDLER --- */\n3059: \n3060: /** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\n3061: async function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n3062:   // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n3063:   // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n3064:   // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n3065:   // carries a code (e.g. preflight.PreflightError) keeps it.\n3066:   const requestId = randomUUID();\n3067:   try {\n3068:     return await handleMemorySaveInner(args, requestId);\n3069:   } catch (error: unknown) {\n3070:     if (error instanceof VRuleUnavailableError) {\n3071:       return createMCPErrorResponse({\n3072:         tool: 'memory_save',\n3073:         error: error.message,\n3074:         code: 'E_RUNTIME',\n3075:         details: { requestId },\n3076:         recovery: {\n3077:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3078:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3079:           severity: 'warning',\n3080:         },\n3081:       });\n3082:     }\n3083:     const message = error instanceof Error ? error.message : String(error);\n3084:     const existingCode = (error as { code?: string }).code;\n3085:     const code = typeof existingCode === 'string' && existingCode.length > 0\n3086:       ? existingCode\n3087:       : classifySaveErrorCode(message);\n3088:     return createMCPErrorResponse({\n3089:       tool: 'memory_save',\n3090:       error: message,\n3091:       code,\n3092:       details: { requestId, ...extractSaveErrorDetails(message) },\n3093:       recovery: {\n3094:         hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n3095:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3096:         severity: 'warning',\n3097:       },\n3098:     });\n3099:   }\n3100: }\n3101: \n3102: async function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n3103:   await ensureMemoryRuntimeInitialized('handler:memory_save');\n3104: \n3105:   // Fail fast with a clear message when the target file does not exist, before any\n3106:   // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n3107:   // caller-supplied path is safe to echo back.\n3108:   if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n3109:     const probePath = path.isAbsolute(args.filePath)\n3110:       ? args.filePath\n3111:       : path.resolve(process.cwd(), args.filePath);\n3112:     if (!fs.existsSync(probePath)) {\n3113:       return createMCPErrorResponse({\n3114:         tool: 'memory_save',\n3115:         error: `File not found: ${probePath}`,\n3116:         code: 'E089',\n3117:         details: { requestId, filePath: probePath },\n3118:         recovery: {\n3119:           hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n3120:           actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n3121:           severity: 'warning',\n3122:         },\n3123:       });\n3124:     }\n3125:   }\n3126: \n3127:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n3128: \n3129:   if (restoreBarrier) {\n3130:     return createMCPErrorResponse({\n3131:       tool: 'memory_save',\n3132:       error: restoreBarrier.message,\n3133:       code: restoreBarrier.code,\n3134:       details: {\n3135:         requestId,\n3136:       },\n3137:       recovery: {\n3138:         hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n3139:         actions: ['Wait for the restore to finish', 'Retry the save request'],\n3140:         severity: 'warning',\n3141:       },\n3142:     });\n3143:   }\n3144: \n3145:   const {\n3146:     filePath: file_path,\n3147:     force = false,\n3148:     dryRun = false,\n3149:     plannerMode: requestedPlannerMode,\n3150:     skipPreflight = false,\n3151:     asyncEmbedding = false,\n3152:     routeAs,\n3153:     mergeModeHint,\n3154:     targetAnchorId,\n3155:     tenantId,\n3156:     userId,\n3157:     agentId,\n3158:     sessionId,\n3159:     provenanceSource,\n3160:     provenanceActor,\n3161:     governedAt,\n3162:     retentionPolicy,\n3163:     deleteAfter,\n3164:   } = args;\n3165:   const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n3166:   const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n3167: \n3168:   // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n3169:   // Return a classified validation error instead of a bare throw, which the dispatcher would\n\n(Showing lines 3000-3169 of 4082. Use offset=3170 to continue.)\n</content>","metadata":{"preview":"    // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n    setImmediate(task);\n  };\n  const run = (): void => {\n    void (async () => {\n      try {\n        if (enrichmentShuttingDown) return; // fenced before this run started — do not reopen the DB during shutdown\n        let db: ReturnType<typeof requireDb>;\n        try {\n          db = requireDb();\n        } catch {\n          return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n        }\n        const row = db\n          .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n          .get(memoryId) as { importance_tier?: string } | undefined;\n        if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n          return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n        }\n        const result = await runPostInsertEnrichment(db, memoryId, parsed);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"    // control back to libuv's poll phase, so the IPC accept() runs between enrichment runs.\n    setImmediate(task);\n  };\n  const run = (): void => {\n    void (async () => {\n      try {\n        if (enrichmentShuttingDown) return; // fenced before this run started — do not reopen the DB during shutdown\n        let db: ReturnType<typeof requireDb>;\n        try {\n          db = requireDb();\n        } catch {\n          return; // DB unavailable (e.g. recycle in flight) — row stays pending for backfill repair\n        }\n        const row = db\n          .prepare('SELECT importance_tier FROM memory_index WHERE id = ?')\n          .get(memoryId) as { importance_tier?: string } | undefined;\n        if (!row || row.importance_tier === 'deprecated' || row.importance_tier === 'archived') {\n          return; // superseded/removed/archived since the save — do not repopulate stale graph/entity data (mirrors the search layer's inactive-tier exclusion)\n        }\n        const result = await runPostInsertEnrichment(db, memoryId, parsed);\n        if (enrichmentShuttingDown) return; // shutdown began during the embed await — do not write after the close checkpoint\n        recordEnrichmentResult(db, memoryId, result);\n        emitPostInsertEnrichmentSubscribers(memoryId, 'post-insert-enrichment-async');\n      } catch (bgErr: unknown) {\n        enrichmentFailureTotal++;\n        enrichmentLastError = bgErr instanceof Error ? bgErr.message : String(bgErr);\n        enrichmentLastErrorAt = new Date().toISOString();\n        // Rate-limit the per-failure warning so a systemic failure burst cannot spam the log; the\n        // running total + last error stay available via memory_health. Log the first few, then suppress\n        // and fold a suppressed-count summary into the next emitted line.\n        if (enrichmentFailureTotal <= 5 || enrichmentFailureTotal % 100 === 0) {\n          const suppressed = enrichmentSuppressedWarnings;\n          enrichmentSuppressedWarnings = 0;\n          console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n        } else {\n          enrichmentSuppressedWarnings++;\n        }\n      } finally {\n        activeBackgroundEnrichments--;\n        if (!enrichmentShuttingDown) {\n          const next = backgroundEnrichmentQueue.shift();\n          if (next) start(next);\n        }\n      }\n    })();\n  };\n  if (activeBackgroundEnrichments < MAX_BACKGROUND_ENRICHMENTS) {\n    start(run);\n  } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n    backgroundEnrichmentQueue.push(run);\n  } else {\n    // Overflow: drop rather than grow the queue (and its retained parsed payloads) without bound under\n    // a sustained save flood. The row is enrichment-pending in the commit transaction, so the backfill\n    // path re-enriches it later. Surfaced via the dropped counter in memory_health.\n    enrichmentDroppedTotal++;\n  }\n}\n\n/* --- 9. MEMORY SAVE HANDLER --- */\n\n/** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\nasync function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n  // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n  // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n  // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n  // carries a code (e.g. preflight.PreflightError) keeps it.\n  const requestId = randomUUID();\n  try {\n    return await handleMemorySaveInner(args, requestId);\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    const message = error instanceof Error ? error.message : String(error);\n    const existingCode = (error as { code?: string }).code;\n    const code = typeof existingCode === 'string' && existingCode.length > 0\n      ? existingCode\n      : classifySaveErrorCode(message);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: message,\n      code,\n      details: { requestId, ...extractSaveErrorDetails(message) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n}\n\nasync function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_save');\n\n  // Fail fast with a clear message when the target file does not exist, before any\n  // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n  // caller-supplied path is safe to echo back.\n  if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n    const probePath = path.isAbsolute(args.filePath)\n      ? args.filePath\n      : path.resolve(process.cwd(), args.filePath);\n    if (!fs.existsSync(probePath)) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `File not found: ${probePath}`,\n        code: 'E089',\n        details: { requestId, filePath: probePath },\n        recovery: {\n          hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n          actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        requestId,\n      },\n      recovery: {\n        hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the save request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    filePath: file_path,\n    force = false,\n    dryRun = false,\n    plannerMode: requestedPlannerMode,\n    skipPreflight = false,\n    asyncEmbedding = false,\n    routeAs,\n    mergeModeHint,\n    targetAnchorId,\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  } = args;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n  // Return a classified validation error instead of a bare throw, which the dispatcher would","lineStart":3000,"lineEnd":3169,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781761568497,"end":1781761568505}},"metadata":{"openai":{"itemId":"fc_0372ccb897927fde016a3386205e28819187c1defd519bf179"}},"id":"prt_ed943eee0001qUD24nF0bfYnT5","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed943c28e001MAxRdWNh41jYp6"}}
{"type":"tool_use","timestamp":1781761568651,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_W4m2Oj61HiiXeTDXNvAKoftw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Spec Folder Mutex\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n5: \n6: import { createHash } from 'node:crypto';\n7: import fs from 'node:fs';\n8: import os from 'node:os';\n9: import path from 'node:path';\n10: \n11: // Feature catalog: Memory indexing (memory_save)\n12: // Feature catalog: Atomic-save parity and partial-indexing hints\n13: \n14: const SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\n15: const LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\n16: const LOCK_WAIT_MS = 25;\n17: const LOCK_TIMEOUT_MS = 30_000;\n18: const LOCK_STALE_MS = 5 * 60 * 1000;\n19: const LOCK_HEARTBEAT_MS = 60_000;\n20: \n21: type LockOwnerState = 'alive' | 'dead' | 'unknown';\n22: \n23: const lockHeartbeats = new Map<string, ReturnType<typeof setInterval>>();\n24: \n25: interface InterprocessLockHandle {\n26:   lockDir: string;\n27: }\n28: \n29: function sleep(ms: number): Promise<void> {\n30:   return new Promise((resolve) => setTimeout(resolve, ms));\n31: }\n32: \n33: function getLockDir(specFolder: string): string {\n34:   const digest = createHash('sha1').update(specFolder).digest('hex');\n35:   return path.join(LOCK_ROOT, digest);\n36: }\n37: \n38: function isExistingDirectoryError(error: unknown): boolean {\n39:   return Boolean(error && typeof error === 'object' && 'code' in error && (error as { code?: string }).code === 'EEXIST');\n40: }\n41: \n42: function getNodeErrorCode(error: unknown): string | null {\n43:   if (error && typeof error === 'object' && 'code' in error) {\n44:     const code = (error as { code?: unknown }).code;\n45:     return typeof code === 'string' ? code : null;\n46:   }\n47:   return null;\n48: }\n49: \n50: // Read back the lock owner pid and probe whether that process is still alive.\n51: // A live owner must never be reaped — that is the TOCTOU this mutex prevents.\n52: function getLockOwnerState(lockDir: string): LockOwnerState {\n53:   let ownerRaw: string;\n54:   try {\n55:     ownerRaw = fs.readFileSync(path.join(lockDir, 'owner.json'), 'utf8');\n56:   } catch {\n57:     return 'unknown';\n58:   }\n59: \n60:   let ownerPid: number;\n61:   try {\n62:     const parsed = JSON.parse(ownerRaw) as { pid?: unknown };\n63:     ownerPid = Number(parsed.pid);\n64:   } catch {\n65:     return 'unknown';\n66:   }\n67:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n68:     return 'unknown';\n69:   }\n70: \n71:   try {\n72:     process.kill(ownerPid, 0);\n73:     return 'alive';\n74:   } catch (error: unknown) {\n75:     const code = getNodeErrorCode(error);\n76:     if (code === 'ESRCH') {\n77:       return 'dead';\n78:     }\n79:     if (code === 'EPERM') {\n80:       return 'alive';\n81:     }\n82:     return 'unknown';\n83:   }\n84: }\n85: \n86: // A lock is reclaimable only when its owner is provably gone (dead), or when the\n87: // owner record is unreadable AND the dir has aged past the stale threshold.\n88: // An alive owner is never reclaimable, regardless of age.\n89: function isReclaimableLock(lockDir: string): boolean {\n90:   let ageMs: number;\n91:   try {\n92:     const stats = fs.statSync(lockDir);\n93:     ageMs = Date.now() - stats.mtimeMs;\n94:   } catch {\n95:     return false;\n96:   }\n97:   const ownerState = getLockOwnerState(lockDir);\n98:   return ownerState === 'dead' || (ownerState === 'unknown' && ageMs > LOCK_STALE_MS);\n99: }\n100: \n101: function stopHeartbeat(lockDir: string): void {\n102:   const heartbeat = lockHeartbeats.get(lockDir);\n103:   if (!heartbeat) {\n104:     return;\n105:   }\n106:   clearInterval(heartbeat);\n107:   lockHeartbeats.delete(lockDir);\n108: }\n109: \n110: // Refresh the lock dir mtime while fn() runs so a long-but-live save is never\n111: // mistaken for an abandoned lock by the stale-age fallback.\n112: function startHeartbeat(lockDir: string): void {\n113:   stopHeartbeat(lockDir);\n114:   const heartbeat = setInterval(() => {\n115:     try {\n116:       const now = new Date();\n117:       fs.utimesSync(lockDir, now, now);\n118:     } catch {\n119:       stopHeartbeat(lockDir);\n120:     }\n121:   }, LOCK_HEARTBEAT_MS);\n122:   const unref = (heartbeat as { unref?: () => void }).unref;\n123:   unref?.call(heartbeat);\n124:   lockHeartbeats.set(lockDir, heartbeat);\n125: }\n126: \n127: function createInterprocessLock(specFolder: string, lockDir: string): InterprocessLockHandle {\n128:   fs.mkdirSync(lockDir);\n129:   fs.writeFileSync(path.join(lockDir, 'owner.json'), JSON.stringify({\n130:     pid: process.pid,\n131:     specFolder,\n132:     acquiredAt: new Date().toISOString(),\n133:   }));\n134:   startHeartbeat(lockDir);\n135:   return { lockDir };\n136: }\n137: \n138: function releaseInterprocessLock(handle: InterprocessLockHandle): void {\n139:   stopHeartbeat(handle.lockDir);\n140:   try {\n141:     fs.rmSync(handle.lockDir, { recursive: true, force: true });\n142:   } catch (error: unknown) {\n143:     console.warn('[memory-save] failed to release interprocess spec-folder lock:', error);\n144:   }\n145: }\n146: \n147: async function acquireInterprocessLock(specFolder: string): Promise<InterprocessLockHandle> {\n148:   const lockDir = getLockDir(specFolder);\n149:   const deadline = Date.now() + LOCK_TIMEOUT_MS;\n150: \n151:   fs.mkdirSync(LOCK_ROOT, { recursive: true });\n152: \n153:   while (true) {\n154:     try {\n155:       return createInterprocessLock(specFolder, lockDir);\n156:     } catch (error: unknown) {\n157:       if (!isExistingDirectoryError(error)) {\n158:         throw error;\n159:       }\n160: \n161:       if (isReclaimableLock(lockDir)) {\n162:         fs.rmSync(lockDir, { recursive: true, force: true });\n163:         continue;\n164:       }\n165: \n166:       if (Date.now() >= deadline) {\n167:         throw new Error(`Timed out acquiring interprocess spec-folder lock for ${specFolder}`);\n168:       }\n169: \n170:       await sleep(LOCK_WAIT_MS);\n171:     }\n172:   }\n173: }\n174: \n175: async function withSpecFolderLock<T>(specFolder: string, fn: () => Promise<T>): Promise<T> {\n176:   const normalizedFolder = specFolder || '__global__';\n177:   const chain = (SPEC_FOLDER_LOCKS.get(normalizedFolder) ?? Promise.resolve())\n178:     .catch((error: unknown) => {\n179:       console.error('[memory-save] prior queued save failed:', error);\n180:     })\n181:     .then(async () => {\n182:       const interprocessLock = await acquireInterprocessLock(normalizedFolder);\n183:       try {\n184:         return await fn();\n185:       } finally {\n186:         releaseInterprocessLock(interprocessLock);\n187:       }\n188:     });\n189:   SPEC_FOLDER_LOCKS.set(normalizedFolder, chain);\n190:   try {\n191:     return await chain;\n192:   } finally {\n193:     if (SPEC_FOLDER_LOCKS.get(normalizedFolder) === chain) {\n194:       SPEC_FOLDER_LOCKS.delete(normalizedFolder);\n195:     }\n196:   }\n197: }\n198: \n199: export {\n200:   SPEC_FOLDER_LOCKS,\n201:   withSpecFolderLock,\n202:   // Exported for targeted lock-liveness tests; not part of the save flow API.\n203:   LOCK_STALE_MS,\n204:   LOCK_HEARTBEAT_MS,\n205:   getLockDir,\n206:   getLockOwnerState,\n207:   isReclaimableLock,\n208:   createInterprocessLock,\n209:   releaseInterprocessLock,\n210: };\n\n(End of file - total 210 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Folder Mutex\n// ───────────────────────────────────────────────────────────────\n// Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n\nimport { createHash } from 'node:crypto';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport path from 'node:path';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\nconst SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\nconst LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\nconst LOCK_WAIT_MS = 25;\nconst LOCK_TIMEOUT_MS = 30_000;\nconst LOCK_STALE_MS = 5 * 60 * 1000;\nconst LOCK_HEARTBEAT_MS = 60_000;\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Folder Mutex\n// ───────────────────────────────────────────────────────────────\n// Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n\nimport { createHash } from 'node:crypto';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport path from 'node:path';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\nconst SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\nconst LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\nconst LOCK_WAIT_MS = 25;\nconst LOCK_TIMEOUT_MS = 30_000;\nconst LOCK_STALE_MS = 5 * 60 * 1000;\nconst LOCK_HEARTBEAT_MS = 60_000;\n\ntype LockOwnerState = 'alive' | 'dead' | 'unknown';\n\nconst lockHeartbeats = new Map<string, ReturnType<typeof setInterval>>();\n\ninterface InterprocessLockHandle {\n  lockDir: string;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction getLockDir(specFolder: string): string {\n  const digest = createHash('sha1').update(specFolder).digest('hex');\n  return path.join(LOCK_ROOT, digest);\n}\n\nfunction isExistingDirectoryError(error: unknown): boolean {\n  return Boolean(error && typeof error === 'object' && 'code' in error && (error as { code?: string }).code === 'EEXIST');\n}\n\nfunction getNodeErrorCode(error: unknown): string | null {\n  if (error && typeof error === 'object' && 'code' in error) {\n    const code = (error as { code?: unknown }).code;\n    return typeof code === 'string' ? code : null;\n  }\n  return null;\n}\n\n// Read back the lock owner pid and probe whether that process is still alive.\n// A live owner must never be reaped — that is the TOCTOU this mutex prevents.\nfunction getLockOwnerState(lockDir: string): LockOwnerState {\n  let ownerRaw: string;\n  try {\n    ownerRaw = fs.readFileSync(path.join(lockDir, 'owner.json'), 'utf8');\n  } catch {\n    return 'unknown';\n  }\n\n  let ownerPid: number;\n  try {\n    const parsed = JSON.parse(ownerRaw) as { pid?: unknown };\n    ownerPid = Number(parsed.pid);\n  } catch {\n    return 'unknown';\n  }\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    return 'unknown';\n  }\n\n  try {\n    process.kill(ownerPid, 0);\n    return 'alive';\n  } catch (error: unknown) {\n    const code = getNodeErrorCode(error);\n    if (code === 'ESRCH') {\n      return 'dead';\n    }\n    if (code === 'EPERM') {\n      return 'alive';\n    }\n    return 'unknown';\n  }\n}\n\n// A lock is reclaimable only when its owner is provably gone (dead), or when the\n// owner record is unreadable AND the dir has aged past the stale threshold.\n// An alive owner is never reclaimable, regardless of age.\nfunction isReclaimableLock(lockDir: string): boolean {\n  let ageMs: number;\n  try {\n    const stats = fs.statSync(lockDir);\n    ageMs = Date.now() - stats.mtimeMs;\n  } catch {\n    return false;\n  }\n  const ownerState = getLockOwnerState(lockDir);\n  return ownerState === 'dead' || (ownerState === 'unknown' && ageMs > LOCK_STALE_MS);\n}\n\nfunction stopHeartbeat(lockDir: string): void {\n  const heartbeat = lockHeartbeats.get(lockDir);\n  if (!heartbeat) {\n    return;\n  }\n  clearInterval(heartbeat);\n  lockHeartbeats.delete(lockDir);\n}\n\n// Refresh the lock dir mtime while fn() runs so a long-but-live save is never\n// mistaken for an abandoned lock by the stale-age fallback.\nfunction startHeartbeat(lockDir: string): void {\n  stopHeartbeat(lockDir);\n  const heartbeat = setInterval(() => {\n    try {\n      const now = new Date();\n      fs.utimesSync(lockDir, now, now);\n    } catch {\n      stopHeartbeat(lockDir);\n    }\n  }, LOCK_HEARTBEAT_MS);\n  const unref = (heartbeat as { unref?: () => void }).unref;\n  unref?.call(heartbeat);\n  lockHeartbeats.set(lockDir, heartbeat);\n}\n\nfunction createInterprocessLock(specFolder: string, lockDir: string): InterprocessLockHandle {\n  fs.mkdirSync(lockDir);\n  fs.writeFileSync(path.join(lockDir, 'owner.json'), JSON.stringify({\n    pid: process.pid,\n    specFolder,\n    acquiredAt: new Date().toISOString(),\n  }));\n  startHeartbeat(lockDir);\n  return { lockDir };\n}\n\nfunction releaseInterprocessLock(handle: InterprocessLockHandle): void {\n  stopHeartbeat(handle.lockDir);\n  try {\n    fs.rmSync(handle.lockDir, { recursive: true, force: true });\n  } catch (error: unknown) {\n    console.warn('[memory-save] failed to release interprocess spec-folder lock:', error);\n  }\n}\n\nasync function acquireInterprocessLock(specFolder: string): Promise<InterprocessLockHandle> {\n  const lockDir = getLockDir(specFolder);\n  const deadline = Date.now() + LOCK_TIMEOUT_MS;\n\n  fs.mkdirSync(LOCK_ROOT, { recursive: true });\n\n  while (true) {\n    try {\n      return createInterprocessLock(specFolder, lockDir);\n    } catch (error: unknown) {\n      if (!isExistingDirectoryError(error)) {\n        throw error;\n      }\n\n      if (isReclaimableLock(lockDir)) {\n        fs.rmSync(lockDir, { recursive: true, force: true });\n        continue;\n      }\n\n      if (Date.now() >= deadline) {\n        throw new Error(`Timed out acquiring interprocess spec-folder lock for ${specFolder}`);\n      }\n\n      await sleep(LOCK_WAIT_MS);\n    }\n  }\n}\n\nasync function withSpecFolderLock<T>(specFolder: string, fn: () => Promise<T>): Promise<T> {\n  const normalizedFolder = specFolder || '__global__';\n  const chain = (SPEC_FOLDER_LOCKS.get(normalizedFolder) ?? Promise.resolve())\n    .catch((error: unknown) => {\n      console.error('[memory-save] prior queued save failed:', error);\n    })\n    .then(async () => {\n      const interprocessLock = await acquireInterprocessLock(normalizedFolder);\n      try {\n        return await fn();\n      } finally {\n        releaseInterprocessLock(interprocessLock);\n      }\n    });\n  SPEC_FOLDER_LOCKS.set(normalizedFolder, chain);\n  try {\n    return await chain;\n  } finally {\n    if (SPEC_FOLDER_LOCKS.get(normalizedFolder) === chain) {\n      SPEC_FOLDER_LOCKS.delete(normalizedFolder);\n    }\n  }\n}\n\nexport {\n  SPEC_FOLDER_LOCKS,\n  withSpecFolderLock,\n  // Exported for targeted lock-liveness tests; not part of the save flow API.\n  LOCK_STALE_MS,\n  LOCK_HEARTBEAT_MS,\n  getLockDir,\n  getLockOwnerState,\n  isReclaimableLock,\n  createInterprocessLock,\n  releaseInterprocessLock,\n};","lineStart":1,"lineEnd":210,"totalLines":210,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","time":{"start":1781761568630,"end":1781761568644}},"metadata":{"openai":{"itemId":"fc_0372ccb897927fde016a3386205e30819182ea69cb3d9ef483"}},"id":"prt_ed943eef2001N17d5MQDzg6FqA","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed943c28e001MAxRdWNh41jYp6"}}
{"type":"tool_use","timestamp":1781761568654,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_8a2nZx4eNYkAorS827Drl7Lb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n\n(Showing lines 1-180 of 344. Use offset=181 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);","lineStart":1,"lineEnd":180,"totalLines":344,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781761568648,"end":1781761568654}},"metadata":{"openai":{"itemId":"fc_0372ccb897927fde016a3386205e3c8191bf1609c63f2a0e45"}},"id":"prt_ed943ef78001LDI8paI9Teo8UK","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed943c28e001MAxRdWNh41jYp6"}}
{"type":"tool_use","timestamp":1781761568710,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_hm4lY8586DBe645p6FEf1U8E","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Bulk Delete\n3: // ────────────────────────────────────────────────────────────────\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* ───────────────────────────────────────────────────────────────\n29:    1. TYPES\n30: ──────────────────────────────────────────────────────────────── */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* ───────────────────────────────────────────────────────────────\n74:     2. HANDLER\n75: ──────────────────────────────────────────────────────────────── */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n(Showing lines 1-180 of 372. Use offset=181 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n    2. HANDLER\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;","lineStart":1,"lineEnd":180,"totalLines":372,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781761568705,"end":1781761568709}},"metadata":{"openai":{"itemId":"fc_0372ccb897927fde016a3386205e448191bf153d671f423c76"}},"id":"prt_ed943ef8a0012ER2YdrVEYxXpO","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed943c28e001MAxRdWNh41jYp6"}}
