{"type":"tool_use","timestamp":1781144209502,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_IZ8Cvbxtvtu08Yd505XbDoa2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","offset":1,"limit":400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Graph Traversal\n3: // -------------------------------------------------------------------\n4: \n5: import type Database from 'better-sqlite3';\n6: import {\n7:   collectCausalWeightedNeighbors,\n8:   collectDependencyReachability,\n9:   collectDirectedReachability,\n10:   collectWeightedWalk,\n11:   type DirectedReachabilityOptions,\n12:   type WeightedWalkOptions,\n13:   type WeightedWalkResult,\n14: } from '../../graph/bfs-traversal.js';\n15: \n16: /** Node identifier accepted by graph traversal ports. */\n17: export type GraphTraversalNode = number | string;\n18: \n19: export type {\n20:   DirectedReachabilityOptions,\n21:   DirectedTraversalEdge,\n22:   WeightedTraversalEdge,\n23:   WeightedWalkOptions,\n24:   WeightedWalkResult,\n25: } from '../../graph/bfs-traversal.js';\n26: \n27: /**\n28:  * Traverses graph-shaped storage data without exposing the caller to the\n29:  * underlying database driver.\n30:  */\n31: export interface GraphTraversal {\n32:   /** Run a generic hop-capped weighted walk. */\n33:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n34:     options: WeightedWalkOptions<TNode>,\n35:   ): Map<TNode, WeightedWalkResult<TNode>>;\n36: \n37:   /** Collect all nodes reachable through directed edges from the roots. */\n38:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n39:     options: DirectedReachabilityOptions<TNode>,\n40:   ): TNode[];\n41: \n42:   /** Traverse causal-neighbor edges from memory IDs. */\n43:   collectCausalWeightedNeighbors(\n44:     seeds: readonly number[],\n45:     maxHops: number,\n46:     relationWeights: Readonly<Record<string, number>>,\n47:   ): Map<number, WeightedWalkResult<number>>;\n48: \n49:   /** Traverse dependency edges from parent paths to transitive children. */\n50:   collectDependencyReachability(roots: readonly string[]): string[];\n51: }\n52: \n53: /** better-sqlite3-backed graph traversal adapter. */\n54: export class BetterSqliteGraphTraversal implements GraphTraversal {\n55:   constructor(private readonly database: Database.Database) {}\n56: \n57:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n58:     options: WeightedWalkOptions<TNode>,\n59:   ): Map<TNode, WeightedWalkResult<TNode>> {\n60:     return collectWeightedWalk(options);\n61:   }\n62: \n63:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n64:     options: DirectedReachabilityOptions<TNode>,\n65:   ): TNode[] {\n66:     return collectDirectedReachability(options);\n67:   }\n68: \n69:   collectCausalWeightedNeighbors(\n70:     seeds: readonly number[],\n71:     maxHops: number,\n72:     relationWeights: Readonly<Record<string, number>>,\n73:   ): Map<number, WeightedWalkResult<number>> {\n74:     return collectCausalWeightedNeighbors(this.database, seeds, maxHops, relationWeights);\n75:   }\n76: \n77:   collectDependencyReachability(roots: readonly string[]): string[] {\n78:     return collectDependencyReachability(this.database, roots);\n79:   }\n80: }\n\n(End of file - total 80 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Graph Traversal\n// -------------------------------------------------------------------\n\nimport type Database from 'better-sqlite3';\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/** Node identifier accepted by graph traversal ports. */\nexport type GraphTraversalNode = number | string;\n\nexport type {\n  DirectedReachabilityOptions,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Graph Traversal\n// -------------------------------------------------------------------\n\nimport type Database from 'better-sqlite3';\nimport {\n  collectCausalWeightedNeighbors,\n  collectDependencyReachability,\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/** Node identifier accepted by graph traversal ports. */\nexport type GraphTraversalNode = number | string;\n\nexport type {\n  DirectedReachabilityOptions,\n  DirectedTraversalEdge,\n  WeightedTraversalEdge,\n  WeightedWalkOptions,\n  WeightedWalkResult,\n} from '../../graph/bfs-traversal.js';\n\n/**\n * Traverses graph-shaped storage data without exposing the caller to the\n * underlying database driver.\n */\nexport interface GraphTraversal {\n  /** Run a generic hop-capped weighted walk. */\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>>;\n\n  /** Collect all nodes reachable through directed edges from the roots. */\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[];\n\n  /** Traverse causal-neighbor edges from memory IDs. */\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>>;\n\n  /** Traverse dependency edges from parent paths to transitive children. */\n  collectDependencyReachability(roots: readonly string[]): string[];\n}\n\n/** better-sqlite3-backed graph traversal adapter. */\nexport class BetterSqliteGraphTraversal implements GraphTraversal {\n  constructor(private readonly database: Database.Database) {}\n\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>> {\n    return collectWeightedWalk(options);\n  }\n\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[] {\n    return collectDirectedReachability(options);\n  }\n\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>> {\n    return collectCausalWeightedNeighbors(this.database, seeds, maxHops, relationWeights);\n  }\n\n  collectDependencyReachability(roots: readonly string[]): string[] {\n    return collectDependencyReachability(this.database, roots);\n  }\n}","lineStart":1,"lineEnd":80,"totalLines":80,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/graph-traversal.ts","time":{"start":1781144209465,"end":1781144209496}},"metadata":{"openai":{"itemId":"fc_095aec1ef8cb9081016a2a1a9164908191ae85fd20f1e9ac72"}},"id":"prt_eb477c814001LQgIAbYJmi1x6F","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477911d001iZ2kO0FPyBDSgU"}}
{"type":"tool_use","timestamp":1781144209502,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_NBPI6sphbsC5YDUElGaa4prm","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Port Fakes\n3: // -------------------------------------------------------------------\n4: \n5: import {\n6:   collectDirectedReachability,\n7:   collectWeightedWalk,\n8:   type DirectedReachabilityOptions,\n9:   type DirectedTraversalEdge,\n10:   type WeightedTraversalEdge,\n11:   type WeightedWalkOptions,\n12:   type WeightedWalkResult,\n13: } from '../../lib/graph/bfs-traversal';\n14: import { isSqliteContentionError } from '../../lib/storage/ports';\n15: import type {\n16:   CheckpointOptions,\n17:   ContentionOperationOptions,\n18:   ContentionPolicy,\n19:   GraphTraversal,\n20:   GraphTraversalNode,\n21:   LexicalDocumentFields,\n22:   LexicalSearch,\n23:   LexicalSearchOptions,\n24:   LexicalSearchResult,\n25:   LexicalSearchStats,\n26:   Maintenance,\n27:   MaintenanceResult,\n28:   StorageId,\n29:   VectorMetadata,\n30:   VectorRecord,\n31:   VectorSearchOptions,\n32:   VectorSearchResult,\n33:   VectorStore,\n34: } from '../../lib/storage/ports';\n35: import type Database from 'better-sqlite3';\n36: \n37: interface FakeCausalEdge {\n38:   readonly sourceId: number;\n39:   readonly targetId: number;\n40:   readonly relation: string;\n41:   readonly strength?: number;\n42: }\n43: \n44: interface FakeDependencyEdge {\n45:   readonly parentPath: string;\n46:   readonly childPath: string;\n47: }\n48: \n49: interface FakeGraphTraversalOptions {\n50:   readonly causalEdges?: readonly FakeCausalEdge[];\n51:   readonly dependencyEdges?: readonly FakeDependencyEdge[];\n52: }\n53: \n54: /** Storage-free graph traversal test double. */\n55: export class FakeGraphTraversal implements GraphTraversal {\n56:   private readonly causalEdges: readonly FakeCausalEdge[];\n57:   private readonly dependencyEdges: readonly FakeDependencyEdge[];\n58: \n59:   constructor(options: FakeGraphTraversalOptions = {}) {\n60:     this.causalEdges = options.causalEdges ?? [];\n61:     this.dependencyEdges = options.dependencyEdges ?? [];\n62:   }\n63: \n64:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n65:     options: WeightedWalkOptions<TNode>,\n66:   ): Map<TNode, WeightedWalkResult<TNode>> {\n67:     return collectWeightedWalk(options);\n68:   }\n69: \n70:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n71:     options: DirectedReachabilityOptions<TNode>,\n72:   ): TNode[] {\n73:     return collectDirectedReachability(options);\n74:   }\n75: \n76:   collectCausalWeightedNeighbors(\n77:     seeds: readonly number[],\n78:     maxHops: number,\n79:     relationWeights: Readonly<Record<string, number>>,\n80:   ): Map<number, WeightedWalkResult<number>> {\n81:     return this.collectWeightedWalk({\n82:       seeds,\n83:       maxHops,\n84:       readEdges: (nodeIds) => this.readCausalEdges(nodeIds, relationWeights),\n85:     });\n86:   }\n87: \n88:   collectDependencyReachability(roots: readonly string[]): string[] {\n89:     return this.collectDirectedReachability({\n90:       roots,\n91:       readEdges: (nodeIds) => this.readDependencyEdges(nodeIds),\n92:     });\n93:   }\n94: \n95:   private readCausalEdges(\n96:     nodeIds: readonly number[],\n97:     relationWeights: Readonly<Record<string, number>>,\n98:   ): WeightedTraversalEdge<number>[] {\n99:     const nodeSet = new Set(nodeIds);\n100:     const edges: WeightedTraversalEdge<number>[] = [];\n101:     for (const edge of this.causalEdges) {\n102:       const weight = relationWeights[edge.relation] ?? 1.0;\n103:       const strength = edge.strength ?? 1.0;\n104:       if (nodeSet.has(edge.sourceId)) {\n105:         edges.push({ from: edge.sourceId, to: edge.targetId, weight, strength });\n106:       }\n107:       if (nodeSet.has(edge.targetId)) {\n108:         edges.push({ from: edge.targetId, to: edge.sourceId, weight, strength });\n109:       }\n110:     }\n111:     return edges;\n112:   }\n113: \n114:   private readDependencyEdges(nodeIds: readonly string[]): DirectedTraversalEdge<string>[] {\n115:     const nodeSet = new Set(nodeIds);\n116:     return this.dependencyEdges\n117:       .filter((edge) => nodeSet.has(edge.parentPath))\n118:       .map((edge) => ({ from: edge.parentPath, to: edge.childPath }));\n119:   }\n120: }\n121: \n122: /** Storage-free lexical search test double. */\n123: export class FakeLexicalSearch implements LexicalSearch {\n124:   private readonly documents = new Map<string, string>();\n125: \n126:   addDocument(id: string, text: string): void {\n127:     this.documents.set(id, text);\n128:   }\n129: \n130:   addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n131:     this.addDocument(id, fieldsToText(fields));\n132:   }\n133: \n134:   removeDocument(id: string): boolean {\n135:     return this.documents.delete(id);\n136:   }\n137: \n138:   search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n139:     const queryTokens = tokenizeForFake(query);\n140:     if (queryTokens.length === 0) {\n141:       return [];\n142:     }\n143: \n144:     const results: LexicalSearchResult[] = [];\n145:     for (const [id, text] of this.documents) {\n146:       const textTokens = tokenizeForFake(text);\n147:       const score = queryTokens.reduce(\n148:         (sum, token) => sum + textTokens.filter((textToken) => textToken === token).length,\n149:         0,\n150:       );\n151:       if (score > 0) {\n152:         results.push({ id, score });\n153:       }\n154:     }\n155: \n156:     return results\n157:       .sort((left, right) => right.score - left.score || left.id.localeCompare(right.id))\n158:       .slice(0, options.limit ?? 10);\n159:   }\n160: \n161:   getStats(): LexicalSearchStats {\n162:     const terms = new Set<string>();\n163:     let totalLength = 0;\n164:     for (const text of this.documents.values()) {\n165:       const tokens = tokenizeForFake(text);\n166:       totalLength += tokens.length;\n167:       for (const token of tokens) {\n168:         terms.add(token);\n169:       }\n170:     }\n171:     const documentCount = this.documents.size;\n172:     return {\n173:       documentCount,\n174:       termCount: terms.size,\n175:       avgDocLength: documentCount === 0 ? 0 : totalLength / documentCount,\n176:     };\n177:   }\n178: \n179:   clear(): void {\n180:     this.documents.clear();\n181:   }\n182: }\n183: \n184: /** Storage-free vector store test double. */\n185: export class FakeVectorStore<TMetadata extends VectorMetadata = VectorMetadata> implements VectorStore<TMetadata> {\n186:   private readonly records = new Map<StorageId, VectorRecord<TMetadata>>();\n187: \n188:   upsert(record: VectorRecord<TMetadata>): void {\n189:     this.records.set(record.id, record);\n190:   }\n191: \n192:   delete(id: StorageId): boolean {\n193:     return this.records.delete(id);\n194:   }\n195: \n196:   get(id: StorageId): VectorRecord<TMetadata> | null {\n197:     return this.records.get(id) ?? null;\n198:   }\n199: \n200:   search(\n201:     embedding: readonly number[] | Float32Array,\n202:     options: VectorSearchOptions,\n203:   ): VectorSearchResult<TMetadata>[] {\n204:     return Array.from(this.records.values())\n205:       .map((record) => ({\n206:         id: record.id,\n207:         score: cosineSimilarity(embedding, record.embedding),\n208:         metadata: record.metadata,\n209:       }))\n210:       .filter((result) => result.score >= (options.minScore ?? Number.NEGATIVE_INFINITY))\n211:       .sort((left, right) => right.score - left.score)\n212:       .slice(0, options.limit);\n213:   }\n214: \n215:   clear(): void {\n216:     this.records.clear();\n217:   }\n218: }\n219: \n220: /** Storage-free maintenance test double. */\n221: export class FakeMaintenance implements Maintenance {\n222:   readonly calls: string[] = [];\n223: \n224:   constructor(private readonly result: MaintenanceResult = { ok: true }) {}\n225: \n226:   integrityCheck(): MaintenanceResult {\n227:     this.calls.push('integrityCheck');\n228:     return this.result;\n229:   }\n230: \n231:   vacuum(): MaintenanceResult {\n232:     this.calls.push('vacuum');\n233:     return this.result;\n234:   }\n235: \n236:   checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n237:     this.calls.push(`checkpoint:${options.mode ?? 'passive'}`);\n238:     return this.result;\n239:   }\n240: }\n241: \n242: /** Storage-free contention policy test double. */\n243: export class FakeContentionPolicy implements ContentionPolicy {\n244:   readonly busyTimeouts: number[] = [];\n245: \n246:   async withRetry<T>(\n247:     operation: () => T | Promise<T>,\n248:     options: ContentionOperationOptions = {},\n249:   ): Promise<T> {\n250:     const attempts = Math.max(1, options.attempts ?? 1);\n251:     const retryable = options.retryable ?? isSqliteContentionError;\n252:     for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n253:       try {\n254:         return await operation();\n255:       } catch (error: unknown) {\n256:         const canRetry = retryable(error) && attemptIndex < attempts - 1;\n257:         if (!canRetry) {\n258:           throw error;\n259:         }\n260:         const delayMs = resolveFakeDelayMs(options, attemptIndex);\n261:         options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n262:       }\n263:     }\n264:     throw new Error('FakeContentionPolicy.withRetry: unreachable');\n265:   }\n266: \n267:   withWriteLock<T>(\n268:     operation: () => T | Promise<T>,\n269:     options: ContentionOperationOptions = {},\n270:   ): Promise<T> {\n271:     return this.withRetry(operation, options);\n272:   }\n273: \n274:   setBusyTimeout(\n275:     _database: Database.Database,\n276:     timeoutMs: number,\n277:   ): void {\n278:     this.busyTimeouts.push(timeoutMs);\n279:   }\n280: }\n281: \n282: function resolveFakeDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n283:   const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n284:   const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n285:   return Math.max(0, delay);\n286: }\n287: \n288: function fieldsToText(fields: LexicalDocumentFields): string {\n289:   return [\n290:     fields.title ?? '',\n291:     arrayOrStringToText(fields.trigger_phrases),\n292:     fields.content_generic ?? '',\n293:     fields.body ?? '',\n294:   ].filter((part) => part.trim().length > 0).join(' ');\n295: }\n296: \n297: function arrayOrStringToText(value: string | string[] | null | undefined): string {\n298:   return Array.isArray(value) ? value.join(' ') : (value ?? '');\n299: }\n300: \n301: function tokenizeForFake(text: string): string[] {\n302:   return text.toLowerCase().match(/[a-z0-9_-]+/g) ?? [];\n303: }\n304: \n305: function cosineSimilarity(\n306:   left: readonly number[] | Float32Array,\n307:   right: readonly number[] | Float32Array,\n308: ): number {\n309:   const length = Math.min(left.length, right.length);\n310:   let dot = 0;\n311:   let leftMagnitude = 0;\n312:   let rightMagnitude = 0;\n313:   for (let index = 0; index < length; index += 1) {\n314:     const leftValue = left[index] ?? 0;\n315:     const rightValue = right[index] ?? 0;\n316:     dot += leftValue * rightValue;\n317:     leftMagnitude += leftValue * leftValue;\n318:     rightMagnitude += rightValue * rightValue;\n319:   }\n320:   if (leftMagnitude === 0 || rightMagnitude === 0) {\n321:     return 0;\n322:   }\n323:   return dot / (Math.sqrt(leftMagnitude) * Math.sqrt(rightMagnitude));\n324: }\n\n(End of file - total 324 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Port Fakes\n// -------------------------------------------------------------------\n\nimport {\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type DirectedTraversalEdge,\n  type WeightedTraversalEdge,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../lib/graph/bfs-traversal';\nimport { isSqliteContentionError } from '../../lib/storage/ports';\nimport type {\n  CheckpointOptions,\n  ContentionOperationOptions,\n  ContentionPolicy,\n  GraphTraversal,\n  GraphTraversalNode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Port Fakes\n// -------------------------------------------------------------------\n\nimport {\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type DirectedTraversalEdge,\n  type WeightedTraversalEdge,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../lib/graph/bfs-traversal';\nimport { isSqliteContentionError } from '../../lib/storage/ports';\nimport type {\n  CheckpointOptions,\n  ContentionOperationOptions,\n  ContentionPolicy,\n  GraphTraversal,\n  GraphTraversalNode,\n  LexicalDocumentFields,\n  LexicalSearch,\n  LexicalSearchOptions,\n  LexicalSearchResult,\n  LexicalSearchStats,\n  Maintenance,\n  MaintenanceResult,\n  StorageId,\n  VectorMetadata,\n  VectorRecord,\n  VectorSearchOptions,\n  VectorSearchResult,\n  VectorStore,\n} from '../../lib/storage/ports';\nimport type Database from 'better-sqlite3';\n\ninterface FakeCausalEdge {\n  readonly sourceId: number;\n  readonly targetId: number;\n  readonly relation: string;\n  readonly strength?: number;\n}\n\ninterface FakeDependencyEdge {\n  readonly parentPath: string;\n  readonly childPath: string;\n}\n\ninterface FakeGraphTraversalOptions {\n  readonly causalEdges?: readonly FakeCausalEdge[];\n  readonly dependencyEdges?: readonly FakeDependencyEdge[];\n}\n\n/** Storage-free graph traversal test double. */\nexport class FakeGraphTraversal implements GraphTraversal {\n  private readonly causalEdges: readonly FakeCausalEdge[];\n  private readonly dependencyEdges: readonly FakeDependencyEdge[];\n\n  constructor(options: FakeGraphTraversalOptions = {}) {\n    this.causalEdges = options.causalEdges ?? [];\n    this.dependencyEdges = options.dependencyEdges ?? [];\n  }\n\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>> {\n    return collectWeightedWalk(options);\n  }\n\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[] {\n    return collectDirectedReachability(options);\n  }\n\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>> {\n    return this.collectWeightedWalk({\n      seeds,\n      maxHops,\n      readEdges: (nodeIds) => this.readCausalEdges(nodeIds, relationWeights),\n    });\n  }\n\n  collectDependencyReachability(roots: readonly string[]): string[] {\n    return this.collectDirectedReachability({\n      roots,\n      readEdges: (nodeIds) => this.readDependencyEdges(nodeIds),\n    });\n  }\n\n  private readCausalEdges(\n    nodeIds: readonly number[],\n    relationWeights: Readonly<Record<string, number>>,\n  ): WeightedTraversalEdge<number>[] {\n    const nodeSet = new Set(nodeIds);\n    const edges: WeightedTraversalEdge<number>[] = [];\n    for (const edge of this.causalEdges) {\n      const weight = relationWeights[edge.relation] ?? 1.0;\n      const strength = edge.strength ?? 1.0;\n      if (nodeSet.has(edge.sourceId)) {\n        edges.push({ from: edge.sourceId, to: edge.targetId, weight, strength });\n      }\n      if (nodeSet.has(edge.targetId)) {\n        edges.push({ from: edge.targetId, to: edge.sourceId, weight, strength });\n      }\n    }\n    return edges;\n  }\n\n  private readDependencyEdges(nodeIds: readonly string[]): DirectedTraversalEdge<string>[] {\n    const nodeSet = new Set(nodeIds);\n    return this.dependencyEdges\n      .filter((edge) => nodeSet.has(edge.parentPath))\n      .map((edge) => ({ from: edge.parentPath, to: edge.childPath }));\n  }\n}\n\n/** Storage-free lexical search test double. */\nexport class FakeLexicalSearch implements LexicalSearch {\n  private readonly documents = new Map<string, string>();\n\n  addDocument(id: string, text: string): void {\n    this.documents.set(id, text);\n  }\n\n  addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n    this.addDocument(id, fieldsToText(fields));\n  }\n\n  removeDocument(id: string): boolean {\n    return this.documents.delete(id);\n  }\n\n  search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n    const queryTokens = tokenizeForFake(query);\n    if (queryTokens.length === 0) {\n      return [];\n    }\n\n    const results: LexicalSearchResult[] = [];\n    for (const [id, text] of this.documents) {\n      const textTokens = tokenizeForFake(text);\n      const score = queryTokens.reduce(\n        (sum, token) => sum + textTokens.filter((textToken) => textToken === token).length,\n        0,\n      );\n      if (score > 0) {\n        results.push({ id, score });\n      }\n    }\n\n    return results\n      .sort((left, right) => right.score - left.score || left.id.localeCompare(right.id))\n      .slice(0, options.limit ?? 10);\n  }\n\n  getStats(): LexicalSearchStats {\n    const terms = new Set<string>();\n    let totalLength = 0;\n    for (const text of this.documents.values()) {\n      const tokens = tokenizeForFake(text);\n      totalLength += tokens.length;\n      for (const token of tokens) {\n        terms.add(token);\n      }\n    }\n    const documentCount = this.documents.size;\n    return {\n      documentCount,\n      termCount: terms.size,\n      avgDocLength: documentCount === 0 ? 0 : totalLength / documentCount,\n    };\n  }\n\n  clear(): void {\n    this.documents.clear();\n  }\n}\n\n/** Storage-free vector store test double. */\nexport class FakeVectorStore<TMetadata extends VectorMetadata = VectorMetadata> implements VectorStore<TMetadata> {\n  private readonly records = new Map<StorageId, VectorRecord<TMetadata>>();\n\n  upsert(record: VectorRecord<TMetadata>): void {\n    this.records.set(record.id, record);\n  }\n\n  delete(id: StorageId): boolean {\n    return this.records.delete(id);\n  }\n\n  get(id: StorageId): VectorRecord<TMetadata> | null {\n    return this.records.get(id) ?? null;\n  }\n\n  search(\n    embedding: readonly number[] | Float32Array,\n    options: VectorSearchOptions,\n  ): VectorSearchResult<TMetadata>[] {\n    return Array.from(this.records.values())\n      .map((record) => ({\n        id: record.id,\n        score: cosineSimilarity(embedding, record.embedding),\n        metadata: record.metadata,\n      }))\n      .filter((result) => result.score >= (options.minScore ?? Number.NEGATIVE_INFINITY))\n      .sort((left, right) => right.score - left.score)\n      .slice(0, options.limit);\n  }\n\n  clear(): void {\n    this.records.clear();\n  }\n}\n\n/** Storage-free maintenance test double. */\nexport class FakeMaintenance implements Maintenance {\n  readonly calls: string[] = [];\n\n  constructor(private readonly result: MaintenanceResult = { ok: true }) {}\n\n  integrityCheck(): MaintenanceResult {\n    this.calls.push('integrityCheck');\n    return this.result;\n  }\n\n  vacuum(): MaintenanceResult {\n    this.calls.push('vacuum');\n    return this.result;\n  }\n\n  checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n    this.calls.push(`checkpoint:${options.mode ?? 'passive'}`);\n    return this.result;\n  }\n}\n\n/** Storage-free contention policy test double. */\nexport class FakeContentionPolicy implements ContentionPolicy {\n  readonly busyTimeouts: number[] = [];\n\n  async withRetry<T>(\n    operation: () => T | Promise<T>,\n    options: ContentionOperationOptions = {},\n  ): Promise<T> {\n    const attempts = Math.max(1, options.attempts ?? 1);\n    const retryable = options.retryable ?? isSqliteContentionError;\n    for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n      try {\n        return await operation();\n      } catch (error: unknown) {\n        const canRetry = retryable(error) && attemptIndex < attempts - 1;\n        if (!canRetry) {\n          throw error;\n        }\n        const delayMs = resolveFakeDelayMs(options, attemptIndex);\n        options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n      }\n    }\n    throw new Error('FakeContentionPolicy.withRetry: unreachable');\n  }\n\n  withWriteLock<T>(\n    operation: () => T | Promise<T>,\n    options: ContentionOperationOptions = {},\n  ): Promise<T> {\n    return this.withRetry(operation, options);\n  }\n\n  setBusyTimeout(\n    _database: Database.Database,\n    timeoutMs: number,\n  ): void {\n    this.busyTimeouts.push(timeoutMs);\n  }\n}\n\nfunction resolveFakeDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n  const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n  const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n  return Math.max(0, delay);\n}\n\nfunction fieldsToText(fields: LexicalDocumentFields): string {\n  return [\n    fields.title ?? '',\n    arrayOrStringToText(fields.trigger_phrases),\n    fields.content_generic ?? '',\n    fields.body ?? '',\n  ].filter((part) => part.trim().length > 0).join(' ');\n}\n\nfunction arrayOrStringToText(value: string | string[] | null | undefined): string {\n  return Array.isArray(value) ? value.join(' ') : (value ?? '');\n}\n\nfunction tokenizeForFake(text: string): string[] {\n  return text.toLowerCase().match(/[a-z0-9_-]+/g) ?? [];\n}\n\nfunction cosineSimilarity(\n  left: readonly number[] | Float32Array,\n  right: readonly number[] | Float32Array,\n): number {\n  const length = Math.min(left.length, right.length);\n  let dot = 0;\n  let leftMagnitude = 0;\n  let rightMagnitude = 0;\n  for (let index = 0; index < length; index += 1) {\n    const leftValue = left[index] ?? 0;\n    const rightValue = right[index] ?? 0;\n    dot += leftValue * rightValue;\n    leftMagnitude += leftValue * leftValue;\n    rightMagnitude += rightValue * rightValue;\n  }\n  if (leftMagnitude === 0 || rightMagnitude === 0) {\n    return 0;\n  }\n  return dot / (Math.sqrt(leftMagnitude) * Math.sqrt(rightMagnitude));\n}","lineStart":1,"lineEnd":324,"totalLines":324,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts","time":{"start":1781144209489,"end":1781144209497}},"metadata":{"openai":{"itemId":"fc_095aec1ef8cb9081016a2a1a9164c08191960491514e0dd193"}},"id":"prt_eb477c850001J6mhzNVufXFnaE","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477911d001iZ2kO0FPyBDSgU"}}
{"type":"tool_use","timestamp":1781144209502,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_3dZGmXBAAcAxPtSCiqSymerz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts","offset":1,"limit":400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Maintenance\n3: // -------------------------------------------------------------------\n4: \n5: import type { Awaitable } from './common.js';\n6: import type Database from 'better-sqlite3';\n7: \n8: /** Result from a storage maintenance command. */\n9: export interface MaintenanceResult {\n10:   readonly ok: boolean;\n11:   readonly message?: string;\n12:   readonly details?: Readonly<Record<string, unknown>>;\n13: }\n14: \n15: /** Options for checkpoint-style maintenance operations. */\n16: export interface CheckpointOptions {\n17:   readonly mode?: 'passive' | 'full' | 'restart' | 'truncate';\n18: }\n19: \n20: /** Maintenance operation names surfaced to call-site warning hooks. */\n21: export type MaintenanceOperation = 'quick_check' | 'auto_vacuum' | 'incremental_vacuum' | 'wal_checkpoint';\n22: \n23: /** Options for the better-sqlite3 maintenance adapter. */\n24: export interface BetterSqliteMaintenanceOptions {\n25:   readonly onMaintenanceError?: (operation: MaintenanceOperation, error: unknown) => void;\n26: }\n27: \n28: /** Port for operational storage maintenance tasks. */\n29: export interface Maintenance {\n30:   /** Run an integrity check against the active storage backend. */\n31:   integrityCheck(): Awaitable<MaintenanceResult>;\n32: \n33:   /** Compact backend storage when supported. */\n34:   vacuum(): Awaitable<MaintenanceResult>;\n35: \n36:   /** Flush write-ahead or equivalent backend state when supported. */\n37:   checkpoint(options?: CheckpointOptions): Awaitable<MaintenanceResult>;\n38: }\n39: \n40: /** better-sqlite3 implementation of operational storage maintenance. */\n41: export class BetterSqliteMaintenance implements Maintenance {\n42:   private readonly onMaintenanceError: ((operation: MaintenanceOperation, error: unknown) => void) | undefined;\n43: \n44:   constructor(\n45:     private readonly database: Database.Database,\n46:     options: BetterSqliteMaintenanceOptions = {},\n47:   ) {\n48:     this.onMaintenanceError = options.onMaintenanceError;\n49:   }\n50: \n51:   integrityCheck(): MaintenanceResult {\n52:     try {\n53:       const rows = this.database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n54:       const first = Object.values(rows[0] ?? {})[0];\n55:       const verdict = typeof first === 'string' ? first : 'quick_check returned no verdict';\n56:       return { ok: verdict === 'ok', message: verdict, details: { verdict } };\n57:     } catch (error: unknown) {\n58:       this.reportError('quick_check', error);\n59:       return { ok: false, message: errorMessage(error) };\n60:     }\n61:   }\n62: \n63:   vacuum(): MaintenanceResult {\n64:     let shouldRunIncrementalVacuum = false;\n65:     try {\n66:       const autoVacuumMode = this.database.pragma('auto_vacuum', { simple: true });\n67:       shouldRunIncrementalVacuum = Number(autoVacuumMode) === 2;\n68:     } catch (error: unknown) {\n69:       this.reportError('auto_vacuum', error);\n70:       return { ok: false, message: errorMessage(error), details: { operation: 'auto_vacuum' } };\n71:     }\n72: \n73:     if (shouldRunIncrementalVacuum) {\n74:       try {\n75:         this.database.pragma('incremental_vacuum');\n76:       } catch (error: unknown) {\n77:         this.reportError('incremental_vacuum', error);\n78:         return { ok: false, message: errorMessage(error), details: { operation: 'incremental_vacuum' } };\n79:       }\n80:     }\n81: \n82:     return { ok: true, details: { incrementalVacuum: shouldRunIncrementalVacuum } };\n83:   }\n84: \n85:   checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n86:     const mode = (options.mode ?? 'passive').toUpperCase();\n87:     try {\n88:       const result = this.database.pragma(`wal_checkpoint(${mode})`) as unknown;\n89:       return { ok: true, details: { mode: options.mode ?? 'passive', result } };\n90:     } catch (error: unknown) {\n91:       this.reportError('wal_checkpoint', error);\n92:       return { ok: false, message: errorMessage(error), details: { mode: options.mode ?? 'passive' } };\n93:     }\n94:   }\n95: \n96:   private reportError(operation: MaintenanceOperation, error: unknown): void {\n97:     this.onMaintenanceError?.(operation, error);\n98:   }\n99: }\n100: \n101: function errorMessage(error: unknown): string {\n102:   return error instanceof Error ? error.message : String(error);\n103: }\n\n(End of file - total 103 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Maintenance\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\n/** Result from a storage maintenance command. */\nexport interface MaintenanceResult {\n  readonly ok: boolean;\n  readonly message?: string;\n  readonly details?: Readonly<Record<string, unknown>>;\n}\n\n/** Options for checkpoint-style maintenance operations. */\nexport interface CheckpointOptions {\n  readonly mode?: 'passive' | 'full' | 'restart' | 'truncate';\n}\n\n/** Maintenance operation names surfaced to call-site warning hooks. */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Maintenance\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\n/** Result from a storage maintenance command. */\nexport interface MaintenanceResult {\n  readonly ok: boolean;\n  readonly message?: string;\n  readonly details?: Readonly<Record<string, unknown>>;\n}\n\n/** Options for checkpoint-style maintenance operations. */\nexport interface CheckpointOptions {\n  readonly mode?: 'passive' | 'full' | 'restart' | 'truncate';\n}\n\n/** Maintenance operation names surfaced to call-site warning hooks. */\nexport type MaintenanceOperation = 'quick_check' | 'auto_vacuum' | 'incremental_vacuum' | 'wal_checkpoint';\n\n/** Options for the better-sqlite3 maintenance adapter. */\nexport interface BetterSqliteMaintenanceOptions {\n  readonly onMaintenanceError?: (operation: MaintenanceOperation, error: unknown) => void;\n}\n\n/** Port for operational storage maintenance tasks. */\nexport interface Maintenance {\n  /** Run an integrity check against the active storage backend. */\n  integrityCheck(): Awaitable<MaintenanceResult>;\n\n  /** Compact backend storage when supported. */\n  vacuum(): Awaitable<MaintenanceResult>;\n\n  /** Flush write-ahead or equivalent backend state when supported. */\n  checkpoint(options?: CheckpointOptions): Awaitable<MaintenanceResult>;\n}\n\n/** better-sqlite3 implementation of operational storage maintenance. */\nexport class BetterSqliteMaintenance implements Maintenance {\n  private readonly onMaintenanceError: ((operation: MaintenanceOperation, error: unknown) => void) | undefined;\n\n  constructor(\n    private readonly database: Database.Database,\n    options: BetterSqliteMaintenanceOptions = {},\n  ) {\n    this.onMaintenanceError = options.onMaintenanceError;\n  }\n\n  integrityCheck(): MaintenanceResult {\n    try {\n      const rows = this.database.pragma('quick_check(1)') as Array<Record<string, unknown>>;\n      const first = Object.values(rows[0] ?? {})[0];\n      const verdict = typeof first === 'string' ? first : 'quick_check returned no verdict';\n      return { ok: verdict === 'ok', message: verdict, details: { verdict } };\n    } catch (error: unknown) {\n      this.reportError('quick_check', error);\n      return { ok: false, message: errorMessage(error) };\n    }\n  }\n\n  vacuum(): MaintenanceResult {\n    let shouldRunIncrementalVacuum = false;\n    try {\n      const autoVacuumMode = this.database.pragma('auto_vacuum', { simple: true });\n      shouldRunIncrementalVacuum = Number(autoVacuumMode) === 2;\n    } catch (error: unknown) {\n      this.reportError('auto_vacuum', error);\n      return { ok: false, message: errorMessage(error), details: { operation: 'auto_vacuum' } };\n    }\n\n    if (shouldRunIncrementalVacuum) {\n      try {\n        this.database.pragma('incremental_vacuum');\n      } catch (error: unknown) {\n        this.reportError('incremental_vacuum', error);\n        return { ok: false, message: errorMessage(error), details: { operation: 'incremental_vacuum' } };\n      }\n    }\n\n    return { ok: true, details: { incrementalVacuum: shouldRunIncrementalVacuum } };\n  }\n\n  checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n    const mode = (options.mode ?? 'passive').toUpperCase();\n    try {\n      const result = this.database.pragma(`wal_checkpoint(${mode})`) as unknown;\n      return { ok: true, details: { mode: options.mode ?? 'passive', result } };\n    } catch (error: unknown) {\n      this.reportError('wal_checkpoint', error);\n      return { ok: false, message: errorMessage(error), details: { mode: options.mode ?? 'passive' } };\n    }\n  }\n\n  private reportError(operation: MaintenanceOperation, error: unknown): void {\n    this.onMaintenanceError?.(operation, error);\n  }\n}\n\nfunction errorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}","lineStart":1,"lineEnd":103,"totalLines":103,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/maintenance.ts","time":{"start":1781144209483,"end":1781144209498}},"metadata":{"openai":{"itemId":"fc_095aec1ef8cb9081016a2a1a9164ac8191b27887d7c08d0480"}},"id":"prt_eb477c8490010DyfKG1GS4kfh2","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477911d001iZ2kO0FPyBDSgU"}}
{"type":"tool_use","timestamp":1781144209502,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_Uy9T47MQ2AmfYdwNSEq926xA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Lexical Search\n3: // -------------------------------------------------------------------\n4: \n5: import {\n6:   BM25Index,\n7:   buildBm25DocumentFields,\n8:   type BM25DocumentFields,\n9:   type BM25DocumentSource,\n10:   type BM25FieldWeights,\n11:   type BM25SearchResult,\n12:   type BM25Stats,\n13:   type InMemoryBm25Engine,\n14: } from '../../search/bm25-index.js';\n15: \n16: /** Fielded document payload accepted by lexical search indexes. */\n17: export type LexicalDocumentFields = BM25DocumentFields;\n18: \n19: /** Source row shape that can be normalized into lexical document fields. */\n20: export type LexicalDocumentSource = BM25DocumentSource;\n21: \n22: /** Ranked lexical search result. */\n23: export type LexicalSearchResult = BM25SearchResult;\n24: \n25: /** Lexical index statistics. */\n26: export type LexicalSearchStats = BM25Stats;\n27: \n28: /** Query-time options for lexical scoring. */\n29: export interface LexicalSearchOptions {\n30:   readonly limit?: number;\n31:   readonly fieldWeights?: Partial<BM25FieldWeights>;\n32: }\n33: \n34: /**\n35:  * Port for document indexing and ranked lexical retrieval.\n36:  * Implementations may use SQLite FTS, in-memory BM25, or a test double.\n37:  */\n38: export interface LexicalSearch {\n39:   /** Index a plain-text document body. */\n40:   addDocument(id: string, text: string): void;\n41: \n42:   /** Index a fielded document with title, trigger, path, and body signals. */\n43:   addDocumentFields(id: string, fields: LexicalDocumentFields): void;\n44: \n45:   /** Remove a document from the lexical index. */\n46:   removeDocument(id: string): boolean;\n47: \n48:   /** Search indexed documents by query text. */\n49:   search(query: string, options?: LexicalSearchOptions): LexicalSearchResult[];\n50: \n51:   /** Return current index statistics. */\n52:   getStats(): LexicalSearchStats;\n53: \n54:   /** Clear all indexed documents. */\n55:   clear(): void;\n56: }\n57: \n58: /** Packed BM25 lexical-search adapter over the shipped in-memory engine. */\n59: export class PackedBm25LexicalSearch implements LexicalSearch {\n60:   private readonly index: BM25Index;\n61: \n62:   constructor(engine: InMemoryBm25Engine = 'packed-inmemory') {\n63:     this.index = new BM25Index(undefined, undefined, engine);\n64:   }\n65: \n66:   addDocument(id: string, text: string): void {\n67:     this.index.addDocument(id, text);\n68:   }\n69: \n70:   addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n71:     this.index.addDocumentFields(id, fields);\n72:   }\n73: \n74:   addDocumentSource(id: string, source: LexicalDocumentSource): void {\n75:     this.addDocumentFields(id, buildBm25DocumentFields(source));\n76:   }\n77: \n78:   removeDocument(id: string): boolean {\n79:     return this.index.removeDocument(id);\n80:   }\n81: \n82:   search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n83:     return this.index.search(query, options.limit, { fieldWeights: options.fieldWeights });\n84:   }\n85: \n86:   getStats(): LexicalSearchStats {\n87:     return this.index.getStats();\n88:   }\n89: \n90:   clear(): void {\n91:     this.index.clear();\n92:   }\n93: \n94:   finalize(): void {\n95:     this.index.finalizePackedPostings();\n96:   }\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Lexical Search\n// -------------------------------------------------------------------\n\nimport {\n  BM25Index,\n  buildBm25DocumentFields,\n  type BM25DocumentFields,\n  type BM25DocumentSource,\n  type BM25FieldWeights,\n  type BM25SearchResult,\n  type BM25Stats,\n  type InMemoryBm25Engine,\n} from '../../search/bm25-index.js';\n\n/** Fielded document payload accepted by lexical search indexes. */\nexport type LexicalDocumentFields = BM25DocumentFields;\n\n/** Source row shape that can be normalized into lexical document fields. */\nexport type LexicalDocumentSource = BM25DocumentSource;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Lexical Search\n// -------------------------------------------------------------------\n\nimport {\n  BM25Index,\n  buildBm25DocumentFields,\n  type BM25DocumentFields,\n  type BM25DocumentSource,\n  type BM25FieldWeights,\n  type BM25SearchResult,\n  type BM25Stats,\n  type InMemoryBm25Engine,\n} from '../../search/bm25-index.js';\n\n/** Fielded document payload accepted by lexical search indexes. */\nexport type LexicalDocumentFields = BM25DocumentFields;\n\n/** Source row shape that can be normalized into lexical document fields. */\nexport type LexicalDocumentSource = BM25DocumentSource;\n\n/** Ranked lexical search result. */\nexport type LexicalSearchResult = BM25SearchResult;\n\n/** Lexical index statistics. */\nexport type LexicalSearchStats = BM25Stats;\n\n/** Query-time options for lexical scoring. */\nexport interface LexicalSearchOptions {\n  readonly limit?: number;\n  readonly fieldWeights?: Partial<BM25FieldWeights>;\n}\n\n/**\n * Port for document indexing and ranked lexical retrieval.\n * Implementations may use SQLite FTS, in-memory BM25, or a test double.\n */\nexport interface LexicalSearch {\n  /** Index a plain-text document body. */\n  addDocument(id: string, text: string): void;\n\n  /** Index a fielded document with title, trigger, path, and body signals. */\n  addDocumentFields(id: string, fields: LexicalDocumentFields): void;\n\n  /** Remove a document from the lexical index. */\n  removeDocument(id: string): boolean;\n\n  /** Search indexed documents by query text. */\n  search(query: string, options?: LexicalSearchOptions): LexicalSearchResult[];\n\n  /** Return current index statistics. */\n  getStats(): LexicalSearchStats;\n\n  /** Clear all indexed documents. */\n  clear(): void;\n}\n\n/** Packed BM25 lexical-search adapter over the shipped in-memory engine. */\nexport class PackedBm25LexicalSearch implements LexicalSearch {\n  private readonly index: BM25Index;\n\n  constructor(engine: InMemoryBm25Engine = 'packed-inmemory') {\n    this.index = new BM25Index(undefined, undefined, engine);\n  }\n\n  addDocument(id: string, text: string): void {\n    this.index.addDocument(id, text);\n  }\n\n  addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n    this.index.addDocumentFields(id, fields);\n  }\n\n  addDocumentSource(id: string, source: LexicalDocumentSource): void {\n    this.addDocumentFields(id, buildBm25DocumentFields(source));\n  }\n\n  removeDocument(id: string): boolean {\n    return this.index.removeDocument(id);\n  }\n\n  search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n    return this.index.search(query, options.limit, { fieldWeights: options.fieldWeights });\n  }\n\n  getStats(): LexicalSearchStats {\n    return this.index.getStats();\n  }\n\n  clear(): void {\n    this.index.clear();\n  }\n\n  finalize(): void {\n    this.index.finalizePackedPostings();\n  }\n}","lineStart":1,"lineEnd":97,"totalLines":97,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/lexical-search.ts","time":{"start":1781144209478,"end":1781144209499}},"metadata":{"openai":{"itemId":"fc_095aec1ef8cb9081016a2a1a9164a48191a6a6848bba6af369"}},"id":"prt_eb477c83b001lbJ6fPKJNDAIjt","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477911d001iZ2kO0FPyBDSgU"}}
{"type":"tool_use","timestamp":1781144209503,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_yzI0LeqrFoYqy03x8cAydnC9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts","offset":1,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Vector Store\n3: // -------------------------------------------------------------------\n4: \n5: import { IVectorStore } from '../../interfaces/vector-store.js';\n6: import {\n7:   activeVectorSource,\n8:   close_db,\n9:   get_embedding_dim,\n10:   initialize_db,\n11:   sqlite_vec_available,\n12: } from '../../search/vector-index-store.js';\n13: import {\n14:   VectorIndexError,\n15:   VectorIndexErrorCode,\n16:   type EmbeddingInput,\n17:   type EnrichedSearchResult,\n18:   type IndexMemoryParams,\n19:   type MemoryRow,\n20:   type VectorSearchOptions as LegacyVectorSearchOptions,\n21: } from '../../search/vector-index-types.js';\n22: \n23: import type { Awaitable, StorageId } from './common.js';\n24: import type Database from 'better-sqlite3';\n25: \n26: type JsonObject = Record<string, unknown>;\n27: \n28: interface BetterSqliteVectorStoreOptions {\n29:   readonly dbPath?: string;\n30: }\n31: \n32: type EnhancedSearchOptions = {\n33:   specFolder?: string | null;\n34:   minSimilarity?: number;\n35:   diversityFactor?: number;\n36:   noDiversity?: boolean;\n37: };\n38: \n39: let cachedQueries: Awaited<typeof import('../../search/vector-index-queries.js')> | null = null;\n40: let cachedMutations: Awaited<typeof import('../../search/vector-index-mutations.js')> | null = null;\n41: let cachedAliases: Awaited<typeof import('../../search/vector-index-aliases.js')> | null = null;\n42: \n43: async function getQueriesModule(): Promise<Awaited<typeof import('../../search/vector-index-queries.js')>> {\n44:   return cachedQueries ??= await import('../../search/vector-index-queries.js');\n45: }\n46: \n47: async function getMutationsModule(): Promise<Awaited<typeof import('../../search/vector-index-mutations.js')>> {\n48:   return cachedMutations ??= await import('../../search/vector-index-mutations.js');\n49: }\n50: \n51: async function getAliasesModule(): Promise<Awaited<typeof import('../../search/vector-index-aliases.js')>> {\n52:   return cachedAliases ??= await import('../../search/vector-index-aliases.js');\n53: }\n54: \n55: /** Metadata attached to a vector record. */\n56: export type VectorMetadata = Readonly<Record<string, unknown>>;\n57: \n58: /** Persisted vector entry. */\n59: export interface VectorRecord<TMetadata extends VectorMetadata = VectorMetadata> {\n60:   readonly id: StorageId;\n61:   readonly embedding: readonly number[] | Float32Array;\n62:   readonly metadata: TMetadata;\n63: }\n64: \n65: /** Ranked vector search hit. */\n66: export interface VectorSearchResult<TMetadata extends VectorMetadata = VectorMetadata> {\n67:   readonly id: StorageId;\n68:   readonly score: number;\n69:   readonly metadata: TMetadata;\n70: }\n71: \n72: /** Query options for vector nearest-neighbor retrieval. */\n73: export interface VectorSearchOptions {\n74:   readonly limit: number;\n75:   readonly minScore?: number;\n76: }\n77: \n78: /** Port for vector persistence and similarity retrieval. */\n79: export interface VectorStore<TMetadata extends VectorMetadata = VectorMetadata> {\n80:   /** Insert or replace one vector record. */\n81:   upsert(record: VectorRecord<TMetadata>): Awaitable<void>;\n82: \n83:   /** Remove one vector record. */\n84:   delete(id: StorageId): Awaitable<boolean>;\n85: \n86:   /** Fetch one vector record by ID. */\n87:   get(id: StorageId): Awaitable<VectorRecord<TMetadata> | null>;\n88: \n89:   /** Return ranked vector matches for a query embedding. */\n90:   search(\n91:     embedding: readonly number[] | Float32Array,\n92:     options: VectorSearchOptions,\n93:   ): Awaitable<VectorSearchResult<TMetadata>[]>;\n94: \n95:   /** Remove all vector records. */\n96:   clear(): Awaitable<void>;\n97: }\n98: \n99: /** better-sqlite3-backed vector-store adapter. */\n100: export class BetterSqliteVectorStore<TMetadata extends VectorMetadata = VectorMetadata>\n101:   extends IVectorStore\n102:   implements VectorStore<TMetadata> {\n103:   dbPath: string | null;\n104:   _initialized: boolean;\n105: \n106:   constructor(options: BetterSqliteVectorStoreOptions = {}) {\n107:     super();\n108:     this.dbPath = options.dbPath || null;\n109:     this._initialized = false;\n110:   }\n111: \n112:   _ensureInitialized(): void {\n113:     if (!this._initialized) {\n114:       this._getDatabase();\n115:       this._initialized = true;\n116:     }\n117:   }\n118: \n119:   _getDatabase(): Database.Database {\n120:     return initialize_db(this.dbPath);\n121:   }\n122: \n123:   search(\n124:     embedding: readonly number[] | Float32Array,\n125:     options: VectorSearchOptions,\n126:   ): Promise<VectorSearchResult<TMetadata>[]>;\n127:   search(\n128:     embedding: EmbeddingInput,\n129:     topK: number,\n130:     options?: LegacyVectorSearchOptions,\n131:   ): Promise<MemoryRow[]>;\n132:   async search(\n133:     embedding: EmbeddingInput,\n134:     optionsOrTopK: VectorSearchOptions | number,\n135:     options: LegacyVectorSearchOptions = {},\n136:   ): Promise<VectorSearchResult<TMetadata>[] | MemoryRow[]> {\n137:     if (typeof optionsOrTopK !== 'number') {\n138:       const rows = await this.search(embedding, optionsOrTopK.limit, {\n139:         minSimilarity: optionsOrTopK.minScore === undefined ? 0 : optionsOrTopK.minScore * 100,\n140:         includeConstitutional: false,\n141:       });\n142:       return rows.map((row) => ({\n143:         id: String(row.id),\n144:         score: typeof row.similarity === 'number' ? row.similarity / 100 : 0,\n145:         metadata: row as unknown as TMetadata,\n146:       }));\n147:     }\n148: \n149:     this._ensureInitialized();\n150:     const database = this._getDatabase();\n151: \n152:     const expected_dim = get_embedding_dim();\n153:     if (!embedding || embedding.length !== expected_dim) {\n154:       throw new VectorIndexError(\n155:         `Invalid embedding dimension: expected ${expected_dim}, got ${embedding?.length}`,\n156:         VectorIndexErrorCode.EMBEDDING_VALIDATION,\n157:       );\n158:     }\n159: \n160:     const search_options = {\n161:       limit: optionsOrTopK,\n162:       specFolder: options.specFolder,\n163:       minSimilarity: options.minSimilarity || 0,\n164:       useDecay: options.useDecay !== false,\n165:       tier: options.tier,\n166:       contextType: options.contextType,\n167:       includeConstitutional: options.includeConstitutional !== false,\n168:       includeArchived: options.includeArchived === true\n169:     };\n170: \n171:     const { vector_search } = await getQueriesModule();\n172:     return vector_search(embedding, search_options, database);\n173:   }\n174: \n175:   upsert(record: VectorRecord<TMetadata>): Promise<void>;\n176:   upsert(id: string, embedding: EmbeddingInput, metadata: JsonObject): Promise<number>;\n177:   async upsert(\n178:     recordOrId: VectorRecord<TMetadata> | string,\n179:     embedding?: EmbeddingInput,\n180:     metadata?: JsonObject,\n181:   ): Promise<void | number> {\n182:     if (typeof recordOrId !== 'string') {\n183:       const recordEmbedding = recordOrId.embedding instanceof Float32Array\n184:         ? recordOrId.embedding\n185:         : Array.from(recordOrId.embedding);\n186:       await this.upsert(String(recordOrId.id), recordEmbedding, recordOrId.metadata);\n187:       return;\n188:     }\n189: \n190:     this._ensureInitialized();\n191:     const database = this._getDatabase();\n192: \n193:     const expected_dim = get_embedding_dim();\n194:     if (!embedding || embedding.length !== expected_dim) {\n195:       throw new VectorIndexError(\n196:         `Embedding dimension mismatch: expected ${expected_dim}, got ${embedding?.length}`,\n197:         VectorIndexErrorCode.EMBEDDING_VALIDATION,\n198:       );\n199:     }\n200: \n201:     const metadata_alias = (metadata ?? {}) as JsonObject & {\n202:       spec_folder?: string;\n203:       specFolder?: string;\n204:       file_path?: string;\n205:       filePath?: string;\n206:       anchor_id?: string;\n207:       anchorId?: string;\n208:       title?: string;\n209:       trigger_phrases?: string[];\n210:       triggerPhrases?: string[];\n211:       importance_weight?: number;\n212:       importanceWeight?: number;\n213:     };\n214: \n215:     const params: IndexMemoryParams = {\n216:       specFolder: metadata_alias.spec_folder || metadata_alias.specFolder || '',\n217:       filePath: metadata_alias.file_path || metadata_alias.filePath || '',\n218:       anchorId: metadata_alias.anchor_id || metadata_alias.anchorId || null,\n219:       title: metadata_alias.title || null,\n220:       triggerPhrases: metadata_alias.trigger_phrases || metadata_alias.triggerPhrases || [],\n221:       importanceWeight: metadata_alias.importance_weight ?? metadata_alias.importanceWeight ?? 0.5,\n222:       embedding: embedding\n223:     };\n224: \n225:     if (!params.specFolder || !params.filePath) {\n226:       throw new VectorIndexError(\n227:         'metadata must include spec_folder and file_path',\n228:         VectorIndexErrorCode.STORE_ERROR,\n229:       );\n230:     }\n231: \n232:     const { index_memory } = await getMutationsModule();\n233:     return index_memory(params, database);\n234:   }\n235: \n236:   async delete(id: StorageId): Promise<boolean> {\n237:     this._ensureInitialized();\n238:     const database = this._getDatabase();\n239:     const { delete_memory } = await getMutationsModule();\n240:     return delete_memory(Number(id), database);\n241:   }\n242: \n243:   async get(id: StorageId): Promise<VectorRecord<TMetadata> | null>;\n244:   async get(id: number): Promise<MemoryRow | null>;\n245:   async get(id: StorageId): Promise<VectorRecord<TMetadata> | MemoryRow | null> {\n246:     this._ensureInitialized();\n247:     const database = this._getDatabase();\n248:     const { get_memory } = await getQueriesModule();\n249:     const row = get_memory(Number(id), database);\n250:     if (!row) {\n251:       return null;\n252:     }\n253:     if (typeof id === 'number') {\n254:       return row;\n255:     }\n256:     const embedding = this.getEmbeddingForId(database, Number(row.id));\n257:     return {\n258:       id: row.id,\n259:       embedding,\n260:       metadata: row as unknown as TMetadata,\n261:     };\n262:   }\n263: \n264:   async clear(): Promise<void> {\n265:     this._ensureInitialized();\n266:     const database = this._getDatabase();\n267:     database.transaction(() => {\n268:       database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')}`).run();\n269:       database.prepare('DELETE FROM active_memory_projection').run();\n270:       database.prepare('DELETE FROM memory_index').run();\n271:     })();\n272:   }\n273: \n274:   async getStats(): Promise<{ total: number; pending: number; success: number; failed: number; retry: number }> {\n275:     this._ensureInitialized();\n276:     const database = this._getDatabase();\n277:     const { get_stats } = await getQueriesModule();\n278:     return get_stats(database);\n279:   }\n280: \n281:   isAvailable(): boolean {\n282:     return sqlite_vec_available();\n283:   }\n284: \n285:   getEmbeddingDimension(): number {\n286:     return get_embedding_dim();\n287:   }\n288: \n289:   async close(): Promise<void> {\n290:     if (this._initialized) {\n291:       close_db();\n292:       this._initialized = false;\n293:     }\n294:   }\n295: \n296:   async deleteByPath(specFolder: string, filePath: string, anchorId: string | null = null): Promise<boolean> {\n297:     this._ensureInitialized();\n298:     const database = this._getDatabase();\n299:     const { delete_memory_by_path } = await getMutationsModule();\n300:     return delete_memory_by_path(specFolder, filePath, anchorId, database);\n301:   }\n302: \n303:   async getByFolder(specFolder: string): Promise<MemoryRow[]> {\n304:     this._ensureInitialized();\n305:     const database = this._getDatabase();\n306:     const { get_memories_by_folder } = await getQueriesModule();\n307:     return get_memories_by_folder(specFolder, database);\n308:   }\n309: \n310:   async searchEnriched(\n311:     embedding: string,\n312:     options: { specFolder?: string | null; minSimilarity?: number } = {},\n313:   ): Promise<EnrichedSearchResult[]> {\n314:     this._ensureInitialized();\n315:     const database = this._getDatabase();\n316:     const { vector_search_enriched } = await getQueriesModule();\n317:     return vector_search_enriched(embedding, undefined, options, database);\n318:   }\n319: \n320:   async enhancedSearch(embedding: string, options: EnhancedSearchOptions = {}): Promise<EnrichedSearchResult[]> {\n321:     this._ensureInitialized();\n322:     const database = this._getDatabase();\n323:     const { enhanced_search } = await getAliasesModule();\n324:     return enhanced_search(embedding, undefined, options, database);\n325:   }\n326: \n327:   async getConstitutionalMemories(\n328:     options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n329:   ): Promise<MemoryRow[]> {\n330:     this._ensureInitialized();\n331:     const database = this._getDatabase();\n332:     const { get_constitutional_memories_public } = await getQueriesModule();\n333:     return get_constitutional_memories_public(options, database);\n334:   }\n335: \n336:   async verifyIntegrity(\n337:     options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n338:   ): Promise<{\n339:     totalMemories: number;\n340:     totalVectors: number;\n341:     orphanedVectors: number;\n342:     missingVectors: number;\n343:     orphanedFiles: Array<{ id: number; file_path: string; reason: string }>;\n344:     orphanedChunks: number;\n345:     isConsistent: boolean;\n346:     cleaned?: { vectors: number; chunks: number; files: number };\n347:   }> {\n348:     this._ensureInitialized();\n349:     const database = this._getDatabase();\n350:     const { verify_integrity } = await getQueriesModule();\n351:     return verify_integrity(options, database);\n352:   }\n353: \n354:   private getEmbeddingForId(database: Database.Database, id: number): Float32Array {\n355:     const row = database.prepare(`\n356:       SELECT embedding\n357:       FROM ${activeVectorSource('vec_memories')}\n358:       WHERE rowid = ?\n359:       LIMIT 1\n360:     `).get(BigInt(id)) as { embedding?: Buffer | Uint8Array } | undefined;\n361:     if (!row?.embedding) {\n362:       return new Float32Array();\n363:     }\n364:     const buffer = row.embedding;\n365:     return new Float32Array(buffer.buffer.slice(buffer.byteOffset, buffer.byteOffset + buffer.byteLength));\n366:   }\n367: }\n\n(End of file - total 367 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Vector Store\n// -------------------------------------------------------------------\n\nimport { IVectorStore } from '../../interfaces/vector-store.js';\nimport {\n  activeVectorSource,\n  close_db,\n  get_embedding_dim,\n  initialize_db,\n  sqlite_vec_available,\n} from '../../search/vector-index-store.js';\nimport {\n  VectorIndexError,\n  VectorIndexErrorCode,\n  type EmbeddingInput,\n  type EnrichedSearchResult,\n  type IndexMemoryParams,\n  type MemoryRow,\n  type VectorSearchOptions as LegacyVectorSearchOptions,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Vector Store\n// -------------------------------------------------------------------\n\nimport { IVectorStore } from '../../interfaces/vector-store.js';\nimport {\n  activeVectorSource,\n  close_db,\n  get_embedding_dim,\n  initialize_db,\n  sqlite_vec_available,\n} from '../../search/vector-index-store.js';\nimport {\n  VectorIndexError,\n  VectorIndexErrorCode,\n  type EmbeddingInput,\n  type EnrichedSearchResult,\n  type IndexMemoryParams,\n  type MemoryRow,\n  type VectorSearchOptions as LegacyVectorSearchOptions,\n} from '../../search/vector-index-types.js';\n\nimport type { Awaitable, StorageId } from './common.js';\nimport type Database from 'better-sqlite3';\n\ntype JsonObject = Record<string, unknown>;\n\ninterface BetterSqliteVectorStoreOptions {\n  readonly dbPath?: string;\n}\n\ntype EnhancedSearchOptions = {\n  specFolder?: string | null;\n  minSimilarity?: number;\n  diversityFactor?: number;\n  noDiversity?: boolean;\n};\n\nlet cachedQueries: Awaited<typeof import('../../search/vector-index-queries.js')> | null = null;\nlet cachedMutations: Awaited<typeof import('../../search/vector-index-mutations.js')> | null = null;\nlet cachedAliases: Awaited<typeof import('../../search/vector-index-aliases.js')> | null = null;\n\nasync function getQueriesModule(): Promise<Awaited<typeof import('../../search/vector-index-queries.js')>> {\n  return cachedQueries ??= await import('../../search/vector-index-queries.js');\n}\n\nasync function getMutationsModule(): Promise<Awaited<typeof import('../../search/vector-index-mutations.js')>> {\n  return cachedMutations ??= await import('../../search/vector-index-mutations.js');\n}\n\nasync function getAliasesModule(): Promise<Awaited<typeof import('../../search/vector-index-aliases.js')>> {\n  return cachedAliases ??= await import('../../search/vector-index-aliases.js');\n}\n\n/** Metadata attached to a vector record. */\nexport type VectorMetadata = Readonly<Record<string, unknown>>;\n\n/** Persisted vector entry. */\nexport interface VectorRecord<TMetadata extends VectorMetadata = VectorMetadata> {\n  readonly id: StorageId;\n  readonly embedding: readonly number[] | Float32Array;\n  readonly metadata: TMetadata;\n}\n\n/** Ranked vector search hit. */\nexport interface VectorSearchResult<TMetadata extends VectorMetadata = VectorMetadata> {\n  readonly id: StorageId;\n  readonly score: number;\n  readonly metadata: TMetadata;\n}\n\n/** Query options for vector nearest-neighbor retrieval. */\nexport interface VectorSearchOptions {\n  readonly limit: number;\n  readonly minScore?: number;\n}\n\n/** Port for vector persistence and similarity retrieval. */\nexport interface VectorStore<TMetadata extends VectorMetadata = VectorMetadata> {\n  /** Insert or replace one vector record. */\n  upsert(record: VectorRecord<TMetadata>): Awaitable<void>;\n\n  /** Remove one vector record. */\n  delete(id: StorageId): Awaitable<boolean>;\n\n  /** Fetch one vector record by ID. */\n  get(id: StorageId): Awaitable<VectorRecord<TMetadata> | null>;\n\n  /** Return ranked vector matches for a query embedding. */\n  search(\n    embedding: readonly number[] | Float32Array,\n    options: VectorSearchOptions,\n  ): Awaitable<VectorSearchResult<TMetadata>[]>;\n\n  /** Remove all vector records. */\n  clear(): Awaitable<void>;\n}\n\n/** better-sqlite3-backed vector-store adapter. */\nexport class BetterSqliteVectorStore<TMetadata extends VectorMetadata = VectorMetadata>\n  extends IVectorStore\n  implements VectorStore<TMetadata> {\n  dbPath: string | null;\n  _initialized: boolean;\n\n  constructor(options: BetterSqliteVectorStoreOptions = {}) {\n    super();\n    this.dbPath = options.dbPath || null;\n    this._initialized = false;\n  }\n\n  _ensureInitialized(): void {\n    if (!this._initialized) {\n      this._getDatabase();\n      this._initialized = true;\n    }\n  }\n\n  _getDatabase(): Database.Database {\n    return initialize_db(this.dbPath);\n  }\n\n  search(\n    embedding: readonly number[] | Float32Array,\n    options: VectorSearchOptions,\n  ): Promise<VectorSearchResult<TMetadata>[]>;\n  search(\n    embedding: EmbeddingInput,\n    topK: number,\n    options?: LegacyVectorSearchOptions,\n  ): Promise<MemoryRow[]>;\n  async search(\n    embedding: EmbeddingInput,\n    optionsOrTopK: VectorSearchOptions | number,\n    options: LegacyVectorSearchOptions = {},\n  ): Promise<VectorSearchResult<TMetadata>[] | MemoryRow[]> {\n    if (typeof optionsOrTopK !== 'number') {\n      const rows = await this.search(embedding, optionsOrTopK.limit, {\n        minSimilarity: optionsOrTopK.minScore === undefined ? 0 : optionsOrTopK.minScore * 100,\n        includeConstitutional: false,\n      });\n      return rows.map((row) => ({\n        id: String(row.id),\n        score: typeof row.similarity === 'number' ? row.similarity / 100 : 0,\n        metadata: row as unknown as TMetadata,\n      }));\n    }\n\n    this._ensureInitialized();\n    const database = this._getDatabase();\n\n    const expected_dim = get_embedding_dim();\n    if (!embedding || embedding.length !== expected_dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${expected_dim}, got ${embedding?.length}`,\n        VectorIndexErrorCode.EMBEDDING_VALIDATION,\n      );\n    }\n\n    const search_options = {\n      limit: optionsOrTopK,\n      specFolder: options.specFolder,\n      minSimilarity: options.minSimilarity || 0,\n      useDecay: options.useDecay !== false,\n      tier: options.tier,\n      contextType: options.contextType,\n      includeConstitutional: options.includeConstitutional !== false,\n      includeArchived: options.includeArchived === true\n    };\n\n    const { vector_search } = await getQueriesModule();\n    return vector_search(embedding, search_options, database);\n  }\n\n  upsert(record: VectorRecord<TMetadata>): Promise<void>;\n  upsert(id: string, embedding: EmbeddingInput, metadata: JsonObject): Promise<number>;\n  async upsert(\n    recordOrId: VectorRecord<TMetadata> | string,\n    embedding?: EmbeddingInput,\n    metadata?: JsonObject,\n  ): Promise<void | number> {\n    if (typeof recordOrId !== 'string') {\n      const recordEmbedding = recordOrId.embedding instanceof Float32Array\n        ? recordOrId.embedding\n        : Array.from(recordOrId.embedding);\n      await this.upsert(String(recordOrId.id), recordEmbedding, recordOrId.metadata);\n      return;\n    }\n\n    this._ensureInitialized();\n    const database = this._getDatabase();\n\n    const expected_dim = get_embedding_dim();\n    if (!embedding || embedding.length !== expected_dim) {\n      throw new VectorIndexError(\n        `Embedding dimension mismatch: expected ${expected_dim}, got ${embedding?.length}`,\n        VectorIndexErrorCode.EMBEDDING_VALIDATION,\n      );\n    }\n\n    const metadata_alias = (metadata ?? {}) as JsonObject & {\n      spec_folder?: string;\n      specFolder?: string;\n      file_path?: string;\n      filePath?: string;\n      anchor_id?: string;\n      anchorId?: string;\n      title?: string;\n      trigger_phrases?: string[];\n      triggerPhrases?: string[];\n      importance_weight?: number;\n      importanceWeight?: number;\n    };\n\n    const params: IndexMemoryParams = {\n      specFolder: metadata_alias.spec_folder || metadata_alias.specFolder || '',\n      filePath: metadata_alias.file_path || metadata_alias.filePath || '',\n      anchorId: metadata_alias.anchor_id || metadata_alias.anchorId || null,\n      title: metadata_alias.title || null,\n      triggerPhrases: metadata_alias.trigger_phrases || metadata_alias.triggerPhrases || [],\n      importanceWeight: metadata_alias.importance_weight ?? metadata_alias.importanceWeight ?? 0.5,\n      embedding: embedding\n    };\n\n    if (!params.specFolder || !params.filePath) {\n      throw new VectorIndexError(\n        'metadata must include spec_folder and file_path',\n        VectorIndexErrorCode.STORE_ERROR,\n      );\n    }\n\n    const { index_memory } = await getMutationsModule();\n    return index_memory(params, database);\n  }\n\n  async delete(id: StorageId): Promise<boolean> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { delete_memory } = await getMutationsModule();\n    return delete_memory(Number(id), database);\n  }\n\n  async get(id: StorageId): Promise<VectorRecord<TMetadata> | null>;\n  async get(id: number): Promise<MemoryRow | null>;\n  async get(id: StorageId): Promise<VectorRecord<TMetadata> | MemoryRow | null> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_memory } = await getQueriesModule();\n    const row = get_memory(Number(id), database);\n    if (!row) {\n      return null;\n    }\n    if (typeof id === 'number') {\n      return row;\n    }\n    const embedding = this.getEmbeddingForId(database, Number(row.id));\n    return {\n      id: row.id,\n      embedding,\n      metadata: row as unknown as TMetadata,\n    };\n  }\n\n  async clear(): Promise<void> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    database.transaction(() => {\n      database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')}`).run();\n      database.prepare('DELETE FROM active_memory_projection').run();\n      database.prepare('DELETE FROM memory_index').run();\n    })();\n  }\n\n  async getStats(): Promise<{ total: number; pending: number; success: number; failed: number; retry: number }> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_stats } = await getQueriesModule();\n    return get_stats(database);\n  }\n\n  isAvailable(): boolean {\n    return sqlite_vec_available();\n  }\n\n  getEmbeddingDimension(): number {\n    return get_embedding_dim();\n  }\n\n  async close(): Promise<void> {\n    if (this._initialized) {\n      close_db();\n      this._initialized = false;\n    }\n  }\n\n  async deleteByPath(specFolder: string, filePath: string, anchorId: string | null = null): Promise<boolean> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { delete_memory_by_path } = await getMutationsModule();\n    return delete_memory_by_path(specFolder, filePath, anchorId, database);\n  }\n\n  async getByFolder(specFolder: string): Promise<MemoryRow[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_memories_by_folder } = await getQueriesModule();\n    return get_memories_by_folder(specFolder, database);\n  }\n\n  async searchEnriched(\n    embedding: string,\n    options: { specFolder?: string | null; minSimilarity?: number } = {},\n  ): Promise<EnrichedSearchResult[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { vector_search_enriched } = await getQueriesModule();\n    return vector_search_enriched(embedding, undefined, options, database);\n  }\n\n  async enhancedSearch(embedding: string, options: EnhancedSearchOptions = {}): Promise<EnrichedSearchResult[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { enhanced_search } = await getAliasesModule();\n    return enhanced_search(embedding, undefined, options, database);\n  }\n\n  async getConstitutionalMemories(\n    options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n  ): Promise<MemoryRow[]> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { get_constitutional_memories_public } = await getQueriesModule();\n    return get_constitutional_memories_public(options, database);\n  }\n\n  async verifyIntegrity(\n    options: { autoClean?: boolean; cleanFiles?: boolean } = {},\n  ): Promise<{\n    totalMemories: number;\n    totalVectors: number;\n    orphanedVectors: number;\n    missingVectors: number;\n    orphanedFiles: Array<{ id: number; file_path: string; reason: string }>;\n    orphanedChunks: number;\n    isConsistent: boolean;\n    cleaned?: { vectors: number; chunks: number; files: number };\n  }> {\n    this._ensureInitialized();\n    const database = this._getDatabase();\n    const { verify_integrity } = await getQueriesModule();\n    return verify_integrity(options, database);\n  }\n\n  private getEmbeddingForId(database: Database.Database, id: number): Float32Array {\n    const row = database.prepare(`\n      SELECT embedding\n      FROM ${activeVectorSource('vec_memories')}\n      WHERE rowid = ?\n      LIMIT 1\n    `).get(BigInt(id)) as { embedding?: Buffer | Uint8Array } | undefined;\n    if (!row?.embedding) {\n      return new Float32Array();\n    }\n    const buffer = row.embedding;\n    return new Float32Array(buffer.buffer.slice(buffer.byteOffset, buffer.byteOffset + buffer.byteLength));\n  }\n}","lineStart":1,"lineEnd":367,"totalLines":367,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/vector-store.ts","time":{"start":1781144209488,"end":1781144209500}},"metadata":{"openai":{"itemId":"fc_095aec1ef8cb9081016a2a1a9164b88191a56d2ff05af035cb"}},"id":"prt_eb477c84f001ZsVrw3e1z42yJD","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477911d001iZ2kO0FPyBDSgU"}}
{"type":"tool_use","timestamp":1781144209503,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_TGawRSWXsMT4pFiwKFVJYipw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Contention Policy\n3: // -------------------------------------------------------------------\n4: \n5: import type { Awaitable } from './common.js';\n6: import type Database from 'better-sqlite3';\n7: \n8: export interface ContentionRetryContext {\n9:   readonly attempt: number;\n10:   readonly delayMs: number;\n11:   readonly label?: string;\n12: }\n13: \n14: /** Retry policy for transient storage contention. */\n15: export interface ContentionRetryOptions {\n16:   readonly attempts?: number;\n17:   readonly delayMs?: number | (() => number);\n18:   readonly retryDelaysMs?: readonly number[];\n19:   readonly retryable?: (error: unknown) => boolean;\n20:   readonly sleep?: (ms: number) => Awaitable<void>;\n21:   readonly sleepSync?: (ms: number) => void;\n22:   readonly sync?: boolean;\n23:   readonly shouldAbort?: () => boolean;\n24:   readonly onRetry?: (error: unknown, context: ContentionRetryContext) => void;\n25: }\n26: \n27: /** Execution metadata for contention-managed operations. */\n28: export interface ContentionOperationOptions extends ContentionRetryOptions {\n29:   readonly label?: string;\n30: }\n31: \n32: export interface BusyTimeoutOptions {\n33:   readonly ignoreErrors?: boolean;\n34: }\n35: \n36: /** Options for the better-sqlite3 contention adapter. */\n37: export interface BetterSqliteContentionPolicyOptions {\n38:   readonly database?: Database.Database;\n39:   readonly retryable?: (error: unknown) => boolean;\n40:   readonly sleep?: (ms: number) => Awaitable<void>;\n41:   readonly sleepSync?: (ms: number) => void;\n42: }\n43: \n44: /** Port for retrying and serializing storage operations under contention. */\n45: export interface ContentionPolicy {\n46:   /** Run an operation through the configured contention retry policy. */\n47:   withRetry<T>(\n48:     operation: () => Awaitable<T>,\n49:     options?: ContentionOperationOptions,\n50:   ): Awaitable<T>;\n51: \n52:   /** Run an operation in an exclusive write section when the backend has one. */\n53:   withWriteLock<T>(\n54:     operation: () => Awaitable<T>,\n55:     options?: ContentionOperationOptions,\n56:   ): Awaitable<T>;\n57: \n58:   /** Apply a backend busy timeout when supported. */\n59:   setBusyTimeout(\n60:     database: Database.Database,\n61:     timeoutMs: number,\n62:     options?: BusyTimeoutOptions,\n63:   ): void;\n64: }\n65: \n66: /** better-sqlite3 implementation of contention retry and write-lock policy. */\n67: export class BetterSqliteContentionPolicy implements ContentionPolicy {\n68:   private readonly database: Database.Database | undefined;\n69:   private readonly retryable: (error: unknown) => boolean;\n70:   private readonly sleep: (ms: number) => Awaitable<void>;\n71:   private readonly sleepSync: (ms: number) => void;\n72: \n73:   constructor(options: BetterSqliteContentionPolicyOptions = {}) {\n74:     this.database = options.database;\n75:     this.retryable = options.retryable ?? isSqliteContentionError;\n76:     this.sleep = options.sleep ?? defaultSleep;\n77:     this.sleepSync = options.sleepSync ?? defaultSleepSync;\n78:   }\n79: \n80:   withRetry<T>(\n81:     operation: () => Awaitable<T>,\n82:     options: ContentionOperationOptions = {},\n83:   ): Awaitable<T> {\n84:     if (options.sync) {\n85:       return this.withRetrySync(operation as () => T, options);\n86:     }\n87:     return this.withRetryAsync(operation, options);\n88:   }\n89: \n90:   withWriteLock<T>(\n91:     operation: () => Awaitable<T>,\n92:     options: ContentionOperationOptions = {},\n93:   ): Awaitable<T> {\n94:     const database = this.database;\n95:     if (!database || database.inTransaction) {\n96:       return this.withRetry(operation, options);\n97:     }\n98: \n99:     return this.withRetry(() => runWithWriteLock(database, operation), options);\n100:   }\n101: \n102:   setBusyTimeout(\n103:     database: Database.Database,\n104:     timeoutMs: number,\n105:     options: BusyTimeoutOptions = {},\n106:   ): void {\n107:     try {\n108:       database.pragma(`busy_timeout = ${timeoutMs}`);\n109:     } catch (error: unknown) {\n110:       if (!options.ignoreErrors) {\n111:         throw error;\n112:       }\n113:     }\n114:   }\n115: \n116:   private async withRetryAsync<T>(\n117:     operation: () => Awaitable<T>,\n118:     options: ContentionOperationOptions,\n119:   ): Promise<T> {\n120:     const retryable = options.retryable ?? this.retryable;\n121:     const attempts = retryAttempts(options);\n122:     for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n123:       if (options.shouldAbort?.()) {\n124:         return undefined as T;\n125:       }\n126:       try {\n127:         return await operation();\n128:       } catch (error: unknown) {\n129:         const canRetry = retryable(error) && attemptIndex < attempts - 1;\n130:         if (!canRetry) {\n131:           throw error;\n132:         }\n133:         const delayMs = retryDelayMs(options, attemptIndex);\n134:         options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n135:         await (options.sleep ?? this.sleep)(delayMs);\n136:         if (options.shouldAbort?.()) {\n137:           return undefined as T;\n138:         }\n139:       }\n140:     }\n141:     throw new Error('BetterSqliteContentionPolicy.withRetry: unreachable');\n142:   }\n143: \n144:   private withRetrySync<T>(\n145:     operation: () => T,\n146:     options: ContentionOperationOptions,\n147:   ): T {\n148:     const retryable = options.retryable ?? this.retryable;\n149:     const attempts = retryAttempts(options);\n150:     for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n151:       if (options.shouldAbort?.()) {\n152:         return undefined as T;\n153:       }\n154:       try {\n155:         return operation();\n156:       } catch (error: unknown) {\n157:         const canRetry = retryable(error) && attemptIndex < attempts - 1;\n158:         if (!canRetry) {\n159:           throw error;\n160:         }\n161:         const delayMs = retryDelayMs(options, attemptIndex);\n162:         options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n163:         (options.sleepSync ?? this.sleepSync)(delayMs);\n164:         if (options.shouldAbort?.()) {\n165:           return undefined as T;\n166:         }\n167:       }\n168:     }\n169:     throw new Error('BetterSqliteContentionPolicy.withRetrySync: unreachable');\n170:   }\n171: }\n172: \n173: export function isSqliteContentionError(error: unknown): boolean {\n174:   const code = typeof error === 'object' && error !== null && 'code' in error\n175:     ? (error as { code?: unknown }).code\n176:     : undefined;\n177:   const message = error instanceof Error ? error.message : String(error);\n178:   return code === 'SQLITE_BUSY'\n179:     || code === 'SQLITE_LOCKED'\n180:     || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n181: }\n182: \n183: function retryAttempts(options: ContentionOperationOptions): number {\n184:   const attempts = options.attempts ?? ((options.retryDelaysMs?.length ?? 0) + 1);\n185:   return Math.max(1, attempts);\n186: }\n187: \n188: function retryDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n189:   const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n190:   const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n191:   return Math.max(0, delay);\n192: }\n193: \n194: function defaultSleep(ms: number): Promise<void> {\n195:   return new Promise((resolve) => setTimeout(resolve, ms));\n196: }\n197: \n198: function defaultSleepSync(ms: number): void {\n199:   Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);\n200: }\n201: \n202: function runWithWriteLock<T>(\n203:   database: Database.Database,\n204:   operation: () => Awaitable<T>,\n205: ): Awaitable<T> {\n206:   database.exec('BEGIN IMMEDIATE');\n207:   try {\n208:     const result = operation();\n209:     if (isPromiseLike(result)) {\n210:       return result.then(\n211:         (value) => {\n212:           database.exec('COMMIT');\n213:           return value;\n214:         },\n215:         (error: unknown) => {\n216:           rollbackQuietly(database);\n217:           throw error;\n218:         },\n219:       );\n220:     }\n221:     database.exec('COMMIT');\n222:     return result;\n223:   } catch (error: unknown) {\n224:     rollbackQuietly(database);\n225:     throw error;\n226:   }\n227: }\n228: \n229: function isPromiseLike<T>(value: Awaitable<T>): value is Promise<T> {\n230:   return typeof value === 'object'\n231:     && value !== null\n232:     && typeof (value as { then?: unknown }).then === 'function';\n233: }\n234: \n235: function rollbackQuietly(database: Database.Database): void {\n236:   try {\n237:     database.exec('ROLLBACK');\n238:   } catch {\n239:     // Ignore rollback errors after a failed write section.\n240:   }\n241: }\n\n(End of file - total 241 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Contention Policy\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\nexport interface ContentionRetryContext {\n  readonly attempt: number;\n  readonly delayMs: number;\n  readonly label?: string;\n}\n\n/** Retry policy for transient storage contention. */\nexport interface ContentionRetryOptions {\n  readonly attempts?: number;\n  readonly delayMs?: number | (() => number);\n  readonly retryDelaysMs?: readonly number[];\n  readonly retryable?: (error: unknown) => boolean;\n  readonly sleep?: (ms: number) => Awaitable<void>;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Contention Policy\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\nexport interface ContentionRetryContext {\n  readonly attempt: number;\n  readonly delayMs: number;\n  readonly label?: string;\n}\n\n/** Retry policy for transient storage contention. */\nexport interface ContentionRetryOptions {\n  readonly attempts?: number;\n  readonly delayMs?: number | (() => number);\n  readonly retryDelaysMs?: readonly number[];\n  readonly retryable?: (error: unknown) => boolean;\n  readonly sleep?: (ms: number) => Awaitable<void>;\n  readonly sleepSync?: (ms: number) => void;\n  readonly sync?: boolean;\n  readonly shouldAbort?: () => boolean;\n  readonly onRetry?: (error: unknown, context: ContentionRetryContext) => void;\n}\n\n/** Execution metadata for contention-managed operations. */\nexport interface ContentionOperationOptions extends ContentionRetryOptions {\n  readonly label?: string;\n}\n\nexport interface BusyTimeoutOptions {\n  readonly ignoreErrors?: boolean;\n}\n\n/** Options for the better-sqlite3 contention adapter. */\nexport interface BetterSqliteContentionPolicyOptions {\n  readonly database?: Database.Database;\n  readonly retryable?: (error: unknown) => boolean;\n  readonly sleep?: (ms: number) => Awaitable<void>;\n  readonly sleepSync?: (ms: number) => void;\n}\n\n/** Port for retrying and serializing storage operations under contention. */\nexport interface ContentionPolicy {\n  /** Run an operation through the configured contention retry policy. */\n  withRetry<T>(\n    operation: () => Awaitable<T>,\n    options?: ContentionOperationOptions,\n  ): Awaitable<T>;\n\n  /** Run an operation in an exclusive write section when the backend has one. */\n  withWriteLock<T>(\n    operation: () => Awaitable<T>,\n    options?: ContentionOperationOptions,\n  ): Awaitable<T>;\n\n  /** Apply a backend busy timeout when supported. */\n  setBusyTimeout(\n    database: Database.Database,\n    timeoutMs: number,\n    options?: BusyTimeoutOptions,\n  ): void;\n}\n\n/** better-sqlite3 implementation of contention retry and write-lock policy. */\nexport class BetterSqliteContentionPolicy implements ContentionPolicy {\n  private readonly database: Database.Database | undefined;\n  private readonly retryable: (error: unknown) => boolean;\n  private readonly sleep: (ms: number) => Awaitable<void>;\n  private readonly sleepSync: (ms: number) => void;\n\n  constructor(options: BetterSqliteContentionPolicyOptions = {}) {\n    this.database = options.database;\n    this.retryable = options.retryable ?? isSqliteContentionError;\n    this.sleep = options.sleep ?? defaultSleep;\n    this.sleepSync = options.sleepSync ?? defaultSleepSync;\n  }\n\n  withRetry<T>(\n    operation: () => Awaitable<T>,\n    options: ContentionOperationOptions = {},\n  ): Awaitable<T> {\n    if (options.sync) {\n      return this.withRetrySync(operation as () => T, options);\n    }\n    return this.withRetryAsync(operation, options);\n  }\n\n  withWriteLock<T>(\n    operation: () => Awaitable<T>,\n    options: ContentionOperationOptions = {},\n  ): Awaitable<T> {\n    const database = this.database;\n    if (!database || database.inTransaction) {\n      return this.withRetry(operation, options);\n    }\n\n    return this.withRetry(() => runWithWriteLock(database, operation), options);\n  }\n\n  setBusyTimeout(\n    database: Database.Database,\n    timeoutMs: number,\n    options: BusyTimeoutOptions = {},\n  ): void {\n    try {\n      database.pragma(`busy_timeout = ${timeoutMs}`);\n    } catch (error: unknown) {\n      if (!options.ignoreErrors) {\n        throw error;\n      }\n    }\n  }\n\n  private async withRetryAsync<T>(\n    operation: () => Awaitable<T>,\n    options: ContentionOperationOptions,\n  ): Promise<T> {\n    const retryable = options.retryable ?? this.retryable;\n    const attempts = retryAttempts(options);\n    for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n      if (options.shouldAbort?.()) {\n        return undefined as T;\n      }\n      try {\n        return await operation();\n      } catch (error: unknown) {\n        const canRetry = retryable(error) && attemptIndex < attempts - 1;\n        if (!canRetry) {\n          throw error;\n        }\n        const delayMs = retryDelayMs(options, attemptIndex);\n        options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n        await (options.sleep ?? this.sleep)(delayMs);\n        if (options.shouldAbort?.()) {\n          return undefined as T;\n        }\n      }\n    }\n    throw new Error('BetterSqliteContentionPolicy.withRetry: unreachable');\n  }\n\n  private withRetrySync<T>(\n    operation: () => T,\n    options: ContentionOperationOptions,\n  ): T {\n    const retryable = options.retryable ?? this.retryable;\n    const attempts = retryAttempts(options);\n    for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n      if (options.shouldAbort?.()) {\n        return undefined as T;\n      }\n      try {\n        return operation();\n      } catch (error: unknown) {\n        const canRetry = retryable(error) && attemptIndex < attempts - 1;\n        if (!canRetry) {\n          throw error;\n        }\n        const delayMs = retryDelayMs(options, attemptIndex);\n        options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n        (options.sleepSync ?? this.sleepSync)(delayMs);\n        if (options.shouldAbort?.()) {\n          return undefined as T;\n        }\n      }\n    }\n    throw new Error('BetterSqliteContentionPolicy.withRetrySync: unreachable');\n  }\n}\n\nexport function isSqliteContentionError(error: unknown): boolean {\n  const code = typeof error === 'object' && error !== null && 'code' in error\n    ? (error as { code?: unknown }).code\n    : undefined;\n  const message = error instanceof Error ? error.message : String(error);\n  return code === 'SQLITE_BUSY'\n    || code === 'SQLITE_LOCKED'\n    || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n}\n\nfunction retryAttempts(options: ContentionOperationOptions): number {\n  const attempts = options.attempts ?? ((options.retryDelaysMs?.length ?? 0) + 1);\n  return Math.max(1, attempts);\n}\n\nfunction retryDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n  const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n  const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n  return Math.max(0, delay);\n}\n\nfunction defaultSleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction defaultSleepSync(ms: number): void {\n  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);\n}\n\nfunction runWithWriteLock<T>(\n  database: Database.Database,\n  operation: () => Awaitable<T>,\n): Awaitable<T> {\n  database.exec('BEGIN IMMEDIATE');\n  try {\n    const result = operation();\n    if (isPromiseLike(result)) {\n      return result.then(\n        (value) => {\n          database.exec('COMMIT');\n          return value;\n        },\n        (error: unknown) => {\n          rollbackQuietly(database);\n          throw error;\n        },\n      );\n    }\n    database.exec('COMMIT');\n    return result;\n  } catch (error: unknown) {\n    rollbackQuietly(database);\n    throw error;\n  }\n}\n\nfunction isPromiseLike<T>(value: Awaitable<T>): value is Promise<T> {\n  return typeof value === 'object'\n    && value !== null\n    && typeof (value as { then?: unknown }).then === 'function';\n}\n\nfunction rollbackQuietly(database: Database.Database): void {\n  try {\n    database.exec('ROLLBACK');\n  } catch {\n    // Ignore rollback errors after a failed write section.\n  }\n}","lineStart":1,"lineEnd":241,"totalLines":241,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts","time":{"start":1781144209486,"end":1781144209501}},"metadata":{"openai":{"itemId":"fc_095aec1ef8cb9081016a2a1a9164b48191b010f7f481bf177d"}},"id":"prt_eb477c84c001Vj3Y2JpXO9fC47","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb477911d001iZ2kO0FPyBDSgU"}}
