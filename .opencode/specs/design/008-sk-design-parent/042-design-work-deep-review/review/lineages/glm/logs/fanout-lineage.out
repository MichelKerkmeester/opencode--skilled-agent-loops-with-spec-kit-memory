dingsNew\":{\"P0\":0,\"P1\":0,\"P2\":1},\"findingDetails\":[{\"findingId\":\"F001\",\"severity\":\"P2\",\"category\":\"correctness\",\"dimension\":\"correctness\",\"title\":\"proof_check.py READY regex accepts any bolded READY in prose\",\"file\":\".opencode/skills/sk-design/shared/scripts/proof_check.py\",\"line\":46,\"firstSeen\":1,\"content_hash\":\"sha256-placeholder-f001-iter1\",\"scopeProof\":\"proof_check.py is the deterministic proof-of-application gate cited by shared/assets/proof_of_application_card.md and named in the orchestrator reviewScopeNote.\",\"affectedSurfaceHints\":[\"shared/scripts/proof_check.py\"],\"status\":\"active\"}],\"traceabilityChecks\":{\"summary\":{\"required\":2,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":2,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.04,\"durationMs\":0,\"timestamp\":\"2026-06-29T16:32:00Z\",\"sessionId\":\"fanout-glm-1782750389509-8fbzzu\",\"generation\":1,\"lineageMode\":\"new\"}\n{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":1,\"passed\":true,\"activeP0P1\":0,\"missingPackets\":[],\"timestamp\":\"2026-06-29T16:32:00Z\",\"sessionId\":\"fanout-glm-1782750389509-8fbzzu\",\"generation\":1}\nEOF\nwc -l .opencode/specs/skilled-agent-orchestration/154-sk-design-parent/042-design-work-deep-review/review/lineages/glm/deep-review-state.jsonl","time":{"start":1782750940981,"end":1782750940982}},"id":"prt_f143c8f280012GYxkdXLbE4BQY","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f143c5199001AgySZq8lQXHIH1"}}
