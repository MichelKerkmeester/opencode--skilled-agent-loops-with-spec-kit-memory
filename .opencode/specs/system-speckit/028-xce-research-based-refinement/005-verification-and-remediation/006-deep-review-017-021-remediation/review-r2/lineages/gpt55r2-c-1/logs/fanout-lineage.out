{"type":"tool_use","timestamp":1781761533937,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_I5oDqRswmKUI9PIA9TR9GH0L","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const fs = require('fs');\n4: const net = require('net');\n5: const path = require('path');\n6: const { StringDecoder } = require('string_decoder');\n7: \n8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n9: const DEFAULT_PROBE_TIMEOUT_MS = 5000;\n10: const MAX_PROBE_TIMEOUT_MS = 6999;\n11: const DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\n12: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n13: const MODEL_SERVER_HEALTH_PATH = '/api/health';\n14: let nextProbeId = 1;\n15: \n16: function parsePositiveInteger(value, fallback) {\n17:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n18:   const parsed = Number.parseInt(String(value).trim(), 10);\n19:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n20: }\n21: \n22: function clampProbeTimeoutMs(value) {\n23:   return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n24: }\n25: \n26: function resolveProbeTimeoutMs(options = {}) {\n27:   if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n28:     return clampProbeTimeoutMs(options.timeoutMs);\n29:   }\n30:   return clampProbeTimeoutMs(parsePositiveInteger(\n31:     (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n32:     DEFAULT_PROBE_TIMEOUT_MS,\n33:   ));\n34: }\n35: \n36: function parseNonNegativeInteger(value, fallback) {\n37:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n38:   const parsed = Number.parseInt(String(value).trim(), 10);\n39:   return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n40: }\n41: \n42: // A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n43: // daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n44: // consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n45: // its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n46: // the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\n47: function resolveLeaseProbeAttempts(env = process.env) {\n48:   return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n49: }\n50: function resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n51:   return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n52: }\n53: function resolveLeaseProbeRetryBackoffMs(env = process.env) {\n54:   return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n55: }\n56: \n57: function repoRoot() {\n58:   return path.resolve(__dirname, '..', '..', '..');\n59: }\n60: \n61: function defaultDbDirForService(serviceName) {\n62:   const root = repoRoot();\n63:   if (serviceName === 'mk-spec-memory') {\n64:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n65:   }\n66:   if (serviceName === 'mk-code-index') {\n67:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n68:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n69:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n70:   }\n71:   if (serviceName === 'mk-skill-advisor') {\n72:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n73:     return advisorOverride\n74:       ? path.resolve(advisorOverride)\n75:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n76:   }\n77:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n78: }\n79: \n80: function getIpcSocketPath(serviceName, options = {}) {\n81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n83:   }\n84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n86:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n87:   return path.join(socketDir, SOCKET_FILE_NAME);\n88: }\n89: \n90: function toConnectionOptions(socketPath) {\n91:   if (!socketPath.startsWith('tcp://')) {\n92:     return socketPath;\n93:   }\n94:   const url = new URL(socketPath);\n95:   return {\n96:     host: url.hostname,\n97:     port: Number.parseInt(url.port, 10),\n98:   };\n99: }\n100: \n101: function bridgeStdioToSocket(socketPath, options = {}) {\n102:   const input = options.stdin ?? process.stdin;\n103:   const output = options.stdout ?? process.stdout;\n104:   const exit = options.exit ?? ((code) => process.exit(code));\n105:   const socket = net.createConnection(toConnectionOptions(socketPath));\n106:   let closed = false;\n107: \n108:   const closeOnce = (code = 0) => {\n109:     if (closed) return;\n110:     closed = true;\n111:     input.unpipe(socket);\n112:     socket.unpipe(output);\n113:     socket.destroy();\n114:     exit(code);\n115:   };\n116: \n117:   socket.once('connect', () => {\n118:     options.onConnect?.(socket);\n119:     input.pipe(socket);\n120:     socket.pipe(output);\n121:   });\n122: \n123:   socket.once('error', (error) => {\n124:     options.onError?.(error);\n125:     closeOnce(0);\n126:   });\n127: \n128:   socket.once('close', () => {\n129:     closeOnce(0);\n130:   });\n131: \n132:   input.once('end', () => {\n133:     socket.end();\n134:   });\n135:   input.once('close', () => {\n136:     closeOnce(0);\n137:   });\n138:   output.once('error', () => {\n139:     closeOnce(0);\n140:   });\n141: \n142:   return socket;\n143: }\n144: \n145: function probeDaemon(socketPath, options = {}) {\n146:   const timeoutMs = resolveProbeTimeoutMs(options);\n147:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n148:   // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n149:   // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n150:   // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n151:   // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n152:   const deepProbe = options.deepProbe === true;\n153:   const id = nextProbeId++;\n154:   const request = `${JSON.stringify({\n155:     jsonrpc: '2.0',\n156:     id,\n157:     method: 'initialize',\n158:     params: {\n159:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n160:       capabilities: {},\n161:       clientInfo: { name: 'liveness-probe', version: '0' },\n162:     },\n163:   })}\\n`;\n164: \n165:   return new Promise((resolve) => {\n166:     let socket;\n167:     let settled = false;\n168:     let buffer = '';\n169:     let timer;\n170:     // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n171:     // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n172:     const decoder = new StringDecoder('utf8');\n173: \n174:     const finish = (status, reason) => {\n175:       if (settled) return;\n176:       settled = true;\n177:       if (timer) clearTimeout(timer);\n178:       if (socket) socket.destroy();\n179:       resolve({ status, reason });\n180:     };\n181: \n182:     try {\n183:       socket = connect(toConnectionOptions(socketPath));\n184:     } catch (error) {\n185:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n186:       return;\n187:     }\n188: \n189:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n190:     timer.unref?.();\n191: \n192:     socket.once('connect', () => {\n193:       if (!deepProbe) {\n194:         finish('alive', 'connect-ok');\n195:         return;\n196:       }\n197:       socket.write(request);\n198:     });\n199:     socket.on('data', (chunk) => {\n200:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n201:       let newlineIndex = buffer.indexOf('\\n');\n202:       while (newlineIndex !== -1) {\n203:         const line = buffer.slice(0, newlineIndex).trim();\n204:         buffer = buffer.slice(newlineIndex + 1);\n205:         newlineIndex = buffer.indexOf('\\n');\n206:         if (!line) continue;\n207:         try {\n208:           const parsed = JSON.parse(line);\n209:           if (\n210:             parsed &&\n211:             parsed.jsonrpc === '2.0' &&\n212:             parsed.id === id &&\n213:             (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n214:               Object.prototype.hasOwnProperty.call(parsed, 'error'))\n215:           ) {\n216:             finish('alive', 'json-rpc-reply');\n217:             return;\n218:           }\n219:         } catch {\n220:           // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n221:         }\n222:       }\n223:     });\n224:     socket.once('error', (error) => {\n225:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n226:     });\n227:     socket.once('close', () => {\n228:       finish('dead', 'closed-before-reply');\n229:     });\n230:   });\n231: }\n232: \n233: function parseHttpJsonResponse(buffer) {\n234:   const raw = buffer.toString('utf8');\n235:   const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n236:   if (headerEnd === -1) return null;\n237:   const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n238:   const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n239:   if (!statusMatch) return null;\n240:   const statusCode = Number.parseInt(statusMatch[1], 10);\n241:   const bodyRaw = raw.slice(headerEnd + 4).trim();\n242:   let body = null;\n243:   try {\n244:     body = bodyRaw ? JSON.parse(bodyRaw) : null;\n245:   } catch {\n246:     return { statusCode, body: null };\n247:   }\n248:   return { statusCode, body };\n249: }\n250: \n251: function probeModelServer(socketPath, options = {}) {\n252:   const timeoutMs = resolveProbeTimeoutMs(options);\n253:   const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n254:     ? options.loadingMaxMs\n255:     : parsePositiveInteger(\n256:       (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n257:       DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n258:     );\n259:   const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n260:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n261:   // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n262:   // without spawning a model server. Genuine embed consumers do not send this header, so their\n263:   // wake-on-demand path is unchanged.\n264:   const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n265: \n266:   return new Promise((resolve) => {\n267:     let socket;\n268:     let settled = false;\n269:     let chunks = [];\n270:     let timer;\n271: \n272:     // Carry the parsed health body so callers (the idle-eviction tick) can read\n273:     // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n274:     const finish = (status, reason, health) => {\n275:       if (settled) return;\n276:       settled = true;\n277:       if (timer) clearTimeout(timer);\n278:       if (socket) socket.destroy();\n279:       resolve({ status, reason, health });\n280:     };\n281: \n282:     try {\n283:       socket = connect(toConnectionOptions(socketPath));\n284:     } catch (error) {\n285:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n286:       return;\n287:     }\n288: \n289:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n290:     timer.unref?.();\n291: \n292:     socket.once('connect', () => {\n293:       socket.write(request);\n294:     });\n295:     socket.on('data', (chunk) => {\n296:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n297:     });\n298:     socket.once('end', () => {\n299:       const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n300:       const state = parsed && parsed.body && typeof parsed.body === 'object'\n301:         ? parsed.body.state\n302:         : null;\n303:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n304:         finish('alive', `health-${state}`, parsed.body);\n305:         return;\n306:       }\n307:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n308:         const loadStartedAt = parsed.body.loadStartedAt;\n309:         const loadProgressAt = parsed.body.loadProgressAt;\n310:         // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n311:         const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n312:           ? loadProgressAt\n313:           : loadStartedAt;\n314:         if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n315:           finish('dead', 'loading-wedged');\n316:           return;\n317:         }\n318:         finish('alive', 'health-loading', parsed.body);\n319:         return;\n320:       }\n321:       finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n322:     });\n323:     socket.once('error', (error) => {\n324:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n325:     });\n326:     socket.once('close', () => {\n327:       if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n328:     });\n329:   });\n330: }\n331: \n332: // Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n333: // only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n334: // sleep are injectable so the retry decision is unit-testable without real sockets or timers.\n335: async function probeLeaseHolderWithRetries(socketPath, options = {}) {\n336:   const {\n337:     probe = probeDaemon,\n338:     firstTimeoutMs,\n339:     retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n340:     retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n341:     attempts = resolveLeaseProbeAttempts(),\n342:     connect,\n343:     sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n344:     onRetry,\n345:   } = options;\n346:   const totalAttempts = Math.max(1, attempts);\n347:   let result = { status: 'dead', reason: 'no-probe-attempted' };\n348:   for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n349:     const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n350:     result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n351:     if (result.status === 'alive') return result;\n352:     if (attempt < totalAttempts) {\n353:       if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n354:       await sleepFn(retryBackoffMs);\n355:     }\n356:   }\n357:   return result;\n358: }\n359: \n360: async function maybeBridgeLeaseHolder(options) {\n361:   const {\n362:     serviceName,\n363:     leaseResult,\n364:     loggerPrefix,\n365:     dbDir,\n366:     legacyReport,\n367:     probeTimeoutMs,\n368:     connect,\n369:     bridge,\n370:   } = options;\n371:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n372:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n373:   const ownerPid = leaseResult.ownerPid;\n374:   const writeLeaseHeld = (suffix = '') => {\n375:     process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n376:   };\n377: \n378:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n379:     if (legacyReport) {\n380:       legacyReport(leaseResult);\n381:       return { action: 'report', reason: 'bridge-disabled' };\n382:     }\n383:     writeLeaseHeld();\n384:     return { action: 'report', reason: 'bridge-disabled' };\n385:   }\n386: \n387:   // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n388:   // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n389:   // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n390:   // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n391:   // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n392:   // leases never carry it.\n393:   const storedSocketPath = leaseResult.socketPath;\n394:   const usableStoredSocketPath = typeof storedSocketPath === 'string'\n395:     && storedSocketPath.length > 0\n396:     && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n397:     ? storedSocketPath\n398:     : null;\n399:   const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n400:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n401:     writeLeaseHeld(' (no-bridge-socket)');\n402:     return { action: 'report', reason: 'no-bridge-socket', socketPath };\n403:   }\n404: \n405:   // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n406:   // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n407:   // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n408:   // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n409:   // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n410:   // does not regress that.\n411:   // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n412:   const probeAttempts = resolveLeaseProbeAttempts();\n413:   const probe = await probeLeaseHolderWithRetries(socketPath, {\n414:     firstTimeoutMs: probeTimeoutMs,\n415:     attempts: probeAttempts,\n416:     connect,\n417:     onRetry: (attempt, total, result) => process.stderr.write(\n418:       `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n419:     ),\n420:   });\n\n(Showing lines 1-420 of 451. Use offset=421 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction parseNonNegativeInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n}\n\n// A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n// daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n// consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n// its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n// the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\nfunction resolveLeaseProbeAttempts(env = process.env) {\n  return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n}\nfunction resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n  return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n}\nfunction resolveLeaseProbeRetryBackoffMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });\n\n  socket.once('error', (error) => {\n    options.onError?.(error);\n    closeOnce(0);\n  });\n\n  socket.once('close', () => {\n    closeOnce(0);\n  });\n\n  input.once('end', () => {\n    socket.end();\n  });\n  input.once('close', () => {\n    closeOnce(0);\n  });\n  output.once('error', () => {\n    closeOnce(0);\n  });\n\n  return socket;\n}\n\nfunction probeDaemon(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n  // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n  // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n  // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n  const deepProbe = options.deepProbe === true;\n  const id = nextProbeId++;\n  const request = `${JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    method: 'initialize',\n    params: {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'liveness-probe', version: '0' },\n    },\n  })}\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let buffer = '';\n    let timer;\n    // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n    // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n    const decoder = new StringDecoder('utf8');\n\n    const finish = (status, reason) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      if (!deepProbe) {\n        finish('alive', 'connect-ok');\n        return;\n      }\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const line = buffer.slice(0, newlineIndex).trim();\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (!line) continue;\n        try {\n          const parsed = JSON.parse(line);\n          if (\n            parsed &&\n            parsed.jsonrpc === '2.0' &&\n            parsed.id === id &&\n            (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n              Object.prototype.hasOwnProperty.call(parsed, 'error'))\n          ) {\n            finish('alive', 'json-rpc-reply');\n            return;\n          }\n        } catch {\n          // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n        }\n      }\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\nfunction parseHttpJsonResponse(buffer) {\n  const raw = buffer.toString('utf8');\n  const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n  if (headerEnd === -1) return null;\n  const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n  const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n  if (!statusMatch) return null;\n  const statusCode = Number.parseInt(statusMatch[1], 10);\n  const bodyRaw = raw.slice(headerEnd + 4).trim();\n  let body = null;\n  try {\n    body = bodyRaw ? JSON.parse(bodyRaw) : null;\n  } catch {\n    return { statusCode, body: null };\n  }\n  return { statusCode, body };\n}\n\nfunction probeModelServer(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n    ? options.loadingMaxMs\n    : parsePositiveInteger(\n      (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n      DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n    );\n  const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n  // without spawning a model server. Genuine embed consumers do not send this header, so their\n  // wake-on-demand path is unchanged.\n  const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let chunks = [];\n    let timer;\n\n    // Carry the parsed health body so callers (the idle-eviction tick) can read\n    // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n    const finish = (status, reason, health) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason, health });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n    });\n    socket.once('end', () => {\n      const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n      const state = parsed && parsed.body && typeof parsed.body === 'object'\n        ? parsed.body.state\n        : null;\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n        finish('alive', `health-${state}`, parsed.body);\n        return;\n      }\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n        const loadStartedAt = parsed.body.loadStartedAt;\n        const loadProgressAt = parsed.body.loadProgressAt;\n        // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n        const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n          ? loadProgressAt\n          : loadStartedAt;\n        if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n          finish('dead', 'loading-wedged');\n          return;\n        }\n        finish('alive', 'health-loading', parsed.body);\n        return;\n      }\n      finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\n// Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n// only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n// sleep are injectable so the retry decision is unit-testable without real sockets or timers.\nasync function probeLeaseHolderWithRetries(socketPath, options = {}) {\n  const {\n    probe = probeDaemon,\n    firstTimeoutMs,\n    retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n    retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n    attempts = resolveLeaseProbeAttempts(),\n    connect,\n    sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n    onRetry,\n  } = options;\n  const totalAttempts = Math.max(1, attempts);\n  let result = { status: 'dead', reason: 'no-probe-attempted' };\n  for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n    const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n    result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt < totalAttempts) {\n      if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n      await sleepFn(retryBackoffMs);\n    }\n  }\n  return result;\n}\n\nasync function maybeBridgeLeaseHolder(options) {\n  const {\n    serviceName,\n    leaseResult,\n    loggerPrefix,\n    dbDir,\n    legacyReport,\n    probeTimeoutMs,\n    connect,\n    bridge,\n  } = options;\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  const ownerPid = leaseResult.ownerPid;\n  const writeLeaseHeld = (suffix = '') => {\n    process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n  };\n\n  if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n    if (legacyReport) {\n      legacyReport(leaseResult);\n      return { action: 'report', reason: 'bridge-disabled' };\n    }\n    writeLeaseHeld();\n    return { action: 'report', reason: 'bridge-disabled' };\n  }\n\n  // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n  // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n  // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n  // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n  // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n  // leases never carry it.\n  const storedSocketPath = leaseResult.socketPath;\n  const usableStoredSocketPath = typeof storedSocketPath === 'string'\n    && storedSocketPath.length > 0\n    && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n    ? storedSocketPath\n    : null;\n  const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n  if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n    writeLeaseHeld(' (no-bridge-socket)');\n    return { action: 'report', reason: 'no-bridge-socket', socketPath };\n  }\n\n  // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n  // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n  // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n  // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n  // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n  // does not regress that.\n  // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n  const probeAttempts = resolveLeaseProbeAttempts();\n  const probe = await probeLeaseHolderWithRetries(socketPath, {\n    firstTimeoutMs: probeTimeoutMs,\n    attempts: probeAttempts,\n    connect,\n    onRetry: (attempt, total, result) => process.stderr.write(\n      `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n    ),\n  });","lineStart":1,"lineEnd":420,"totalLines":451,"truncated":true}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1781761533928,"end":1781761533934}},"metadata":{"openai":{"itemId":"fc_0cc555b152a783cd016a3385fdadd48191b17aa0e46415e45c"}},"id":"prt_ed943675f001rsqPkQfOJfDdEn","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed94330b3001IpObaMweHoFajZ"}}
{"type":"tool_use","timestamp":1781761533965,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"grep","callID":"call_GZMXVS3IqdJTk8kop51gUZZG","state":{"status":"completed","input":{"pattern":"function getIpcSocketPath|SPECKIT_IPC_SOCKET_DIR|tcp://|daemon-ipc.sock|probeLeaseHolder","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib","include":"*.cjs"},"output":"Found 32 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs:\n  Line 8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n\n  Line 80: function getIpcSocketPath(serviceName, options = {}) {\n\n  Line 81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n\n  Line 82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n\n  Line 84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n\n  Line 85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n\n  Line 91:   if (!socketPath.startsWith('tcp://')) {\n\n  Line 335: async function probeLeaseHolderWithRetries(socketPath, options = {}) {\n\n  Line 388:   // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n\n  Line 390:   // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n\n  Line 396:     && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n\n  Line 400:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n\n  Line 413:   const probe = await probeLeaseHolderWithRetries(socketPath, {\n\n  Line 445:   probeLeaseHolderWithRetries,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs:\n  Line 432:   if (raw.startsWith('tcp://')) return raw;\n\n  Line 435:     return `tcp://${url.hostname}:${url.port || (url.protocol === 'https:' ? '443' : '80')}`;\n\n  Line 444:   if (env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) return env.SPECKIT_IPC_SOCKET_DIR;\n\n  Line 447:   const socketDir = env.SPECKIT_IPC_SOCKET_DIR\n\n  Line 448:     ? path.resolve(env.SPECKIT_IPC_SOCKET_DIR)\n\n  Line 460:   if (socketPath.startsWith('tcp://')) return;\n\n  Line 467:     `hf-model-server socket path exceeds the conservative 104-byte sun_path limit (${byteLength} bytes): ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory.`,\n\n  Line 472:   if (socketPath.startsWith('tcp://')) return;\n\n  Line 485:       throw codedError('ESOCKETDIRSYMLINK', `Refusing to use symlinked SPECKIT_IPC_SOCKET_DIR for hf-model-server socket: ${socketDir}`);\n\n  Line 505:   const lockDirPath = socketPath.startsWith('tcp://')\n\n  Line 513:   const giveUpDirPath = socketPath.startsWith('tcp://')\n\n  Line 773:   // SPECKIT_IPC_SOCKET_DIR (e.g. worktree env). Optional + additive: leases without it fall back\n\n  Line 791:   if (socketPath.startsWith('tcp://')) return;\n\n  Line 1214:     if (socketPath.startsWith('tcp://')) {\n\n  Line 1220:     // Keep SPECKIT_IPC_SOCKET_DIR fail-closed: never mkdir/unlink through a symlinked or foreign-owned perimeter.\n\n  Line 1333:           if (error && error.code === 'EADDRINUSE' && !socketPath.startsWith('tcp://') && !reclaimedStaleSocket) {\n\n  Line 1367:         if (socketPath.startsWith('tcp://')) {\n\n  Line 1379:     if (!socketPath.startsWith('tcp://')) {\n","metadata":{"matches":32,"truncated":false},"title":"function getIpcSocketPath|SPECKIT_IPC_SOCKET_DIR|tcp://|daemon-ipc.sock|probeLeaseHolder","time":{"start":1781761533949,"end":1781761533963}},"metadata":{"openai":{"itemId":"fc_0cc555b152a783cd016a3385fdade88191819bcbb5c75bed8e"}},"id":"prt_ed94367f0001pxkFnwtKttTQ6J","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed94330b3001IpObaMweHoFajZ"}}
{"type":"tool_use","timestamp":1781761534063,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"grep","callID":"call_ERh0E1PBCzpcsDffuKCCEWNn","state":{"status":"completed","input":{"pattern":"SPECKIT_IPC_SOCKET_DIR.*tcp|tcp://.*SPECKIT_IPC_SOCKET_DIR|Set SPECKIT_IPC_SOCKET_DIR","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit","include":"*.{md,ts,js,cjs,json}"},"output":"Found 9 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/ENV_REFERENCE.md:\n  Line 180: | `SPECKIT_IPC_SOCKET_DIR` | database directory | string | Overrides the daemon IPC socket directory. **Required on macOS** for production runtimes: the default `<service-db>/daemon-ipc.sock` path exceeds the 104-char `sun_path` limit and `listen()` fails with `EINVAL`. Runtime configs (`.mcp.json`, `opencode.json`, `.codex/config.toml`) pin each service to a short `/tmp/<service>` directory. Also accepts `tcp://host:port`. Uses `daemon-ipc.sock` as the socket file name. The hf-model-server demand path additionally **fail-fasts** (031/005) with `ESUNPATHTOOLONG` if the resolved socket path exceeds 104 bytes, and refuses a symlinked or foreign-uid-owned socket directory (`ESOCKETDIRSYMLINK`/`ESOCKETDIRFOREIGN`/`ESOCKETSYMLINK`) before binding or reclaiming — perimeter hardening so a hostile/misconfigured dir cannot redirect the socket. | `.opencode/bin/lib/launcher-ipc-bridge.cjs`, `.opencode/bin/lib/model-server-supervision.cjs`, `mcp_server/lib/ipc/socket-server.ts` |\n\n  Line 472: | `HF_EMBED_SERVER_URL` | (unset → `<dbDir>/hf-embed.sock`) | string | Overrides the local HF model-server endpoint. Accepts a Unix socket path, `unix://<path>`, or `tcp://<host>:<port>`. Both launchers and the `hf-local` client resolve this first, then `SPECKIT_IPC_SOCKET_DIR`, then `<dbDir>/hf-embed.sock`. Leave unset so mk-spec-memory and skill-advisor share one resident server. | `bin/hf-model-server.cjs`, `shared/embeddings/providers/hf-local.ts` |\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge-probe.vitest.ts:\n  Line 124:     process.env.SPECKIT_IPC_SOCKET_DIR = 'tcp://127.0.0.1:65535';\n\n  Line 140:     process.env.SPECKIT_IPC_SOCKET_DIR = 'tcp://127.0.0.1:65535';\n\n  Line 252:     process.env.SPECKIT_IPC_SOCKET_DIR = 'tcp://127.0.0.1:65535';\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/embeddings/providers/hf-local.ts:\n  Line 312:   if (env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/embedders/hf-model-server.vitest.ts:\n  Line 154:     expect(serverModule.resolveListenTarget({ env: { SPECKIT_IPC_SOCKET_DIR: 'tcp://127.0.0.1:0' } })).toBe('tcp://127.0.0.1:0');\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/embedders/launcher-model-server-cross-launcher.vitest.ts:\n  Line 178:     expect(mss.resolveModelServerSocketPath({ HF_EMBED_SERVER_URL: 'http://127.0.0.1:31337', SPECKIT_IPC_SOCKET_DIR: '/tmp/ignored' }, { dbDir: systemSpecKitDbDir })).toBe('tcp://127.0.0.1:31337');\n\n  Line 179:     expect(mss.resolveModelServerSocketPath({ SPECKIT_IPC_SOCKET_DIR: 'tcp://127.0.0.1:41414' }, { dbDir: systemSpecKitDbDir })).toBe('tcp://127.0.0.1:41414');\n","metadata":{"matches":9,"truncated":false},"title":"SPECKIT_IPC_SOCKET_DIR.*tcp|tcp://.*SPECKIT_IPC_SOCKET_DIR|Set SPECKIT_IPC_SOCKET_DIR","time":{"start":1781761534010,"end":1781761534062}},"metadata":{"openai":{"itemId":"fc_0cc555b152a783cd016a3385fdadf081918d3d2910e8d9b00c"}},"id":"prt_ed943680c001iAXm9wpZ0R3tUT","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed94330b3001IpObaMweHoFajZ"}}
{"type":"tool_use","timestamp":1781761534088,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_KCbSQjchnQm9kXBr3tsol9n7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/ipc-socket-fresh-bind.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/ipc-socket-fresh-bind.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC socket fresh-bind symlink rejection\n3: // ───────────────────────────────────────────────────────────────\n4: // The EADDRINUSE reclaim branch fences a stale socket node via lstat\n5: // (canUnlinkExistingSocket). The FRESH-bind path — where no socket is\n6: // listening yet — needs the same protection: a symlink planted at the\n7: // bind path must be refused before listen()/chmod, so the later 0o600\n8: // chmod cannot be redirected onto an attacker-pointed target. These\n9: // tests drive the fresh-bind path (no pre-bound socket) and assert the\n10: // symlink is rejected up front, while a normal fresh bind still serves.\n11: \n12: import fs from 'node:fs';\n13: import net from 'node:net';\n14: import { mkdtempSync, rmSync } from 'node:fs';\n15: import { tmpdir } from 'node:os';\n16: import { join } from 'node:path';\n17: \n18: import { Server } from '@modelcontextprotocol/sdk/server/index.js';\n19: import { ListToolsRequestSchema } from '@modelcontextprotocol/sdk/types.js';\n20: import { afterEach, describe, expect, it } from 'vitest';\n21: \n22: import {\n23:   startIpcSocketServer,\n24:   type IpcSocketServerHandle,\n25: } from '../lib/ipc/socket-server.js';\n26: \n27: const tempDirs: string[] = [];\n28: const handles: IpcSocketServerHandle[] = [];\n29: const clients: net.Socket[] = [];\n30: \n31: function tempRoot(prefix: string): string {\n32:   // os.tmpdir() resolves inside an allowed socket root on every supported host.\n33:   const dir = mkdtempSync(join(tmpdir(), prefix));\n34:   tempDirs.push(dir);\n35:   return dir;\n36: }\n37: \n38: function makeServer(): Server {\n39:   const server = new Server(\n40:     { name: 'ipc-fresh-bind-test', version: '0.0.0' },\n41:     { capabilities: { tools: {} } },\n42:   );\n43:   server.setRequestHandler(ListToolsRequestSchema, async () => ({ tools: [] }));\n44:   return server;\n45: }\n46: \n47: async function connect(socketPath: string): Promise<net.Socket> {\n48:   const socket = net.createConnection({ path: socketPath });\n49:   clients.push(socket);\n50:   await new Promise<void>((resolve, reject) => {\n51:     socket.once('connect', resolve);\n52:     socket.once('error', reject);\n53:   });\n54:   return socket;\n55: }\n56: \n57: async function readLine(socket: net.Socket): Promise<string> {\n58:   return await new Promise<string>((resolve, reject) => {\n59:     let buffer = '';\n60:     const onData = (chunk: Buffer) => {\n61:       buffer += chunk.toString('utf8');\n62:       const index = buffer.indexOf('\\n');\n63:       if (index === -1) return;\n64:       socket.off('data', onData);\n65:       resolve(buffer.slice(0, index));\n66:     };\n67:     socket.on('data', onData);\n68:     socket.once('error', reject);\n69:   });\n70: }\n71: \n72: afterEach(async () => {\n73:   while (clients.length > 0) clients.pop()?.destroy();\n74:   while (handles.length > 0) await handles.pop()?.close();\n75:   while (tempDirs.length > 0) {\n76:     const dir = tempDirs.pop();\n77:     if (dir) rmSync(dir, { recursive: true, force: true });\n78:   }\n79: });\n80: \n81: describe('IPC socket fresh-bind symlink fence', () => {\n82:   it('refuses to bind when a symlink is planted at the socket path (no EADDRINUSE involved)', async () => {\n83:     const dir = tempRoot('sk-fresh-bind-symlink-');\n84:     const socketPath = join(dir, 'daemon-ipc.sock');\n85:     // A real file the symlink points at; if the fence were missing, the post-bind chmod could be\n86:     // redirected onto this target. Nothing is listening, so this exercises the FRESH-bind path, not\n87:     // the EADDRINUSE reclaim branch.\n88:     const decoyTarget = join(dir, 'decoy-target');\n89:     fs.writeFileSync(decoyTarget, 'do-not-chmod-me', 'utf8');\n90:     fs.symlinkSync(decoyTarget, socketPath);\n91: \n92:     await expect(\n93:       startIpcSocketServer({\n94:         socketPath,\n95:         createServer: makeServer,\n96:         log: () => undefined,\n97:       }),\n98:     ).rejects.toThrow(/symlink/i);\n99: \n100:     // The symlink node is left intact (the fence rejected before any unlink/listen), and the decoy\n101:     // target's permissions were never touched by a redirected chmod.\n102:     expect(fs.lstatSync(socketPath).isSymbolicLink()).toBe(true);\n103:   });\n104: \n105:   it('binds cleanly on the fresh path when no node exists and the survivor serves', async () => {\n106:     const dir = tempRoot('sk-fresh-bind-clean-');\n107:     const socketPath = join(dir, 'daemon-ipc.sock');\n108: \n109:     const handle = await startIpcSocketServer({\n110:       socketPath,\n111:       createServer: makeServer,\n112:       log: () => undefined,\n113:     });\n114:     handles.push(handle);\n115: \n116:     const client = await connect(socketPath);\n117:     client.write('{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\",\"params\":{}}\\n');\n118:     const response = await readLine(client);\n119:     expect(response).toContain('\"jsonrpc\":\"2.0\"');\n120:   });\n121: });\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC socket fresh-bind symlink rejection\n// ───────────────────────────────────────────────────────────────\n// The EADDRINUSE reclaim branch fences a stale socket node via lstat\n// (canUnlinkExistingSocket). The FRESH-bind path — where no socket is\n// listening yet — needs the same protection: a symlink planted at the\n// bind path must be refused before listen()/chmod, so the later 0o600\n// chmod cannot be redirected onto an attacker-pointed target. These\n// tests drive the fresh-bind path (no pre-bound socket) and assert the\n// symlink is rejected up front, while a normal fresh bind still serves.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport { mkdtempSync, rmSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\n\nimport { Server } from '@modelcontextprotocol/sdk/server/index.js';\nimport { ListToolsRequestSchema } from '@modelcontextprotocol/sdk/types.js';\nimport { afterEach, describe, expect, it } from 'vitest';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/ipc-socket-fresh-bind.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC socket fresh-bind symlink rejection\n// ───────────────────────────────────────────────────────────────\n// The EADDRINUSE reclaim branch fences a stale socket node via lstat\n// (canUnlinkExistingSocket). The FRESH-bind path — where no socket is\n// listening yet — needs the same protection: a symlink planted at the\n// bind path must be refused before listen()/chmod, so the later 0o600\n// chmod cannot be redirected onto an attacker-pointed target. These\n// tests drive the fresh-bind path (no pre-bound socket) and assert the\n// symlink is rejected up front, while a normal fresh bind still serves.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport { mkdtempSync, rmSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\n\nimport { Server } from '@modelcontextprotocol/sdk/server/index.js';\nimport { ListToolsRequestSchema } from '@modelcontextprotocol/sdk/types.js';\nimport { afterEach, describe, expect, it } from 'vitest';\n\nimport {\n  startIpcSocketServer,\n  type IpcSocketServerHandle,\n} from '../lib/ipc/socket-server.js';\n\nconst tempDirs: string[] = [];\nconst handles: IpcSocketServerHandle[] = [];\nconst clients: net.Socket[] = [];\n\nfunction tempRoot(prefix: string): string {\n  // os.tmpdir() resolves inside an allowed socket root on every supported host.\n  const dir = mkdtempSync(join(tmpdir(), prefix));\n  tempDirs.push(dir);\n  return dir;\n}\n\nfunction makeServer(): Server {\n  const server = new Server(\n    { name: 'ipc-fresh-bind-test', version: '0.0.0' },\n    { capabilities: { tools: {} } },\n  );\n  server.setRequestHandler(ListToolsRequestSchema, async () => ({ tools: [] }));\n  return server;\n}\n\nasync function connect(socketPath: string): Promise<net.Socket> {\n  const socket = net.createConnection({ path: socketPath });\n  clients.push(socket);\n  await new Promise<void>((resolve, reject) => {\n    socket.once('connect', resolve);\n    socket.once('error', reject);\n  });\n  return socket;\n}\n\nasync function readLine(socket: net.Socket): Promise<string> {\n  return await new Promise<string>((resolve, reject) => {\n    let buffer = '';\n    const onData = (chunk: Buffer) => {\n      buffer += chunk.toString('utf8');\n      const index = buffer.indexOf('\\n');\n      if (index === -1) return;\n      socket.off('data', onData);\n      resolve(buffer.slice(0, index));\n    };\n    socket.on('data', onData);\n    socket.once('error', reject);\n  });\n}\n\nafterEach(async () => {\n  while (clients.length > 0) clients.pop()?.destroy();\n  while (handles.length > 0) await handles.pop()?.close();\n  while (tempDirs.length > 0) {\n    const dir = tempDirs.pop();\n    if (dir) rmSync(dir, { recursive: true, force: true });\n  }\n});\n\ndescribe('IPC socket fresh-bind symlink fence', () => {\n  it('refuses to bind when a symlink is planted at the socket path (no EADDRINUSE involved)', async () => {\n    const dir = tempRoot('sk-fresh-bind-symlink-');\n    const socketPath = join(dir, 'daemon-ipc.sock');\n    // A real file the symlink points at; if the fence were missing, the post-bind chmod could be\n    // redirected onto this target. Nothing is listening, so this exercises the FRESH-bind path, not\n    // the EADDRINUSE reclaim branch.\n    const decoyTarget = join(dir, 'decoy-target');\n    fs.writeFileSync(decoyTarget, 'do-not-chmod-me', 'utf8');\n    fs.symlinkSync(decoyTarget, socketPath);\n\n    await expect(\n      startIpcSocketServer({\n        socketPath,\n        createServer: makeServer,\n        log: () => undefined,\n      }),\n    ).rejects.toThrow(/symlink/i);\n\n    // The symlink node is left intact (the fence rejected before any unlink/listen), and the decoy\n    // target's permissions were never touched by a redirected chmod.\n    expect(fs.lstatSync(socketPath).isSymbolicLink()).toBe(true);\n  });\n\n  it('binds cleanly on the fresh path when no node exists and the survivor serves', async () => {\n    const dir = tempRoot('sk-fresh-bind-clean-');\n    const socketPath = join(dir, 'daemon-ipc.sock');\n\n    const handle = await startIpcSocketServer({\n      socketPath,\n      createServer: makeServer,\n      log: () => undefined,\n    });\n    handles.push(handle);\n\n    const client = await connect(socketPath);\n    client.write('{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\",\"params\":{}}\\n');\n    const response = await readLine(client);\n    expect(response).toContain('\"jsonrpc\":\"2.0\"');\n  });\n});","lineStart":1,"lineEnd":121,"totalLines":121,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/ipc-socket-fresh-bind.vitest.ts","time":{"start":1781761534084,"end":1781761534088}},"metadata":{"openai":{"itemId":"fc_0cc555b152a783cd016a3385fdadf88191974783305febfa09"}},"id":"prt_ed9436877001mea6TVohTw6MPt","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed94330b3001IpObaMweHoFajZ"}}
{"type":"tool_use","timestamp":1781761534098,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_TSJICS4b8ZUU4S8ndU2hsqTC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/ipc-socket-resolve.vitest.ts","offset":1,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/ipc-socket-resolve.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC socket-dir resolution regression\n3: // ───────────────────────────────────────────────────────────────\n4: // resolveIpcSocketPath must canonicalize the socket dir even when it does not\n5: // exist yet. A /tmp socket dir cleared on reboot previously stayed literal\n6: // (/tmp/...) and failed the allowed-root check (which canonicalizes /tmp to\n7: // /private/tmp on macOS), crashing the server with MCP error -32000. The guard\n8: // must still reject directories outside the workspace root and system temp dirs.\n9: \n10: import { afterEach, beforeEach, describe, expect, it } from 'vitest';\n11: import { join } from 'node:path';\n12: \n13: import { resolveIpcSocketPath } from '../lib/ipc/socket-server.js';\n14: \n15: const ORIGINAL = process.env.SPECKIT_IPC_SOCKET_DIR;\n16: \n17: beforeEach(() => {\n18:   delete process.env.SPECKIT_IPC_SOCKET_DIR;\n19: });\n20: \n21: afterEach(() => {\n22:   if (ORIGINAL === undefined) {\n23:     delete process.env.SPECKIT_IPC_SOCKET_DIR;\n24:   } else {\n25:     process.env.SPECKIT_IPC_SOCKET_DIR = ORIGINAL;\n26:   }\n27: });\n28: \n29: describe('resolveIpcSocketPath canonicalization', () => {\n30:   it('resolves a non-existent /tmp socket dir without throwing (reboot-cleared dir)', () => {\n31:     const leaf = `mk-code-index-resolve-test-${process.pid}-${Date.now()}`;\n32:     const missingDir = join('/tmp', leaf);\n33:     process.env.SPECKIT_IPC_SOCKET_DIR = missingDir;\n34: \n35:     let socketPath = '';\n36:     expect(() => {\n37:       socketPath = resolveIpcSocketPath('/unused/db/dir');\n38:     }).not.toThrow();\n39:     // Returns <canonicalized missing dir>/<socket file>: keeps the unique leaf and appends a file.\n40:     expect(socketPath).toContain(leaf);\n41:     expect(socketPath.length).toBeGreaterThan(missingDir.length);\n42:   });\n43: \n44:   it('still rejects a non-existent dir outside the workspace and system temp dirs', () => {\n45:     process.env.SPECKIT_IPC_SOCKET_DIR = '/var/mk-code-index-out-of-root-xyz';\n46:     expect(() => resolveIpcSocketPath('/unused/db/dir')).toThrow(/must stay within/);\n47:   });\n48: });\n\n(End of file - total 48 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC socket-dir resolution regression\n// ───────────────────────────────────────────────────────────────\n// resolveIpcSocketPath must canonicalize the socket dir even when it does not\n// exist yet. A /tmp socket dir cleared on reboot previously stayed literal\n// (/tmp/...) and failed the allowed-root check (which canonicalizes /tmp to\n// /private/tmp on macOS), crashing the server with MCP error -32000. The guard\n// must still reject directories outside the workspace root and system temp dirs.\n\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\nimport { join } from 'node:path';\n\nimport { resolveIpcSocketPath } from '../lib/ipc/socket-server.js';\n\nconst ORIGINAL = process.env.SPECKIT_IPC_SOCKET_DIR;\n\nbeforeEach(() => {\n  delete process.env.SPECKIT_IPC_SOCKET_DIR;\n});\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/ipc-socket-resolve.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC socket-dir resolution regression\n// ───────────────────────────────────────────────────────────────\n// resolveIpcSocketPath must canonicalize the socket dir even when it does not\n// exist yet. A /tmp socket dir cleared on reboot previously stayed literal\n// (/tmp/...) and failed the allowed-root check (which canonicalizes /tmp to\n// /private/tmp on macOS), crashing the server with MCP error -32000. The guard\n// must still reject directories outside the workspace root and system temp dirs.\n\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\nimport { join } from 'node:path';\n\nimport { resolveIpcSocketPath } from '../lib/ipc/socket-server.js';\n\nconst ORIGINAL = process.env.SPECKIT_IPC_SOCKET_DIR;\n\nbeforeEach(() => {\n  delete process.env.SPECKIT_IPC_SOCKET_DIR;\n});\n\nafterEach(() => {\n  if (ORIGINAL === undefined) {\n    delete process.env.SPECKIT_IPC_SOCKET_DIR;\n  } else {\n    process.env.SPECKIT_IPC_SOCKET_DIR = ORIGINAL;\n  }\n});\n\ndescribe('resolveIpcSocketPath canonicalization', () => {\n  it('resolves a non-existent /tmp socket dir without throwing (reboot-cleared dir)', () => {\n    const leaf = `mk-code-index-resolve-test-${process.pid}-${Date.now()}`;\n    const missingDir = join('/tmp', leaf);\n    process.env.SPECKIT_IPC_SOCKET_DIR = missingDir;\n\n    let socketPath = '';\n    expect(() => {\n      socketPath = resolveIpcSocketPath('/unused/db/dir');\n    }).not.toThrow();\n    // Returns <canonicalized missing dir>/<socket file>: keeps the unique leaf and appends a file.\n    expect(socketPath).toContain(leaf);\n    expect(socketPath.length).toBeGreaterThan(missingDir.length);\n  });\n\n  it('still rejects a non-existent dir outside the workspace and system temp dirs', () => {\n    process.env.SPECKIT_IPC_SOCKET_DIR = '/var/mk-code-index-out-of-root-xyz';\n    expect(() => resolveIpcSocketPath('/unused/db/dir')).toThrow(/must stay within/);\n  });\n});","lineStart":1,"lineEnd":48,"totalLines":48,"truncated":false}},"title":".opencode/skills/system-code-graph/mcp_server/tests/ipc-socket-resolve.vitest.ts","time":{"start":1781761534095,"end":1781761534098}},"metadata":{"openai":{"itemId":"fc_0cc555b152a783cd016a3385fdae0081918356082a762a4dab"}},"id":"prt_ed9436885001EM1bJcanxxjHw1","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed94330b3001IpObaMweHoFajZ"}}
