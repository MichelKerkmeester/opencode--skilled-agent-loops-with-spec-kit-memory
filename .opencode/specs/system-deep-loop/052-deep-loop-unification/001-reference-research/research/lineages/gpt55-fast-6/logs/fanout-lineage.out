ath) {\n566:   const text = fs.readFileSync(filePath, 'utf8');\n567:   return text\n568:     .split(/\\r?\\n/)\n569:     .filter((line) => line.trim() !== '')\n570:     .map((line) => JSON.parse(line));\n571: }\n572: \n573: function lineageStateLogName(loopType) {\n574:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n575: }\n576: \n577: function readLineageStateRecords(loopType, lineageDir) {\n578:   const stateLogName = lineageStateLogName(loopType);\n579:   if (!stateLogName) {\n580:     return { statePath: null, records: [], missing: true, parseError: null };\n581:   }\n582:   const statePath = path.join(lineageDir, stateLogName);\n583:   if (!hasNonEmptyFile(statePath)) {\n584:     return { statePath, records: [], missing: true, parseError: null };\n585:   }\n586:   try {\n587:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n588:   } catch (error) {\n589:     return {\n590:       statePath,\n591:       records: [],\n592:       missing: false,\n593:       parseError: error instanceof Error ? error.message : String(error),\n594:     };\n595:   }\n596: }\n597: \n598: // A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n599: // spelling. The iteration-count check above already proves the lineage ran every iteration,\n600: // so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n601: // \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n602: // such as convergence, a manual stop, or an error.\n603: function isMaxIterationsStopReason(stopReason) {\n604:   if (typeof stopReason !== 'string') return false;\n605:   return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n606: }\n607: \n608: function findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n609:   if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n610:   if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n611:     return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n612:   }\n613: \n614:   if (!stateRead || stateRead.missing) {\n615:     return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n616:   }\n617:   if (stateRead.parseError) {\n618:     return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n619:   }\n620: \n621:   const records = stateRead.records;\n622:   const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n623:   const synthesis = [...records]\n624:     .reverse()\n625:     .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n626:   if (!synthesis) {\n627:     return 'missing synthesis_complete event for max-iterations stop-policy validation';\n628:   }\n629: \n630:   const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n631:     ? Number(synthesis.totalIterations)\n632:     : iterationCount;\n633:   if (totalIterations !== lineage.iterations) {\n634:     return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n635:   }\n636:   if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n637:     return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n638:   }\n639:   return null;\n640: }\n641: \n642: function isRecord(value) {\n643:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n644: }\n645: \n646: function normalizeStallWatchdogMs(rawConfig) {\n647:   // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n648:   // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n649:   // because this knob is intentionally outside fanoutConfigSchema. Set 0 to opt out.\n650:   return readRawConfigNumber(rawConfig, [\n651:     'stallWatchdogMs',\n652:     'stall_watchdog_ms',\n653:     'stallWatchdogMillis',\n654:     'stall_watchdog_millis',\n655:   ], 'stallWatchdogMs') ?? 300000;\n656: }\n657: \n658: function normalizeLineageBudgetGuards(rawConfig = {}) {\n659:   return {\n660:     max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n661:       'maxCostUnitsPerLineage',\n662:       'max_cost_units_per_lineage',\n663:       'maxLineageCostUnits',\n664:       'max_lineage_cost_units',\n665:       'maxTokensPerLineage',\n666:       'max_tokens_per_lineage',\n667:       'maxTokenBudget',\n668:       'max_token_budget',\n669:       'maxTokenBudgetPerLineage',\n670:       'max_token_budget_per_lineage',\n671:     ], 'maxCostUnitsPerLineage') ?? 0,\n672:     cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n673:       'costUnitsPerIteration',\n674:       'cost_units_per_iteration',\n675:       'estimatedTokensPerIteration',\n676:       'estimated_tokens_per_iteration',\n677:     ], 'costUnitsPerIteration', 1),\n678:   };\n679: }\n680: \n681: function computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n682:   const guards = normalizeLineageBudgetGuards(guardsInput);\n683:   const rawIterations = Number(lineage && lineage.iterations);\n684:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n685:   return {\n686:     ...guards,\n687:     iterations,\n688:     estimated_cost_units: iterations * guards.cost_units_per_iteration,\n689:   };\n690: }\n691: \n692: function evaluateLineageBudgetCap(input = {}) {\n693:   const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n694:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n695:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n696:   return {\n697:     continue_allowed: !exceeded,\n698:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n699:     upper_bound: upperBound,\n700:   };\n701: }\n702: \n703: function buildTimestampAnomalyCounts(check) {\n704:   return {\n705:     anomalous: check.anomalous,\n706:     untimestamped: check.untimestamped,\n707:     unparseable: check.unparseable,\n708:     total: check.total,\n709:   };\n710: }\n711: \n712: function buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n713:   return {\n714:     label: lineage.label,\n715:     state_log: statePath,\n716:     window: {\n717:       start_at_iso: check.windowStart,\n718:       end_at_iso: check.windowEnd,\n719:       tolerance_ms: check.toleranceMs,\n720:     },\n721:     counts: buildTimestampAnomalyCounts(check),\n722:     sample: check.sample,\n723:   };\n724: }\n725: \n726: function collectTimestampAnomalies(results) {\n727:   return results\n728:     .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n729:     .map((result) => result.output.timestamp_anomaly);\n730: }\n731: \n732: function normalizeNonNegativeDelayMs(value) {\n733:   if (value === undefined || value === null) return null;\n734:   const n = Number(value);\n735:   if (!Number.isFinite(n) || n < 0) return null;\n736:   return Math.floor(n);\n737: }\n738: \n739: function normalizeWaitDurationMs(value) {\n740:   return normalizeNonNegativeDelayMs(value) ?? 0;\n741: }\n742: \n743: function waitCheckpointPath(baseArtifactDir) {\n744:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n745: }\n746: \n747: function atomicWriteJson(filePath, payload) {\n748:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n749:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n750:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n751:   fs.renameSync(tmpPath, filePath);\n752: }\n753: \n754: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n755:   const durationMs = normalizeWaitDurationMs(waitMs);\n756:   const updatedAt = new Date(nowMs).toISOString();\n757:   if (durationMs <= 0) {\n758:     return {\n759:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n760:       status: 'idle',\n761:       nextRunAt: null,\n762:       remainingDelayMs: null,\n763:       updatedAt,\n764:       runId,\n765:       loopType,\n766:       specFolder,\n767:     };\n768:   }\n769: \n770:   return {\n771:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n772:     status: 'waiting',\n773:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n774:     remainingDelayMs: durationMs,\n775:     updatedAt,\n776:     runId,\n777:     loopType,\n778:     specFolder,\n779:   };\n\n(Showing lines 520-779 of 1871. Use offset=780 to continue.)\n</content>","metadata":{"preview":"}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {\n    child.kill(signal);\n  } catch {\n    // The process may have already exited.\n  }\n}\n\nfunction expectedLineageArtifactPaths(loopType, lineageDir) {\n  assertActiveFanoutLoopType(loopType);\n  if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n  return [path.join(lineageDir, 'research.md')];\n}\n\nfunction hasNonEmptyFile(filePath) {\n  try {\n    return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n  } catch {\n    return false;\n  }\n}\n\nfunction findMissingLineageArtifacts(loopType, lineageDir) {\n  return expectedLineageArtifactPaths(loopType, lineageDir)\n    .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n}\n\nfunction parseJsonlRecords(filePath) {\n  const text = fs.readFileSync(filePath, 'utf8');\n  return text\n    .split(/\\r?\\n/)\n    .filter((line) => line.trim() !== '')\n    .map((line) => JSON.parse(line));\n}\n\nfunction lineageStateLogName(loopType) {\n  return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n}\n\nfunction readLineageStateRecords(loopType, lineageDir) {\n  const stateLogName = lineageStateLogName(loopType);\n  if (!stateLogName) {\n    return { statePath: null, records: [], missing: true, parseError: null };\n  }\n  const statePath = path.join(lineageDir, stateLogName);\n  if (!hasNonEmptyFile(statePath)) {\n    return { statePath, records: [], missing: true, parseError: null };\n  }\n  try {\n    return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n  } catch (error) {\n    return {\n      statePath,\n      records: [],\n      missing: false,\n      parseError: error instanceof Error ? error.message : String(error),\n    };\n  }\n}\n\n// A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n// spelling. The iteration-count check above already proves the lineage ran every iteration,\n// so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n// \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n// such as convergence, a manual stop, or an error.\nfunction isMaxIterationsStopReason(stopReason) {\n  if (typeof stopReason !== 'string') return false;\n  return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n}\n\nfunction findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n  if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n  if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n    return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n  }\n\n  if (!stateRead || stateRead.missing) {\n    return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n  }\n  if (stateRead.parseError) {\n    return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n  }\n\n  const records = stateRead.records;\n  const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n  const synthesis = [...records]\n    .reverse()\n    .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n  if (!synthesis) {\n    return 'missing synthesis_complete event for max-iterations stop-policy validation';\n  }\n\n  const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n    ? Number(synthesis.totalIterations)\n    : iterationCount;\n  if (totalIterations !== lineage.iterations) {\n    return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n  }\n  if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n    return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n  }\n  return null;\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n  // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n  // because this knob is intentionally outside fanoutConfigSchema. Set 0 to opt out.\n  return readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs') ?? 300000;\n}\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? 0,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  return {\n    ...guards,\n    iterations,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction buildTimestampAnomalyCounts(check) {\n  return {\n    anomalous: check.anomalous,\n    untimestamped: check.untimestamped,\n    unparseable: check.unparseable,\n    total: check.total,\n  };\n}\n\nfunction buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n  return {\n    label: lineage.label,\n    state_log: statePath,\n    window: {\n      start_at_iso: check.windowStart,\n      end_at_iso: check.windowEnd,\n      tolerance_ms: check.toleranceMs,\n    },\n    counts: buildTimestampAnomalyCounts(check),\n    sample: check.sample,\n  };\n}\n\nfunction collectTimestampAnomalies(results) {\n  return results\n    .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n    .map((result) => result.output.timestamp_anomaly);\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };","lineStart":520,"lineEnd":779,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783487604733,"end":1783487604747}},"metadata":{"openai":{"itemId":"fc_0857107a0922c201016a4ddc74a3408191a16abcfaca7dd7a9"}},"id":"prt_f402527f8001iNZFyO7Y2vbTuI","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f40250329001N72jGfouTIm3kb"}}
