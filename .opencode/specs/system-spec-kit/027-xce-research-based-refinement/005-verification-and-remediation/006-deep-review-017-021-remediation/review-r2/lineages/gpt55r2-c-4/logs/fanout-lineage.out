emories virtual table (only if sqlite-vec is available)\n3142:   if (sqlite_vec_available) {\n3143:     const embedding_dim = get_embedding_dim();\n3144:     database.exec(`\n3145:       CREATE VIRTUAL TABLE vec_memories USING vec0(\n3146:         embedding FLOAT[${embedding_dim}]\n3147:       )\n3148:     `);\n3149:     database.exec(`\n3150:       CREATE TABLE IF NOT EXISTS vec_metadata (\n3151:         key TEXT PRIMARY KEY,\n3152:         value TEXT NOT NULL,\n3153:         created_at TEXT DEFAULT (datetime('now'))\n3154:       )\n3155:     `);\n3156:     database.prepare(`\n3157:       INSERT OR REPLACE INTO vec_metadata (key, value) VALUES ('embedding_dim', ?)\n3158:     `).run(String(embedding_dim));\n3159:     logger.info(`Created vec_memories table with dimension ${embedding_dim}`);\n3160:   }\n3161: \n3162:   // Create FTS5 virtual table (includes content_text for full-text search)\n3163:   database.exec(`\n3164:     CREATE VIRTUAL TABLE IF NOT EXISTS memory_fts USING fts5(\n3165:       title, trigger_phrases, file_path, content_text,\n3166:       content='memory_index', content_rowid='id'\n3167:     )\n3168:   `);\n3169: \n3170:   // Create FTS5 sync triggers (includes content_text)\n3171:   database.exec(`\n3172:     CREATE TRIGGER IF NOT EXISTS memory_fts_insert AFTER INSERT ON memory_index BEGIN\n3173:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n3174:       VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n3175:     END\n3176:   `);\n3177: \n3178:   database.exec(`\n3179:     CREATE TRIGGER IF NOT EXISTS memory_fts_update AFTER UPDATE ON memory_index BEGIN\n3180:       INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n3181:       VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n3182:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n3183:       VALUES (new.id,