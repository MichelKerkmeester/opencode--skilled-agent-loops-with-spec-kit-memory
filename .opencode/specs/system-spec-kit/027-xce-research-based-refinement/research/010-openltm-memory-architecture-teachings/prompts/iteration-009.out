ent)\n\n  Line 59:   INSERT INTO context_items_fts(context_items_fts, rowid, title, content)\n\n  Line 64:   INSERT INTO context_items_fts(context_items_fts, rowid, title, content)\n\n  Line 66:   INSERT INTO context_items_fts(rowid, title, content)\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/migrations/014_update_audit_op_check.sql:\n  Line 1: -- Migration 014: rebuild memory_audit with updated CHECK constraint to include 'archive' op.\n","metadata":{"matches":19,"truncated":false},"title":"schema_migrations|BEGIN IMMEDIATE|checksum|memories_fts|context_items_fts|rebuild|integrity-check","time":{"start":1780925692155,"end":1780925692163}},"metadata":{"openai":{"itemId":"fc_03456e79d32cfa5c016a26c4fba210819abdb3051da08efd49"}},"id":"prt_ea77178c90019zTqfwgnrFMGXy","sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","messageID":"msg_ea7714897001OjkRmEUOnqXZ7u"}}
