   130	    const stat = statSync(sourcePath);
   131	    if (!stat.isFile()) {
   132	      throw new Error('not a file');
   133	    }
   134	    hash.update(label);
   135	    hash.update('\u001f');
   136	    hash.update(sourcePath);
   137	    hash.update('\u001f');
   138	    hash.update(String(stat.mtimeMs));
   139	    hash.update('\u001f');
   140	    hash.update(String(stat.size));
   141	    hash.update('\u001f');
   142	    hash.update(createHash('sha256').update(readFileSync(sourcePath)).digest('hex'));
   143	    hash.update('\u001e');
   144	  } catch {
   145	    hash.update(label);
   146	    hash.update('\u001fmissing\u001e');
   147	  }
   148	}
   149	
   150	function advisorSourceSignature(workspaceRoot) {
   151	  const hash = createHash('sha256');
   152	  for (const sourcePath of ADVISOR_SOURCE_PATHS) {
   153	    addFileSignature(hash, `implementation:${sourcePath}`, sourcePath);
   154	  }
   155	
   156	  const skillRoot = join(workspaceRoot, SKILL_ROOT_RELATIVE_PATH);
   157	  try {
   158	    const skillSlugs = readdirSync(skillRoot, { withFileTypes: true })
   159	      .filter((entry) => entry.isDirectory() && !entry.name.startsWith('.'))
   160	      .map((entry) => entry.name)
   161	      .sort((left, right) => left.localeCompare(right));
   162	    for (const skillSlug of skillSlugs) {
   163	      const skillDir = join(skillRoot, skillSlug);
   164	      addFileSignature(hash, `skill:${skillSlug}:SKILL.md`, join(skillDir, 'SKILL.md'));
   165	      addFileSignature(hash, `skill:${skillSlug}:graph-metadata.json`, join(skillDir, 'graph-metadata.json'));
   166	    }
   167	  } catch {
   168	    hash.update(`${SKILL_ROOT_RELATIVE_PATH}\u001fmissing\u001e`);
   169	  }
   170	
   171	  for (const relativePath of ADVISOR_SCRIPT_RELATIVE_PATHS) {
   172	    addFileSignature(hash, relativePath, join(workspaceRoot, relativePath));
   173	  }
   174	  const dbDir = process.env.MK_SKILL_ADVISOR_DB_DIR
   175	    ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR
   176	    ?? join(workspaceRoot, ADVISOR_ROOT_RELATIVE_PATH, 'database');
   177	  addFileSignature(hash, 'skill-graph.sqlite', join(dbDir, 'skill-graph.sqlite'));
   178	  addFileSignature(hash, ADVISOR_JSON_RELATIVE_PATH, join(workspaceRoot, ADVISOR_JSON_RELATIVE_PATH));
   179	  return hash.digest('hex');
   180	}
