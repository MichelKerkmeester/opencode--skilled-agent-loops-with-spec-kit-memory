     1	// ╔══════════════════════════════════════════════════════════════════════════╗
     2	// ║ Review Research Paths                                                    ║
     3	// ╚══════════════════════════════════════════════════════════════════════════╝
     4	
     5	'use strict';
     6	
     7	// ─────────────────────────────────────────────────────────────────────────────
     8	// 1. IMPORTS
     9	// ─────────────────────────────────────────────────────────────────────────────
    10	
    11	const fs = require('node:fs');
    12	const path = require('node:path');
    13	
    14	const MODE_CONFIG_FILE = {
    15	  research: 'deep-research-config.json',
    16	  review: 'deep-review-config.json',
    17	};
    18	
    19	const MODE_STATE_FILE = {
    20	  research: 'deep-research-state.jsonl',
    21	  review: 'deep-review-state.jsonl',
    22	};
    23	
    24	// ─────────────────────────────────────────────────────────────────────────────
    25	// 2. CORE LOGIC
    26	// ─────────────────────────────────────────────────────────────────────────────
    27	
    28	/**
    29	 * Allocate the next artifact subfolder name under an artifact root directory
    30	 * using the {phaseSlug}-pt-{NN} naming convention.
    31	 *
    32	 * The phase slug is the FULL first-segment folder name under the spec tree
    33	 * root (e.g. "019-system-hardening").  NN is a two-digit zero-padded counter:
    34	 * 1 + the number of existing pt-folders whose slug prefix matches the requested
    35	 * phase, so repeated calls produce sequential names without any stored counter.
    36	 *
    37	 * @param {string} rootDir   - Absolute path to the artifact root (research/ or review/)
    38	 * @param {string} phaseSlug - Full phase folder name (e.g. "019-system-hardening")
    39	 * @returns {string} Subfolder name, e.g. "019-system-hardening-pt-03"
    40	 */
    41	function allocateShortSubfolder(rootDir, phaseSlug) {
    42	  let existingCount = 0;
    43	
    44	  if (fs.existsSync(rootDir)) {
    45	    const prefix = `${phaseSlug}-pt-`;
    46	    existingCount = fs.readdirSync(rootDir).filter(
    47	      (entry) => entry.startsWith(prefix),
    48	    ).length;
    49	  }
    50	
    51	  const nn = String(existingCount + 1).padStart(2, '0');
    52	  return `${phaseSlug}-pt-${nn}`;
    53	}
    54	
    55	function normalizeSpecFolderReference(specFolder) {
    56	  if (!specFolder) {
    57	    return null;
    58	  }
    59	
    60	  const normalized = String(specFolder)
    61	    .trim()
    62	    .replace(/\\/g, '/')
    63	    .replace(/\/+$/g, '');
    64	
    65	  if (!normalized) {
    66	    return null;
    67	  }
    68	
    69	  const opencodeSpecsMarker = '/.opencode/specs/';
    70	  const specsMarker = '/specs/';
    71	  const opencodeIndex = normalized.lastIndexOf(opencodeSpecsMarker);
    72	  if (opencodeIndex !== -1) {
    73	    return normalized.slice(opencodeIndex + opencodeSpecsMarker.length);
    74	  }
    75	
    76	  const specsIndex = normalized.lastIndexOf(specsMarker);
    77	  if (specsIndex !== -1) {
    78	    return normalized.slice(specsIndex + specsMarker.length);
    79	  }
    80	
    81	  return normalized
    82	    .replace(/^\.\/+/, '')
    83	    .replace(/^\.opencode\/specs\//, '')
    84	    .replace(/^specs\//, '');
    85	}
    86	
    87	function findAncestorSpecFolder(specFolder) {
    88	  let current = path.resolve(specFolder);
    89	
    90	  while (true) {
    91	    const parent = path.dirname(current);
    92	
    93	    if (parent === current || path.basename(parent) === 'specs') {
    94	      return null;
    95	    }
    96	
    97	    if (fs.existsSync(path.join(parent, 'spec.md'))) {
    98	      return parent;
    99	    }
   100	
   101	    current = parent;
   102	  }
   103	}
   104	
   105	function readPacketSpecFolder(packetDir, mode) {
   106	  const configPath = path.join(packetDir, MODE_CONFIG_FILE[mode]);
   107	  if (fs.existsSync(configPath)) {
   108	    try {
   109	      const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));
   110	      return normalizeSpecFolderReference(config.specFolder);
   111	    } catch (_error) {
   112	      // Fall through to state log probing.
   113	    }
   114	  }
   115	
   116	  const stateLogPath = path.join(packetDir, MODE_STATE_FILE[mode]);
   117	  if (!fs.existsSync(stateLogPath)) {
   118	    return null;
   119	  }
   120	
   121	  try {
   122	    const lines = fs.readFileSync(stateLogPath, 'utf8').split(/\r?\n/);
   123	    for (const line of lines) {
   124	      if (!line.trim()) {
   125	        continue;
   126	      }
   127	      const parsed = JSON.parse(line);
   128	      return normalizeSpecFolderReference(parsed.specFolder);
   129	    }
   130	  } catch (_error) {
   131	    return null;
   132	  }
   133	
   134	  return null;
   135	}
   136	
   137	function listPacketDirectories(rootDir) {
   138	  if (!fs.existsSync(rootDir)) {
   139	    return [];
   140	  }
   141	
   142	  return fs.readdirSync(rootDir, { withFileTypes: true })
   143	    .filter((entry) => entry.isDirectory() && /-pt-\d+$/.test(entry.name))
   144	    .map((entry) => entry.name)
   145	    .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }));
   146	}
   147	
   148	function findExistingPacket(rootDir, specFolder, mode) {
   149	  const targetSpecFolder = normalizeSpecFolderReference(specFolder);
   150	
   151	  if (!targetSpecFolder) {
   152	    return null;
   153	  }
   154	
   155	  const matches = [];
   156	  for (const packetName of listPacketDirectories(rootDir)) {
   157	    const packetDir = path.join(rootDir, packetName);
   158	    if (readPacketSpecFolder(packetDir, mode) === targetSpecFolder) {
   159	      matches.push(packetName);
   160	    }
   161	  }
   162	
   163	  return matches.at(-1) || null;
   164	}
   165	
   166	/**
   167	 * Resolve the canonical artifact directory for review or research output.
   168	 *
   169	 * Conventions (post-028 contract fix):
   170	 *   - Root specs ALWAYS use flat: {spec_folder}/{mode}/
   171	 *   - Child phases use FLAT-FIRST:
   172	 *       (a) First run with empty {mode}/ directory → flat (subfolder=null)
   173	 *       (b) Continuation when flat artifact's config matches current target → reuse flat
   174	 *       (c) Existing pt-NN packet matches current target → reuse pt-NN
   175	 *       (d) Prior content exists for non-matching target → allocate pt-NN
   176	 *
   177	 * Subfolder naming convention (when pt-NN allocation kicks in): {phaseSlug}-pt-{NN}
   178	 *   - phaseSlug: the FULL immediate child phase segment under the spec tree
   179	 *     root (e.g. "019-system-hardening")
   180	 *   - NN: sequential two-digit counter scoped to that phase within the
   181	 *     artifact root directory; allocated by counting existing same-prefix
   182	 *     entries at call time
   183	 *
   184	 * Example:
   185	 *   - root spec run → {spec_folder}/research/
   186	 *   - child phase first run → {spec_folder}/research/   (flat, no pt-NN wrapper)
   187	 *   - child phase second run with prior content for different target → {spec_folder}/research/{phaseSlug}-pt-NN/
   188	 *   - child phase same-target continuation → reuses prior flat or pt-NN
   189	 *
   190	 * @param {string} specFolder - Absolute or relative path to the target spec folder
   191	 * @param {'review'|'research'} [mode='review'] - Which artifact type to resolve
   192	 *
   193	 * @returns {{
   194	 *   rootDir: string,
   195	 *   subfolder: string|null,
   196	 *   artifactDir: string,
   197	 *   artifactArchiveRoot: string
   198	 * }} Resolved packet root plus canonical packet/archive directories
   199	 */
   200	function resolveArtifactRoot(specFolder, mode = 'review') {
   201	  const resolved = path.resolve(specFolder);
   202	  const rootDir = path.join(resolved, mode);
   203	  const artifactArchiveRoot = path.join(resolved, `${mode}_archive`);
   204	  const ancestorSpecFolder = findAncestorSpecFolder(resolved);
   205	
   206	  // ROOT spec: always flat
   207	  if (!ancestorSpecFolder) {
   208	    return {
   209	      rootDir,
   210	      subfolder: null,
   211	      artifactDir: rootDir,
   212	      artifactArchiveRoot,
   213	    };
   214	  }
   215	
   216	  // CHILD phase: prefer existing pt-NN packet for current target if any
   217	  const existingPacket = findExistingPacket(rootDir, resolved, mode);
   218	  if (existingPacket) {
   219	    return {
   220	      rootDir,
   221	      subfolder: existingPacket,
   222	      artifactDir: path.join(rootDir, existingPacket),
   223	      artifactArchiveRoot: path.join(artifactArchiveRoot, existingPacket),
   224	    };
   225	  }
   226	
   227	  // CHILD phase: check for flat artifact at rootDir
   228	  const targetSpecFolder = normalizeSpecFolderReference(resolved);
   229	  const flatConfigPath = path.join(rootDir, MODE_CONFIG_FILE[mode]);
   230	  const flatStateLogPath = path.join(rootDir, MODE_STATE_FILE[mode]);
   231	  const hasFlatArtifact = fs.existsSync(flatConfigPath) || fs.existsSync(flatStateLogPath);
   232	
   233	  if (hasFlatArtifact) {
   234	    const flatSpecFolder = readPacketSpecFolder(rootDir, mode);
   235	    if (flatSpecFolder === null || flatSpecFolder === targetSpecFolder) {
   236	      // Flat artifact matches current target (or its config is unreadable but rootDir is owned by this target's path) → reuse flat
   237	      return {
   238	        rootDir,
   239	        subfolder: null,
   240	        artifactDir: rootDir,
   241	        artifactArchiveRoot,
   242	      };
   243	    }
   244	    // Flat artifact is for a different target — fall through to allocate pt-NN
   245	  }
   246	
   247	  const ptFolders = listPacketDirectories(rootDir);
   248	  const hasPtFolders = ptFolders.length > 0;
   249	
   250	  // CHILD phase first run: empty rootDir → flat
   251	  if (!hasFlatArtifact && !hasPtFolders) {
   252	    return {
   253	      rootDir,
   254	      subfolder: null,
   255	      artifactDir: rootDir,
   256	      artifactArchiveRoot,
   257	    };
   258	  }
   259	
   260	  // CHILD phase: prior content exists (flat for different target, or pt-NN folders)
   261	  // and no matching packet for current target → allocate next pt-NN
   262	  const subfolder = allocateShortSubfolder(rootDir, path.basename(resolved));
   263	  return {
   264	    rootDir,
   265	    subfolder,
   266	    artifactDir: path.join(rootDir, subfolder),
   267	    artifactArchiveRoot: path.join(artifactArchiveRoot, subfolder),
   268	  };
   269	}
   270	
   271	module.exports = {
   272	  resolveArtifactRoot,
   273	  allocateShortSubfolder,
   274	  normalizeSpecFolderReference,
   275	};
