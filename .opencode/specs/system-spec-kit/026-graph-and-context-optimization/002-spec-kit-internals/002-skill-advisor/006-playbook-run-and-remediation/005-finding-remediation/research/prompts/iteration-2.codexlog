+{"type":"remediation","id":"F2-R2","summary":"Gate fix: align the Python warm default with the documented 50 ms envelope and stop treating one-shot subprocess cold p95 as a 60 ms native-scorer gate; either make cold_p95 advisory/opt-in or raise it to a workstation-calibrated subprocess budget while keeping throughput_multiplier as the main Python-surface regression gate.","targetFiles":[".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py",".opencode/skills/system-skill-advisor/mcp_server/stress_test/skill-advisor/python-bench-runner-stress.vitest.ts",".opencode/skills/system-skill-advisor/feature_catalog/08--python-compat/03-bench-runner.md"],"evidence":[".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:246",".opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor_bench.py:247",".opencode/skills/system-skill-advisor/mcp_server/stress_test/skill-advisor/python-bench-runner-stress.vitest.ts:93",".opencode/skills/system-skill-advisor/mcp_server/stress_test/skill-advisor/python-bench-runner-stress.vitest.ts:97",".opencode/skills/system-skill-advisor/feature_catalog/08--python-compat/03-bench-runner.md:21"]}

