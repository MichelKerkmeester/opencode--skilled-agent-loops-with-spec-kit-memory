806:     async def memory_bulk_find_by_content_hashes(\n807:         self,\n808:         tenant_id: str,\n809:         hashes: list[str],\n810:         fleet_id: str | None = None,\n811:         agent_id: str | None = None,\n812:     ) -> dict[str, dict]:\n813:         \"\"\"Map ``content_hash → {id, client_request_id}`` for existing rows.\n814: \n815:         ``client_request_id`` is included so the upstream bulk-write\n816:         path can distinguish the two duplicate states (CAURA-602):\n817:         a content match whose stored ``client_request_id`` equals the\n818:         current request's per-item id is the caller's *own* retry\n819:         (``duplicate_attempt``); any other match is a different\n820:         attempt's content (``duplicate_content``). NULL on legacy rows\n821:         written before the column existed.\n822: \n823:         ``agent_id`` scopes the dedup lookup so cross-agent writes of\n824:         identical content no longer collide (Stage 5 / friction §2.8).\n825:         \"\"\"\n826:         async with get_session() as session:\n827:             stmt = select(Memory.content_hash, Memory.id, Memory.client_request_id).where(\n828:                 Memory.tenant_id == tenant_id,\n829:                 Memory.content_hash.in_(hashes),\n830:                 Memory.deleted_at.is_(None),\n831:             )\n832:             if fleet_id:\n833:                 stmt = stmt.where(Memory.fleet_id == fleet_id)\n834:             else:\n835:                 stmt = stmt.where(Memory.fleet_id.is_(None))\n836:             if agent_id is not None:\n837:                 stmt = stmt.where(Memory.agent_id == agent_id)\n838:             rows = (await session.execute(stmt)).all()\n839:             return {row[0]: {\"id\": row[1], \"client_request_id\": row[2]} for row in rows}\n840: \n841:     # ------------------------------------------------------------------\n842:     # C) Scored search (CTE-based)\n843:     # ------------------------------------------------------------------\n844: \n845:     async def memory_scored_search(\n846:         self,\n847:         tenant_id: str,\n848:         embedding: list[float],\n849:         query: str,\n850:         *,\n851:         fleet_ids: list[str] | None = None,\n852:         caller_agent_id: str | None = None,\n853:         filter_agent_id: str | None = None,\n854:         memory_type_filter: str | None = None,\n855:         status_filter: str | None = None,\n856:         valid_at: datetime | None = None,\n857:         boosted_memory_ids: set[UUID] | None = None,\n858:         memory_boost_factor: dict[UUID, float] | None = None,\n859:         search_params: dict,\n860:         temporal_window: timedelta | None = None,\n861:         recall_boost_enabled: bool = True,\n862:         top_k: int = 10,\n863:         date_range_start: str | None = None,\n864:         date_range_end: str | None = None,\n865:         readable_tenant_ids: list[str] | None = None,\n866:     ) -> list[SimpleNamespace]:\n867:         \"\"\"Execute the full CTE-based scored search with entity-link JOIN.\n868: \n869:         Returns a list of SimpleNamespace objects with attributes:\n870:         Memory, score, similarity, vec_sim, entity_links.\n871:         \"\"\"\n872:         boosted_memory_ids = boosted_memory_ids or set()\n873:         memory_boost_factor = memory_boost_factor or {}\n874:         sp = search_params\n875: \n876:         _fts_weight = sp[\"fts_weight\"]\n877:         _freshness_floor = sp[\"freshness_floor\"]\n878:         _freshness_decay_days = sp[\"freshness_decay_days\"]\n879:         _recall_boost_cap = sp[\"recall_boost_cap\"]\n880:         _recall_decay_window_days = sp[\"recall_decay_window_days\"]\n881:         _similarity_blend = sp[\"similarity_blend\"]\n882:         _top_k = sp.get(\"top_k\", top_k)\n883: \n884:         # -- Scoring expressions --\n885:         # CAURA-594: pgvector's `<=>` is strict — NULL in → NULL out. A\n886:         # bare `1 - cosine_distance` would therefore propagate NULL up\n887:         # through the similarity blend into `score`, and PostgreSQL's\n888:         # default `ORDER BY score DESC` sorts NULLS FIRST — putting\n889:         # every unembedded row at the TOP of results. The CASE forces\n890:         # a numeric value (0.0) and also short-circuits so\n891:         # cosine_distance isn't even evaluated for NULL rows.\n892:         # `has_embedding` below is the authoritative NULL-vs-orthogonal\n893:         # signal for callers — `vec_sim == 0.0` is ambiguous with a\n894:         # genuinely orthogonal embedding.\n895:         vec_sim = case(\n896:             (\n897:                 Memory.embedding.is_not(None),\n898:                 1.0 - Memory.embedding.cosine_distance(embedding),\n899:             ),\n900:             else_=0.0,\n901:         ).label(\"vec_sim\")\n902:         has_embedding = Memory.embedding.is_not(None).label(\"has_embedding\")\n903: \n904:         ts_query = func.plainto_tsquery(\"english\", query)\n905:         raw_fts = func.ts_rank_cd(Memory.search_vector, ts_query)\n906:         fts_score = (raw_fts / (1.0 + raw_fts)).label(\"fts_score\")\n907: \n908:         # CAURA-679: NULL-embedding rows fall back to `fts_score` alone\n909:         # rather than the `(1 - w) * 0 + w * fts_score` haircut that\n910:         # the unconditional blend would apply. The haircut multiplies\n911:         # the FTS signal by `fts_weight` (≤1), so an FTS-matching but\n912:         # unembedded row could rank below noise-floor-cosine embedded\n913:         # rows (vec_sim ~0.15-0.20 from high-dim sphere clustering),\n914:         # which then drop it past the `LIMIT top_k * overfetch_factor`\n915:         # cutoff. This protects the FTS-fallback contract for both the\n916:         # CAURA-594 deferred-embed window and any case where the embed\n917:         # worker fails permanently — the row stays discoverable rather\n918:         # than silently undiscoverable.\n919:         similarity = case(\n\n(Showing lines 780-919 of 4754. Use offset=920 to continue.)\n</content>","metadata":{"preview":"            )\n            result = await session.execute(stmt)\n            return list(result.scalars().all())\n\n    async def dedup_review_decide(\n        self, review_id: UUID, status: str, decided_by: str | None = None\n    ) -> DedupReview | None:\n        \"\"\"Transition a review from ``pending`` to one of the terminal\n        statuses (``confirmed_duplicate`` / ``override_not_duplicate``\n        / ``dismissed``). Returns the updated row, or None if the row\n        doesn't exist. Raises ``ValueError`` for unknown statuses.\"\"\"\n        from common.models.dedup_review import DEDUP_REVIEW_STATUSES\n\n        if status not in DEDUP_REVIEW_STATUSES or status == \"pending\":\n            raise ValueError(f\"invalid terminal status: {status!r}\")\n\n        async with get_session() as session:\n            row = await session.get(DedupReview, review_id)\n            if row is None:\n                return None","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"            )\n            result = await session.execute(stmt)\n            return list(result.scalars().all())\n\n    async def dedup_review_decide(\n        self, review_id: UUID, status: str, decided_by: str | None = None\n    ) -> DedupReview | None:\n        \"\"\"Transition a review from ``pending`` to one of the terminal\n        statuses (``confirmed_duplicate`` / ``override_not_duplicate``\n        / ``dismissed``). Returns the updated row, or None if the row\n        doesn't exist. Raises ``ValueError`` for unknown statuses.\"\"\"\n        from common.models.dedup_review import DEDUP_REVIEW_STATUSES\n\n        if status not in DEDUP_REVIEW_STATUSES or status == \"pending\":\n            raise ValueError(f\"invalid terminal status: {status!r}\")\n\n        async with get_session() as session:\n            row = await session.get(DedupReview, review_id)\n            if row is None:\n                return None\n            row.status = status\n            row.decided_by = decided_by\n            row.decided_at = datetime.now(UTC)\n            await session.flush()\n            return row\n\n    async def memory_bulk_find_by_content_hashes(\n        self,\n        tenant_id: str,\n        hashes: list[str],\n        fleet_id: str | None = None,\n        agent_id: str | None = None,\n    ) -> dict[str, dict]:\n        \"\"\"Map ``content_hash → {id, client_request_id}`` for existing rows.\n\n        ``client_request_id`` is included so the upstream bulk-write\n        path can distinguish the two duplicate states (CAURA-602):\n        a content match whose stored ``client_request_id`` equals the\n        current request's per-item id is the caller's *own* retry\n        (``duplicate_attempt``); any other match is a different\n        attempt's content (``duplicate_content``). NULL on legacy rows\n        written before the column existed.\n\n        ``agent_id`` scopes the dedup lookup so cross-agent writes of\n        identical content no longer collide (Stage 5 / friction §2.8).\n        \"\"\"\n        async with get_session() as session:\n            stmt = select(Memory.content_hash, Memory.id, Memory.client_request_id).where(\n                Memory.tenant_id == tenant_id,\n                Memory.content_hash.in_(hashes),\n                Memory.deleted_at.is_(None),\n            )\n            if fleet_id:\n                stmt = stmt.where(Memory.fleet_id == fleet_id)\n            else:\n                stmt = stmt.where(Memory.fleet_id.is_(None))\n            if agent_id is not None:\n                stmt = stmt.where(Memory.agent_id == agent_id)\n            rows = (await session.execute(stmt)).all()\n            return {row[0]: {\"id\": row[1], \"client_request_id\": row[2]} for row in rows}\n\n    # ------------------------------------------------------------------\n    # C) Scored search (CTE-based)\n    # ------------------------------------------------------------------\n\n    async def memory_scored_search(\n        self,\n        tenant_id: str,\n        embedding: list[float],\n        query: str,\n        *,\n        fleet_ids: list[str] | None = None,\n        caller_agent_id: str | None = None,\n        filter_agent_id: str | None = None,\n        memory_type_filter: str | None = None,\n        status_filter: str | None = None,\n        valid_at: datetime | None = None,\n        boosted_memory_ids: set[UUID] | None = None,\n        memory_boost_factor: dict[UUID, float] | None = None,\n        search_params: dict,\n        temporal_window: timedelta | None = None,\n        recall_boost_enabled: bool = True,\n        top_k: int = 10,\n        date_range_start: str | None = None,\n        date_range_end: str | None = None,\n        readable_tenant_ids: list[str] | None = None,\n    ) -> list[SimpleNamespace]:\n        \"\"\"Execute the full CTE-based scored search with entity-link JOIN.\n\n        Returns a list of SimpleNamespace objects with attributes:\n        Memory, score, similarity, vec_sim, entity_links.\n        \"\"\"\n        boosted_memory_ids = boosted_memory_ids or set()\n        memory_boost_factor = memory_boost_factor or {}\n        sp = search_params\n\n        _fts_weight = sp[\"fts_weight\"]\n        _freshness_floor = sp[\"freshness_floor\"]\n        _freshness_decay_days = sp[\"freshness_decay_days\"]\n        _recall_boost_cap = sp[\"recall_boost_cap\"]\n        _recall_decay_window_days = sp[\"recall_decay_window_days\"]\n        _similarity_blend = sp[\"similarity_blend\"]\n        _top_k = sp.get(\"top_k\", top_k)\n\n        # -- Scoring expressions --\n        # CAURA-594: pgvector's `<=>` is strict — NULL in → NULL out. A\n        # bare `1 - cosine_distance` would therefore propagate NULL up\n        # through the similarity blend into `score`, and PostgreSQL's\n        # default `ORDER BY score DESC` sorts NULLS FIRST — putting\n        # every unembedded row at the TOP of results. The CASE forces\n        # a numeric value (0.0) and also short-circuits so\n        # cosine_distance isn't even evaluated for NULL rows.\n        # `has_embedding` below is the authoritative NULL-vs-orthogonal\n        # signal for callers — `vec_sim == 0.0` is ambiguous with a\n        # genuinely orthogonal embedding.\n        vec_sim = case(\n            (\n                Memory.embedding.is_not(None),\n                1.0 - Memory.embedding.cosine_distance(embedding),\n            ),\n            else_=0.0,\n        ).label(\"vec_sim\")\n        has_embedding = Memory.embedding.is_not(None).label(\"has_embedding\")\n\n        ts_query = func.plainto_tsquery(\"english\", query)\n        raw_fts = func.ts_rank_cd(Memory.search_vector, ts_query)\n        fts_score = (raw_fts / (1.0 + raw_fts)).label(\"fts_score\")\n\n        # CAURA-679: NULL-embedding rows fall back to `fts_score` alone\n        # rather than the `(1 - w) * 0 + w * fts_score` haircut that\n        # the unconditional blend would apply. The haircut multiplies\n        # the FTS signal by `fts_weight` (≤1), so an FTS-matching but\n        # unembedded row could rank below noise-floor-cosine embedded\n        # rows (vec_sim ~0.15-0.20 from high-dim sphere clustering),\n        # which then drop it past the `LIMIT top_k * overfetch_factor`\n        # cutoff. This protects the FTS-fallback contract for both the\n        # CAURA-594 deferred-embed window and any case where the embed\n        # worker fails permanently — the row stays discoverable rather\n        # than silently undiscoverable.\n        similarity = case(","lineStart":780,"lineEnd":919,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780729347848,"end":1780729347868}},"metadata":{"openai":{"itemId":"fc_06253be963551f1e016a23c603c2f881919dc8e94e77f81f27"}},"id":"prt_e9bbd7f05001FpvbA4oM8WBNMd","sessionID":"ses_164436571ffe8MyT3INeMfMzFK","messageID":"msg_e9bbd54e1001VqmkJBcmip4MhM"}}
{"type":"tool_use","timestamp":1780729347877,"sessionID":"ses_164436571ffe8MyT3INeMfMzFK","part":{"type":"tool","tool":"read","callID":"call_V5HCPyESkrKX7RnWPAFrejw4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","offset":4540,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py</path>\n<type>file</type>\n<content>\n4540:         \"\"\"Return the stored idempotency row if live, else None.\n4541: \n4542:         Expired rows are treated as absent so callers transparently\n4543:         re-run the request after TTL. A separate cleanup job prunes\n4544:         them from storage.\n4545:         \"\"\"\n4546:         async with get_session() as session:\n4547:             stmt = select(IdempotencyResponse).where(\n4548:                 IdempotencyResponse.tenant_id == tenant_id,\n4549:                 IdempotencyResponse.idempotency_key == idempotency_key,\n4550:                 # Match ``func.now()`` used by ``idempotency_claim``'s\n4551:                 # ON CONFLICT WHERE so the two paths agree on what\n4552:                 # \"expired\" means even when the app and DB clocks drift.\n4553:                 IdempotencyResponse.expires_at > func.now(),\n4554:             )\n4555:             result = await session.execute(stmt)\n4556:             return result.scalar_one_or_none()\n4557: \n4558:     async def idempotency_claim(\n4559:         self,\n4560:         *,\n4561:         tenant_id: str,\n4562:         idempotency_key: str,\n4563:         request_hash: str,\n4564:         expires_at: datetime,\n4565:     ) -> IdempotencyResponse | None:\n4566:         \"\"\"Atomically claim ``(tenant_id, idempotency_key)`` for a new\n4567:         request. Returns the freshly inserted (or reclaimed) row if the\n4568:         caller won the race, ``None`` if a *live* row already existed.\n4569: \n4570:         Expired rows are reclaimed in place: the conflict triggers an\n4571:         UPDATE only when ``expires_at`` is in the past. Without that\n4572:         clause an expired-but-not-yet-pruned row would block fresh\n4573:         claims indefinitely — ``idempotency_get`` filters expired rows\n4574:         out, so the middleware would loop forever between \"no cache\"\n4575:         and \"claim conflicts\" until the cleanup job pruned the row.\n4576: \n4577:         The claim row carries ``is_pending=True`` and an empty\n4578:         ``response_body``. :meth:`idempotency_record` flips\n4579:         ``is_pending`` to False once the handler completes.\n4580:         \"\"\"\n4581:         async with get_session() as session:\n4582:             stmt = (\n4583:                 pg_insert(IdempotencyResponse)\n4584:                 .values(\n4585:                     tenant_id=tenant_id,\n4586:                     idempotency_key=idempotency_key,\n4587:                     request_hash=request_hash,\n4588:                     response_body={},\n4589:                     status_code=0,\n4590:                     expires_at=expires_at,\n4591:                     is_pending=True,\n4592:                 )\n4593:                 .on_conflict_do_update(\n4594:                     constraint=\"pk_idempotency_responses\",\n4595:                     set_={\n4596:                         \"request_hash\": request_hash,\n4597:                         \"response_body\": {},\n4598:                         \"status_code\": 0,\n4599:                         \"expires_at\": expires_at,\n4600:                         \"is_pending\": True,\n4601:                     },\n4602:                     # ``func.now()`` evaluates against the DB clock, not the\n4603:                     # app clock — avoids a row being treated as still-live\n4604:                     # when the app and DB clocks have drifted.\n4605:                     where=IdempotencyResponse.expires_at <= func.now(),\n4606:                 )\n4607:                 .returning(IdempotencyResponse)\n4608:             )\n4609:             # ``ON CONFLICT DO UPDATE WHERE`` either inserts a fresh row,\n4610:             # reclaims an expired row, or returns nothing — the WHERE\n4611:             # blocks the UPDATE on a live row, so RETURNING yields no\n4612:             # rows. ``scalar_one_or_none`` cleanly maps that to None\n4613:             # (caller must poll for the original request's completion).\n4614:             result = await session.execute(stmt)\n4615:             return result.scalar_one_or_none()\n4616: \n4617:     async def idempotency_record(\n4618:         self,\n4619:         *,\n4620:         tenant_id: str,\n4621:         idempotency_key: str,\n4622:         request_hash: str,\n4623:         response_body: dict,\n4624:         status_code: int,\n4625:         expires_at: datetime,\n4626:     ) -> IdempotencyResponse:\n4627:         \"\"\"Persist the handler's response and clear ``is_pending``.\n4628: \n4629:         Optimistic about the prior :meth:`idempotency_claim` having\n4630:         inserted the row: this is an UPDATE-by-(tenant, key, hash) first,\n4631:         scoped to the still-pending claim. If no row exists (claim was\n4632:         skipped, e.g. legacy callers calling ``upsert`` directly), falls\n4633:         back to INSERT ON CONFLICT DO NOTHING and returns whichever row\n4634:         wins. The ``request_hash`` filter ensures a late-arriving record\n4635:         for an *expired* claim doesn't clobber a fresh claim that\n4636:         reclaimed the slot — its UPDATE will match no rows and the\n4637:         fallback INSERT will conflict against the new claim, returning\n4638:         the new row's state.\n4639:         \"\"\"\n4640:         async with get_session() as session:\n4641:             update_stmt = (\n4642:                 sql_update(IdempotencyResponse)\n4643:                 .where(\n4644:                     IdempotencyResponse.tenant_id == tenant_id,\n4645:                     IdempotencyResponse.idempotency_key == idempotency_key,\n4646:                     IdempotencyResponse.request_hash == request_hash,\n4647:                     IdempotencyResponse.is_pending.is_(True),\n4648:                 )\n4649:                 .values(\n4650:                     response_body=response_body,\n4651:                     status_code=status_code,\n4652:                     expires_at=expires_at,\n4653:                     is_pending=False,\n4654:                 )\n4655:                 .returning(IdempotencyResponse)\n4656:             )\n4657:             result = await session.execute(update_stmt)\n4658:             row = result.scalar_one_or_none()\n4659:             if row is not None:\n4660:                 return row\n4661: \n4662:             insert_stmt = (\n4663:                 pg_insert(IdempotencyResponse)\n4664:                 .values(\n4665:                     tenant_id=tenant_id,\n4666:                     idempotency_key=idempotency_key,\n4667:                     request_hash=request_hash,\n4668:                     response_body=response_body,\n4669:                     status_code=status_code,\n\n(Showing lines 4540-4669 of 4754. Use offset=4670 to continue.)\n</content>","metadata":{"preview":"        \"\"\"Return the stored idempotency row if live, else None.\n\n        Expired rows are treated as absent so callers transparently\n        re-run the request after TTL. A separate cleanup job prunes\n        them from storage.\n        \"\"\"\n        async with get_session() as session:\n            stmt = select(IdempotencyResponse).where(\n                IdempotencyResponse.tenant_id == tenant_id,\n                IdempotencyResponse.idempotency_key == idempotency_key,\n                # Match ``func.now()`` used by ``idempotency_claim``'s\n                # ON CONFLICT WHERE so the two paths agree on what\n                # \"expired\" means even when the app and DB clocks drift.\n                IdempotencyResponse.expires_at > func.now(),\n            )\n            result = await session.execute(stmt)\n            return result.scalar_one_or_none()\n\n    async def idempotency_claim(\n        self,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","text":"        \"\"\"Return the stored idempotency row if live, else None.\n\n        Expired rows are treated as absent so callers transparently\n        re-run the request after TTL. A separate cleanup job prunes\n        them from storage.\n        \"\"\"\n        async with get_session() as session:\n            stmt = select(IdempotencyResponse).where(\n                IdempotencyResponse.tenant_id == tenant_id,\n                IdempotencyResponse.idempotency_key == idempotency_key,\n                # Match ``func.now()`` used by ``idempotency_claim``'s\n                # ON CONFLICT WHERE so the two paths agree on what\n                # \"expired\" means even when the app and DB clocks drift.\n                IdempotencyResponse.expires_at > func.now(),\n            )\n            result = await session.execute(stmt)\n            return result.scalar_one_or_none()\n\n    async def idempotency_claim(\n        self,\n        *,\n        tenant_id: str,\n        idempotency_key: str,\n        request_hash: str,\n        expires_at: datetime,\n    ) -> IdempotencyResponse | None:\n        \"\"\"Atomically claim ``(tenant_id, idempotency_key)`` for a new\n        request. Returns the freshly inserted (or reclaimed) row if the\n        caller won the race, ``None`` if a *live* row already existed.\n\n        Expired rows are reclaimed in place: the conflict triggers an\n        UPDATE only when ``expires_at`` is in the past. Without that\n        clause an expired-but-not-yet-pruned row would block fresh\n        claims indefinitely — ``idempotency_get`` filters expired rows\n        out, so the middleware would loop forever between \"no cache\"\n        and \"claim conflicts\" until the cleanup job pruned the row.\n\n        The claim row carries ``is_pending=True`` and an empty\n        ``response_body``. :meth:`idempotency_record` flips\n        ``is_pending`` to False once the handler completes.\n        \"\"\"\n        async with get_session() as session:\n            stmt = (\n                pg_insert(IdempotencyResponse)\n                .values(\n                    tenant_id=tenant_id,\n                    idempotency_key=idempotency_key,\n                    request_hash=request_hash,\n                    response_body={},\n                    status_code=0,\n                    expires_at=expires_at,\n                    is_pending=True,\n                )\n                .on_conflict_do_update(\n                    constraint=\"pk_idempotency_responses\",\n                    set_={\n                        \"request_hash\": request_hash,\n                        \"response_body\": {},\n                        \"status_code\": 0,\n                        \"expires_at\": expires_at,\n                        \"is_pending\": True,\n                    },\n                    # ``func.now()`` evaluates against the DB clock, not the\n                    # app clock — avoids a row being treated as still-live\n                    # when the app and DB clocks have drifted.\n                    where=IdempotencyResponse.expires_at <= func.now(),\n                )\n                .returning(IdempotencyResponse)\n            )\n            # ``ON CONFLICT DO UPDATE WHERE`` either inserts a fresh row,\n            # reclaims an expired row, or returns nothing — the WHERE\n            # blocks the UPDATE on a live row, so RETURNING yields no\n            # rows. ``scalar_one_or_none`` cleanly maps that to None\n            # (caller must poll for the original request's completion).\n            result = await session.execute(stmt)\n            return result.scalar_one_or_none()\n\n    async def idempotency_record(\n        self,\n        *,\n        tenant_id: str,\n        idempotency_key: str,\n        request_hash: str,\n        response_body: dict,\n        status_code: int,\n        expires_at: datetime,\n    ) -> IdempotencyResponse:\n        \"\"\"Persist the handler's response and clear ``is_pending``.\n\n        Optimistic about the prior :meth:`idempotency_claim` having\n        inserted the row: this is an UPDATE-by-(tenant, key, hash) first,\n        scoped to the still-pending claim. If no row exists (claim was\n        skipped, e.g. legacy callers calling ``upsert`` directly), falls\n        back to INSERT ON CONFLICT DO NOTHING and returns whichever row\n        wins. The ``request_hash`` filter ensures a late-arriving record\n        for an *expired* claim doesn't clobber a fresh claim that\n        reclaimed the slot — its UPDATE will match no rows and the\n        fallback INSERT will conflict against the new claim, returning\n        the new row's state.\n        \"\"\"\n        async with get_session() as session:\n            update_stmt = (\n                sql_update(IdempotencyResponse)\n                .where(\n                    IdempotencyResponse.tenant_id == tenant_id,\n                    IdempotencyResponse.idempotency_key == idempotency_key,\n                    IdempotencyResponse.request_hash == request_hash,\n                    IdempotencyResponse.is_pending.is_(True),\n                )\n                .values(\n                    response_body=response_body,\n                    status_code=status_code,\n                    expires_at=expires_at,\n                    is_pending=False,\n                )\n                .returning(IdempotencyResponse)\n            )\n            result = await session.execute(update_stmt)\n            row = result.scalar_one_or_none()\n            if row is not None:\n                return row\n\n            insert_stmt = (\n                pg_insert(IdempotencyResponse)\n                .values(\n                    tenant_id=tenant_id,\n                    idempotency_key=idempotency_key,\n                    request_hash=request_hash,\n                    response_body=response_body,\n                    status_code=status_code,","lineStart":4540,"lineEnd":4669,"totalLines":4754,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/services/postgres_service.py","time":{"start":1780729347865,"end":1780729347876}},"metadata":{"openai":{"itemId":"fc_06253be963551f1e016a23c603c2fc8191abae86833a1306c1"}},"id":"prt_e9bbd7f0e001XKF46pNsgHo8U4","sessionID":"ses_164436571ffe8MyT3INeMfMzFK","messageID":"msg_e9bbd54e1001VqmkJBcmip4MhM"}}
