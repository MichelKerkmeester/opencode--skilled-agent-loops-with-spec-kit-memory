{"type":"step_start","timestamp":1782750456424,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"id":"prt_f14352a5b001pIoALFwC65BK6x","messageID":"msg_f14350496001gx0zfXBqjHj7Pj","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","snapshot":"9a129c36f56667947980347614eba6f006742ddb","type":"step-start"}}
{"type":"text","timestamp":1782750460009,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"id":"prt_f1435385d001aocKHF8CVdlrz3","messageID":"msg_f14350496001gx0zfXBqjHj7Pj","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","type":"text","text":"I need to ignore the deep-context system-reminder — I'm running deep-review. Let me read the rest of the workflow YAML and check the existing artifact directory structure.","time":{"start":1782750459997,"end":1782750460007}}}
{"type":"tool_use","timestamp":1782750460016,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_68131200197f49d5ac46e4eb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":639},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n639:           - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n640:           - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n641:           - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n642:           - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n643:           - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n644:           - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n645:           - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n646:           - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n647:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n648:           - graph_signals_json: \"JSON object returned by graph convergence\"\n649:           - graph_blockers_json: \"JSON array of graph blockers\"\n650:           - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n651:           - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n652: \n653:       step_emit_blocked_stop:\n654:         action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n655:         if_blocked:\n656:           append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n657:           log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n658:         if_not_blocked:\n659:           proceed: true\n660: \n661:       step_handle_convergence:\n662:         action: \"Act on convergence decision\"\n663:         if_stop:\n664:           log: \"Loop stopping. Reason: {reason}\"\n665:           skip_to: phase_synthesis\n666:         if_blocked:\n667:           log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n668:         if_stuck_recovery:\n669:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n670:           recovery_strategies:\n671:             - \"Change granularity: file-level → function-level → line-level review\"\n672:             - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n673:             - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n674:           pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n675:           set:\n676:             next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n677:             pending_stop_event: \"stuck_recovery\"\n678:             pending_stop_reason: \"stuckRecovery\"\n679:             pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n680:           reset: { stuck_count: 0 }\n681:         if_continue:\n682:           log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n683: \n684:       step_normalize_pause_events:\n685:         action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n686:         if_pending_pause_event:\n687:           append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n688:           message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n689:           reset:\n690:             pending_stop_event: null\n691:             pending_stop_reason: null\n692:             pending_stop_detail: null\n693:           halt: true\n694:         if_pending_stuck_recovery:\n695:           append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n696:           reset:\n697:             pending_stop_event: null\n698:             pending_stop_reason: null\n699:             pending_stop_detail: null\n700:         if_no_pending_event:\n701:           proceed: true\n702: \n703:       step_generate_state_summary:\n704:         action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n705:         generate: |\n706:           STATE SUMMARY (auto-generated):\n707:           Iteration: {current_iteration} of {max_iterations}\n708:           Dimension: {next_dimension}\n709:           Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n710:           Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n711:           Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n712:           {resource_map_prompt_line}\n713:           Coverage Age: {coverage_age}\n714:           Last 2 ratios: {ratio_prev} -> {ratio_latest}\n715:           Stuck count: {stuck_count}\n716:           Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n717: \n718:       step_marker_scan:\n719:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n720:         algorithm: |\n721:           if current_iteration > 1:\n722:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n723:             if file_exists(PREV_PROMPT_PATH):\n724:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n725:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n726:                 log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n727:                 halt with exit code 2\n728:         note: |\n729:           False-positive prevention: only matches when the first line is exactly one of the\n730:           three canonical markers. Markers appearing in comments or body text are ignored.\n731:           True-positive triggers only when a previous iteration's rendered prompt literally\n732:           starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n733: \n734:       step_dispatch_iteration:\n735:         action: \"Dispatch @deep-review agent for one review iteration\"\n736:         resolve_executor:\n737:           source: \"config.executor\"\n738:           loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n739:         pre_dispatch:\n740:           generate_summary: |\n741:             STATE SUMMARY (auto-generated):\n742:             Iteration: {current_iteration} of {max_iterations}\n743:             Dimension: {next_dimension}\n744:             Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n745:             Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n746:             Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n747:             {resource_map_prompt_line}\n748:             Coverage Age: {coverage_age}\n749:             Last 2 ratios: {ratio_prev} -> {ratio_latest}\n750:             Stuck count: {stuck_count}\n751:             Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n752:           render_prompt_pack:\n753:             template_path: \".opencode/skills/deep-loop-workflows/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n754:             renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n755:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n756:             variables:\n757:               state_summary: \"{state_summary}\"\n758:               current_iteration: \"{current_iteration}\"\n759:               max_iterations: \"{max_iterations}\"\n760:               next_dimension: \"{next_dimension}\"\n761:               review_target: \"{review_target}\"\n762:               review_scope_files: \"{review_scope_files}\"\n763:               p0_count: \"{p0_count}\"\n764:               p1_count: \"{p1_count}\"\n765:               p2_count: \"{p2_count}\"\n766:               state_paths_config: \"{state_paths.config}\"\n767:               state_paths_state_log: \"{state_paths.state_log}\"\n768:               state_paths_findings_registry: \"{state_paths.findings_registry}\"\n769:               state_paths_strategy: \"{state_paths.strategy}\"\n770:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n771:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n772:         pre_dispatch_audit:\n773:           skip_when: \"config.executor.kind == 'native'\"\n774:           call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n775:           args:\n776:             stateLogPath: \"{state_paths.state_log}\"\n777:             executor: \"{config.executor}\"\n778:             iteration: \"{current_iteration}\"\n779:         branch_on: \"config.executor.kind\"\n780:         if_native:\n781:           dispatch:\n782:             agent: deep-review\n783:             model: opus\n784:             context_source: \"rendered_prompt_pack\"\n785:           wait_for_completion: true\n786:         if_cli_codex:\n787:           command: |\n788:             node --experimental-strip-types --input-type=module <<'EOF'\n789:             import { readFileSync } from 'node:fs';\n790: \n791:             import { runAuditedExecutorCommandAsync } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n792:             import { resolveCodexSandboxMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n793: \n794:             const executor = {\n795:               kind: 'cli-codex',\n796:               model: '{config.executor.model}',\n797:               configDir: '{config.executor.configDir}' === 'null' ? null : '{config.executor.configDir}',\n798:               reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n799:               serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n800:               sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n801:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n802:             };\n803: \n804:             process.exit(await runAuditedExecutorCommandAsync({\n805:               command: 'codex',\n806:               args: [\n807:                 'exec',\n808:                 '--model',\n809:                 executor.model,\n810:                 '-c',\n811:                 `model_reasoning_effort=${executor.reasoningEffort}`,\n812:                 '-c',\n813:                 `service_tier=${executor.serviceTier}`,\n814:                 '-c',\n815:                 'approval_policy=never',\n816:                 '--sandbox',\n817:                 resolveCodexSandboxMode(executor.sandboxMode),\n818:                 '-',\n819:               ],\n820:               cwd: '{repo_root}',\n821:               timeoutSeconds: executor.timeoutSeconds,\n822:               stateLogPath: '{state_paths.state_log}',\n823:               executor,\n824:               iteration: Number('{current_iteration}'),\n825:               input: readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n826:             }));\n827:             EOF\n828:           working_directory: \"{repo_root}\"\n829:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n830:           wait_for_completion: true\n831:         if_cli_copilot:\n832:           command: |\n833:             node --experimental-strip-types --input-type=module <<'EOF'\n834:             import { readFileSync, writeFileSync } from 'node:fs';\n835:             import { spawnSync } from 'node:child_process';\n836: \n837:             import { buildCopilotPromptArg } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n838: \n839:             const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n840:             const prompt = readFileSync(promptPath, 'utf8');\n841: \n842:             // Workflow-resolved spec folder is the only legal write authority.\n843:             // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n844:             // is the single source of truth for rejecting empty / unresolved\n845:             // template / whitespace-only / string-coerced empty values. The\n846:             // YAML hands the raw `{spec_folder}` directly; on rejection the\n847:             // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n848:             // enforcement, --allow-all-tools stripped).\n849:             const specFolderRaw = '{spec_folder}';\n850:             const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n851: \n852:             const baseArgs = [\n853:               '-p',\n854:               prompt,\n855:               '--model',\n856:               '{config.executor.model}',\n857:               '--allow-all-tools',\n858:               '--no-ask-user',\n859:             ];\n860: \n861:             const built = buildCopilotPromptArg({\n862:               promptPath,\n863:               prompt,\n864:               targetAuthority,\n865:               baseArgv: baseArgs,\n866:             });\n867: \n868:             // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n869:             // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n870:             // Write it to disk so the file Copilot reads via @path opens with\n871:             // the authority block. Without this, recovered/bootstrap folder\n872:             // mentions inside the file could still anchor the model.\n873:             if (built.promptFileBody !== undefined) {\n874:               writeFileSync(promptPath, built.promptFileBody, 'utf8');\n875:             }\n876: \n877:             const result = spawnSync('copilot', built.argv, {\n878:               cwd: '{repo_root}',\n879:               stdio: 'inherit',\n880:               timeout: Number('{config.executor.timeoutSeconds}') * 1000,\n881:             });\n882:             process.exit(result.status ?? 1);\n883:             EOF\n884:           working_directory: \"{repo_root}\"\n885:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n886:           wait_for_completion: true\n887:           notes:\n888:             - \"copilot has no stdin support; prompt is positional\"\n889:             - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n890:             - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n891:             - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n892:             - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n893:             - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n894:         if_cli_claude_code:\n895:           command: |\n896:             if [ -n \"{optional_claude_config_dir}\" ]; then export CLAUDE_CONFIG_DIR=\"{optional_claude_config_dir}\"; fi\n897:             claude \\\n898:               -p \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n899:               --model \"{config.executor.model}\" \\\n900:               --permission-mode acceptEdits \\\n901:               --output-format text \\\n902:               {optional_effort_flag}\n903:           working_directory: \"{repo_root}\"\n904:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n905:           wait_for_completion: true\n906:           render_hint:\n907:             optional_claude_config_dir: |\n908:               If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n909:               Otherwise expand to empty string.\n910:             optional_effort_flag: |\n911:               If config.executor.reasoningEffort is set and non-null, expand to: --effort {config.executor.reasoningEffort}\n912:               Otherwise expand to empty string.\n913:           notes:\n914:             - \"claude-code default permission-mode is 'plan' (read-only); we override to 'acceptEdits' for iteration writes\"\n915:             - \"config.executor.configDir maps to CLAUDE_CONFIG_DIR for account-specific Claude Code routing\"\n916:             - \"claude-code has no serviceTier flag\"\n917:             - \"claude-code supports --effort for reasoning depth\"\n918:         if_cli_opencode:\n919:           command: |\n920:             opencode run \\\n921:               --model \"{config.executor.model}\" \\\n922:               --format json \\\n923:               --dangerously-skip-permissions \\\n924:               --pure \\\n925:               --dir \"{repo_root}\" \\\n926:               {optional_variant_flag} \\\n927:               \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n928:               </dev/null\n929:           working_directory: \"{repo_root}\"\n930:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n931:           wait_for_completion: true\n932:           render_hint:\n933:             optional_variant_flag: |\n934:               If config.executor.reasoningEffort is set and non-null, expand to: --variant {config.executor.reasoningEffort}\n935:               Otherwise expand to empty string.\n936:           notes:\n937:             - \"opencode run takes a positional message; prompt is fed via command substitution\"\n938:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n939:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n940:             - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude/Codex/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n941:             - \"</dev/null required: opencode v1.14.39 reads stdin at startup before session creation. Without explicit closed stdin, automation that redirects stdout/stderr hangs at 0% CPU after `+60s snapshot prune cleanup`. See cli-opencode SKILL.md §4 ALWAYS rule + memory feedback_opencode_run_requires_dev_null_stdin.md.\"\n942:         post_dispatch_validate:\n943:           validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n944:           assert_exists: \"{state_paths.iteration_pattern}\"\n945:           assert_appended: \"{state_paths.state_log}\"\n946:           assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n947:           assert_canonical_type: \"iteration\"\n948:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n949:           assert_delta_file_has_iteration_record: true\n950:           failure_reasons:\n951:             - iteration_file_missing\n952:             - iteration_file_empty\n953:             - jsonl_not_appended\n954:             - jsonl_missing_fields\n955:             - jsonl_parse_error\n956:             - jsonl_wrong_type\n957:             - delta_file_missing\n958:             - delta_file_empty\n959:             - delta_file_missing_iteration_record\n960:             - executor_missing\n961:             - dispatch_failure_logged\n962:             - v2_missing_ledger\n963:             - v2_uncited_ledger_row\n964:             - v2_broken_linked_finding\n965:             - v2_shallow_finding_details\n966:             - delta_iteration_id_mismatch\n967:             - state_delta_iteration_mismatch\n968:           warning_surface:\n969:             source: \"result.warnings\"\n970:             action: \"emit schema_advisory canonical conflict event\"\n971:             severity: \"advisory\"\n972:             event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n973:             note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n974:           on_failure:\n975:             action: \"emit schema_mismatch canonical conflict event\"\n976:             escalation: \"After 3 consecutive failures, trigger stuck_recovery event with diagnostic context\"\n977:         record_executor_audit:\n978:           skip_when: \"config.executor.kind == 'native'\"\n979:           target: \"{state_paths.state_log}\"\n980:           field: \"executor\"\n981:           value:\n982:             kind: \"{config.executor.kind}\"\n983:             model: \"{config.executor.model}\"\n984:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n985:             serviceTier: \"{config.executor.serviceTier}\"\n986: \n987:       step_evaluate_results:\n988:         action: \"Verify iteration outputs and extract metrics\"\n989:         verify:\n990:           - file_exists: \"{state_paths.iteration_pattern}\"\n991:           - jsonl_appended: \"New iteration record in state.jsonl\"\n992:           - strategy_updated: \"Strategy.md has been modified\"\n993:         extract:\n994:           - newFindingsRatio: \"From latest JSONL iteration record\"\n995:           - findings_count: \"From latest JSONL iteration record\"\n996:           - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n997:           - dimensions: \"From latest JSONL iteration record\"\n998:           - files_reviewed: \"From latest JSONL iteration record\"\n999:           - status: \"From latest JSONL iteration record\"\n1000:           - reviewed_artifacts: \"From latest JSONL iteration record\"\n1001:           - traceability_checks: \"From latest JSONL iteration record when present\"\n1002:         on_missing_outputs:\n1003:           action: \"Mark iteration as 'error', continue to next\"\n1004:           # <!-- F-010-B5-03 -->\n1005:           # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n1006:           # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1007:           append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n1008: \n1009:       step_post_iteration_claim_adjudication:\n1010:         action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n1011:         verify:\n1012:           - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n1013:           - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n1014:           - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n1015:         on_pass:\n1016:           set:\n1017:             claim_adjudication_passed: true\n1018:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1019:           log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n1020:         on_fail:\n1021:           action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n1022:           set:\n1023:             claim_adjudication_passed: false\n1024:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1025:           log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n1026: \n1027:       step_reduce_review_state:\n1028:         action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n1029:         command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder}\"\n1030:         read:\n1031:           - \"{state_paths.state_log}\"\n1032:           - \"{state_paths.iteration_pattern}\"\n1033:           - \"{state_paths.findings_registry}\"\n1034:           - \"{state_paths.strategy}\"\n1035:         write:\n1036:           - \"{state_paths.findings_registry}\"\n1037:           - \"{state_paths.dashboard}\"\n1038:           - \"{state_paths.strategy}\"\n1039:         failure_modes:\n1040:           malformed_delta: \"skip + warn\"\n1041:           missing_iteration_file: \"no-op + error\"\n1042:           schema_mismatch: \"reject + conflict event\"\n1043:         guarantee: \"Idempotent for identical inputs\"\n1044:         note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n1045: \n1046:       step_graph_upsert:\n1047:         action: \"Transform the latest iteration graphEvents delta into review graph nodes and edges, then upsert it\"\n1048:         read:\n1049:           - \"{state_paths.state_log}\"\n1050:           - \"{state_paths.findings_registry}\"\n1051:         transform: |\n1052:           1. Read the latest iteration JSONL record after reducer completion.\n1053:           2. If graphEvents is absent or empty, set graph_nodes_json = [] and graph_edges_json = [] and skip the upsert.\n1054:           3. For each graph event without relation/source/target, normalize type = uppercase(event.type || event.nodeKind || event.type) and keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n1055:           4. Emit nodes as { id, type, name, iteration, metadata } using the event label (or id fallback) and review metadata for run/current focus.\n1056:           5. For each graph event with relation + source + target, normalize relation = uppercase(event.relation) and keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n1057:           6. Emit edges as { id, relation, sourceId, targetId, metadata } and deduplicate the batch by id.\n1058:           7. Discard malformed or unknown graph events instead of failing the review iteration.\n1059:         bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n1060:         note: \"Invoke the runtime script directly. Upsert only the latest iteration graph delta.\"\n1061:         outputs:\n1062:           - graph_nodes_json: \"JSON array of normalized review graph nodes for the latest iteration\"\n1063:           - graph_edges_json: \"JSON array of normalized review graph edges for the latest iteration\"\n1064:         skip_conditions:\n1065:           - \"Latest iteration record has no graphEvents array\"\n1066: \n1067:       step_generate_dashboard:\n1068:         action: \"Generate or refresh the review dashboard\"\n1069:         read:\n1070:           - \"{state_paths.state_log}\"\n1071:           - \"{state_paths.findings_registry}\"\n1072:           - \"{state_paths.strategy}\"\n1073:         content: |\n1074:           # Deep Review Dashboard - Session Overview\n1075: \n1076:           Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n1077: \n1078:           ## Status\n1079:           - Review Target: {review_target} ({review_target_type})\n1080:           - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n1081:           - Iteration: {current_iteration} of {max_iterations}\n1082:           - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n1083:           - hasAdvisories: {has_advisories}\n1084: \n1085:           ## Findings Summary\n1086:           | Severity | Count | Trend |\n1087:           |----------|------:|-------|\n1088:           | P0 (Blockers) | {p0_count} | {p0_trend} |\n1089:           | P1 (Required) | {p1_count} | {p1_trend} |\n1090:           | P2 (Suggestions) | {p2_count} | {p2_trend} |\n1091: \n1092:           ## Dimension Coverage\n1093:           | Dimension | Status | Iteration | Findings |\n1094:           |-----------|--------|-----------|----------|\n1095:           | [per dimension from strategy + JSONL] |\n1096: \n1097:           ## Traceability Coverage\n1098:           | Protocol | Level | Status | Findings |\n1099:           |----------|-------|--------|----------|\n1100:           | [per protocol from traceabilityChecks] |\n1101: \n1102:           ## Progress\n1103:           | # | Dimension | Ratio | P0/P1/P2 | Status |\n1104:           |---|-----------|-------|----------|--------|\n1105:           | [per iteration from JSONL] |\n1106: \n1107:           ## Trend\n1108:           - Last 3 ratios: [{ratios}] [{trend}]\n1109:           - Stuck count: {stuck_count}\n1110:           - Gate violations: {guard_violations}\n1111: \n1112:           ## Next Focus\n1113:           {next_dimension}\n1114:         output: \"{state_paths.dashboard}\"\n1115:         note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n1116: \n1117:       step_update_tracking:\n1118:         action: \"Update loop tracking variables\"\n1119:         set:\n1120:           current_iteration: \"{current_iteration + 1}\"\n1121:           p0_count: \"Accumulate from severity_counts\"\n1122:           p1_count: \"Accumulate from severity_counts\"\n1123:           p2_count: \"Accumulate from severity_counts\"\n1124:           stuck_count: |\n1125:             if status == 'thought': unchanged (skip)\n1126:             if status == 'insight': 0 (reset)\n1127:             if newFindingsRatio <= 0.05: stuck_count + 1\n1128:             else: 0\n1129:         log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n1130: \n1131:       step_loop_decision:\n1132:         action: \"Return to step_read_state for next iteration\"\n1133:         goto: step_read_state\n1134: \n1135:   # ═══════════════════════════════════════════════════════════════\n1136:   # PHASE 3: SYNTHESIS\n1137:   # ═══════════════════════════════════════════════════════════════\n1138:   phase_synthesis:\n1139:     purpose: Compile all iteration findings into review/review-report.md\n1140:     steps:\n1141: \n1142:       step_fanout_merge:\n1143:         description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n1144:         skip_when: \"config.fanout is absent\"\n1145:         command: |\n1146:           node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n1147:             --loop-type review \\\n1148:             --artifact-dir {artifact_dir}\n1149:         working_directory: \"{repo_root}\"\n1150:         wait_for_completion: true\n1151:         bind_from_output:\n1152:           p0_count: \"active_p0\"\n1153:           p1_count: \"active_p1\"\n1154:           p2_count: \"active_p2\"\n1155: \n1156:       step_hydrate_summary_metrics:\n1157:         action: \"Hydrate summary metrics before synthesis\"\n1158:         read:\n1159:           - \"{state_paths.config}\"\n1160:           - \"{state_paths.state_log}\"\n1161:           - \"{state_paths.findings_registry}\"\n1162:           - \"{state_paths.strategy}\"\n1163:         extract:\n1164:           - iteration_count: \"Count lines where type === 'iteration'\"\n1165:           - p0_count: \"Total P0 findings across all iterations (deduped)\"\n1166:           - p1_count: \"Total P1 findings across all iterations (deduped)\"\n1167:           - p2_count: \"Total P2 findings across all iterations (deduped)\"\n1168:           - dimensions_covered: \"List of reviewed dimensions\"\n1169:           - dimension_coverage: \"covered / total\"\n1170:           - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n1171:           - last_3_summaries: \"Summarize the latest 3 iteration records\"\n1172:           - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1173: \n1174:       # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n1175:       # - PASS: no P0 or P1 findings (P2-only or clean)\n1176:       # - CONDITIONAL: any P1 findings (no P0)\n1177:       # - FAIL: any P0 findings\n1178:       # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n1179:       step_derive_verdict:\n1180:         action: \"Derive review verdict from accumulated findings\"\n1181:         algorithm: |\n1182:           if p0_count > 0:\n1183:             verdict = \"FAIL\"\n1184:           elif p1_count > 0:\n1185:             verdict = \"CONDITIONAL\"\n1186:           else:\n1187:             verdict = \"PASS\"\n1188:           has_advisories = (verdict == \"PASS\" and p2_count > 0)\n1189:           ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n1190:         outputs:\n1191:           - verdict: \"PASS | CONDITIONAL | FAIL\"\n1192:           - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n1193:           - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n1194:         contract: |\n1195:           Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n1196:           Downstream automation parses this final line via exact string match — do not vary the format.\n1197: \n1198:       step_read_all_iterations:\n1199:         action: \"Read all iteration files and strategy\"\n1200:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1201:         read_also: \"{state_paths.strategy}\"\n1202: \n1203:       step_build_finding_registry:\n1204:         action: \"Build deduplicated finding registry from all iterations\"\n1205:         algorithm: |\n1206:           1. Extract all findings from iteration JSONL delta files\n1207:           2. Compute content_hash for each finding (emission requirement):\n1208:              content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n1209:              Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n1210:           3. Two-tier dedup:\n1211:              PRIMARY: group by content_hash field\n1212:                - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n1213:                - Keep highest severity on duplicates\n1214:              FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n1215:                - Same file:line, multiple dimensions → single finding, multiple dimension tags\n1216:                - Keep highest severity on duplicates\n1217:           4. Track finding lifecycle:\n1218:              - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n1219:              - Record first_seen, upgraded_in, previous_severity for severity changes\n1220:              - Record dimensions array reflecting all dimensions that emitted this finding\n1221:           5. Resolve contradictions:\n1222:              - Findings marked contested across iterations → referee pass\n1223:              - Determine final severity and status\n1224:           6. Count only 'active' findings for totals\n1225:         outputs:\n1226:           - finding_registry: \"Deduplicated list of all findings with metadata\"\n1227:           - active_p0: \"Count of active P0 findings\"\n1228:           - active_p1: \"Count of active P1 findings\"\n1229:           - active_p2: \"Count of active P2 findings\"\n1230: \n1231:       step_adversarial_selfcheck:\n1232:         action: \"Final adversarial self-check on all P0 and P1 findings\"\n1233:         algorithm: |\n1234:           For each active P0/P1 finding:\n1235:             1. Hunter: Re-verify finding against source code (re-read file:line)\n1236:             2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n1237:             3. Referee: Final call — confirm, downgrade, or mark false_positive\n1238:           Update finding_registry with adjudicated results.\n1239: \n1240:       step_emit_resource_map:\n1241:         action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n1242:         command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1243:         read:\n1244:           - \"{state_paths.config}\"\n1245:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1246:         write:\n1247:           - \"{state_paths.resource_map_output}\"\n1248:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1249: \n1250:       step_resource_map_coverage_gate:\n1251:         action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n1252:         note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n1253: \n1254:       step_compile_review_report:\n1255:         action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n1256:         instructions: |\n1257:           Create review/review-report.md with the following sections:\n1258: \n1259:           1. **Executive Summary**\n1260:              - Overall verdict: PASS | CONDITIONAL | FAIL\n1261:              - hasAdvisories: true when PASS carries active P2 items\n1262:              - P0/P1/P2 counts (active only)\n1263:              - Review scope summary\n1264: \n1265:           2. **Planning Trigger**\n1266:              - State whether `/speckit:plan` is required\n1267:              - Include a fenced `json` block labeled `Planning Packet`\n1268:              - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n1269:              - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n1270: \n1271:           3. **Active Finding Registry**\n1272:              - Unified registry for active P0/P1/P2 findings\n1273:              - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n1274: \n1275:           4. **Remediation Workstreams**\n1276:              - Ordered action groups: P0 first, then P1, with P2 advisories separated\n1277: \n1278:           5. **Spec Seed**\n1279:              - Concrete seed bullets for follow-on spec updates\n1280: \n1281:           6. **Plan Seed**\n1282:              - Concrete starter tasks for `/speckit:plan`\n1283: \n1284:            7. **Traceability Status**\n1285:               - Summarize required core protocols first, then applicable overlay protocols\n1286:               - Include status, evidence, and any unresolved drift per protocol\n1287:               - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n1288: \n1289:           If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n1290:              - `Entries touched`: count of resource-map paths that appear in applied reports\n1291:              - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n1292:              - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n1293: \n1294:           8. **Deferred Items**\n1295:              - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n1296: \n1297:           9. **Search Ledger**\n1298:              - Always include this section before the appendix.\n1299:              - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n1300:              - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n1301:              - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n1302: \n1303:           10. **Audit Appendix**\n1304:              - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n1305:              - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n1306: \n1307:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n1308:         output: \"{state_paths.review_output}\"\n1309: \n1310:       step_convergence_report:\n1311:         action: \"Append convergence report to JSONL\"\n1312:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":{iteration_count},\"activeP0\":{active_p0},\"activeP1\":{active_p1},\"activeP2\":{active_p2},\"dimensionCoverage\":{dimension_coverage},\"verdict\":\"{verdict}\",\"releaseReadinessState\":\"{release_readiness_state}\",\"stopReason\":\"{reason}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1313:         note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n1314: \n1315:       step_update_config_status:\n1316:         action: \"Mark config as complete\"\n1317:         edit: \"{state_paths.config}\"\n1318:         set_field: { status: \"complete\" }\n1319: \n1320:       step_stage_artifact_dir:\n1321:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1322:         command: \"git add {state_paths.packet_dir}\"\n1323:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add review-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, findings-registry, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1324:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1325: \n1326:   # ═══════════════════════════════════════════════════════════════\n1327:   # PHASE 4: SAVE\n1328:   # ═══════════════════════════════════════════════════════════════\n1329:   phase_save:\n1330:     purpose: Preserve review context to memory system\n1331:     steps:\n1332: \n1333:       step_compose_save_payload:\n1334:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1335:         output: \"/tmp/save-context-data-<session-id>.json\"\n1336:         requirements:\n1337:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1338:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed review loop.\"\n1339:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1340:         example_payload: |\n1341:           {\n1342:             \"specFolder\": \"{spec_folder}\",\n1343:             \"sessionSummary\": \"Deep review completed; see review/review-report.md for verdict, findings, and workstreams.\",\n1344:             \"observations\": [\"Summarize the active findings, verdict, and remediation guidance.\"],\n1345:             \"recent_context\": [\"Point to the generated review artifacts and next action.\"],\n1346:             \"exchanges\": [],\n1347:             \"toolCalls\": []\n1348:           }\n1349: \n1350:       step_generate_context:\n1351:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1352:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1353:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1354: \n1355:       step_index_memory:\n1356:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1357:         mcp_tool: memory_save\n1358:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1359:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1360: \n1361:       step_verify_save:\n1362:         action: \"Verify canonical save routed content into the correct spec document\"\n1363:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1364:         on_fail: \"Log warning but do not block completion\"\n1365: \n1366:       step_release_lock:\n1367:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1368:         command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1369:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1370: \n1371:   # ═══════════════════════════════════════════════════════════════\n1372:   # COMPLETION\n1373:   # ═══════════════════════════════════════════════════════════════\n1374:   completion:\n1375:     message: |\n1376:       Deep review complete.\n1377:       Iterations: {iteration_count} | Stop reason: {reason}\n1378:       Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n1379:       Verdict: {verdict} | hasAdvisories={has_advisories}\n1380: \n1381:       Artifacts:\n1382:         - review/review-report.md (compiled from {iteration_count} iterations)\n1383:         - {iteration_count} iteration files in review/iterations/\n1384:         - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n1385:         - Memory context saved\n1386: \n1387:       STATUS=OK PATH={spec_folder}\n1388:     next_steps:\n1389:       - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n1390:       - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n1391:       - \"/deep:review [target] (for another review)\"\n1392:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1393: \n1394: # ─────────────────────────────────────────────────────────────────\n1395: # ERROR RECOVERY\n1396: # ─────────────────────────────────────────────────────────────────\n1397: error_recovery:\n1398:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer files per iteration). If second timeout, mark as 'timeout' and continue.\"\n1399:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1400:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1401:   memory_save_failure: \"Preserve the review packet in review/ as backup. Log warning.\"\n1402: \n1403: # ─────────────────────────────────────────────────────────────────\n1404: # RULES\n1405: # ─────────────────────────────────────────────────────────────────\n1406: rules:\n1407:   ALWAYS:\n1408:     - follow_workflow_phases_in_order\n1409:     - dispatch_deep_review_agent_per_iteration\n1410:     - check_convergence_before_each_iteration\n1411:     - write_all_state_to_files\n1412:     - save_memory_context_after_synthesis\n1413:     - respect_max_iterations_cap\n1414:     - treat_review_target_as_read_only\n1415:     - deduplicate_findings_before_synthesis\n1416:     - run_adversarial_selfcheck_on_p0_p1\n1417:   NEVER:\n1418:     - skip_convergence_check\n1419:     - dispatch_non_leaf_agents\n1420:     - hold_iteration_findings_in_memory_only\n1421:     - modify_config_after_initialization\n1422:     - overwrite_jsonl_state_log\n1423:     - proceed_without_state_file_verification\n1424:     - modify_files_under_review\n1425:     - report_p0_without_file_line_evidence\n1426: \n1427: # ─────────────────────────────────────────────────────────────────\n1428: # REFERENCE-ONLY APPENDIX\n1429: # ─────────────────────────────────────────────────────────────────\n1430: reference_only_appendix:\n1431:   checkpoint_commit:\n1432:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n1433:     commands:\n1434:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.findings_registry} {state_paths.strategy} {state_paths.review_output}\"\n1435:       - 'git commit -m \"chore(deep-review): iteration {NNN} complete\"'\n1436:   severity_weights:\n\n(Output capped at 50 KB. Showing lines 639-1436. Use offset=1437 to continue.)\n</content>","metadata":{"preview":"          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:\n        action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n        if_blocked:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:\n        action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n        if_blocked:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          log: \"Loop stopping. Reason: {reason}\"\n          skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:\n            next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n            pending_stop_event: \"stuck_recovery\"\n            pending_stop_reason: \"stuckRecovery\"\n            pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n\n      step_normalize_pause_events:\n        action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n        if_pending_pause_event:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n          halt: true\n        if_pending_stuck_recovery:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n        if_no_pending_event:\n          proceed: true\n\n      step_generate_state_summary:\n        action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n        generate: |\n          STATE SUMMARY (auto-generated):\n          Iteration: {current_iteration} of {max_iterations}\n          Dimension: {next_dimension}\n          Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n          Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n          Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n          {resource_map_prompt_line}\n          Coverage Age: {coverage_age}\n          Last 2 ratios: {ratio_prev} -> {ratio_latest}\n          Stuck count: {stuck_count}\n          Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch @deep-review agent for one review iteration\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Iteration: {current_iteration} of {max_iterations}\n            Dimension: {next_dimension}\n            Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n            Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n            Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n            {resource_map_prompt_line}\n            Coverage Age: {coverage_age}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest}\n            Stuck count: {stuck_count}\n            Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n          render_prompt_pack:\n            template_path: \".opencode/skills/deep-loop-workflows/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_dimension: \"{next_dimension}\"\n              review_target: \"{review_target}\"\n              review_scope_files: \"{review_scope_files}\"\n              p0_count: \"{p0_count}\"\n              p1_count: \"{p1_count}\"\n              p2_count: \"{p2_count}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_findings_registry: \"{state_paths.findings_registry}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.kind\"\n        if_native:\n          dispatch:\n            agent: deep-review\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n\n            import { runAuditedExecutorCommandAsync } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n            import { resolveCodexSandboxMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const executor = {\n              kind: 'cli-codex',\n              model: '{config.executor.model}',\n              configDir: '{config.executor.configDir}' === 'null' ? null : '{config.executor.configDir}',\n              reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n              serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n              sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n            };\n\n            process.exit(await runAuditedExecutorCommandAsync({\n              command: 'codex',\n              args: [\n                'exec',\n                '--model',\n                executor.model,\n                '-c',\n                `model_reasoning_effort=${executor.reasoningEffort}`,\n                '-c',\n                `service_tier=${executor.serviceTier}`,\n                '-c',\n                'approval_policy=never',\n                '--sandbox',\n                resolveCodexSandboxMode(executor.sandboxMode),\n                '-',\n              ],\n              cwd: '{repo_root}',\n              timeoutSeconds: executor.timeoutSeconds,\n              stateLogPath: '{state_paths.state_log}',\n              executor,\n              iteration: Number('{current_iteration}'),\n              input: readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n            }));\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n        if_cli_copilot:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync, writeFileSync } from 'node:fs';\n            import { spawnSync } from 'node:child_process';\n\n            import { buildCopilotPromptArg } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n            const prompt = readFileSync(promptPath, 'utf8');\n\n            // Workflow-resolved spec folder is the only legal write authority.\n            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n            // is the single source of truth for rejecting empty / unresolved\n            // template / whitespace-only / string-coerced empty values. The\n            // YAML hands the raw `{spec_folder}` directly; on rejection the\n            // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n            // enforcement, --allow-all-tools stripped).\n            const specFolderRaw = '{spec_folder}';\n            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n\n            const baseArgs = [\n              '-p',\n              prompt,\n              '--model',\n              '{config.executor.model}',\n              '--allow-all-tools',\n              '--no-ask-user',\n            ];\n\n            const built = buildCopilotPromptArg({\n              promptPath,\n              prompt,\n              targetAuthority,\n              baseArgv: baseArgs,\n            });\n\n            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n            // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n            // Write it to disk so the file Copilot reads via @path opens with\n            // the authority block. Without this, recovered/bootstrap folder\n            // mentions inside the file could still anchor the model.\n            if (built.promptFileBody !== undefined) {\n              writeFileSync(promptPath, built.promptFileBody, 'utf8');\n            }\n\n            const result = spawnSync('copilot', built.argv, {\n              cwd: '{repo_root}',\n              stdio: 'inherit',\n              timeout: Number('{config.executor.timeoutSeconds}') * 1000,\n            });\n            process.exit(result.status ?? 1);\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"copilot has no stdin support; prompt is positional\"\n            - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n            - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n            - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n            - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n            - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n        if_cli_claude_code:\n          command: |\n            if [ -n \"{optional_claude_config_dir}\" ]; then export CLAUDE_CONFIG_DIR=\"{optional_claude_config_dir}\"; fi\n            claude \\\n              -p \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n              --model \"{config.executor.model}\" \\\n              --permission-mode acceptEdits \\\n              --output-format text \\\n              {optional_effort_flag}\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_claude_config_dir: |\n              If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n              Otherwise expand to empty string.\n            optional_effort_flag: |\n              If config.executor.reasoningEffort is set and non-null, expand to: --effort {config.executor.reasoningEffort}\n              Otherwise expand to empty string.\n          notes:\n            - \"claude-code default permission-mode is 'plan' (read-only); we override to 'acceptEdits' for iteration writes\"\n            - \"config.executor.configDir maps to CLAUDE_CONFIG_DIR for account-specific Claude Code routing\"\n            - \"claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        if_cli_opencode:\n          command: |\n            opencode run \\\n              --model \"{config.executor.model}\" \\\n              --format json \\\n              --dangerously-skip-permissions \\\n              --pure \\\n              --dir \"{repo_root}\" \\\n              {optional_variant_flag} \\\n              \"$(cat '{state_paths.prompt_dir}/iteration-{current_iteration}.md')\" \\\n              </dev/null\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_variant_flag: |\n              If config.executor.reasoningEffort is set and non-null, expand to: --variant {config.executor.reasoningEffort}\n              Otherwise expand to empty string.\n          notes:\n            - \"opencode run takes a positional message; prompt is fed via command substitution\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude/Codex/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n            - \"</dev/null required: opencode v1.14.39 reads stdin at startup before session creation. Without explicit closed stdin, automation that redirects stdout/stderr hangs at 0% CPU after `+60s snapshot prune cleanup`. See cli-opencode SKILL.md §4 ALWAYS rule + memory feedback_opencode_run_requires_dev_null_stdin.md.\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:\n            - iteration_file_missing\n            - iteration_file_empty\n            - jsonl_not_appended\n            - jsonl_missing_fields\n            - jsonl_parse_error\n            - jsonl_wrong_type\n            - delta_file_missing\n            - delta_file_empty\n            - delta_file_missing_iteration_record\n            - executor_missing\n            - dispatch_failure_logged\n            - v2_missing_ledger\n            - v2_uncited_ledger_row\n            - v2_broken_linked_finding\n            - v2_shallow_finding_details\n            - delta_iteration_id_mismatch\n            - state_delta_iteration_mismatch\n          warning_surface:\n            source: \"result.warnings\"\n            action: \"emit schema_advisory canonical conflict event\"\n            severity: \"advisory\"\n            event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            escalation: \"After 3 consecutive failures, trigger stuck_recovery event with diagnostic context\"\n        record_executor_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.kind}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Strategy.md has been modified\"\n        extract:\n          - newFindingsRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n          - dimensions: \"From latest JSONL iteration record\"\n          - files_reviewed: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - reviewed_artifacts: \"From latest JSONL iteration record\"\n          - traceability_checks: \"From latest JSONL iteration record when present\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # <!-- F-010-B5-03 -->\n          # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n          # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n\n      step_post_iteration_claim_adjudication:\n        action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n        verify:\n          - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n          - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n          - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n        on_pass:\n          set:\n            claim_adjudication_passed: true\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n        on_fail:\n          action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n          set:\n            claim_adjudication_passed: false\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n\n      step_reduce_review_state:\n        action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder}\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.iteration_pattern}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        write:\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n        guarantee: \"Idempotent for identical inputs\"\n        note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n\n      step_graph_upsert:\n        action: \"Transform the latest iteration graphEvents delta into review graph nodes and edges, then upsert it\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Read the latest iteration JSONL record after reducer completion.\n          2. If graphEvents is absent or empty, set graph_nodes_json = [] and graph_edges_json = [] and skip the upsert.\n          3. For each graph event without relation/source/target, normalize type = uppercase(event.type || event.nodeKind || event.type) and keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n          4. Emit nodes as { id, type, name, iteration, metadata } using the event label (or id fallback) and review metadata for run/current focus.\n          5. For each graph event with relation + source + target, normalize relation = uppercase(event.relation) and keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n          6. Emit edges as { id, relation, sourceId, targetId, metadata } and deduplicate the batch by id.\n          7. Discard malformed or unknown graph events instead of failing the review iteration.\n        bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n        note: \"Invoke the runtime script directly. Upsert only the latest iteration graph delta.\"\n        outputs:\n          - graph_nodes_json: \"JSON array of normalized review graph nodes for the latest iteration\"\n          - graph_edges_json: \"JSON array of normalized review graph edges for the latest iteration\"\n        skip_conditions:\n          - \"Latest iteration record has no graphEvents array\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the review dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        content: |\n          # Deep Review Dashboard - Session Overview\n\n          Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n\n          ## Status\n          - Review Target: {review_target} ({review_target_type})\n          - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n          - Iteration: {current_iteration} of {max_iterations}\n          - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n          - hasAdvisories: {has_advisories}\n\n          ## Findings Summary\n          | Severity | Count | Trend |\n          |----------|------:|-------|\n          | P0 (Blockers) | {p0_count} | {p0_trend} |\n          | P1 (Required) | {p1_count} | {p1_trend} |\n          | P2 (Suggestions) | {p2_count} | {p2_trend} |\n\n          ## Dimension Coverage\n          | Dimension | Status | Iteration | Findings |\n          |-----------|--------|-----------|----------|\n          | [per dimension from strategy + JSONL] |\n\n          ## Traceability Coverage\n          | Protocol | Level | Status | Findings |\n          |----------|-------|--------|----------|\n          | [per protocol from traceabilityChecks] |\n\n          ## Progress\n          | # | Dimension | Ratio | P0/P1/P2 | Status |\n          |---|-----------|-------|----------|--------|\n          | [per iteration from JSONL] |\n\n          ## Trend\n          - Last 3 ratios: [{ratios}] [{trend}]\n          - Stuck count: {stuck_count}\n          - Gate violations: {guard_violations}\n\n          ## Next Focus\n          {next_dimension}\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          p0_count: \"Accumulate from severity_counts\"\n          p1_count: \"Accumulate from severity_counts\"\n          p2_count: \"Accumulate from severity_counts\"\n          stuck_count: |\n            if status == 'thought': unchanged (skip)\n            if status == 'insight': 0 (reset)\n            if newFindingsRatio <= 0.05: stuck_count + 1\n            else: 0\n        log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into review/review-report.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n            --loop-type review \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n        bind_from_output:\n          p0_count: \"active_p0\"\n          p1_count: \"active_p1\"\n          p2_count: \"active_p2\"\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - p0_count: \"Total P0 findings across all iterations (deduped)\"\n          - p1_count: \"Total P1 findings across all iterations (deduped)\"\n          - p2_count: \"Total P2 findings across all iterations (deduped)\"\n          - dimensions_covered: \"List of reviewed dimensions\"\n          - dimension_coverage: \"covered / total\"\n          - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records\"\n          - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n      # - PASS: no P0 or P1 findings (P2-only or clean)\n      # - CONDITIONAL: any P1 findings (no P0)\n      # - FAIL: any P0 findings\n      # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n      step_derive_verdict:\n        action: \"Derive review verdict from accumulated findings\"\n        algorithm: |\n          if p0_count > 0:\n            verdict = \"FAIL\"\n          elif p1_count > 0:\n            verdict = \"CONDITIONAL\"\n          else:\n            verdict = \"PASS\"\n          has_advisories = (verdict == \"PASS\" and p2_count > 0)\n          ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n        outputs:\n          - verdict: \"PASS | CONDITIONAL | FAIL\"\n          - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n          - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n        contract: |\n          Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n          Downstream automation parses this final line via exact string match — do not vary the format.\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_build_finding_registry:\n        action: \"Build deduplicated finding registry from all iterations\"\n        algorithm: |\n          1. Extract all findings from iteration JSONL delta files\n          2. Compute content_hash for each finding (emission requirement):\n             content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n             Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n          3. Two-tier dedup:\n             PRIMARY: group by content_hash field\n               - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n               - Keep highest severity on duplicates\n             FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n               - Same file:line, multiple dimensions → single finding, multiple dimension tags\n               - Keep highest severity on duplicates\n          4. Track finding lifecycle:\n             - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n             - Record first_seen, upgraded_in, previous_severity for severity changes\n             - Record dimensions array reflecting all dimensions that emitted this finding\n          5. Resolve contradictions:\n             - Findings marked contested across iterations → referee pass\n             - Determine final severity and status\n          6. Count only 'active' findings for totals\n        outputs:\n          - finding_registry: \"Deduplicated list of all findings with metadata\"\n          - active_p0: \"Count of active P0 findings\"\n          - active_p1: \"Count of active P1 findings\"\n          - active_p2: \"Count of active P2 findings\"\n\n      step_adversarial_selfcheck:\n        action: \"Final adversarial self-check on all P0 and P1 findings\"\n        algorithm: |\n          For each active P0/P1 finding:\n            1. Hunter: Re-verify finding against source code (re-read file:line)\n            2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n            3. Referee: Final call — confirm, downgrade, or mark false_positive\n          Update finding_registry with adjudicated results.\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-review/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_resource_map_coverage_gate:\n        action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n        note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n\n      step_compile_review_report:\n        action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n        instructions: |\n          Create review/review-report.md with the following sections:\n\n          1. **Executive Summary**\n             - Overall verdict: PASS | CONDITIONAL | FAIL\n             - hasAdvisories: true when PASS carries active P2 items\n             - P0/P1/P2 counts (active only)\n             - Review scope summary\n\n          2. **Planning Trigger**\n             - State whether `/speckit:plan` is required\n             - Include a fenced `json` block labeled `Planning Packet`\n             - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n             - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n\n          3. **Active Finding Registry**\n             - Unified registry for active P0/P1/P2 findings\n             - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n\n          4. **Remediation Workstreams**\n             - Ordered action groups: P0 first, then P1, with P2 advisories separated\n\n          5. **Spec Seed**\n             - Concrete seed bullets for follow-on spec updates\n\n          6. **Plan Seed**\n             - Concrete starter tasks for `/speckit:plan`\n\n           7. **Traceability Status**\n              - Summarize required core protocols first, then applicable overlay protocols\n              - Include status, evidence, and any unresolved drift per protocol\n              - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n\n          If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n             - `Entries touched`: count of resource-map paths that appear in applied reports\n             - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n             - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n\n          8. **Deferred Items**\n             - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n\n          9. **Search Ledger**\n             - Always include this section before the appendix.\n             - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n             - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n             - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n\n          10. **Audit Appendix**\n             - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n             - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n        output: \"{state_paths.review_output}\"\n\n      step_convergence_report:\n        action: \"Append convergence report to JSONL\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"synthesis_complete\",\"mode\":\"review\",\"totalIterations\":{iteration_count},\"activeP0\":{active_p0},\"activeP1\":{active_p1},\"activeP2\":{active_p2},\"dimensionCoverage\":{dimension_coverage},\"verdict\":\"{verdict}\",\"releaseReadinessState\":\"{release_readiness_state}\",\"stopReason\":\"{reason}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n        note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add review-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, findings-registry, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve review context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed review loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep review completed; see review/review-report.md for verdict, findings, and workstreams.\",\n            \"observations\": [\"Summarize the active findings, verdict, and remediation guidance.\"],\n            \"recent_context\": [\"Point to the generated review artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep review complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n      Verdict: {verdict} | hasAdvisories={has_advisories}\n\n      Artifacts:\n        - review/review-report.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in review/iterations/\n        - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n      - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n      - \"/deep:review [target] (for another review)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer files per iteration). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the review packet in review/ as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_review_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n    - treat_review_target_as_read_only\n    - deduplicate_findings_before_synthesis\n    - run_adversarial_selfcheck_on_p0_p1\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n    - modify_files_under_review\n    - report_p0_without_file_line_evidence\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.findings_registry} {state_paths.strategy} {state_paths.review_output}\"\n      - 'git commit -m \"chore(deep-review): iteration {NNN} complete\"'\n  severity_weights:","lineStart":639,"lineEnd":1436,"totalLines":1437,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1782750460002,"end":1782750460013}},"id":"prt_f14353860001S4ZE4W9Y8wlQqd","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f14350496001gx0zfXBqjHj7Pj"}}
