{"type":"tool_use","timestamp":1784313654702,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_sJK1cA7twqnHsmoysVK6f3Iq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":930,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n930: \n931: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n932:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n933:   const loaded = readWaitCheckpoint(checkpointPath, context);\n934:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n935:     return { didWait: false, migrated: loaded.migrated };\n936:   }\n937: \n938:   appendFanoutStatusLedger(ledgerPath, {\n939:     event: 'resume_waiting',\n940:     at: new Date().toISOString(),\n941:     run_id: runId,\n942:     loop_type: loopType,\n943:     spec_folder: specFolder,\n944:     nextRunAt: loaded.checkpoint.nextRunAt,\n945:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n946:   });\n947: \n948:   await waitUntilCheckpointExpires({\n949:     checkpointPath,\n950:     checkpoint: loaded.checkpoint,\n951:     context: { runId, loopType, specFolder },\n952:   });\n953: \n954:   appendFanoutStatusLedger(ledgerPath, {\n955:     event: 'resume_waiting_complete',\n956:     at: new Date().toISOString(),\n957:     run_id: runId,\n958:     loop_type: loopType,\n959:     spec_folder: specFolder,\n960:   });\n961: \n962:   return { didWait: true, migrated: loaded.migrated };\n963: }\n964: \n965: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n966:   const durationMs = normalizeWaitDurationMs(waitMs);\n967:   if (durationMs <= 0) {\n968:     return { didWait: false };\n969:   }\n970: \n971:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n972:   atomicWriteJson(checkpointPath, checkpoint);\n973:   appendFanoutStatusLedger(ledgerPath, {\n974:     event: 'wait_checkpoint_persisted',\n975:     at: checkpoint.updatedAt,\n976:     run_id: runId,\n977:     loop_type: loopType,\n978:     spec_folder: specFolder,\n979:     nextRunAt: checkpoint.nextRunAt,\n980:     remainingDelayMs: checkpoint.remainingDelayMs,\n981:   });\n982: \n983:   await waitUntilCheckpointExpires({\n984:     checkpointPath,\n985:     checkpoint,\n986:     context: { runId, loopType, specFolder },\n987:   });\n988: \n989:   appendFanoutStatusLedger(ledgerPath, {\n990:     event: 'wait_checkpoint_cleared',\n991:     at: new Date().toISOString(),\n992:     run_id: runId,\n993:     loop_type: loopType,\n994:     spec_folder: specFolder,\n995:   });\n996: \n997:   return { didWait: true };\n998: }\n999: \n1000: /**\n1001:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1002:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1003:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1004:  */\n1005: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1006:   assertActiveFanoutLoopType(loopType);\n1007:   const skillFile =\n1008:     loopType === 'review'\n1009:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1010:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1011:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1012:   const detachedIntro = lineage.kind === 'cli-opencode'\n1013:     ? [\n1014:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1015:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1016:         ``,\n1017:       ]\n1018:     : lineage.kind === 'native'\n1019:       ? [\n1020:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1021:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1022:           ``,\n1023:         ]\n1024:       : [];\n1025:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1026:   const stopPolicy = options.stopPolicy || 'convergence';\n1027:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1028:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1029:     : hasIterationCap\n1030:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1031:       : 'to legal convergence';\n1032:   const params = [\n1033:     `  spec_folder: ${specFolder}`,\n1034:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1035:     `  session_id: ${sessionId}`,\n1036:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1037:     `  loop_type: ${loopType}`,\n1038:     `  config.stopPolicy: ${stopPolicy}`,\n1039:   ];\n1040:   if (researchTopic) {\n1041:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1042:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1043:     // Review loops scope by spec_folder and intentionally pass no topic.\n1044:     params.push(`  research_topic: ${researchTopic}`);\n1045:   }\n1046:   if (hasIterationCap) {\n1047:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1048:   }\n1049:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1050:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1051:   }\n1052:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1053:   // still requires the same review setup bindings the native command path pre-binds.\n1054:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1055:   // different setup contract than native lineages.\n1056:   const setupBindings =\n1057:     loopType === 'review'\n1058:       ? [\n1059:           ``,\n1060:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1061:           `review_target: ${specFolder}`,\n1062:           `review_target_type: spec-folder`,\n1063:           `review_dimensions: all`,\n1064:           `spec_folder: ${specFolder}`,\n1065:           `execution_mode: AUTONOMOUS`,\n1066:           `lineage_mode: auto`,\n1067:           ``,\n1068:         ]\n1069:       : [];\n1070:   return [\n1071:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1072:     ...detachedIntro,\n1073:     ``,\n1074:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1075:     ...params,\n1076:     ...setupBindings,\n1077:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1078:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1079:     `command; bind artifact_dir directly to the override value.`,\n1080:     ``,\n1081:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1082:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1083:     ``,\n1084:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1085:   ].join('\\n');\n1086: }\n1087: \n1088: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1089:   assertActiveFanoutLoopType(loopType);\n1090:   const maxIterations = lineage.iterations || 12;\n1091:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1092:   const stopPolicy = options.stopPolicy || 'convergence';\n1093:   const sessionId = options.sessionId || '';\n1094:   const args = [\n1095:     ':auto',\n1096:     JSON.stringify(specFolder),\n1097:     `--spec-folder=${specFolder}`,\n1098:     `--max-iterations=${maxIterations}`,\n1099:     `--convergence=${convergenceThreshold}`,\n1100:     `--stop-policy=${stopPolicy}`,\n1101:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1102:     '--lineage-mode=auto',\n1103:   ];\n1104:   if (loopType === 'research' && options.researchTopic) {\n1105:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1106:   }\n1107: \n1108:   return [\n1109:     args.join(' '),\n1110:     '',\n1111:     'PRE-BOUND SETUP ANSWERS:',\n1112:     `review_target: ${specFolder}`,\n1113:     'review_target_type: spec-folder',\n1114:     'review_dimensions: all',\n1115:     `spec_folder: ${specFolder}`,\n1116:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1117:     'execution_mode: AUTONOMOUS',\n1118:     'lineage_mode: auto',\n1119:     `maxIterations: ${maxIterations}`,\n1120:     `convergenceThreshold: ${convergenceThreshold}`,\n1121:     `stop_policy: ${stopPolicy}`,\n1122:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1123:   ].join('\\n');\n1124: }\n1125: \n1126: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1127: // ceiling and a positive override may only narrow it, never widen past it.\n1128: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1129: \n1130: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1131:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1132:     throw inputError(\n1133:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1134:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1135:     );\n1136:   }\n1137: }\n1138: \n1139: /**\n1140:  * Compute a generous timeout for a full lineage loop run.\n1141:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1142:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1143:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1144:  */\n1145: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1146:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1147:   const iters = lineage.iterations || 12;\n1148:   const perIterSecs = lineage.timeoutSeconds || 900;\n1149:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1150:     ? ceilingHoursOverride * 60 * 60 * 1000\n1151:     : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n1152:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1153: }\n1154: \n1155: function normalizeProgressHeartbeatMs(seconds) {\n1156:   const value = Number(seconds);\n1157:   if (!Number.isFinite(value) || value <= 0) return 0;\n1158:   return Math.max(1, Math.floor(value * 1000));\n1159: }\n1160: \n1161: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1162:   const explicit = readRawConfigNumber(rawConfig, [\n1163:     'postExitGraceMs',\n1164:     'post_exit_grace_ms',\n1165:     'postSubprocessExitGraceMs',\n1166:     'post_subprocess_exit_grace_ms',\n1167:     'orchestratorPostExitGraceMs',\n1168:     'orchestrator_post_exit_grace_ms',\n1169:   ], 'postExitGraceMs');\n1170:   if (explicit !== null) return explicit;\n1171: \n1172:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1173:     ? progressHeartbeatMs * 2\n1174:     : 0;\n1175:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1176: }\n1177: \n1178: function slotDurationMsFromHrtime(hrStart) {\n1179:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1180:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1181: }\n1182: \n1183: function computeSkippedCount(slotDurationMs, intervalMs) {\n1184:   const elapsed = Number(slotDurationMs);\n1185:   const interval = Number(intervalMs);\n1186:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1187:     return 0;\n1188:   }\n1189:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1190: }\n1191: \n1192: function buildSlotAccounting(hrStart, intervalMs) {\n1193:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1194:   return {\n1195:     slotDurationMs,\n1196:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1197:   };\n1198: }\n1199: \n1200: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1201:   if (!event || typeof event.label !== 'string') return event;\n1202:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1203: \n1204:   const accounting = accountingByLabel.get(event.label);\n1205:   if (!accounting) return event;\n1206:   return {\n1207:     ...event,\n1208:     skippedCount: accounting.skippedCount,\n1209:     slotDurationMs: accounting.slotDurationMs,\n\n(Showing lines 930-1209 of 2021. Use offset=1210 to continue.)\n</content>","metadata":{"preview":"\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n      : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n// Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n// ceiling and a positive override may only narrow it, never widen past it.\nconst LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n\nfunction assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n  if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n    throw inputError(\n      `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n        + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n    );\n  }\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,","lineStart":930,"lineEnd":1209,"totalLines":2021,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784313654684,"end":1784313654700}},"metadata":{"openai":{"itemId":"fc_0a75312c601b7e8e016a5a773681e081919d03614d2fd4b383"}},"id":"prt_f7161ad13001Prtx03GYyOduNf","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161806e001Yr5w9CB85Z4se9"}}
{"type":"tool_use","timestamp":1784313654706,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_2yQkjSpzPCyjj4HMHjAJ4OS6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":720,"limit":650},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n720:               step_prepare_divergent_pivot:\n721:                 action: \"Generate state-grounded research candidates and prepare or resume the pivot transaction\"\n722:                 command: |\n723:                   node --experimental-strip-types --input-type=module <<'EOF'\n724:                   import {\n725:                     buildResearchPivotPreparationInput,\n726:                     renderResearchPivotSeatPrompt,\n727:                   } from './.opencode/skills/system-deep-loop/deep-research/scripts/divergent-research-pivot.ts';\n728:                   import {\n729:                     preparePivotTransaction,\n730:                   } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n731: \n732:                   const input = buildResearchPivotPreparationInput({\n733:                     artifactRoot: '{state_paths.packet_dir}',\n734:                     configPath: '{state_paths.config}',\n735:                     stateLogPath: '{state_paths.state_log}',\n736:                     strategyPath: '{state_paths.strategy}',\n737:                     registryPath: '{state_paths.registry}',\n738:                     currentIteration: Number('{current_iteration}'),\n739:                     maxIterations: Number('{max_iterations}'),\n740:                     triggerReason: '{reason}',\n741:                   });\n742:                   const prepared = await preparePivotTransaction(input);\n743:                   const seatPrompts = prepared.status === 'pending'\n744:                     ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n745:                         seat.id,\n746:                         renderResearchPivotSeatPrompt(seat, prepared.dispatchContext),\n747:                       ]))\n748:                     : {};\n749:                   process.stdout.write(`${JSON.stringify({\n750:                     ...prepared,\n751:                     seatPrompts,\n752:                     boundaryRejections: input.boundaryRejections,\n753:                   })}\\n`);\n754:                   EOF\n755:                 working_directory: \"{repo_root}\"\n756:                 outputs:\n757:                   - pivot_prepare_json: \"The complete parsed JSON result\"\n758:                   - pivot_prepare_status: \"status from the prepare result\"\n759:                   - pivot_id: \"pivotId from the prepare result\"\n760:                   - pivot_paths_json: \"paths from the prepare result as JSON\"\n761:                   - pivot_resumed: \"resumed from the prepare result\"\n762:                   - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n763:                   - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n764:                   - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n765:                   - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n766:                   - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n767:                   - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n768:                   - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n769:                   - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n770:                 short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n771: \n772:               step_dispatch_pivot_seat_001:\n773:                 action: \"Natively dispatch the analytical research direction-selection seat\"\n774:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n775:                 capture_timing: true\n776:                 if_native:\n777:                   dispatch:\n778:                     agent: deep-research\n779:                     model: opus\n780:                     context_source: \"pivot_seat_001_prompt\"\n781:                   wait_for_completion: true\n782:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n783:                 outputs:\n784:                   - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n785:                   - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n786:                   - pivot_seat_001_error_json: \"{name,message} when rejected\"\n787:                   - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n788:                   - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n789:                   - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n790: \n791:               step_record_pivot_seat_001:\n792:                 action: \"Durably record the seat-001 native dispatch outcome\"\n793:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n794:                 command: |\n795:                   node --experimental-strip-types --input-type=module <<'EOF'\n796:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n797:                   const status = '{pivot_seat_001_dispatch_status}';\n798:                   const outcome = status === 'fulfilled'\n799:                     ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n800:                     : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n801:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n802:                   EOF\n803:                 working_directory: \"{repo_root}\"\n804: \n805:               step_dispatch_pivot_seat_002:\n806:                 action: \"Natively dispatch the critical research direction-selection seat\"\n807:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n808:                 capture_timing: true\n809:                 if_native:\n810:                   dispatch:\n811:                     agent: deep-research\n812:                     model: opus\n813:                     context_source: \"pivot_seat_002_prompt\"\n814:                   wait_for_completion: true\n815:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n816:                 outputs:\n817:                   - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n818:                   - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n819:                   - pivot_seat_002_error_json: \"{name,message} when rejected\"\n820:                   - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n821:                   - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n822:                   - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n823: \n824:               step_record_pivot_seat_002:\n825:                 action: \"Durably record the seat-002 native dispatch outcome\"\n826:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n827:                 command: |\n828:                   node --experimental-strip-types --input-type=module <<'EOF'\n829:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n830:                   const status = '{pivot_seat_002_dispatch_status}';\n831:                   const outcome = status === 'fulfilled'\n832:                     ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n833:                     : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n834:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n835:                   EOF\n836:                 working_directory: \"{repo_root}\"\n837: \n838:               step_dispatch_pivot_seat_003:\n839:                 action: \"Natively dispatch the pragmatic research direction-selection seat\"\n840:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n841:                 capture_timing: true\n842:                 if_native:\n843:                   dispatch:\n844:                     agent: deep-research\n845:                     model: opus\n846:                     context_source: \"pivot_seat_003_prompt\"\n847:                   wait_for_completion: true\n848:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n849:                 outputs:\n850:                   - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n851:                   - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n852:                   - pivot_seat_003_error_json: \"{name,message} when rejected\"\n853:                   - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n854:                   - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n855:                   - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n856: \n857:               step_record_pivot_seat_003:\n858:                 action: \"Durably record the seat-003 native dispatch outcome\"\n859:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n860:                 command: |\n861:                   node --experimental-strip-types --input-type=module <<'EOF'\n862:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n863:                   const status = '{pivot_seat_003_dispatch_status}';\n864:                   const outcome = status === 'fulfilled'\n865:                     ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n866:                     : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n867:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n868:                   EOF\n869:                 working_directory: \"{repo_root}\"\n870: \n871:               step_finalize_divergent_pivot:\n872:                 action: \"Finalize the prepared pivot after all missing native seats are durable\"\n873:                 skip_when: \"pivot_prepare_status != 'pending'\"\n874:                 command: |\n875:                   node --experimental-strip-types --input-type=module <<'EOF'\n876:                   import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n877:                   process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n878:                   EOF\n879:                 working_directory: \"{repo_root}\"\n880:                 outputs:\n881:                   - pivot_finalize_json: \"The complete parsed final result\"\n882: \n883:               step_resolve_divergent_pivot_result:\n884:                 action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n885:                 branch_on: \"pivot_prepare_status\"\n886:                 if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n887:                 if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n888: \n889:               step_apply_divergent_pivot_result:\n890:                 action: \"Adopt a successful focus or fail closed to the existing synthesis path\"\n891:                 branch_on: \"pivot_result.status\"\n892:                 if_completed:\n893:                   set:\n894:                     next_focus: \"{pivot_result.restoredFocus}\"\n895:                     pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n896:                     saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n897:                   command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n898:                   log: \"Divergent pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n899:                   proceed_to: step_rejected_pattern_cache\n900:                 if_failed:\n901:                   log: \"Divergent pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n902:                   skip_to: phase_synthesis\n903:             on_error:\n904:               log: \"Divergent pivot integration error; failing closed to the existing synthesis path.\"\n905:               skip_to: phase_synthesis\n906:           if_existing_terminal_path:\n907:             log: \"Loop stopping. Reason: {reason}\"\n908:             skip_to: phase_synthesis\n909:         if_stuck_recovery:\n910:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n911:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n912:           set: { next_focus: \"RECOVERY: Widen scope. Try fundamentally different approach. Least-explored question: {least_explored}\" }\n913:           reset: { stuck_count: 0 }\n914:         if_continue:\n915:           log: \"Iteration {current_iteration}: Continuing. Focus: {next_focus}\"\n916: \n917:       step_rejected_pattern_cache:\n918:         action: \"Apply reducer-derived rejected-pattern suppression before dispatch candidate selection\"\n919:         read:\n920:           - \"{state_paths.state_log}\"\n921:           - \"{state_paths.registry}\"\n922:           - \"{state_paths.strategy}\"\n923:         candidate_sources:\n924:           next_focus:\n925:             category: \"next-focus\"\n926:             values:\n927:               - \"{next_focus}\"\n928:               - \"{remaining_questions_list}\"\n929:               - \"{carried_forward_open_questions}\"\n930:           recovery:\n931:             category: \"recovery\"\n932:             values:\n933:               - \"{recovery_strategy}\"\n934:               - \"{least_explored}\"\n935:           ideas:\n936:             category: \"ideas\"\n937:             values:\n938:               - \"{promoted_ideas_list}\"\n939:             optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n940:         algorithm: |\n941:           Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n942:           reducer pass as the source of truth.\n943:           Compare normalized exact text first. Then compare fuzzy similarity with\n944:           rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n945:           are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n946:           selection before rendering the dispatch prompt. If all candidates are suppressed,\n947:           halt for operator input instead of reusing a rejected idea.\n948:         outputs:\n949:           - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n950:           - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n951:           - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n952:           - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n953:         if_next_focus_suppressed:\n954:           set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n955:           log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n956:         if_all_candidates_suppressed:\n957:           halt: true\n958:           message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n959: \n960:       step_ideas_backlog_lifecycle:\n961:         action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n962:         read:\n963:           - \"{state_paths.state_log}\"\n964:           - \"{state_paths.registry}\"\n965:           - \"{state_paths.config}\"\n966:         lifecycle:\n967:           observed_event: \"idea_observed\"\n968:           promoted_event: \"idea_promoted\"\n969:           rejected_event: \"idea_rejected\"\n970:           min_observations: \"{min_idea_observations}\"\n971:           authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n972:         validate:\n973:           - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n974:           - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n975:           - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n976:         outputs:\n977:           - observed_ideas_count: \"Reducer-derived observed ideas count\"\n978:           - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n979:           - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n980:           - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n981: \n982:       step_normalize_pause_events:\n983:         action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n984:         stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n985:         rule_pause_sentinel:\n986:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n987:           canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n988:         rule_stuck_recovery:\n989:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n990:           canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n991: \n992:       step_marker_scan:\n993:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n994:         algorithm: |\n995:           if current_iteration > 1:\n996:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n997:             if file_exists(PREV_PROMPT_PATH):\n998:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n999:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n1000:                 log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n1001:                 halt with exit code 2\n1002:         note: |\n1003:           False-positive prevention: only matches when the first line is exactly one of the\n1004:           three canonical markers. Markers appearing in comments or body text are ignored.\n1005:           True-positive triggers only when a previous iteration's rendered prompt literally\n1006:           starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n1007: \n1008:       step_dispatch_iteration:\n1009:         action: \"Dispatch one iteration via the selected executor\"\n1010:         resolve_executor:\n1011:           source: \"config.executor\"\n1012:           loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n1013:         pre_dispatch:\n1014:           generate_summary: |\n1015:             STATE SUMMARY (auto-generated):\n1016:             Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n1017:             Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n1018:             Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n1019:             {resource_map_prompt_line}\n1020:             {memory_context_prompt_line}\n1021:             Next focus: {next_focus}\n1022:           render_prompt_pack:\n1023:             template_path: \".opencode/skills/system-deep-loop/deep-research/assets/prompt_pack_iteration.md.tmpl\"\n1024:             renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n1025:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n1026:             variables:\n1027:               state_summary: \"{state_summary}\"\n1028:               research_topic: \"{research_topic}\"\n1029:               current_iteration: \"{current_iteration}\"\n1030:               max_iterations: \"{max_iterations}\"\n1031:               next_focus: \"{next_focus}\"\n1032:               remaining_questions_list: \"{remaining_questions_list}\"\n1033:               carried_forward_open_questions: \"{carried_forward_open_questions}\"\n1034:               last_3_summaries: \"{last_3_summaries}\"\n1035:               pivot_lineage: \"{pivot_lineage}\"\n1036:               saturated_directions: \"{saturated_directions}\"\n1037:               state_paths_config: \"{state_paths.config}\"\n1038:               state_paths_state_log: \"{state_paths.state_log}\"\n1039:               state_paths_strategy: \"{state_paths.strategy}\"\n1040:               state_paths_registry: \"{state_paths.registry}\"\n1041:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n1042:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n1043:         pre_dispatch_audit:\n1044:           skip_when: \"config.executor.type == 'native'\"\n1045:           call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n1046:           args:\n1047:             stateLogPath: \"{state_paths.state_log}\"\n1048:             executor: \"{config.executor}\"\n1049:             iteration: \"{current_iteration}\"\n1050:         branch_on: \"config.executor.type\"\n1051:         if_native:\n1052:           dispatch:\n1053:             agent: deep-research\n1054:             model: opus\n1055:             context_source: \"rendered_prompt_pack\"\n1056:           wait_for_completion: true\n1057:         if_cli_claude_code:\n1058:           command: |\n1059:             node --experimental-strip-types --input-type=module <<'EOF'\n1060:             import { readFileSync } from 'node:fs';\n1061:             import { createHash } from 'node:crypto';\n1062: \n1063:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1064:             import { resolveClaudePermissionMode } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n1065: \n1066:             const executor = {\n1067:               kind: 'cli-claude-code',\n1068:               model: '{config.executor.model}',\n1069:               reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n1070:               serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n1071:               sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n1072:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1073:             };\n1074:             const args = [\n1075:               '-p',\n1076:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n1077:               '--model',\n1078:               executor.model,\n1079:               '--permission-mode',\n1080:               resolveClaudePermissionMode(executor.sandboxMode),\n1081:               '--output-format',\n1082:               'text',\n1083:             ];\n1084:             if (executor.reasoningEffort) {\n1085:               args.push('--effort', executor.reasoningEffort);\n1086:             }\n1087: \n1088:             const dispatchFacts = {\n1089:               command: 'deep/research',\n1090:               mode: 'research',\n1091:               specFolder: '{spec_folder}',\n1092:               artifactDir: '{state_paths.packet_dir}',\n1093:               iteration: Number('{current_iteration}'),\n1094:               executorKind: '{config.executor.type}',\n1095:               branchId: '{config.executor.type}',\n1096:               sessionId: '{config.lineage.sessionId}',\n1097:               generation: Number('{config.lineage.generation}'),\n1098:             };\n1099:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n1100:             process.exit(\n1101:               runAuditedExecutorCommand({\n1102:                 command: 'claude',\n1103:                 args,\n1104:                 cwd: '{repo_root}',\n1105:                 timeoutSeconds: executor.timeoutSeconds,\n1106:                 stateLogPath: '{state_paths.state_log}',\n1107:                 executor,\n1108:                 iteration: Number('{current_iteration}'),\n1109:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1110:                 dispatchId,\n1111:               }),\n1112:             );\n1113:             EOF\n1114:           working_directory: \"{repo_root}\"\n1115:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1116:           wait_for_completion: true\n1117:           notes:\n1118:             - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n1119:             - \"claude-code has no serviceTier flag\"\n1120:             - \"claude-code supports --effort for reasoning depth\"\n1121:         record_executor_audit:\n1122:           skip_when: \"config.executor.type == 'native'\"\n1123:           target: \"{state_paths.state_log}\"\n1124:           field: \"executor\"\n1125:           value:\n1126:             kind: \"{config.executor.type}\"\n1127:             model: \"{config.executor.model}\"\n1128:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1129:             serviceTier: \"{config.executor.serviceTier}\"\n1130:         if_cli_opencode:\n1131:           command: |\n1132:             node --experimental-strip-types --input-type=module <<'EOF'\n1133:             import { readFileSync } from 'node:fs';\n1134:             import { createHash } from 'node:crypto';\n1135: \n1136:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1137: \n1138:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1139:             const executor = {\n1140:               kind: 'cli-opencode',\n1141:               model: '{config.executor.model}',\n1142:               configDir: null,\n1143:               reasoningEffort,\n1144:               serviceTier: null,\n1145:               sandboxMode: null,\n1146:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1147:               governor: null,\n1148:             };\n1149:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1150:             const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n1151:               + '\\n\\n'\n1152:               + promptBody;\n1153:             const args = [\n1154:               'run',\n1155:               '--model',\n1156:               executor.model,\n1157:               '--format',\n1158:               'json',\n1159:               '--dangerously-skip-permissions',\n1160:               '--pure',\n1161:               '--dir',\n1162:               '{repo_root}',\n1163:             ];\n1164:             if (executor.reasoningEffort) {\n1165:               args.push('--variant', executor.reasoningEffort);\n1166:             }\n1167:             args.push(message);\n1168: \n1169:             const dispatchFacts = {\n1170:               command: 'deep/research',\n1171:               mode: 'research',\n1172:               specFolder: '{spec_folder}',\n1173:               artifactDir: '{state_paths.packet_dir}',\n1174:               iteration: Number('{current_iteration}'),\n1175:               executorKind: '{config.executor.type}',\n1176:               branchId: '{config.executor.type}',\n1177:               sessionId: '{config.lineage.sessionId}',\n1178:               generation: Number('{config.lineage.generation}'),\n1179:             };\n1180:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n1181:             process.exit(\n1182:               runAuditedExecutorCommand({\n1183:                 command: 'opencode',\n1184:                 args,\n1185:                 cwd: '{repo_root}',\n1186:                 timeoutSeconds: executor.timeoutSeconds,\n1187:                 stateLogPath: '{state_paths.state_log}',\n1188:                 executor,\n1189:                 iteration: Number('{current_iteration}'),\n1190:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1191:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1192:                 input: '',\n1193:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1194:                 dispatchId,\n1195:               }),\n1196:             );\n1197:             EOF\n1198:           working_directory: \"{repo_root}\"\n1199:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1200:           wait_for_completion: true\n1201:           notes:\n1202:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1203:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n1204:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1205:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1206:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1207:             - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1208:         if_cli_codex:\n1209:           command: |\n1210:             node --experimental-strip-types --input-type=module <<'EOF'\n1211:             import { readFileSync } from 'node:fs';\n1212:             import { execFileSync } from 'node:child_process';\n1213: \n1214:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1215: \n1216:             // Fail closed: a requested codex executor must dispatch codex or abort,\n1217:             // never silently degrade to another executor. Undetected absence is what\n1218:             // got Codex deprecated before, so the branch exits non-zero when the\n1219:             // binary is missing instead of falling through to a native/other path.\n1220:             let codexAvailable = false;\n1221:             try {\n1222:               execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n1223:               codexAvailable = true;\n1224:             } catch {}\n1225:             if (!codexAvailable) {\n1226:               console.error('cli-codex executor unavailable: command -v codex failed');\n1227:               process.exit(1);\n1228:             }\n1229: \n1230:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1231:             const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n1232:             const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n1233:             const executor = {\n1234:               kind: 'cli-codex',\n1235:               model,\n1236:               configDir: null,\n1237:               reasoningEffort,\n1238:               serviceTier,\n1239:               sandboxMode: 'workspace-write',\n1240:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1241:               governor: null,\n1242:             };\n1243: \n1244:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1245: \n1246:             // codex reads the iteration prompt from stdin via the trailing '-'. A research\n1247:             // iteration must WRITE its own iteration file, delta and state record, so the\n1248:             // sandbox is workspace-write — read-only would block those required writes.\n1249:             // approval_policy=never keeps the run non-interactive.\n1250:             const args = ['exec'];\n1251:             if (model) {\n1252:               args.push('--model', model);\n1253:             }\n1254:             args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n1255:             if (serviceTier) {\n1256:               args.push('-c', 'service_tier=' + serviceTier);\n1257:             }\n1258:             args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n1259: \n1260:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n1261:             process.exit(\n1262:               runAuditedExecutorCommand({\n1263:                 command: 'codex',\n1264:                 args,\n1265:                 cwd: '{repo_root}',\n1266:                 timeoutSeconds: executor.timeoutSeconds,\n1267:                 stateLogPath: '{state_paths.state_log}',\n1268:                 executor,\n1269:                 iteration: Number('{current_iteration}'),\n1270:                 input: promptBody,\n1271:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1272:                 dispatchId,\n1273:               }),\n1274:             );\n1275:             EOF\n1276:           working_directory: \"{repo_root}\"\n1277:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1278:           wait_for_completion: true\n1279:           notes:\n1280:             - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n1281:             - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n1282:             - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n1283:             - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n1284:         post_dispatch_validate:\n1285:           validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1286:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1287:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1288:           assert_exists: \"{state_paths.iteration_pattern}\"\n1289:           assert_appended: \"{state_paths.state_log}\"\n1290:           assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n1291:           route_proof:\n1292:             mode: research\n1293:             target_agent: deep-research\n1294:             agent_definition_loaded: true\n1295:             resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n1296:           dispatchReceipt:\n1297:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1298:             dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n1299:           optional_jsonl_fields:\n1300:             logOffset: \"Byte offset where the seekable log region starts\"\n1301:             logSize: \"Byte length of the seekable log region\"\n1302:             logPath: \"Absolute path to the file containing the seekable log region\"\n1303:             skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n1304:             slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n1305:           assert_canonical_type: \"iteration\"\n1306:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1307:           assert_delta_file_has_iteration_record: true\n1308:           on_failure:\n1309:             action: \"emit schema_mismatch canonical conflict event\"\n1310:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n1311:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1312:           failure_reasons_reference:\n1313:             - \"iteration_file_missing — iteration narrative markdown not written\"\n1314:             - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n1315:             - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n1316:             - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n1317:             - \"jsonl_parse_error — last state-log line is not valid JSON\"\n1318:             - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n1319:             - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n1320:             - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n1321:             - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n1322:             - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n1323:             - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n1324:             - \"executor_missing — non-native executor did not record provenance\"\n1325:             - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n1326: \n1327:       step_run_now_restore_check:\n1328:         action: \"Record a run-now sentinel recreated during the completed dispatch\"\n1329:         command: |\n1330:           node <<'EOF'\n1331:           const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n1332: \n1333:           const stateLogPath = \"{state_paths.state_log}\";\n1334:           const sentinelPath = \"{state_paths.run_now_sentinel}\";\n1335:           const timestamp = \"{ISO_8601_NOW}\";\n1336:           const sessionId = \"{config.lineage.sessionId}\";\n1337:           const generation = Number(\"{config.lineage.generation}\");\n1338:           const run = Number(\"{current_iteration}\");\n1339: \n1340:           function hasAcceptedCurrentRun() {\n1341:             if (!existsSync(stateLogPath)) return false;\n1342:             const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n1343:             for (let index = lines.length - 1; index >= 0; index -= 1) {\n1344:               const record = JSON.parse(lines[index]);\n1345:               if (record.run !== run || record.sessionId !== sessionId) continue;\n1346:               if (record.event === \"run_now_accepted\") return true;\n1347:               if (record.event === \"run_now_rejected\") return false;\n1348:             }\n1349:             return false;\n1350:           }\n1351: \n1352:           if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n1353:             appendFileSync(\n1354:               stateLogPath,\n1355:               `${JSON.stringify({\n1356:                 type: \"event\",\n1357:                 event: \"run_now_restored\",\n1358:                 mode: \"research\",\n1359:                 run,\n1360:                 sentinelPath,\n1361:                 timestamp,\n1362:                 sessionId,\n1363:                 generation,\n1364:               })}\\n`,\n1365:               \"utf8\",\n1366:             );\n1367:           }\n1368:           EOF\n1369:         outputs:\n\n(Showing lines 720-1369 of 2012. Use offset=1370 to continue.)\n</content>","metadata":{"preview":"              step_prepare_divergent_pivot:\n                action: \"Generate state-grounded research candidates and prepare or resume the pivot transaction\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import {\n                    buildResearchPivotPreparationInput,\n                    renderResearchPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-research/scripts/divergent-research-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildResearchPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"              step_prepare_divergent_pivot:\n                action: \"Generate state-grounded research candidates and prepare or resume the pivot transaction\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import {\n                    buildResearchPivotPreparationInput,\n                    renderResearchPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-research/scripts/divergent-research-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildResearchPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),\n                    triggerReason: '{reason}',\n                  });\n                  const prepared = await preparePivotTransaction(input);\n                  const seatPrompts = prepared.status === 'pending'\n                    ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n                        seat.id,\n                        renderResearchPivotSeatPrompt(seat, prepared.dispatchContext),\n                      ]))\n                    : {};\n                  process.stdout.write(`${JSON.stringify({\n                    ...prepared,\n                    seatPrompts,\n                    boundaryRejections: input.boundaryRejections,\n                  })}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_prepare_json: \"The complete parsed JSON result\"\n                  - pivot_prepare_status: \"status from the prepare result\"\n                  - pivot_id: \"pivotId from the prepare result\"\n                  - pivot_paths_json: \"paths from the prepare result as JSON\"\n                  - pivot_resumed: \"resumed from the prepare result\"\n                  - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n                  - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n                  - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n                  - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n                  - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n                  - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n                  - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n                  - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n                short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n\n              step_dispatch_pivot_seat_001:\n                action: \"Natively dispatch the analytical research direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-research\n                    model: opus\n                    context_source: \"pivot_seat_001_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n                outputs:\n                  - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_001_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_001:\n                action: \"Durably record the seat-001 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_001_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_002:\n                action: \"Natively dispatch the critical research direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-research\n                    model: opus\n                    context_source: \"pivot_seat_002_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n                outputs:\n                  - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_002_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_002:\n                action: \"Durably record the seat-002 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_002_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_003:\n                action: \"Natively dispatch the pragmatic research direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-research\n                    model: opus\n                    context_source: \"pivot_seat_003_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n                outputs:\n                  - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_003_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_003:\n                action: \"Durably record the seat-003 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_003_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_finalize_divergent_pivot:\n                action: \"Finalize the prepared pivot after all missing native seats are durable\"\n                skip_when: \"pivot_prepare_status != 'pending'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_finalize_json: \"The complete parsed final result\"\n\n              step_resolve_divergent_pivot_result:\n                action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n                branch_on: \"pivot_prepare_status\"\n                if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n                if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n\n              step_apply_divergent_pivot_result:\n                action: \"Adopt a successful focus or fail closed to the existing synthesis path\"\n                branch_on: \"pivot_result.status\"\n                if_completed:\n                  set:\n                    next_focus: \"{pivot_result.restoredFocus}\"\n                    pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n                    saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n                  command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n                  log: \"Divergent pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n                  proceed_to: step_rejected_pattern_cache\n                if_failed:\n                  log: \"Divergent pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n                  skip_to: phase_synthesis\n            on_error:\n              log: \"Divergent pivot integration error; failing closed to the existing synthesis path.\"\n              skip_to: phase_synthesis\n          if_existing_terminal_path:\n            log: \"Loop stopping. Reason: {reason}\"\n            skip_to: phase_synthesis\n        if_stuck_recovery:\n          append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          set: { next_focus: \"RECOVERY: Widen scope. Try fundamentally different approach. Least-explored question: {least_explored}\" }\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Focus: {next_focus}\"\n\n      step_rejected_pattern_cache:\n        action: \"Apply reducer-derived rejected-pattern suppression before dispatch candidate selection\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        candidate_sources:\n          next_focus:\n            category: \"next-focus\"\n            values:\n              - \"{next_focus}\"\n              - \"{remaining_questions_list}\"\n              - \"{carried_forward_open_questions}\"\n          recovery:\n            category: \"recovery\"\n            values:\n              - \"{recovery_strategy}\"\n              - \"{least_explored}\"\n          ideas:\n            category: \"ideas\"\n            values:\n              - \"{promoted_ideas_list}\"\n            optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n        algorithm: |\n          Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n          reducer pass as the source of truth.\n          Compare normalized exact text first. Then compare fuzzy similarity with\n          rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n          are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n          selection before rendering the dispatch prompt. If all candidates are suppressed,\n          halt for operator input instead of reusing a rejected idea.\n        outputs:\n          - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n          - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n          - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n          - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n        if_next_focus_suppressed:\n          set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n          log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n        if_all_candidates_suppressed:\n          halt: true\n          message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n\n      step_ideas_backlog_lifecycle:\n        action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.config}\"\n        lifecycle:\n          observed_event: \"idea_observed\"\n          promoted_event: \"idea_promoted\"\n          rejected_event: \"idea_rejected\"\n          min_observations: \"{min_idea_observations}\"\n          authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n        validate:\n          - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n          - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n          - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n        outputs:\n          - observed_ideas_count: \"Reducer-derived observed ideas count\"\n          - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n          - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n          - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n\n      step_normalize_pause_events:\n        action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n        stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n        rule_pause_sentinel:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n        rule_stuck_recovery:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch one iteration via the selected executor\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n            Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n            {resource_map_prompt_line}\n            {memory_context_prompt_line}\n            Next focus: {next_focus}\n          render_prompt_pack:\n            template_path: \".opencode/skills/system-deep-loop/deep-research/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              research_topic: \"{research_topic}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_focus: \"{next_focus}\"\n              remaining_questions_list: \"{remaining_questions_list}\"\n              carried_forward_open_questions: \"{carried_forward_open_questions}\"\n              last_3_summaries: \"{last_3_summaries}\"\n              pivot_lineage: \"{pivot_lineage}\"\n              saturated_directions: \"{saturated_directions}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_registry: \"{state_paths.registry}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.type\"\n        if_native:\n          dispatch:\n            agent: deep-research\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n            import { resolveClaudePermissionMode } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n              serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n              sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              resolveClaudePermissionMode(executor.sandboxMode),\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n            - \"claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        record_executor_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.type}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { execFileSync } from 'node:child_process';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            // Fail closed: a requested codex executor must dispatch codex or abort,\n            // never silently degrade to another executor. Undetected absence is what\n            // got Codex deprecated before, so the branch exits non-zero when the\n            // binary is missing instead of falling through to a native/other path.\n            let codexAvailable = false;\n            try {\n              execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n              codexAvailable = true;\n            } catch {}\n            if (!codexAvailable) {\n              console.error('cli-codex executor unavailable: command -v codex failed');\n              process.exit(1);\n            }\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n            const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n            const executor = {\n              kind: 'cli-codex',\n              model,\n              configDir: null,\n              reasoningEffort,\n              serviceTier,\n              sandboxMode: 'workspace-write',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n\n            // codex reads the iteration prompt from stdin via the trailing '-'. A research\n            // iteration must WRITE its own iteration file, delta and state record, so the\n            // sandbox is workspace-write — read-only would block those required writes.\n            // approval_policy=never keeps the run non-interactive.\n            const args = ['exec'];\n            if (model) {\n              args.push('--model', model);\n            }\n            args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n            if (serviceTier) {\n              args.push('-c', 'service_tier=' + serviceTier);\n            }\n            args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'codex',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                input: promptBody,\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n            - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n            - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n            - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n          route_proof:\n            mode: research\n            target_agent: deep-research\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n          optional_jsonl_fields:\n            logOffset: \"Byte offset where the seekable log region starts\"\n            logSize: \"Byte length of the seekable log region\"\n            logPath: \"Absolute path to the file containing the seekable log region\"\n            skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n            slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n          failure_reasons_reference:\n            - \"iteration_file_missing — iteration narrative markdown not written\"\n            - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n            - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n            - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n            - \"jsonl_parse_error — last state-log line is not valid JSON\"\n            - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n            - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n            - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n            - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n            - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n            - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n            - \"executor_missing — non-native executor did not record provenance\"\n            - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n\n      step_run_now_restore_check:\n        action: \"Record a run-now sentinel recreated during the completed dispatch\"\n        command: |\n          node <<'EOF'\n          const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n\n          const stateLogPath = \"{state_paths.state_log}\";\n          const sentinelPath = \"{state_paths.run_now_sentinel}\";\n          const timestamp = \"{ISO_8601_NOW}\";\n          const sessionId = \"{config.lineage.sessionId}\";\n          const generation = Number(\"{config.lineage.generation}\");\n          const run = Number(\"{current_iteration}\");\n\n          function hasAcceptedCurrentRun() {\n            if (!existsSync(stateLogPath)) return false;\n            const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n            for (let index = lines.length - 1; index >= 0; index -= 1) {\n              const record = JSON.parse(lines[index]);\n              if (record.run !== run || record.sessionId !== sessionId) continue;\n              if (record.event === \"run_now_accepted\") return true;\n              if (record.event === \"run_now_rejected\") return false;\n            }\n            return false;\n          }\n\n          if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n            appendFileSync(\n              stateLogPath,\n              `${JSON.stringify({\n                type: \"event\",\n                event: \"run_now_restored\",\n                mode: \"research\",\n                run,\n                sentinelPath,\n                timestamp,\n                sessionId,\n                generation,\n              })}\\n`,\n              \"utf8\",\n            );\n          }\n          EOF\n        outputs:","lineStart":720,"lineEnd":1369,"totalLines":2012,"truncated":true}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1784313654696,"end":1784313654704}},"metadata":{"openai":{"itemId":"fc_0a75312c601b7e8e016a5a773681f881919acc304cb312bbde"}},"id":"prt_f7161ad9d001hr3cyARr7TLH3e","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161806e001Yr5w9CB85Z4se9"}}
{"type":"tool_use","timestamp":1784313654726,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_3AdzC627dnnSZZbLtJfYJQ3H","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/deep-research/feature_catalog/loop_lifecycle/fanout_dispatch.md","limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/deep-research/feature_catalog/loop_lifecycle/fanout_dispatch.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Fan-out loop dispatch\"\n3: description: \"Opt-in fan-out dispatch layer in the research loop: step_resolve_artifact_root artifact-dir override branch, step_fanout_spawn (CLI pool + native sequential agent dispatch), and step_fanout_merge at the top of phase_synthesis. Single-executor path unchanged.\"\n4: trigger_phrases:\n5:   - \"fan-out loop dispatch\"\n6:   - \"fanout dispatch\"\n7:   - \"step_fanout_spawn\"\n8:   - \"parallel lineage execution\"\n9:   - \"multi-executor research\"\n10: version: 1.14.0.4\n11: ---\n12: \n13: # Fan-out loop dispatch\n14: \n15: <!-- sk-doc-template: skill_asset_feature_catalog -->\n16: \n17: ---\n18: \n19: ## 1. OVERVIEW\n20: \n21: When `config.fanout` is present, three new YAML steps activate in the research loop.\n22: \n23: **`step_resolve_artifact_root`** gains a `branch_on: config.fanout_lineage_artifact_dir`\n24: branch. When the override is present (set by a lineage subprocess), `artifact_dir` is bound\n25: directly. When absent (single-executor mode), the `if_absent` branch runs the byte-identical\n26: original `resolveArtifactRoot` command — zero behavior change for single-executor runs.\n27: \n28: **`step_fanout_spawn`** (`skip_when: config.fanout is absent`) spawns CLI lineages via\n29: `fanout-run.cjs` (pool-capped headless subprocesses) and dispatches native lineages as\n30: sequential `agent: deep-research` runs with per-lineage isolated artifact dirs. When\n31: complete, control jumps directly to `phase_synthesis`, skipping `phase_init` and\n32: `phase_main_loop`.\n33: \n34: **`step_fanout_merge`** (`skip_when: config.fanout is absent`) sits at the top of\n35: `phase_synthesis`. It calls `fanout-merge.cjs --loop-type research` to produce a\n36: consolidated `deep-research-findings-registry.json` from all lineage registries before the\n37: existing `step_compile_research` runs.\n38: \n39: ### Why This Matters\n40: \n41: These three YAML steps are the sole integration point between the research loop and the\n42: fan-out runtime primitives. If any drift or lose their `skip_when` guard, single-executor\n43: behavior breaks or lineage isolation fails.\n44: \n45: ---\n46: \n47: ## 2. HOW IT WORKS\n48: \n49: Fully shipped in both `deep_research_auto.yaml` and `confirm.yaml`. Parity\n50: gate: `if_absent` branch is byte-identical to the original command; `skip_when` guards\n51: ensure zero behavioral change for single-executor mode. Full vitest suite (197/197) confirms\n52: no single-executor regression. Command surface: `--executor` (repeatable, with\n53: `--model/--count/--label/--iters`), `--executors <json>` escape hatch, `--concurrency N`.\n54: Default policy: 0–1 executor → `config.executor`; 2+ / `--executors` / `count>1` →\n55: `config.fanout`.\n56: \n57: ---\n58: \n59: ## 3. SOURCE FILES\n60: \n61: ### Implementation\n62: \n63: | File | Role |\n64: |---|---|\n65: | `.opencode/commands/deep/assets/deep_research_auto.yaml` | `step_resolve_artifact_root` (if_present/if_absent branches), `step_fanout_spawn`, `step_fanout_merge` |\n66: | `.opencode/commands/deep/assets/deep_research_confirm.yaml` | Same steps (confirm variant) |\n67: | `.opencode/commands/deep/research.md` | `--executor`/`--executors`/`--concurrency` flag docs, default policy, fan-out examples |\n68: | `.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs` | CLI lineage pool driver called by `step_fanout_spawn_cli` |\n69: | `.opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs` | Cross-lineage merger called by `step_fanout_merge` |\n70: \n71: ### Validation\n72: \n73: | File | Role |\n74: |---|---|\n75: | `.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vitest.ts` | Pool dispatch + lineage dir isolation |\n76: | `.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-merge.vitest.ts` | Research registry dedup + attribution |\n77: \n78: ---\n79: \n80: ## 4. SOURCE METADATA\n81: \n82: - Group: Loop Lifecycle\n83: - Catalog source: `feature_catalog/loop_lifecycle/fanout_dispatch.md`\n84: - Primary source files: `deep_research_auto.yaml`, `research.md`\n85: Related references:\n86: - [resource-map-emission.md](../loop_lifecycle/resource_map_emission.md) — Resource Map Emission\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Fan-out loop dispatch\"\ndescription: \"Opt-in fan-out dispatch layer in the research loop: step_resolve_artifact_root artifact-dir override branch, step_fanout_spawn (CLI pool + native sequential agent dispatch), and step_fanout_merge at the top of phase_synthesis. Single-executor path unchanged.\"\ntrigger_phrases:\n  - \"fan-out loop dispatch\"\n  - \"fanout dispatch\"\n  - \"step_fanout_spawn\"\n  - \"parallel lineage execution\"\n  - \"multi-executor research\"\nversion: 1.14.0.4\n---\n\n# Fan-out loop dispatch\n\n<!-- sk-doc-template: skill_asset_feature_catalog -->\n\n---\n\n## 1. OVERVIEW\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/deep-research/feature_catalog/loop_lifecycle/fanout_dispatch.md","text":"---\ntitle: \"Fan-out loop dispatch\"\ndescription: \"Opt-in fan-out dispatch layer in the research loop: step_resolve_artifact_root artifact-dir override branch, step_fanout_spawn (CLI pool + native sequential agent dispatch), and step_fanout_merge at the top of phase_synthesis. Single-executor path unchanged.\"\ntrigger_phrases:\n  - \"fan-out loop dispatch\"\n  - \"fanout dispatch\"\n  - \"step_fanout_spawn\"\n  - \"parallel lineage execution\"\n  - \"multi-executor research\"\nversion: 1.14.0.4\n---\n\n# Fan-out loop dispatch\n\n<!-- sk-doc-template: skill_asset_feature_catalog -->\n\n---\n\n## 1. OVERVIEW\n\nWhen `config.fanout` is present, three new YAML steps activate in the research loop.\n\n**`step_resolve_artifact_root`** gains a `branch_on: config.fanout_lineage_artifact_dir`\nbranch. When the override is present (set by a lineage subprocess), `artifact_dir` is bound\ndirectly. When absent (single-executor mode), the `if_absent` branch runs the byte-identical\noriginal `resolveArtifactRoot` command — zero behavior change for single-executor runs.\n\n**`step_fanout_spawn`** (`skip_when: config.fanout is absent`) spawns CLI lineages via\n`fanout-run.cjs` (pool-capped headless subprocesses) and dispatches native lineages as\nsequential `agent: deep-research` runs with per-lineage isolated artifact dirs. When\ncomplete, control jumps directly to `phase_synthesis`, skipping `phase_init` and\n`phase_main_loop`.\n\n**`step_fanout_merge`** (`skip_when: config.fanout is absent`) sits at the top of\n`phase_synthesis`. It calls `fanout-merge.cjs --loop-type research` to produce a\nconsolidated `deep-research-findings-registry.json` from all lineage registries before the\nexisting `step_compile_research` runs.\n\n### Why This Matters\n\nThese three YAML steps are the sole integration point between the research loop and the\nfan-out runtime primitives. If any drift or lose their `skip_when` guard, single-executor\nbehavior breaks or lineage isolation fails.\n\n---\n\n## 2. HOW IT WORKS\n\nFully shipped in both `deep_research_auto.yaml` and `confirm.yaml`. Parity\ngate: `if_absent` branch is byte-identical to the original command; `skip_when` guards\nensure zero behavioral change for single-executor mode. Full vitest suite (197/197) confirms\nno single-executor regression. Command surface: `--executor` (repeatable, with\n`--model/--count/--label/--iters`), `--executors <json>` escape hatch, `--concurrency N`.\nDefault policy: 0–1 executor → `config.executor`; 2+ / `--executors` / `count>1` →\n`config.fanout`.\n\n---\n\n## 3. SOURCE FILES\n\n### Implementation\n\n| File | Role |\n|---|---|\n| `.opencode/commands/deep/assets/deep_research_auto.yaml` | `step_resolve_artifact_root` (if_present/if_absent branches), `step_fanout_spawn`, `step_fanout_merge` |\n| `.opencode/commands/deep/assets/deep_research_confirm.yaml` | Same steps (confirm variant) |\n| `.opencode/commands/deep/research.md` | `--executor`/`--executors`/`--concurrency` flag docs, default policy, fan-out examples |\n| `.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs` | CLI lineage pool driver called by `step_fanout_spawn_cli` |\n| `.opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs` | Cross-lineage merger called by `step_fanout_merge` |\n\n### Validation\n\n| File | Role |\n|---|---|\n| `.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vitest.ts` | Pool dispatch + lineage dir isolation |\n| `.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-merge.vitest.ts` | Research registry dedup + attribution |\n\n---\n\n## 4. SOURCE METADATA\n\n- Group: Loop Lifecycle\n- Catalog source: `feature_catalog/loop_lifecycle/fanout_dispatch.md`\n- Primary source files: `deep_research_auto.yaml`, `research.md`\nRelated references:\n- [resource-map-emission.md](../loop_lifecycle/resource_map_emission.md) — Resource Map Emission","lineStart":1,"lineEnd":86,"totalLines":86,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-research/feature_catalog/loop_lifecycle/fanout_dispatch.md","time":{"start":1784313654722,"end":1784313654725}},"metadata":{"openai":{"itemId":"fc_0a75312c601b7e8e016a5a7736820081919b6f76b8c107f994"}},"id":"prt_f7161ada9001LOJtxDrG3EJqdg","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161806e001Yr5w9CB85Z4se9"}}
{"type":"tool_use","timestamp":1784313654743,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_OpV3ttoWUFUHd7EjgV7mmeF5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vitest.ts","offset":730,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vitest.ts</path>\n<type>file</type>\n<content>\n730:         '-c', 'service_tier=fast',\n731:         '-c', 'approval_policy=never',\n732:         '--sandbox', 'workspace-write',\n733:         '-',\n734:       ],\n735:       input: 'bounded prompt',\n736:     });\n737:   });\n738: \n739:   it('fails closed before command construction when codex is absent', () => {\n740:     const env = { ...process.env, PATH: makeTempDir('fanout-run-no-codex-') };\n741:     expect(isCodexBinaryAvailable(env)).toBe(false);\n742:     expect(() => buildLineageCommand(\n743:       { kind: 'cli-codex', model: 'gpt-5.6-codex' },\n744:       'bounded prompt',\n745:       'workspace-write',\n746:       'default',\n747:       { env },\n748:     )).toThrow(/command -v codex failed/);\n749:   });\n750: });\n751: \n752: describe('fanout-run.cjs — buildLoopPrompt identity wording', () => {\n753:   const { buildLoopPrompt } = requireCjs(fanoutRunScript) as {\n754:     buildLoopPrompt: (\n755:       loopType: 'research' | 'review',\n756:       specFolder: string,\n757:       lineageDir: string,\n758:       sessionId: string,\n759:       lineage: { kind: 'cli-opencode'; label: string; model?: string },\n760:       researchTopic?: string,\n761:       options?: { stopPolicy?: string; convergenceThreshold?: number },\n762:     ) => string;\n763:   };\n764: \n765:   it('does not claim LEAF-agent identity while preserving loop phase instructions', () => {\n766:     for (const [loopType, agentName] of [\n767:       ['research', 'deep-research'],\n768:       ['review', 'deep-review'],\n769:     ] as const) {\n770:       const prompt = buildLoopPrompt(\n771:         loopType,\n772:         'specs/test-fanout-loop-identity',\n773:         `/tmp/fanout-${loopType}-lineage`,\n774:         `fanout-${loopType}-run-123`,\n775:         { kind: 'cli-opencode', label: `${loopType}-seat`, model: 'opencode-go/glm-5.1' },\n776:         loopType === 'research' ? 'test research topic' : undefined,\n777:       );\n778: \n779:       expect(prompt).not.toContain(`You are a ${agentName} agent`);\n780:       expect(prompt).not.toContain(`${agentName} agent running a fan-out lineage`);\n781:       expect(prompt).toContain(\n782:         `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n783:       );\n784:       expect(prompt).toContain(\n785:         'Run phase_init, phase_main_loop (to legal convergence), and phase_synthesis.',\n786:       );\n787:     }\n788:   });\n789: \n790:   it('rejects deprecated context fan-out prompt construction', () => {\n791:     expect(() => buildLoopPrompt(\n792:       'context' as never,\n793:       'specs/test-fanout-loop-identity',\n794:       '/tmp/fanout-context-lineage',\n795:       'fanout-context-run-123',\n796:       { kind: 'cli-opencode', label: 'context-seat', model: 'opencode-go/glm-5.1' },\n797:     )).toThrow(/context fan-out is deprecated/);\n798:   });\n799: });\n800: \n801: describe('fanout-run.cjs — review session id propagation templates', () => {\n802:   const { buildLineageCommand } = requireCjs(fanoutRunScript) as {\n803:     buildLineageCommand: (\n804:       lineage: { kind: 'native'; iterations?: number },\n805:       prompt: string,\n806:       resolvedSandbox: string,\n807:       resolvedPermission: string,\n808:       options: {\n809:         loopType: 'review';\n810:         specFolder: string;\n811:         lineageDir: string;\n812:         sessionId?: string;\n813:       },\n814:     ) => { command: string; args: string[]; input: string };\n815:   };\n816: \n817:   it('uses a supplied session_id for review init artifacts and preserves the timestamp fallback', () => {\n818:     const suppliedSessionId = 'fanout-lineage-a-run-123';\n819: \n820:     for (const workflowPath of reviewWorkflowPaths) {\n821:       expect(renderReviewInitSessionIds(workflowPath, suppliedSessionId)).toEqual({\n822:         config: suppliedSessionId,\n823:         stateLog: suppliedSessionId,\n824:         findingsRegistry: suppliedSessionId,\n825:       });\n826:       expect(renderReviewInitSessionIds(workflowPath)).toEqual({\n827:         config: '2035-02-03T04:05:06.000Z',\n828:         stateLog: '2035-02-03T04:05:06.000Z',\n829:         findingsRegistry: '2035-02-03T04:05:06.000Z',\n\n(Showing lines 730-829 of 2361. Use offset=830 to continue.)\n</content>","metadata":{"preview":"        '-c', 'service_tier=fast',\n        '-c', 'approval_policy=never',\n        '--sandbox', 'workspace-write',\n        '-',\n      ],\n      input: 'bounded prompt',\n    });\n  });\n\n  it('fails closed before command construction when codex is absent', () => {\n    const env = { ...process.env, PATH: makeTempDir('fanout-run-no-codex-') };\n    expect(isCodexBinaryAvailable(env)).toBe(false);\n    expect(() => buildLineageCommand(\n      { kind: 'cli-codex', model: 'gpt-5.6-codex' },\n      'bounded prompt',\n      'workspace-write',\n      'default',\n      { env },\n    )).toThrow(/command -v codex failed/);\n  });","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vitest.ts","text":"        '-c', 'service_tier=fast',\n        '-c', 'approval_policy=never',\n        '--sandbox', 'workspace-write',\n        '-',\n      ],\n      input: 'bounded prompt',\n    });\n  });\n\n  it('fails closed before command construction when codex is absent', () => {\n    const env = { ...process.env, PATH: makeTempDir('fanout-run-no-codex-') };\n    expect(isCodexBinaryAvailable(env)).toBe(false);\n    expect(() => buildLineageCommand(\n      { kind: 'cli-codex', model: 'gpt-5.6-codex' },\n      'bounded prompt',\n      'workspace-write',\n      'default',\n      { env },\n    )).toThrow(/command -v codex failed/);\n  });\n});\n\ndescribe('fanout-run.cjs — buildLoopPrompt identity wording', () => {\n  const { buildLoopPrompt } = requireCjs(fanoutRunScript) as {\n    buildLoopPrompt: (\n      loopType: 'research' | 'review',\n      specFolder: string,\n      lineageDir: string,\n      sessionId: string,\n      lineage: { kind: 'cli-opencode'; label: string; model?: string },\n      researchTopic?: string,\n      options?: { stopPolicy?: string; convergenceThreshold?: number },\n    ) => string;\n  };\n\n  it('does not claim LEAF-agent identity while preserving loop phase instructions', () => {\n    for (const [loopType, agentName] of [\n      ['research', 'deep-research'],\n      ['review', 'deep-review'],\n    ] as const) {\n      const prompt = buildLoopPrompt(\n        loopType,\n        'specs/test-fanout-loop-identity',\n        `/tmp/fanout-${loopType}-lineage`,\n        `fanout-${loopType}-run-123`,\n        { kind: 'cli-opencode', label: `${loopType}-seat`, model: 'opencode-go/glm-5.1' },\n        loopType === 'research' ? 'test research topic' : undefined,\n      );\n\n      expect(prompt).not.toContain(`You are a ${agentName} agent`);\n      expect(prompt).not.toContain(`${agentName} agent running a fan-out lineage`);\n      expect(prompt).toContain(\n        `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n      );\n      expect(prompt).toContain(\n        'Run phase_init, phase_main_loop (to legal convergence), and phase_synthesis.',\n      );\n    }\n  });\n\n  it('rejects deprecated context fan-out prompt construction', () => {\n    expect(() => buildLoopPrompt(\n      'context' as never,\n      'specs/test-fanout-loop-identity',\n      '/tmp/fanout-context-lineage',\n      'fanout-context-run-123',\n      { kind: 'cli-opencode', label: 'context-seat', model: 'opencode-go/glm-5.1' },\n    )).toThrow(/context fan-out is deprecated/);\n  });\n});\n\ndescribe('fanout-run.cjs — review session id propagation templates', () => {\n  const { buildLineageCommand } = requireCjs(fanoutRunScript) as {\n    buildLineageCommand: (\n      lineage: { kind: 'native'; iterations?: number },\n      prompt: string,\n      resolvedSandbox: string,\n      resolvedPermission: string,\n      options: {\n        loopType: 'review';\n        specFolder: string;\n        lineageDir: string;\n        sessionId?: string;\n      },\n    ) => { command: string; args: string[]; input: string };\n  };\n\n  it('uses a supplied session_id for review init artifacts and preserves the timestamp fallback', () => {\n    const suppliedSessionId = 'fanout-lineage-a-run-123';\n\n    for (const workflowPath of reviewWorkflowPaths) {\n      expect(renderReviewInitSessionIds(workflowPath, suppliedSessionId)).toEqual({\n        config: suppliedSessionId,\n        stateLog: suppliedSessionId,\n        findingsRegistry: suppliedSessionId,\n      });\n      expect(renderReviewInitSessionIds(workflowPath)).toEqual({\n        config: '2035-02-03T04:05:06.000Z',\n        stateLog: '2035-02-03T04:05:06.000Z',\n        findingsRegistry: '2035-02-03T04:05:06.000Z',","lineStart":730,"lineEnd":829,"totalLines":2361,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vitest.ts","time":{"start":1784313654734,"end":1784313654742}},"metadata":{"openai":{"itemId":"fc_0a75312c601b7e8e016a5a7736820c8191a6ae1c5b78376218"}},"id":"prt_f7161adcc001g6UUahVqgLKDn3","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161806e001Yr5w9CB85Z4se9"}}
{"type":"step_finish","timestamp":1784313655302,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"id":"prt_f7161b004001zUsMP7crjW46vu","reason":"tool-calls","snapshot":"c91d1d34f9ec35463a782ae0dbce29c0af8ca81d","messageID":"msg_f7161806e001Yr5w9CB85Z4se9","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","type":"step-finish","tokens":{"total":88946,"input":10792,"output":282,"reasoning":48,"cache":{"write":0,"read":77824}},"cost":0}}
{"type":"step_start","timestamp":1784313658520,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"id":"prt_f7161bc96001AFZKtdpzZwoWhg","messageID":"msg_f7161b179001t24Z3aZePXY9Mc","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","snapshot":"c91d1d34f9ec35463a782ae0dbce29c0af8ca81d","type":"step-start"}}
{"type":"tool_use","timestamp":1784313663501,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"skill","callID":"call_BgenjYCFAPPNfKinpd6SCwjV","state":{"status":"completed","input":{"name":"cli-opencode"},"output":"<skill_content name=\"cli-opencode\">\n# Skill: cli-opencode\n\n<!-- Keywords: opencode, opencode-cli, opencode-run, cross-ai, spec-kit-runtime, plugin-runtime, parallel-sessions, share-url, detached-session, agent-delegation, deepseek, openai, minimax, minimax-coding-plan, minimax-m3, token-plan, xiaomi, xiaomi-token-plan, xiaomi-token-plan-ams, xiaomi-api, xiaomi-direct, mimo, mimo-v2.5-pro, mimo-v2.5-pro-ultraspeed, ultraspeed, glm-5.2, zai-coding-plan, z.ai-coding-plan, glm-coding-plan -->\n\n# OpenCode CLI Orchestrator - Full-Runtime Cross-AI Dispatch\n\n> **CRITICAL — SELF-INVOCATION PROHIBITED**\n>\n> This skill dispatches to the OpenCode CLI binary (`opencode`). If the agent currently reading this skill is itself running inside OpenCode (TUI / acp / serve / run modes — detection signals listed in §2), the skill MUST refuse to load and return the documented error message instead of generating any `opencode` invocation. The only exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session with its own session id and state directory.\n>\n> A running CLI skill never dispatches itself. The cli-X skills are for **cross-AI delegation only** — never self-invocation.\n\nOrchestrate OpenCode's `opencode run` from external AI assistants (Claude Code, OpenCode, raw shell) AND from inside an existing OpenCode session for parallel detached workers. Three documented use cases keep the cycle risk explicit while giving every dispatch path a copy-paste invocation shape.\n\n**Core Principle**: The calling AI stays the conductor. Delegate to OpenCode for what it does best — full plugin, skill, MCP, and Spec Kit Memory runtime in a one-shot dispatch. Validate and integrate the output.\n\n---\n\n## 1. WHEN TO USE\n\n### Activation Triggers\n\n- **Full plugin / skill / MCP runtime** (use case 1) — calling AI is Claude Code / OpenCode / Copilot / raw shell AND the task needs the project's full Spec Kit Memory database, Code Graph semantic index, structural code graph, or every plugin/skill/MCP tool in a one-shot dispatch. Includes `@deep-research` / `@deep-review` agent loops with externalized state under `.opencode/specs/`.\n- **Parallel detached session** (use case 2) — operator already inside OpenCode (TUI / web / serve / acp) AND wants a SEPARATE session with its own session id and state directory for ablation, worker farm, or parallel research. Prompt explicitly mentions \"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", or \"share URL\".\n- **Cross-AI orchestration handback** (use case 3) — calling AI is non-Anthropic (OpenCode / Copilot), task targets a project-specific subsystem (spec-kit, memory, code-graph, advisor), and the non-Anthropic CLI cannot load the project's plugin/skill/MCP runtime on its own and needs OpenCode as a bridge. When the caller only needs a daemon-backed tool call, prefer the shipped front doors (`spec-memory.cjs`, `code-index.cjs`, `skill-advisor.cjs`) over a full `opencode run` delegation.\n- **Agent dispatch** — task matches a specialized OpenCode agent. Primary agents (directly invokable via `--agent`): `general`, `plan` (built-in), `orchestrate`. Generic subagents fully dispatched via the orchestrate primary: `context`, `review`, `write`, `debug`, `ai-council`. Command-owned loop executors (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) are owned end-to-end by their parent `/deep:*` command; `orchestrate` may perform exactly one bounded hand-off dispatch to a recognized loop request, but never manages the loop itself. See §3 \"OpenCode Agent Delegation\" for the full contract.\n- **Cross-repo dispatch** — session in repo A dispatches into repo B's plugin/skill/MCP runtime via `--dir <path>` or remote OpenCode server via `--attach <url>`.\n\n### When NOT to Use\n\n- **You ARE OpenCode already.** If your runtime is OpenCode (detection signal: `$OPENCODE_CONFIG_DIR` or any `OPENCODE_*` env var set, `opencode` in process ancestry, or `~/.opencode/state/<id>/lock` present), this skill refuses to load. Self-invocation creates a circular dispatch loop and burns tokens for no value. The cli-X family is exclusively for cross-AI delegation. The single legitimate exception is an explicit \"parallel detached\" request that intentionally spawns a SEPARATE session id and state directory (use case 2); without that qualifier, the smart router refuses per ADR-001.\n- Simple, quick tasks where `opencode run` overhead is not worth it.\n- Tasks that only need a raw model dispatch — use a sibling cli-* skill.\n- Tasks requiring interactive TUI or web UI (use `opencode` directly instead of `opencode run`).\n- Context already loaded and understood by the calling AI.\n- Tasks where the OpenCode binary is not installed at the expected path.\n\n---\n\n## 2. SMART ROUTING\n\n\n### Prerequisite Detection\n\n```bash\n# Verify OpenCode CLI is available\ncommand -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n```\n\n### Self-Invocation Guard (ADR-001)\n\nBefore any dispatch, run the layered ADR-001 detection: Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for an `opencode` parent, Layer 3 a best-effort `~/.opencode/state/<id>/lock` probe. A positive on any layer refuses the dispatch unless the prompt carries explicit parallel-session keywords (use case 2), which permits a SEPARATE session id and state directory instead. Full bash + python detection: [`references/self_invocation_guard.md`](./references/self_invocation_guard.md). Decision tree + refusal text: [`references/integration_patterns.md`](./references/integration_patterns.md) §5.\n\n### Resource Loading Levels\n\n| Level       | When to Load            | Resources                      |\n| ----------- | ----------------------- | ------------------------------ |\n| ALWAYS      | Every skill invocation  | `references/cli_reference.md`, `assets/prompt_quality_card.md` |\n| CONDITIONAL | If intent signals match | Intent-mapped reference docs   |\n| ON_DEMAND   | Only on explicit request| Extended templates and patterns |\n\n### Smart Router\n\nIntent-specific dictionaries (used by the shared helper functions in [`system-spec-kit/references/cli/shared_smart_router.md`](../../system-spec-kit/references/cli/shared_smart_router.md)):\n\n- Pattern 1: Runtime Discovery - `discover_markdown_resources()` recursively scans existing `references/` and `assets/` folders with `base.exists()` safeguards.\n- Pattern 2: Existence-Check Before Load - `load_if_available()` uses `_guard_in_skill()`, `inventory`, and `seen` so raw loads, missing files, duplicate loads, and path escapes are rejected.\n- Pattern 3: Not applicable here - `cli-opencode` has flat resource folders, not keyed `references/<key>/` or `assets/<key>/` subdirectories. Routing selects from `RESOURCE_MAP` by intent signal rather than by runtime resource key.\n- Pattern 4: Multi-Tier Graceful Fallback - low-confidence intent scores return `UNKNOWN_FALLBACK` with a disambiguation checklist; missing intent resources still return always-load baseline docs plus a clear notice.\n\n```python\nINTENT_SIGNALS = {\n    \"EXTERNAL_DISPATCH\":  {\"weight\": 4, \"keywords\": [\"delegate to opencode\", \"opencode run\", \"from claude code\", \"from opencode\", \"from copilot\", \"external runtime\", \"full plugin runtime\", \"hand this off to opencode\", \"hand off to opencode\", \"send this to opencode\", \"dispatch to opencode\", \"run this through opencode\", \"let opencode handle this\", \"opencode's full runtime\", \"full runtime dispatch\", \"one-shot dispatch\", \"invoke opencode\", \"kick this off in opencode\", \"have opencode take care of this\", \"get opencode to run this\", \"pass this over to opencode\", \"opencode has access to every tool\", \"opencode has the whole toolchain\", \"since opencode has all the plugins\", \"opencode can load every skill\", \"ask opencode to handle this\", \"opencode should handle this\", \"offload this to opencode\", \"outsource this to opencode\", \"forward this to opencode\", \"route this to opencode\", \"push this to opencode\", \"opencode has everything loaded\", \"opencode has the whole toolset\", \"opencode cli\", \"run externally\", \"full toolset\", \"handle this externally\", \"external ai assistant\", \"run in opencode\", \"hand off externally\"]},\n    \"PARALLEL_DETACHED\":  {\"weight\": 4, \"keywords\": [\"parallel detached\", \"ablation suite\", \"worker farm\", \"parallel research\", \"spawn detached\", \"share url\", \"share-url\", \"detached session\", \"separate session id\", \"own state directory\", \"spin up a new session\", \"background opencode session\", \"run this in the background\", \"fan out workers\", \"concurrent sessions\", \"isolated session\", \"run these in parallel\", \"spin off a few workers\", \"kick off several sessions at once\", \"run copies side by side\", \"fire off multiple runs at the same time\", \"farm this out to multiple workers\", \"run a bunch of these concurrently\", \"distribute the work across sessions\", \"batch this across sessions\", \"start several sessions at once\", \"spin up another instance\", \"new opencode instance\", \"run it as its own session\", \"own separate session\", \"side session\", \"run this independently\", \"additional worker\", \"background job\", \"separate instance\", \"own instance\", \"parallel run\", \"concurrent run\", \"session of its own\", \"spin up a worker\", \"worker pool\", \"run in parallel\"]},\n    \"CROSS_AI_HANDBACK\":  {\"weight\": 4, \"keywords\": [\"spec kit\", \"spec-kit\", \"spec_kit\", \"code graph\", \"memory_search\", \"session_bootstrap\", \"skill advisor\", \"cross-ai handback\", \"hand back to opencode\", \"bridge back to opencode\", \"opencode as a bridge\", \"non-anthropic cli\", \"project's memory database\", \"structural code index\", \"use the skill advisor\"]},\n    \"AGENT_DISPATCH\":     {\"weight\": 4, \"keywords\": [\"delegate\", \"agent\", \"deep-research\", \"deep-review\", \"ai-council\", \"review agent\", \"context agent\", \"dispatch an agent\", \"spawn an agent\", \"run a subagent\", \"invoke a subagent\", \"specialized subagent\", \"debug agent\", \"write agent\"]},\n    \"CROSS_REPO\":         {\"weight\": 3, \"keywords\": [\"cross-repo\", \"different repo\", \"--dir\", \"another repository\", \"remote opencode\", \"different repository\", \"target repo\", \"other codebase\", \"separate repository\", \"remote opencode server\", \"--attach\"]},\n    \"TEMPLATES\":          {\"weight\": 3, \"keywords\": [\"template\", \"prompt\", \"how to ask\", \"opencode prompt\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\", \"prompt framework\", \"prompt template\", \"how do i phrase this\", \"copy-paste template\", \"prompt quality\", \"prompt craft\", \"costar framework\", \"example prompt\"]},\n    \"PATTERNS\":           {\"weight\": 3, \"keywords\": [\"pattern\", \"workflow\", \"orchestrate\", \"session continue\", \"resume session\", \"integration pattern\", \"dispatch pattern\", \"continue the session\", \"resume a session\", \"session continuation\"]},\n    # WHY: DESIGN is an intent signal only — a deliberate cross-skill handoff to sk-design,\n    # not a same-skill resource bundle. It intentionally has NO RESOURCE_MAP entry: this skill\n    # hands design work off rather than owning design reference docs. The durable sk-design\n    # loading contract lives in the always-fires Design Standards Loading rule and the dispatch\n    # manifest (see ALWAYS rules 13-14); RESOURCE_MAP stays limited to same-skill markdown paths.\n    \"DESIGN\":             {\"weight\": 4, \"keywords\": [\"sk-design\", \"interface design\", \"frontend design\", \"visual design\", \"redesign the ui\", \"design foundations\", \"design tokens\", \"motion design\", \"micro-interactions\", \"design audit\", \"ui critique\", \"extract design system\", \"generate design.md\"]},\n}\n\nRESOURCE_MAP = {\n    \"EXTERNAL_DISPATCH\":  [\"references/cli_reference.md\", \"references/integration_patterns.md\"],\n    \"PARALLEL_DETACHED\":  [\"references/integration_patterns.md\", \"assets/prompt_templates.md\"],\n    \"CROSS_AI_HANDBACK\":  [\"references/integration_patterns.md\", \"references/opencode_tools.md\"],\n    \"AGENT_DISPATCH\":     [\"references/agent_delegation.md\", \"assets/prompt_templates.md\"],\n    \"CROSS_REPO\":         [\"references/cli_reference.md\", \"references/opencode_tools.md\"],\n    \"TEMPLATES\":          [\"assets/prompt_templates.md\", \"references/cli_reference.md\"],\n    \"PATTERNS\":           [\"references/integration_patterns.md\", \"references/cli_reference.md\"],\n}\n\nLOADING_LEVELS = {\n    \"ALWAYS\": [\"references/cli_reference.md\", \"assets/prompt_quality_card.md\"],\n    \"ON_DEMAND_KEYWORDS\": [\"full reference\", \"all templates\", \"deep dive\", \"complete guide\", \"opencode agent\", \"opencode prompt\", \"share url\", \"ablation\", \"worker farm\", \"self-invocation\", \"memory handback\", \"minimax\", \"MiniMax-M3\", \"tidd-ec\"],\n    \"ON_DEMAND\": [\"references/opencode_tools.md\", \"assets/prompt_templates.md\"],\n}\n\nUNKNOWN_FALLBACK_CHECKLIST = [\n    \"Is the user asking about OpenCode CLI specifically?\",\n    \"Does the task need the project's full plugin / skill / MCP runtime?\",\n    \"Is a parallel detached session what they want?\",\n    \"Is a non-Anthropic CLI handing back to OpenCode for a spec-kit workflow?\",\n]\n```\n\n**Call sequence** (using shared helpers from `shared_smart_router.md`):\n\n1. `discover_markdown_resources()` — recursively enumerate current `.md` files under existing `references/` and `assets/` folders at routing time.\n2. `_guard_in_skill()` + `load_if_available()` — sandbox paths to this skill, reject non-markdown loads, skip missing files, and suppress duplicates.\n3. `score_intents(task)` and `select_intents(scores, ambiguity_delta=1.0)` — preserve provider-specific weighted intent scoring and top-2 ambiguity handling.\n4. ALWAYS-load `LOADING_LEVELS[\"ALWAYS\"]`, then return `UNKNOWN_FALLBACK` with `UNKNOWN_FALLBACK_CHECKLIST` when max score is 0.\n5. CONDITIONAL-load existing `RESOURCE_MAP[intent]` entries via `load_if_available()`, ON_DEMAND-load keyword matches, and return a notice when no intent-specific knowledge base is available beyond always-load resources.\n\nThe `route_opencode_resources(task)` function body lives in [`shared_smart_router.md`](../../system-spec-kit/references/cli/shared_smart_router.md) — substitute `<PROVIDER>` = `opencode`.\n\n---\n\n## 3. HOW IT WORKS\n\n### Prerequisites\n\n```bash\n# Verify installation (cli-opencode v1.0.0 is pinned to opencode v1.3.17)\nopencode --version | grep -q '^1\\.' || echo \"Not installed or version drift. See references/cli_reference.md §9.\"\n\n# Self-invocation guard\nenv | grep -q '^OPENCODE_' && echo \"ERROR: Already inside OpenCode session\"\n\n# Authentication — providers configured via opencode providers (alias auth)\nopencode providers\n```\n\n**Authentication options**: `opencode providers login <provider>` (and `opencode auth login` for subscription plans). Full per-provider login shapes and the configured-provider list: `references/cli_reference.md` §4.\n\n### Provider Auth Pre-Flight (Smart Fallback)\n\n**MANDATORY before any first dispatch in a session.** The default provider may not be logged in — silently failing with `provider/model not found` or `401 Unauthorized` mid-dispatch wastes a round-trip. Run the pre-flight once per session, cache the result, and re-run only on an auth failure.\n\nThe one-shot pre-flight bash, the per-provider decision trees, the user-facing prompt templates for missing providers, and the error-recovery contract live in [`references/cli_reference.md`](./references/cli_reference.md) §4 — do not duplicate them here. Never substitute a model the user didn't approve; ASK when the default is unavailable.\n\n### Default Invocation (Skill Default)\n\n**Default model + variant + format + dir**: `deepseek/deepseek-v4-pro` · `--variant high` · `--format json` · `--dir <repo-root>` (pinned to avoid CWD ambiguity). Direct DeepSeek is the default provider — elevated reasoning at low cost for routine dispatches.\n\nUse `opencode run --model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root> \"<prompt>\"`.\n\n> **The `--agent` flag (read this):** Do NOT pass `--agent` on a top-level `opencode run` — current opencode treats named agents like `general` as **subagents** and rejects them at the top level, so `--agent general` fails outright. The default agent runs when `--agent` is omitted, which is correct for almost every dispatch. **To target a specific agent profile, describe the role in the prompt body instead** (e.g. open with \"Act as a code-review agent: …\"); only pass `--agent <name>` after confirming acceptance via `opencode run --help` on the installed version.\n\nHonor explicit user model, port, and handback phrasing verbatim; otherwise use the default invocation above.\n\n### Core Invocation Pattern\n\nCore flags: `--model`, `--agent`, `--variant`, `--format json`, `--dir`, continuation/session/fork flags, `--share` and `--port` for detached sessions, `--file`, `--thinking`, `--pure`, and log flags.\n\n> **Non-interactive invocation stdin**: always append `</dev/null` to any non-interactive `opencode run` invocation — without it, opencode can inherit parent-terminal stdin and hang. See `references/integration_patterns.md` §6.\n\n> **Registered command dispatch (`--command`)**: slash-command text inside a `run` message is NOT expanded — `opencode run \"/memory:search query\"` delivers the slash text as raw prose. Execute a registered command via `opencode run --command <family>/<name> [flags] \"<args>\"` (becomes `$ARGUMENTS`; e.g. `memory/search` for `/memory:search`). Full semantics: `references/cli_reference.md` §4.\n\n### Model Selection\n\nRun `opencode providers list` to confirm credentials and `opencode models <provider>` for live choices. Default: `deepseek/deepseek-v4-pro --variant high` (direct DeepSeek API). Alternates (all omit `--agent`): MiniMax Token Plan/Direct API `MiniMax-M3`, Xiaomi Token Plan/Direct API `mimo-v2.5-pro` (+ low-latency `-ultraspeed`), Kimi For Coding `k2p7` (256k, subscription), Z.AI GLM Coding Plan `glm-5.2` (1M, subscription), and the OpenAI GPT-5.6 catalog (`gpt-5.6-sol` flagship default; bare/Sol/Terra/Luna x base/Fast/Pro, `--variant` up to `xhigh`). Full model table, per-provider `--variant` mapping, and model-specific operational caveats: `references/cli_reference.md` §5.\n\nShared small-model facts, context defaults, quota pools, and fallback targets live in `../../sk-prompt/prompt-models/assets/model_profiles.json`.\n\n### OpenCode Agent Delegation\n\nThe calling AI is the conductor. OpenCode distinguishes **primary agents** (directly invokable via `--agent <slug>`) from **subagents** (dispatched as Task-tool subagents from a primary).\n\n#### Primary agents — directly invokable via `--agent`\n\nOpenCode defines `general`, `plan`, and `orchestrate` as primary agents. **Never pass `--agent general`** — it is rejected at the top level; the default agent (used when `--agent` is omitted) already covers that case. Pin `--agent plan|orchestrate` only when the task needs that profile AND `opencode run --help` confirms top-level acceptance; otherwise state the role in the prompt body.\n\n#### Subagents — dispatched as Task subagents from a primary\n\nThese live at `.opencode/agents/<slug>.md` with `mode: subagent` and are NOT directly invokable via `opencode run --agent`. Three dispatch surfaces are legal under the single-hop NDP contract:\n\n1. **Generic subagents** (`context`, `review`, `write`, `debug`) — dispatched by `orchestrate` via the Task tool. Route through `--agent orchestrate` and let it dispatch the relevant subagent.\n2. **`ai-council`** — dispatched via `/deep:ai-council` or `orchestrate`'s registry-backed Task-dispatch. Direct `--agent ai-council` is rejected at the top level (`mode: subagent`).\n3. **Command-owned loop executors** (`deep-research`, `deep-review`, `deep-improvement`, `prompt-improver`) — LOOP-OWNED by their parent commands (`/deep:research`, `/deep:review`, `/deep:agent-improvement`, `/prompt`), which own iteration state, convergence detection, and continuity. Never dispatch these directly via raw `--agent <slug>`. `orchestrate` is an authorized **caller/coordinator only** — it may perform exactly one bounded hand-off dispatch to the resolved leaf, but MUST NOT re-implement the loop.\n\nSee [agent_delegation.md](./references/agent_delegation.md) for the complete agent roster and dispatch patterns.\n\n### Unique OpenCode Strengths\n\nFull project runtime loading, detached sessions, JSON event streams, agent routing, cross-repo/server dispatch, session continuation, and plugin-disable debugging.\n\n### Essential Commands\n\nDefault invocation for external runtime handback; `--share --port <N>` only for explicit detached sessions; `--agent orchestrate` for generic subagent routing; `--dir` for cross-repo dispatch.\n\n### Error Handling\n\nInstall missing binaries, refuse ambiguous self-invocation, run provider pre-flight for model/auth errors, check version drift for unknown flags, force `--format json` for empty streams, add `</dev/null` for background loops, confirm `--share`, use `--pure` only for plugin crashes, inspect state logs for stuck sessions.\n\n---\n\n## 4. RULES\n\n### ✅ ALWAYS\n\n1. Verify OpenCode CLI is installed before first invocation; confirm version baseline against v1.3.17 (drift handling per `references/cli_reference.md` §9).\n2. **Run the self-invocation guard before dispatch** (ADR-001): Layer 1 env-var lookup for any `OPENCODE_*`, Layer 2 process-ancestry probe for `opencode` parent, Layer 3 `~/.opencode/state/<id>/lock` probe. Trip on ANY positive — refuse unless prompt has explicit parallel-session keywords.\n3. Pin model + variant + format + dir explicitly — **no `--agent`** (see the Default Invocation note: current opencode rejects a top-level `--agent general`; put any agent-profile request in the prompt body). Default: `--model deepseek/deepseek-v4-pro --variant high --format json --dir <repo-root>`. Honor user overrides verbatim (e.g. `deepseek/deepseek-v4-pro`, `minimax-coding-plan/MiniMax-M3`, `minimax/MiniMax-M3`, `xiaomi-token-plan-ams/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro`, `xiaomi/mimo-v2.5-pro-ultraspeed`, `openai/gpt-5.6-sol-pro`).\n4. Pass `--format json` unless the calling AI explicitly wants formatted output — JSON event stream is what external runtimes parse incrementally.\n5. **Append `</dev/null` to every non-interactive `opencode run` invocation** that redirects stdout and/or stderr to files OR runs inside `while read` loops. opencode v1.14.39 reads stdin at startup before session creation; without explicit closed stdin, automation hangs forever at 0% CPU after the `+60s service=snapshot prune=7.days cleanup` log line. Position: AFTER the prompt positional argument, BEFORE the `> stdout 2> stderr` redirects. Foreground `| tail` happens to provide closed stdin (pipe stage upstream is empty) and accidentally bypasses the bug, but `> stdout.log 2> stderr.log` does not. The 9-character `</dev/null` redirect provides immediate EOF on stdin, unblocking the dispatch. **DO NOT auto-kill external operator-owned opencode sessions** when sweeping orphans between dispatches; exclude `opencode run` from pkill (per 2026-05-23 operator directive captured in memory `feedback_proactive_orphan_cleanup.md`). See `references/integration_patterns.md` §6 + memory `feedback_opencode_run_requires_dev_null_stdin.md` + CHANGELOG-2026-05-08-tool-name-regex-fix.md §Fix 4.\n6. **Pass the spec folder to the dispatched session** in the prompt: if the calling AI has an active Gate-3 spec folder, include `Spec folder: <path> (pre-approved, skip Gate 3)`. If none, ASK the user before delegating — the dispatched session cannot answer Gate 3 interactively in non-interactive `run` mode.\n7. **Prompt construction & model-craft (cli-* family precedence).** Compose every dispatch prompt via the 3-tier rule canonical in `../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md`:\n   1. **Fast path (default).** Build from the local `assets/prompt_quality_card.md`, which delegates the framework table + CLEAR check to the canonical card.\n   2. **Model override (mandatory for a profiled model).** If the target model has a profile at `../../sk-prompt/prompt-models/references/models/<id>.md`, that profile OVERRIDES the cross-model default. The **sk-prompt/prompt-models** hub owns per-model prompt-craft (framework + scaffold + gotchas, mirroring `sk-prompt/prompt-models/assets/model_profiles.json` `recommended_frameworks`); consult it before composing for any small model.\n   3. **Deep path (escalation).** Dispatch `@prompt-improver` via the Task tool (never load full `sk-prompt` inline) when any canonical **Tier 3** trigger applies — the trigger list lives in `../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` under \"Tier 3 — Deep path\"; do not re-enumerate it here.\n8. Validate dispatched session output: parse JSON events incrementally (tool calls, partial messages, final summary), run syntax checks if code generated, and cross-reference against project standards via `sk-code` surface detection plus its code-review mode when findings-first review is requested (see ALWAYS rule 12).\n9. Capture stderr (`2>&1`) to catch tool errors and warnings.\n10. Classify the use case (1 / 2 / 3) before dispatching — the smart router refuses dispatches that do not map to one of the three.\n11. **Run the Provider Auth Pre-Flight once per session** (see §3 Provider Auth Pre-Flight). Cache the configured-providers list. If the default `deepseek` is missing, ASK the user — never silently substitute the model. If a later dispatch returns an auth error, invalidate the cache and rerun the pre-flight before retrying.\n12. **Code Standards Loading (surface-aware contract)** — When dispatching for code review or code generation, instruct the dispatched session to: (1) load `sk-code`; (2) let `sk-code` emit a surface tag matching the detected stack from markers and target files; (3) load the selected surface resources and run its verification commands; (4) load `sk-code`'s code-review mode only for formal findings-first review output. Fallback: if the surface cannot be determined confidently, ask for the runtime surface and verification command set. NEVER hardcode obsolete sibling code skills in dispatch prompts.\n13. **Design Standards Loading (surface-aware contract)** — When dispatching for design or UI work, instruct the dispatched session to: (1) load `sk-design` (the hub); (2) let the hub resolve a `workflowMode` through `mode-registry.json` (interface / foundations / motion / audit / md-generator / design-mcp-open-design); (3) load the selected mode packet, set the design register, and run that mode's design verification; (4) if the work feeds Open Design, carry the `design-mcp-open-design` pairing (a nested transport packet of the hub) — the transport never decides taste. Fallback: if the design mode cannot be determined confidently, ask for the surface and design intent. NEVER treat `mcp-figma` or `design-mcp-open-design` as the taste authority, or hardcode obsolete flat design skills in dispatch prompts.\n14. **Pass the design dispatch manifest to the dispatched session** — when dispatching design or UI work, inline a `DESIGN_DISPATCH_MANIFEST v1` block in the prompt (the child cannot resolve skill paths, so the manifest travels in the payload, not by reference): `skDesignLoaded` true, `register` resolved to `Brand` or `Product` (never `unknown`), registry-valid `workflowModes`, `dials`, `loadedFiles`, and `proofDemandBack`. If the manifest cannot be assembled — `sk-design` not loaded, register unresolved, or no registry-valid mode — ASK before launching the child rather than starting a silent design dispatch. The child returns the demanded proof; the parent reconciles it on the return path.\n15. **Destructive-scope-violation prevention (RM-8) for deep-loop dispatches** — The structured permissions-matrix gate (`permissions-gate.ts`; schema and design in `references/permissions_matrix.md`) is built and unit-tested but has ZERO production callers today — no `opencode run` dispatch path invokes it, so a loaded `--permissions-matrix <path>` config or recipe field is NOT currently enforced and does NOT bypass anything. Regardless of whether a matrix config is present, any non-interactive `opencode run` with `--dangerously-skip-permissions` against a populated worktree MUST apply the four-layer mitigation — it is the only active protection today: (L1) rendered prompt contains literal `BANNED OPERATIONS` and `ALLOWED WRITE PATHS`; (L2) `--dir` points at a fresh `git worktree`; (L3) main `git status` clean OR committed, recovery-baseline commit hash recorded; (L4) for multi-phase / phase-parent targets, prefer `cli-copilot` + `gpt-5.6-sol --reasoning-effort high` (verify `gpt-5.6-sol` availability on the Copilot surface — unverified, carried over from a gpt-5.5-era check; if absent, pick an available Copilot model, don't silently fall back to the risky default) over `deepseek-v4-pro`. Background: on 2026-05-04 an `opencode-go/deepseek-v4-pro` dispatch under `/deep:review:auto` deleted 44 files across two phase folders because the only safeguard was prose and `--dangerously-skip-permissions` granted unrestricted FS write. Full incident + root cause + checklist: `references/destructive_scope_violations.md`.\n16. **Single-dispatch discipline (operator-gated, session-scoped)** — Default: launch ONE cli-* dispatch at a time across the cli-* family (cli-opencode, cli-claude-code). Wait for the dispatched agent's work to return, verify outputs exist, then SIGKILL only the dispatch THIS skill started: capture its PID at launch (`opencode run ... & OC_PID=$!`) and kill that captured PID directly plus its own orphan children (`kill -9 \"$OC_PID\" 2>/dev/null; pkill -9 -P \"$OC_PID\" 2>/dev/null`), then apply the same PID-scoped `gtimeout` / `positional_scoring_fallback:app` cleanup. (A backgrounded `opencode run &` is NOT a process-group leader unless launched with `setsid`/`set -m`, so a negative-PID group kill would target a nonexistent group and miss the process — kill the captured PID directly.) **Kill only the dispatch you started, by captured PID; never a blanket `pkill -9 -f \"opencode run\"` pattern — see Rule 5** (a blanket match kills operator-owned `opencode run` sessions too). Only launch the next dispatch (this skill OR a sibling) after the prior one is dead and RSS has dropped. **Within a deep-flow session** (deep-review / deep-research): the operator authorizes the whole multi-iteration session at start — iterations chain back-to-back with kill-between as the safety mechanism, NOT a per-iteration operator confirmation prompt. **Exception (cross-skill parallel)**: when the operator explicitly authorizes N parallel dispatches, run N concurrently — but still SIGKILL each by its own captured PID as its work returns.\n17. **Set `AI_SESSION_CHILD=1` in the dispatched session's env** when sessions may be launched through the per-session worktree wrapper (`.opencode/bin/worktree-session.sh`). A dispatched `opencode run` is an orchestrated sub-session, not a new top-level session, so it must SHARE the parent's worktree rather than allocate its own. The wrapper checks `AI_SESSION_CHILD` (plus a `git --git-common-dir` structural backstop) and exec's in place when set. Pattern: `AI_SESSION_CHILD=1 opencode run ... </dev/null`. Harmless when the wrapper is not in use. See `.opencode/bin/README.md` → \"Worktree session isolation\". Prepend `MK_SPEC_GATE_ENFORCE=0` next to it so a dispatched child never inherits an enforced spec-gate from the parent shell (belt-and-suspenders alongside the wrapper's own neutralization and the core's `AI_SESSION_CHILD` deny-narrowing): `MK_SPEC_GATE_ENFORCE=0 AI_SESSION_CHILD=1 opencode run ... </dev/null`.\n\n### ⛔ NEVER\n\n1. Invoke this skill from within OpenCode itself for a self-dispatch — refuse with the documented error message; use a sibling cli-* / fresh shell / parallel-session keywords.\n2. Pass `--share` without operator confirmation (CHK-033) — share URL exposes session contents.\n3. Trust dispatched session output blindly for security-sensitive code, send sensitive data (API keys, passwords, credentials) in prompts, or hammer the API with rapid sequential calls.\n4. Use `--pure` outside of plugin debugging (disabling plugins removes the entire point of cli-opencode dispatch).\n5. Nest `opencode run` inside a dispatched session's tool calls — use OpenCode's native Task tool for sub-agent dispatch.\n\n### ⚠️ ESCALATE IF\n\n1. OpenCode CLI is not installed and user has not acknowledged (provide `brew install opencode` or `curl -fsSL https://opencode.ai/install | bash`).\n2. Operator wants to publish a `--share` URL — get explicit confirmation per CHK-033.\n3. Binary version differs from the v1.3.17 baseline — run `opencode --version` and `opencode run --help`; surface drift and fall back or require approval.\n4. Smart router cannot map the prompt to one of the three use cases — surface the disambiguation checklist from UNKNOWN_FALLBACK.\n5. Self-invocation guard trips AND the prompt is ambiguous — surface the refusal with three remediation options (sibling cli-* / fresh shell / parallel-session keywords).\n\n### Memory Handback Protocol\n\nWhen the calling AI needs to preserve session context from an OpenCode CLI delegation, run the canonical 7-step procedure (extract `MEMORY_HANDBACK` section → build structured JSON → scrub secrets → invoke `generate-context.js` via `--stdin`/`--json`/temp-file → `memory_index_scan`). Full procedure and caveats: [`system-spec-kit/references/cli/memory_handback.md`](../../system-spec-kit/references/cli/memory_handback.md).\n\nFor read-only or hook-style recovery, use the daemon-backed CLI front doors instead of spawning OpenCode: `node .opencode/bin/spec-memory.cjs <tool>`, `node .opencode/bin/code-index.cjs <tool>`, or `node .opencode/bin/skill-advisor.cjs <tool>`. Prompt-time paths must probe warm sockets or pass `--warm-only`; exit `75` is retryable daemon/IPC unavailability, not a model failure.\n\nOpenCode-specific Memory Epilogue template: see [assets/prompt_templates.md](./assets/prompt_templates.md) §14.\n\nExample invocation:\n```bash\nprintf '%s' \"$JSON_PAYLOAD\" | node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js --stdin [spec-folder]\n```\n\n---\n\n## 5. REFERENCES AND RELATED RESOURCES\n\n### Core References\n\n- [cli_reference.md](./references/cli_reference.md) - Full subcommand/flag reference, provider auth pre-flight, models, version drift\n- [integration_patterns.md](./references/integration_patterns.md) - 3 use cases, decision tree, silent stdin\n- [self_invocation_guard.md](./references/self_invocation_guard.md) - ADR-001 layered bash + python detection contract\n- [opencode_tools.md](./references/opencode_tools.md) - Unique value props vs sibling cli-* skills\n- [agent_delegation.md](./references/agent_delegation.md) - Agent routing matrix, leaf-agent constraints\n- [destructive_scope_violations.md](./references/destructive_scope_violations.md) - RM-8 incident, root cause, four-layer prevention playbook\n\n### Templates and Assets\n\n- [prompt_templates.md](./assets/prompt_templates.md) - Copy-paste templates per use case + agent + handback\n- [prompt_quality_card.md](./assets/prompt_quality_card.md) - Executor-specific model overrides; delegates framework/CLEAR check to canonical card\n\n### Shared (cli-* family)\n- [shared_smart_router.md](../../system-spec-kit/references/cli/shared_smart_router.md) - Helper-function bodies for the smart router.\n- [memory_handback.md](../../system-spec-kit/references/cli/memory_handback.md) - Canonical 7-step Memory Handback procedure.\n\n### External\n- [OpenCode GitHub](https://github.com/sst/opencode) - Official repository\n- [OpenCode Install](https://opencode.ai/install) - Standalone installer entry point\n- [OpenCode Documentation](https://opencode.ai/docs) - Official docs\n\n### Reference Loading Notes\n\n- Load only references needed for current intent.\n- Smart Routing (Section 2) is the single routing authority.\n- `cli_reference.md` and `prompt_quality_card.md` are ALWAYS loaded as baseline.\n- The router discovers reference, asset, and script docs dynamically — task-specific resources from `references/`, templates from `assets/`, and automation from `scripts/` when present.\n\n### Related Skills\n\n`cli-claude-code` and `cli-opencode` for sibling cross-AI dispatch; `system-spec-kit` for handback; `sk-code` plus the selected overlay for generated code; `system-deep-loop` for loop execution (its `research` and `review` modes); and `mcp-code-mode` for MCP-backed tools.\n\n---\n\n## 6. SUCCESS CRITERIA\n\n### Task Completion\n\n- OpenCode CLI invoked with the correct subcommand, flags, model, agent, variant, format, and dir.\n- Self-invocation guard checked before dispatch — refused when appropriate.\n- Use case (1 / 2 / 3) classified explicitly before invocation.\n- JSON event stream captured, parsed incrementally, validated, integrated.\n- No security vulnerabilities introduced from generated code.\n- `--share` URLs opt-in with operator confirmation per CHK-033.\n- Background dispatches in `while read` loops include `</dev/null` redirect.\n- Memory Handback extracted and saved through `generate-context.js` when applicable.\n\n### Skill Quality\n\n- All numbered sections present and correctly ordered.\n- Smart routing covers all intent signals with UNKNOWN_FALLBACK.\n- Reference files provide deep-dive content without duplication.\n- Self-invocation guard pseudocode reproduced in Section 2 mirrors ADR-001.\n\n---\n\n## 7. INTEGRATION POINTS\n\n### Framework Integration\n\nThis skill operates within the behavioral framework defined in [AGENTS.md](../../../../AGENTS.md).\n\nKey integrations:\n- **Gate 2**: Skill routing via the Skill Advisor Hook (or `skill_advisor.py` fallback)\n- **Tool Routing**: Per AGENTS.md Section 6 decision tree\n- **Memory**: Context preserved via Spec Kit Memory MCP (`generate-context.js`)\n- **Validation**: `bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh` for spec-folder workflows\n\n**Tool roles**: Bash dispatches the CLI; Read/Glob/Grep validate output and probe `~/.opencode/state/` for session locks.\n\nBase directory for this skill: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode\nRelative paths in this skill (e.g., scripts/, reference/) are relative to this base directory.\nNote: file list is sampled.\n\n<skill_files>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt_templates.md</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/permissions_matrix.example-repo-wide.json</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt_quality_card.md</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/permissions_matrix.example-readonly.json</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/permissions_matrix.example-packet-local.json</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/permissions_matrix.schema.json</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/scripts/lib/dispatch-audit.mjs</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/scripts/lib/README.md</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/scripts/lib/dispatch-audit.test.mjs</file>\n<file>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/scripts/lib/dispatch-rule-checks.test.mjs</file>\n</skill_files>\n</skill_content>","metadata":{"name":"cli-opencode","dir":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode","truncated":false},"title":"Loaded skill: cli-opencode","time":{"start":1784313663489,"end":1784313663500}},"metadata":{"openai":{"itemId":"fc_0d206a5a043aa1dc016a5a773f4a04819185f3574e253eab2f"}},"id":"prt_f7161cf4d001gsHoHvOI7og70H","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161b179001t24Z3aZePXY9Mc"}}
{"type":"step_finish","timestamp":1784313663910,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"id":"prt_f7161d1a40016S1Tria5fsNjbr","reason":"tool-calls","snapshot":"c91d1d34f9ec35463a782ae0dbce29c0af8ca81d","messageID":"msg_f7161b179001t24Z3aZePXY9Mc","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","type":"step-finish","tokens":{"total":105083,"input":16759,"output":21,"reasoning":239,"cache":{"write":0,"read":88064}},"cost":0}}
{"type":"step_start","timestamp":1784313667395,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"id":"prt_f7161df41001bPKlCjana2ZbVT","messageID":"msg_f7161d316001tR0EXYHa3Q88Ji","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","snapshot":"c91d1d34f9ec35463a782ae0dbce29c0af8ca81d","type":"step-start"}}
{"type":"tool_use","timestamp":1784313692273,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_MZK3yiJhAyBp3h7mc16GhBE9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":1370,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n1370:           - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n1371: \n1372:       step_reduce_state:\n1373:         action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n1374:         command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n1375:         inputs:\n1376:           latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n1377:           newIterationFile: \"{state_paths.iteration_pattern}\"\n1378:           priorReducedState: \"{state_paths.registry}\"\n1379:         outputs:\n1380:           - \"{state_paths.registry}\"\n1381:           - \"{state_paths.dashboard}\"\n1382:           - \"{state_paths.strategy}\"\n1383:           - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n1384:           - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n1385:           - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n1386:         failure_modes:\n1387:           malformed_delta: \"skip + warn\"\n1388:           missing_iteration_file: \"no-op + error\"\n1389:           schema_mismatch: \"reject + conflict event\"\n1390:           question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n1391:         guarantee: \"Idempotent for identical inputs\"\n1392: \n1393:       step_graph_upsert:\n1394:         action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n1395:         read:\n1396:           - \"{state_paths.state_log}\"\n1397:         extract:\n1398:           - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n1399:           - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n1400:           - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n1401:           - graph_upsert_event_count: \"Count mapped node and edge events\"\n1402:         if_graph_events_present:\n1403:           bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n1404:           note: \"Skip silently when graphEvents is missing or empty.\"\n1405:         if_graph_events_missing:\n1406:           proceed: true\n1407: \n1408:       step_memory_upsert_iteration:\n1409:         action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n1410:         mcp_tool: memory_save\n1411:         invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n1412:         timeout_seconds: 5\n1413:         idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n1414:         failure_policy:\n1415:           mcp_error: \"non-fatal; log advisory warning and continue\"\n1416:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n1417:         outputs:\n1418:           - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n1419:           - memory_upsert_status: \"upserted | advisory_error\"\n1420: \n1421:       step_refresh_memory_context:\n1422:         action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n1423:         mcp_tool: memory_context\n1424:         invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n1425:         timeout_seconds: 5\n1426:         use_response:\n1427:           - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n1428:         failure_policy:\n1429:           mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n1430:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n1431:         outputs:\n1432:           - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n1433:           - memory_context_refresh_status: \"refreshed | advisory_error\"\n1434: \n1435:       step_evaluate_results:\n1436:         action: \"Verify iteration outputs and extract metrics\"\n1437:         verify:\n1438:           - file_exists: \"{state_paths.iteration_pattern}\"\n1439:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1440:           - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n1441:           - registry_updated: \"Reducer refreshed findings-registry.json\"\n1442:         extract:\n1443:           - newInfoRatio: \"From latest JSONL iteration record\"\n1444:           - findings_count: \"From latest JSONL iteration record\"\n1445:           - status: \"From latest JSONL iteration record\"\n1446:           - latest_focus: \"From latest JSONL iteration record\"\n1447:         on_missing_outputs:\n1448:           action: \"Mark iteration as 'error', continue to next\"\n1449:           # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n1450:           # so the reducer can persist the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1451:           append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n1452: \n1453:       step_telemetry_heartbeat_progress:\n1454:         action: \"Emit a single-loop progress row when iteration state changes\"\n1455:         skip_when: \"config.fanout is present\"\n1456:         command: |\n1457:           node --experimental-strip-types --input-type=module <<'EOF'\n1458:           import { existsSync, readFileSync } from 'node:fs';\n1459: \n1460:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n1461:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n1462: \n1463:           const { appendObservabilityEvent } = observabilityEvents;\n1464:           const stateLogPath = '{state_paths.state_log}';\n1465:           const timestamp = '{ISO_8601_NOW}';\n1466:           const sessionId = '{config.lineage.sessionId}';\n1467:           const generation = Number('{config.lineage.generation}');\n1468:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1469: \n1470:           function readRecords(path) {\n1471:             if (!existsSync(path)) return [];\n1472:             return readFileSync(path, 'utf8')\n1473:               .split(/\\r?\\n/)\n1474:               .map((line) => line.trim())\n1475:               .filter(Boolean)\n1476:               .map((line) => JSON.parse(line));\n1477:           }\n1478: \n1479:           function elapsedSince(value) {\n1480:             const startedAtMs = Date.parse(String(value ?? ''));\n1481:             const nowMs = Date.parse(timestamp);\n1482:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1483:             return Math.max(0, nowMs - startedAtMs);\n1484:           }\n1485: \n1486:           const records = readRecords(stateLogPath);\n1487:           const iterations = records.filter((record) => record.type === 'iteration');\n1488:           const latest = iterations.at(-1) ?? {};\n1489:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1490:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1491:             ?? timestamp;\n1492:           const elapsedMs = elapsedSince(startedAt);\n1493:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1494:           const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n1495:           const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n1496:           const row = {\n1497:             event: 'progress',\n1498:             label: 'single',\n1499:             at: timestamp,\n1500:             duration_ms: elapsedMs,\n1501:             loop_type: 'research',\n1502:             sessionId,\n1503:             generation,\n1504:             run,\n1505:             status,\n1506:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1507:           };\n1508: \n1509:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1510:             diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n1511:             diffField: 'state_hash',\n1512:           });\n1513:           if (appended) {\n1514:             try {\n1515:               appendObservabilityEvent(observabilityPath, row, {\n1516:                 producer: 'deep-research-auto',\n1517:                 stream: 'single-loop-telemetry',\n1518:                 subject: { label: row.label, sessionId, generation, run },\n1519:                 event: row.event,\n1520:                 status,\n1521:               });\n1522:             } catch {}\n1523:           }\n1524:           EOF\n1525:         working_directory: \"{repo_root}\"\n1526:         outputs:\n1527:           - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n1528: \n1529:       step_generate_dashboard:\n1530:         action: \"Generate or refresh the human-readable dashboard\"\n1531:         read:\n1532:           - \"{state_paths.state_log}\"\n1533:           - \"{state_paths.registry}\"\n1534:           - \"{state_paths.strategy}\"\n1535:         template: .opencode/skills/system-deep-loop/deep-research/assets/deep_research_dashboard.md\n1536:         output: \"{state_paths.dashboard}\"\n1537:         note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n1538: \n1539:       step_update_tracking:\n1540:         action: \"Update loop tracking variables\"\n1541:         set:\n1542:           current_iteration: \"{current_iteration + 1}\"\n1543:           stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n1544:         log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n1545: \n1546:       step_loop_decision:\n1547:         action: \"Return to step_read_state for next iteration\"\n1548:         goto: step_read_state\n1549: \n1550:   # ═══════════════════════════════════════════════════════════════\n1551:   # PHASE 3: SYNTHESIS\n1552:   # ═══════════════════════════════════════════════════════════════\n1553:   phase_synthesis:\n1554:     purpose: Compile all iteration findings into final research/research.md\n1555:     steps:\n1556: \n1557:       step_fanout_merge:\n1558:         description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n1559:         skip_when: \"config.fanout is absent\"\n1560:         command: |\n1561:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n1562:             --loop-type research \\\n1563:             --artifact-dir {artifact_dir}\n1564:         working_directory: \"{repo_root}\"\n1565:         wait_for_completion: true\n1566: \n1567:       step_hydrate_summary_metrics:\n1568:         action: \"Hydrate summary metrics before synthesis\"\n1569:         read:\n1570:           - \"{state_paths.config}\"\n1571:           - \"{state_paths.state_log}\"\n1572:           - \"{state_paths.registry}\"\n1573:           - \"{state_paths.strategy}\"\n1574:         extract:\n1575:           - iteration_count: \"Count lines where type === 'iteration'\"\n1576:           - current_iteration: \"iteration_count + 1\"\n1577:           - current_segment: \"Latest segment_start event segment, else 1\"\n1578:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n1579:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n1580:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n1581:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n1582:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n1583:           - answered_count: \"Count answered questions from strategy.md\"\n1584:           - total_questions: \"Count total questions tracked in strategy.md\"\n1585:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n1586:           - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n1587:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1588: \n1589:       step_read_all_iterations:\n1590:         action: \"Read all iteration files and strategy\"\n1591:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1592:         read_also: \"{state_paths.strategy}\"\n1593: \n1594:       step_emit_resource_map:\n1595:         action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n1596:         command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1597:         read:\n1598:           - \"{state_paths.config}\"\n1599:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1600:         write:\n1601:           - \"{state_paths.resource_map_output}\"\n1602:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1603: \n1604:       step_compile_research:\n1605:         action: \"Compile or finalize research/research.md\"\n1606:         instructions: |\n1607:           If research/research.md exists (progressive synthesis was active):\n1608:             1. Read current research/research.md\n1609:             2. Consolidate and deduplicate findings across all iterations\n1610:             3. Fill any empty sections with findings from iteration files\n1611:             4. Remove redundancy while preserving all unique findings\n1612:             5. Add convergence report as appendix\n1613:             6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1614:             7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n1615: \n1616:           If research/research.md does not exist:\n1617:             1. Create research/research.md following 17-section template\n1618:             2. Populate sections from iteration files\n1619:             3. Add citations from original sources\n1620:             4. Note unanswered questions in Open Questions section\n1621:             5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1622:             6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n1623:           Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n1624:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n1625:         output: \"{state_paths.research_output}\"\n1626: \n1627:       step_convergence_report:\n1628:         action: \"Generate and append convergence report\"\n1629:         report: |\n1630:           ## Convergence Report\n1631:           - Stop reason: {reason}\n1632:           - Total iterations: {iteration_count}\n1633:           - Questions answered: {answered_count} / {total_questions}\n1634:           - Remaining questions: {remaining_questions}\n1635:           - Last 3 iteration summaries: {last_3_summaries}\n1636:           - Convergence threshold: {convergence_threshold}\n1637:           - Divergence summary: {divergence_summary}\n1638:           - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n1639:         command: |\n1640:           node --input-type=module <<'EOF'\n1641:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1642: \n1643:           const paths = {\n1644:             stateLog: String.raw`{state_paths.state_log}`,\n1645:             registry: String.raw`{state_paths.registry}`,\n1646:             research: String.raw`{state_paths.research_output}`,\n1647:             dashboard: String.raw`{state_paths.dashboard}`,\n1648:           };\n1649: \n1650:           function hasFile(filePath) {\n1651:             try {\n1652:               return existsSync(filePath) && statSync(filePath).isFile();\n1653:             } catch {\n1654:               return false;\n1655:             }\n1656:           }\n1657: \n1658:           function readJson(filePath) {\n1659:             try {\n1660:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1661:             } catch {\n1662:               return null;\n1663:             }\n1664:           }\n1665: \n1666:           function readJsonl(filePath) {\n1667:             if (!hasFile(filePath)) return [];\n1668:             return readFileSync(filePath, 'utf8')\n1669:               .split(/\\r?\\n/)\n1670:               .map((line) => line.trim())\n1671:               .filter(Boolean)\n1672:               .flatMap((line) => {\n1673:                 try {\n1674:                   return [JSON.parse(line)];\n1675:                 } catch {\n1676:                   return [];\n1677:                 }\n1678:               });\n1679:           }\n1680: \n1681:           function countIterationFindings(record) {\n1682:             if (!record || record.type !== 'iteration') return 0;\n1683:             const numeric = Number(record.findingsCount);\n1684:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1685:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1686:             if (Array.isArray(record.findings)) return record.findings.length;\n1687:             return 0;\n1688:           }\n1689: \n1690:           function normalizeFindingKey(value) {\n1691:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1692:           }\n1693: \n1694:           function findingKeys(candidate) {\n1695:             if (typeof candidate === 'string') {\n1696:               const key = normalizeFindingKey(candidate);\n1697:               return key ? [key] : [];\n1698:             }\n1699:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1700:             return [...new Set([\n1701:               candidate.id,\n1702:               candidate.title,\n1703:               candidate.summary,\n1704:               candidate.text,\n1705:               candidate.finding,\n1706:               candidate.description,\n1707:             ].map(normalizeFindingKey).filter(Boolean))];\n1708:           }\n1709: \n1710:           function collectIterationFindingGroups(record) {\n1711:             if (!record || record.type !== 'iteration') return [];\n1712:             const structured = [record.keyFindings, record.findings]\n1713:               .find((value) => Array.isArray(value) && value.length > 0);\n1714:             if (!Array.isArray(structured)) return [];\n1715:             return structured\n1716:               .map(findingKeys)\n1717:               .filter((keys) => keys.length > 0);\n1718:           }\n1719: \n1720:           function collectRegistryFindingKeys(registry) {\n1721:             if (!Array.isArray(registry?.keyFindings)) return [];\n1722:             return registry.keyFindings\n1723:               .flatMap(findingKeys);\n1724:           }\n1725: \n1726:           function appendEvent(event) {\n1727:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1728:           }\n1729: \n1730:           const registry = readJson(paths.registry);\n1731:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1732:           const stateRecords = readJsonl(paths.stateLog);\n1733:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1734:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1735:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1736:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1737:           const identifiableFindingCount = identifiableFindingGroups.length;\n1738:           const missingArtifacts = [\n1739:             ['registry', paths.registry],\n1740:             ['research', paths.research],\n1741:             ['dashboard', paths.dashboard],\n1742:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1743:           const invariantFailures = [];\n1744:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1745:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1746:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1747:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1748:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1749: \n1750:           if (invariantFailures.length > 0) {\n1751:             appendEvent({\n1752:               type: 'event',\n1753:               event: 'synthesis_incomplete',\n1754:               mode: 'research',\n1755:               severity: 'warning',\n1756:               totalIterations: Number('{iteration_count}'),\n1757:               answeredCount: Number('{answered_count}'),\n1758:               totalQuestions: Number('{total_questions}'),\n1759:               stopReason: '{reason}',\n1760:               reason: 'synthesis_artifact_invariant_failed',\n1761:               invariantFailures,\n1762:               missingArtifacts,\n1763:               registryFindingCount,\n1764:               iterationFindingCount,\n1765:               identifiableFindingCount,\n1766:               missingStructuredFindingCount,\n1767:               timestamp: '{ISO_8601_NOW}',\n1768:             });\n1769:           } else {\n1770:             appendEvent({\n1771:               type: 'event',\n1772:               event: 'synthesis_complete',\n1773:               totalIterations: Number('{iteration_count}'),\n1774:               answeredCount: Number('{answered_count}'),\n1775:               totalQuestions: Number('{total_questions}'),\n1776:               stopReason: '{reason}',\n1777:               timestamp: '{ISO_8601_NOW}',\n1778:             });\n1779:           }\n1780:           EOF\n1781: \n1782:       step_writeback_spec_findings:\n1783:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1784:         edit: \"{spec_folder}/spec.md\"\n1785:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1786:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1787:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1788:         fail_closed_conflict_check:\n1789:           if_existing_generated_fence_present:\n1790:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1791:             on_manual_edit_conflict:\n1792:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1793:               halt: true\n1794:         instructions:\n1795:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1796:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1797:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1798:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1799:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1800:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1801: \n1802:       step_validate_post_synthesis_spec_doc:\n1803:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1804:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1805:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1806: \n1807:       step_update_config_status:\n1808:         action: \"Mark config as complete\"\n1809:         edit: \"{state_paths.config}\"\n1810:         set_field: { status: \"complete\" }\n1811: \n1812:       step_telemetry_heartbeat_terminal:\n1813:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1814:         skip_when: \"config.fanout is present\"\n1815:         terminal_events: [completed, failed, stopped]\n1816:         command: |\n1817:           node --experimental-strip-types --input-type=module <<'EOF'\n1818:           import { existsSync, readFileSync } from 'node:fs';\n1819: \n1820:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n1821:           import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n1822: \n1823:           const { appendObservabilityEvent } = observabilityEvents;\n1824:           const stateLogPath = '{state_paths.state_log}';\n1825:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1826:           const timestamp = '{ISO_8601_NOW}';\n1827:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1828:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1829:           const reason = '{reason}';\n1830:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1831: \n1832:           function readRecords(path) {\n1833:             if (!existsSync(path)) return [];\n1834:             return readFileSync(path, 'utf8')\n1835:               .split(/\\r?\\n/)\n1836:               .map((line) => line.trim())\n1837:               .filter(Boolean)\n1838:               .map((line) => JSON.parse(line));\n1839:           }\n1840: \n1841:           function elapsedSince(value) {\n1842:             const startedAtMs = Date.parse(String(value ?? ''));\n1843:             const nowMs = Date.parse(timestamp);\n1844:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1845:             return Math.max(0, nowMs - startedAtMs);\n1846:           }\n1847: \n1848:           function terminalEvent(stopReason) {\n1849:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1850:             if (stopReason === 'error') return 'failed';\n1851:             return 'completed';\n1852:           }\n1853: \n1854:           const records = readRecords(stateLogPath);\n1855:           const iterations = records.filter((record) => record.type === 'iteration');\n1856:           const latest = iterations.at(-1) ?? {};\n1857:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1858:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1859:             ?? timestamp;\n1860:           const elapsedMs = elapsedSince(startedAt);\n1861:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1862:           const event = terminalEvent(reason);\n1863:           const row = {\n1864:             event,\n1865:             label: 'single',\n1866:             terminal: true,\n1867:             reason,\n1868:             at: timestamp,\n1869:             duration_ms: elapsedMs,\n1870:             loop_type: 'research',\n1871:             sessionId,\n1872:             generation,\n1873:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1874:           };\n1875: \n1876:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1877:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1878:             diffField: 'state_hash',\n1879:           });\n1880:           if (appended) {\n1881:             try {\n1882:               appendObservabilityEvent(observabilityPath, row, {\n1883:                 producer: 'deep-research-auto',\n1884:                 stream: 'single-loop-telemetry',\n1885:                 subject: { label: row.label, sessionId, generation, reason },\n1886:                 event,\n1887:                 status: event,\n1888:               });\n1889:             } catch {}\n1890:           }\n1891:           EOF\n1892:         working_directory: \"{repo_root}\"\n1893:         outputs:\n1894:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1895: \n1896:       step_stage_artifact_dir:\n1897:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1898:         command: \"git add {state_paths.packet_dir}\"\n1899:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1900:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1901: \n1902:   # ═══════════════════════════════════════════════════════════════\n1903:   # PHASE 4: SAVE\n1904:   # ═══════════════════════════════════════════════════════════════\n1905:   phase_save:\n1906:     purpose: Preserve research context to memory system\n1907:     steps:\n1908: \n1909:       step_compose_save_payload:\n1910:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1911:         output: \"/tmp/save-context-data-<session-id>.json\"\n1912:         requirements:\n1913:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1914:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1915:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1916:         example_payload: |\n1917:           {\n1918:             \"specFolder\": \"{spec_folder}\",\n1919:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n1920:             \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n1921:             \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n1922:             \"exchanges\": [],\n1923:             \"toolCalls\": []\n1924:           }\n1925: \n1926:       step_generate_context:\n1927:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n1928:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n1929:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n1930: \n1931:       step_index_memory:\n1932:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n1933:         mcp_tool: memory_save\n1934:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n1935:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n1936: \n1937:       step_verify_save:\n1938:         action: \"Verify canonical save routed content into the correct spec document\"\n1939:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n1940:         on_fail: \"Log warning but do not block completion\"\n1941: \n1942:       step_release_lock:\n1943:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n1944:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n1945:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1946: \n1947:   # ═══════════════════════════════════════════════════════════════\n1948:   # COMPLETION\n1949:   # ═══════════════════════════════════════════════════════════════\n1950:   completion:\n1951:     message: |\n1952:       Deep research complete.\n1953:       Iterations: {iteration_count} | Stop reason: {reason}\n1954:       Questions answered: {answered_count}/{total_questions}\n1955: \n1956:       Artifacts:\n1957:         - research/research.md (compiled from {iteration_count} iterations)\n1958:         - {iteration_count} iteration files in research/\n1959:         - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n1960:         - Memory context saved\n1961: \n1962:       STATUS=OK PATH={spec_folder}\n1963:     next_steps:\n1964:       - \"/speckit:plan [feature-description]\"\n1965:       - \"/deep:research [new-topic] (for related deep research)\"\n1966:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n1967: \n1968: # ─────────────────────────────────────────────────────────────────\n1969: # ERROR RECOVERY\n1970: # ─────────────────────────────────────────────────────────────────\n1971: error_recovery:\n1972:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n1973:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n1974:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n1975:   memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n1976: \n1977: # ─────────────────────────────────────────────────────────────────\n1978: # RULES\n1979: # ─────────────────────────────────────────────────────────────────\n1980: rules:\n1981:   ALWAYS:\n1982:     - follow_workflow_phases_in_order\n1983:     - dispatch_deep_research_agent_per_iteration\n1984:     - check_convergence_before_each_iteration\n1985:     - write_all_state_to_files\n1986:     - upsert_iteration_memory_after_reducer\n1987:     - refresh_memory_context_before_next_prompt\n1988:     - save_memory_context_after_synthesis\n1989:     - respect_max_iterations_cap\n1990:   NEVER:\n1991:     - skip_convergence_check\n1992:     - dispatch_non_leaf_agents\n1993:     - hold_iteration_findings_in_memory_only\n1994:     - modify_config_after_initialization\n1995:     - overwrite_jsonl_state_log\n1996:     - proceed_without_state_file_verification\n1997: \n1998: # ─────────────────────────────────────────────────────────────────\n1999: # REFERENCE-ONLY APPENDIX\n2000: # ─────────────────────────────────────────────────────────────────\n2001: reference_only_appendix:\n2002:   checkpoint_commit:\n2003:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n2004:     commands:\n2005:       - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n2006:       - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n2007:   wave_orchestration:\n2008:     note: \"Wave execution is intentionally excluded from workflow.steps.\"\n2009:     summary:\n2010:       - \"Check whether 3+ independent unanswered questions justify a wave.\"\n2011:       - \"Dispatch up to 3 parallel agents on distinct questions.\"\n2012:       - \"Score wave results by median newInfoRatio and promote top branches.\"\n\n(End of file - total 2012 lines)\n</content>","metadata":{"preview":"          - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n\n      step_reduce_state:\n        action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n        inputs:\n          latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n          newIterationFile: \"{state_paths.iteration_pattern}\"\n          priorReducedState: \"{state_paths.registry}\"\n        outputs:\n          - \"{state_paths.registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n          - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n          - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"          - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n\n      step_reduce_state:\n        action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n        inputs:\n          latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n          newIterationFile: \"{state_paths.iteration_pattern}\"\n          priorReducedState: \"{state_paths.registry}\"\n        outputs:\n          - \"{state_paths.registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n          - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n          - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n          question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n        guarantee: \"Idempotent for identical inputs\"\n\n      step_graph_upsert:\n        action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n        read:\n          - \"{state_paths.state_log}\"\n        extract:\n          - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n          - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n          - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n          - graph_upsert_event_count: \"Count mapped node and edge events\"\n        if_graph_events_present:\n          bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n          note: \"Skip silently when graphEvents is missing or empty.\"\n        if_graph_events_missing:\n          proceed: true\n\n      step_memory_upsert_iteration:\n        action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n        timeout_seconds: 5\n        idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n        outputs:\n          - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n          - memory_upsert_status: \"upserted | advisory_error\"\n\n      step_refresh_memory_context:\n        action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n        mcp_tool: memory_context\n        invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n        timeout_seconds: 5\n        use_response:\n          - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n        outputs:\n          - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n          - memory_context_refresh_status: \"refreshed | advisory_error\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n          - registry_updated: \"Reducer refreshed findings-registry.json\"\n        extract:\n          - newInfoRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - latest_focus: \"From latest JSONL iteration record\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n          # so the reducer can persist the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_telemetry_heartbeat_progress:\n        action: \"Emit a single-loop progress row when iteration state changes\"\n        skip_when: \"config.fanout is present\"\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = '{config.lineage.sessionId}';\n          const generation = Number('{config.lineage.generation}');\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n          const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n          const row = {\n            event: 'progress',\n            label: 'single',\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            run,\n            status,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, run },\n                event: row.event,\n                status,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the human-readable dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        template: .opencode/skills/system-deep-loop/deep-research/assets/deep_research_dashboard.md\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n        log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into final research/research.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n            --loop-type research \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - divergence_summary: \"Read registry.divergence and summarize saturated directions, completed pivots, failures, overrides, Council artifact refs, and remaining frontier; else 'no divergent pivots recorded'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_compile_research:\n        action: \"Compile or finalize research/research.md\"\n        instructions: |\n          If research/research.md exists (progressive synthesis was active):\n            1. Read current research/research.md\n            2. Consolidate and deduplicate findings across all iterations\n            3. Fill any empty sections with findings from iteration files\n            4. Remove redundancy while preserving all unique findings\n            5. Add convergence report as appendix\n            6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            7. Preserve the mandatory `## Eliminated Alternatives` section, then add or replace `## Divergence Map` immediately after it and before Section 12 Open Questions. Populate it from `{state_paths.registry}` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier.\n\n          If research/research.md does not exist:\n            1. Create research/research.md following 17-section template\n            2. Populate sections from iteration files\n            3. Add citations from original sources\n            4. Note unanswered questions in Open Questions section\n            5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n            6. After the mandatory `## Eliminated Alternatives` section and before Section 12 Open Questions, add `## Divergence Map` with saturated directions, pivots taken, evidence and Council artifact references, pivot failures and audited overrides, and the remaining frontier from `{state_paths.registry}`.\n          Divergence Map documents breadth. Never claim the topic converged merely because divergent mode broadened the investigated frontier.\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n        output: \"{state_paths.research_output}\"\n\n      step_convergence_report:\n        action: \"Generate and append convergence report\"\n        report: |\n          ## Convergence Report\n          - Stop reason: {reason}\n          - Total iterations: {iteration_count}\n          - Questions answered: {answered_count} / {total_questions}\n          - Remaining questions: {remaining_questions}\n          - Last 3 iteration summaries: {last_3_summaries}\n          - Convergence threshold: {convergence_threshold}\n          - Divergence summary: {divergence_summary}\n          - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.registry}`,\n            research: String.raw`{state_paths.research_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n            \"observations\": [\"Summarize the final research conclusions and evidence.\"],\n            \"recent_context\": [\"Point to the generated research artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep research complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Questions answered: {answered_count}/{total_questions}\n\n      Artifacts:\n        - research/research.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in research/\n        - State files: config.json, state.jsonl, strategy.md, findings-registry.json, dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [feature-description]\"\n      - \"/deep:research [new-topic] (for related deep research)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer research actions). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the research/ packet as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_research_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - upsert_iteration_memory_after_reducer\n    - refresh_memory_context_before_next_prompt\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:\n      - \"git add {state_paths.iteration_pattern} {state_paths.state_log} {state_paths.strategy} {state_paths.research_output}\"\n      - 'git commit -m \"chore(deep-research): iteration {NNN} complete\"'\n  wave_orchestration:\n    note: \"Wave execution is intentionally excluded from workflow.steps.\"\n    summary:\n      - \"Check whether 3+ independent unanswered questions justify a wave.\"\n      - \"Dispatch up to 3 parallel agents on distinct questions.\"\n      - \"Score wave results by median newInfoRatio and promote top branches.\"","lineStart":1370,"lineEnd":2012,"totalLines":2012,"truncated":false}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1784313692266,"end":1784313692271}},"metadata":{"openai":{"itemId":"fc_0ef6d54251161905016a5a775c1afc8191950af4c4fcf37121"}},"id":"prt_f71624015001BbmHYZZyp6DKD3","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161d316001tR0EXYHa3Q88Ji"}}
{"type":"tool_use","timestamp":1784313692290,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_e4h45JxYuvKtNRKqjvVVWzxp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-external-orchestration/cli-opencode/references/cli_reference.md","limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-external-orchestration/cli-opencode/references/cli_reference.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"OpenCode CLI - Complete Command Reference\"\n3: description: \"Comprehensive reference for OpenCode CLI subcommands, flags, models, configuration, agent flags, sandbox boundaries, and troubleshooting. Pinned to v1.3.17.\"\n4: trigger_phrases:\n5:   - \"opencode cli reference\"\n6:   - \"opencode run flags\"\n7:   - \"opencode model selection\"\n8:   - \"opencode provider auth pre-flight\"\n9:   - \"opencode variant reasoning effort\"\n10:   - \"opencode version drift\"\n11: importance_tier: important\n12: contextType: implementation\n13: version: 1.3.0.29\n14: ---\n15: \n16: # OpenCode CLI - Complete Command Reference\n17: \n18: Comprehensive reference for the OpenCode CLI binary, every subcommand the cli-opencode skill dispatches against, the flag set it relies on, the agent surface it can target, and the failure modes that need explicit handling. Pinned to v1.3.17 baseline.\n19: \n20: ---\n21: \n22: ## 1. OVERVIEW\n23: \n24: ### Core Principle\n25: \n26: OpenCode is the framework that owns this repository. The same binary that hosts the operator's TUI session also accepts non-interactive invocations through `opencode run`. The cli-opencode skill calls `opencode run` from external runtimes (Claude Code, OpenCode, Copilot, raw shell) so the calling AI can dispatch a task into a fresh OpenCode session that loads the full plugin, skill, MCP, and Spec Kit Memory runtime.\n27: \n28: ### Purpose\n29: \n30: Provide a single-source reference for the OpenCode CLI surface — every subcommand cli-opencode invokes, every flag it pins, every agent it can route to, the version baseline it is built against, and the error envelopes that need explicit recovery.\n31: \n32: ### When to Use\n33: \n34: - Looking up an OpenCode CLI subcommand or flag during a delegation\n35: - Selecting a model + variant + agent for a dispatch\n36: - Confirming the version baseline before pinning a flag set\n37: - Troubleshooting a failed `opencode run` invocation\n38: - Confirming the self-invocation guard signal against the live binary\n39: \n40: ### Key Sources\n41: \n42: | Source | URL |\n43: |--------|-----|\n44: | **Binary** | `$(command -v opencode)` (typically `~/.superset/bin/opencode` or another local bin path) |\n45: | **Repository** | https://github.com/sst/opencode |\n46: | **Version baseline** | v1.3.17 (pinned in this reference) |\n47: | **Runtime** | Node.js 18+ for the npm install path; standalone binary on macOS |\n48: \n49: ---\n50: \n51: ## 2. INSTALLATION\n52: \n53: | Method | Command | Notes |\n54: |--------|---------|-------|\n55: | **Standalone** | `curl -fsSL https://opencode.ai/install \\| bash` | macOS / Linux installer |\n56: | **Homebrew** | `brew install opencode` | macOS package manager |\n57: | **npm global** | `npm install -g opencode-ai` | Cross-platform when Node.js 18+ is present |\n58: | **Upgrade** | `opencode upgrade [target]` | Pin a specific version with the `target` argument |\n59: | **Uninstall** | `opencode uninstall` | Removes the binary and related state |\n60: \n61: After installation, run `opencode --version` to confirm. The cli-opencode skill is pinned to v1.3.17. Newer binaries may add or rename flags — consult Section 9 (Version Drift) before relying on a non-pinned flag.\n62: \n63: ---\n64: \n65: ## 3. SUBCOMMAND MAP\n66: \n67: OpenCode exposes a multi-subcommand surface. The cli-opencode skill primarily invokes `run`, with secondary use of `serve`, `web`, `agent`, and `debug`.\n68: \n69: | Subcommand | Purpose | Invoked by cli-opencode |\n70: |------------|---------|-------------------------|\n71: | `opencode` (default) | Start the TUI in the current project | No (interactive only) |\n72: | `opencode run [message..]` | Non-interactive single-shot dispatch | YES (canonical use case) |\n73: | `opencode serve` | Start a headless server | YES (for parallel detached sessions) |\n74: | `opencode web` | Start a server plus open the web interface | YES (when the operator wants a browser surface) |\n75: | `opencode acp` | Start an ACP (Agent Client Protocol) server | No (specialized integration path) |\n76: | `opencode attach <url>` | Attach to a running OpenCode server | YES (for share-URL flows) |\n77: | `opencode agent` | Manage agent definitions | YES (for agent listing) |\n78: | `opencode debug` | Debugging and troubleshooting tools | YES (for `debug skill` and `debug agent` listings) |\n79: | `opencode mcp` | Manage MCP server registrations | No |\n80: | `opencode providers` (alias `auth`) | Manage AI providers and credentials | No (operator-driven setup) |\n81: | `opencode models [provider]` | List available models | YES (for capability discovery) |\n82: | `opencode session` | Manage sessions | No (state inspection only) |\n83: | `opencode export [sessionID]` | Export session data as JSON | YES (for memory handback flows) |\n84: | `opencode stats` | Token and cost statistics | No |\n85: | `opencode db` | Database tools | No |\n86: | `opencode plugin <module>` (alias `plug`) | Install a plugin | No (operator-driven setup) |\n87: | `opencode upgrade [target]` | Upgrade the binary | No (operator-driven) |\n88: | `opencode uninstall` | Uninstall the binary | No (operator-driven) |\n89: \n90: ---\n91: \n92: ## 4. `opencode run` FLAGS\n93: \n94: `opencode run [message..]` is the canonical non-interactive entry point. The cli-opencode skill builds every dispatch around this subcommand.\n95: \n96: ### Core flags\n97: \n98: | Flag / Option | Type | Purpose |\n99: |---------------|------|---------|\n100: | `[message..]` | positional | One or more positional message strings |\n101: | `--print-logs` | boolean | Stream logs to stderr |\n102: | `--log-level` | enum | `DEBUG`, `INFO`, `WARN`, `ERROR` |\n103: | `--pure` | boolean | Run without external plugins (skill loads disabled) |\n104: | `--command` | string | Run a known command, the message becomes its args |\n105: | `-c`, `--continue` | boolean | Continue the last session in this project |\n106: | `-s`, `--session` | string | Continue a specific session id |\n107: | `--fork` | boolean | Fork before continuing — requires `--continue` or `--session` |\n108: | `--share` | boolean | Publish a shareable URL for this session |\n109: | `-m`, `--model` | string | Provider/model selector — e.g. `deepseek/deepseek-v4-pro` |\n110: | `--agent` | string | Agent slug (loads from `.opencode/agents/<slug>.md`) |\n111: | `--format` | enum | `default` (formatted) or `json` (raw event stream) |\n112: | `-f`, `--file` | array | Attach files to the message |\n113: | `--title` | string | Session title (truncated message used when omitted) |\n114: | `--attach` | string | Attach to a running OpenCode server URL |\n115: | `-p`, `--password` | string | Basic auth password (or `OPENCODE_SERVER_PASSWORD`) |\n116: | `--dir` | string | Working directory or remote-server path |\n117: | `--port` | number | Local server port (random when omitted) |\n118: | `--variant` | string | Provider-specific reasoning effort (`high`, `max`, `minimal`, etc.) |\n119: | `--thinking` | boolean | Show thinking blocks (default false) |\n120: \n121: > **`--command` semantics (verified on v1.17.4):** the `run` message is plain text — slash-command syntax inside it (`opencode run \"/memory:search query\"`) is NOT expanded, so the command's template never reaches the model. Executing a registered command non-interactively requires `--command <family>/<name>` with the args as the message (they become `$ARGUMENTS`). Registry names are slash-namespaced (`memory/search` for `/memory:search`); a wrong name fails with the full registry list. Behavior probes of slash commands MUST use `--command`; the raw-text form only measures the model freestyling without the contract. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n122: \n123: ### cli-opencode default invocation shape\n124: \n125: The skill builds every dispatch from a base shape and overlays use-case-specific flags:\n126: \n127: ```bash\n128: opencode run \\\n129:   --model deepseek/deepseek-v4-pro \\\n130:   --agent <agent-slug> \\\n131:   --variant high \\\n132:   --format json \\\n133:   --dir \"$REPO_ROOT\" \\\n134:   \"<prompt>\"\n135: ```\n136: \n137: | Flag | Default | Reason |\n138: |------|---------|--------|\n139: | `--model` | `deepseek/deepseek-v4-pro` | Direct DeepSeek is the default provider — elevated reasoning at low cost; operator may override (e.g. `deepseek/deepseek-v4-flash`, `kimi-for-coding/k2p7`, or any live OpenAI GPT-5.6 slug: `openai/gpt-5.6`, `openai/gpt-5.6-fast`, `openai/gpt-5.6-pro`, `openai/gpt-5.6-sol`, `openai/gpt-5.6-sol-fast`, `openai/gpt-5.6-sol-pro`, `openai/gpt-5.6-terra`, `openai/gpt-5.6-terra-fast`, `openai/gpt-5.6-terra-pro`, `openai/gpt-5.6-luna`, `openai/gpt-5.6-luna-fast`, `openai/gpt-5.6-luna-pro`) |\n140: | `--agent` | per use case | Required for use case 1 / 3; optional for use case 2 |\n141: | `--variant high` | high | Routine cli-opencode dispatches benefit from elevated reasoning effort |\n142: | `--format json` | json | Structured event stream is what external runtimes parse |\n143: | `--dir` | repo root | Pin the working directory to avoid CWD ambiguity |\n144: \n145: ### Stdin handling — `</dev/null` is required for non-interactive dispatch\n146: \n147: > **opencode v1.14.39 reads stdin at startup before session creation.** If you redirect stdout/stderr to files in automation (`> stdout.log 2> stderr.log`), opencode hangs at 0% CPU after the `+60s snapshot prune cleanup` log line because stdin remains attached to the parent terminal and never receives EOF.\n148: \n149: ALWAYS append `</dev/null` AFTER the prompt argument and BEFORE the stdout/stderr redirects:\n150: \n151: ```bash\n152: opencode run --model X \"<prompt>\" </dev/null > stdout.log 2> stderr.log\n153: #                                  ^^^^^^^^^^\n154: #                                  redirects stdin from /dev/null → immediate EOF\n155: ```\n156: \n157: Foreground `| tail` accidentally works because the upstream pipe stage provides closed stdin, but `> file 2> file` does not. See `references/integration_patterns.md` §6 for the full failure-mode + fix matrix and `../CHANGELOG-2026-05-08-tool-name-regex-fix.md` §Fix 4 for the discovery context.\n158: \n159: ### Sessions, share URLs, and ports\n160: \n161: `--share` publishes the session over the OpenCode share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). External-runtime dispatches do NOT publish share URLs by default.\n162: \n163: `--port` only matters when the dispatch needs to bind a known port (e.g. for a parallel detached session that another tool will attach to). The default random port is correct for one-shot dispatches.\n164: \n165: `--continue` and `--session <id>` reuse prior session state. `--fork` branches an existing session into a new one. cli-opencode uses session continuation in memory handback flows where the calling AI wants to thread context across multiple delegations.\n166: \n167: ### Provider Auth Pre-Flight (smart fallback)\n168: \n169: Before the first dispatch in a session, run a one-shot auth pre-flight against `opencode providers list` so a missing default doesn't fail mid-dispatch. Cache the result for the session; only re-run on auth failure.\n170: \n171: ```bash\n172: # Pre-flight — one call per session\n173: PROVIDERS=$(opencode providers list 2>&1)\n174: echo \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\n175: echo \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\n176: echo \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\n177: echo \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\n178: echo \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\n179: echo \"default=$DEEPSEEK_OK minimax_token=$MINIMAX_TOKEN_OK minimax_direct=$MINIMAX_DIRECT_OK xiaomi=$XIAOMI_OK xiaomi_direct=$XIAOMI_DIRECT_OK\"\n180: ```\n181: \n182: | State | DEEPSEEK_OK | Action |\n183: |-------|-------------|--------|\n184: | Default available | 1 | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n185: | Default missing | 0 | **ASK user** before substituting (offer A: openai/gpt-5.6-sol-pro, B: login deepseek and retry, C: name a different model) — do not dispatch until configured |\n186: \n187: **MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative):\n188: \n189: | State | Condition | Action |\n190: |-------|-----------|--------|\n191: | MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n192: | Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n193: | Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n194: | Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n195: \n196: **MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n197: \n198: | State | Condition | Action |\n199: |-------|-----------|--------|\n200: | MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n201: | MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n202: | Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n203: | Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n204: | Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n205: | Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n206: \n207: **Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n208: \n209: ```bash\n210: # Recommended default — direct DeepSeek API\n211: opencode providers login deepseek\n212: \n213: # MiniMax Token Plan — DEFAULT MiniMax path (subscription). Interactive: pick \"MiniMax Token Plan (minimax.io)\".\n214: opencode auth login          # → provider minimax-coding-plan; Anthropic-compatible https://api.minimax.io/anthropic/v1 (China: api.minimaxi.com)\n215: \n216: # MiniMax Direct API — pay-per-token alternative (needs MINIMAX_API_KEY; platform endpoint https://api.minimax.io/v1)\n217: opencode providers login minimax\n218: \n219: # Xiaomi Token Plan (Europe) — provider-managed endpoint. Interactive: pick \"Xiaomi Token Plan (Europe)\".\n220: opencode auth login          # → provider xiaomi-token-plan-ams (Xiaomi Token Plan, Europe)\n221: \n222: # Xiaomi Direct API — pay-per-token alternative\n223: opencode providers login xiaomi\n224: \n225: # Z.AI GLM Coding Plan — GLM coding subscription. Interactive: pick \"Z.AI Coding Plan\".\n226: opencode auth login          # → provider zai-coding-plan; model zai-coding-plan/glm-5.2\n227: ```\n228: \n229: > Do not mix region endpoints (international `minimax.io` vs China `minimaxi.com`). Confirm live model ids with `opencode models minimax-coding-plan`. The Xiaomi endpoint is provider-managed (no documented base URL — do not invent one); confirm live model ids with `opencode models xiaomi-token-plan-ams` (Token Plan) or `opencode models xiaomi` (Direct API).\n230: \n231: **On auth-error mid-dispatch** (`401 Unauthorized`, `provider/model not found`): invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n232: \n233: ### User-facing prompt templates\n234: \n235: Surface these verbatim to the operator when the pre-flight decision tree lands on \"ASK user\" (default missing with a fallback configured, or all providers missing). Never dispatch until the operator responds.\n236: \n237: **Default missing, fallback configured:**\n238: \n239: ```text\n240: The skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\n241: A configured fallback is available. Pick one:\n242:   A) Use `openai/gpt-5.6-sol-pro --variant high` (OpenAI premium, configured now — paid)\n243:   B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n244:   C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n245:   D) Run `opencode providers login deepseek` first, then retry the original dispatch\n246:   E) Name a different model — paste the `--model <provider/model>` you want to use\n247: ```\n248: \n249: **All providers missing:**\n250: \n251: ```text\n252: No supported providers are configured on this machine. Run one:\n253:   - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n254:   - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n255:   - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n256:   - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n257:   - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n258:   - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n259:   - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n260:   - `opencode providers login openai`       (OpenAI premium alternative — paid)\n261: Which would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n262: ```\n263: \n264: **Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n265: \n266: ---\n267: \n268: ## 5. MODEL SELECTION\n269: \n270: OpenCode resolves models through configured providers. The cli-opencode skill supports `deepseek` (default), `minimax-coding-plan` (MiniMax Token Plan — default MiniMax path), `minimax` (MiniMax Direct API — pay-per-token alternative), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe — MiMo, explicitly-selectable; NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), and `xiaomi` (Xiaomi Direct API — MiMo: `xiaomi/mimo-v2.5-pro` + low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`, pay-per-token) — confirmed against `opencode providers list` and `opencode models`. Run `opencode models [provider]` for the full live list on a given install.\n271: \n272: | Provider | Example model id | Use case |\n273: |----------|------------------|----------|\n274: | `deepseek` (DEFAULT) | `deepseek/deepseek-v4-pro` | Default — deep reasoning at low cost via direct DeepSeek API |\n275: | `deepseek` | `deepseek/deepseek-v4-flash` | Latency-optimized direct-API sibling |\n276: | `kimi-for-coding` | `kimi-for-coding/k2p7` | Long-context Kimi K2.7 Code (256k; subscription plan) |\n277: | `zai-coding-plan` | `zai-coding-plan/glm-5.2` | Z.AI GLM Coding Plan — GLM-5.2 flagship long-horizon coding (1M context; subscription); omit `--agent`; verify with `opencode models zai-coding-plan` |\n278: | `minimax-coding-plan` (DEFAULT MiniMax) | `minimax-coding-plan/MiniMax-M3` | MiniMax Token Plan (subscription) — default MiniMax dispatch; omit `--agent`; verify with `opencode models minimax-coding-plan` |\n279: | `minimax` | `minimax/MiniMax-M3` | MiniMax Direct API — pay-per-token alternative; needs `MINIMAX_API_KEY`; confirm the live id via `opencode models minimax` |\n280: | `xiaomi-token-plan-ams` | `xiaomi-token-plan-ams/mimo-v2.5-pro` | Xiaomi Token Plan (Europe) — MiMo-V2.5-Pro: 1M-token context, strongly agentic (1000+ tool calls), token-efficient; omit `--agent`; verify with `opencode models xiaomi-token-plan-ams` |\n281: | `xiaomi` | `xiaomi/mimo-v2.5-pro` | Xiaomi Direct API — pay-per-token; MiMo-V2.5-Pro; confirm the live id via `opencode models xiaomi` |\n282: \n283: `opencode models <provider>` lists every model id the provider exposes. The model string passed to `--model` is always `provider/model-id`.\n284: \n285: ### Reasoning effort via `--variant`\n286: \n287: The `--variant` flag maps to provider-specific reasoning effort. Underlying-model conventions apply per provider routing.\n288: \n289: | Provider | Variant values |\n290: |----------|----------------|\n291: | `deepseek` (`deepseek-v4-pro`) | reasoning effort accepted |\n292: | `deepseek` (`deepseek-v4-flash`) | non-reasoning — `--variant` ignored |\n293: | `minimax-coding-plan` / `minimax` (MiniMax-M3) | `--variant` behavior unverified — omitted by default; confirm against the MiniMax API before relying on it |\n294: | `xiaomi-token-plan-ams` (mimo-v2.5-pro) | `--variant` maps to MiMo reasoning effort (low/medium/high); **always use `--variant high`** (confirmed accepted on opencode 1.15.13) |\n295: | `zai-coding-plan` (glm-5.2) | GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it |\n296: | `openai` GPT-5.6 (`gpt-5.6` / `gpt-5.6-fast` / `gpt-5.6-pro` / `gpt-5.6-sol` / `gpt-5.6-sol-fast` / `gpt-5.6-sol-pro` / `gpt-5.6-terra` / `gpt-5.6-terra-fast` / `gpt-5.6-terra-pro` / `gpt-5.6-luna` / `gpt-5.6-luna-fast` / `gpt-5.6-luna-pro`) | `--variant` maps to OpenAI reasoning effort — a separate lever from the model tier: `none`/`low`/`medium`/`high`/**`xhigh`** (Pro tiers — `gpt-5.6-pro` / `gpt-5.6-sol-pro` / `gpt-5.6-terra-pro` / `gpt-5.6-luna-pro`: `medium`/`high`/`xhigh` — **inferred from the now-retired `gpt-5.5-pro` mapping and unverified against the live catalog (which no longer lists `gpt-5.5-pro` to re-check); smoke-test a Pro slug at `--variant low` before relying on the restriction**). **The `-fast` slugs** (`gpt-5.6-fast` / `gpt-5.6-sol-fast` / `gpt-5.6-terra-fast` / `gpt-5.6-luna-fast`) are the low-latency **Fast** model tier (OpenAI `priority` service tier) with the same effort range — e.g. `--model openai/gpt-5.6-sol-fast --variant xhigh`. `gpt-5.6-sol` is the flagship default; confirm live slugs via `opencode models openai`. |\n297: \n298: Default skill behavior: pass `--variant high` for cross-AI dispatches. Operators may override via the prompt template's variant field.\n299: \n300: ### Model-specific operational caveats\n301: \n302: - **Kimi K2.7 Code (`kimi-for-coding/k2p7`) over-exploration (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`.\n303: - **GLM-5.2 (`zai-coding-plan/glm-5.2`) latency variance (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45 transient dispatch failures (retry the cell). Empirical prompt framework: COSTAR (benchmark 008).\n304: - **GLM-5.2 vision (image input):** `glm-5.2` is natively multimodal (vision-to-code), but `opencode run --file <image>` does NOT deliver images to this provider — upstream #20802 for custom OpenAI-compatible providers (confirmed 2026-06-28: `--file` → `NO_IMAGE_RECEIVED`). For image input use the direct Z.AI Coding Plan multimodal API (base64 `image_url` at `https://api.z.ai/api/coding/paas/v4/chat/completions`) — a deviation from this skill's dispatch path justified only by the verified #20802 breakage; see `../../sk-prompt/prompt-models/references/models/glm-5.2.md` §7.\n305: \n306: ---\n307: \n308: ## 6. AGENT FLAG\n309: \n310: `--agent <slug>` loads an agent definition from `.opencode/agents/<slug>.md` (project-local) or the user-level fallback. The agent definition's frontmatter pins the model, tool permissions, and system prompt that shape the dispatch.\n311: \n312: ### Discovering agents\n313: \n314: | Command | What it shows |\n315: |---------|---------------|\n316: | `opencode agent list` | All registered agent slugs across project + user scopes |\n317: | `opencode debug agent <slug>` | Resolved frontmatter and system prompt for a slug |\n318: | `opencode debug skill <slug>` | Skill resolution for a slug if the agent loads one |\n319: \n320: ### Agent slugs in this repo\n321: \n322: | Slug | Role |\n323: |------|------|\n324: | `general` | Implementation, default subagent |\n325: | `context` | Read-only retrieval and search |\n326: | `orchestrate` | Multi-agent coordination |\n327: | `write` | Documentation generation |\n328: | `review` | Code review and PR analysis |\n329: | `debug` | Fresh-perspective debugging |\n330: | `deep-research` | Iterative research loop executor |\n331: | `deep-review` | Iterative code review loop executor |\n332: | `ai-council` | Multi-strategy planning |\n333: | `deep-improvement` | Agent improvement proposal mutator |\n334: \n335: The cli-opencode skill defers to the calling AI on agent selection — see `references/agent_delegation.md` for the routing matrix and `assets/prompt_templates.md` for canonical invocation shapes.\n336: \n337: ---\n338: \n339: ## 7. OUTPUT FORMAT AND EVENT STREAM\n340: \n341: `--format default` produces a human-formatted log. `--format json` emits a newline-delimited JSON event stream.\n342: \n343: ### JSON event shape (v1.3.17)\n344: \n345: Each line is a JSON object with at minimum:\n346: \n347: | Field | Meaning |\n348: |-------|---------|\n349: | `type` | Event type (`session.started`, `message.delta`, `tool.call`, `tool.result`, `session.completed`, ...) |\n350: | `timestamp` | ISO 8601 UTC timestamp |\n351: | `session_id` | The session id assigned by OpenCode |\n352: | `payload` | Type-specific payload |\n353: \n354: External runtimes parse the stream incrementally to surface tool calls, partial messages, and the final summary. cli-opencode prompt templates always pass `--format json` so the calling AI parses structured events instead of guessing format boundaries.\n355: \n356: ---\n357: \n358: ## 8. STATE LOCATION AND SHARE URLS\n359: \n360: ### State directory\n361: \n362: OpenCode persists session state in a shared SQLite database and storage tree under `~/.local/share/opencode/`:\n363: \n364: - `opencode.db` (`-shm`/`-wal` companions) — the session/message database\n365: - `storage/` — per-session structured artifacts\n366: - `snapshot/` — working-tree snapshots\n367: \n368: There is no per-session directory under `~/.opencode/state/<session_id>/` on a standard install — that path does not exist on this runtime layout. To inspect a specific session, use `opencode export <session_id>` (§3) rather than reading files from a state directory. The cli-opencode self-invocation guard's Layer 3 lock-file probe (`~/.opencode/state/<id>/lock`, per ADR-001) targets the older path as a best-effort third layer on top of the env-var and process-ancestry checks; treat it as a heuristic, not a verified-present artifact, on installs where `~/.opencode/state/` does not exist.\n369: \n370: ### Share URLs\n371: \n372: `--share` publishes a session URL via OpenCode's share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). The CHK-033 P1 checklist item requires operator confirmation before publishing a share URL because the URL exposes the session contents.\n373: \n374: ---\n375: \n376: ## 9. VERSION DRIFT\n377: \n378: This reference is pinned to OpenCode v1.3.17. If the live binary reports a different version, do the following:\n379: \n380: 1. Run `opencode run --help` and diff the flag list against Section 4.\n381: 2. Run `opencode --help` and diff the subcommand list against Section 3.\n382: 3. If a flag was renamed, prefer the new name in the dispatch. If a flag was removed, fall back to the closest analogue and surface the drift in the calling AI's response.\n383: 4. If the operator's machine has a major version bump (v1.4+, v2.x), re-validate the entire skill against the new flag table and bump the cli-opencode minor version.\n384: \n385: ### Failure modes specific to drift\n386: \n387: | Symptom | Likely cause |\n388: |---------|--------------|\n389: | `unknown option --variant` | v1.2 or earlier — variant flag was named `--reasoning` |\n390: | `unknown option --share` | Older standalone build without share infrastructure |\n391: | `unknown option --format json` | v1.0 — JSON event stream was the default and the flag did not exist |\n392: | `MODULE_NOT_FOUND` | Plugin loader crash; rerun with `--pure` to bypass plugins |\n393: \n394: ---\n395: \n396: ## 10. TROUBLESHOOTING\n397: \n398: | Symptom | Cause | Fix |\n399: |---------|-------|-----|\n400: | `command not found: opencode` | Binary not on PATH | Install via standalone installer or `brew install opencode` |\n401: | `OPENCODE_SERVER_PASSWORD required` | Server enforces basic auth | Pass `-p <password>` or set the env var |\n402: | `provider/model not found` | Provider not configured | Run `opencode providers` to enumerate, then `auth login <provider>` |\n403: | Empty output stream | `--format default` with non-TTY parent | Pass `--format json` and parse the event stream |\n404: | Session never finishes | Tool call hung | Run `opencode export <session_id>` and inspect the message log it returns |\n405: | Plugin load crash | Misconfigured plugin | Rerun with `--pure` to bypass all plugins |\n406: | Self-invocation refused | cli-opencode detected an in-OpenCode runtime | Use a sibling cli-* skill or a fresh shell session — see ADR-001 |\n407: | `--share` URL leaks | Share infrastructure published a session containing secrets | Operator MUST confirm before publishing per CHK-033 |\n408: \n409: ---\n410: \n411: ## 11. RELATED RESOURCES\n412: \n413: - `./integration_patterns.md` - The three documented use cases and their copy-paste invocation shapes\n414: - `./agent_delegation.md` - Agent routing matrix and invocation patterns\n415: - `./opencode_tools.md` - Unique capabilities (full plugin/skill/MCP runtime, parallel detached sessions)\n416: - `../assets/prompt_templates.md` - Copy-paste prompt templates per use case\n417: - `../assets/prompt_quality_card.md` - Framework selection and CLEAR 5-check\n418: - `../SKILL.md` - Skill entry point and smart router\n\n(End of file - total 418 lines)\n</content>","metadata":{"preview":"---\ntitle: \"OpenCode CLI - Complete Command Reference\"\ndescription: \"Comprehensive reference for OpenCode CLI subcommands, flags, models, configuration, agent flags, sandbox boundaries, and troubleshooting. Pinned to v1.3.17.\"\ntrigger_phrases:\n  - \"opencode cli reference\"\n  - \"opencode run flags\"\n  - \"opencode model selection\"\n  - \"opencode provider auth pre-flight\"\n  - \"opencode variant reasoning effort\"\n  - \"opencode version drift\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.3.0.29\n---\n\n# OpenCode CLI - Complete Command Reference\n\nComprehensive reference for the OpenCode CLI binary, every subcommand the cli-opencode skill dispatches against, the flag set it relies on, the agent surface it can target, and the failure modes that need explicit handling. Pinned to v1.3.17 baseline.\n\n---","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/cli-external-orchestration/cli-opencode/references/cli_reference.md","text":"---\ntitle: \"OpenCode CLI - Complete Command Reference\"\ndescription: \"Comprehensive reference for OpenCode CLI subcommands, flags, models, configuration, agent flags, sandbox boundaries, and troubleshooting. Pinned to v1.3.17.\"\ntrigger_phrases:\n  - \"opencode cli reference\"\n  - \"opencode run flags\"\n  - \"opencode model selection\"\n  - \"opencode provider auth pre-flight\"\n  - \"opencode variant reasoning effort\"\n  - \"opencode version drift\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.3.0.29\n---\n\n# OpenCode CLI - Complete Command Reference\n\nComprehensive reference for the OpenCode CLI binary, every subcommand the cli-opencode skill dispatches against, the flag set it relies on, the agent surface it can target, and the failure modes that need explicit handling. Pinned to v1.3.17 baseline.\n\n---\n\n## 1. OVERVIEW\n\n### Core Principle\n\nOpenCode is the framework that owns this repository. The same binary that hosts the operator's TUI session also accepts non-interactive invocations through `opencode run`. The cli-opencode skill calls `opencode run` from external runtimes (Claude Code, OpenCode, Copilot, raw shell) so the calling AI can dispatch a task into a fresh OpenCode session that loads the full plugin, skill, MCP, and Spec Kit Memory runtime.\n\n### Purpose\n\nProvide a single-source reference for the OpenCode CLI surface — every subcommand cli-opencode invokes, every flag it pins, every agent it can route to, the version baseline it is built against, and the error envelopes that need explicit recovery.\n\n### When to Use\n\n- Looking up an OpenCode CLI subcommand or flag during a delegation\n- Selecting a model + variant + agent for a dispatch\n- Confirming the version baseline before pinning a flag set\n- Troubleshooting a failed `opencode run` invocation\n- Confirming the self-invocation guard signal against the live binary\n\n### Key Sources\n\n| Source | URL |\n|--------|-----|\n| **Binary** | `$(command -v opencode)` (typically `~/.superset/bin/opencode` or another local bin path) |\n| **Repository** | https://github.com/sst/opencode |\n| **Version baseline** | v1.3.17 (pinned in this reference) |\n| **Runtime** | Node.js 18+ for the npm install path; standalone binary on macOS |\n\n---\n\n## 2. INSTALLATION\n\n| Method | Command | Notes |\n|--------|---------|-------|\n| **Standalone** | `curl -fsSL https://opencode.ai/install \\| bash` | macOS / Linux installer |\n| **Homebrew** | `brew install opencode` | macOS package manager |\n| **npm global** | `npm install -g opencode-ai` | Cross-platform when Node.js 18+ is present |\n| **Upgrade** | `opencode upgrade [target]` | Pin a specific version with the `target` argument |\n| **Uninstall** | `opencode uninstall` | Removes the binary and related state |\n\nAfter installation, run `opencode --version` to confirm. The cli-opencode skill is pinned to v1.3.17. Newer binaries may add or rename flags — consult Section 9 (Version Drift) before relying on a non-pinned flag.\n\n---\n\n## 3. SUBCOMMAND MAP\n\nOpenCode exposes a multi-subcommand surface. The cli-opencode skill primarily invokes `run`, with secondary use of `serve`, `web`, `agent`, and `debug`.\n\n| Subcommand | Purpose | Invoked by cli-opencode |\n|------------|---------|-------------------------|\n| `opencode` (default) | Start the TUI in the current project | No (interactive only) |\n| `opencode run [message..]` | Non-interactive single-shot dispatch | YES (canonical use case) |\n| `opencode serve` | Start a headless server | YES (for parallel detached sessions) |\n| `opencode web` | Start a server plus open the web interface | YES (when the operator wants a browser surface) |\n| `opencode acp` | Start an ACP (Agent Client Protocol) server | No (specialized integration path) |\n| `opencode attach <url>` | Attach to a running OpenCode server | YES (for share-URL flows) |\n| `opencode agent` | Manage agent definitions | YES (for agent listing) |\n| `opencode debug` | Debugging and troubleshooting tools | YES (for `debug skill` and `debug agent` listings) |\n| `opencode mcp` | Manage MCP server registrations | No |\n| `opencode providers` (alias `auth`) | Manage AI providers and credentials | No (operator-driven setup) |\n| `opencode models [provider]` | List available models | YES (for capability discovery) |\n| `opencode session` | Manage sessions | No (state inspection only) |\n| `opencode export [sessionID]` | Export session data as JSON | YES (for memory handback flows) |\n| `opencode stats` | Token and cost statistics | No |\n| `opencode db` | Database tools | No |\n| `opencode plugin <module>` (alias `plug`) | Install a plugin | No (operator-driven setup) |\n| `opencode upgrade [target]` | Upgrade the binary | No (operator-driven) |\n| `opencode uninstall` | Uninstall the binary | No (operator-driven) |\n\n---\n\n## 4. `opencode run` FLAGS\n\n`opencode run [message..]` is the canonical non-interactive entry point. The cli-opencode skill builds every dispatch around this subcommand.\n\n### Core flags\n\n| Flag / Option | Type | Purpose |\n|---------------|------|---------|\n| `[message..]` | positional | One or more positional message strings |\n| `--print-logs` | boolean | Stream logs to stderr |\n| `--log-level` | enum | `DEBUG`, `INFO`, `WARN`, `ERROR` |\n| `--pure` | boolean | Run without external plugins (skill loads disabled) |\n| `--command` | string | Run a known command, the message becomes its args |\n| `-c`, `--continue` | boolean | Continue the last session in this project |\n| `-s`, `--session` | string | Continue a specific session id |\n| `--fork` | boolean | Fork before continuing — requires `--continue` or `--session` |\n| `--share` | boolean | Publish a shareable URL for this session |\n| `-m`, `--model` | string | Provider/model selector — e.g. `deepseek/deepseek-v4-pro` |\n| `--agent` | string | Agent slug (loads from `.opencode/agents/<slug>.md`) |\n| `--format` | enum | `default` (formatted) or `json` (raw event stream) |\n| `-f`, `--file` | array | Attach files to the message |\n| `--title` | string | Session title (truncated message used when omitted) |\n| `--attach` | string | Attach to a running OpenCode server URL |\n| `-p`, `--password` | string | Basic auth password (or `OPENCODE_SERVER_PASSWORD`) |\n| `--dir` | string | Working directory or remote-server path |\n| `--port` | number | Local server port (random when omitted) |\n| `--variant` | string | Provider-specific reasoning effort (`high`, `max`, `minimal`, etc.) |\n| `--thinking` | boolean | Show thinking blocks (default false) |\n\n> **`--command` semantics (verified on v1.17.4):** the `run` message is plain text — slash-command syntax inside it (`opencode run \"/memory:search query\"`) is NOT expanded, so the command's template never reaches the model. Executing a registered command non-interactively requires `--command <family>/<name>` with the args as the message (they become `$ARGUMENTS`). Registry names are slash-namespaced (`memory/search` for `/memory:search`); a wrong name fails with the full registry list. Behavior probes of slash commands MUST use `--command`; the raw-text form only measures the model freestyling without the contract. Consequences: (a) any behavior/adherence probe of a slash command MUST use `--command`, and the raw-text form is only valid as a labeled negative control; (b) inside `` !`…` `` template injections `$ARGUMENTS` expands like `\"$@\"` — one word per argument — so renderer scripts must join argv themselves.\n\n### cli-opencode default invocation shape\n\nThe skill builds every dispatch from a base shape and overlays use-case-specific flags:\n\n```bash\nopencode run \\\n  --model deepseek/deepseek-v4-pro \\\n  --agent <agent-slug> \\\n  --variant high \\\n  --format json \\\n  --dir \"$REPO_ROOT\" \\\n  \"<prompt>\"\n```\n\n| Flag | Default | Reason |\n|------|---------|--------|\n| `--model` | `deepseek/deepseek-v4-pro` | Direct DeepSeek is the default provider — elevated reasoning at low cost; operator may override (e.g. `deepseek/deepseek-v4-flash`, `kimi-for-coding/k2p7`, or any live OpenAI GPT-5.6 slug: `openai/gpt-5.6`, `openai/gpt-5.6-fast`, `openai/gpt-5.6-pro`, `openai/gpt-5.6-sol`, `openai/gpt-5.6-sol-fast`, `openai/gpt-5.6-sol-pro`, `openai/gpt-5.6-terra`, `openai/gpt-5.6-terra-fast`, `openai/gpt-5.6-terra-pro`, `openai/gpt-5.6-luna`, `openai/gpt-5.6-luna-fast`, `openai/gpt-5.6-luna-pro`) |\n| `--agent` | per use case | Required for use case 1 / 3; optional for use case 2 |\n| `--variant high` | high | Routine cli-opencode dispatches benefit from elevated reasoning effort |\n| `--format json` | json | Structured event stream is what external runtimes parse |\n| `--dir` | repo root | Pin the working directory to avoid CWD ambiguity |\n\n### Stdin handling — `</dev/null` is required for non-interactive dispatch\n\n> **opencode v1.14.39 reads stdin at startup before session creation.** If you redirect stdout/stderr to files in automation (`> stdout.log 2> stderr.log`), opencode hangs at 0% CPU after the `+60s snapshot prune cleanup` log line because stdin remains attached to the parent terminal and never receives EOF.\n\nALWAYS append `</dev/null` AFTER the prompt argument and BEFORE the stdout/stderr redirects:\n\n```bash\nopencode run --model X \"<prompt>\" </dev/null > stdout.log 2> stderr.log\n#                                  ^^^^^^^^^^\n#                                  redirects stdin from /dev/null → immediate EOF\n```\n\nForeground `| tail` accidentally works because the upstream pipe stage provides closed stdin, but `> file 2> file` does not. See `references/integration_patterns.md` §6 for the full failure-mode + fix matrix and `../CHANGELOG-2026-05-08-tool-name-regex-fix.md` §Fix 4 for the discovery context.\n\n### Sessions, share URLs, and ports\n\n`--share` publishes the session over the OpenCode share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). External-runtime dispatches do NOT publish share URLs by default.\n\n`--port` only matters when the dispatch needs to bind a known port (e.g. for a parallel detached session that another tool will attach to). The default random port is correct for one-shot dispatches.\n\n`--continue` and `--session <id>` reuse prior session state. `--fork` branches an existing session into a new one. cli-opencode uses session continuation in memory handback flows where the calling AI wants to thread context across multiple delegations.\n\n### Provider Auth Pre-Flight (smart fallback)\n\nBefore the first dispatch in a session, run a one-shot auth pre-flight against `opencode providers list` so a missing default doesn't fail mid-dispatch. Cache the result for the session; only re-run on auth failure.\n\n```bash\n# Pre-flight — one call per session\nPROVIDERS=$(opencode providers list 2>&1)\necho \"$PROVIDERS\" | grep -q \"deepseek\"            && DEEPSEEK_OK=1       || DEEPSEEK_OK=0\necho \"$PROVIDERS\" | grep -q \"minimax-coding-plan\" && MINIMAX_TOKEN_OK=1  || MINIMAX_TOKEN_OK=0   # MiniMax Token Plan (default MiniMax path)\necho \"$PROVIDERS\" | grep -qE \"minimax([^-]|$)\"    && MINIMAX_DIRECT_OK=1 || MINIMAX_DIRECT_OK=0  # MiniMax Direct API (pay-per-token); regex skips the coding-plan provider\necho \"$PROVIDERS\" | grep -q \"xiaomi-token-plan-ams\" && XIAOMI_OK=1       || XIAOMI_OK=0          # Xiaomi Token Plan (Europe)\necho \"$PROVIDERS\" | grep -qE \"xiaomi([^-]|$)\"     && XIAOMI_DIRECT_OK=1 || XIAOMI_DIRECT_OK=0   # Xiaomi Direct API (pay-per-token); regex skips the token-plan-ams provider\necho \"default=$DEEPSEEK_OK minimax_token=$MINIMAX_TOKEN_OK minimax_direct=$MINIMAX_DIRECT_OK xiaomi=$XIAOMI_OK xiaomi_direct=$XIAOMI_DIRECT_OK\"\n```\n\n| State | DEEPSEEK_OK | Action |\n|-------|-------------|--------|\n| Default available | 1 | Proceed with `--model deepseek/deepseek-v4-pro --variant high` |\n| Default missing | 0 | **ASK user** before substituting (offer A: openai/gpt-5.6-sol-pro, B: login deepseek and retry, C: name a different model) — do not dispatch until configured |\n\n**MiniMax routing** (default = Token Plan; Direct API is the pay-per-token alternative):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiniMax requested (default) | `MINIMAX_TOKEN_OK=1` | Proceed with `--model minimax-coding-plan/MiniMax-M3` — **omit `--agent`** (rejected on opencode 1.15.13) |\n| Token Plan not configured | `MINIMAX_TOKEN_OK=0` | **ASK user** to run `opencode auth login` → MiniMax Token Plan — never substitute silently |\n| Direct API explicitly requested | `MINIMAX_DIRECT_OK=1` | Proceed with `--model minimax/MiniMax-M3` (pay-per-token; confirm the live id via `opencode models minimax`) |\n| Direct API requested, not configured | `MINIMAX_DIRECT_OK=0` | **ASK user** to configure the `minimax` provider (`MINIMAX_API_KEY`) — do not substitute silently |\n\n**MiMo routing** (Xiaomi Token Plan Europe and Xiaomi Direct API; explicitly-selectable — first match wins):\n\n| State | Condition | Action |\n|-------|-----------|--------|\n| MiMo requested (default) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` — **omit `--agent`** (`--agent general` warns and falls back on opencode 1.15.13). Confirm the live id via `opencode models xiaomi` |\n| MiMo speed variant (\"ultraspeed\", latency-sensitive) | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro-ultraspeed` — low-latency MiMo-V2.5-Pro tier, same prompt contract |\n| Token Plan explicitly requested | `XIAOMI_OK=1` | `--model xiaomi-token-plan-ams/mimo-v2.5-pro` — NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead |\n| Token Plan not configured | `XIAOMI_OK=0` | **ASK user** to run `opencode auth login` → Xiaomi Token Plan (Europe) — never substitute silently |\n| Direct API explicitly requested | `XIAOMI_DIRECT_OK=1` | Proceed with `--model xiaomi/mimo-v2.5-pro` or `xiaomi/mimo-v2.5-pro-ultraspeed` (pay-per-token; confirm live ids via `opencode models xiaomi`) |\n| Direct API requested, not configured | `XIAOMI_DIRECT_OK=0` | **ASK user** to run `opencode providers login xiaomi` — never substitute silently |\n\n**Login / setup command shapes** (the AI surfaces these to the user; the user runs them in their own terminal):\n\n```bash\n# Recommended default — direct DeepSeek API\nopencode providers login deepseek\n\n# MiniMax Token Plan — DEFAULT MiniMax path (subscription). Interactive: pick \"MiniMax Token Plan (minimax.io)\".\nopencode auth login          # → provider minimax-coding-plan; Anthropic-compatible https://api.minimax.io/anthropic/v1 (China: api.minimaxi.com)\n\n# MiniMax Direct API — pay-per-token alternative (needs MINIMAX_API_KEY; platform endpoint https://api.minimax.io/v1)\nopencode providers login minimax\n\n# Xiaomi Token Plan (Europe) — provider-managed endpoint. Interactive: pick \"Xiaomi Token Plan (Europe)\".\nopencode auth login          # → provider xiaomi-token-plan-ams (Xiaomi Token Plan, Europe)\n\n# Xiaomi Direct API — pay-per-token alternative\nopencode providers login xiaomi\n\n# Z.AI GLM Coding Plan — GLM coding subscription. Interactive: pick \"Z.AI Coding Plan\".\nopencode auth login          # → provider zai-coding-plan; model zai-coding-plan/glm-5.2\n```\n\n> Do not mix region endpoints (international `minimax.io` vs China `minimaxi.com`). Confirm live model ids with `opencode models minimax-coding-plan`. The Xiaomi endpoint is provider-managed (no documented base URL — do not invent one); confirm live model ids with `opencode models xiaomi-token-plan-ams` (Token Plan) or `opencode models xiaomi` (Direct API).\n\n**On auth-error mid-dispatch** (`401 Unauthorized`, `provider/model not found`): invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n### User-facing prompt templates\n\nSurface these verbatim to the operator when the pre-flight decision tree lands on \"ASK user\" (default missing with a fallback configured, or all providers missing). Never dispatch until the operator responds.\n\n**Default missing, fallback configured:**\n\n```text\nThe skill default `deepseek/deepseek-v4-pro` is not configured on this machine.\nA configured fallback is available. Pick one:\n  A) Use `openai/gpt-5.6-sol-pro --variant high` (OpenAI premium, configured now — paid)\n  B) Use `xiaomi/mimo-v2.5-pro --variant high` (Xiaomi Direct API, configured now) — or `xiaomi/mimo-v2.5-pro-ultraspeed --variant high` for latency-sensitive runs\n  C) Use `kimi-for-coding/k2p7` (Kimi For Coding plan, configured now — subscription)\n  D) Run `opencode providers login deepseek` first, then retry the original dispatch\n  E) Name a different model — paste the `--model <provider/model>` you want to use\n```\n\n**All providers missing:**\n\n```text\nNo supported providers are configured on this machine. Run one:\n  - `opencode providers login deepseek`     (recommended — default for cli-opencode)\n  - `opencode auth login`                   (MiniMax Token Plan — default MiniMax path; pick \"MiniMax Token Plan (minimax.io)\" → provider minimax-coding-plan; model minimax-coding-plan/MiniMax-M3)\n  - `opencode providers login minimax`      (MiniMax Direct API — pay-per-token; needs MINIMAX_API_KEY; model minimax/MiniMax-M3)\n  - `opencode auth login`                   (Xiaomi Token Plan — default Xiaomi path; pick \"Xiaomi Token Plan (Europe)\" → provider xiaomi-token-plan-ams; model xiaomi-token-plan-ams/mimo-v2.5-pro)\n  - `opencode providers login xiaomi`       (Xiaomi Direct API — pay-per-token; models xiaomi/mimo-v2.5-pro and xiaomi/mimo-v2.5-pro-ultraspeed)\n  - `opencode auth login`                   (Kimi For Coding plan — Kimi/Moonshot coding subscription; provider kimi-for-coding; model kimi-for-coding/k2p7)\n  - `opencode auth login`                   (Z.AI GLM Coding Plan — GLM coding subscription; provider zai-coding-plan; model zai-coding-plan/glm-5.2)\n  - `opencode providers login openai`       (OpenAI premium alternative — paid)\nWhich would you like to set up? Confirm when login finishes; the skill will retry the original dispatch.\n```\n\n**Error-recovery contract.** If a dispatch returns an auth error after pre-flight passed (credential expired or rotated), invalidate the cache, rerun the pre-flight, and apply the same decision tree before retrying. Never substitute a model the user didn't approve.\n\n---\n\n## 5. MODEL SELECTION\n\nOpenCode resolves models through configured providers. The cli-opencode skill supports `deepseek` (default), `minimax-coding-plan` (MiniMax Token Plan — default MiniMax path), `minimax` (MiniMax Direct API — pay-per-token alternative), `xiaomi-token-plan-ams` (Xiaomi Token Plan Europe — MiMo, explicitly-selectable; NOTE: observed not resolving on this install 2026-06-11 (ProviderModelNotFoundError surfaced as 'Unexpected server error'); re-auth via `opencode auth login` or use the `xiaomi` Direct API instead), and `xiaomi` (Xiaomi Direct API — MiMo: `xiaomi/mimo-v2.5-pro` + low-latency `xiaomi/mimo-v2.5-pro-ultraspeed`, pay-per-token) — confirmed against `opencode providers list` and `opencode models`. Run `opencode models [provider]` for the full live list on a given install.\n\n| Provider | Example model id | Use case |\n|----------|------------------|----------|\n| `deepseek` (DEFAULT) | `deepseek/deepseek-v4-pro` | Default — deep reasoning at low cost via direct DeepSeek API |\n| `deepseek` | `deepseek/deepseek-v4-flash` | Latency-optimized direct-API sibling |\n| `kimi-for-coding` | `kimi-for-coding/k2p7` | Long-context Kimi K2.7 Code (256k; subscription plan) |\n| `zai-coding-plan` | `zai-coding-plan/glm-5.2` | Z.AI GLM Coding Plan — GLM-5.2 flagship long-horizon coding (1M context; subscription); omit `--agent`; verify with `opencode models zai-coding-plan` |\n| `minimax-coding-plan` (DEFAULT MiniMax) | `minimax-coding-plan/MiniMax-M3` | MiniMax Token Plan (subscription) — default MiniMax dispatch; omit `--agent`; verify with `opencode models minimax-coding-plan` |\n| `minimax` | `minimax/MiniMax-M3` | MiniMax Direct API — pay-per-token alternative; needs `MINIMAX_API_KEY`; confirm the live id via `opencode models minimax` |\n| `xiaomi-token-plan-ams` | `xiaomi-token-plan-ams/mimo-v2.5-pro` | Xiaomi Token Plan (Europe) — MiMo-V2.5-Pro: 1M-token context, strongly agentic (1000+ tool calls), token-efficient; omit `--agent`; verify with `opencode models xiaomi-token-plan-ams` |\n| `xiaomi` | `xiaomi/mimo-v2.5-pro` | Xiaomi Direct API — pay-per-token; MiMo-V2.5-Pro; confirm the live id via `opencode models xiaomi` |\n\n`opencode models <provider>` lists every model id the provider exposes. The model string passed to `--model` is always `provider/model-id`.\n\n### Reasoning effort via `--variant`\n\nThe `--variant` flag maps to provider-specific reasoning effort. Underlying-model conventions apply per provider routing.\n\n| Provider | Variant values |\n|----------|----------------|\n| `deepseek` (`deepseek-v4-pro`) | reasoning effort accepted |\n| `deepseek` (`deepseek-v4-flash`) | non-reasoning — `--variant` ignored |\n| `minimax-coding-plan` / `minimax` (MiniMax-M3) | `--variant` behavior unverified — omitted by default; confirm against the MiniMax API before relying on it |\n| `xiaomi-token-plan-ams` (mimo-v2.5-pro) | `--variant` maps to MiMo reasoning effort (low/medium/high); **always use `--variant high`** (confirmed accepted on opencode 1.15.13) |\n| `zai-coding-plan` (glm-5.2) | GLM has native `reasoning_effort` (high/max); whether opencode `--variant` forwards to it is unverified — smoke-test before relying on it |\n| `openai` GPT-5.6 (`gpt-5.6` / `gpt-5.6-fast` / `gpt-5.6-pro` / `gpt-5.6-sol` / `gpt-5.6-sol-fast` / `gpt-5.6-sol-pro` / `gpt-5.6-terra` / `gpt-5.6-terra-fast` / `gpt-5.6-terra-pro` / `gpt-5.6-luna` / `gpt-5.6-luna-fast` / `gpt-5.6-luna-pro`) | `--variant` maps to OpenAI reasoning effort — a separate lever from the model tier: `none`/`low`/`medium`/`high`/**`xhigh`** (Pro tiers — `gpt-5.6-pro` / `gpt-5.6-sol-pro` / `gpt-5.6-terra-pro` / `gpt-5.6-luna-pro`: `medium`/`high`/`xhigh` — **inferred from the now-retired `gpt-5.5-pro` mapping and unverified against the live catalog (which no longer lists `gpt-5.5-pro` to re-check); smoke-test a Pro slug at `--variant low` before relying on the restriction**). **The `-fast` slugs** (`gpt-5.6-fast` / `gpt-5.6-sol-fast` / `gpt-5.6-terra-fast` / `gpt-5.6-luna-fast`) are the low-latency **Fast** model tier (OpenAI `priority` service tier) with the same effort range — e.g. `--model openai/gpt-5.6-sol-fast --variant xhigh`. `gpt-5.6-sol` is the flagship default; confirm live slugs via `opencode models openai`. |\n\nDefault skill behavior: pass `--variant high` for cross-AI dispatches. Operators may override via the prompt template's variant field.\n\n### Model-specific operational caveats\n\n- **Kimi K2.7 Code (`kimi-for-coding/k2p7`) over-exploration (observed 2026-06-17):** on broad / large-repo scopes at `--variant high`, k2p7 over-explores (many sequential reads) and can exceed a 600s timeout WITHOUT emitting — opencode flushes only the final assistant message to stdout, so a killed run yields 0 bytes (looks like a hang, but it was working). Mitigate with a hard read-cap in the prompt (\"read ≤N files then emit\") + a 1200s+ timeout, or omit `--variant`.\n- **GLM-5.2 (`zai-coding-plan/glm-5.2`) latency variance (benchmark 008, n=45):** thinking-on drives latency variance 6–161s (avg ~26s) — budget generous timeouts; expect ~1/45 transient dispatch failures (retry the cell). Empirical prompt framework: COSTAR (benchmark 008).\n- **GLM-5.2 vision (image input):** `glm-5.2` is natively multimodal (vision-to-code), but `opencode run --file <image>` does NOT deliver images to this provider — upstream #20802 for custom OpenAI-compatible providers (confirmed 2026-06-28: `--file` → `NO_IMAGE_RECEIVED`). For image input use the direct Z.AI Coding Plan multimodal API (base64 `image_url` at `https://api.z.ai/api/coding/paas/v4/chat/completions`) — a deviation from this skill's dispatch path justified only by the verified #20802 breakage; see `../../sk-prompt/prompt-models/references/models/glm-5.2.md` §7.\n\n---\n\n## 6. AGENT FLAG\n\n`--agent <slug>` loads an agent definition from `.opencode/agents/<slug>.md` (project-local) or the user-level fallback. The agent definition's frontmatter pins the model, tool permissions, and system prompt that shape the dispatch.\n\n### Discovering agents\n\n| Command | What it shows |\n|---------|---------------|\n| `opencode agent list` | All registered agent slugs across project + user scopes |\n| `opencode debug agent <slug>` | Resolved frontmatter and system prompt for a slug |\n| `opencode debug skill <slug>` | Skill resolution for a slug if the agent loads one |\n\n### Agent slugs in this repo\n\n| Slug | Role |\n|------|------|\n| `general` | Implementation, default subagent |\n| `context` | Read-only retrieval and search |\n| `orchestrate` | Multi-agent coordination |\n| `write` | Documentation generation |\n| `review` | Code review and PR analysis |\n| `debug` | Fresh-perspective debugging |\n| `deep-research` | Iterative research loop executor |\n| `deep-review` | Iterative code review loop executor |\n| `ai-council` | Multi-strategy planning |\n| `deep-improvement` | Agent improvement proposal mutator |\n\nThe cli-opencode skill defers to the calling AI on agent selection — see `references/agent_delegation.md` for the routing matrix and `assets/prompt_templates.md` for canonical invocation shapes.\n\n---\n\n## 7. OUTPUT FORMAT AND EVENT STREAM\n\n`--format default` produces a human-formatted log. `--format json` emits a newline-delimited JSON event stream.\n\n### JSON event shape (v1.3.17)\n\nEach line is a JSON object with at minimum:\n\n| Field | Meaning |\n|-------|---------|\n| `type` | Event type (`session.started`, `message.delta`, `tool.call`, `tool.result`, `session.completed`, ...) |\n| `timestamp` | ISO 8601 UTC timestamp |\n| `session_id` | The session id assigned by OpenCode |\n| `payload` | Type-specific payload |\n\nExternal runtimes parse the stream incrementally to surface tool calls, partial messages, and the final summary. cli-opencode prompt templates always pass `--format json` so the calling AI parses structured events instead of guessing format boundaries.\n\n---\n\n## 8. STATE LOCATION AND SHARE URLS\n\n### State directory\n\nOpenCode persists session state in a shared SQLite database and storage tree under `~/.local/share/opencode/`:\n\n- `opencode.db` (`-shm`/`-wal` companions) — the session/message database\n- `storage/` — per-session structured artifacts\n- `snapshot/` — working-tree snapshots\n\nThere is no per-session directory under `~/.opencode/state/<session_id>/` on a standard install — that path does not exist on this runtime layout. To inspect a specific session, use `opencode export <session_id>` (§3) rather than reading files from a state directory. The cli-opencode self-invocation guard's Layer 3 lock-file probe (`~/.opencode/state/<id>/lock`, per ADR-001) targets the older path as a best-effort third layer on top of the env-var and process-ancestry checks; treat it as a heuristic, not a verified-present artifact, on installs where `~/.opencode/state/` does not exist.\n\n### Share URLs\n\n`--share` publishes a session URL via OpenCode's share infrastructure. The skill ONLY appends `--share` for use case 2 (in-OpenCode parallel detached sessions). The CHK-033 P1 checklist item requires operator confirmation before publishing a share URL because the URL exposes the session contents.\n\n---\n\n## 9. VERSION DRIFT\n\nThis reference is pinned to OpenCode v1.3.17. If the live binary reports a different version, do the following:\n\n1. Run `opencode run --help` and diff the flag list against Section 4.\n2. Run `opencode --help` and diff the subcommand list against Section 3.\n3. If a flag was renamed, prefer the new name in the dispatch. If a flag was removed, fall back to the closest analogue and surface the drift in the calling AI's response.\n4. If the operator's machine has a major version bump (v1.4+, v2.x), re-validate the entire skill against the new flag table and bump the cli-opencode minor version.\n\n### Failure modes specific to drift\n\n| Symptom | Likely cause |\n|---------|--------------|\n| `unknown option --variant` | v1.2 or earlier — variant flag was named `--reasoning` |\n| `unknown option --share` | Older standalone build without share infrastructure |\n| `unknown option --format json` | v1.0 — JSON event stream was the default and the flag did not exist |\n| `MODULE_NOT_FOUND` | Plugin loader crash; rerun with `--pure` to bypass plugins |\n\n---\n\n## 10. TROUBLESHOOTING\n\n| Symptom | Cause | Fix |\n|---------|-------|-----|\n| `command not found: opencode` | Binary not on PATH | Install via standalone installer or `brew install opencode` |\n| `OPENCODE_SERVER_PASSWORD required` | Server enforces basic auth | Pass `-p <password>` or set the env var |\n| `provider/model not found` | Provider not configured | Run `opencode providers` to enumerate, then `auth login <provider>` |\n| Empty output stream | `--format default` with non-TTY parent | Pass `--format json` and parse the event stream |\n| Session never finishes | Tool call hung | Run `opencode export <session_id>` and inspect the message log it returns |\n| Plugin load crash | Misconfigured plugin | Rerun with `--pure` to bypass all plugins |\n| Self-invocation refused | cli-opencode detected an in-OpenCode runtime | Use a sibling cli-* skill or a fresh shell session — see ADR-001 |\n| `--share` URL leaks | Share infrastructure published a session containing secrets | Operator MUST confirm before publishing per CHK-033 |\n\n---\n\n## 11. RELATED RESOURCES\n\n- `./integration_patterns.md` - The three documented use cases and their copy-paste invocation shapes\n- `./agent_delegation.md` - Agent routing matrix and invocation patterns\n- `./opencode_tools.md` - Unique capabilities (full plugin/skill/MCP runtime, parallel detached sessions)\n- `../assets/prompt_templates.md` - Copy-paste prompt templates per use case\n- `../assets/prompt_quality_card.md` - Framework selection and CLEAR 5-check\n- `../SKILL.md` - Skill entry point and smart router","lineStart":1,"lineEnd":418,"totalLines":418,"truncated":false}},"title":"../../.opencode/skills/cli-external-orchestration/cli-opencode/references/cli_reference.md","time":{"start":1784313692286,"end":1784313692289}},"metadata":{"openai":{"itemId":"fc_0ef6d54251161905016a5a775c1b148191a2ff243713e69597"}},"id":"prt_f71624076001QMSmXN4c46mlor","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161d316001tR0EXYHa3Q88Ji"}}
{"type":"tool_use","timestamp":1784313692375,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_XaGD88PyfYqzSxBDC1J1taEG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/references/self_invocation_guard.md","limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/references/self_invocation_guard.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"OpenCode CLI - Self-Invocation Guard (ADR-001)\"\n3: description: \"Full three-layer self-invocation detection contract (env var, process ancestry, state lock-file) behind ADR-001 in both bash and python pseudocode form, relocated out of SKILL.md so the entry point carries only a short pointer.\"\n4: trigger_phrases:\n5:   - \"opencode self-invocation guard\"\n6:   - \"opencode adr-001 detection\"\n7:   - \"opencode layered self-dispatch check\"\n8:   - \"opencode circular dispatch refusal\"\n9: importance_tier: important\n10: contextType: implementation\n11: version: 1.0.0.0\n12: ---\n13: \n14: # OpenCode CLI - Self-Invocation Guard (ADR-001)\n15: \n16: Layered detection contract for refusing a circular cli-opencode dispatch when the calling agent is already running inside OpenCode, in both bash and python pseudocode form.\n17: \n18: ---\n19: \n20: ## 1. OVERVIEW\n21: \n22: ### Purpose\n23: \n24: Document the full three-layer self-invocation detection contract behind ADR-001 — env-var lookup, process-ancestry probe, and state lock-file probe — so `SKILL.md` §2 (SMART ROUTING) can carry a short summary and pointer instead of the full code.\n25: \n26: ### When to Use\n27: \n28: Read this when implementing, auditing, or debugging the self-invocation guard referenced from `SKILL.md` §2 and from `integration_patterns.md` §5 (decision tree + exact refusal message).\n29: \n30: ### Core Principle\n31: \n32: A running cli-opencode skill never dispatches itself. The guard trips on ANY positive detection layer unless the prompt carries explicit parallel-session keywords (use case 2 — parallel detached session), in which case the router permits a SEPARATE session id and state directory instead of a self-dispatch.\n33: \n34: ---\n35: \n36: ## 2. BASH DETECTION (LAYERS 1-3)\n37: \n38: ```bash\n39: # Verify OpenCode CLI is available\n40: command -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n41: \n42: # SELF-INVOCATION GUARD (ADR-001 layered detection)\n43: # Layer 1: env var lookup — any OPENCODE_* variable\n44: env | grep -q '^OPENCODE_' && echo \"ERROR: OPENCODE_* env detected — already inside OpenCode.\"\n45: # Layer 2: process ancestry — opencode in parent tree\n46: ps -o command= -p \"$PPID\" | grep -q opencode && echo \"ERROR: opencode parent process detected.\"\n47: # Layer 3: state lock-file probe\n48: ls ~/.opencode/state/*/lock 2>/dev/null | head -1 | grep -q lock && echo \"ERROR: live OpenCode session lock detected.\"\n49: ```\n50: \n51: ---\n52: \n53: ## 3. PYTHON PSEUDOCODE\n54: \n55: ```python\n56: def detect_self_invocation():\n57:     \"\"\"Returns a non-None signal when the orchestrator is already running inside OpenCode.\"\"\"\n58:     # Layer 1: env var lookup — OpenCode sets OPENCODE_CONFIG_DIR and OPENCODE_* vars\n59:     for key in os.environ:\n60:         if key == 'OPENCODE_CONFIG_DIR' or key.startswith('OPENCODE_'):\n61:             return ('env', key)\n62:     # Layer 2: process ancestry — opencode in parent tree\n63:     try:\n64:         ancestry = subprocess.check_output(['ps', '-o', 'command=', '-p', str(os.getppid())]).decode()\n65:         if '/opencode' in ancestry or 'opencode ' in ancestry:\n66:             return ('ancestry', 'opencode')\n67:     except subprocess.SubprocessError:\n68:         pass\n69:     # Layer 3: state lock-file probe\n70:     state_dir = os.path.expanduser('~/.opencode/state')\n71:     if os.path.isdir(state_dir):\n72:         for entry in os.listdir(state_dir):\n73:             if os.path.exists(os.path.join(state_dir, entry, 'lock')):\n74:                 return ('lockfile', entry)\n75:     return None\n76: \n77: if detect_self_invocation():\n78:     # Single legitimate exception: explicit \"parallel detached\" keywords (use case 2)\n79:     # spawn a SEPARATE session id and state directory, not a self-dispatch.\n80:     if not has_parallel_session_keywords(prompt):\n81:         refuse(\n82:             \"Self-invocation refused: this agent is already running inside OpenCode. \"\n83:             \"Use a sibling cli-* skill or a fresh shell session in a different runtime to dispatch a different model. \"\n84:             \"For a parallel detached session, restate with explicit parallel-session keywords.\"\n85:         )\n86: ```\n87: \n88: ---\n89: \n90: ## 4. REFUSAL BEHAVIOR\n91: \n92: When `detect_self_invocation()` returns a signal and the prompt lacks explicit parallel-session keywords, the skill refuses to load and returns the documented error message instead of generating any `opencode` invocation. See [`integration_patterns.md`](./integration_patterns.md) §5 for the full decision tree and the exact refusal text surfaced to the operator, and [`destructive_scope_violations.md`](./destructive_scope_violations.md) for the incident class this guard-plus-worktree-isolation combination protects against.\n93: \n94: ---\n95: \n96: ## 5. RELATED RESOURCES\n97: \n98: - [`integration_patterns.md`](./integration_patterns.md) - Decision tree and exact refusal message text\n99: - [`destructive_scope_violations.md`](./destructive_scope_violations.md) - RM-8 incident this guard protects against\n100: - [`agent_delegation.md`](./agent_delegation.md) - Agent routing this guard gates before dispatch\n101: - [`../SKILL.md`](../SKILL.md) - Section 2 SMART ROUTING pointer and Section 4 ALWAYS rule 2\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"---\ntitle: \"OpenCode CLI - Self-Invocation Guard (ADR-001)\"\ndescription: \"Full three-layer self-invocation detection contract (env var, process ancestry, state lock-file) behind ADR-001 in both bash and python pseudocode form, relocated out of SKILL.md so the entry point carries only a short pointer.\"\ntrigger_phrases:\n  - \"opencode self-invocation guard\"\n  - \"opencode adr-001 detection\"\n  - \"opencode layered self-dispatch check\"\n  - \"opencode circular dispatch refusal\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.0.0.0\n---\n\n# OpenCode CLI - Self-Invocation Guard (ADR-001)\n\nLayered detection contract for refusing a circular cli-opencode dispatch when the calling agent is already running inside OpenCode, in both bash and python pseudocode form.\n\n---\n\n## 1. OVERVIEW","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/references/self_invocation_guard.md","text":"---\ntitle: \"OpenCode CLI - Self-Invocation Guard (ADR-001)\"\ndescription: \"Full three-layer self-invocation detection contract (env var, process ancestry, state lock-file) behind ADR-001 in both bash and python pseudocode form, relocated out of SKILL.md so the entry point carries only a short pointer.\"\ntrigger_phrases:\n  - \"opencode self-invocation guard\"\n  - \"opencode adr-001 detection\"\n  - \"opencode layered self-dispatch check\"\n  - \"opencode circular dispatch refusal\"\nimportance_tier: important\ncontextType: implementation\nversion: 1.0.0.0\n---\n\n# OpenCode CLI - Self-Invocation Guard (ADR-001)\n\nLayered detection contract for refusing a circular cli-opencode dispatch when the calling agent is already running inside OpenCode, in both bash and python pseudocode form.\n\n---\n\n## 1. OVERVIEW\n\n### Purpose\n\nDocument the full three-layer self-invocation detection contract behind ADR-001 — env-var lookup, process-ancestry probe, and state lock-file probe — so `SKILL.md` §2 (SMART ROUTING) can carry a short summary and pointer instead of the full code.\n\n### When to Use\n\nRead this when implementing, auditing, or debugging the self-invocation guard referenced from `SKILL.md` §2 and from `integration_patterns.md` §5 (decision tree + exact refusal message).\n\n### Core Principle\n\nA running cli-opencode skill never dispatches itself. The guard trips on ANY positive detection layer unless the prompt carries explicit parallel-session keywords (use case 2 — parallel detached session), in which case the router permits a SEPARATE session id and state directory instead of a self-dispatch.\n\n---\n\n## 2. BASH DETECTION (LAYERS 1-3)\n\n```bash\n# Verify OpenCode CLI is available\ncommand -v opencode || echo \"Not installed. Run: brew install opencode (macOS) or curl -fsSL https://opencode.ai/install | bash\"\n\n# SELF-INVOCATION GUARD (ADR-001 layered detection)\n# Layer 1: env var lookup — any OPENCODE_* variable\nenv | grep -q '^OPENCODE_' && echo \"ERROR: OPENCODE_* env detected — already inside OpenCode.\"\n# Layer 2: process ancestry — opencode in parent tree\nps -o command= -p \"$PPID\" | grep -q opencode && echo \"ERROR: opencode parent process detected.\"\n# Layer 3: state lock-file probe\nls ~/.opencode/state/*/lock 2>/dev/null | head -1 | grep -q lock && echo \"ERROR: live OpenCode session lock detected.\"\n```\n\n---\n\n## 3. PYTHON PSEUDOCODE\n\n```python\ndef detect_self_invocation():\n    \"\"\"Returns a non-None signal when the orchestrator is already running inside OpenCode.\"\"\"\n    # Layer 1: env var lookup — OpenCode sets OPENCODE_CONFIG_DIR and OPENCODE_* vars\n    for key in os.environ:\n        if key == 'OPENCODE_CONFIG_DIR' or key.startswith('OPENCODE_'):\n            return ('env', key)\n    # Layer 2: process ancestry — opencode in parent tree\n    try:\n        ancestry = subprocess.check_output(['ps', '-o', 'command=', '-p', str(os.getppid())]).decode()\n        if '/opencode' in ancestry or 'opencode ' in ancestry:\n            return ('ancestry', 'opencode')\n    except subprocess.SubprocessError:\n        pass\n    # Layer 3: state lock-file probe\n    state_dir = os.path.expanduser('~/.opencode/state')\n    if os.path.isdir(state_dir):\n        for entry in os.listdir(state_dir):\n            if os.path.exists(os.path.join(state_dir, entry, 'lock')):\n                return ('lockfile', entry)\n    return None\n\nif detect_self_invocation():\n    # Single legitimate exception: explicit \"parallel detached\" keywords (use case 2)\n    # spawn a SEPARATE session id and state directory, not a self-dispatch.\n    if not has_parallel_session_keywords(prompt):\n        refuse(\n            \"Self-invocation refused: this agent is already running inside OpenCode. \"\n            \"Use a sibling cli-* skill or a fresh shell session in a different runtime to dispatch a different model. \"\n            \"For a parallel detached session, restate with explicit parallel-session keywords.\"\n        )\n```\n\n---\n\n## 4. REFUSAL BEHAVIOR\n\nWhen `detect_self_invocation()` returns a signal and the prompt lacks explicit parallel-session keywords, the skill refuses to load and returns the documented error message instead of generating any `opencode` invocation. See [`integration_patterns.md`](./integration_patterns.md) §5 for the full decision tree and the exact refusal text surfaced to the operator, and [`destructive_scope_violations.md`](./destructive_scope_violations.md) for the incident class this guard-plus-worktree-isolation combination protects against.\n\n---\n\n## 5. RELATED RESOURCES\n\n- [`integration_patterns.md`](./integration_patterns.md) - Decision tree and exact refusal message text\n- [`destructive_scope_violations.md`](./destructive_scope_violations.md) - RM-8 incident this guard protects against\n- [`agent_delegation.md`](./agent_delegation.md) - Agent routing this guard gates before dispatch\n- [`../SKILL.md`](../SKILL.md) - Section 2 SMART ROUTING pointer and Section 4 ALWAYS rule 2","lineStart":1,"lineEnd":101,"totalLines":101,"truncated":false}},"title":".opencode/skills/cli-external-orchestration/cli-opencode/references/self_invocation_guard.md","time":{"start":1784313692370,"end":1784313692374}},"metadata":{"openai":{"itemId":"fc_0ef6d54251161905016a5a775c1b1c81919a9e95862fce9434"}},"id":"prt_f71624083001kTSXRrcECMDg8u","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161d316001tR0EXYHa3Q88Ji"}}
{"type":"tool_use","timestamp":1784313692380,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_7zZku0SjOMQ0fOHmzKM1Rv8o","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt_quality_card.md","limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt_quality_card.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: OpenCode CLI — Prompt Quality Card\n3: description: Fast-path prompt discipline for OpenCode CLI dispatches; frameworks and CLEAR are canonical in sk-prompt.\n4: trigger_phrases:\n5:   - \"opencode prompt quality card\"\n6:   - \"opencode model overrides\"\n7:   - \"minimax tidd-ec dense pre-plan\"\n8:   - \"mimo costar lean prompt\"\n9:   - \"opencode dispatch framework precedence\"\n10: importance_tier: normal\n11: contextType: planning\n12: version: 1.3.0.21\n13: ---\n14: \n15: # OpenCode CLI — Prompt Quality Card\n16: \n17: Fast-path dispatch discipline for `opencode run` prompts. The 7-framework table, task-to-framework map, pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are owned by the canonical card — do not inline them here.\n18: \n19: ## 1. OVERVIEW\n20: \n21: ### Purpose\n22: \n23: This card is the OpenCode CLI fast-path prompt-quality reference; it delegates the framework table + CLEAR check to the canonical card and records only OpenCode-specific model overrides plus the precedence rule.\n24: \n25: ### Usage\n26: \n27: Compose a dispatch prompt by starting from the shared layer (canonical card), applying the OpenCode model overrides, and following the precedence rule.\n28: \n29: ---\n30: \n31: ## 2. SHARED LAYER (DELEGATED — DO NOT INLINE)\n32: \n33: The 7-framework selection table, the task->framework map, the pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are OWNED by the canonical card. Do NOT copy them here.\n34: \n35: -> `../../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md`  (deep theory: `../../../sk-prompt/prompt-improve/references/patterns_evaluation.md`)\n36: \n37: ---\n38: \n39: ## 3. OPENCODE MODEL OVERRIDES\n40: \n41: OpenCode dispatches the MiniMax, MiMo, DeepSeek-v4-pro, and Kimi-K2.7 small models, which override or default against the cross-model defaults from the canonical card:\n42: \n43: | Model (dispatchable here) | Override | Profile |\n44: |---|---|---|\n45: | MiniMax M3 (Token Plan default) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n46: | MiniMax M3 (Direct API) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n47: | MiMo V2.5 Pro (Token Plan) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n48: | MiMo V2.5 Pro (Direct API) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n49: | MiMo V2.5 Pro UltraSpeed (Direct API, low-latency) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n50: | GLM-5.2 (Z.AI GLM Coding Plan) | COSTAR + lean (empirical, benchmark 008) | [`glm-5.2.md`](../../../sk-prompt/prompt-models/references/models/glm-5.2.md) |\n51: | deepseek-v4-pro / kimi-k2.7-code | default RCAF (no model-specific benchmark; shared default-unverified note) | [`deepseek-v4-pro.md`](../../../sk-prompt/prompt-models/references/models/deepseek-v4-pro.md) · [`kimi-k2.7-code.md`](../../../sk-prompt/prompt-models/references/models/kimi-k2.7-code.md) |\n52: \n53: **Executor notes:** Omit `--agent` for all small-model dispatches listed above. OpenCode maps `--variant low/medium/high` to MiMo's reasoning effort; `high` is the standing default for MiMo. MiniMax Token Plan (`minimax-coding-plan/MiniMax-M3`) and Direct API (`minimax/MiniMax-M3`) both serve M3. Xiaomi Token Plan (`xiaomi-token-plan-ams/mimo-v2.5-pro`) and Direct API (`xiaomi/mimo-v2.5-pro`) both serve MiMo-V2.5-Pro; the Direct API additionally serves `xiaomi/mimo-v2.5-pro-ultraspeed`, a low-latency tier with the same prompt contract. Ambiguous use-case (1 vs 2 vs 3) prevents the router from picking a path — resolve before dispatch. Always include a self-invocation guard signal when the dispatched session could loop back.\n54: \n55: ---\n56: \n57: ## 4. DELEGATION / PRECEDENCE\n58: \n59: The 3-tier precedence rule (fast path -> model override -> deep path) is canonical in `../../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` and restated in `../SKILL.md`.\n60: \n61: OpenCode-specific escalation example: if the task would otherwise need a long `opencode run` prompt plus an explicit Memory Epilogue and a parallel-session decision, ask `@prompt-improver` for the final `ENHANCED_PROMPT` first, then pass that result to OpenCode.\n62: \n63: ---\n64: \n65: ## 5. RELATED RESOURCES\n66: \n67: -> `../../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` · `./prompt_templates.md` · `../SKILL.md` · `../../../sk-prompt/prompt-models/references/models/` (per-model profiles)\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"---\ntitle: OpenCode CLI — Prompt Quality Card\ndescription: Fast-path prompt discipline for OpenCode CLI dispatches; frameworks and CLEAR are canonical in sk-prompt.\ntrigger_phrases:\n  - \"opencode prompt quality card\"\n  - \"opencode model overrides\"\n  - \"minimax tidd-ec dense pre-plan\"\n  - \"mimo costar lean prompt\"\n  - \"opencode dispatch framework precedence\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.3.0.21\n---\n\n# OpenCode CLI — Prompt Quality Card\n\nFast-path dispatch discipline for `opencode run` prompts. The 7-framework table, task-to-framework map, pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are owned by the canonical card — do not inline them here.\n\n## 1. OVERVIEW\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt_quality_card.md","text":"---\ntitle: OpenCode CLI — Prompt Quality Card\ndescription: Fast-path prompt discipline for OpenCode CLI dispatches; frameworks and CLEAR are canonical in sk-prompt.\ntrigger_phrases:\n  - \"opencode prompt quality card\"\n  - \"opencode model overrides\"\n  - \"minimax tidd-ec dense pre-plan\"\n  - \"mimo costar lean prompt\"\n  - \"opencode dispatch framework precedence\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.3.0.21\n---\n\n# OpenCode CLI — Prompt Quality Card\n\nFast-path dispatch discipline for `opencode run` prompts. The 7-framework table, task-to-framework map, pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are owned by the canonical card — do not inline them here.\n\n## 1. OVERVIEW\n\n### Purpose\n\nThis card is the OpenCode CLI fast-path prompt-quality reference; it delegates the framework table + CLEAR check to the canonical card and records only OpenCode-specific model overrides plus the precedence rule.\n\n### Usage\n\nCompose a dispatch prompt by starting from the shared layer (canonical card), applying the OpenCode model overrides, and following the precedence rule.\n\n---\n\n## 2. SHARED LAYER (DELEGATED — DO NOT INLINE)\n\nThe 7-framework selection table, the task->framework map, the pre-planning-density / bundle-gate / anti-hallucination notes, and the CLEAR 5-question check are OWNED by the canonical card. Do NOT copy them here.\n\n-> `../../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md`  (deep theory: `../../../sk-prompt/prompt-improve/references/patterns_evaluation.md`)\n\n---\n\n## 3. OPENCODE MODEL OVERRIDES\n\nOpenCode dispatches the MiniMax, MiMo, DeepSeek-v4-pro, and Kimi-K2.7 small models, which override or default against the cross-model defaults from the canonical card:\n\n| Model (dispatchable here) | Override | Profile |\n|---|---|---|\n| MiniMax M3 (Token Plan default) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n| MiniMax M3 (Direct API) | TIDD-EC + dense | `../../../sk-prompt/prompt-models/references/models/minimax-m3.md` |\n| MiMo V2.5 Pro (Token Plan) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n| MiMo V2.5 Pro (Direct API) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n| MiMo V2.5 Pro UltraSpeed (Direct API, low-latency) | COSTAR + lean, `--variant high` | `../../../sk-prompt/prompt-models/references/models/mimo-v2.5-pro.md` |\n| GLM-5.2 (Z.AI GLM Coding Plan) | COSTAR + lean (empirical, benchmark 008) | [`glm-5.2.md`](../../../sk-prompt/prompt-models/references/models/glm-5.2.md) |\n| deepseek-v4-pro / kimi-k2.7-code | default RCAF (no model-specific benchmark; shared default-unverified note) | [`deepseek-v4-pro.md`](../../../sk-prompt/prompt-models/references/models/deepseek-v4-pro.md) · [`kimi-k2.7-code.md`](../../../sk-prompt/prompt-models/references/models/kimi-k2.7-code.md) |\n\n**Executor notes:** Omit `--agent` for all small-model dispatches listed above. OpenCode maps `--variant low/medium/high` to MiMo's reasoning effort; `high` is the standing default for MiMo. MiniMax Token Plan (`minimax-coding-plan/MiniMax-M3`) and Direct API (`minimax/MiniMax-M3`) both serve M3. Xiaomi Token Plan (`xiaomi-token-plan-ams/mimo-v2.5-pro`) and Direct API (`xiaomi/mimo-v2.5-pro`) both serve MiMo-V2.5-Pro; the Direct API additionally serves `xiaomi/mimo-v2.5-pro-ultraspeed`, a low-latency tier with the same prompt contract. Ambiguous use-case (1 vs 2 vs 3) prevents the router from picking a path — resolve before dispatch. Always include a self-invocation guard signal when the dispatched session could loop back.\n\n---\n\n## 4. DELEGATION / PRECEDENCE\n\nThe 3-tier precedence rule (fast path -> model override -> deep path) is canonical in `../../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` and restated in `../SKILL.md`.\n\nOpenCode-specific escalation example: if the task would otherwise need a long `opencode run` prompt plus an explicit Memory Epilogue and a parallel-session decision, ask `@prompt-improver` for the final `ENHANCED_PROMPT` first, then pass that result to OpenCode.\n\n---\n\n## 5. RELATED RESOURCES\n\n-> `../../../sk-prompt/prompt-models/assets/cli_prompt_quality_card.md` · `./prompt_templates.md` · `../SKILL.md` · `../../../sk-prompt/prompt-models/references/models/` (per-model profiles)","lineStart":1,"lineEnd":67,"totalLines":67,"truncated":false}},"title":".opencode/skills/cli-external-orchestration/cli-opencode/assets/prompt_quality_card.md","time":{"start":1784313692376,"end":1784313692379}},"metadata":{"openai":{"itemId":"fc_0ef6d54251161905016a5a775c1b2881918aa471e3ba02ed34"}},"id":"prt_f716240d3001c87qj4qmQb4qVX","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161d316001tR0EXYHa3Q88Ji"}}
{"type":"tool_use","timestamp":1784313692394,"sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","part":{"type":"tool","tool":"read","callID":"call_Q7QNnxU4OpAD04AVuPO1i1t1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":1200,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1200: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1201:   if (!event || typeof event.label !== 'string') return event;\n1202:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1203: \n1204:   const accounting = accountingByLabel.get(event.label);\n1205:   if (!accounting) return event;\n1206:   return {\n1207:     ...event,\n1208:     skippedCount: accounting.skippedCount,\n1209:     slotDurationMs: accounting.slotDurationMs,\n1210:   };\n1211: }\n1212: \n1213: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1214:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1215:     return () => {};\n1216:   }\n1217:   const startedAtMs = Date.now();\n1218:   const timer = setInterval(() => {\n1219:     appendFanoutStatusLedger(ledgerPath, {\n1220:       event: 'progress',\n1221:       label,\n1222:       at: new Date().toISOString(),\n1223:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1224:         gauges: getGauges(),\n1225:       });\n1226:       if (typeof onProgress === 'function') onProgress();\n1227:     }, cadenceMs);\n1228:   timer.unref?.();\n1229:   return () => clearInterval(timer);\n1230: }\n1231: \n1232: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1233:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1234:     return () => {};\n1235:   }\n1236: \n1237:   let timer = null;\n1238:   let fired = false;\n1239:   const schedule = () => {\n1240:     if (fired) return;\n1241:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1242:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1243:     timer = setTimeout(() => {\n1244:       timer = null;\n1245:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1246:       if (latestQuietMs >= thresholdMs) {\n1247:         fired = true;\n1248:         appendFanoutStatusLedger(ledgerPath, {\n1249:           event: 'stall_detected',\n1250:           label,\n1251:           at: new Date().toISOString(),\n1252:           severity: 'warning',\n1253:           metric: 'time_since_last_lineage_event',\n1254:           stall_watchdog_ms: thresholdMs,\n1255:           quiet_ms: Math.floor(latestQuietMs),\n1256:           gauges: getGauges(),\n1257:         });\n1258:         return;\n1259:       }\n1260:       schedule();\n1261:     }, delayMs);\n1262:     timer.unref?.();\n1263:   };\n1264: \n1265:   schedule();\n1266:   return () => {\n1267:     fired = true;\n1268:     if (timer) clearTimeout(timer);\n1269:   };\n1270: }\n1271: \n1272: /**\n1273:  * Run a lineage subprocess without blocking the Node event loop.\n1274:  *\n1275:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1276:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1277:  * thread until each child exited, serializing every lineage regardless of the\n1278:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1279:  *\n1280:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1281:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1282:  *\n1283:  * @param {string} command - Executable to run.\n1284:  * @param {string[]} cmdArgs - Arguments for the executable.\n1285:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1286:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1287:  */\n1288: function runLineageProcess(command, cmdArgs, opts) {\n1289:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1290:   const hasInput = typeof opts.input === 'string';\n1291: \n1292:   return new Promise((resolvePromise) => {\n1293:     let child;\n1294:     try {\n1295:       child = spawn(command, cmdArgs, {\n1296:         cwd,\n1297:         env,\n1298:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1299:         detached: process.platform !== 'win32',\n1300:       });\n1301:     } catch (error) {\n1302:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1303:       return;\n1304:     }\n1305:     activeLineageProcesses.add(child);\n1306:     if (typeof opts.onSpawn === 'function') {\n1307:       opts.onSpawn({ pid: child.pid });\n1308:     }\n1309: \n1310:     let stdout = '';\n1311:     let stdoutBytes = 0;\n1312:     let truncated = false;\n1313:     let timedOut = false;\n1314:     let settled = false;\n1315:     let spawnError;\n1316: \n1317:     const timer = setTimeout(() => {\n1318:       timedOut = true;\n1319:       terminateLineageProcess(child, 'SIGTERM');\n1320:     }, timeoutMs);\n1321:     timer.unref?.();\n1322: \n1323:     const abortHandler = () => {\n1324:       terminateLineageProcess(child, 'SIGTERM');\n1325:     };\n1326:     if (opts.abortSignal) {\n1327:       if (opts.abortSignal.aborted) {\n1328:         abortHandler();\n1329:       } else {\n1330:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1331:       }\n1332:     }\n1333: \n1334:     child.stdout?.setEncoding('utf8');\n1335:     child.stdout?.on('data', (chunk) => {\n1336:       if (typeof opts.onOutput === 'function') opts.onOutput();\n1337:       if (truncated) return;\n1338:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1339:       if (stdoutBytes > maxBuffer) {\n1340:         truncated = true;\n1341:         terminateLineageProcess(child, 'SIGTERM');\n1342:         return;\n1343:       }\n1344:       stdout += chunk;\n1345:     });\n1346:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1347:     child.stderr?.resume();\n1348: \n1349:     child.on('error', (error) => {\n1350:       spawnError = error;\n1351:     });\n1352: \n1353:     child.on('close', (code, signal) => {\n1354:       if (settled) return;\n1355:       settled = true;\n1356:       activeLineageProcesses.delete(child);\n1357:       clearTimeout(timer);\n1358:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1359:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1360:       if (typeof opts.onExit === 'function') {\n1361:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1362:       }\n1363:       resolvePromise({\n1364:         status: timedOut ? null : code,\n1365:         signal: effectiveSignal,\n1366:         stdout,\n1367:         ...(spawnError ? { error: spawnError } : {}),\n1368:       });\n1369:     });\n1370: \n1371:     if (hasInput) {\n1372:       child.stdin?.on('error', () => {});\n1373:       child.stdin?.end(opts.input);\n1374:     }\n1375:   });\n1376: }\n1377: \n1378: /**\n1379:  * Build the subprocess command for a fan-out lineage.\n1380:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1381:  */\n1382: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1383:   const kind = lineage.kind;\n1384: \n1385:   if (kind === 'cli-codex') {\n1386:     if (!isCodexBinaryAvailable(options.env || process.env)) {\n1387:       throw inputError('cli-codex executor unavailable: command -v codex failed');\n1388:     }\n1389:     const args = [\n1390:       'exec',\n1391:       '--model',\n1392:       lineage.model || 'o4-mini',\n1393:       '-c',\n1394:       `model_reasoning_effort=${lineage.reasoningEffort || 'medium'}`,\n1395:     ];\n1396:     if (lineage.serviceTier) {\n1397:       args.push('-c', `service_tier=${lineage.serviceTier}`);\n1398:     }\n1399:     args.push('-c', 'approval_policy=never', '--sandbox', resolvedSandbox, '-');\n1400:     return { command: 'codex', args, input: prompt };\n1401:   }\n1402: \n1403:   if (kind === 'cli-claude-code') {\n1404:     const args = [\n1405:       '-p',\n1406:       prompt,\n1407:       '--model',\n1408:       lineage.model || 'claude-opus-4-8',\n1409:       '--permission-mode',\n1410:       resolvedPermission,\n1411:       '--output-format',\n1412:       'text',\n1413:     ];\n1414:     if (lineage.reasoningEffort) {\n1415:       args.push('--effort', lineage.reasoningEffort);\n1416:     }\n1417:     return { command: 'claude', args };\n1418:   }\n1419: \n1420:   if (kind === 'native') {\n1421:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1422:     // For review runs this is the real deep/review command surface with a lineage\n1423:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1424:     const args = [\n1425:       'run',\n1426:       '--format',\n1427:       'json',\n1428:       '--dangerously-skip-permissions',\n1429:       '--dir',\n1430:       process.cwd(),\n1431:       '--command',\n1432:       `deep/${options.loopType || 'review'}`,\n1433:     ];\n1434:     args.push(buildNativeCommandInput(\n1435:       options.loopType || 'review',\n1436:       options.specFolder || '',\n1437:       options.lineageDir || '',\n1438:       lineage,\n1439:       options,\n1440:     ));\n1441:     return { command: 'opencode', args, input: '' };\n1442:   }\n1443: \n1444:   if (kind === 'cli-opencode') {\n1445:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1446:     // on a top-level `run`. The default agent runs when none is named, and a\n1447:     // specific agent profile can be requested in the prompt body instead.\n1448:     const args = [\n1449:       'run',\n1450:       '--model',\n1451:       lineage.model || 'anthropic/claude-opus-4-8',\n1452:       '--format',\n1453:       'json',\n1454:       '--pure',\n1455:       '--dir',\n1456:       process.cwd(),\n1457:     ];\n1458:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1459:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1460:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1461:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1462:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n1463:     // must now opt into full bypass rather than getting it silently by default.\n1464:     const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n1465:     if (useDangerousBypass) {\n1466:       args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n1467:       process.stderr.write(\n1468:         `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n1469:           + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n1470:       );\n1471:     }\n1472:     if (lineage.reasoningEffort) {\n1473:       args.push('--variant', lineage.reasoningEffort);\n1474:     }\n1475:     args.push(prompt);\n1476:     return { command: 'opencode', args, input: '' };\n1477:   }\n1478: \n1479:   throw inputError(`Unknown fan-out executor kind: ${kind}`);\n1480: }\n1481: \n1482: function isCodexBinaryAvailable(env = process.env) {\n1483:   const result = spawnSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], {\n1484:     env,\n1485:     stdio: 'ignore',\n1486:   });\n1487:   return result.status === 0;\n1488: }\n1489: \n1490: // ─────────────────────────────────────────────────────────────────────────────\n1491: // 4. CORE LOGIC\n1492: // ─────────────────────────────────────────────────────────────────────────────\n1493: \n1494: async function main() {\n1495:   const args = parseArgs();\n1496:   const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n1497:   const loopType = ensureString(args, 'loopType');\n1498:   assertActiveFanoutLoopType(loopType);\n1499:   // Optional shared research question, threaded into each lineage prompt so a research\n1500:   // fan-out can bind research_topic. Absent for review, which scopes by folder.\n1501:   const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n1502:     ? args.researchTopic.trim()\n1503:     : null;\n1504:   const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n1505:   const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n1506:   const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n1507:   const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n1508:   assertLineageTimeoutHoursOverrideWithinCeiling(lineageTimeoutHoursOverride);\n1509:   const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n1510: \n1511:   const {\n1512:     parseFanoutConfig,\n1513:     expandLineages,\n1514:     resolveSandboxMode,\n1515:     resolveClaudePermissionMode,\n1516:   } = await import('../lib/deep-loop/executor-config.ts');\n1517:   const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n1518:   const {\n1519:     DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1520:     checkLineageTimestampWindow,\n1521:   } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n1522: \n1523:   maybeThrowTestFault();\n1524: \n1525:   let rawConfig;\n1526:   try {\n1527:     rawConfig = JSON.parse(fanoutConfigJson);\n1528:   } catch {\n1529:     throw inputError('fanoutConfigJson is not valid JSON');\n1530:   }\n1531: \n1532:   const lineagesDir = path.join(baseArtifactDir, 'lineages');\n1533:   const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n1534:   const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n1535:   const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n1536:   const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n1537:   const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n1538:   const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n1539:   const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n1540:   const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n1541:   const fanoutConfig = guardedAssignment.config;\n1542:   const allLineages = expandLineages(fanoutConfig);\n1543: \n1544:   // Aggregate budget is a SEPARATE ceiling from the per-lineage cap enforced inside the\n1545:   // worker below — both must pass, neither replaces the other. Checked upfront (before any\n1546:   // lineage spawns) because it is fully computable from static config, so failing fast here\n1547:   // avoids burning real subprocess time on a run that was already over budget at submission.\n1548:   const aggregateBudgetDecision = evaluateAggregateBudgetCap({\n1549:     lineages: allLineages,\n1550:     guards: rawGuardConfig,\n1551:     maxRetries: fanoutConfig.maxRetries,\n1552:   });\n1553:   if (!aggregateBudgetDecision.continue_allowed) {\n1554:     appendFanoutStatusLedger(ledgerPath, {\n1555:       event: 'aggregate_budget_cap_exceeded',\n1556:       at: new Date().toISOString(),\n1557:       run_id: runId,\n1558:       loop_type: loopType,\n1559:       spec_folder: specFolder,\n1560:       severity: 'error',\n1561:       stop_reasons: aggregateBudgetDecision.stop_reasons,\n1562:       upper_bound: aggregateBudgetDecision.upper_bound,\n1563:     });\n1564:     throw inputError(\n1565:       `fan-out aggregate budget exceeded: ${aggregateBudgetDecision.upper_bound.estimated_cost_units} > `\n1566:         + `${aggregateBudgetDecision.upper_bound.max_aggregate_cost_units} cost units across `\n1567:         + `${aggregateBudgetDecision.upper_bound.lineage_count} lineage(s)`,\n1568:     );\n1569:   }\n1570: \n1571:   const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n1572:   const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n1573:   const slotIntervalMs = progressHeartbeatMs;\n1574: \n1575:   logFlatPoolGuardRejections({\n1576:     rejections: guardedAssignment.rejections,\n1577:     ledgerPath,\n1578:     runId,\n1579:     loopType,\n1580:     specFolder,\n1581:   });\n1582: \n1583:   // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n1584:   // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n1585:   // ownership here so all lineages share the same retries and artifact validation.\n1586:   const cliLineages = allLineages;\n1587:   const checkpointPath = waitCheckpointPath(baseArtifactDir);\n1588:   const resumeWaiting = await resumeWaitingCheckpoint({\n1589:     checkpointPath,\n1590:     ledgerPath,\n1591:     runId,\n1592:     loopType,\n1593:     specFolder,\n1594:   });\n1595:   if (!resumeWaiting.didWait) {\n1596:     await persistPreDispatchWait({\n1597:       checkpointPath,\n1598:       ledgerPath,\n1599:       runId,\n1600:       loopType,\n1601:       specFolder,\n1602:       waitMs: args.preDispatchWaitMs,\n1603:     });\n1604:   }\n1605: \n1606:   if (cliLineages.length === 0) {\n1607:     const summary = {\n1608:       total: 0,\n1609:       succeeded: 0,\n1610:       failed: 0,\n1611:       all_failed: false,\n1612:       gauges: { lag: 0, pending: 0, failed: 0 },\n1613:       convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n1614:     };\n1615:     writeOrchestrationSummary(summaryPath, {\n1616:       run_id: runId,\n1617:       loop_type: loopType,\n1618:       spec_folder: specFolder,\n1619:       base_artifact_dir: baseArtifactDir,\n1620:       total_cli_lineages: 0,\n1621:       ...summary,\n1622:     });\n1623:     jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n1624:     return;\n1625:   }\n1626: \n1627:   fs.mkdirSync(lineagesDir, { recursive: true });\n1628:   const orphanedLineages = markOrphanedLineages(ledgerPath);\n1629:   const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n1630: \n1631:   const lineageSnapshots = new Map();\n1632:   const lineageSlotAccounting = new Map();\n1633:   const lineageProcessLiveness = new Map();\n1634:   let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n1635:   let stoppedSummaryWritten = false;\n1636: \n1637:   const writeStoppedSummary = (signal) => {\n1638:     if (stoppedSummaryWritten) return;\n1639:     stoppedSummaryWritten = true;\n1640:     stopActiveLineageProcesses(signal);\n1641:     const stoppedAtIso = new Date().toISOString();\n1642:     const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n1643:     const gauges = {\n1644:       lag: latestGauges.lag,\n1645:       pending: latestGauges.pending,\n1646:       failed: Math.max(latestGauges.failed, partial.summary.failed),\n1647:     };\n1648:     appendFanoutStatusLedger(ledgerPath, {\n1649:       event: 'stopped',\n1650:       signal,\n1651:       at: stoppedAtIso,\n1652:       gauges,\n1653:     });\n1654:     writeOrchestrationSummary(summaryPath, {\n1655:       run_id: runId,\n1656:       loop_type: loopType,\n1657:       spec_folder: specFolder,\n1658:       base_artifact_dir: baseArtifactDir,\n1659:       total_cli_lineages: cliLineages.length,\n1660:       stopped: true,\n1661:       stopped_signal: signal,\n1662:       stopped_at_iso: stoppedAtIso,\n1663:       status: 'partial',\n1664:       ...partial.summary,\n1665:       gauges,\n1666:       results: partial.results,\n1667:     });\n1668:   };\n1669: \n1670:   installFanoutSignalHandlers(writeStoppedSummary);\n1671: \n1672:   const { results, summary } = await runCappedPool({\n1673:     items: cliLineages,\n1674:     concurrency: fanoutConfig.concurrency,\n1675:     maxRetries: fanoutConfig.maxRetries,\n1676:     lagCeilingMs: fanoutConfig.lagCeilingMs,\n1677:     postExitGraceMs,\n1678:     initialRetryCounts,\n1679:     getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n1680:     onEvent: (event) => {\n1681:       const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n1682:       updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n1683:       if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n1684:       appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n1685:     },\n1686:     worker: async (lineage, context) => {\n1687:       const slotWindowStartIso = new Date().toISOString();\n1688:       const hrStart = process.hrtime();\n1689:       const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n1690:       const livenessKey = `${lineage.label}:${attempt}`;\n1691:       const lineageDir = path.join(lineagesDir, lineage.label);\n1692:       const stateDir = path.join(lineageDir, '.executor-state');\n1693:       fs.mkdirSync(lineageDir, { recursive: true });\n1694:       fs.mkdirSync(stateDir, { recursive: true });\n1695: \n1696:       const budgetDecision = evaluateLineageBudgetCap({\n1697:         lineage,\n1698:         guards: lineageBudgetGuards,\n1699:         maxRetries: fanoutConfig.maxRetries,\n1700:       });\n1701:       if (!budgetDecision.continue_allowed) {\n1702:         appendFanoutStatusLedger(ledgerPath, {\n1703:           event: 'budget_cap_exceeded',\n1704:           label: lineage.label,\n1705:           at: new Date().toISOString(),\n1706:           severity: 'error',\n1707:           stop_reasons: budgetDecision.stop_reasons,\n1708:           upper_bound: budgetDecision.upper_bound,\n1709:           gauges: latestGauges,\n1710:         });\n1711:         const failure = new Error(\n1712:           `lineage ${lineage.label} exceeds configured budget cap: `\n1713:             + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n1714:         );\n1715:         failure.label = lineage.label;\n1716:         failure.exitCode = null;\n1717:         failure.timedOut = false;\n1718:         failure.budgetCap = budgetDecision;\n1719:         throw failure;\n1720:       }\n1721: \n1722:       const sessionId = `fanout-${lineage.label}-${runId}`;\n1723:       const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n1724:         convergenceThreshold,\n1725:         stopPolicy,\n1726:       });\n1727: \n1728:       // Sandbox resolution stays write-capable by default even for review lineages:\n1729:       // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n1730:       // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n1731:       // blanket read-only default would break those writes. The lineageDir-only write boundary\n1732:       // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n1733:       // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n1734:       // exposed one. Callers can still pass an explicit sandboxMode to override.\n1735:       const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n1736:       const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n1737: \n1738:       const effectiveSandbox = resolvedSandbox;\n1739:       const effectivePermission = resolvedPermission;\n1740: \n1741:       const { command, args: cmdArgs, input } = buildLineageCommand(\n1742:         lineage,\n1743:         prompt,\n1744:         effectiveSandbox,\n1745:         effectivePermission,\n1746:         {\n1747:           loopType,\n1748:           specFolder,\n1749:           lineageDir,\n1750:           sessionId,\n1751:           convergenceThreshold,\n1752:           stopPolicy,\n1753:           researchTopic,\n1754:         },\n1755:       );\n1756: \n1757:       // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n1758:       // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n1759:       // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n1760:       // native lockfile. Real same-kind-replica isolation comes from each lineage's\n1761:       // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n1762:       // is deliberately avoided here because relocating the home breaks credential/auth\n1763:       // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n1764:       const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n1765:       const extraEnv = {\n1766:         SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n1767:         ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n1768:         ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n1769:           ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n1770:           : {}),\n1771:       };\n1772: \n1773:       // Recursion guard (fail closed): the executor stack can already name the hosting\n1774:       // runtime before the first detached fan-out spawn. The lineage marker is added only\n1775:       // to a spawned seat, so both signals are required to prove that a seat is trying to\n1776:       // fan out its own executor kind again.\n1777:       const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n1778:       const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n1779:         && inheritedLineageId.trim() !== '';\n1780:       if (\n1781:         isInsideFanoutLineage\n1782:         && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n1783:       ) {\n1784:         throw new Error(\n1785:           `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n1786:         );\n1787:       }\n1788: \n1789:       // Stamp the dispatch stack with this lineage's executor kind so a seat that\n1790:       // tries to recursively launch the same kind is detectable by the runtime\n1791:       // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n1792:       // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n1793:       // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n1794:       // preserve the per-replica lockfile isolation they provide.\n1795:       const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n1796: \n1797:       const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n1798:       let lastLineageEventAtMs = Date.now();\n1799:       const markLineageEvent = () => {\n1800:         lastLineageEventAtMs = Date.now();\n1801:       };\n1802:       const stopStallWatchdog = startLineageStallWatchdog({\n1803:         thresholdMs: stallWatchdogMs,\n1804:         label: lineage.label,\n1805:         ledgerPath,\n1806:         getLastEventAtMs: () => lastLineageEventAtMs,\n1807:         getGauges: () => latestGauges,\n1808:       });\n1809: \n1810:       const stopProgressHeartbeat = startLineageProgressHeartbeat({\n1811:         cadenceMs: progressHeartbeatMs,\n1812:         label: lineage.label,\n1813:         ledgerPath,\n1814:         getGauges: () => latestGauges,\n1815:       });\n1816:       let result;\n1817:       try {\n1818:         result = await runLineageProcess(command, cmdArgs, {\n1819:           cwd: process.cwd(),\n1820:           timeoutMs,\n1821:           env: dispatchEnv,\n1822:           maxBuffer: 20 * 1024 * 1024,\n1823:           abortSignal: context.signal,\n1824:           onOutput: markLineageEvent,\n1825:           onSpawn: ({ pid }) => {\n1826:             lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n1827:           },\n1828:           onExit: ({ pid, exitedAtMs }) => {\n1829:             lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n1830:           },\n1831:           ...(typeof input === 'string' ? { input } : {}),\n1832:         });\n1833:       } finally {\n1834:         stopProgressHeartbeat();\n1835:         stopStallWatchdog();\n1836:       }\n1837: \n1838:       // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n1839:       const logsDir = path.join(lineageDir, 'logs');\n1840:       fs.mkdirSync(logsDir, { recursive: true });\n1841:       const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n1842:       fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n1843: \n1844:       // Recover missing iteration files from captured stdout when possible. Runs\n1845:       // BEFORE the failure throw below so iteration recovery is never lost.\n1846:       const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n1847:       const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n1848:       lineageSlotAccounting.set(lineage.label, slotAccounting);\n1849: \n1850:       const exitCode = result.status ?? (result.error ? 1 : 0);\n1851:       const timedOut = result.signal === 'SIGTERM';\n1852:       // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n1853:       // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n1854:       // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n1855:       const killedBySignal = result.signal != null;\n1856:       const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n1857:       const stateRead = readLineageStateRecords(loopType, lineageDir);\n1858:       const stopPolicyViolation = findMaxIterationsPolicyViolation({\n1859:         loopType,\n1860:         stateRead,\n1861:         lineage,\n1862:         stopPolicy,\n1863:       });\n1864: \n1865:       // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n1866:       // not a success. Throw so the pool settles this item as rejected and counts it\n1867:       // in summary.failed/all_failed, which drives the process exit code. Returning a\n1868:       // plain object here would let the pool record any completed worker as fulfilled\n1869:       // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n1870:       if (timedOut || killedBySignal || exitCode !== 0) {\n1871:         const reason = timedOut\n1872:           ? 'timed out'\n1873:           : killedBySignal\n1874:             ? `killed by signal ${result.signal}`\n1875:             : `exited with code ${exitCode}`;\n1876:         const failure = new Error(`lineage ${lineage.label} ${reason}`);\n1877:         failure.label = lineage.label;\n1878:         failure.exitCode = exitCode;\n1879:         failure.timedOut = timedOut;\n1880:         failure.killedBySignal = killedBySignal;\n1881:         failure.salvage = salvage;\n1882:         throw failure;\n1883:       }\n1884: \n1885:       if (missingArtifacts.length > 0) {\n1886:         const failure = new Error(\n1887:           `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n1888:         );\n1889:         failure.label = lineage.label;\n1890:         failure.exitCode = exitCode;\n1891:         failure.timedOut = false;\n1892:         failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n1893:         failure.missingArtifacts = missingArtifacts;\n1894:         throw failure;\n1895:       }\n1896: \n1897:       if (stopPolicyViolation) {\n1898:         const failure = new Error(\n1899:           `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,\n\n(Showing lines 1200-1899 of 2021. Use offset=1900 to continue.)\n</content>","metadata":{"preview":"function decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"function decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (typeof opts.onOutput === 'function') opts.onOutput();\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-codex') {\n    if (!isCodexBinaryAvailable(options.env || process.env)) {\n      throw inputError('cli-codex executor unavailable: command -v codex failed');\n    }\n    const args = [\n      'exec',\n      '--model',\n      lineage.model || 'o4-mini',\n      '-c',\n      `model_reasoning_effort=${lineage.reasoningEffort || 'medium'}`,\n    ];\n    if (lineage.serviceTier) {\n      args.push('-c', `service_tier=${lineage.serviceTier}`);\n    }\n    args.push('-c', 'approval_policy=never', '--sandbox', resolvedSandbox, '-');\n    return { command: 'codex', args, input: prompt };\n  }\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n    // --dangerously-skip-permissions so their writes are subject to the CLI permission\n    // boundary. opencode has no path-scoped write flag, so a workspace-write review\n    // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n    // must now opt into full bypass rather than getting it silently by default.\n    const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n    if (useDangerousBypass) {\n      args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n      process.stderr.write(\n        `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n          + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n      );\n    }\n    if (lineage.reasoningEffort) {\n      args.push('--variant', lineage.reasoningEffort);\n    }\n    args.push(prompt);\n    return { command: 'opencode', args, input: '' };\n  }\n\n  throw inputError(`Unknown fan-out executor kind: ${kind}`);\n}\n\nfunction isCodexBinaryAvailable(env = process.env) {\n  const result = spawnSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], {\n    env,\n    stdio: 'ignore',\n  });\n  return result.status === 0;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const args = parseArgs();\n  const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n  const loopType = ensureString(args, 'loopType');\n  assertActiveFanoutLoopType(loopType);\n  // Optional shared research question, threaded into each lineage prompt so a research\n  // fan-out can bind research_topic. Absent for review, which scopes by folder.\n  const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n    ? args.researchTopic.trim()\n    : null;\n  const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n  const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n  const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n  const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n  assertLineageTimeoutHoursOverrideWithinCeiling(lineageTimeoutHoursOverride);\n  const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n\n  const {\n    parseFanoutConfig,\n    expandLineages,\n    resolveSandboxMode,\n    resolveClaudePermissionMode,\n  } = await import('../lib/deep-loop/executor-config.ts');\n  const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n  const {\n    DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n    checkLineageTimestampWindow,\n  } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n\n  maybeThrowTestFault();\n\n  let rawConfig;\n  try {\n    rawConfig = JSON.parse(fanoutConfigJson);\n  } catch {\n    throw inputError('fanoutConfigJson is not valid JSON');\n  }\n\n  const lineagesDir = path.join(baseArtifactDir, 'lineages');\n  const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n  const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n  const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n  const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n  const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n  const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n  const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n  const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n  const fanoutConfig = guardedAssignment.config;\n  const allLineages = expandLineages(fanoutConfig);\n\n  // Aggregate budget is a SEPARATE ceiling from the per-lineage cap enforced inside the\n  // worker below — both must pass, neither replaces the other. Checked upfront (before any\n  // lineage spawns) because it is fully computable from static config, so failing fast here\n  // avoids burning real subprocess time on a run that was already over budget at submission.\n  const aggregateBudgetDecision = evaluateAggregateBudgetCap({\n    lineages: allLineages,\n    guards: rawGuardConfig,\n    maxRetries: fanoutConfig.maxRetries,\n  });\n  if (!aggregateBudgetDecision.continue_allowed) {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'aggregate_budget_cap_exceeded',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      severity: 'error',\n      stop_reasons: aggregateBudgetDecision.stop_reasons,\n      upper_bound: aggregateBudgetDecision.upper_bound,\n    });\n    throw inputError(\n      `fan-out aggregate budget exceeded: ${aggregateBudgetDecision.upper_bound.estimated_cost_units} > `\n        + `${aggregateBudgetDecision.upper_bound.max_aggregate_cost_units} cost units across `\n        + `${aggregateBudgetDecision.upper_bound.lineage_count} lineage(s)`,\n    );\n  }\n\n  const progressHeartbeatMs = normalizeProgressHeartbeatMs(fanoutConfig.progressHeartbeatSeconds);\n  const postExitGraceMs = normalizePostExitGraceMs(rawGuardConfig, progressHeartbeatMs);\n  const slotIntervalMs = progressHeartbeatMs;\n\n  logFlatPoolGuardRejections({\n    rejections: guardedAssignment.rejections,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n\n  // Fan-out pool owns every lineage kind. The old YAML-native branch dispatched the\n  // LEAF review agent with a full-loop prompt, which is invalid; keep full-loop\n  // ownership here so all lineages share the same retries and artifact validation.\n  const cliLineages = allLineages;\n  const checkpointPath = waitCheckpointPath(baseArtifactDir);\n  const resumeWaiting = await resumeWaitingCheckpoint({\n    checkpointPath,\n    ledgerPath,\n    runId,\n    loopType,\n    specFolder,\n  });\n  if (!resumeWaiting.didWait) {\n    await persistPreDispatchWait({\n      checkpointPath,\n      ledgerPath,\n      runId,\n      loopType,\n      specFolder,\n      waitMs: args.preDispatchWaitMs,\n    });\n  }\n\n  if (cliLineages.length === 0) {\n    const summary = {\n      total: 0,\n      succeeded: 0,\n      failed: 0,\n      all_failed: false,\n      gauges: { lag: 0, pending: 0, failed: 0 },\n      convergence: { status: 'converged', reason: 'empty_tick', no_new_findings: true },\n    };\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: 0,\n      ...summary,\n    });\n    jsonOut({ status: 'ok', message: 'no CLI lineages to spawn', run_id: runId, results: [], summary });\n    return;\n  }\n\n  fs.mkdirSync(lineagesDir, { recursive: true });\n  const orphanedLineages = markOrphanedLineages(ledgerPath);\n  const initialRetryCounts = readRetryCountsFromLedger(ledgerPath);\n\n  const lineageSnapshots = new Map();\n  const lineageSlotAccounting = new Map();\n  const lineageProcessLiveness = new Map();\n  let latestGauges = { lag: cliLineages.length, pending: cliLineages.length, failed: 0 };\n  let stoppedSummaryWritten = false;\n\n  const writeStoppedSummary = (signal) => {\n    if (stoppedSummaryWritten) return;\n    stoppedSummaryWritten = true;\n    stopActiveLineageProcesses(signal);\n    const stoppedAtIso = new Date().toISOString();\n    const partial = summarizeSnapshots(cliLineages, lineageSnapshots);\n    const gauges = {\n      lag: latestGauges.lag,\n      pending: latestGauges.pending,\n      failed: Math.max(latestGauges.failed, partial.summary.failed),\n    };\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'stopped',\n      signal,\n      at: stoppedAtIso,\n      gauges,\n    });\n    writeOrchestrationSummary(summaryPath, {\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      base_artifact_dir: baseArtifactDir,\n      total_cli_lineages: cliLineages.length,\n      stopped: true,\n      stopped_signal: signal,\n      stopped_at_iso: stoppedAtIso,\n      status: 'partial',\n      ...partial.summary,\n      gauges,\n      results: partial.results,\n    });\n  };\n\n  installFanoutSignalHandlers(writeStoppedSummary);\n\n  const { results, summary } = await runCappedPool({\n    items: cliLineages,\n    concurrency: fanoutConfig.concurrency,\n    maxRetries: fanoutConfig.maxRetries,\n    lagCeilingMs: fanoutConfig.lagCeilingMs,\n    postExitGraceMs,\n    initialRetryCounts,\n    getAttemptLiveness: (attempt) => lineageProcessLiveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n    onEvent: (event) => {\n      const enrichedEvent = decorateSlotAccountingEvent(event, lineageSlotAccounting);\n      updateLineageSnapshot(lineageSnapshots, enrichedEvent);\n      if (enrichedEvent.gauges) latestGauges = enrichedEvent.gauges;\n      appendFanoutStatusLedger(ledgerPath, enrichedEvent);\n    },\n    worker: async (lineage, context) => {\n      const slotWindowStartIso = new Date().toISOString();\n      const hrStart = process.hrtime();\n      const attempt = Number.isFinite(Number(context.attempt)) ? Number(context.attempt) : 1;\n      const livenessKey = `${lineage.label}:${attempt}`;\n      const lineageDir = path.join(lineagesDir, lineage.label);\n      const stateDir = path.join(lineageDir, '.executor-state');\n      fs.mkdirSync(lineageDir, { recursive: true });\n      fs.mkdirSync(stateDir, { recursive: true });\n\n      const budgetDecision = evaluateLineageBudgetCap({\n        lineage,\n        guards: lineageBudgetGuards,\n        maxRetries: fanoutConfig.maxRetries,\n      });\n      if (!budgetDecision.continue_allowed) {\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'budget_cap_exceeded',\n          label: lineage.label,\n          at: new Date().toISOString(),\n          severity: 'error',\n          stop_reasons: budgetDecision.stop_reasons,\n          upper_bound: budgetDecision.upper_bound,\n          gauges: latestGauges,\n        });\n        const failure = new Error(\n          `lineage ${lineage.label} exceeds configured budget cap: `\n            + `${budgetDecision.upper_bound.estimated_cost_units} > ${budgetDecision.upper_bound.max_cost_units_per_lineage} cost units`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = null;\n        failure.timedOut = false;\n        failure.budgetCap = budgetDecision;\n        throw failure;\n      }\n\n      const sessionId = `fanout-${lineage.label}-${runId}`;\n      const prompt = buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, {\n        convergenceThreshold,\n        stopPolicy,\n      });\n\n      // Sandbox resolution stays write-capable by default even for review lineages:\n      // the review subprocess writes its own iteration artifacts (iterations/iteration-NNN.md,\n      // deep-review-state.jsonl, review-report.md, resource-map.md) INTO lineageDir, so a\n      // blanket read-only default would break those writes. The lineageDir-only write boundary\n      // is enforced by the prompt ('Do not touch any path outside lineageDir') rather than by a\n      // narrower sandbox; a path-scoped workspace-write would be the stronger fix if the CLIs\n      // exposed one. Callers can still pass an explicit sandboxMode to override.\n      const resolvedSandbox = resolveSandboxMode(lineage.sandboxMode);\n      const resolvedPermission = resolveClaudePermissionMode(lineage.sandboxMode);\n\n      const effectiveSandbox = resolvedSandbox;\n      const effectivePermission = resolvedPermission;\n\n      const { command, args: cmdArgs, input } = buildLineageCommand(\n        lineage,\n        prompt,\n        effectiveSandbox,\n        effectivePermission,\n        {\n          loopType,\n          specFolder,\n          lineageDir,\n          sessionId,\n          convergenceThreshold,\n          stopPolicy,\n          researchTopic,\n        },\n      );\n\n      // Advertise a per-replica state dir hint to the child via SPECKIT_<KIND>_STATE_DIR.\n      // This is DETECTION-ONLY: the native CLIs read their own home env (OPENCODE_HOME /\n      // OPENCODE_HOME / CLAUDE_CODE_HOME), not this var, so it does NOT relocate the\n      // native lockfile. Real same-kind-replica isolation comes from each lineage's\n      // unique artifact dir (lineage.label); remapping the CLI home to isolate the lock\n      // is deliberately avoided here because relocating the home breaks credential/auth\n      // lookup (the \"Not logged in\" failure the dispatch-env allowlist guards against).\n      const stateEnvKey = SPECKIT_STATE_ENV_BY_KIND[lineage.kind];\n      const extraEnv = {\n        SPECKIT_FANOUT_LINEAGE_ID: lineage.label,\n        ...(stateEnvKey ? { [stateEnvKey]: stateDir } : {}),\n        ...(lineage.kind === 'cli-claude-code' && lineage.configDir\n          ? { CLAUDE_CONFIG_DIR: validateClaudeConfigDir(lineage.configDir) }\n          : {}),\n      };\n\n      // Recursion guard (fail closed): the executor stack can already name the hosting\n      // runtime before the first detached fan-out spawn. The lineage marker is added only\n      // to a spawned seat, so both signals are required to prove that a seat is trying to\n      // fan out its own executor kind again.\n      const inheritedLineageId = process.env.SPECKIT_FANOUT_LINEAGE_ID;\n      const isInsideFanoutLineage = typeof inheritedLineageId === 'string'\n        && inheritedLineageId.trim() !== '';\n      if (\n        isInsideFanoutLineage\n        && detectSameKindFromStack(process.env[CLI_DISPATCH_STACK_ENV], lineage.kind)\n      ) {\n        throw new Error(\n          `recursive ${lineage.kind} dispatch blocked for lineage ${lineage.label}: ${lineage.kind} already on ${CLI_DISPATCH_STACK_ENV}`,\n        );\n      }\n\n      // Stamp the dispatch stack with this lineage's executor kind so a seat that\n      // tries to recursively launch the same kind is detectable by the runtime\n      // recursion guard (detectSameKindFromStack reads SPECKIT_CLI_DISPATCH_STACK).\n      // buildExecutorDispatchEnv filters the parent env to the per-kind allowlist,\n      // so the SPECKIT_* lineage/state-dir keys are applied AFTER the filter to\n      // preserve the per-replica lockfile isolation they provide.\n      const dispatchEnv = { ...buildExecutorDispatchEnv(lineage, process.env), ...extraEnv };\n\n      const timeoutMs = computeLineageTimeoutMs(lineage, lineageTimeoutHoursOverride);\n      let lastLineageEventAtMs = Date.now();\n      const markLineageEvent = () => {\n        lastLineageEventAtMs = Date.now();\n      };\n      const stopStallWatchdog = startLineageStallWatchdog({\n        thresholdMs: stallWatchdogMs,\n        label: lineage.label,\n        ledgerPath,\n        getLastEventAtMs: () => lastLineageEventAtMs,\n        getGauges: () => latestGauges,\n      });\n\n      const stopProgressHeartbeat = startLineageProgressHeartbeat({\n        cadenceMs: progressHeartbeatMs,\n        label: lineage.label,\n        ledgerPath,\n        getGauges: () => latestGauges,\n      });\n      let result;\n      try {\n        result = await runLineageProcess(command, cmdArgs, {\n          cwd: process.cwd(),\n          timeoutMs,\n          env: dispatchEnv,\n          maxBuffer: 20 * 1024 * 1024,\n          abortSignal: context.signal,\n          onOutput: markLineageEvent,\n          onSpawn: ({ pid }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: true, pid });\n          },\n          onExit: ({ pid, exitedAtMs }) => {\n            lineageProcessLiveness.set(livenessKey, { alive: false, pid, exitedAtMs });\n          },\n          ...(typeof input === 'string' ? { input } : {}),\n        });\n      } finally {\n        stopProgressHeartbeat();\n        stopStallWatchdog();\n      }\n\n      // Save subprocess stdout for salvage sweep (write failures in weak CLI executors).\n      const logsDir = path.join(lineageDir, 'logs');\n      fs.mkdirSync(logsDir, { recursive: true });\n      const savedStdout = typeof result.stdout === 'string' ? result.stdout : '';\n      fs.writeFileSync(path.join(logsDir, 'fanout-lineage.out'), savedStdout, 'utf8');\n\n      // Recover missing iteration files from captured stdout when possible. Runs\n      // BEFORE the failure throw below so iteration recovery is never lost.\n      const salvage = runSalvageSweep(lineageDir, loopType, savedStdout);\n      const slotAccounting = buildSlotAccounting(hrStart, slotIntervalMs);\n      lineageSlotAccounting.set(lineage.label, slotAccounting);\n\n      const exitCode = result.status ?? (result.error ? 1 : 0);\n      const timedOut = result.signal === 'SIGTERM';\n      // Any signal-kill is abnormal, not just the orchestrator's own SIGTERM timeout — a\n      // stall-watchdog / lag-ceiling abort or an external SIGKILL leaves result.status null,\n      // so exitCode computes to 0 and the lineage would otherwise be masked as success.\n      const killedBySignal = result.signal != null;\n      const missingArtifacts = findMissingLineageArtifacts(loopType, lineageDir);\n      const stateRead = readLineageStateRecords(loopType, lineageDir);\n      const stopPolicyViolation = findMaxIterationsPolicyViolation({\n        loopType,\n        stateRead,\n        lineage,\n        stopPolicy,\n      });\n\n      // A lineage whose CLI exits non-zero or is killed by the timeout is a FAILURE,\n      // not a success. Throw so the pool settles this item as rejected and counts it\n      // in summary.failed/all_failed, which drives the process exit code. Returning a\n      // plain object here would let the pool record any completed worker as fulfilled\n      // regardless of the underlying CLI exit, masking failed/timed-out lineages.\n      if (timedOut || killedBySignal || exitCode !== 0) {\n        const reason = timedOut\n          ? 'timed out'\n          : killedBySignal\n            ? `killed by signal ${result.signal}`\n            : `exited with code ${exitCode}`;\n        const failure = new Error(`lineage ${lineage.label} ${reason}`);\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = timedOut;\n        failure.killedBySignal = killedBySignal;\n        failure.salvage = salvage;\n        throw failure;\n      }\n\n      if (missingArtifacts.length > 0) {\n        const failure = new Error(\n          `lineage ${lineage.label} exited 0 but did not produce expected artifact: ${missingArtifacts.join(', ')}`,\n        );\n        failure.label = lineage.label;\n        failure.exitCode = exitCode;\n        failure.timedOut = false;\n        failure.salvage = { salvaged: salvage.salvaged, failed: Math.max(1, salvage.failed) };\n        failure.missingArtifacts = missingArtifacts;\n        throw failure;\n      }\n\n      if (stopPolicyViolation) {\n        const failure = new Error(\n          `lineage ${lineage.label} violated max-iterations stop policy: ${stopPolicyViolation}`,","lineStart":1200,"lineEnd":1899,"totalLines":2021,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784313692389,"end":1784313692393}},"metadata":{"openai":{"itemId":"fc_0ef6d54251161905016a5a775c1b308191afa04de21c766213"}},"id":"prt_f716240e00011sktsZ0Vts8mvq","sessionID":"ses_08ea082c8ffeulTMP4nVP9BJov","messageID":"msg_f7161d316001tR0EXYHa3Q88Ji"}}
