   149	
   150	export function passingRecommendations(
   151	  recommendations: readonly AdvisorRecommendation[],
   152	  thresholdConfig: AdvisorThresholds | undefined,
   153	): AdvisorRecommendation[] {
   154	  const resolvedThresholds = resolveAdvisorThresholdConfig(thresholdConfig);
   155	  return recommendations.filter((recommendation) => {
   156	    if (recommendation.passes_threshold === true) {
   157	      return true;
   158	    }
   159	    if (resolvedThresholds.confidenceOnly) {
   160	      return recommendation.confidence >= resolvedThresholds.confidenceThreshold;
   161	    }
   162	    return recommendation.confidence >= resolvedThresholds.confidenceThreshold
   163	      && recommendation.uncertainty <= resolvedThresholds.uncertaintyThreshold;
   164	  });
   165	}
   166	
   167	function renderSharedBrief(
   168	  recommendations: readonly AdvisorRecommendation[],
   169	  freshness: AdvisorHookFreshness,
   170	  tokenCap: number,
   171	  thresholdConfig: AdvisorThresholds | undefined,
   172	): string | null {
   173	  const renderableResult: AdvisorBriefRenderableResult = {
   174	    status: 'ok',
   175	    freshness,
   176	    recommendations,
   177	    metrics: { tokenCap },
   178	    sharedPayload: null,
   179	  };
   180	  return renderAdvisorBrief(renderableResult, {
   181	    tokenCap,
   182	    thresholdConfig,
   183	  });
   184	}
   185	
   186	export function buildAdvisorHookResultFromRecommendations(args: {
   187	  readonly startedAt?: number;
   188	  readonly freshnessResult: AdvisorFreshnessResult;
   189	  readonly recommendations: readonly AdvisorRecommendation[];
   190	  readonly thresholdConfig?: AdvisorThresholds;
   191	  readonly maxTokens?: number;
   192	  readonly diagnostics?: AdvisorHookDiagnostics | null;
   193	  readonly metrics?: Partial<AdvisorHookMetrics>;
   194	}): AdvisorHookResult {
   195	  const freshness = args.freshnessResult.state;
   196	  if (freshness !== 'live' && freshness !== 'stale') {
   197	    return result({
   198	      startedAt: args.startedAt ?? performance.now(),
   199	      status: freshness === 'absent' ? 'skipped' : 'degraded',
   200	      freshness,
   201	      brief: null,
   202	      diagnostics: args.diagnostics ?? null,
   203	      metrics: args.metrics,
   204	      freshnessResult: args.freshnessResult,
   205	    });
   206	  }
   207	
