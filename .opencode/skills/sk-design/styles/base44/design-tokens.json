  "font": {
    "wixmadefortext": {
      "$value": "WixMadeforText",
      "$type": "fontFamily",
      "$description": "Primary UI sans — body text, buttons, nav, inputs, badges, all chrome. The geometric forms and slightly expanded tracking on small sizes (0.025em at 12px, 0.18em uppercase) give it a friendly, slightly humanist feel that keeps 16px body text comfortable to scan"
    },
    "wixmisoregular": {
      "$value": "WixMisoRegular",
      "$type": "fontFamily",
      "$description": "Display headline face — used at 48-56px with tight tracking (-0.02em) and very tight line-height (1.05). The single weight at 400 creates a calm, confident headline that doesn't shout — authority through spaciousness. Body sizes (20-24px) share the same character, keeping the type system coherent across scales"
    },
    "wixmisolight": {
      "$value": "WixMisoLight",
      "$type": "fontFamily",
      "$description": "Secondary display — lighter weight version for subheadings (25px) and lead body text (17px), creating tonal contrast against the Regular headlines. Same family guarantees harmony while the weight difference adds hierarchy without size jumps"
    }
  },
