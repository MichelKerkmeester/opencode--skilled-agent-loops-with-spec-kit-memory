#!/usr/bin/env python3
"""Grader calibration protocol.

  calibrate.py <result-file.txt> [more...] --graders modelA,modelB [--max-disagreement 2.0]

Re-grades the same deliverables with TWO different-family graders (regrade.py per model) and
reports inter-grader agreement: per-file scores, mean absolute disagreement, and a verdict.
Run this before trusting any new grader model, and re-run when grader models change.

Verdict: PROCEED when mean abs disagreement <= --max-disagreement (default 2.0 of {{SCORE_TOTAL}},
the council's calibration threshold); RECALIBRATE otherwise. Both graders must also differ from
the proposer family (regrade.py enforces that per dispatch).
"""
import json
import os
import statistics
import subprocess
import sys
from typing import Any, Dict, List, Optional, Tuple

HERE = os.path.dirname(os.path.abspath(__file__))


def regrade_with(model: str, files: List[str]) -> Dict[str, Any]:
    """Run regrade.py with a specific grader.

    Args:
        model: The grader model identifier.
        files: Result files to re-grade.

    Returns:
        Dict mapping filename to its grade record.
    """
    r = subprocess.run(["python3", os.path.join(HERE, "regrade.py"), *files],
                       env={**os.environ, "GRADER_MODEL": model},
                       capture_output=True, text=True, stdin=subprocess.DEVNULL, timeout=3600)
    if r.returncode != 0:
        sys.exit(f"calibrate.py: regrade with '{model}' failed (rc={r.returncode}): " + (r.stdout + r.stderr).strip()[-200:])
    recs = []
    for l in r.stdout.splitlines():
        if not l.strip().startswith("{"):
            continue
        try:
            recs.append(json.loads(l))
        except Exception:
            continue
    return {rec["file"]: rec for rec in recs}


def agreement(by_model: Dict[str, Any]) -> Tuple[List[Dict[str, Any]], List[float]]:
    """Fold two models' records into per-file comparisons and summary stats.

    Args:
        by_model: Mapping of grader model name to its per-file grade records.

    Returns:
        Tuple of (per-file comparison rows, absolute differences).
    """
    models = list(by_model)
    a, b = by_model[models[0]], by_model[models[1]]
    rows, diffs = [], []
    for f in sorted(set(a) & set(b)):
        sa, sb = a[f].get("independent_meqt"), b[f].get("independent_meqt")
        row = {"file": f, models[0]: sa, models[1]: sb,
               "self": a[f].get("self_meqt"),
               "abs_diff": abs(sa - sb) if (sa is not None and sb is not None) else None}
        rows.append(row)
        if row["abs_diff"] is not None:
            diffs.append(row["abs_diff"])
    return rows, diffs


def main() -> None:
    argv = sys.argv[1:]
    if "--graders" not in argv:
        sys.exit("usage: calibrate.py <result-file.txt> [...] --graders modelA,modelB [--max-disagreement 2.0]")
    gi = argv.index("--graders")
    graders = argv[gi + 1].split(",")
    max_dis = 2.0
    if "--max-disagreement" in argv:
        mi = argv.index("--max-disagreement")
        if mi + 1 >= len(argv):
            sys.exit("calibrate.py: --max-disagreement requires a value")
        max_dis = float(argv[mi + 1])
    files = [a for a in argv[:gi] if not a.startswith("--")]
    if len(graders) != 2 or not files:
        sys.exit("calibrate.py: need exactly 2 graders and at least 1 result file")

    by_model = {g: regrade_with(g, files) for g in graders}
    rows, diffs = agreement(by_model)
    mean_dis = statistics.mean(diffs) if diffs else None
    # n=0 is a measurement gap, not a calibration verdict — never PROCEED, never blame the grader
    verdict = "UNMEASURABLE" if mean_dis is None else ("PROCEED" if mean_dis <= max_dis else "RECALIBRATE")
    report = {"graders": graders, "files": rows, "n_compared": len(diffs),
              "mean_abs_disagreement": round(mean_dis, 2) if mean_dis is not None else None,
              "max_allowed": max_dis, "verdict": verdict}
    print(json.dumps(report, ensure_ascii=False, indent=2))
    sys.exit(0 if verdict == "PROCEED" else 1)


if __name__ == "__main__":
    main()
