    92	/** Read advisor freshness state.
    93	 *
    94	 * Diagnostic-only: this function reports stale, absent, or unavailable advisor
    95	 * state and does not rebuild it. Use `advisor_rebuild` to repair stale state.
    96	 */
    97	export function readAdvisorStatus(input: AdvisorStatusInput): AdvisorStatusOutput {
    98	  const args = AdvisorStatusInputSchema.parse(input);
    99	  const workspaceRoot = resolve(args.workspaceRoot);
   100	  const dbPath = join(workspaceRoot, SKILL_GRAPH_DB);
   101	  const skillRoot = join(workspaceRoot, SKILL_ROOT);
   102	  const errors: string[] = [];
   103	
   104	  try {
   105	    const generation = readSkillGraphGeneration(workspaceRoot);
   106	    const hasSources = existsSync(skillRoot);
   107	    const hasArtifact = existsSync(dbPath);
   108	    const sourceScan = scanSkillMetadataFiles(skillRoot, args.maxMetadataFiles ?? DEFAULT_MAX_METADATA_FILES);
   109	    if (sourceScan.truncated) {
   110	      errors.push(`advisor_status metadata scan capped at ${sourceScan.count} files`);
   111	    }
   112	    const sourceChanged = generation.state === 'stale'
   113	      || (
   114	        generation.sourceSignature
   115	          ? computeAdvisorSourceSignature(workspaceRoot) !== generation.sourceSignature
   116	          : hasArtifact && hasSources && sourceScan.maxMtimeMs > fileMtimeMs(dbPath)
   117	      );
   118	    const daemonPid = parseDaemonPid();
   119	    const daemonAvailable = daemonPid === undefined ? true : hasRunningDaemon(daemonPid);
   120	    // Only flag a daemon-evidence divergence when a PID file exists but the
   121	    // process is gone. Missing PID file = daemon never started, not a
   122	    // divergence between freshness artifacts and live process evidence.
   123	    if (daemonPid !== undefined && !daemonAvailable && generation.state !== 'unavailable') {
   124	      errors.push('advisor_status found freshness artifacts, but no live daemon PID/process evidence');
   125	    }
   126	    const state = isFreshness(generation.state) ? generation.state : 'unavailable';
   127	    // F10/F18: data is stale when sources are physically newer than the
   128	    // artifact, regardless of stored sourceSignature semantics. This is the
   129	    // stronger physical-evidence signal vs. signature mismatch which can
   130	    // arise from benign workspace differences.
   131	    const sourcesNewerThanArtifact = hasArtifact && hasSources
   132	      && sourceScan.maxMtimeMs > fileMtimeMs(dbPath);
   133	    const trustState = createTrustState({
   134	      hasSources,
   135	      hasArtifact,
   136	      sourceChanged,
   137	      daemonAvailable,
   138	      generation: generation.generation,
   139	      reason: generation.reason,
   140	      lastLiveAt: state === 'live' ? generation.updatedAt : null,
   141	    });
   142	    // F10/F18: `freshness` describes data/artifact state (live/stale/absent/
   143	    // unavailable from the generation file), while `trustState.state` is the
   144	    // daemon-gated caller-trust axis. Keep them decoupled so callers reading
   145	    // `freshness` see artifact health independent of daemon availability.
   146	    // When physical evidence shows sources are newer than the DB, downgrade
   147	    // a 'live' generation to 'stale' regardless of signature noise.
   148	    const freshnessOutput: AdvisorFreshness = state === 'live' && (sourceChanged || (!generation.sourceSignature && sourcesNewerThanArtifact))
   149	      ? 'stale'
   150	      : state;
   151	    const output: AdvisorStatusOutput = {
   152	      freshness: freshnessOutput,
   153	      generation: generation.generation,
   154	      trustState,
   155	      lastGenerationBump: generation.updatedAt === new Date(0).toISOString() ? null : generation.updatedAt,
   156	      lastScanAt: generation.updatedAt === new Date(0).toISOString() ? null : generation.updatedAt,
   157	      skillCount: sourceScan.count,
   158	      laneWeights: DEFAULT_SCORER_WEIGHTS,
   159	      ...(daemonPid ? { daemonPid } : {}),
   160	      ...(errors.length > 0 ? { errors } : {}),
   161	    };
   162	    return AdvisorStatusOutputSchema.parse(output);
   163	  } catch (error: unknown) {
   164	    const message = redactDiagnosticText(errorMessage(error));
   165	    const sourceScan = scanSkillMetadataFiles(skillRoot, args.maxMetadataFiles ?? DEFAULT_MAX_METADATA_FILES);
   166	    const trustState = createTrustState({
   167	      hasSources: existsSync(skillRoot),
   168	      hasArtifact: existsSync(dbPath),
   169	      sourceChanged: false,
   170	      daemonAvailable: false,
   171	      generation: 0,
   172	      reason: 'ADVISOR_STATUS_UNAVAILABLE',
   173	    });
