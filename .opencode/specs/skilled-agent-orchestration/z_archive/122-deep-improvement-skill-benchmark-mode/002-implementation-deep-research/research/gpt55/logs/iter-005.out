   100	        const file = resolveCriteriaFile(cwdAbs, a.file);
   101	        if (file === null) { detail = 'file outside fixture cwd (rejected)'; }
   102	        else if (!fs.existsSync(file)) { detail = 'file missing'; }
   103	        else {
   104	          const text = fs.readFileSync(file, 'utf8');
   105	          const matches = text.match(new RegExp(new RegExp(a.pattern).source, 'g'));
   106	          const count = matches ? matches.length : 0;
   107	          if (typeof a.expected_count === 'number') ok = count === a.expected_count;
   108	          else if (typeof a.expected_count === 'string' && a.expected_count.startsWith('>=')) {
   109	            ok = count >= parseInt(a.expected_count.slice(2).trim(), 10);
   110	          } else ok = count >= 1;
   111	          detail = `count=${count}`;
   112	        }
   113	      } else if (a.type === 'grep_absent') {
   114	        const file = resolveCriteriaFile(cwdAbs, a.file);
   115	        if (file === null) { ok = false; detail = 'file outside fixture cwd (rejected)'; }
   116	        else if (!fs.existsSync(file)) { ok = true; detail = 'file missing (treated as absent)'; }
   117	        else {
   118	          ok = !new RegExp(a.pattern).test(fs.readFileSync(file, 'utf8'));
   119	          detail = ok ? 'absent' : 'present';
   120	        }
   121	      } else if (a.type === 'deterministic') {
   122	        // F-P1-3 (122 review): `a.command` is profile/fixture-supplied data that flows
   123	        // into a shell via execSync. Benchmark profiles are trusted-author content today,
   124	        // so this is a latent injection surface rather than an open exploit. The gate lets
   125	        // a hardened deployment refuse criteria-driven shell execution by setting
   126	        // DEEP_AGENT_ALLOW_CRITERIA_EXEC=0. Default ('1'/unset) preserves backward-compat.
   127	        if (process.env.DEEP_AGENT_ALLOW_CRITERIA_EXEC === '0') {
   128	          ok = false;
   129	          detail = 'deterministic criterion skipped: criteria exec disabled (DEEP_AGENT_ALLOW_CRITERIA_EXEC=0)';
   130	          results.push({ id: a.id, type: a.type, passed: ok, detail });
   131	          if (ok) pass++;
   132	          continue;
   133	        }
